DEBUG=True
SECRET_KEY=dev-only-not-a-real-secret-replace-me
DATABASE_URL=postgres://corpus:corpus@localhost:5432/corpus
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional. When set, the embedding pipeline + vector search use the real
# voyage-law-2 model instead of the deterministic FakeEmbeddingClient.
# Get a key at https://www.voyageai.com — the first 200M tokens are free.
# VOYAGE_API_KEY=

# Optional. Used by Phase-2 query expansion (cheap Haiku call to add legal
# terms-of-art to a query before searching). No-op fallback if unset.
# ANTHROPIC_API_KEY=

# Required in production. Server-side key for the /api/chat assistant
# (no longer BYO). The endpoint requires login and is spend-capped below.
# OPENAI_API_KEY=
# Per-user messages/day and a global hard ceiling/month for /api/chat.
# CHAT_DAILY_USER_LIMIT=50
# CHAT_MONTHLY_GLOBAL_LIMIT=20000

# --- Production only (leave unset for local dev; security is DEBUG-gated) ---
# Comma-separated https origins allowed to POST (login/CSRF). Your app domain.
# CSRF_TRUSTED_ORIGINS=https://corpus.example.com
# Managed Redis. Without it the per-user chat cap + API rate limiter use
# per-process memory and DO NOT hold across App Platform instances/deploys.
# REDIS_URL=rediss://default:pass@host:25061/0
# Override the default sslmode=require if your provider differs.
# DATABASE_SSLMODE=require
