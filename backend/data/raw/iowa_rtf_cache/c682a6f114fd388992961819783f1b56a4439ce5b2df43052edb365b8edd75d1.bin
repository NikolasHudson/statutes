\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F235E}{\*\bkmkend codeChapter_5F235E}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 235E}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{DEPENDENT ADULT ABUSE IN FACILITIES AND PROGRAMS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7235B.3}}}{{\f5\fs12\qc{, 235B.16A}}}{{\f5\fs12\qc{, 235F.1}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235E.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCaretaker\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is a staff member of a facility or program who provides care, protection, or services to a dependent adult voluntarily, by contract, through employment, or by order of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCourt\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDependent adult\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person eighteen years of age or older whose ability to perform the normal activities of daily living or to provide for the person\u8217\'3fs own care or protection is impaired, either temporarily or permanently.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDependent adult abuse\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following as a result of the willful misconduct or gross negligence or reckless acts or omissions of a caretaker, taking into account the totality of the circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physical injury to, or injury which is at a variance with the history given of the injury, or unreasonable confinement, unreasonable punishment, or assault of a dependent adult which involves a breach of skill, care, and learning ordinarily exercised by a caretaker in similar circumstances. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssault of a dependent adult\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the commission of any act which is generally intended to cause pain or injury to a dependent adult, or which is generally intended to result in physical contact which would be considered by a reasonable person to be insulting or offensive or any act which is intended to place another in fear of immediate physical contact which will be painful, injurious, insulting, or offensive, coupled with the apparent ability to execute the act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission of a sexual offense under }}}{{\f5\fs18\hyphpar0\qj{chapter 709}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 726.2}}}{{\f5\fs18\hyphpar0\qj{ with or against a dependent adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exploitation of a dependent adult. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fExploitation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a caretaker who knowingly obtains, uses, endeavors to obtain to use, or who misappropriates, a dependent adult\u8217\'3fs funds, assets, medications, or property with the intent to temporarily or permanently deprive a dependent adult of the use, benefit, or possession of the funds, assets, medication, or property for the benefit of someone other than the dependent adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Neglect of a dependent adult. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNeglect of a dependent adult\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the deprivation of the minimum food, shelter, clothing, supervision, physical or mental health care, or other care necessary to maintain a dependent adult\u8217\'3fs life or physical or mental health.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual exploitation of a dependent adult by a caretaker whether within a facility or program or at a location outside of a facility or program. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSexual exploitation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any consensual or nonconsensual sexual conduct with a dependent adult which includes but is not limited to kissing; touching of the clothed or unclothed breast, groin, buttock, anus, pubes, or genitals; or a sex act, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.17}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSexual exploitation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the transmission, display, taking of electronic images of the unclothed breast, groin, buttock, anus, pubes, or genitals of a dependent adult by a caretaker for a purpose not related to treatment or diagnosis or as part of an ongoing evaluation or investigation. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSexual exploitation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include touching which is part of a necessary examination, treatment, or care by a caretaker acting within the scope of the practice or employment of the caretaker; the exchange of a brief touch or hug between the dependent adult and a caretaker for the purpose of reassurance, comfort, or casual friendship; or touching between spouses or domestic partners in an intimate relationship.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personal degradation of a dependent adult. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal degradation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a willful act or statement by a caretaker intended to shame, degrade, humiliate, or otherwise harm the personal dignity of a dependent adult, or where the caretaker knew or reasonably should have known the act or statement would cause shame, degradation, humiliation, or harm to the personal dignity of a reasonable person. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal degradation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the taking, transmission, or display of an electronic image of a dependent adult by a caretaker, where the caretaker\u8217\'3fs actions constitute a willful act or statement intended to shame, degrade, humiliate, or otherwise harm the personal dignity of the dependent adult, or where the caretaker knew or reasonably should have known the act would cause shame, degradation, humiliation, or harm to the personal dignity of a reasonable person. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal degradation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include the taking, transmission, or display of an electronic image of a dependent adult for the purpose of reporting dependent adult abuse to law enforcement, the department, or other regulatory agency that oversees caretakers or enforces abuse or neglect provisions, or for the purpose of treatment or diagnosis or as part of an ongoing evaluation or investigation. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal degradation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also does not include the taking, transmission, or display of an electronic image by a caretaker in accordance with the facility\u8217\'3fs or program\u8217\'3fs confidentiality policy and release of information or consent policies. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDependent adult abuse\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Circumstances in which the dependent adult declines medical treatment if the dependent adult holds a belief or is an adherent of a religion whose tenets and practices call for reliance on spiritual means in place of reliance on medical treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Circumstances in which the dependent adult\u8217\'3fs caretaker, acting in accordance with the dependent adult\u8217\'3fs stated or implied consent, declines medical treatment or care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The withholding or withdrawing of health care from a dependent adult who is terminally ill in the opinion of a licensed physician, when the withholding or withdrawing of health care is done at the request of the dependent adult or at the request of the dependent adult\u8217\'3fs next of kin, attorney in fact, or guardian pursuant to the applicable procedures under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{144A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{144B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{222}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{229}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{633}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFacility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a health care facility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{{\f5\fs18\hyphpar0\qj{ or a hospital as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135B.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIntimate relationship\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a significant romantic involvement between two persons that need not include sexual involvement, but does not include a casual social relationship or association in a business or professional capacity. In determining whether persons are in an intimate relationship, the court may consider the following nonexclusive list of factors:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The duration of the relationship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The frequency of interaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the relationship has been terminated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nature of the relationship, characterized by either person\u8217\'3fs expectation of sexual or romantic involvement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means person as defined in }}}{{\f5\fs18\hyphpar0\qj{section 4.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProgram\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an elder group home as defined in }}}{{\f5\fs18\hyphpar0\qj{section 231B.1}}}{{\f5\fs18\hyphpar0\qj{, an assisted living program certified under }}}{{\f5\fs18\hyphpar0\qj{section 231C.3}}}{{\f5\fs18\hyphpar0\qj{, or an adult day services program as defined in }}}{{\f5\fs18\hyphpar0\qj{section 231D.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecklessly\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that a person acts or fails to act with respect to a material element of a public offense, when the person is aware of and consciously disregards a substantial and unjustifiable risk that the material element exists or will result from the act or omission. The risk must be of such a nature and degree that disregard of the risk constitutes a gross deviation from the standard conduct that a reasonable person would observe in the situation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSupport services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to community-based services including area agency on aging assistance, mental health services, fiscal management, home health services, housing-related services, counseling services, transportation services, adult day services, respite services, legal services, and advocacy services.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1093, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 25, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71947}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1073, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7231B.10}}}{{\f5\fs12\hyphpar0\qj{, 231C.10}}}{{\f5\fs12\hyphpar0\qj{, 231D.5}}}{{\f5\fs12\hyphpar0\qj{, 235B.2}}}{{\f5\fs12\hyphpar0\qj{, 235B.5}}}{{\f5\fs12\hyphpar0\qj{, 235B.6}}}{{\f5\fs12\hyphpar0\qj{, 235E.2}}}{{\f5\fs12\hyphpar0\qj{, 235F.1}}}{{\f5\fs12\hyphpar0\qj{, 633B.116}}}{{\f5\fs12\hyphpar0\qj{, 633B.118}}}{{\f5\fs12\hyphpar0\qj{, 726.26}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235E.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dependent adult abuse reports in facilities and programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall receive and evaluate reports of dependent adult abuse in facilities and programs. The department shall inform the department of health and human services of such evaluations and dispositions and those individuals who should be placed on the central registry for dependent adult abuse pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 235E.7}}}{{\f5\fs18\hyphpar0\qj{. If the department believes the situation involves an immediate danger to the public health, safety, or welfare requiring immediate agency action to seek emergency placement on the central registry, the department may utilize emergency adjudicative proceedings pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.18A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reports of dependent adult abuse which is the result of the acts or omissions of the dependent adult shall be collected and maintained in the files of the dependent adult as assessments only and shall not be included in the central registry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A report of dependent adult abuse that meets the definition of dependent adult abuse under }}}{{\f5\fs18\hyphpar0\qj{section 235E.1, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (a) or (d), or }}}{{\f5\fs18\hyphpar0\qj{section 235E.1, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), which the department determines is minor, isolated, and unlikely to reoccur shall be collected and maintained by the department of health and human services as an assessment only for a five-year period and shall not be included in the central registry and shall not be considered to be founded dependent adult abuse. A subsequent report of dependent adult abuse that meets the definition of dependent adult abuse under }}}{{\f5\fs18\hyphpar0\qj{section 235E.1, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (a) or (d), or }}}{{\f5\fs18\hyphpar0\qj{section 235E.1, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), that occurs within the five-year period, and that is committed by the caretaker responsible for the act or omission which was the subject of the previous report of dependent adult abuse which the department determined was minor, isolated, and unlikely to reoccur, may be considered minor, isolated, and unlikely to reoccur depending on the circumstances of the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A staff member or employee of a facility or program who, in the course of employment, examines, attends, counsels, or treats a dependent adult in a facility or program and reasonably believes the dependent adult has suffered dependent adult abuse, shall report the suspected dependent adult abuse to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a staff member or employee is required to make a report pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the staff member or employee shall immediately notify the person in charge or the person\u8217\'3fs designated agent who shall then notify the department within twenty-four hours of such notification. If the person in charge is the alleged perpetrator of dependent adult abuse, the staff member shall directly report the abuse to the department within twenty-four hours.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer or supervisor of a person who is required to or may make a report pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply a policy, work rule, or other requirement that interferes with the person making a report of dependent adult abuse or that results in the failure of another person to make the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee of a financial institution may report suspected financial exploitation of a dependent adult to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other person who believes that a dependent adult has suffered dependent adult abuse may report the suspected dependent adult abuse to the department. The department shall transfer any reports received of dependent adult abuse in the community to the department of health and human services. The department of health and human services shall transfer any reports received of dependent adult abuse in facilities or programs to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall inform the appropriate county attorney of any report of dependent adult abuse. The department may provide the county attorney, other appropriate law enforcement agencies, and appropriate licensing boards with the department\u8217\'3fs evaluation materials and findings related to a report of dependent adult abuse. The department may request information from any person believed to have knowledge of a case of dependent adult abuse. The person, including but not limited to a county attorney, a law enforcement agency, a multidisciplinary team, a social services agency in the state, or any person who is required pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ to report dependent adult abuse, whether or not the person made the specific dependent adult abuse report, shall cooperate and assist in the evaluation upon the request of the department. If the department\u8217\'3fs assessment reveals that dependent adult abuse exists which might constitute a criminal offense, a report shall be made to the appropriate law enforcement agency. County attorneys and appropriate law enforcement agencies shall also take any other lawful action necessary or advisable for the protection of the dependent adult.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, upon completion of an investigation of a report of dependent adult abuse, the department determines that the best interests of the dependent adult require court action, the department shall notify the department of health and human services of the potential need for a guardian or conservator or for admission or commitment to an appropriate institution or facility pursuant to the applicable procedures under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{222}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{229}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{633}}}{{\f5\fs18\hyphpar0\qj{, or shall pursue other remedies provided by law. The appropriate county attorney shall assist the department of health and human services in the preparation of the necessary papers to initiate the action and shall appear and represent the department of health and human services at all district court proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inspectors within the department shall be specially trained to investigate cases of dependent adult abuse including but not limited to cases involving gerontological, dementia, and wound care issues.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall assist the court during all stages of court proceedings involving a suspected case of dependent adult abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In every case involving dependent adult abuse which is substantiated by the department and which results in a judicial proceeding on behalf of the dependent adult, legal counsel shall be appointed by the court to represent the dependent adult in the proceedings. The court may also appoint a guardian ad litem to represent the dependent adult if necessary to protect the dependent adult\u8217\'3fs best interests. The same attorney shall not be appointed to serve both as legal counsel and as guardian ad litem. Before legal counsel or a guardian ad litem is appointed pursuant to this paragraph, the court shall require the dependent adult and any person legally responsible for the support of the dependent adult to complete under oath a detailed financial statement. If, on the basis of that financial statement, the court deems that the dependent adult or the legally responsible person is able to bear all or a portion of the cost of the legal counsel or guardian ad litem, the court shall so order. In cases where the dependent adult or the legally responsible person is unable to bear the cost of the legal counsel or guardian ad litem, the expense shall be paid by the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person participating in good faith in reporting or cooperating with or assisting the department in evaluating a report or investigating a case of dependent adult abuse has immunity from liability, civil or criminal, which might otherwise be incurred or imposed based upon the act of making the report or giving the assistance. The person has the same immunity with respect to participating in good faith in a judicial proceeding resulting from the report, cooperation, or assistance or relating to the subject matter of the report, cooperation, or assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any person or employer to discharge, suspend, or otherwise discipline a person required to report or voluntarily reporting an instance of suspected dependent adult abuse pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2 or 5}}}{{\f5\fs18\hyphpar0\qj{, or cooperating with, or assisting the department in evaluating a report or investigating a case of dependent adult abuse, or participating in judicial proceedings relating to the reporting or cooperation or assistance based solely upon the person\u8217\'3fs reporting or assistance relative to the instance of dependent adult abuse. A person or employer found in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to report a suspected case of dependent adult abuse pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ who knowingly and willfully fails to do so within twenty-four hours commits a simple misdemeanor. A person required by }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ to report a suspected case of dependent adult abuse who knowingly fails to do so or who knowingly interferes with the making of such a report or applies a requirement that results in such a failure is civilly liable for the damages proximately caused by the failure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules which require facilities and programs to separate an alleged perpetrator of dependent adult abuse from a victim following the report of an allegation of perpetration of dependent adult abuse and prior to the completion of an investigation of the report by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Independent of the department\u8217\'3fs investigation of the report, the facility or program employing the alleged perpetrator of dependent adult abuse shall conduct an investigation of the alleged dependent adult abuse and determine what, if any, employment action should be taken including but not limited to placing the alleged perpetrator of dependent adult abuse on administrative leave or reassigning or terminating the alleged perpetrator of dependent adult abuse as a result of the investigation by the facility or program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the facility or program terminates the alleged perpetrator of dependent adult abuse as a result of the investigation by the facility or program, the alleged perpetrator of dependent adult abuse shall disclose such termination or investigation to any prospective facility or program employer. An alleged perpetrator of dependent adult abuse who fails to disclose such termination or investigation is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving notice from a credible source, the department shall notify a facility or program that subsequently employs a perpetrator of founded dependent adult abuse when the notice of investigative findings has been issued. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An inspector of the department may enter any facility or program without a warrant and may examine all records pertaining to residents, employees, former employees, and the alleged perpetrator of dependent adult abuse.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If upon entry the inspector has knowledge of or learns during the course of an investigation of a report that alleged dependent adult abuse is suspected or is being investigated by the facility or program, the inspector shall inform the facility or program that the inspector is investigating a report of an alleged case of dependent adult abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An inspector of the department may contact or interview any resident, employee, former employee, or any other person who may have knowledge about the alleged dependent adult abuse. Prior to the interview, the department shall provide written notification to the alleged perpetrator of dependent adult abuse. The notification shall include all of the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the person is the subject of a report of dependent adult abuse being investigated by the department. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nature of the abuse being investigated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The possible civil administrative consequences of founded abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement that the department forward a report to law enforcement if the department\u8217\'3fs investigation reveals a potential criminal offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the person has the right to retain legal counsel at the person\u8217\'3fs expense and may choose to have legal counsel, union representation, or any other desired representative employed by the facility present during the interview.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the person has the right to decline to be interviewed or to terminate an interview at any time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person who is the subject of the report shall inform the department of the representatives the person wants to have present during the interview and not delay the interview by more than five working days to make arrangements for the person\u8217\'3fs representatives to be present at the interview.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any employer representative shall be informed of the requirement to maintain strict confidentiality and of the prohibition against redissemination of such information pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 235B}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During the interview, the department shall request and the alleged perpetrator of dependent adult abuse shall provide the alleged perpetrator\u8217\'3fs most current contact information to facilitate provision of the findings of the investigation to the alleged perpetrator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An inspector may take or cause to be taken photographs of the dependent adult abuse victim and the vicinity involved. The department shall obtain consent from the dependent adult abuse victim or guardian or other person with a power of attorney over the dependent adult abuse victim prior to taking photographs of the dependent adult abuse victim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 235B.6}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{, an employee organization or union representative may observe an interview conducted by the department of an alleged perpetrator of dependent adult abuse if all of the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alleged perpetrator of dependent adult abuse is part of a bargaining unit that is party to a collective bargaining agreement under }}}{{\f5\fs18\hyphpar0\qj{chapter 20}}}{{\f5\fs18\hyphpar0\qj{ or any other applicable state or federal law.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alleged perpetrator of dependent adult abuse requests the presence of an employee organization or union representative.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employee organization or union representative maintains the confidentiality of all information from the interview subject to the penalties provided in }}}{{\f5\fs18\hyphpar0\qj{section 235B.12}}}{{\f5\fs18\hyphpar0\qj{ if such confidentiality is breached.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall only apply to interviews conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to interviews conducted pursuant to the regulatory activities of }}}{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{135C}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{231B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{231C}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{231D}}}{{\f5\fs18\hyphpar0\qj{, or any other state or federal law.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1093, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a789}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1177, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 80, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 69, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7722 \u8211\'3f 724, 1948}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1073, \'a73 \u8211\'3f 7}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7235B.3}}}{{\f5\fs12\hyphpar0\qj{, 235B.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235E.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prevention of additional dependent adult abuse \u8212\'3f notification of rights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a peace officer has reason to believe that dependent adult abuse, which is criminal in nature, has occurred in a facility or program, the officer shall use all reasonable means to prevent further dependent adult abuse, including but not limited to any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If requested, remaining on the scene as long as there is a danger to the dependent adult\u8217\'3fs physical safety without the presence of a peace officer, including but not limited to staying in the facility or program, or if unable to remain at the scene, assisting the dependent adult in leaving the facility or program and securing support services or emergency shelter services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assisting the dependent adult in obtaining medical treatment necessitated by the dependent adult abuse, including providing assistance to the dependent adult in obtaining transportation to the emergency room of the nearest hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing a dependent adult with immediate and adequate notice of the dependent adult\u8217\'3fs rights. The notice shall consist of handing the dependent adult a document that includes the telephone numbers of shelters, support groups, and crisis lines operating in the area and contains the following written statement of rights; requesting the dependent adult to read the document; and asking the dependent adult whether the dependent adult understands the rights:}}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[1]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{You have the right to ask the court for the following help on a temporary basis:}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[a]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Keeping the alleged perpetrator away from you, your home, your facility, and your place of work.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[b]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{The right to stay at your home or facility without interference from the alleged perpetrator.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[c]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Professional counseling for you, your family, or household members, and the alleged perpetrator of the dependent adult abuse.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[2]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If you are in need of medical treatment, you have the right to request that the peace officer present assist you in obtaining transportation to the nearest hospital or otherwise assist you.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[3]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If you believe that police protection is needed for your physical safety, you have the right to request that the peace officer present remain at the scene until you and other affected parties can leave or safety is otherwise ensured.}{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1093, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a790, 91}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a772}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Similar provisions, }{{\f5\fs12\hyphpar0\qj{\'a7235B.3A}}}{, }{{\f5\fs12\hyphpar0\qj{236.12}}}{, }{{\f5\fs12\hyphpar0\qj{236A.13}}}{, }{{\f5\fs12\hyphpar0\qj{709.22}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235E.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Chapter 235B and section 726.26 application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sections 235B.4 through 235B.19}}}{ and }{{\f5\fs18\hyphpar0\qj{section 726.26}}}{, where not inconsistent with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, shall apply to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1093, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a797}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1132, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235E.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rulemaking authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department, in cooperation and consultation with affected industry representatives and professional and consumer groups, may adopt rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ to administer }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1093, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7279}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235E.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dependent adult abuse finding }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ notification to employer and employee. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon a determination that an allegation of perpetration of dependent adult abuse by a caretaker is founded, the department shall provide written notification of the department\u8217\'3fs findings to the caretaker and the caretaker\u8217\'3fs employer. In addition, the written notification shall detail the consequences of placement on the central abuse registry, the caretaker\u8217\'3fs appeal rights, and include a separate appeal request form. The written appeal request form shall clearly set forth that the caretaker shall not be placed on the central abuse registry until final agency action is taken if an appeal is filed within fifteen days.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1177, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a761}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235E.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal process }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ dependent adult abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a request for an appeal is filed within fifteen days of the issuance of the written notification of a finding of dependent adult abuse, the department shall not place the caretaker on the central abuse registry until final agency action is taken. For a request for an appeal filed within fifteen days of the issuance of the written notification of the finding, the contested case hearing shall be held within sixty days of the request. The caretaker may extend the hearing timeframe by thirty days one time. Additional requests for an extension must be agreed upon by all parties or for good cause. The administrative law judge\u8217\'3fs proposed decision shall be issued within thirty days of the contested case hearing. If further review of the decision is not requested before the proposed decision becomes final, the proposed decision shall be deemed final agency action. If further review is requested, the department\u8217\'3fs final agency action shall occur within thirty days of the issuance of the administrative law judge\u8217\'3fs proposed decision. Upon final agency action, further appeal rights shall be governed by }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a caretaker fails to request an appeal within fifteen days, the caretaker shall have sixty days from the issuance of the written notification of the abuse findings to file an appeal pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. However, the caretaker\u8217\'3fs name shall be placed on the central abuse registry pending the outcome of the appeal. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the caretaker requests an appeal within fifteen days, the caretaker may waive the expedited hearing under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ to proceed under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, but the caretaker\u8217\'3fs name shall be placed on the central abuse registry pending the outcome of the appeal.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1177, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7235E.2}}}\par}}