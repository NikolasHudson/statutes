\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F533A}{\*\bkmkend codeChapter_5F533A}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 533A}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{DEBT MANAGEMENT}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7524.211}}}{{\f5\fs12\qc{, 524.212}}}{{\f5\fs12\qc{, 524.606}}}{{\f5\fs12\qc{, 546.3}}}{{\f5\fs12\qc{, 669.14}}}{{\f5\fs12\qc{, 714E.1}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCreditor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who grants credit, a person who takes assignment of the rights to payments of a person who grants credit, or a person for whose benefit moneys are being collected and distributed by a licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDebt management\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, when done for a fee, any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Arranging or negotiating, or attempting to arrange or negotiate, the amount or terms of debt owed by a debtor to a creditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Receiving from a debtor, directly or indirectly, money or evidences thereof for the purposes of distributing the same to one or more creditors of the debtor in payment or partial payment of the debtor\u8217\'3fs obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serving as an intermediary between a debtor and one or more creditors of the debtor for the purpose of obtaining concessions from the creditors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Engaging in debt settlement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serving as an intermediary between a debtor and one or more creditors or loan servicers of the debtor for the purpose of seeking modification of the terms of an educational loan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDebt settlement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means seeking to settle the amount of a debtor\u8217\'3fs debts with creditors for less than the amounts owed on the debts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDebtor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any natural person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDonation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means money given by the debtor to a licensee as a gift for debt management and outside of the debt management contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEducational loan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 261F.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the moneys paid by the debtor to the licensee as payment for debt management and shall not include money paid to the licensee or held by the licensee for distribution to a creditor, a distribution to the debtor as a refund, or a donation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGratuitous debt-management service\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means debt management without charging a fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLoan servicer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is engaged in the direct collection of payments on a loan from the debtor or holds the right to undertake direct collection of payments on a loan from the debtor, including but not limited to receiving scheduled periodic payments from the debtor pursuant to the terms of the loan or holding the right to service the loan, such as by contracting with or otherwise arranging for another person to service the loan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNatural person\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who is not an association, joint venture or joint stock company, partnership, limited partnership, business corporation, nonprofit corporation, other business entity, or any group of individuals or business entities, however organized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOffice\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means each location by street number, building number, city, and state where any person engages in debt management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual, an association, joint venture or joint stock company, partnership, limited partnership, business corporation, nonprofit corporation, or any other group of individuals however organized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSuperintendent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the superintendent of banking.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 34, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1067, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7533A.8A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licenses required \u8212\'3f exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not engage in the business of debt management in this state without a license as provided for in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ unless exempt under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. A person engages in the business of debt management in this state if the person solicits on behalf of the person or another person to provide, or enters into a contract with one or more debtors to provide, debt management to a debtor who resides in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following persons, including employees of such persons, shall not be required to be licensed or to otherwise comply with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensed attorney admitted to practice in this state acting solely as an incident to the practice of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Banks, federally chartered savings and loan associations, credit unions, mortgage bankers and mortgage brokers licensed or registered under }}}{{\f5\fs18\hyphpar0\qj{chapter 535B}}}{{\f5\fs18\hyphpar0\qj{, insurance companies and similar fiduciaries, regulated loan companies licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 536}}}{{\f5\fs18\hyphpar0\qj{, and industrial loan companies licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 536A}}}{{\f5\fs18\hyphpar0\qj{, authorized and admitted to transact business in this state and performing credit and financial adjusting in the regular course of their principal business, or while performing an escrow function.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Abstract companies, while performing an escrow function.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employees of licensees under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, while performing services for the employee\u8217\'3fs licensed employer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Judicial officers or others acting under court orders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonprofit religious, fraternal, or cooperative organizations offering to debtors gratuitous debt-management service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Those persons whose principal business is the origination of first mortgage loans on real estate for their own portfolios or for sale to institutional investors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 533C}}}{{\f5\fs18\hyphpar0\qj{, including that person\u8217\'3fs authorized delegates as defined in }}}{{\f5\fs18\hyphpar0\qj{section 533C.102}}}{{\f5\fs18\hyphpar0\qj{, or a person exempt from licensing under }}}{{\f5\fs18\hyphpar0\qj{section 533C.103}}}{{\f5\fs18\hyphpar0\qj{, when engaging in money transmission as defined in }}}{{\f5\fs18\hyphpar0\qj{section 533C.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application for a license shall be in the form prescribed by the superintendent. If the applicant is not a natural person, a copy of the legal documents creating the applicant shall be filed with the application. The application shall contain all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant is not a natural person, the type of business entity of the applicant and the date the entity was organized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant is a foreign corporation, both of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An irrevocable consent, duly acknowledged, that suits and actions may be commenced against the licensee in the courts of this state by service of process performed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 617.3}}}{{\f5\fs18\hyphpar0\qj{ or as provided in the Iowa rules of civil procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proof of authorization to do business in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The address where the business is to be conducted, including information as to any branch office of the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and resident address of the applicant\u8217\'3fs owner or partners, or, if a corporation, association, or agency, of the members, shareholders, directors, trustees, principal officers, managers, and agents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name, physical address, and telephone number of the licensee\u8217\'3fs agent for service of process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other pertinent information as the superintendent may require, including a credit report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each application shall be accompanied by a bond to be approved by the superintendent in favor of the people of the state of Iowa in the penal sum of twenty-five thousand dollars for each office, and conditioned that the obligor will not violate any law pertaining to such business and upon the faithful accounting of all moneys collected upon accounts entrusted to such person engaged in debt management, and their employees and agents for the purpose of indemnifying debtors for loss resulting from conduct prohibited by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The aggregate liability of the surety to all debtors doing business with the office for which the bond is filed shall, in no event, exceed the penal sum of such bond. The surety on the bond shall have the right to cancel such bond upon giving thirty days\u8217\'3f notice to the superintendent and thereafter shall be relieved of liability for any breach of condition occurring after the effective date of the cancellation. A person shall not engage in the business of debt management until a good and sufficient bond is filed in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each applicant shall furnish with the application a description of its proposed debt management program, a copy of the disclosures it will be providing debtors pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 533A.8, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and a copy of the contract the applicant proposes to use between the applicant and the debtor pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 533A.8, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of making the application the applicant shall pay to the superintendent the sum of two hundred fifty dollars as a license fee for each of the applicant\u8217\'3fs offices and an investigation fee in the sum of one hundred dollars. A separate application shall be made for each office maintained by the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent may authorize applicants and licensees to be licensed through a nationwide licensing system and to pay the corresponding system processing fees. The superintendent may establish by rule or order new requirements as necessary, including but not limited to requirements that applicants, including officers and directors and those who have control of the applicant, submit to fingerprinting and criminal history checks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and in order to reduce the points of contact which the federal bureau of investigation may be required to maintain for purposes of }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{, the superintendent may use the nationwide licensing system as a channeling agent for requesting information from and distributing information to the United States department of justice or other governmental agency, or to or from any other source so directed by the superintendent.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 158, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1042, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 126, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1160, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 34, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a7131}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 5, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 83, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7533C.103}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of each application and the payment of the fees, the superintendent shall conduct an investigation of the facts concerning the application and the requirements provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent shall grant or deny each application for a license within sixty days from the date that the application and the required fee are filed and paid, unless the period is extended by written agreement between the applicant and the superintendent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent shall enter an order granting the application, and issue and deliver a license to the applicant if the superintendent finds that both of the following are satisfied:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The experience, financial responsibility, character, and general fitness of the applicant is sufficient as to command the confidence of the public and to warrant belief that the business will be operated lawfully, honestly, fairly, and efficiently within the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not been convicted of or pled guilty to a felony or an indictable misdemeanor for financial gain, or has not had a record of having defaulted in payment of money collected for others, including the discharge of such debts through bankruptcy proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant is not a natural person, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall apply to the owners, partners, members, shareholders, officers, directors, and managers of the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant has, at the time of the application, a license for an office located within ten miles of the location of the office named in the application, a license shall not be issued unless the superintendent finds that public convenience will be served by the issuance of the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license shall not be transferable or assignable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the superintendent finds the applicant not qualified under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the superintendent shall enter an order denying the application and notify the applicant of the denial, returning the license fee. Within fifteen days after the entry of such order, the superintendent shall prepare written findings and shall deliver a copy to the applicant.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7533A.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expiration date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The license issued under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall expire on December 31 following its issuance unless sooner surrendered, revoked, or suspended, but may be renewed as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 5, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Renewal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To continue in the business of debt management, each licensee shall annually apply on or before December 1 to the superintendent for renewal of its license. The superintendent may assess a late fee of ten dollars per day for applications submitted and accepted for processing after December 1.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The renewal application shall be on the form prescribed by the superintendent and shall be accompanied by a fee of two hundred fifty dollars. A separate renewal application shall be made for each office maintained by the applicant.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 126, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 5, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.5A}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Change in control \u8212\'3f name or address.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prior written approval of the superintendent is required whenever a change in the control of a licensee is proposed. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcontrol\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ in the case of a corporation means direct or indirect ownership, or the right to control, ten percent or more of the voting shares of the corporation, or the ability of a person to elect a majority of the directors or otherwise effect a change in policy. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fControl\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ in the case of any other entity means the principals of the organization whether active or passive. The superintendent may require information deemed necessary to determine whether a new application is required. When requesting approval, the person shall submit a fee of one hundred dollars to the superintendent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall notify the superintendent and submit a fee of twenty-five dollars per license to the superintendent thirty days in advance of the effective date of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A change in the name of the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A change in the address where the business is conducted.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of process agent.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0034.pdf" }{\fldrslt \cf5 \f5 \fs18{{2009 Acts, ch 34, \'a79}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{\'a7533A.2(3)}}}{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disciplinary action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent may, after notice and hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, take disciplinary action against a licensee if the superintendent finds any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee, or an owner, partner, member, shareholder, officer, director, or manager of the licensee, has been convicted of a felony or of an indictable misdemeanor for financial gain.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee, or an owner, partner, member, shareholder, officer, director, or manager of the licensee, has violated any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or any other state or federal law, rule, or regulation applicable to the conduct of its business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee, or an owner, partner, member, shareholder, officer, director, or manager of the licensee, has engaged in fraud or deceit in procuring the issuance of a license or renewal under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee, or an owner, partner, member, shareholder, officer, director, or manager of the licensee, has engaged in unfair conduct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee is insolvent, or has filed for bankruptcy, receivership, or assignment for the benefit of creditors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee fails to post the bond required by the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the superintendent receives notice that the required bond has been canceled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent may impose one or more of the following disciplinary actions against a licensee:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revoke a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspend a license until further order of the superintendent for a specified period of time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Impose a period of probation under specified conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Impose civil penalties in an amount not to exceed five thousand dollars for each violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a citation and warning respecting licensee behavior.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Order the licensee to pay restitution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent may order an emergency suspension of a licensee\u8217\'3fs license pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.18A}}}{{\f5\fs18\hyphpar0\qj{. A written order containing the facts or conduct which warrants the emergency action shall be timely sent to the licensee by restricted certified mail. Upon issuance of the suspension order, the licensee must also be notified of the right to an evidentiary hearing. A suspension proceeding shall be promptly instituted and determined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a license shall not be revoked or suspended except after notice and a hearing thereon in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee may surrender a license by delivering to the superintendent written notice of surrender, but a surrender does not affect the licensee\u8217\'3fs civil or criminal liability for acts committed before the surrender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A revocation, suspension, or surrender of a license does not impair or affect the obligation of a preexisting lawful contract between the licensee and any person, including a debtor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1160, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7533A.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licensee requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall describe the methodology of its debt management program to each potential debtor client so that the debtor can make an informed decision as to whether or not the licensee\u8217\'3fs program is an appropriate option for the debtor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall conduct a comprehensive review of a debtor\u8217\'3fs debts and monthly budget and make a determination that the licensee\u8217\'3fs program is an appropriate option for the debtor before entering into a contract with the debtor. A licensee shall not accept an account unless a written and thorough budget analysis has been performed which indicates that the debtor can meet the requirements determined by the budget analysis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee, including any third party who markets or sells a debt management program on behalf of a licensee, shall make the following disclosures to a debtor both verbally and in writing before the debtor signs a contract to enroll in the debt management program:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total estimated fee the debtor will pay for participating in the program if the debtor remains in the program for the entire term of the contract.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the licensee cannot guarantee any specific results from participation in the program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the debtor may elect to discontinue participation in the program without penalty at any time during the program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the program includes obtaining concessions regarding the principal amount of the debt from creditors, that any concessions may be considered income to the debtor subject to income tax.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the program is based on a model which does not require the licensee or another licensee to receive money or evidence thereof from the debtor to distribute to the debtor\u8217\'3fs creditors, the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That payments are not made to creditors on the debtor\u8217\'3fs behalf, so the debtor is still obligated to make payments to creditors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That creditors may continue to try to collect the debtor\u8217\'3fs debts while the debtor is enrolled in the program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the program is a debt settlement program, that the following may occur:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The debtor\u8217\'3fs credit report and credit score may be harmed by participating in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure to make required minimum payments to the debtor\u8217\'3fs creditors may violate the debtor\u8217\'3fs agreement with the creditors and may result in additional charges, such as late fees, over limit fees, and penalties and creditors may raise the debtor\u8217\'3fs interest rate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The debtor may be sued by creditors if the debtor fails to make required minimum payments to the debtor\u8217\'3fs creditors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The verbal disclosures required pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be made at a normal rate of speech in a manner designed to ensure the debtor understands the disclosures. The written disclosures shall be provided in a separate document from the contract between the licensee and the debtor and shall be designed to ensure the debtor understands the disclosures. It is a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for a licensee, or any third party who markets or sells a debt management program on behalf of a licensee, to contradict these disclosures in any representation, advertising, or solicitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall make a written contract with a debtor and shall immediately and before collecting any fee, furnish the debtor with a true copy of the contract. A contract shall not extend for a period longer than sixty months. The contract between a licensee and a debtor shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total estimated charges agreed upon for the services of the licensee and any third parties providing services for or in conjunction with the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement of how and when the charges are to be paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the debtor may elect to discontinue participation in the program without penalty at any time during the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The beginning and expiration date of the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name, physical address, mailing address if different from the physical address, and telephone number of the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the services to be provided by the licensee, which shall include educational and counseling services designed to assist the debtor in managing the debtor\u8217\'3fs borrowing, spending, and saving habits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the debt management program is a debt settlement program, the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A comprehensive list of every debt at the time of enrollment that is to be negotiated for settlement by the licensee, including the creditors\u8217\'3f names and identifying information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The estimated amount of money needed to fund settlements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the debt management program is based on a model which requires the licensee or any licensee to receive money or evidences thereof from the debtor to distribute to the debtor\u8217\'3fs creditors, the contract shall set forth the complete list of creditors who are to receive payments under the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the debt management program is based on a model which requires the licensee or any licensee to receive money or evidences thereof from the debtor to distribute to the debtor\u8217\'3fs creditors, the licensee who receives the money or evidences thereof from the debtor for distribution to the debtor\u8217\'3fs creditors shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintain a separate bank trust account in which all payments received from debtors for the benefit of creditors shall be deposited and in which all payments shall remain until a remittance is made to either the debtor or the creditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make remittances to creditors within forty-five days after initial receipt of funds, and thereafter remittances shall be made to creditors within thirty days of receipt, less fees, unless the reasonable payment of one or more of the debtor\u8217\'3fs obligations requires that such funds be held for a longer period so as to accumulate a sum certain.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide each debtor a monthly written statement of disbursements made and fees deducted from the debtor\u8217\'3fs account. The licensee shall also provide a verbal accounting of disbursements made and fees deducted from the debtor\u8217\'3fs account at any time the debtor requests it during normal business hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not receive any fee, or have or cause any fee to be received by any other licensee, other than the initiation fee permitted in }}}{{\f5\fs18\hyphpar0\qj{section 533A.9, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, unless the licensee has the consent of at least fifty percent of the total number of the creditors listed in the licensee\u8217\'3fs contract with the debtor, or such a like number of creditors have accepted a distribution of payment. The debtor shall be informed by the licensee of those creditors who have not agreed to the licensee\u8217\'3fs handling of the account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the debt management program is not based on a model which requires the licensee or any licensee to receive money or evidences thereof from the debtor to distribute to the debtor\u8217\'3fs creditors, both of the following shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The debtor shall maintain full control of and access to any moneys set aside for payment to creditors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee may not receive consideration from any third party in connection with services rendered to a debtor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall keep, and use in the licensee\u8217\'3fs business, books, accounts, and records which will enable the superintendent to determine whether such licensee is complying with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, any applicable state or federal laws or regulations, and the rules and regulations of the superintendent. A licensee shall preserve such books, accounts, and records for at least five years after making the final entry on any transaction recorded therein. Records shall contain complete information regarding all contracts, extensions thereof, payments, disbursements, and charges, which records shall be open to inspection by the superintendent and the superintendent\u8217\'3fs duly appointed agents during normal business hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event a compromise of a debt is arranged by a licensee with one or more creditors, the debtor shall have the full benefit of such compromise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All licensee advertising content, and data supporting any claims made in the advertising, shall be maintained in retrievable format and available to the superintendent for inspection for a minimum of five years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the licensee maintains an internet site, the licensee shall make available on its internet site a physical address for its headquarters, a main telephone number, and an electronic mail contact address.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent may adopt additional requirements applicable to licensees pursuant to administrative rule.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 34, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7257}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7533A.2}}}{{\f5\fs12\hyphpar0\qj{, 533A.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.8A}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Educational loan debt management services }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ contract requirements }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ prohibitions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ remedies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other requirements applicable to a licensee pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a licensee who is engaged primarily in the business of debt management in connection with educational loans, as described in }}}{{\f5\fs18\hyphpar0\qj{section 533A.1, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall do so in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are not exclusive and do not relieve persons or a contract from compliance with other applicable law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall not receive any compensation for providing educational loan debt management services until after the licensee has fully performed all services that the licensee contracted to perform or represented the licensee would perform, and shall not request any payment from the debtor or require the debtor to provide payment to any third party prior to fully performing all services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A debtor has an unconditional right to cancel a contract with a licensee for educational loan debt management services at any time prior to midnight of the third business day following the date a contract which complies with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is signed and executed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cancellation of a contract occurs when the debtor delivers, by any means, written notice of cancellation to the address specified in the contract. Notice of cancellation, if delivered by mail, is effective when deposited in the mail properly addressed with postage prepaid. Notice of cancellation delivered by electronic mail is effective upon transmission. Notice of cancellation delivered personally is effective upon delivery. Notice of cancellation given by the debtor need not take the particular form as provided in the contract and, however expressed, is effective if the notice of cancellation indicates the intention of the debtor not to be bound by the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract to provide debt management services in connection with an educational loan shall be written in clear, understandable language, shall clearly and conspicuously set forth any and all terms, restrictions, and conditions governing the contract, and shall describe fully and in detail all services that the licensee contracts to perform for the debtor. The contract shall be dated and signed by the debtor. The contract shall set forth information required in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in at least ten point type. The following shall be included in the contract:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee\u8217\'3fs name, the licensee\u8217\'3fs electronic mail address, and the physical address of the licensee\u8217\'3fs place of business to which the notice of cancellation is to be mailed or otherwise delivered. A post office box does not constitute a physical address. A post office box may be designated for delivery by mail only if it is accompanied by a physical address at which the notice could be delivered by a method other than mail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A disclosure statement in substantially the following form shall appear in at least fourteen point boldface type immediately above the place where the debtor is to sign:}}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{You, the debtor, may cancel this contract at any time prior to midnight of the third business day after the contract is signed and executed. See the attached notice of cancellation form for an explanation of this right.}{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A completed, easily detachable form in duplicate, captioned \u8220\'3fnotice of cancellation\u8221\'3f, as an attachment, in at least fourteen point boldface type, containing the following statement in substantially the following form and language:}}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084{\f5\fs18\hyphpar0\qc}{NOTICE OF CANCELLATION}{\f5\fs18\hyphpar0\qc}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{........}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{(date contract is signed and executed)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{You, the debtor, may cancel this contract without any penalty or obligation, within three business days from the above date.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{To cancel this contract, you may use any of the following methods: (1) send by postal mail or otherwise deliver a signed and dated copy of this cancellation notice, or any other written notice of cancellation, to (physical address of licensee\u8217\'3fs place of business); or (2) send by electronic mail a notice of cancellation to (licensee\u8217\'3fs electronic mail address).}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{No later than midnight of (date).}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{I hereby cancel this contract.}{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{......}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{(date)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{............}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{(debtor\u8217\'3fs signature)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A disclosure statement in substantially the following form shall appear in at least fourteen point boldface type immediately above the \u8220\'3fNotice of Cancellation\u8221\'3f form described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084{\f5\fs18\hyphpar0\qc}{NOTICE REQUIRED BY IOWA LAW}{\f5\fs18\hyphpar0\qc}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{(Insert name of licensee) or anyone working for (insert name of licensee) CANNOT take payment directly from you or require you to pay for or finance its services through a third party until (insert name of licensee) has fully performed each and every service that (insert name of licensee) contracted to perform or represented that (insert name of licensee) would perform.}{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee who is engaged primarily in the business of debt management in connection with educational loans shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Claim, demand, charge, collect, or receive compensation until after the licensee has fully performed each and every service the licensee contracted to perform or represented the licensee would perform.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Execute a contract with a debtor for educational loan debt management services in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Receive consideration from any third party in connection with services rendered to a debtor unless the consideration is first fully disclosed to the debtor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prohibit or impede a debtor from contacting any creditor, lender, loan servicer, government entity, attorney, counselor, individual, or company that may seek to help the debtor. Any such provision is void and unenforceable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Access or obtain a debtor\u8217\'3fs federal student aid information in violation of federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compensate employees, including independent contractors, based on the number of debtors recruited by the employees or enrolled in particular programs, or provide compensation to employees on any other commission-based system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pay or offer to pay any compensation, bonus, gift, commission, or other consideration to any person for the referral of a debtor to the licensee\u8217\'3fs business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Accept or receive any compensation, bonus, gift, commission, or other consideration for service to the debtor from any person other than the debtor, the debtor\u8217\'3fs representative, or any third party providing financing that is otherwise in compliance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disclose any information regarding a debtor to anyone other than law enforcement, government entities, loan servicers, creditors of the debtor, or as required by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disclose any information regarding the creditor of a debtor to anyone other than the debtor, the debtor\u8217\'3fs representative, or as required by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is an unlawful practice pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{, and all remedies of }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{ are available for such an action. A private cause of action brought under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by a debtor is in the public interest. A debtor may bring an action against a licensee for a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. If the court finds that the licensee violated }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court shall award the debtor actual damages, appropriate equitable relief, and the costs of the action, and shall award reasonable fees to the debtor\u8217\'3fs attorney.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rights and remedies provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are cumulative to, and not a limitation of, any other rights and remedies provided by law. Any action brought by a person other than the attorney general or the superintendent pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ must be commenced within four years from the date of the alleged violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, an action shall not be brought on the basis of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, except by a debtor against whom the violation was committed or by the attorney general or superintendent. This limitation does not apply to administrative action by either the attorney general or the superintendent.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1067, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.9}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fee agreed in advance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee of a licensee charged to a debtor shall be agreed upon in advance and stated in the contract and provision for settlement in case of cancellation shall also be clearly stated in the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A debtor may be charged a one-time initiation fee for debt management services, which shall not exceed fifty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a debt management program is based on a model that required the licensee or any other licensee to receive money or evidences thereof from the debtor to distribute to the debtor\u8217\'3fs creditors, the debtor may not be charged a fee exceeding the initiation fee permitted in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ plus a fee not to exceed fifteen percent of amounts actually applied to the debtor\u8217\'3fs accounts with the creditors. Other than the initiation fee, the debtor shall at no time be required to pay fees exceeding fifteen percent of amounts actually applied to the debtor\u8217\'3fs accounts with the creditors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a debt management program is not based on a model that requires the licensee or another licensee to receive money or evidences thereof from the debtor to distribute to the debtor\u8217\'3fs creditors, a debtor may not be charged a fee exceeding the sum of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The initiation fee permitted in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An additional fee not to exceed eighteen percent of the total amount of the debtor\u8217\'3fs debts enrolled in the licensee\u8217\'3fs program at the time the debtor enrolled in the program. The additional fee shall not be collected pursuant to a method other than the percent of total debt method or the percent of savings method, as provided in subparagraphs (1) and (2), respectively.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The percent of total debt method involves the additional fee being collected in equal monthly installments payable over the first two-thirds of the term of the contract between the debtor and the licensee. The debtor may elect to discontinue participation at any time during the program by providing written notice to the licensee at the address specified in the contract. Notice of discontinuance, if given by mail, is effective when deposited in the mail properly addressed with postage paid. If the debtor discontinues participation in the program, no future installments are due after the mailing of the notice. If participation is discontinued within the first twelve months of the contract, the licensee may retain only fifty percent of the installments it is scheduled to receive through the date the debtor gives the discontinuation notice and shall refund the excess to the debtor. Notwithstanding the foregoing, the licensee may collect a pro rata portion of the total fee upon completion of a settlement of a debtor\u8217\'3fs debt. The pro rata portion shall be calculated by multiplying the total dollar amount of the contracted additional fee by the percentage of debt settled of the original amount of debt enrolled in the program. In no event shall the additional fee exceed eighteen percent of the total amount of the debtor\u8217\'3fs debts enrolled in the licensee\u8217\'3fs program at the time the debtor enrolled in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The percent of savings method involves the additional fee being collected in monthly installments of fifty dollars per month, and the monthly fees collected shall be credited against any fees the licensee earns as the result of settlements. The debtor may elect to discontinue participation at any time during the program by providing written notice to the licensee at the address specified in the contract. Notice of discontinuance, if given by mail, is effective when deposited in the mail properly addressed with postage paid. If the debtor discontinues participation in the program, no future installments are due after the mailing of the notice. If participation is discontinued within the first twelve months of the contract, the licensee may retain only fifty percent of the installments it is scheduled to receive through the date the debtor gives the discontinuation notice and shall refund the excess to the debtor. Notwithstanding the foregoing, the licensee may collect a pro rata portion of the total fee upon completion of a settlement of a debtor\u8217\'3fs debt. The pro rata portion, which may be collected at the time of settlement, shall be calculated by multiplying the contracted savings percentage, not to exceed thirty percent, by the amount saved on settled debt. The amount saved on settled debt is the difference between the balance of that debt upon enrollment in the program and the amount settled. In no event shall the additional fee exceed eighteen percent of the total amount of the debtor\u8217\'3fs debts enrolled in the licensee\u8217\'3fs program at the time the debtor enrolled in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any services provided by a third party, other than the debtor\u8217\'3fs own banking fees, including lead generating, marketing, and selling services, shall be paid for by the licensee. Under no circumstances shall a debtor be required to pay a fee to a third party to obtain a licensee\u8217\'3fs services.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1100, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 34, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7533A.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.9A}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Donations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A donation shall not be charged to a debtor or creditor, deducted from a payment to a creditor, deducted from the debtor\u8217\'3fs account, or deducted from payments made to the licensee pursuant to the debt management contract. If a licensee requests a donation from a debtor, the licensee must clearly indicate that any donation is voluntary and not a condition or requirement for providing debt management.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 126, \'a794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.10}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Examination of licensee \u8212\'3f records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent may examine the condition and affairs of a licensee. In connection with any examination, the superintendent may examine on oath any licensee, and any director, officer, employee, customer, creditor, or stockholder of a licensee concerning the affairs and business of the licensee. The superintendent shall ascertain whether the licensee transacts its business in the manner prescribed by the law and applicable rules. The licensee shall pay the cost of the examination as determined by the superintendent based on the actual cost of the operation of the finance bureau of the banking division of the department of insurance and financial services, including the proportionate share of the administrative expenses in the operation of the banking division attributable to the finance bureau, as determined by the superintendent, incurred in the discharge of duties imposed upon the superintendent by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. Failure to pay the examination fee within thirty days of receipt of demand from the superintendent shall subject the licensee to a late fee of up to five percent per day of the amount of the examination fee for each day the payment is delinquent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the investigation of alleged violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the superintendent may compel the attendance of any person or the production of any books, accounts, records and files, and may examine under oath all persons in attendance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, all papers, documents, examination reports and other writings relating to the supervision of licensees are not public records and are not subject to disclosure under }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{. The superintendent may disclose information to representatives of other state or federal regulatory authorities. The superintendent may release summary complaint information as long as the information does not specifically identify the complainant. The superintendent may prepare and circulate reports reflecting financial information examination results for all licensees on an aggregate basis, including other information considered pertinent to the purpose of each report for general statistical information. The superintendent may prepare and circulate reports provided by law. The superintendent may release the reports and correspondence in the course of an enforcement proceeding or a hearing held by the superintendent and may provide this information to the attorney general for purposes of enforcing }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the consumer fraud Act, }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent may receive documents, materials, or other information, including otherwise confidential and privileged documents, materials, or other information, through a nationwide licensing system and from other local, state, federal, or international regulatory agencies, the conference of state bank supervisors and its affiliates and subsidiaries, the national association of consumer credit administrators and its affiliates and subsidiaries, and any other regulator association, and shall maintain as confidential and privileged any such document, material, or other information received with notice or the understanding that it is confidential or privileged under the laws of the jurisdiction that is the source of the document, material, or other information.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 170, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 5, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72748}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.11}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unlawful acts of licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is unlawful and a violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ for the holder of any license issued under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To purchase from a creditor any obligation of a debtor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To operate as a collection agent and as a licensee as to the same debtor\u8217\'3fs account without first disclosing in writing such fact to both the debtor and creditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To execute any contract or agreement to be signed by the debtor unless the contract or agreement is fully and completely filled in and finished.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To receive or charge any fee in the form of a promissory note or other promise to pay, or receive or accept any mortgage or other security for any fee, both as to real or personal property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To pay any bonus or other consideration to any individual, agency, partnership, unincorporated association, or corporation for the referral of a debtor to the licensee\u8217\'3fs business, or to accept or receive any bonus, commission, or other consideration for referring any debtor to any individual, partnership, unincorporated association, agency, or corporation for any reason.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To advertise the licensee\u8217\'3fs services, display, distribute, broadcast, or televise, or permit to be displayed, advertised, distributed, broadcast, or televised the licensee\u8217\'3fs services in any manner inconsistent with the law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To make, or facilitate the debtor in making, any false or misleading claim regarding a creditor\u8217\'3fs right to collect a debt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To dispute, or facilitate the debtor in disputing, the validity of a debt absent a good faith belief by the debtor that the debt is not validly owing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To challenge a debt without the written consent of the debtor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide or offer to provide legal advice or legal services, including but not limited to the negotiation of payments or the settlement of a debtor\u8217\'3fs delinquent account that is subject to pending litigation, unless the person providing or offering to provide legal advice is licensed to practice law in the state in which the debtor resides.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To execute a power of attorney or any other written agreement that extinguishes or limits the debtor\u8217\'3fs right to contact or communicate with any creditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To take a wage assignment, a lien of any type on real or personal property, or other security to secure the payment of compensation. Any such security is void and unenforceable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To induce or attempt to induce a debtor to enter into a contract which does not comply in all respects with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where applicable, to make any statements, or allow a third party marketing or selling the licensee\u8217\'3fs program to make any statements, in the course of advertising or solicitation that contradicts the disclosures required by }}}{{\f5\fs18\hyphpar0\qj{section 533A.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the licensee\u8217\'3fs program is a debt settlement program, the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To advise a debtor to stop making payments to creditors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To lead a debtor to believe that a payment to a creditor is in settlement of a debt to the creditor unless the creditor provides a written certification or confirmation that the payment is in full settlement of the debt, or is part of a payment plan that is in full settlement of the debt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To make any of the following representations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee will furnish money to pay bills or prevent attachments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Payment of a certain amount will guarantee satisfaction of a certain amount or range of indebtedness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Participation in a program will prevent debt collection calls, litigation, garnishment, attachment, repossession, foreclosure, eviction, or loss of employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Participation in a program will not harm the debtor\u8217\'3fs credit report or credit score.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Participation in a program will prevent the debtor from having to declare bankruptcy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the licensee is authorized or competent to furnish legal advice or perform legal services, including but not limited to the negotiation of payments or the settlement of a debtor\u8217\'3fs delinquent account that is subject to pending litigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the licensee\u8217\'3fs negotiations with creditors will result in the elimination of adverse information on the debtor\u8217\'3fs credit report.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1100, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 34, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.12}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The superintendent may adopt administrative rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ to administer and enforce the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.13}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License mandatory to business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be unlawful for a person to engage in the business of debt management without first obtaining a license as required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Any person or any owner, partner, member, officer, director, employee, agent, or representative thereof who shall willfully or knowingly engage in the business of debt management without the license required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be guilty of a serious misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1042, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.14}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees to state treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All moneys received by the superintendent from fees, licenses, and examinations pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be deposited by the superintendent with the treasurer of state for deposit in the commerce revolving fund created in }{{\f5\fs18\hyphpar0\qj{section 546.12}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 181, \'a7105}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.15}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judicial review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Judicial review of actions of the superintendent pursuant to }{{\f5\fs18\hyphpar0\qj{sections 533A.3}}}{ and }{{\f5\fs18\hyphpar0\qj{533A.7}}}{ may be sought in accordance with the terms of the Iowa administrative procedure Act, }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7533A.15}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 44, \'a7114}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.16}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations \u8212\'3f injunctions \u8212\'3f civil penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the superintendent believes that a person has engaged in, or is about to engage in, an act or practice that constitutes or will constitute a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the superintendent may apply to the district court for an order enjoining such act or practice. Upon a showing by the superintendent that such person has engaged, or is about to engage, in any such act or practice, the district court shall grant an injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent may investigate or initiate complaints against persons who are not licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to determine whether the person is violating }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to or as an alternative to applying to the district court for an injunction, the superintendent may issue an order to a person who is not licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to require compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, may impose a civil penalty against such person for any violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in an amount up to five thousand dollars for each violation, and may order the person to pay restitution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before issuing an order under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the superintendent shall provide the person written notice and the opportunity to request a hearing. The hearing must be requested within thirty days after receipt of the notice and shall be conducted in the same manner as provided for in disciplinary proceedings involving a licensee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person aggrieved by the imposition of a civil penalty under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may seek judicial review pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action to enforce an order under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be joined with an action for an injunction.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1160, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{533A.17}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Waiver not allowed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A waiver by a debtor of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is void and unenforceable as contrary to public policy. An attempt by a licensee to induce a debtor to waive the debtor\u8217\'3fs rights is a violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 34, \'a78}}}\par}}