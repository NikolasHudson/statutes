\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F357H}{\*\bkmkend codeChapter_5F357H}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 357H}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{RURAL IMPROVEMENT ZONES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7331.382}}}{{\f5\fs12\qc{, 466B.2}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rural improvement zones }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors of a county with less than twenty thousand residents, not counting persons admitted or committed to an institution enumerated in }}}{{\f5\fs18\hyphpar0\qj{section 218.1}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{904.102}}}{{\f5\fs18\hyphpar0\qj{, based upon the most recent certified federal census, and with a private real estate development adjacent to or abutting in part a lake may designate an area surrounding the lake, if it is an unincorporated area of the county, a rural improvement zone upon receipt of a petition pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 357H.2}}}{{\f5\fs18\hyphpar0\qj{, and upon the board\u8217\'3fs determination that the area is in need of improvements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the board of supervisors of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fImprovements\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means dredging, installation of erosion control measures, water quality activities, land acquisition, and related improvements, including soil conservation practices, within or outside of the boundaries of the zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLake\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a body of water that is located entirely in a single county and that has a surface area of at least eighty acres.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWater quality activities\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to creation or maintenance of grass waterways or wetlands, bank stabilization, watershed protection, activities on lands outside the rural improvement zone which affect water quality within the zone, and any other activity which will improve water quality of a stream, river, or lake.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1168, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1190, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 108, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 97, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a7149 \u8211\'3f 151}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2020 amendment to subsection 1 applies to rural improvement zones in existence on or established on or after June 29, 2020; }{{\f5\fs12\hyphpar0\qj{2020 Acts, ch 1118, \'a7151}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petition for public hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall, on the petition of twenty-five percent of the residents of a proposed rural improvement zone, if the assessed valuation of the property owned by the petitioners represents at least twenty-five percent of the total assessed value of the proposed zone, hold a public hearing concerning the establishment of a proposed zone. The petition shall include a statement containing the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The need for the proposed zone, which shall be based upon a report of a licensed professional engineer prepared not more than two years before the date the petition is filed, and that includes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Surface area of the lake in acres.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Number of acres of land comprising the lake\u8217\'3fs watershed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Soil classification of the land comprising the lake\u8217\'3fs watershed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Description of all current land uses within the lake\u8217\'3fs watershed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Estimate of historical annual silt accumulation for the lake during the twenty years immediately preceding the year in which the engineer\u8217\'3fs report was completed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Estimate of the amount of silt currently accumulated in the lake.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Estimates of annual silt accumulation in the lake for the twenty-year period following establishment of the rural improvement zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Estimate of remaining space available to the proposed zone in existing detention basins for storage of dredged and removed silt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Estimate of storage space that will be required to store dredged and removed silt from the lake for the twenty-year period following establishment of the rural improvement zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assessment of the current water quality of the lake.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assessment of the current need for preventative practices to improve the water quality of the lake.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assessment of the impact preventative practices will have on the water quality of the lake.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Estimate of the cost to effectively address erosion control and water quality for the twenty-year period following establishment of the rural improvement zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the boundaries of the proposed zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The approximate number of families in the proposed zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the report prepared by the licensed professional engineer and used to prepare the petition shall be submitted with the petition under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may require the petitioners to post a bond conditioned upon the payment of all costs and expenses incurred in the proceedings if the zone is not established.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 97, \'a74, 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7357H.1}}}{{\f5\fs12\hyphpar0\qj{, 357H.3}}}{{\f5\fs12\hyphpar0\qj{, 357H.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Time of public hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the petition substantially meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 357H.2}}}{{\f5\fs18\hyphpar0\qj{, the public hearing required in }}}{{\f5\fs18\hyphpar0\qj{section 357H.2}}}{{\f5\fs18\hyphpar0\qj{ shall be held within sixty days of the presentation of the petition. Notice of hearing shall be given by publication as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{. Holding a public hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not dispositive of the approval or denial of a petition by the board under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board determines that the petition or the engineer\u8217\'3fs report does not substantially meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 357H.2}}}{{\f5\fs18\hyphpar0\qj{, the board may, within thirty days of presentation of the petition, request additional information from the petitioners. The board\u8217\'3fs request for additional information shall be limited to the information required under }}}{{\f5\fs18\hyphpar0\qj{section 357H.2}}}{{\f5\fs18\hyphpar0\qj{ that was not contained in the petition or the accompanying engineer\u8217\'3fs report. The board shall be limited to one request for additional information under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The public hearing required in }}}{{\f5\fs18\hyphpar0\qj{section 357H.2}}}{{\f5\fs18\hyphpar0\qj{ shall be held within sixty days of receiving the additional information. Notice of hearing shall be given in the same manner as required under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 97, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7357H.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hearing on petition }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ action by board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the public hearing the board may consider the boundaries of a proposed rural improvement zone, whether the boundaries shall be as described in the petition or otherwise, and for that purpose may amend the petition and change the boundaries of the proposed zone as stated in the petition. The board may adjust the boundaries of a proposed zone as needed to exclude land that has no reasonable likelihood of benefit from inclusion in a rural improvement zone. However, the boundaries of a proposed zone shall not be changed to incorporate property which is not included in the original petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within thirty days after the hearing, the board shall establish the rural improvement zone by resolution or disallow the petition. However, the zone shall not include any area which is part of an urban renewal area under }}}{{\f5\fs18\hyphpar0\qj{chapter 403}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 97, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Election of candidates for trustees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a preliminary plat has been approved by the board, an election shall be held within the rural improvement zone within sixty days to choose candidates for the offices of trustees of the zone. Notice of the election shall be given as provided in }{{\f5\fs18\hyphpar0\qj{section 357H.3}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trustees \u8212\'3f terms and qualifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The election of trustees of a rural improvement zone shall take place at a special election on ballots which shall not reflect a nominee\u8217\'3fs political affiliation. Nomination shall be made by petition in accordance with }{{\f5\fs18\hyphpar0\qj{chapter 45}}}{. The petition form shall be furnished by the county commissioner of elections, signed by eligible electors of the rural improvement zone equal in number to one percent of the vote cast within the zone for governor in the last previous general election, and shall be filed with the county commissioner of elections. A plurality shall be sufficient to elect the five trustees of the rural improvement zone, and no primary election for that office shall be held. At the original election, two trustees shall be elected for one year, two for two years, and one for three years. The terms of the succeeding trustees are for three years. The terms of the trustees shall begin immediately after their election and certification. The trustees must be residents of the zone. Vacancies on the board shall be filled by appointment by the remaining trustees.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1168, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7357H.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Board of trustees }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ power.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The trustees of a rural improvement zone elected pursuant to }{{\f5\fs18\hyphpar0\qj{section 357H.6}}}{ shall constitute the board of trustees of the zone and shall manage and control the affairs, property, and facilities of the zone. The board of trustees shall elect a president, a clerk, and a treasurer from its membership. The trustees may authorize construction, reconstruction, or repair of improvements following procedures set out in }{{\f5\fs18\hyphpar0\qj{section 331.341}}}{. For these purposes, the trustees may purchase material, employ personnel, acquire real estate and interests in real estate, and perform all other acts necessary to properly maintain and operate the zone. The trustees are allowed necessary expenses in the discharge of their duties, but they shall not receive salaries.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 128, \'a722, 60}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7357H.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificates, contracts, and other obligations \u8212\'3f standby tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{To provide funds for the payment of the costs of improvement projects and for the payment of other activities authorized pursuant to }{{\f5\fs18\hyphpar0\qj{section 357H.7}}}{, the board of trustees may borrow money and issue and sell certificates or may enter into contracts or other obligations payable from a sufficient portion of the future receipts of tax revenue authorized pursuant to }{{\f5\fs18\hyphpar0\qj{section 357H.9}}}{ and the standby tax in }{{\f5\fs18\hyphpar0\qj{subsection 4}}}{ of }{{\f5\fs18\hyphpar0\qj{this section}}}{. The receipts shall be pledged to the payment of principal of and interest on the certificates, contracts, or other obligations.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certificates may be sold at public sale or at private sale at par, premium, or discount at the discretion of the board of trustees. }}}{{\f5\fs18\hyphpar0\qj{Chapter 75}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the issuance of these certificates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certificates may be issued with respect to a single improvement project or multiple projects and may contain terms or conditions as the board of trustees may provide by resolution authorizing the issuance of the certificates. However, certificates, including certificates to refund outstanding certificates under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, shall not be issued if the maturity date of the certificates would be after the date the rural improvement zone is, at the time of issuing the certificates, to be dissolved by law under }}}{{\f5\fs18\hyphpar0\qj{section 357H.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certificates issued to refund other certificates may be sold at public sale or at private sale as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ with the proceeds from the sale to be used for the payment of the certificates being refunded. The refunding certificates may be exchanged in payment and discharge of the certificates being refunded, in installments at different times, or an entire issue or series at one time. Refunding certificates may be sold or exchanged at any time on, before, or after the maturity of the outstanding certificates to be refunded, may be issued for the purpose of refunding a like, greater, or lesser principal amount of certificates, and may bear a rate of interest higher or lower than, or equivalent to, the rate of interest on certificates being renewed or refunded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To further secure the payment of the certificates, the board of trustees shall, by resolution, provide for the assessment of an annual levy of a standby tax upon all taxable property within the rural improvement zone. The rate of the standby tax shall be not less than fifty cents per thousand dollars of the assessed value of the taxable property and not more than two dollars and fifty cents per thousand dollars of the assessed value of the taxable property. A copy of the resolution shall be sent to the county auditor. The revenues from the standby tax shall be deposited in a special fund and shall be expended only for the payment of principal of and interest on the certificates issued as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, when the receipt of tax revenues pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 357H.9}}}{{\f5\fs18\hyphpar0\qj{ is insufficient. If payments are necessary and made from the special fund, the amount of the payments shall be promptly repaid into the special fund from the first available payments received which are not required for the payment of principal of or interest on certificates due. No reserves may be built up in the special fund in anticipation of a projected default. The board of trustees shall adjust the annual standby tax levy for each year to reflect the amount of revenues in the special fund and the amount of principal and interest which is due in that year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before certificates, contracts, or other obligations are issued or entered into, the board of trustees shall publish a notice of its intention, stating the amount, the purpose, and the improvement project or projects for which the certificates, contracts, or other obligations are to be issued or entered into. A person may, within fifteen days after the publication of the notice, appeal the decision of the board of trustees in proposing to issue the certificates or to enter into the contracts or other obligations to the district court in the county in which the rural improvement zone exists. The action of the board of trustees in determining to issue the certificates or to enter into the contracts or other obligations is final and conclusive unless the district court finds that the board of trustees has exceeded its legal authority. An action shall not be brought which questions the legality of the certificates, contracts, or other obligations, the power of the board of trustees to issue the certificates or to enter into the contracts or other obligations, the effectiveness of any proceedings relating to the authorization of the project, or the authorization and issuance of the certificates or entrance into the contracts or other obligations after fifteen days from the publication of the notice of intention to issue certificates or enter into contracts or other obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of trustees shall determine if revenues are sufficient to secure the faithful performance of obligations.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1168, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1190, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 97, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7357H.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Incremental property taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of trustees shall provide by resolution that taxes levied on the taxable property in a rural improvement zone each year by or for the benefit of the state, city, county, school district, or other taxing district after the effective date of the resolution shall, except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, be divided as provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, in the same manner as if the taxable property in the rural improvement zone was taxable property in an urban renewal area and the resolution was an ordinance within the meaning of those subsections. The taxes received by the board of trustees shall be allocated to, and when collected be paid into, a special fund and may be irrevocably pledged by the trustees to pay the principal of and interest on the certificates, contracts, or other obligations approved by the board of trustees to finance or refinance, in whole or in part, an improvement project.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For fiscal years beginning on or after July 1, 2016, when calculating the amount of taxes subject to the division of taxes in a rural improvement zone established on or after July 1, 2004, if the assessed value of the taxable property in the rural improvement zone used to calculate the amount of taxes under }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, is less than the greater of the base year taxable value and fifty percent of the assessed value of the taxable property in the rural improvement zone used to calculate the total amount of property taxes in the rural improvement zone for the fiscal year in which the taxes are due and payable, the assessed value used to calculate the amount of taxes under }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall be increased for that fiscal year until the amount is equal to the greater of the base year taxable value and fifty percent of the assessed value used to calculate the total amount of property taxes in the rural improvement zone for the fiscal year in which the taxes are due and payable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, for the period of ten consecutive fiscal years beginning with the first fiscal year in which the zone receives revenue from a division of taxes under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the division of taxes authorized under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be calculated subject to the provisions of subparagraph (1), except that any references to fifty percent in subparagraph (1) shall be forty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For fiscal years beginning on or after July 1, 2016, when calculating the amount of taxes subject to the division of taxes in a rural improvement zone established before July 1, 2004, if the assessed value of the taxable property in the rural improvement zone used to calculate the amount of taxes under }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, is less than the greater of the base year taxable value and sixty percent of the assessed value of the taxable property in the rural improvement zone used to calculate the total amount of property taxes in the rural improvement zone for the fiscal year in which the taxes are due and payable, the assessed value used to calculate the amount of taxes under }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall be increased for that fiscal year until the amount is equal to the greater of the base year taxable value and sixty percent of the assessed value used to calculate the total amount of property taxes in the rural improvement zone for the fiscal year in which the taxes are due and payable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the valuation adjustments required under }}}{{\f5\fs18\hyphpar0\qj{section 403.20}}}{{\f5\fs18\hyphpar0\qj{, this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be used in determining the assessed value of property within a rural improvement zone that is subject to a division of taxes in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The difference between the actual value of the property as determined by the assessor each year and the assessed value of the property following application of the assessment limitations pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 441.21, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, shall be subtracted from the actual value of the property as determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the assessed value of the property as determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, is reduced to zero due to the reduction under subparagraph (2), or if the reduction in the assessed value is limited by operation of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the additional valuation reduction shall be subtracted from the actual value of the property as determined by the assessor. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the actual value of the property as determined by the assessor is reduced to zero due to the reduction under subparagraph (3), the remaining valuation reduction, notwithstanding the limitation in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be subtracted from the assessed value of the property as determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of trustees may enter into an agreement with the board that modifies the allocation of the taxes levied in the rural improvement zone. Such an agreement shall not, however, provide an allocation to the other taxing districts that is less than the amount of taxes resulting from application of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBase year taxable value\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the actual value of the property as determined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, following application of the assessment limitations pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 441.21, subsection 9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTaxes\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to all levies on an ad valorem basis upon land or real property located in the rural improvement zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each board of trustees that has by resolution provided for a division of taxes in the rural improvement zone during the most recently ended fiscal year shall complete and file with the department of management a tax increment financing report by December 1 following the end of such fiscal year. The report shall be approved by the affirmative vote of a majority of the board of trustees and be prepared in the format and submitted electronically pursuant to the instructions prescribed by the department of management in consultation with the legislative services agency.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The report required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall include substantially the same information required for counties under }}}{{\f5\fs18\hyphpar0\qj{section 331.403, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, as of June 30 of the most recently ended fiscal year or the information for such fiscal year, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By December 1, 2012, the department of management shall make publicly available on an internet site a searchable database of all such information contained in the reports required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Reports from previous years shall be retained by the department and shall continue to be available and searchable on the internet site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A board of trustees that fails to satisfy the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall have all future incremental taxes withheld from payment into the rural improvement zone\u8217\'3fs special fund until such requirements are met.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1168, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1124, \'a79, 25}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 97, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a731, 32, 38}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.403}}}{{\f5\fs12\hyphpar0\qj{, 357H.8}}}{{\f5\fs12\hyphpar0\qj{, 357H.10}}}{{\f5\fs12\hyphpar0\qj{, 357H.11}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 1, paragraph d, subparagraph (2) applies retroactively to assessment years beginning on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a738}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 1, paragraph f, subparagraph (1) applies retroactively to assessment years beginning on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a738}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.9A}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual financial report }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ audit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than December 1 of each year on forms and pursuant to the instructions prescribed by the department of management, the board of trustees shall file with the county auditor an annual financial report showing the rural improvement zone\u8217\'3fs financial condition as of June 30 and the results of operations for the year then ended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A rural improvement zone is subject to annual audit by the auditor of state. In lieu of an audit by the auditor of state, the rural improvement zone may contract with or employ a certified public accountant to conduct the audit pursuant to the applicable terms and conditions prescribed by sections }}}{{\f5\fs18\hyphpar0\qj{11.6}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{11.14}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{11.19}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{11.41}}}{{\f5\fs18\hyphpar0\qj{. The audit format shall be as prescribed by the auditor of state. The rural improvement zone shall pay all expenses incurred by the auditor of state in conducting an audit under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 97, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dissolution of zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Prior to the date required for dissolution under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a rural improvement zone may be dissolved upon the adoption of a resolution of the board of trustees which specifies that all improvements have been made in the zone, the need for the zone, as identified under }}}{{\f5\fs18\hyphpar0\qj{section 357H.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, has been satisfied, and all indebtedness has been paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless dissolved by resolution of the board of trustees under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or an extension is approved under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, each rural improvement zone is dissolved on June 30, 2019, or twenty years after the first day of the fiscal year following the fiscal year in which the zone first receives revenue from the division of taxes under }}}{{\f5\fs18\hyphpar0\qj{section 357H.9}}}{{\f5\fs18\hyphpar0\qj{, whichever date is later.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for dissolution of a rural improvement zone may be extended by resolution of the board adopted prior to the date required for dissolution under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or a date prior to the date to which the rural improvement zone was previously extended by the board under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or by operation of law under subparagraph (1). Each extension approved by the board under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be for a period of twenty years. Prior to approval of an extension by the board under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, all of the following requirements shall be met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not more than forty-eight months nor less than thirty-six months prior to the date required for dissolution, the board of trustees shall file a written request with the board for an extension of the zone\u8217\'3fs dissolution date. The request shall state the improvements needed in the rural improvement zone beyond the dissolution date otherwise required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The board shall, within ninety days after receiving the request, either adopt a resolution granting the twenty-year extension without further proceedings or notify the board of trustees in writing of the board\u8217\'3fs intent to review the zone\u8217\'3fs dissolution date under subparagraphs (2) through (4). The board may, as part of its notice to the board of trustees, request a report prepared by a licensed professional engineer containing all of the information required under }}}{{\f5\fs18\hyphpar0\qj{section 357H.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. If the board fails to either approve the extension by resolution or notify the board of trustees of the board\u8217\'3fs intent to review the zone\u8217\'3fs dissolution date under subparagraphs (2) through (4) within the ninety-day period, the request for a twenty-year extension shall be deemed approved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following receipt of the board\u8217\'3fs notice of intent to review and not less than twenty-four months prior to the date required for dissolution, the board of trustees shall, if requested by the board under subparagraph (1), submit to the board a report prepared by a licensed professional engineer that includes the information required under }}}{{\f5\fs18\hyphpar0\qj{section 357H.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. If the board determined that the engineer\u8217\'3fs report does not substantially meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 357H.2}}}{{\f5\fs18\hyphpar0\qj{ or that additional relevant information is needed, the board may, within thirty days of the date the request was filed under subparagraph (1), request additional information from the board of trustees. The board shall be limited to one request for additional information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not more than sixty days after receiving the engineer\u8217\'3fs report required or the additional information requested under subparagraph (2), whichever is later, the board shall hold a public hearing to determine the need for improvements in the rural improvement zone. Notice of hearing shall be given by publication as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{. Holding a public hearing pursuant to this subparagraph is not dispositive of the approval or denial of a request for an extension of the dissolution date by the board under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within thirty days after the public hearing, the board shall either find a need for improvements in the rural improvement zone and adopt a resolution approving the twenty-year extension or find that the area is no longer in need of improvements. If the board fails to either approve or deny the extension within the thirty-day period, the request for a twenty-year extension is deemed approved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon dissolution of the zone, all assets shall be deeded or otherwise transferred to a nonprofit corporation whose members are property owners of the improvement zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon dissolution of the zone, the collection of the property tax authorized under }}}{{\f5\fs18\hyphpar0\qj{section 357H.8, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and the division of taxes authorized under }}}{{\f5\fs18\hyphpar0\qj{section 357H.9}}}{{\f5\fs18\hyphpar0\qj{ shall cease immediately.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 152, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 97, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7357H.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{357H.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any agreement or other instrument in connection with an agreement between a board of trustees and a board in effect on July 1, 2015, relating to the division of taxes under }{{\f5\fs18\hyphpar0\qj{section 357H.9}}}{, the dissolution date of a rural improvement zone, or the criteria used for determining the need for improvements in the rural improvement zone that is inconsistent with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be null and void. However, nothing in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be construed to prohibit the board of trustees and the board from entering into an agreement on or after July 1, 2015, relating to the division of taxes under }{{\f5\fs18\hyphpar0\qj{section 357H.9}}}{, the dissolution date of the rural improvement zone, or the criteria used for determining the need for improvements in the rural improvement zone, so long as such agreement does not violate the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 97, \'a713}}}\par}}