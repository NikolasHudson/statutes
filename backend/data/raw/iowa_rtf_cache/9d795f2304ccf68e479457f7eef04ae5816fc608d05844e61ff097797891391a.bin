hapter 147}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 154C.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProfessional limited liability company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a limited liability company subject to }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, except a foreign professional limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRegulating board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any board, commission, court, or governmental authority which, under the laws of this state, is charged with the licensing, registration, certification, admission to practice, or other legal authorization of the practitioners of any profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fVoluntary transfer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a sale, voluntary assignment, gift, pledge, or encumbrance; a voluntary change of legal or equitable ownership or beneficial interest; or a voluntary change of persons having voting rights with respect to any transferable interest, except as proxies.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fVoluntary transfer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a transfer of an individual\u8217\'3fs interest in a limited liability company or other property to a guardian or conservator appointed for that individual or the individual\u8217\'3fs property.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a7141}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1162, \'a787, 155}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 1, \'a71, 5, 6}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1066, \'a71, 5}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7111, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1102}}}{\*\bkmkstart stylerid1_2E15_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Purposes and powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A professional limited liability company shall be organized only for the purpose of engaging in the practice of one specific profession, or two or more specific professions which could lawfully be practiced in combination by a licensed individual or a partnership of licensed individuals, and for the additional purpose of doing all lawful things which may be incidental to or necessary or convenient in connection with the practice of the profession or professions. The certificate of organization of a professional limited liability company shall state in substance that the purposes for which the professional limited liability company is organized are to engage in the general practice of a specified profession or professions, or one or more specified branches or divisions thereof, and to do all lawful things which may be incidental to or necessary or convenient in connection with the practice of the profession or professions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, medicine and surgery, osteopathic medicine and surgery, and practice as a physician assistant shall be deemed to be professions which could lawfully be practiced in combination by licensed individuals or a partnership of licensed individuals.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to expand the scope of practice of a physician assistant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, marital and family therapy, mental health counseling, psychology, and social work shall be deemed to be professions which could lawfully be practiced in combination by licensed individuals or a partnership of licensed individuals.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a788, 155}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 1, \'a72, 5, 6}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1066, \'a72, 5}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 73, \'a722}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7489.1105}}}{{\f5\fs12\hyphpar0\qj{, 489.1114}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1103}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The name of a professional limited liability company, the name of a foreign professional limited liability company or its name as modified for use in this state, and any fictitious name or trade name adopted by a professional limited liability company or foreign professional limited liability company shall contain the words \u8220\'3fProfessional Limited Company\u8221\'3f, \u8220\'3fProfessional Limited Liability Company\u8221\'3f, or the abbreviation \u8220\'3fP.L.C.\u8221\'3f, \u8220\'3fPLC\u8221\'3f, \u8220\'3fP.L.L.C.\u8221\'3f, or \u8220\'3fPLLC\u8221\'3f, and except for the addition of such words or abbreviation, shall be a name which could lawfully be used by a licensed individual or by a partnership of licensed individuals in the practice in this state of a profession which the professional limited liability company is authorized to practice. Each regulating board may by rule adopt additional requirements as to the corporate names and fictitious or trade names of professional limited liability companies and foreign professional limited liability companies which are authorized to practice a profession which is within the jurisdiction of the regulating board.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a789, 155}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 56, \'a73, 5, 6}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1097, \'a721}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1104}}}{\*\bkmkstart stylerid1_2E15_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Who may organize.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{One or more individuals having capacity to contract and licensed to practice a profession in this state in which the professional limited liability company is to be authorized to practice, may organize a professional limited liability company.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a790, 155}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1105}}}{\*\bkmkstart stylerid1_2E15_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Practice by professional limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other statute or rule of law, a professional limited liability company may practice a profession, but may do so in this state only through a member, manager, employee, or agent, who is licensed to practice the same profession in this state. In its practice of a profession, a professional limited liability company shall not do any act which could not lawfully be done by an individual licensed to practice the profession which the professional limited liability company is authorized to practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit persons practicing medicine and surgery, persons practicing osteopathic medicine and surgery, or persons practicing as physician assistants from practicing their respective professions in lawful combination pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 489.1102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to expand the scope of practice of a physician assistant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, marital and family therapy, mental health counseling, psychology, and social work shall be deemed to be professions which could lawfully be practiced in combination by licensed individuals or a partnership of licensed individuals.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a791, 155}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 1, \'a73, 5, 6}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7268}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 73, \'a723}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1106}}}{\*\bkmkstart stylerid1_2E15_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Professional regulation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A professional limited liability company shall not be required to register with or to obtain any license, registration, certificate, or other legal authorization from a regulating board in order to practice a profession. Except as provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{, }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ does not restrict or limit in any manner the authority or duties of any regulating board with respect to an individual practicing a profession which is within the jurisdiction of the regulating board, even if the individual is a member, manager, employee, or agent of a professional limited liability company or foreign professional limited liability company and practices the individual\u8217\'3fs profession through such professional limited liability company.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a792, 155}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7112, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1107}}}{\*\bkmkstart stylerid1_2E15_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Relationship and liability to persons served.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subchapter}}}{ does not modify any law applicable to the relationship between an individual practicing a profession and a person receiving professional services, including but not limited to any liability arising out of such practice or any law respecting privileged communications. }{{\f5\fs18\hyphpar0\qj{This subchapter}}}{ does not modify or affect the ethical standards or standards of conduct of any profession, including but not limited to any standards prohibiting or limiting the practice of the profession by a limited liability company or prohibiting or limiting the practice of two or more professions in combination. All such standards shall apply to the members, managers, employees, and agents through whom a professional limited liability company practices any profession in this state, to the same extent that the standards apply to an individual practitioner.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a793, 155}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7113, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1108}}}{\*\bkmkstart stylerid1_2E15_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An interest of a professional limited liability company shall be issued only to an individual who is licensed to practice in any state a profession which the professional limited liability company is authorized to practice. Interests of a professional limited liability company shall not at any time be issued in, transferred into, or held in joint tenancy, tenancy in common, or any other form of joint ownership or co-ownership. }{{\f5\fs18\hyphpar0\qj{Chapter 502}}}{ shall not be applicable to nor govern any transaction relating to any interests of a professional limited liability company.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a794, 155}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1109}}}{\*\bkmkstart stylerid1_2E15_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Assignment of interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A member or other person shall not make a voluntary assignment of an interest in a professional limited liability company to any person, except to the professional limited liability company or to an individual who is licensed to practice in this state a profession which the limited liability company is authorized to practice. The certificate of organization or operating agreement of the professional limited liability company may contain any additional provisions restricting the assignment of interests. Unless the certificate of organization or an operating agreement otherwise provides, a voluntary assignment requires the unanimous consent of the members.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a795, 155}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1110}}}{\*\bkmkstart stylerid1_2E15_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Convertible interests }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ rights and options.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A professional limited liability company shall not create or issue any interest convertible into an interest of the professional limited liability company. The provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ with respect to the issuance and transfer of interests apply to the creation, issuance, and transfer of any right or option entitling the holder to purchase from a professional limited liability company any interest of the professional limited liability company. A right or option shall not be transferable, whether voluntarily, involuntarily, by operation of law, or in any other manner. Upon the death of the holder, or when the holder ceases to be licensed to practice a profession in this state which the professional limited liability company is authorized to practice, the right or option shall expire.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a796, 155}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7114, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1111}}}{\*\bkmkstart stylerid1_2E15_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Voting trust \u8212\'3f proxy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A member of a professional limited liability company shall not create or enter into a voting trust or any other agreement conferring upon any other person the right to vote or otherwise represent any interests of a professional limited liability company, and no such voting trust or agreement is valid or effective. Any proxy of a member of a professional limited liability company shall be an individual licensed to practice a profession in this state which the professional limited liability company is authorized to practice. Any provision in any proxy instrument denying the right of the member to revoke the proxy at any time or for any period of time is not valid or effective. }{{\f5\fs18\hyphpar0\qj{This section}}}{ does not otherwise limit the right of a member to vote by proxy, but the certificate of organization or operating agreement of the professional limited liability company may further limit or deny the right to vote by proxy.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a797, 155}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1112}}}{\*\bkmkstart stylerid1_2E15_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Required purchase by professional limited liability company of its own interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other statute or rule of law, a professional limited liability company shall purchase its own interests as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{; and a member of a professional limited liability company and the member\u8217\'3fs executor, administrator, legal representative, and successors in interest, shall sell and transfer the interests held by them as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the death of a member, the professional limited liability company shall immediately purchase all interests held by the deceased member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to remain a member of a professional limited liability company, the member shall at all times be licensed to practice in this state a profession which the professional limited liability company is authorized to practice. When a member does not have or ceases to have this qualification, the professional limited liability company shall immediately purchase all interests held by that member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a person other than a member of record becomes entitled to have interests of a professional limited liability company transferred into that person\u8217\'3fs name or to exercise voting rights, except as a proxy, with respect to interests of the professional limited liability company, the professional limited liability company shall immediately purchase the interests. Without limiting the generality of the foregoing, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be applicable whether the event occurs as a result of appointment of a guardian or conservator for a member or the member\u8217\'3fs property, transfer of interests by operation of law, involuntary transfer of interests, judicial proceeding, execution, levy, bankruptcy proceeding, receivership proceeding, foreclosure or enforcement of a pledge or encumbrance, or any other situation or occurrence. However, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to any voluntary transfer of interests as defined in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interests purchased by a professional limited liability company under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be transferred to the professional limited liability company as of the close of business on the date of the death or other event which requires purchase. The member and the member\u8217\'3fs executors, administrators, legal representatives, or successors in interest, shall promptly do all things which may be necessary or convenient to cause transfer to be made as of the transfer date. However, the interests shall promptly be transferred on the books and records of the professional limited liability company as of the transfer date, notwithstanding any delay in transferring or surrendering the interests or certificates representing the interests, and the transfer shall be valid and effective for all purposes as of the close of business on the transfer date. The purchase price for such interests shall be paid as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, but the transfer of interests to the professional limited liability company as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be delayed or affected by any delay or default in making payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 5}}}{{\f5\fs18\hyphpar0\qj{, purchase by the professional limited liability company is not required upon the occurrence of any event other than death of a member, if the professional limited liability company is dissolved within sixty days after the occurrence of the event or voluntarily elects to no longer be a professional limited liability company but continue its existence as a limited liability company pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 489.1119}}}{{\f5\fs18\hyphpar0\qj{ within sixty days after the occurrence of the event. The certificate of organization or operating agreement of the professional limited liability company may provide that purchase is not required upon the death of a member, if the professional limited liability company is dissolved within sixty days after the date of the member\u8217\'3fs death.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 5}}}{{\f5\fs18\hyphpar0\qj{, purchase by the professional limited liability company is not required upon the death of a member if the professional limited liability company voluntarily elects to no longer be a professional limited liability company but continue its existence as a limited liability company pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 489.1119}}}{{\f5\fs18\hyphpar0\qj{ within sixty days after death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided in the certificate of organization or an operating agreement of the professional limited liability company or in an agreement among all members of the professional limited liability company, all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purchase price for interests shall be its book value as of the end of the month immediately preceding the death or other event which requires purchase. Book value shall be determined from the books and records of the professional limited liability company in accordance with the regular method of accounting used by the professional limited liability company, uniformly and consistently applied. Adjustments to book value shall be made, if necessary, to take into account work in process and accounts receivable. A final determination of book value made in good faith by an independent certified public accountant or firm of certified public accountants employed by the professional limited liability company for the purpose shall be conclusive on all persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purchase price shall be paid in cash as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the death of a member, thirty percent of the purchase price shall be paid within ninety days after death, and the balance shall be paid in three equal annual installments on the first three anniversaries of the death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the happening of any other event referred to in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, one-tenth of the purchase price shall be paid within ninety days after the date of the event, and the balance shall be paid in three equal annual installments on the first three anniversaries of the date of the event.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest from the date of death or other event shall be payable annually on principal payment dates, at the rate of six percent per annum on the unpaid balance of the purchase price.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All persons who are members of the professional limited liability company on the date of death or other event, and their executors, administrators, and legal representatives, shall, to the extent the professional limited liability company fails to meet its obligations under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, be jointly liable for the payment of the purchase price and interest in proportion to their percentage of ownership of the professional limited liability company\u8217\'3fs interests, disregarding interests of the deceased or withdrawing member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The part of the purchase price remaining unpaid after the initial payment shall be evidenced by a negotiable promissory note, which shall be executed by the professional limited liability company and all members liable for payment. Any person liable on the note shall have the right to prepay the note in full or in part at any time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person making any payment is not reasonably able to determine which of two or more persons is entitled to receive a payment, or if the payment is payable to a person who is unknown, or who is under disability and there is no person legally competent to receive the payment, or who cannot be found after the exercise of reasonable diligence by the person making the payment, it shall be deposited with the treasurer of state and shall be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 490.1440}}}{{\f5\fs18\hyphpar0\qj{ with respect to funds deposited with the treasurer of state upon the voluntary or involuntary dissolution of a business corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, no part of the purchase price shall be required to be paid until the certificates, if any, representing the interests have been surrendered to the professional limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, payment of any part of the purchase price for interests of a deceased member shall not be required until the executor or administrator of the deceased member provides any indemnity, release, or other document from any taxing authority, which is reasonably necessary to protect the professional limited liability company against liability for estate, inheritance, and death taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate of organization or an operating agreement of the professional limited liability company or an agreement among all members of a professional limited liability company may provide for a different purchase price, a different method of determining the purchase price, a different interest rate or no interest, and other terms, conditions, and schedules of payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate of organization or an operating agreement of the professional limited liability company or an agreement among all members of a professional limited liability company may provide for the optional or mandatory purchase of its own interests by the professional limited liability company in other situations, subject to any applicable law regarding such a purchase.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a798, 155}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7115, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1113}}}{\*\bkmkstart stylerid1_2E15_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificates representing interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each certificate representing an interest of a professional limited liability company shall state in substance that the certificate represents an interest in a professional limited liability company and is not transferable except as expressly provided in }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ and in the certificate of organization or an operating agreement of the professional limited liability company.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a799, 155}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7116, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1114}}}{\*\bkmkstart stylerid1_2E15_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All managers of a professional limited liability company shall at all times be individuals who are licensed to practice a profession in this state or a lawful combination of professions pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 489.1102}}}{{\f5\fs18\hyphpar0\qj{, which the limited liability company is authorized to practice. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, upon the occurrence of any event that requires the professional limited liability company either to be dissolved or to elect to no longer be a professional limited liability company but continue its existence as a limited liability company, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 489.1119}}}{{\f5\fs18\hyphpar0\qj{, all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The professional limited liability company ceases to practice the profession that the professional limited liability company is authorized to practice, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 489.1119}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individuals who are not licensed to practice in this state a profession that the professional limited liability company is authorized to practice may be appointed as officers and directors for the sole purpose of doing any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carrying out the dissolution of the professional limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If applicable, carrying out the voluntary election of the professional limited liability company to no longer be a professional limited liability company but continue its existence as a limited liability company, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 489.1119}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a7100, 155}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 1, \'a74, 5, 6}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7117, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1115}}}{\*\bkmkstart stylerid1_2E15_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Merger.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A professional limited liability company shall not merge with any entity except another professional limited liability company subject to }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ or a professional corporation subject to }{{\f5\fs18\hyphpar0\qj{chapter 496C}}}{. Merger is not permitted unless the surviving or new professional limited liability company is a professional limited liability company that complies with all requirements of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a7101, 155}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7118, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1116}}}{\*\bkmkstart stylerid1_2E15_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dissolution or liquidation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A violation of any provision of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ by a professional limited liability company or any of its members or managers shall be cause for its involuntary dissolution, or liquidation of its assets and business by the district court. Upon the death of the last remaining member of a professional limited liability company, or when the last remaining member is not licensed or ceases to be licensed to practice a profession in this state which the professional limited liability company is authorized to practice, or when any person other than the member of record becomes entitled to have all interests of the last remaining member of the professional limited liability company transferred into that person\u8217\'3fs name or to exercise voting rights, except as a proxy, with respect to such interests, the professional limited liability company shall not practice any profession. In that case, the professional limited liability company shall either be promptly dissolved or shall promptly elect to no longer be a professional limited liability company but continue its existence as a limited liability company as provided in }{{\f5\fs18\hyphpar0\qj{section 489.1119}}}{. However, if prior to dissolution all outstanding interests of the professional limited liability company are acquired by two or more persons licensed to practice a profession in this state which the professional limited liability company is authorized to practice, the professional limited liability company need not be dissolved nor elect to no longer be a professional limited liability company and may instead practice the profession as provided in }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a7102, 155}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7119, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1117}}}{\*\bkmkstart stylerid1_2E15_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Foreign professional limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A foreign professional limited liability company may practice a profession in this state if it complies with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. The secretary of state may prescribe forms for this purpose. A foreign professional limited liability company may practice a profession in this state only through members, managers, employees, and agents who are licensed to practice the profession in this state. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ with respect to the practice of a profession by a professional limited liability company apply to a foreign professional limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subchapter}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit the practice of a profession in this state by an individual who is a member, manager, employee, or agent of a foreign professional limited liability company, if the individual could lawfully practice the profession in this state in the absence of any relationship to a foreign professional limited liability company. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies regardless of whether or not the foreign professional limited liability company is authorized to practice a profession in this state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a7103, 155}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7120, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1118}}}{\*\bkmkstart stylerid1_2E15_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limited liability companies organized under the other laws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subchapter}}}{ does not apply to or interfere with the practice of any profession by or through any professional limited liability company organized after July 1, 1992, under any other law of this state or any other state or country, if the practice is lawful under any other statute or rule of law of this state. Any such professional limited liability company may voluntarily elect to adopt }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ and become subject to its provisions, by amending its certificate of organization to be consistent with all provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ and by stating in its amended certificate of organization that the limited liability company has voluntarily elected to adopt }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{. Any limited liability company organized under any law of any other state or country may become subject to the provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ by complying with all provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ with respect to foreign professional limited liability companies.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a7104, 155}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 152, \'a7121, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1119}}}{\*\bkmkstart stylerid1_2E15_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Election to no longer be a professional limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A professional limited liability company may elect to no longer be a professional limited liability company but continue its existence as a limited liability company by filing with the secretary of state an amendment to or restatement of its certificate of organization that states that the limited liability company is no longer a professional limited liability company and amending its name to no longer indicate it is a professional limited liability company.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 152, \'a7123, 161}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7489.1112}}}{{\f5\fs12\hyphpar0\qj{, 489.1114}}}{{\f5\fs12\hyphpar0\qj{, 489.1116}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Former \'a7489.1119 transferred to }{{\f5\fs12\hyphpar0\qj{\'a7489.1120}}}{; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 152, \'a7143, 161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1120}}}{\*\bkmkstart stylerid1_2E15_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conflicts with other provisions of }}}{{\f5\b\fs18\hyphpar0\qj{this chapter}}}{{\f5\b\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ shall prevail over any inconsistent provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a7105, 155}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2009, \'a7489.1119}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 152, \'a7122, 143, 161}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7489.1120}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{489.1121 through 489.1200}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER XII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E16_2E2_2E2}{MISCELLANEOUS PROVISIONS}{\*\bkmkend stylerid1_2E16_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{489.1201}}}{\*\bkmkstart stylerid1_2E16_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Uniformity of application and construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In applying and construing }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, consideration must be given to the need to promote uniformity of the law with respect to its subject matter among states that enact it.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1162, \'a7112, 