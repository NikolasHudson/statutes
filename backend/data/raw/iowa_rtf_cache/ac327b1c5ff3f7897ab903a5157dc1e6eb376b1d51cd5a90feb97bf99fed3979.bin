8\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out other duties required by law and duties assigned pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.323}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7170, 177; R60, \'a7383, 390, 3264; C73, \'a7337, 344, 346; C97, \'a7499, 504, 506; S13, \'a7499-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5183, 5188, 5190;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7337.3}}}{, }{{\f5\fs18\hyphpar0\qj{337.8}}}{, }{{\f5\fs18\hyphpar0\qj{337.10}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.653(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7652}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[S13, \'a7499-c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5184;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7337.4}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.653(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7652}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7178; R60, \'a7391; C73, \'a7345; C97, \'a7505; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5189;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7337.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.653(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7652}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7174; R60, \'a7387; C73, \'a7341; C97, \'a7503; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5187;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7337.7}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.653(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7652}}}{]}\par}{}{\pard\plain\f5\