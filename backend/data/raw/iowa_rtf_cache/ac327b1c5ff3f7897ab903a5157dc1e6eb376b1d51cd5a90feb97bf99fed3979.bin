 1026, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7202}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71085}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7114, 115, 137}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Contracts to provide services to tax-exempt property; see }{{\f5\fs12\hyphpar0\qj{\'a7364.19}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsection 1, paragraphs e, f, and g effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsection 3 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraphs e, f, and g stricken and former paragraphs h \u8211\'3f j redesignated as e \u8211\'3f g}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 stricken and former subsections 4 \u8211\'3f 10 renumbered as 3 \u8211\'3f 9}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.383}}}{\*\bkmkstart stylerid1_2E7_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties and powers relating to elections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board shall ensure that the county commissioner of elections conducts primary, general, city, school, and special elections in accordance with applicable state law. The board shall canvass elections in accordance with }{{\f5\fs18\hyphpar0\qj{sections 43.49 through 43.51}}}{, }{{\f5\fs18\hyphpar0\qj{43.60 through 43.62}}}{, }{{\f5\fs18\hyphpar0\qj{46.24}}}{, }{{\f5\fs18\hyphpar0\qj{50.13}}}{, }{{\f5\fs18\hyphpar0\qj{50.24 through 50.29}}}{, }{{\f5\fs18\hyphpar0\qj{50.44 through 50.47}}}{, }{{\f5\fs18\hyphpar0\qj{260C.39}}}{, }{{\f5\fs18\hyphpar0\qj{275.25}}}{, }{{\f5\fs18\hyphpar0\qj{277.20}}}{, }{{\f5\fs18\hyphpar0\qj{376.1}}}{, }{{\f5\fs18\hyphpar0\qj{376.7}}}{, and }{{\f5\fs18\hyphpar0\qj{376.9}}}{. The board shall prepare and deliver a list of persons nominated in accordance with }{{\f5\fs18\hyphpar0\qj{section 43.55}}}{, provide for a recount in accordance with }{{\f5\fs18\hyphpar0\qj{section 50.48}}}{, provide for election precincts in accordance with }{{\f5\fs18\hyphpar0\qj{sections 49.3}}}{, }{{\f5\fs18\hyphpar0\qj{49.4}}}{, }{{\f5\fs18\hyphpar0\qj{49.6 through 49.8}}}{, and }{{\f5\fs18\hyphpar0\qj{49.11}}}{, pay election costs as provided in }{{\f5\fs18\hyphpar0\qj{section 47.3}}}{, participate in election contests as provided in }{{\f5\fs18\hyphpar0\qj{sections 62.1A}}}{ and }{{\f5\fs18\hyphpar0\qj{62.9}}}{, and perform other election duties required by state law. The board shall provide for the use of an optical scan voting system as provided in }{{\f5\fs18\hyphpar0\qj{sections 52.2}}}{ and }{{\f5\fs18\hyphpar0\qj{52.3}}}{, and exercise other election powers as provided by state law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.383}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7382}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a736}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 190, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 57, \'a784}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1060, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7176}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.384}}}{\*\bkmkstart stylerid1_2E7_2E7_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abatement of public health and safety hazards \u8212\'3f special assessments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the abatement of a nuisance, public or private, in any reasonable manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the removal of diseased trees or dead wood, except on publicly owned property or right-of-way.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the removal, repair, or dismantling of an abandoned or dangerous building or structure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the numbering of buildings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require connection to public drainage systems from abutting property when necessary for public health or safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the cutting or destruction of weeds or other growth which constitutes a health, safety, or fire hazard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the property owner does not perform an action required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ within a reasonable time after notice, a county may perform the required action and assess the costs against the property for collection in the same manner as a property tax. Notice may be in the form of an ordinance or by certified mail to the property owner as shown by the records of the county auditor, and shall state the time within which action is required. However, in an emergency, a county may perform any action which may be required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ without prior notice and assess the costs as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ after notice to the property owner and hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any amount assessed against property under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ exceeds five hundred dollars, a county may permit the assessment to be paid in up to ten annual installments in the same manner and with the same interest rates provided for assessments against benefited property under }}}{{\f5\fs18\hyphpar0\qj{chapter 384, subchapter IV}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special assessment levied pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including all interest and penalties, is a lien against the benefited property from the date of filing the schedule of assessments until the assessment is paid. A special assessment has equal precedence with ordinary taxes and is not divested by judicial sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The procedures for making and levying a special assessment pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and for an appeal of the assessment are the same procedures as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 384.59 through 384.67}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 384.72 through 384.75}}}{{\f5\fs18\hyphpar0\qj{, provided that the references in those sections to the council shall be to the board of supervisors and the references to the city shall be to the county.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1197, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1204, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a797}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.385}}}{\*\bkmkstart stylerid1_2E7_2E7_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and duties relating to emergency services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may, by resolution, assume the exercise of the powers and duties of township trustees relating to fire protection service and emergency medical service for any township located in the unincorporated area of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors shall publish notice of the proposed resolution, and of a public hearing to be held on the proposed resolution, in a newspaper of general circulation in the county at least ten days but no more than twenty days before the date of the public hearing. If, after notice and hearing, the resolution is adopted, the board of supervisors shall assume the exercise of the powers and duties of township trustees relating to fire protection service and emergency medical service as set forth in }}}{{\f5\fs18\hyphpar0\qj{sections 359.42 through 359.45}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of the real and personal township property used to provide fire protection service or emergency medical service shall be transferred to the county. The county shall assume all of the outstanding obligations of the township relating to fire protection service or emergency medical service. If the township provides fire protection outside of the county\u8217\'3fs boundaries, the county shall continue to provide fire protection to this area for at least ninety days after adoption of the resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fire protection service and emergency medical service shall be paid from the emergency services fund of the county authorized in }}}{{\f5\fs18\hyphpar0\qj{section 331.424C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, if as of July 1, 2006, a township has in force an agreement entered into pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ for a city or another township to provide fire protection service or fire protection service and emergency medical service for the township, or if a township is otherwise contracting with a city or another township for provision to the township of fire protection service or fire protection service and emergency medical service, the county board of supervisors shall, for the fiscal year beginning July 1, 2007, and subsequent fiscal years, negotiate for and enter into an agreement pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ providing for continued fire protection service, or fire protection service and emergency medical service, to the township, and shall certify taxes for levy in the township, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.424C}}}{{\f5\fs18\hyphpar0\qj{, in amounts sufficient to meet the financial obligations pertaining to the agreement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies to a county with a population in excess of three hundred thousand. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a county with a population in excess of three hundred thousand from also assuming the powers and duties of township trustees in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 4}}}{{\f5\fs18\hyphpar0\qj{, for those townships in the county that are not subject to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1117, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1146, \'a71, 2}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 74, \'a71, 3, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.424C}}}{{\f5\fs12\hyphpar0\qj{, 359.42}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.386 and 331.387}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 6}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E8_2E2_2E2}{MENTAL HEALTH AND DISABILITY SERVICES }{{\f5\fs18\qc{\u8212\'3f}}}{ REGIONAL SERVICE SYSTEM }{{\f5\fs18\qc{\u8212\'3f}}}{ CHILDREN\u8217\'3fS BEHAVIORAL HEALTH SYSTEM}{\*\bkmkend stylerid1_2E7_2E8_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.388 through 331.400}}}{Transferred to }{{\f5\fs18\qj{\'a7225C.55}}}{ through }{{\f5\fs18\qj{225C.69}}}{; }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH0140.pdf" }{\fldrslt \f5 \fs18{{2023 Acts, ch 140, \'a715}}}}}}{{\f5\fs18\qj{2023 Acts, ch 140, \'a715}}}{.}\par}{}{\pard\plain\keep\keepn\f5\fs12\qj\fi180\ri0\li0{\f5\fs12\qj}{{\f5\fs12\qj{Chapter 225C}}}{ repealed by }\par}{\pard\plain\keep\keepn\f5\fs12\qj\fi0\ri0\li0\cf5{{\f5\fs12\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1161, \'a7134}}}}}}\par}{\pard\plain\keep\keepn\f5\fs12\qj\fi180\ri0\li0{; for behavioral health service system, see }{{\f5\fs12\qj{chapter 225A}}}\par}{\pard\plain\keep\keepn\f5\fs2\qj\fi0\ri0\li0\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E2_2E2}{POWERS AND DUTIES OF THE BOARD RELATING TO COUNTY FINANCES}{\*\bkmkend stylerid1_2E8_2E2_2E2}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 1}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E3_2E1_2E2}{GENERAL FINANCIAL POWERS AND DUTIES}{\*\bkmkend stylerid1_2E8_2E3_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.401}}}{\*\bkmkstart stylerid1_2E8_2E3_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties relating to finances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Audit expenses charged to the county for the annual examination by the auditor of state and approve or object to the expenses as provided in }}}{{\f5\fs18\hyphpar0\qj{section 11.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish budgets for the farm-to-market road fund and the secondary road fund in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 309.10}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{309.93 through 309.97}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pay expenses of administration of juvenile justice, attributable to the county under }}}{{\f5\fs18\hyphpar0\qj{section 232.141}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the expense of persons committed to the county jail or a regional detention facility in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 356.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt resolutions authorizing the county assessor to provide forms for homestead tax exemption and credit claimants as provided in }}}{{\f5\fs18\hyphpar0\qj{section 425.2}}}{{\f5\fs18\hyphpar0\qj{ and military service tax exemptions as provided in }}}{{\f5\fs18\hyphpar0\qj{section 426A.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Examine and allow or disallow claims for homestead tax exemption and credit in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 425.3}}}{{\f5\fs18\hyphpar0\qj{ and claims for military service tax exemption in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 426A}}}{{\f5\fs18\hyphpar0\qj{. The board, by a single resolution, may allow or disallow the exemptions recommended by the assessor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hear appeals relating to the agricultural land tax credit in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 426.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Order the suspension of property taxes of certain persons in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 427.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approve or deny an application for a property tax exemption for impoundment structures, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 427.1, subsection 20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serve on the conference board as provided in }}}{{\f5\fs18\hyphpar0\qj{section 441.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Levy taxes as certified to it by tax-certifying bodies in the county, in accordance with the statutes authorizing the levies and in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 24}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 444.1 through 444.4}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{sections 444.6 through 444.8}}}{{\f5\fs18\hyphpar0\qj{, and levy taxes as required in }}}{{\f5\fs18\hyphpar0\qj{chapters 434}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{437}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{438}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out duties in regard to the collection of taxes as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 445.16}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{445.60}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{445.62}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Apportion taxes upon receipt of a petition, in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 449.1A through 449.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Comply with }}}{{\f5\fs18\hyphpar0\qj{chapters 12B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{12C}}}{{\f5\fs18\hyphpar0\qj{ in the management of public funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allocate payments from flood control projects as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 161E.13}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{161E.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Examine and settle all accounts of the receipts and expenditures of the county and all claims against the county, except as otherwise provided by state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require a local historical society to submit to it a proposed budget, including the amount of available funds and estimated expenditures, as a prerequisite to receiving funds. A local historical society receiving funds shall present to the board an annual report describing in detail its use of the funds received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Retain overpayments of moneys paid to the county in an amount of five dollars or less, unless the payor has requested a refund of the overpayment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Perform other financial duties as required by state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall not pay membership dues for a county officers association in this state other than the Iowa state association of counties or an organization affiliated with it. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit expenditures for organizations with which the Iowa state association or its affiliates are affiliated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall not pay bounties on crows, rattlesnakes, foxes, or wolves other than coyotes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall not approve for payment to the auditor, treasurer, recorder, sheriff, county attorney, or to a supervisor a separation allowance or severance pay.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{a \u8211\'3f o.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.401(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7400}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{p.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[R60, \'a7312; C73, \'a7303; C97, \'a7422; SS15, \'a7422; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5130;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.3(5)}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.401(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7400}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{r.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.401(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7400}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.3(27)}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.401(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7400}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[79, 81, \'a7350.2; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.401(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7400}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7132 \u8211\'3f 135, 209}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1001, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1236, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1150, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 75, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 185, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 55, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1158, \'a72, 28}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7203}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a727, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.902}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 1, paragraphs e and f applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.402}}}{\*\bkmkstart stylerid1_2E8_2E3_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers relating to finances \u8212\'3f limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The payment of county obligations by anticipatory warrants is subject to }}}{{\f5\fs18\hyphpar0\qj{chapters 74}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{74A}}}{{\f5\fs18\hyphpar0\qj{ and other applicable state law. Anticipatory warrants drawn on the secondary road fund are also subject to }}}{{\f5\fs18\hyphpar0\qj{sections 309.46 through 309.55}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require a person who is not a part of county government but is receiving county funds to submit to audit by auditors chosen by the county. The person shall make available all pertinent records needed for the audit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter into an agreement with the department of health and human services for assistance in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 249A.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Levy within a township at a rate not to exceed the rate permitted under }}}{{\f5\fs18\hyphpar0\qj{sections 359.30}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{359.33}}}{{\f5\fs18\hyphpar0\qj{ for the care and maintenance of cemeteries, if the township officials fail to levy the tax as needed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorize the county auditor to issue warrants for certain purposes as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.506, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorize the auditor to issue checks in lieu of warrants. The checks shall be charged directly against a bank account controlled by the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Impose a hotel and motel tax in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 423A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Order the suspension of property taxes or cancel and remit the taxes of certain persons as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 427.8}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{427.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for a partial exemption from property taxation in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 427B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contract with certified public accountants to conduct the annual audit of the financial accounts and transactions of the county as provided in }}}{{\f5\fs18\hyphpar0\qj{section 11.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may enter into loan agreements to borrow money for any public purpose in accordance with the following terms and procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A loan agreement entered into by a county may contain provisions similar to those sometimes found in loan agreements between private parties, including, but not limited to, the issuance of notes to evidence its obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision of a loan agreement which stipulates that a portion of the payments be applied as interest is subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{. Other laws relating to interest rates do not apply. }}}{{\f5\fs18\hyphpar0\qj{Chapter 75}}}{{\f5\fs18\hyphpar0\qj{ is not applicable. A county enterprise is a separate entity under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, whether it is governed by the board or another governing body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall follow substantially the same authorization procedure required for the issuance of general obligation bonds issued for the same purpose to authorize a loan agreement made payable from the debt service fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may authorize a loan agreement which is payable from the general fund if the loan agreement would not cause the total of scheduled annual payments of principal or interest or both principal and interest due from the general fund of the county in any single future fiscal year with respect to all loan agreements in force on the date of the authorization to exceed ten percent of the last certified general fund budget amount in accordance with the following procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall follow substantially the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 331.443}}}{{\f5\fs18\hyphpar0\qj{ to authorize a loan agreement for personal property which is payable from the general fund. The board must follow substantially the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 331.443}}}{{\f5\fs18\hyphpar0\qj{ to authorize a loan agreement for real property which is payable from the general fund if the principal amount of the loan agreement does not exceed the following limits:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five hundred twenty thousand dollars in a county having a population of twenty-five thousand or less.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six hundred fifty thousand dollars in a county having a population of more than twenty-five thousand but not more than fifty thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seven hundred eighty thousand dollars in a county having a population of more than fifty thousand but not more than one hundred thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One million forty thousand dollars in a county having a population of more than one hundred thousand but not more than two hundred thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One million three hundred thousand dollars in a county having a population of more than two hundred thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board must follow the following procedures to authorize a loan agreement for real property which is payable from the general fund if the principal amount of the loan agreement exceeds the limits set forth in subparagraph (1):}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board must institute proceedings for entering into a loan agreement payable from the general fund by causing a notice of the meeting to discuss entering into the loan agreement, including a statement of the principal amount and purpose of the loan agreement and the right to petition for an election, to be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{ at least ten days prior to the discussion meeting. No sooner than thirty days following the discussion meeting shall the board hold a meeting at which it is proposed to take action to enter into the loan agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time before the end of the thirty-day period after which a meeting may be held to take action to enter into the loan agreement, a petition is filed with the auditor in the manner provided by }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{ asking that the question of entering into the loan agreement be submitted to the registered voters of the county, the board shall either by resolution declare the proposal to enter into the loan agreement to have been abandoned or shall direct the county commissioner of elections to call a special election upon the question of entering into the loan agreement. However, for purposes of this subparagraph (2), the petition shall not require signatures in excess of one thousand persons.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The question to be placed on the ballot shall be stated affirmatively in substantially the following manner:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the county of }{{\f5\fs18\hyphpar0\qj{....................}}}{ enter into a loan agreement in amount of $ }{{\f5\fs18\hyphpar0\qj{........}}}{ for the purpose of ....................?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of the election and its conduct shall be in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.442, subsections 2 through 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a petition is not filed or if a petition is filed and the proposition of entering into the loan agreement is approved at an election, the board may proceed and enter into the loan agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body may authorize a loan agreement payable from the net revenues of a county enterprise or combined county enterprise by following the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 331.464}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A loan agreement to which a county is a party or in which a county has a participatory interest is an obligation of a political subdivision of this state for the purpose of }}}{{\f5\fs18\hyphpar0\qj{chapters 502}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{636}}}{{\f5\fs18\hyphpar0\qj{, and is a lawful investment for banks, trust companies, savings associations, investment companies, insurance companies, insurance associations, executors, guardians, trustees, and any other fiduciaries responsible for the investment of funds.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.402(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7401}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{a.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.3(31)}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.402(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7401}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{b.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.402(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7401}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a724.37(14)}}}{, }{{\f5\fs18\hyphpar0\qj{332.3(30)}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.402(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7401}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{d \u8211\'3f g.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.402(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7401}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1123, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 103, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1138, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 45, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 100, \'a79, 21}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7135}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a785}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7204}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71103}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a7139, 154}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.403}}}{\*\bkmkstart stylerid1_2E8_2E3_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual reports }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ financial report }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ urban renewal report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than December 1 of each year on forms and pursuant to instructions prescribed by the department of management, a county shall prepare an annual financial report showing for each county fund the financial condition as of June 30 and the results of operations for the year then ended. Copies of the report shall be maintained as a public record at the auditor\u8217\'3fs office and shall be filed with the director of the department of management and with the auditor of state by December 1. A summary of the report, in a form prescribed by the director, shall be published by each county not later than December 1 of each year in one or more newspapers which meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 618.14}}}{{\f5\fs18\hyphpar0\qj{. Beginning with the annual financial report filed by December 1, 2025, each report shall include a list of bonds, notes, or other obligations issued by the county during the most recently completed fiscal year, and the applicable lists for other fiscal years beginning on or after July 1, 2024, for which obligations remain unpaid, payable from any source, including the amount of the issuance, the project or purpose of the issuance, whether the issuance was approved at election, eligible to be subject to a petition for an election, or was exempt from approval at election as the result of statutory exclusions based on population of the county or amount of the issuance, and identification of issuances from the fiscal year or prior fiscal years related to the same project or purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning with the fiscal year ending June 30, 1985, the annual financial report required in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be prepared in conformity with generally accepted accounting principles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each county that had an urban renewal plan and area in effect at any time during the most recently ended fiscal year shall complete for each such urban renewal plan and area and file with the department of management an urban renewal report by December 1 following the end of such fiscal year. Each report shall be approved by the affirmative vote of a majority of the board and be prepared in the format and submitted electronically pursuant to the instructions prescribed by the department of management in consultation with the legislative services agency.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The report required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall include all of the following as of June 30 of the most recently ended fiscal year or the information for such fiscal year, as applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the urban renewal area is determined by the county to be a slum area, blighted area, economic development area or a combination of those areas, and the date such determination was made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A map clearly identifying the boundaries of the urban renewal area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the ordinance providing for a division of revenue in the urban renewal area under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the urban renewal plan adopted for the urban renewal area, the date of each amendment to the plan, and a copy of such amendment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list and description of all urban renewal projects within the urban renewal area that are in process and all urban renewal projects that were completed during the fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of each expenditure during the fiscal year from the county\u8217\'3fs special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{. Each such expenditure shall be classified by the county according to categories established by the department of management and shall be designated as corresponding to the specific loan, advance, indebtedness, or bond which qualifies for payment from the special fund under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{. Each such expenditure shall also be designated as corresponding to one or more specific urban renewal projects. This description shall not be required for the report required to be filed on or before December 1, 2012.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of loans, advances, indebtedness, or bonds, including interest negotiated on such loans, advances, indebtedness, or bonds, which qualify for payment from the special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{, and which were incurred or issued during the fiscal year. Each such loan, advance, debt, or bond shall be classified by the county according to categories established by the department of management and shall be designated as corresponding to one or more specific urban renewal projects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of loans, advances, indebtedness, or bonds that remain unpaid at the close of the fiscal year, and which qualify for payment from the special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{, including interest negotiated on such loans, advances, indebtedness, or bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total amount of property taxes that were exempted, rebated, refunded, or reimbursed by the county, used to fund a grant provided by the county, or directly paid by the county during the fiscal year for property in the urban renewal area using moneys in the county\u8217\'3fs special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ and such amounts agreed to by the county for future fiscal years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list of all properties, including the owner of such properties, and the amount of property taxes due and payable for the fiscal year that were exempted, rebated, refunded, or reimbursed by the county, used to fund a grant provided by the county, or directly paid by the county during the fiscal year using moneys in the county\u8217\'3fs special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ and information for such amounts agreed to by the county for future fiscal years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The balance of the county\u8217\'3fs special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The aggregate assessed value of the taxable property in the urban renewal area, as shown on the assessment roll used to calculate the amount of taxes under }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The aggregate assessed value of each classification of taxable property located in the urban renewal area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(14)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That portion of the assessed value of all taxable property located in the urban renewal area that was used to calculate the amount of excess taxes under }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(15)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of taxes determined under }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, in excess of the amount required to pay the applicable loans, advances, indebtedness, and bonds, if any, and interest thereon, for the fiscal year that was paid into the funds for the respective taxing districts in the same manner as taxes on all other property. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(16)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest or earnings received by each urban renewal area during the fiscal year on amounts deposited into the special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ and the net proceeds during the fiscal year from the sale of assets purchased using amounts deposited into the special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(17)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each taxing district for which the county divided taxes, the amount of taxes determined under }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, that, in lieu of allocation to the taxing district, were deposited into the county\u8217\'3fs special fund during the fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(18)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of expenditures by the county during the fiscal year for the purpose of providing or aiding in the provision of public improvements related to housing and residential development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(19)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of assistance to low and moderate income housing provided by the county under }}}{{\f5\fs18\hyphpar0\qj{section 403.22}}}{{\f5\fs18\hyphpar0\qj{ during the fiscal year if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(20)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When required as part of an urban renewal development or redevelopment agreement that includes the use of incremental taxes collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the total number of jobs to be created, the wages associated with those jobs, the total private capital investment, and the total cost of the public infrastructure constructed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(21)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All other additional information or documentation relating to a county\u8217\'3fs urban renewal activities or use of divisions of revenue under }}}{{\f5\fs18\hyphpar0\qj{chapter 403}}}{{\f5\fs18\hyphpar0\qj{ deemed relevant by the department of management, in consultation with the county finance committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By December 1, 2012, the department of management, in collaboration with the legislative services agency, shall make publicly available on an internet site a searchable database of all such information contained in the reports required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Reports from previous years shall be retained by the department and shall continue to be available and searchable on the internet site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legislative services agency, in consultation with the department of management, shall annually prepare a report for submission to the governor and the general assembly that summarizes and analyzes the information contained in the reports submitted under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 357H.9, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 384.22, subsection 2}}}{{\f5\fs18\hyphpar0\qj{. The report prepared by the legislative services agency shall be submitted not later than February 15 following the most recently ended fiscal year for which the reports were filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3findebtedness\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to written agreements whereby the county agrees to exempt, rebate, refund, or reimburse property taxes, provide a grant for property taxes paid, or make a direct payment of taxes, with moneys in the special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{, and bonds, notes, or other obligations that are secured by or subject to repayment from moneys appropriated by the county from moneys in the special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual financial report shall be prepared on forms and pursuant to instructions prescribed by the department of management and shall be filed with the department of management. The urban renewal report shall be filed with the department of management. Each report must be filed prior to the publication and adoption of the county budget under }}}{{\f5\fs18\hyphpar0\qj{section 331.434}}}{{\f5\fs18\hyphpar0\qj{ for the fiscal year beginning July 1 following the date such reports are due. If such reports are not filed pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the department of management shall not certify the county\u8217\'3fs taxes back to the county auditor under }}}{{\f5\fs18\hyphpar0\qj{section 24.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a72, 209}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 206, \'a714, 15, 24}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1124, \'a75, 6, 25}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a7140, 154}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a711.11}}}{{\f5\fs12\hyphpar0\qj{, 331.431}}}{{\f5\fs12\hyphpar0\qj{, 331.434}}}{{\f5\fs12\hyphpar0\qj{, 333A.4}}}{{\f5\fs12\hyphpar0\qj{, 357H.9}}}{{\f5\fs12\hyphpar0\qj{, 403.5}}}{{\f5\fs12\hyphpar0\qj{, 403.23}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.404 to 331.420}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 2}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E4_2E1_2E2}{COUNTY LEVIES, FUNDS, BUDGETS,}{\*\bkmkend stylerid1_2E8_2E4_2E1_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{AND EXPENDITURES}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.421}}}{\*\bkmkstart stylerid1_2E8_2E4_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in this part, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBasic levy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a levy authorized and limited by }}}{{\f5\fs18\hyphpar0\qj{section 331.423}}}{{\f5\fs18\hyphpar0\qj{ for general county services and rural county services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommittee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the county finance committee established in }}}{{\f5\fs18\hyphpar0\qj{chapter 333A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDebt service\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means expenditures for servicing the county\u8217\'3fs debt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDebt service levy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a levy authorized and limited by }}}{{\f5\fs18\hyphpar0\qj{section 331.422, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmergency services levy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a levy authorized and limited by }}}{{\f5\fs18\hyphpar0\qj{section 331.424C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFiscal year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the period of twelve months beginning July 1 and ending on the following June 30.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGeneral county services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the services which are primarily intended to benefit all residents of a county, including secondary road services, but excluding services financed by other statutory funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRural county services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the services which are primarily intended to benefit those persons residing in the county outside of incorporated city areas, including secondary road services, but excluding services financed by other statutory funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSecondary road services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the services related to secondary road construction and maintenance, excluding debt service and services financed by other statutory funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSupplemental levy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a levy authorized and limited by }}}{{\f5\fs18\hyphpar0\qj{section 331.424}}}{{\f5\fs18\hyphpar0\qj{ for general county services and rural county services.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a75, 209}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1178, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1237, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1117, \'a719}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.422}}}{\*\bkmkstart stylerid1_2E8_2E4_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County property tax levies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Subject to }{{\f5\fs18\hyphpar0\qj{this section}}}{ and }{{\f5\fs18\hyphpar0\qj{sections 331.423 through 331.425}}}{ or as otherwise provided by state law, the board of each county shall certify property taxes annually at its April session to be levied for county purposes as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Taxes for general county services shall be levied on all taxable property within the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Taxes for rural county services shall be levied on all taxable property not within incorporated areas of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Taxes in the amount necessary for debt service shall be levied on all taxable property within the county, except as otherwise provided by state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other taxes shall be levied as provided by state law.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a76, 209}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a71, 10, 80, 98}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.421}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to unnumbered paragraph 1 by }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH71.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 71, \'a71}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{ applies to taxes and budgets for fiscal years beginning on or after July 1, 2024; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a710}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to unnumbered paragraph 1 by }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH71.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 71, \'a780}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{ applies to political subdivision budgets for fiscal years beginning on or after July 1, 2024; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH71.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 71, \'a798}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.423}}}{\*\bkmkstart stylerid1_2E8_2E4_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Basic levies }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ maximums }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ adjustments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Annually, the board may certify basic levies, subject to the following limits:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For general county services on all taxable property in the county:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For fiscal years beginning before July 1, 2024, three dollars and fifty cents per thousand dollars of assessed value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each fiscal year beginning on or after July 1, 2024, but before July 1, 2028, subject to subparagraph (3), the greater of three dollars and fifty cents per thousand dollars of assessed value used to calculate taxes for general county services for the budget year and the adjusted general county basic levy rate, as adjusted under subparagraph (2), if applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the total assessed value used to calculate taxes for general county services under this paragraph for the budget year exceeds one hundred two and seventy-five hundredths percent, but is less than one hundred four percent, of the total assessed value used to calculate taxes for general county services for the current fiscal year, the adjusted general county basic levy rate, as previously adjusted under this subparagraph, if applicable, shall be reduced to a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred one percent of the total assessed value used to calculate such taxes for the current fiscal year. For the budget year beginning July 1, 2024, only, the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall also include property tax dollar amounts levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the total assessed value used to calculate taxes for general county services under this paragraph for the budget year is equal to or exceeds one hundred four percent, but is less than one hundred six percent, of the total assessed value used to calculate taxes for general county services for the current fiscal year, the adjusted general county basic levy rate, as previously adjusted under this subparagraph, if applicable, shall be reduced to a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred two percent of the total assessed value used to calculate such taxes for the current fiscal year. For the budget year beginning July 1, 2024, only, the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall also include property tax dollar amounts levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the total assessed value used to calculate taxes for general county services under this paragraph for the budget year is equal to or exceeds one hundred six percent of the total assessed value used to calculate taxes for general county services for the current fiscal year, the adjusted general county basic levy rate, as previously adjusted under this subparagraph, if applicable, shall be reduced to a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred three percent of the total assessed value used to calculate such taxes for the current fiscal year. For the budget year beginning July 1, 2024, only, the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall also include property tax dollar amounts levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the limitation under subparagraph (2), if the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year is three dollars and fifty cents or less per thousand dollars of assessed value and the total assessed value used to calculate taxes for general county services under this paragraph for the budget year exceeds one hundred two and seventy-five hundredths percent, but is less than one hundred four percent, of the total assessed value used to calculate taxes for general county services for the current fiscal year, the levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the budget year shall not exceed a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred one percent of the total assessed value used to calculate taxes for general county services for the current fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the budget year beginning July 1, 2024, only, the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year shall also include the amount per thousand dollars of assessed value levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023, and the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall also include amounts levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the limitation under subparagraph (2), if the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year is three dollars and fifty cents or less per thousand dollars of assessed value and the total assessed value used to calculate taxes for general county services under this paragraph for the budget year is equal to or exceeds one hundred four percent, but is less than one hundred six percent, of the total assessed value used to calculate taxes for general county services for the current fiscal year, the levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the budget year shall not exceed a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred two percent of the total assessed value used to calculate taxes for general county services for the current fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the budget year beginning July 1, 2024, only, the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year shall also include the amount per thousand dollars of assessed value levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023, and the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall also include amounts levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the limitation under subparagraph (2), if the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year is three dollars and fifty cents or less per thousand dollars of assessed value and the total assessed value used to calculate taxes for general county services under this paragraph for the budget year is equal to or exceeds one hundred six percent of the total assessed value used to calculate taxes for general county services for the current fiscal year, the levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the budget year shall not exceed a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred three percent of the total assessed value used to calculate taxes for general county services for the current fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the budget year beginning July 1, 2024, only, the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year shall also include the amount per thousand dollars of assessed value levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023, and the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall also include amounts levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to adjustment under subparagraph (2), for purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadjusted general county basic levy rate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a levy rate per thousand dollars of assessed value equal to the sum of three dollars and fifty cents plus the amount per thousand dollars of assessed value levied for general county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each fiscal year beginning on or after July 1, 2028, three dollars and fifty cents per thousand dollars of assessed value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For rural county services on all taxable property in the county outside of incorporated city areas:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For fiscal years beginning before July 1, 2024, three dollars and ninety-five cents per thousand dollars of assessed value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each fiscal year beginning on or after July 1, 2024, but before July 1, 2028, subject to subparagraph (3), the greater of three dollars and ninety-five cents per thousand dollars of assessed value used to calculate taxes for rural county services for the budget year and the adjusted rural county basic levy rate, as adjusted under subparagraph (2), if applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the total assessed value used to calculate taxes for rural county services under this paragraph for the budget year exceeds one hundred two and seventy-five hundredths percent, but is less than one hundred four percent, of the total assessed value used to calculate taxes for rural county services for the current fiscal year, the adjusted rural county basic levy rate, as previously adjusted under this subparagraph, if applicable, shall be reduced to a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred one percent of the total assessed value used to calculate such taxes for the current fiscal year. For the budget year beginning July 1, 2024, only, the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall also include property tax dollar amounts levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the total assessed value used to calculate taxes for rural county services under this paragraph for the budget year is equal to or exceeds one hundred four percent, but is less than one hundred six percent, of the total assessed value used to calculate taxes for rural county services for the current fiscal year, the adjusted rural county basic levy rate, as previously adjusted under this subparagraph, if applicable, shall be reduced to a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred two percent of the total assessed value used to calculate such taxes for the current fiscal year. For the budget year beginning July 1, 2024, only, the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall also include property tax dollar amounts levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the total assessed value used to calculate taxes for rural county services under this paragraph for the budget year is equal to or exceeds one hundred six percent of the total assessed value used to calculate taxes for rural county services for the current fiscal year, the adjusted rural county basic levy rate, as previously adjusted under this subparagraph, if applicable, shall be reduced to a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred three percent of the total assessed value used to calculate such taxes for the current fiscal year. For the budget year beginning July 1, 2024, only, the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall also include property tax dollar amounts levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the limitation under subparagraph (2), if the county\u8217\'3fs actual levy rate imposed under this paragraph for the current fiscal year is three dollars and ninety-five cents or less per thousand dollars of assessed value and the total assessed value used to calculate taxes for rural county services under this paragraph for the budget year exceeds one hundred two and seventy-five hundredths percent, but is less than one hundred four percent, of the total assessed value used to calculate taxes for rural county services for the current fiscal year, the levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ for the budget year shall not exceed a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred one percent of the total assessed value used to calculate taxes for rural county services for the current fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the budget year beginning July 1, 2024, only, the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year shall also include the amount per thousand dollars of assessed value levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023, and the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall also include amounts levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the limitation under subparagraph (2), if the county\u8217\'3fs actual levy rate imposed under this paragraph for the current fiscal year is three dollars and ninety-five cents or less per thousand dollars of assessed value and the total assessed value used to calculate taxes for rural county services under this paragraph for the budget year exceeds one hundred four percent, but is less than one hundred six percent, of the total assessed value used to calculate taxes for rural county services for the current fiscal year, the levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ for the budget year shall not exceed a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred two percent of the total assessed value used to calculate taxes for rural county services for the current fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the budget year beginning July 1, 2024, only, the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year shall also include the amount per thousand dollars of assessed value levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023, and the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall also include amounts levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the limitation under subparagraph (2), if the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year is three dollars and ninety-five cents or less per thousand dollars of assessed value and the total assessed value used to calculate taxes for rural county services under this paragraph for the budget year is equal to or exceeds one hundred six percent of the total assessed value used to calculate taxes for rural county services for the current fiscal year, the levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ for the budget year shall not exceed a rate per thousand dollars of assessed value that is equal to one thousand multiplied by the quotient of the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ divided by one hundred three percent of the total assessed value used to calculate taxes for rural county services for the current fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the budget year beginning July 1, 2024, only, the county\u8217\'3fs actual levy rate imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ for the current fiscal year shall also include the amount per thousand dollars of assessed value levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023, and the current fiscal year\u8217\'3fs actual property tax dollars certified for levy under }}}{{\f5\fs18\hyphpar0\qj{this subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall also include amounts levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to adjustment under subparagraph (2), for purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadjusted rural county basic levy rate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a levy rate per thousand dollars of assessed value equal to the sum of three dollars and ninety-five cents plus the amount per thousand dollars of assessed value levied for rural county services by the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.426, Code 2023}}}{{\f5\fs18\hyphpar0\qj{, for the fiscal year beginning July 1, 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each fiscal year beginning on or after July 1, 2028, three dollars and ninety-five cents per thousand dollars of assessed value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBudget year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is the fiscal year beginning during the calendar year in which a budget is certified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCurrent fiscal year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is the fiscal year ending during the calendar year in which a budget for the budget year is certified.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a77, 209}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1237, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a72, 10}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 153, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a755, 56, 58}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728M.5}}}{{\f5\fs12\hyphpar0\qj{, 331.421}}}{{\f5\fs12\hyphpar0\qj{, 331.422}}}{{\f5\fs12\hyphpar0\qj{, 331.424}}}{{\f5\fs12\hyphpar0\qj{, 331.425}}}{{\f5\fs12\hyphpar0\qj{, 331.434}}}{{\f5\fs12\hyphpar0\qj{, 331.435}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment by }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH71.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 71, \'a72}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{ applies to taxes and budgets for fiscal years beginning on or after July 1, 2024; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a710}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1, paragraph b, subparagraphs (2) and (3) applies to taxes and budgets for fiscal years beginning on or after July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a758}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 2, paragraph b, subparagraphs (2) and (3) applies to taxes and budgets for fiscal years beginning on or after July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a758}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.424}}}{\*\bkmkstart stylerid1_2E8_2E4_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supplemental levies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{To the extent that the basic levies under }{{\f5\fs18\hyphpar0\qj{section 331.423}}}{ are insufficient to meet the county\u8217\'3fs needs for the following services, the board may certify supplemental levies as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For general county services, an amount sufficient to pay the charges for the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the extent that the county is obligated by statute to pay the charges for:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs of inpatient or outpatient substance use disorder admission, commitment, transportation, care, and treatment at any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alcoholic treatment center at Oakdale. However, the county may require that an admission to the center shall be reported to the board by the center within five days as a condition of the payment of county funds for that admission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state mental health institute, or a community-based public or private facility or service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Clothing, transportation, medical, or other services provided persons attending the Iowa school for the deaf or the university of Iowa hospitals and clinics\u8217\'3f center for disabilities and development for children with severe disabilities at Iowa City, for which the county becomes obligated to pay pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 263.12}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{256.99}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Foster care and related services provided under court order to a child who is under the jurisdiction of the juvenile court, including court-ordered costs for a guardian ad litem under }}}{{\f5\fs18\hyphpar0\qj{section 232.71C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Elections, and voter registration pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 48A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employee benefits under }}}{{\f5\fs18\hyphpar0\qj{chapters 96}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{97B}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{97C}}}{{\f5\fs18\hyphpar0\qj{, which are associated with salaries for general county services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tort liability insurance, property insurance, and any other insurance that may be necessary in the operation of the county, costs of a self-insurance program, costs of a local government risk pool, and amounts payable under any insurance agreements to provide or procure such insurance, self-insurance program, or local government risk pool.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maintenance and operation of the courts, including but not limited to the salary and expenses of the clerk of the district court and other employees of the clerk\u8217\'3fs office, and bailiffs, court costs if the prosecution fails or if the costs cannot be collected from the person liable, costs and expenses of prosecution under }}}{{\f5\fs18\hyphpar0\qj{section 189A.17}}}{{\f5\fs18\hyphpar0\qj{, salaries and expenses of juvenile court officers under }}}{{\f5\fs18\hyphpar0\qj{chapter 602}}}{{\f5\fs18\hyphpar0\qj{, court-ordered costs in domestic abuse cases under }}}{{\f5\fs18\hyphpar0\qj{section 236.5}}}{{\f5\fs18\hyphpar0\qj{, sexual abuse cases under }}}{{\f5\fs18\hyphpar0\qj{section 236A.7}}}{{\f5\fs18\hyphpar0\qj{, and elder abuse cases under }}}{{\f5\fs18\hyphpar0\qj{section 235F.6}}}{{\f5\fs18\hyphpar0\qj{, the county\u8217\'3fs expense for confinement of prisoners under }}}{{\f5\fs18\hyphpar0\qj{chapter 356A}}}{{\f5\fs18\hyphpar0\qj{, temporary assistance to the county attorney, county contributions to a retirement system for bailiffs, reimbursement for judicial magistrates under }}}{{\f5\fs18\hyphpar0\qj{section 602.6501}}}{{\f5\fs18\hyphpar0\qj{, claims filed under }}}{{\f5\fs18\hyphpar0\qj{section 622.93}}}{{\f5\fs18\hyphpar0\qj{, sign language interpreters\u8217\'3f fees under }}}{{\f5\fs18\hyphpar0\qj{section 622B.7}}}{{\f5\fs18\hyphpar0\qj{, uniform citation and complaint supplies under }}}{{\f5\fs18\hyphpar0\qj{section 805.6}}}{{\f5\fs18\hyphpar0\qj{, and costs of prosecution under }}}{{\f5\fs18\hyphpar0\qj{section 815.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Court-ordered costs of conciliation procedures under }}}{{\f5\fs18\hyphpar0\qj{section 598.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishment and maintenance of a joint county indigent defense fund pursuant to an agreement under }}}{{\f5\fs18\hyphpar0\qj{section 28E.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maintenance and operation of a local emergency management agency established pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 29C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may require a public or private facility, as a condition of receiving payment from county funds for services it has provided, to furnish the board with a statement of the income, assets, and legal residence including township and county of each person who has received services from that facility for which payment has been made from county funds under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) and (2). However, the facility shall not disclose to anyone the name or street or route address of a person receiving services for which commitment is not required, without first obtaining that person\u8217\'3fs written permission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parents or other persons may voluntarily reimburse the county or state for the reasonable cost of caring for a patient or an inmate in a county or state facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For rural county services, an amount sufficient to pay the charges for the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employee benefits under }}}{{\f5\fs18\hyphpar0\qj{chapters 96}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{97B}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{97C}}}{{\f5\fs18\hyphpar0\qj{, which are associated with salaries for rural county services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An aviation authority under }}}{{\f5\fs18\hyphpar0\qj{chapter 330A}}}{{\f5\fs18\hyphpar0\qj{, to the extent that the county contributes to the authority under }}}{{\f5\fs18\hyphpar0\qj{section 330A.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a78, 209}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1178, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1312, \'a78}}}{{\f