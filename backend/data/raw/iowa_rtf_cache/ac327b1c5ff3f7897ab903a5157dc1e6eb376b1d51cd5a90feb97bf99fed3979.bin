{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county zoning commission, an administrative officer, and a board of adjustment in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 335.8 through 335.11}}}{{\f5\fs18\hyphpar0\qj{, if the board adopts county zoning under }}}{{\f5\fs18\hyphpar0\qj{chapter 335}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A board of library trustees in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 336.4}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{336.5}}}{{\f5\fs18\hyphpar0\qj{, if a proposition to establish a library district has been approved by the voters, or }}}{{\f5\fs18\hyphpar0\qj{section 336.18}}}{{\f5\fs18\hyphpar0\qj{ if a proposition to provide library service by contract has been approved by the voters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local representatives to serve with the city development board as provided in }}}{{\f5\fs18\hyphpar0\qj{section 368.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{t.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of a city planning and zoning commission and board of adjustment when a city extends its zoning powers outside the city limits, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 414.23}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{u.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list of residents eligible to serve as a compensation commission in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 6B.4}}}{{\f5\fs18\hyphpar0\qj{, in condemnation proceedings under }}}{{\f5\fs18\hyphpar0\qj{chapter 6B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{v.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the county judicial magistrate appointing commission in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 602.6503}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{w.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of a county enterprise commission or joint county enterprise commission if the commission is approved by the voters as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.471}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{x.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other officers and agencies as required by state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board proposes to appoint a county surveyor, it shall appoint a person qualified in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 542B}}}{{\f5\fs18\hyphpar0\qj{ and provide the surveyor with a suitable book in which to record field notes and plats.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided by state law, a person appointed as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ may be removed by the board by written order. The order shall give the reasons and be filed in the office of the auditor, and a copy shall be sent by certified mail to the person removed who, upon request filed with the auditor within thirty days of the date of mailing the copy, shall be granted a public hearing before the board on all issues connected with the removal. The hearing shall be held within thirty days of the date the request is filed unless the person removed requests a later date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A board or commission appointed by the board of supervisors shall notify the county auditor of the name and address of its clerk or secretary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A supervisor serving on another county board or commission shall be paid only as a supervisor for a day which includes official service on both boards.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.321(1, 2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7320}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7208; R60, \'a7418; C73, \'a7375; C97, \'a7539; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5487;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7355.6}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.321(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7320}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7411; R60, \'a7642; C73, \'a7766; C97, \'a7298, 481, 491, 496, 510; S13, \'a7496; SS15, \'a7298, 481, 491, 510-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5240;}}}{ C46, 50, 54, 58, \'a7341.3; C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7111A.2}}}{, }{{\f5\fs18\hyphpar0\qj{341.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.321(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7320}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.321(5)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7320}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3661.011;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7234.10}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.321(6)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7320}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710070, 10201}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1067, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 227, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1161, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1236, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1139, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1212, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 54, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1173, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1075, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1011, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1057, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 95, \'a71}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2001 Acts, 2nd Ex, ch 4, \'a78, 9}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 110, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1036, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a788, 245}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7196}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71083, 2778}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7111, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7350.2}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsection 1, paragraph e effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph e stricken and former paragraphs f \u8211\'3f y redesignated as e \u8211\'3f x}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.322}}}{\*\bkmkstart stylerid1_2E7_2E4_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties relating to county and township officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require and approve official bonds in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 64}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 636.6}}}{{\f5\fs18\hyphpar0\qj{, and pay the cost of certain officers\u8217\'3f bonds as provided in }}}{{\f5\fs18\hyphpar0\qj{section 64.11}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 331.324, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make temporary appointments in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 66.19}}}{{\f5\fs18\hyphpar0\qj{, when an officer is suspended under }}}{{\f5\fs18\hyphpar0\qj{chapter 66}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fill vacancies in county offices in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 69.8 through 69.12}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 69.14A}}}{{\f5\fs18\hyphpar0\qj{, and make appointments in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 4A.12}}}{{\f5\fs18\hyphpar0\qj{ unless a special election is called pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 69.14A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide suitable offices for the meetings of the county conservation board and the safekeeping of its records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Furnish offices within the county for the sheriff, and at the county seat for the recorder, treasurer, auditor, county attorney, county surveyor or engineer, county assessor, and city assessor. The board shall furnish the officers with fuel, lights, and office supplies. However, the board is not required to furnish the county attorney with law books. The board shall not furnish an office also occupied by a practicing attorney to an officer other than the county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annually prepare and review the compensation schedule, or review the final compensation schedule of the county compensation board if the board of supervisors has established a county compensation board, and determine the final compensation schedule in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 331.907}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide necessary office facilities and the technical and clerical assistance requested by the county compensation board to accomplish the purposes of }}}{{\f5\fs18\hyphpar0\qj{sections 331.905}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{331.907}}}{{\f5\fs18\hyphpar0\qj{, if the board of supervisors has established a county compensation board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide the sheriff with county-owned automobiles or contract for privately owned automobiles as needed for the sheriff and deputies to perform their duties, the need to be determined by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide the sheriff and the sheriff\u8217\'3fs full-time deputies with necessary uniforms and accessories in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 331.657}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pay for the cost of board furnished prisoners in the sheriff\u8217\'3fs custody, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.658}}}{{\f5\fs18\hyphpar0\qj{, appoint and pay salaries of assistants at the jails, furnish supplies, and inspect the jails.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Furnish necessary equipment and materials for the sheriff to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 690.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Install radio materials in the office of the sheriff as provided in }}}{{\f5\fs18\hyphpar0\qj{section 693.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the examination of the accounts of an officer who neglects or refuses to report fees collected, if a report is required by state law. The expense of the examination shall be charged to the officer and collectible on the officer\u8217\'3fs bond.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish and pay compensation of township trustees and township clerk, as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 359.46}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{359.47}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Furnish quarters for meetings of the board of review of assessments.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[R60, \'a7312; C73, \'a7303; C97, \'a7422; SS15, \'a7422; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18