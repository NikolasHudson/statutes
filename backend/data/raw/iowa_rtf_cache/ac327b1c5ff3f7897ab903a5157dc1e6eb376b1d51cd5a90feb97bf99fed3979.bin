 evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the case presents a conflict of interest, the review shall be referred to an independent county attorney, the attorney general, or a special prosecutor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fofficer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4, subsection 11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, SS15, \'a7301; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5180;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7336.2}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.756}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7756}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1021, \'a710, 12(1)}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1100, \'a728}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1104, \'a759}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7111, 112, 157, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1163, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1299, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 195, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1001, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1112, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1155, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1238, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71117}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 30, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 98, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1134, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 197, \'a730}}}{{\f5