\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.510}}}{\*\bkmkstart stylerid1_2E9_2E3_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E3_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports by the auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The auditor shall make:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A report to the governor of a vacancy, except by resignation, in the office of state representative or senator as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A report to the secretary of state of the name, office, and term of office of each appointed or elected county officer within ten days of the officer\u8217\'3fs election or appointment and qualification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An annual report not later than January 1 to the department of management of the valuation by class of property for each taxing district in the county as instructed by and on forms provided by the department of management. The valuations reported shall be those valuations used for determining the levy rates necessary to fund the budgets of the taxing districts for the following fiscal year. Each annual report under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for assessment years beginning on or after January 1, 2024, shall distinguish such values as revaluation or other type of addition to value, as defined and submitted in the assessor\u8217\'3fs abstract transmitted to the department of revenue under }}}{{\f5\fs18\hyphpar0\qj{section 441.45}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An annual report not later than January 1 to the governing body of each taxing district in the county of the assessed valuations of taxable property in the taxing district as reported to the department of management. Each annual report under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for assessment years beginning on or after January 1, 2024, shall distinguish such values as revaluation or other type of addition to value, as defined and submitted in the assessor\u8217\'3fs abstract transmitted to the department of revenue under }}}{{\f5\fs18\hyphpar0\qj{section 441.45}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7291; C73, \'a7324; C97, \'a7474; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5150;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7333.10; C73, 75, 77, \'a7333.10, 442.2; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7333.10}}}{, }{{\f5\fs18\hyphpar0\qj{333.16}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.510}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7509}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7141, 209}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 21, \'a742}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 197, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1134, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a739, 47}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7441.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\