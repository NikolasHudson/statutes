s18\hyphpar0\qj{; 87 Acts, ch 227, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1161, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 215, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 133, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7175}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a751}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.324}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.323}}}{\*\bkmkstart stylerid1_2E7_2E4_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers relating to county officers \u8212\'3f combining duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may combine the duties of two or more of the following county officers and employees as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sheriff.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Treasurer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recorder.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Auditor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Medical examiner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{General assistance director.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Commission on veteran affairs.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Executive officer of the advisory board in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 217.43}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{County assessor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{County weed commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a petition of electors equal in number to twenty-five percent of the votes cast for the county office receiving the greatest number of votes at the preceding general election is filed with the auditor no later than five working days before the filing deadline for candidates for county offices as specified in }}}{{\f5\fs18\hyphpar0\qj{section 44.4}}}{{\f5\fs18\hyphpar0\qj{ for the next general election, the board shall direct the commissioner of elections to call an election for the purpose of voting on the proposal. If the petition contains more than one proposal for combining duties, each proposal shall be listed on the ballot as a separate issue. If the majority of the votes cast is in favor of a proposal, the board shall take all steps necessary to combine the duties as specified in the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition shall state the offices and positions to be combined and the offices or positions to be abolished. Offices and positions that have been combined may be subsequently separated by a petition and election in the same manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an appointive officer or position is abolished, the term of office of the incumbent shall terminate one month from the day the proposal is approved. If an elective office is abolished, the incumbent shall hold office until the completion of the term for which elected, except that if a proposal is approved at a general election which fills the abolished office, the person elected shall not take office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the duties of an officer or employee are assigned to one or more elected officers, the board shall set the initial salary for each elected officer. Thereafter, the salary shall be determined as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.907}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require additional security on an officer\u8217\'3fs bond, in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 65.2}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{65.3}}}{{\f5\fs18\hyphpar0\qj{, or hear a petition of the surety for release and require a new bond, in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 65.4 through 65.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require any county officer to make a report to it under oath on any subject connected with the duties of the office, and remove from office by majority vote an officer who refuses or neglects to make a report or give a bond required by the board within twenty days after the requirement is made known to the officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compromise an unsatisfied judgment rendered in favor of the county against a county officer and the sureties on the officer\u8217\'3fs bond, if the county is satisfied that the full amount cannot be collected. The county may compromise with one or more of the sureties and release those sureties if the officer and each of the sureties on the officer\u8217\'3fs bond execute a written consent to the compromise and to the release of each of the sureties who agree to the compromise, and in the writing agree that the compromise and release do not release any of the sureties who do not agree to the compromise. The written consent shall be filed with the auditor. If the judgment is based upon a default in county funds, the money received under the compromise shall be paid pro rata to the funds in proportion to the amount each fund was in default at the time the judgment was rendered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorize a county officer to destroy records in the officer\u8217\'3fs possession which have been on file for more than ten years, and are not required to be kept as permanent records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter into an agreement with one or more other counties to share the services of a county attorney, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 331.753}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide that the county attorney be a full-time or part-time officer in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 331.752}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish the number of deputies, assistants, and clerks for the offices of auditor, treasurer, recorder, sheriff, and county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exercise other powers authorized by state law.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.17}}}{ \u8211\'3f 332.22; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.323(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7322}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{a.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.323(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7322}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{b.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[R60, \'a7312; C73, \'a7303; C97, \'a7422; SS15, \'a7422; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5130(8, 9);}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.3(8, 9)}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.323}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7322}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a7437 \u8211\'3f 439; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5136 \u8211\'3f 5138;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.12}}}{ \u8211\'3f 332.14; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.323(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7322}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{d.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5139;}}}{ C46, 50, \'a7332.15; C54, 58, 62, 66, 71, \'a7332.15, 343.13; C73, 75, 77, \'a7110.9, 332.15, 335.11, 343.13; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7110.16}}}{, }{{\f5\fs18\hyphpar0\qj{332.15}}}{, }{{\f5\fs18\hyphpar0\qj{335.11}}}{, }{{\f5\fs18\hyphpar0\qj{343.13}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.323}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7322}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{e, f.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.323(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7322}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{g.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a7298, 303, 481, 491, 496, 510, 2734; S13, \'a7303-a; SS15, \'a7298, 481, 491, 510-b, 2734-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5238;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7341.1}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.323(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7322}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{h.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.323(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7322}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710072, 10073, 10201}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1155, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 227, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1212, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 143, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7197}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a782}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71084}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7112, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.502}}}{{\f5\fs12\hyphpar0\qj{, 331.552}}}{{\f5\fs12\hyphpar0\qj{, 331.602}}}{{\f5\fs12\hyphpar0\qj{, 331.610}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}{{\f5\fs12\hyphpar0\qj{, 331.756(74)}}}{{\f5\fs12\hyphpar0\qj{, 441.56}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsection 1, paragraph a, subparagraph (7) effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph a, subparagraph (7) stricken and former subparagraphs (8) \u8211\'3f (11) renumbered as (7) \u8211\'3f (10)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.324}}}{\*\bkmkstart stylerid1_2E7_2E4_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties and powers relating to county and township officers and employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out the duties of a public employer to engage in collective bargaining in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Grant claims for mileage and expenses of officers and employees in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 70A.9 through 70A.13}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 331.215, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide workers\u8217\'3f compensation benefits to officers and employees as required by }}}{{\f5\fs18\hyphpar0\qj{chapter 85}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide occupational disease compensation to employees as required by }}}{{\f5\fs18\hyphpar0\qj{chapter 85A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cooperate with the workers\u8217\'3f compensation commissioner and comply with requirements imposed upon counties under }}}{{\f5\fs18\hyphpar0\qj{chapter 10A, subchapter III}}}{{\f5\fs18\hyphpar0\qj{, and}}}{{\f5\fs18\hyphpar0\qj{ chapter 87}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Comply with occupational safety and health standards as required by }}}{{\f5\fs18\hyphpar0\qj{chapter 88}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Comply with wage payment requirements imposed upon counties under }}}{{\f5\fs18\hyphpar0\qj{chapter 91A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Comply with employment security requirements imposed upon counties under }}}{{\f5\fs18\hyphpar0\qj{chapter 96}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Participate in the Iowa public employees\u8217\'3f retirement system as required by }}}{{\f5\fs18\hyphpar0\qj{chapter 97B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Participate in the federal Social Security Act as required by }}}{{\f5\fs18\hyphpar0\qj{chapter 97C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for support of the civil service commission for deputy sheriffs in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 341A.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish the compensation of deputies and assistants in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 331.904}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide a deferred compensation program for any employee, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 509A.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employ persons who are blind or partially blind and persons with disabilities in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 216C.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fix the compensation for services of county and township officers and employees if not otherwise fixed by state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Perform other duties required by state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board wishes to participate in a program of interchange of employees, it shall do so in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 28D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In exercising its power to resolve disputes with officers and employees, the board may arbitrate disputes in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 679B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the liability of a county officer or employee in the performance of official duties is not fully indemnified by insurance, the board shall pay a loss for which the officer or employee is found liable beyond the amount of insurance, and may compromise and settle any such claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a board provides group insurance for county employees, it shall also provide the insurance to a full-time county extension office assistant employed in the county, if the county is reimbursed for the premium by the county extension district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In carrying out the requirement of }}}{{\f5\fs18\hyphpar0\qj{section 331.322, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the board may purchase an individual or a blanket surety bond insuring the fidelity of county officers and county employees who are accountable for county funds or property subject to the minimum surety bond requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 64}}}{{\f5\fs18\hyphpar0\qj{. An elected county officer is deemed to have furnished surety if the officer is covered by a blanket bond purchased as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{a \u8211\'3f n.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.324(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7323}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{o.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[R60, \'a7312; C73, \'a7303; C97, \'a7422; SS15, \'a7422; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5130;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.3(10)}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.324(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7323}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{p.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.324(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7323}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2, 3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.324(2 \u8211\'3f 4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7323}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.43}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.324(5)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7323}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a735}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7509A.7}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1101, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 14, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 186, \'a710074, 10075, 10201}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1173, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1061, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1079, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7198}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72010}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7137.110}}}{{\f5\fs12\hyphpar0\qj{, 331.322}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.325}}}{\*\bkmkstart stylerid1_2E7_2E4_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Control and maintenance of pioneer cemeteries \u8212\'3f cemetery commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpioneer cemetery\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a cemetery where there have been twelve or fewer burials in the preceding fifty years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each county board of supervisors may adopt an ordinance assuming jurisdiction and control of pioneer cemeteries in the county. The board shall exercise the powers and duties of township trustees relating to the maintenance and repair of cemeteries in the county as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 359.28 through 359.40}}}{{\f5\fs18\hyphpar0\qj{ except that the board shall not certify a tax levy pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 359.30}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{359.33}}}{{\f5\fs18\hyphpar0\qj{ and except that the maintenance and repair of all cemeteries under the jurisdiction of the county including pioneer cemeteries shall be paid from the county general fund. The maintenance and improvement program for a pioneer cemetery may include restoration and management of native prairie grasses and wildflowers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of management of the cemeteries, the board of supervisors may create, by ordinance, a cemetery commission to assume jurisdiction and management of the pioneer cemeteries in the county. The ordinance shall delineate the number of commissioners, the appointing authority, the term of office, officers, employees, organizational matters, rules of procedure, compensation and expenses, and other matters deemed pertinent by the board. The board may delegate any power and duties relating to cemeteries that may otherwise be exercised by township trustees pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 359.28 through 359.40}}}{{\f5\fs18\hyphpar0\qj{ to the cemetery commission except the commission shall not certify a tax levy pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 359.30}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{359.33}}}{{\f5\fs18\hyphpar0\qj{ and except that the expenses of the cemetery commission shall be paid from the county general fund.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cemetery commission, once created, may continue to assume jurisdiction and management of a cemetery that would no longer qualify as a pioneer cemetery due to recent burials if the cemetery qualified as a pioneer cemetery upon or after creation of the cemetery commission. The choice to continue retaining jurisdiction and control of a cemetery that no longer qualifies as a pioneer cemetery shall be made jointly between the county board of supervisors and the cemetery commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors and the cemetery commission may jointly decide to allow the cemetery commission to care for any cemetery that had between thirteen and twenty-four burials within the previous fifty years. However, a cemetery that had thirteen or more burials within the previous fifty years shall not be considered a pioneer cemetery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cemetery that does not otherwise qualify to be under the jurisdiction and control of a county board of supervisors or county cemetery commission may designate a portion of the cemetery as a pioneer section if at least fifty percent of the burials in that portion occurred at least one hundred years prior to the designation. Upon approval by the cemetery, the county board of supervisors, and the county cemetery commission, the county cemetery commission may use its resources to restore and maintain the pioneer section of the cemetery as though that section was a pioneer cemetery. However, a cemetery with a designated pioneer section and the pioneer section itself shall not be considered a pioneer cemetery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{sections 359.30}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{359.33}}}{{\f5\fs18\hyphpar0\qj{, the costs of management, repair, and maintenance of pioneer cemeteries shall be paid from the county general fund.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1182, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 128, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 132, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 29, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1153, \'a754}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.424B}}}{{\f5\fs12\hyphpar0\qj{, 359.28}}}{{\f5\fs12\hyphpar0\qj{, 459.102}}}{{\f5\fs12\hyphpar0\qj{, 523I.102}}}{{\f5\fs12\hyphpar0\qj{, 523I.403}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.326 through 331.340}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 3}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E5_2E1_2E2}{DUTIES AND POWERS OF THE BOARD}{\*\bkmkend stylerid1_2E7_2E5_2E1_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{RELATING TO COUNTY CONTRACTS}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7331.486}}}{{\f5\fs12\qc{, 468.586}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Subject to reciprocal resident bidder preference in }{{\f5\fs12\qc{\'a78A.311B}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.341}}}{\*\bkmkstart stylerid1_2E7_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the estimated total cost of a public improvement, other than improvements which may be paid for from the secondary road fund, exceeds the competitive bid threshold in }}}{{\f5\fs18\hyphpar0\qj{section 26.3}}}{{\f5\fs18\hyphpar0\qj{, or as established in }}}{{\f5\fs18\hyphpar0\qj{section 314.1B}}}{{\f5\fs18\hyphpar0\qj{, the board shall follow the competitive bid procedures for governmental entities in }}}{{\f5\fs18\hyphpar0\qj{chapter 26}}}{{\f5\fs18\hyphpar0\qj{ and the contract letting procedures in }}}{{\f5\fs18\hyphpar0\qj{section 384.103}}}{{\f5\fs18\hyphpar0\qj{. As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpublic improvement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 26.2}}}{{\f5\fs18\hyphpar0\qj{ as modified by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall give preference to Iowa products in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 73}}}{{\f5\fs18\hyphpar0\qj{ and shall comply with bid and contract requirements in }}}{{\f5\fs18\hyphpar0\qj{chapter 26}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts for improvements which may be paid for from the secondary road fund shall be awarded in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 309.40 through 309.41,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\f5\fs18\hyphpar0\qj{309.43}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{310.14}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{314.1}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{314.2}}}{{\f5\fs18\hyphpar0\qj{, and other applicable state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the contract price for a public improvement is twenty-five thousand dollars or more, the board shall require a contractor\u8217\'3fs bond in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 573}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In exercising its power to contract for public improvements, the board may contract for the application of contract termination procedures in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 573A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{351, 5131, 5132;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a723.1, 332.7, 332.8; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a723.1}}}{, }{{\f5\fs18\hyphpar0\qj{332.7}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.341}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7340}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1173, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 71, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1153, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1017, \'a731, 32, 42, 43}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 144, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 133, \'a78, 10, 11}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7199}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728J.3}}}{{\f5\fs12\hyphpar0\qj{, 28M.4}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 331.471}}}{{\f5\fs12\hyphpar0\qj{, 346A.2}}}{{\f5\fs12\hyphpar0\qj{, 350.6}}}{{\f5\fs12\hyphpar0\qj{, 357H.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.342}}}{\*\bkmkstart stylerid1_2E7_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conflicts of interest in public contracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcontract\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a claim, account, or demand against or agreement with a county, express or implied, other than a contract to serve as an officer or employee of the county. However, contracts subject to }}}{{\f5\fs18\hyphpar0\qj{section 314.2}}}{{\f5\fs18\hyphpar0\qj{ are not subject to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer or employee of a county shall not have an interest, direct or indirect, in a contract with that county. A contract entered into in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is void. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ do not apply to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The designation of a bank or trust company as a depository, paying agent, or for investment of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee of a bank or trust company, who serves as treasurer of a county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts made by a county upon competitive bid in writing, publicly invited and opened.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts in which a county officer or employee has an interest solely by reason of employment, or a stock interest of the kind described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or both, if the contracts are made by competitive bid, publicly invited and opened, or if the remuneration of employment will not be directly affected as a result of the contract and the duties of employment do not directly involve the procurement or preparation of any part of the contract. The competitive bid qualification of this paragraph does not apply to a contract for professional services not customarily awarded by competitive bid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The designation of official newspapers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract in which a county officer or employee has an interest if the contract was made before the time the officer or employee was elected or appointed, but the contract shall not be renewed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract with volunteer fire fighters or civil defense volunteers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract with a corporation in which a county officer or employee has an interest by reason of stockholdings when less than five percent of the outstanding stock of the corporation is owned or controlled directly or indirectly by the officer or employee or the spouse or immediate family of the officer or employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract made by competitive bid, publicly invited and opened, in which a member of a county board, commission, or administrative agency has an interest, if the member is not authorized by law to participate in the awarding of the contract. The competitive bid qualification of this paragraph does not apply to a contract for professional services not customarily awarded by competitive bid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts not otherwise permitted by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, for the purchase of goods or services by a county, which benefit a county officer or employee, if the purchases benefiting that officer or employee do not exceed a cumulative total purchase price of six thousand dollars in a fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract that is a bond, note, or other obligation of the county and the contract is not acquired directly from the county, but is acquired in a transaction with a third party, who may or may not be the original underwriter, purchaser, or obligee of the contract.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.342}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7341}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1209, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 36, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7134}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 74, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728J.3}}}{{\f5\fs12\hyphpar0\qj{, 28M.4}}}{{\f5\fs12\hyphpar0\qj{, 331.471}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.343 through 331.360}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 4}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E6_2E1_2E2}{DUTIES AND POWERS OF THE BOARD}{\*\bkmkend stylerid1_2E7_2E6_2E1_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{RELATING TO COUNTY PROPERTY}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.361}}}{\*\bkmkstart stylerid1_2E7_2E6_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Counties bounded by a body of water have concurrent jurisdiction over the entire body of water lying between them.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In disposing of an interest in real property by sale or exchange, by lease for a term of more than three years, or by gift, the following procedures shall be followed, except as otherwise provided by state law:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall set forth its proposal in a resolution and shall publish notice of the time and place of a public hearing on the proposal, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the public hearing, the board may make a final determination on the proposal by resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When unused highway right-of-way is not being sold or transferred to another governmental authority, the county shall comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 306.23}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An interest in real property which is assessed for taxation as residential or commercial multifamily property may be disposed of through a public request for proposals process. A proposal submitted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall state the housing use planned by the person submitting the proposal. The board shall publish the proposals in a notice of the time and place of a public hearing on the proposals, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{. After the public hearing, the board may choose by resolution from among the proposals submitted or may reject all proposals and submit a new request for proposals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall not dispose of real property by gift except for a public purpose, as determined by the board, in accordance with other state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proceed upon a petition to establish a memorial hall or monument under }}}{{\f5\fs18\hyphpar0\qj{chapter 37}}}{{\f5\fs18\hyphpar0\qj{, as provided in that chapter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Comply with }}}{{\f5\fs18\hyphpar0\qj{section 103A.10, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, in the construction of new buildings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proceed upon a petition to, or with approval of the voters, establish a county public hospital under }}}{{\f5\fs18\hyphpar0\qj{chapter 347}}}{{\f5\fs18\hyphpar0\qj{ or sell or lease a county hospital for use as a private hospital or as a merged area hospital under }}}{{\f5\fs18\hyphpar0\qj{chapter 145A}}}{{\f5\fs18\hyphpar0\qj{ or sell or lease a county hospital in conjunction with the establishment of a merged area hospital in accordance with procedures set out in }}}{{\f5\fs18\hyphpar0\qj{chapter 347}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bid for real property at a tax sale as required under }}}{{\f5\fs18\hyphpar0\qj{section 446.19}}}{{\f5\fs18\hyphpar0\qj{, and handle the property in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 446.31}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 569}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the conduction of a life cycle cost analysis for county facilities in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 470}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Comply with }}}{{\f5\fs18\hyphpar0\qj{chapter 216D}}}{{\f5\fs18\hyphpar0\qj{ if food service is provided in public buildings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Comply with }}}{{\f5\fs18\hyphpar0\qj{section 216C.9}}}{{\f5\fs18\hyphpar0\qj{ if curb ramps and sloped areas are constructed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide facilities for the district court in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 602.1303}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Perform other duties required by state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In exercising its power to manage county real property, the board may lease land for oil and gas exploration as provided in }}}{{\f5\fs18\hyphpar0\qj{section 458A.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall not lease, purchase, or construct a facility or building before considering the leasing of a vacant facility or building which is located in the county and owned by a public school corporation. The board may lease a facility or building owned by the public school corporation with an option to purchase the facility or building in compliance with }}}{{\f5\fs18\hyphpar0\qj{section 297.22}}}{{\f5\fs18\hyphpar0\qj{. The lease shall provide that the public school corporation may terminate the lease if the corporation needs to use the facility or building for school purposes. The public school corporation shall notify the board at least thirty days before the termination of the lease.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a795; R60, \'a7223; C73, \'a7280; C97, \'a7395; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5129;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.2}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.361(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7360}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2, 3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, 27, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5130;}}}{ C46, 50, 54, 58, 62, 66, \'a7332.3; C71, 73, 75, 77, 79, \'a7332.3, 569.8; }{{\f5\fs18\hyphpar0\qj{C81, \'a7332.3}}}{(13); }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.361(2, 3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7360}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5130.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.5}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.361(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7360}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{487;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a737.5}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.361(5)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7360}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.361(6)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7360}}}{]}\par}{}{\pard\plain\f5\fs18