6}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1017, \'a74, 8}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1113, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 5, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a7123}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1069, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1132, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 138, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1031, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 27, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a774}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1141, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7211}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1093, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 148, \'a729, 53, 54}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.610}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 23 applies retroactively to January 1, 2025, to the estates of decedents dying on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 148, \'a754}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 23 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.603}}}{\*\bkmkstart stylerid1_2E9_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder may administer oaths and take affirmations on matters relating to the business of the office of recorder as provided in }}}{{\f5\fs18\hyphpar0\qj{section 63A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 331.903}}}{{\f5\fs18\hyphpar0\qj{, the recorder may appoint and remove deputies, assistants, and clerks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder may reproduce in miniature on a durable medium any instrument to be recorded. When a recorded instrument involves a release, assignment, or other subsequent reference to an original document, the separate instrument filed acknowledging the release, assignment, or other subsequent reference shall be reproduced. In lieu of marginal entries, the recorder shall cross-reference the release, assignment, or other subsequent reference with the record of the original document. When an official record is produced in miniature, a security copy shall be reproduced at the same time and kept outside of the courthouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder may, in lieu of maintaining separate index books, prepare and maintain a combined index record or system which shall contain the same data and information as required to be kept in the separate index books.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing board of the county land record information system shall not enter into an agreement to provide access to electronic documents or records on a batch basis. The county recorder may collect reasonable fees for access to electronic documents and records pursuant to an agreement. The fees shall not exceed the actual cost of providing access to the electronic documents and records. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fActual cost\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means only those expenses directly attributable to providing access to electronic documents and records. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fActual cost\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not include costs such as employment benefits, depreciation, maintenance, electricity, or insurance associated with the administration of the office of the county recorder or the county land record information system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Electronic documents and records made available under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not include personally identifiable information and shall be subjected to a redaction process prior to the transfer of the electronic documents or records to another person pursuant to an agreement under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1, 2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7411; R60, \'a7642; C73, \'a7766; C97, \'a7496; S13, \'a7496; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5238, 5240;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7341.1}}}{, }{{\f5\fs18\hyphpar0\qj{341.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.603}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7602}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3, 4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C54, 58, 62, 66, \'a7343.13; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7335.17}}}{, }{{\f5\fs18\hyphpar0\qj{343.13}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.603}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7602}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 44, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1031, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 27, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 159, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.604}}}{\*\bkmkstart stylerid1_2E9_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Recording and filing fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided by state law, }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 331.605}}}{{\f5\fs18\hyphpar0\qj{, the recorder shall collect a fee of five dollars for each page or fraction of a page of an instrument which is filed or recorded in the recorder\u8217\'3fs office. If a page or fraction of a page contains more than one transaction, the recorder shall collect the fee for each transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder shall also collect a fee of one dollar for each recorded transaction for which a fee is paid pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ to be used exclusively for the purpose of preserving and maintaining public records. The treasurer, on behalf of the recorder, shall establish and maintain a county recorder\u8217\'3fs records management fund into which all moneys collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited. Interest earned on moneys deposited in the fund shall be credited to the county recorder\u8217\'3fs records management fund. The recorder shall use the moneys deposited in the fund to produce and maintain public records that meet archival standards, and to enhance the technological storage, retrieval, and transmission capabilities related to archival quality records. The recorder may cooperate with other entities, boards, and agencies to establish methods of records management, and participate in other joint ventures which further the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fees collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be used to accomplish the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Preserve and maintain public records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assist counties in reducing record preservation costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Encourage and foster maximum access to public records maintained by county recorders at locations throughout the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish plans for anticipated and possible future needs, including the handling and preservation of vital statistics.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each county shall participate in the county land record information system and shall comply with the policies and procedures established by the governing board of the county land record information system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder shall also collect a fee of one dollar for each recorded transaction, regardless of the number of pages, for which a fee is paid pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ to be used for the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing and implementing standards for recording, processing, and archiving electronic documents and records.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintaining the statewide internet site and the county land record information system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Integrating information contained in documents and records maintained by the recorder and other land record information from other sources with the county land record information system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Implementing and maintaining a process for redacting personally identifiable information contained in electronic documents that are displayed for public access through an internet site or that are transferred to another person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee collected by the recorder under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for recording a plat of survey is one dollar, regardless of the number of pages. For purposes of this subparagraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fplat of survey\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 355.1, subsection 9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fees collected in excess of the amount needed for the purposes specified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be used by the county land record information system to reduce or eliminate service fees for electronic submission of documents and instruments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer, on behalf of the recorder, shall establish and maintain a county recorder\u8217\'3fs electronic transaction fund into which all moneys collected pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited. Interest earned on moneys deposited in this fund shall be computed based on the average monthly balance in the fund and shall be credited to the county recorder\u8217\'3fs electronic transaction fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local government electronic transaction fund is established in the office of the treasurer of state under the control of the treasurer of state. Moneys deposited into the fund are not subject to }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the local government electronic transaction fund shall be credited to the fund. Moneys in the local government electronic transaction fund are not subject to transfer, appropriation, or reversion to any other fund, or any other use except as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. On a monthly basis, the county treasurer shall pay the fees deposited into the county recorder\u8217\'3fs electronic transaction fund to the treasurer of state for deposit into the local government electronic transaction fund. Moneys credited to the local government electronic transaction fund are appropriated to the treasurer of state for the payment of claims approved by the governing board of the county land record information system. Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, expenditures from the fund shall be for the purpose of planning and implementing electronic recording and electronic transactions in each county, developing county and statewide internet sites to provide electronic access to records and information, and to pay the ongoing costs of integrating and maintaining the statewide internet site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder shall make available any information required by the county auditor or auditor of state concerning the fees collected under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for the purposes of determining the amount of fees collected and the uses for which such fees are expended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county land record information system agreement may be amended by a vote of the boards of supervisors on behalf of the respective county recorders, pursuant to the terms of the agreement, to provide for the ongoing implementation of the county land record information system. As used in this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcounty land record information system agreement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the agreement entered under }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ between the counties as required by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2005/CH0179.pdf" }{\fldrslt \cf5 \f5 \fs18{{2005 Iowa Acts, ch. 179, \'a7101}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, as amended by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0126.pdf" }{\fldrslt \cf5 \f5 \fs18{{2021 Iowa Acts, ch. 126}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request by a peace officer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{, civilian employee of a law enforcement agency, or state or federal judicial officer or state or federal prosecutor, the county assessor or the county assessor\u8217\'3fs staff, or the county recorder or the county recorder\u8217\'3fs staff, shall redact the requestor\u8217\'3fs name contained in electronic documents that are displayed for public access through an internet site. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request by a former peace officer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{, or a former civilian employee of a law enforcement agency, the county assessor or the county assessor\u8217\'3fs staff, or the county recorder or the county recorder\u8217\'3fs staff, may redact, upon the presentation of evidence that a compelling safety interest is served by doing so, the requestor\u8217\'3fs name contained in electronic documents that are displayed for public access through an internet site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph does not apply to a requestor holding or seeking public office. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county assessor and the county recorder shall implement and maintain a process to facilitate requests pursuant to this paragraph. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fee shall not be charged for the administration of this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not be required to pay a fee to the recorder for filing or recording instruments. However, a county treasurer is required to pay recording fees pursuant to }}}{{\f5\fs18\hyphpar0\qj{ sections 437A.11}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{437B.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a72534; R60, \'a74143; C73, \'a73792; C97, S13, \'a7498; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5177;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7335.14}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.604}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7603}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1124, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1005, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1212, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 27, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 159, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7257}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 94, \'a72, 35, 36}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 126, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 164, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 183, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a710A.108}}}{{\f5\fs1