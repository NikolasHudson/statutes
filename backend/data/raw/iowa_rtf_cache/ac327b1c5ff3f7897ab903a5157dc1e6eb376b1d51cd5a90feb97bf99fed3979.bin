8_2E5_2E1_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a728M.3}}}{{\f5\fs12\qc{, 331.552}}}{{\f5\fs12\qc{, 350.6}}}{{\f5\fs12\qc{, 403.12}}}{{\f5\fs12\qc{, 423A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.441}}}{\*\bkmkstart stylerid1_2E8_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this part, the use of the conjunctive }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fand\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the disjunctive }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3for\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and the use of the disjunctive }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3for\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the conjunctive }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fand\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, unless the context clearly indicates otherwise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this part, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGeneral obligation bond\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a negotiable bond issued by a county and payable from the levy of ad valorem taxes on all taxable property within the county through its debt service fund which is required to be established by }}}{{\f5\fs18\hyphpar0\qj{section 331.430}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEssential county purpose\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An optical scan voting system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bridges on highways or parts of highways which are located along the corporate limits of cities and are partly within and partly without the limits and are in whole or in part secondary roads.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sanitary disposal projects as defined in }}}{{\f5\fs18\hyphpar0\qj{section 455B.301}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Works and facilities useful for the collection, treatment, and disposal of sewage and industrial waste in a sanitary manner, for the collection and disposal of solid waste, and for the collection and disposal of surface waters and streams, including the planning, acquisition, leasing, construction, reconstruction, extension, remodeling, improvement, repair, equipping, maintenance, and operation of the works and facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Public buildings, including the site or grounds of, and the erection, equipment, remodeling, or reconstruction of, and additions or extensions to the buildings, and including the provision and maintenance of juvenile detention or shelter care facilities, when the cost does not exceed the following limits:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seven hundred eighty thousand dollars in a county having a population of twenty-five thousand or less.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nine hundred seventy-five thousand dollars in a county having a population of more than twenty-five thousand but not more than fifty thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One million one hundred seventy thousand dollars in a county having a population of more than fifty thousand but not more than one hundred thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One million five hundred sixty thousand dollars in a county having a population of more than one hundred thousand but not more than two hundred thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One million nine hundred fifty thousand dollars in a county having a population of more than two hundred thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Funding or refunding outstanding indebtedness if the outstanding indebtedness exceeds five thousand dollars on the first day of January, April, June, or September in any year. However, a county shall not levy taxes to repay refunding bonds for bridges on property within cities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enlargement and improvement of a county hospital acquired and operated under }}}{{\f5\fs18\hyphpar0\qj{chapter 347A}}}{{\f5\fs18\hyphpar0\qj{, subject to a maximum of two percent of the assessed value of the taxable property in the county. However, notice of the proposed bond issue shall be published once each week for two consecutive weeks and if, within twenty days following the date of the first publication, a petition requesting an election on the proposal and signed by eligible electors of the county equal in number to at least twenty percent of the votes cast at the preceding election for governor is filed with the county auditor, the proposal is subject to the election requirements in }}}{{\f5\fs18\hyphpar0\qj{section 331.442, subsections 2, 3, and 4}}}{{\f5\fs18\hyphpar0\qj{, for general county purpose bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provision of insurance, or funding a self-insurance program or local government risk pool, including but not limited to the investigation and defense of claims, the payment of claims, and the administration and management of such self-insurance program or local government risk pool.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The acquisition, restoration, or demolition of abandoned, dilapidated, or dangerous buildings, structures or properties or the abatement of a nuisance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The establishment or funding of programs to provide for or assist in providing for the acquisition, restoration, or demolition of housing, as part of a municipal housing project under }}}{{\f5\fs18\hyphpar0\qj{chapter 403}}}{{\f5\fs18\hyphpar0\qj{ or otherwise, or for other purposes as may be authorized under }}}{{\f5\fs18\hyphpar0\qj{chapter 403A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The acquiring, developing, and improving of a geographic computer data base system suitable for automated mapping and facilities management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Funding the acquisition, construction, reconstruction, improvement, repair, or equipping of waterworks, water mains and extensions, ponds, reservoirs, capacity, wells, dams, pumping installations, real and personal property, or other facilities available or used for the storage, transportation, or utilization of water.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county board of supervisors may on its own motion or upon a written petition of a water supplier established under }}}{{\f5\fs18\hyphpar0\qj{chapter 357A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{504}}}{{\f5\fs18\hyphpar0\qj{ direct the county auditor to establish a special service area tax district for the purpose of issuing general obligation bonds. The special service area tax district shall include only unincorporated portions of the county and shall be drawn according to engineering recommendations provided by the water supplier or the county engineer and, in addition, shall be drawn in order that an election provided for in subparagraph division (b) can be administered. The county\u8217\'3fs debt service tax levy for the county general obligation bonds issued for the purposes set out in this subparagraph shall be levied only against taxable property within the county which is included within the boundaries of the special service area tax district. An owner of property not included within the boundaries of the special service area tax district may petition the board of supervisors to be included in the special service area tax district subsequent to its establishment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{General obligation bonds for the purposes described in this subparagraph are subject to an election held in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.442, subsections 1 through 4}}}{{\f5\fs18\hyphpar0\qj{, if not later than fifteen days following the action by the county board of supervisors, eligible electors file a petition with the county commissioner of elections asking that the question of issuing the bonds be submitted to the registered voters of the special service area tax district. The petition must be signed by eligible electors equal in number to at least five percent of the registered voters residing in the special service area tax district. If the petition is duly filed within the fifteen days, the board of supervisors shall either adopt a resolution declaring that the proposal to issue the bonds is abandoned, or direct the county commissioner of elections to call a special election within a special service area tax district upon the question of issuing the bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The acquisition, pursuant to a }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ agreement, of a city convention center or veterans memorial auditorium, including the renovation, remodeling, reconstruction, expansion, improvement, or equipping of such a center or auditorium, provided that debt service funds shall not be derived from the division of taxes under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(14)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The aiding of the planning, undertaking, and carrying out of urban renewal projects under the authority of }}}{{\f5\fs18\hyphpar0\qj{chapter 403}}}{{\f5\fs18\hyphpar0\qj{ and for the purposes set out in }}}{{\f5\fs18\hyphpar0\qj{section 403.12}}}{{\f5\fs18\hyphpar0\qj{. However, bonds issued for this purpose are subject to the right of petition for an election as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.442, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, without limitation on the amount of the bond issue or the population of the county, and the board shall include notice of the right of petition in the notice of proposed action required under }}}{{\f5\fs18\hyphpar0\qj{section 331.443, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(15)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The establishment, construction, reconstruction, repair, equipping, remodeling, extension, maintenance, and operation of works, vehicles, and facilities of a regional transit district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(16)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Capital projects for the construction, reconstruction, improvement, repair, or equipping of bridges, roads, and culverts if such capital projects assist in economic development which creates jobs and wealth, if such capital projects relate to damage caused by a disaster as defined in }}}{{\f5\fs18\hyphpar0\qj{section 29C.2}}}{{\f5\fs18\hyphpar0\qj{, or if such capital projects are designed to prevent or mitigate future disasters as defined in }}}{{\f5\fs18\hyphpar0\qj{section 29C.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(17)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Peace officer communication equipment and other emergency services communication equipment and systems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(18)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The remediation, restoration, repair, cleanup, replacement, and improvement of property, buildings, equipment, and public facilities that have been damaged by a disaster as defined in }}}{{\f5\fs18\hyphpar0\qj{section 29C.2}}}{{\f5\fs18\hyphpar0\qj{ and that are located in an area that the governor has proclaimed a disaster emergency or the president of the United States has declared a major disaster. Bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.443}}}{{\f5\fs18\hyphpar0\qj{ for the purposes specified in this subparagraph shall be issued not later than ten years after the governor has proclaimed a disaster emergency or the president of the United States has declared a major disaster, whichever is later.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(19)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reimbursement of the county\u8217\'3fs general fund or other funds of the county for expenditures made related to remediation, restoration, repair, and cleanup of damage caused by a disaster as defined in }}}{{\f5\fs18\hyphpar0\qj{section 29C.2}}}{{\f5\fs18\hyphpar0\qj{, if the damage is located in an area that the governor has proclaimed a disaster emergency or the president of the United States has declared a major disaster. Bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.443}}}{{\f5\fs18\hyphpar0\qj{ for the purposes specified in this subparagraph shall be issued not later than ten years after the governor has proclaimed a disaster emergency or the president of the United States has declared a major disaster, whichever is later.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(20)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The construction, reconstruction, and improvement of all waterways, and real and personal property, useful for the protection or reclamation of property from floods or high waters, and for the protection of property from the effects of flood waters, including the deepening, widening, alteration, change, diversion, or other improvement of watercourses, the construction of levees, embankments, structures, impounding reservoirs, pumping stations or conduits, and the establishment, improvement, and widening of streets, avenues, boulevards, and alleys across and adjacent to the project, as well as the development and beautification of the banks and other areas adjacent to flood control improvements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGeneral county purpose\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A memorial building or monument to commemorate the service rendered by members of the armed services of the United States, including the acquisition of ground and the purchase, erection, construction, reconstruction, and equipment of the building or monument, to be managed by a commission as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 37}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Acquisition and development of land for a public museum, park, parkway, preserve, playground, or other recreation or conservation purpose to be managed by the county conservation board. The board may submit a proposition under this subparagraph only upon receipt of a petition from the county conservation board asking that bonds be issued for a specified amount.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The building and maintenance of a bridge over state boundary line streams. The board shall submit a proposition under this subparagraph to an election upon receipt of a petition which is valid under }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contributions of money to the state department of transportation to help finance the construction of toll bridges across navigable rivers constituting boundaries between the county and an adjoining state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An airport, including establishment, acquisition, equipment, improvement, or enlargement of the airport.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A joint city-county building, established by contract between the county and its county seat city, including purchase, acquisition, ownership, and equipment of the county portion of the building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county health center as defined in }}}{{\f5\fs18\hyphpar0\qj{section 346A.1}}}{{\f5\fs18\hyphpar0\qj{, including additions and facilities for the center and including the acquisition, reconstruction, completion, equipment, improvement, repair, and remodeling of the center, additions, or facilities. Bonds for the purpose specified in this subparagraph are exempt from taxation by the state and the interest on the bonds is exempt from state income taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county public hospital, including procuring a site and the erection, equipment, and maintenance of the hospital, and additions to the hospital, subject to the levy limits in }}}{{\f5\fs18\hyphpar0\qj{section 347.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Public buildings, including the site or grounds of, the erection, equipment, remodeling, or reconstruction of, and additions or extensions to the buildings, and including the provision and maintenance of juvenile detention or shelter care facilities, when the cost exceeds the limits stated in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (5).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The undertaking of any project jointly or in cooperation with any other governmental body which, if undertaken by the county alone, would be for a general county purpose, including the joint purchase, acquisition, construction, ownership, or control of any real or personal property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcost\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of a project for an essential county purpose or general county purpose includes construction contracts and the cost of engineering, architectural, technical, and legal services, preliminary reports, property valuations, estimates, plans, specifications, notices, acquisition of real and personal property, consequential damages or costs, easements, rights-of-way, supervision, inspection, testing, publications, printing and sale of bonds, interest during the period or estimated period of construction and for twelve months thereafter or for twelve months after the acquisition date, and provisions for contingencies.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1, 2}}}{a.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(1, 2a)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2}}}{b(1).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[S13, \'a71137-a14; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{906;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a752.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2b)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{b(2).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[SS15, \'a71527-s3; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4666;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7309.73}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2b)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{b(3).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7346.23}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2b)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{b(4).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.52}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2b)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{b(5).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7114, 117; R60, \'a7250, 253; C73, \'a7309, 312; C97, \'a7443, 448; SS15, \'a7448; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5263, 5268;}}}{ C46, 50, 54, 58, 62, \'a7345.4, 345.9; C66, 71, 73, 75, 77, \'a7232.22, 345.4, 345.9; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.142}}}{, }{{\f5\fs18\hyphpar0\qj{345.4}}}{, }{{\f5\fs18\hyphpar0\qj{345.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2b)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{b(6).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C73, \'a7289; C97, S13, \'a7403; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5275, 5276;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7346.1}}}{, }{{\f5\fs18\hyphpar0\qj{346.2}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2b)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{b(7).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347A.7}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2b)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2}}}{c(1).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{488;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a737.6}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2c)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a745}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c(2).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7111A.6}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2c)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c(3).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[S13, \'a7424-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4682;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7309.89}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2b)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a744, 46}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c(4).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7313A.35}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2c)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c(5).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C31, 35, \'a75903-c6, -c8; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5903.06, 5903.08;}}}{ C46, 50, \'a7330.8, 330.10, 330.16; C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7330.7}}}{, }{{\f5\fs18\hyphpar0\qj{330.10}}}{, }{{\f5\fs18\hyphpar0\qj{330.16}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2c)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c(6).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C50, \'a7368.58, 368.59; C54, 58, 62, 66, 71, 73, \'a7368.20, 368.21; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7346.26}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2c)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c(7).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7346A.3}}}{ \u8211\'3f 346A.5; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2c)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c(8).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[S13, \'a7409-a, -b, -f; C24, 27, 31, 35, \'a75348 \u8211\'3f 5351, 5354; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5348, 5348.1, 5349 \u8211\'3f 5351, 5354;}}}{ C46, 50, 54, 58, \'a7347.1 \u8211\'3f 347.5, 347.8; C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a737.27}}}{, }{{\f5\fs18\hyphpar0\qj{347.1}}}{ \u8211\'3f }{{\f5\fs18\hyphpar0\qj{347.5}}}{, }{{\f5\fs18\hyphpar0\qj{347.8}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2c)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c(9).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7114, 117; R60, \'a7250, 253; C73, \'a7309, 312; C97, \'a7443, 448; SS15, \'a7448; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5263, 5268;}}}{ C46, 50, 54, 58, 62, \'a7345.4, 345.9; C66, 71, 73, 75, 77, \'a7232.22, 345.4, 345.9; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7232.142}}}{, }{{\f5\fs18\hyphpar0\qj{345.4}}}{, }{{\f5\fs18\hyphpar0\qj{345.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2c)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c(10, 11).}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(2c)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.441(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7136 \u8211\'3f 139, 209}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1211, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 103, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 189, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1255, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1102, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1138, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 180, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1014, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1182, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1204, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1188, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 56, \'a722, 23}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1049, \'a7191}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1072, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7393}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 109, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 190, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1013, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 57, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 100, \'a710, 21}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 173, \'a733, 36}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 95, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a78, 10, 141, 154}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a723A.2}}}{{\f5\fs12\hyphpar0\qj{, 37.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 52.3}}}{{\f5\fs12\hyphpar0\qj{, 76.1}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 331.443}}}{{\f5\fs12\hyphpar0\qj{, 331.444}}}{{\f5\fs12\hyphpar0\qj{, 331.445}}}{{\f5\fs12\hyphpar0\qj{, 350.6}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}{{\f5\fs12\hyphpar0\qj{, 422.7(2)(q)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 strike of former subsection 2, paragraph c, subparagraph (11) applies to taxes and budgets for fiscal years beginning on or after July 1, 2024; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.442}}}{\*\bkmkstart stylerid1_2E8_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General county purpose bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county which proposes to carry out any general county purpose within or without its boundaries, and to contract indebtedness and issue general obligation bonds to provide funds to pay all or any part of the costs of a project, shall do so in accordance with this part.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall publish notice of the proposal to issue the bonds, including a statement of the amount and purpose of the bonds, a statement of the estimated cost of the project for which the bonds are to be issued, and an estimate of the annual increase in property taxes as the result of the bond issuance on a residential property with an actual value of one hundred thousand dollars. The notice shall be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{ with the minutes of the meeting at which the board adopts a resolution to call a county special election to vote upon the question of issuing the bonds. The cost of the project, as published in the notice pursuant to this paragraph, is an estimate and is not intended to be binding on the board in later proceedings related to the project.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before the board may institute proceedings for the issuance of bonds for a general county purpose, it shall call a county special election to vote upon the question of issuing the bonds. At the election the proposition shall be submitted in the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the county of }{{\f5\fs18\hyphpar0\qj{....................}}}{, state of Iowa, issue its general obligation bonds in an amount not exceeding the amount of $}{{\f5\fs18\hyphpar0\qj{............}}}{ for the purpose of }{{\f5\fs18\hyphpar0\qj{................................................}}}{?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All elections held pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be held on the date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of the election shall be given by publication as specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{. At the election the ballot used for the submission of the proposition shall be in substantially the form for submitting special questions at general elections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proposition of issuing bonds for a general county purpose is not carried or adopted unless the vote in favor of the proposition is equal to at least sixty percent of the total vote cast for and against the proposition at the election. If the proposition of issuing the general county purpose bonds is approved by the voters, the board may proceed with the issuance of the bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a board, in lieu of calling an election, may institute proceedings for the issuance of bonds for a general county purpose by causing a notice of the proposal to issue the bonds, including a statement of the amount and purpose of the bonds, and the right to petition for an election, to be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{ at least ten days prior to the meeting at which it is proposed to take action for the issuance of the bonds subject to the following population-based limitations, adjusted and published annually in January by the department of management by applying the percentage change in the consumer price index for all urban consumers for the most recent available twelve-month period published in the federal register by the United States department of labor, bureau of labor statistics:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In counties having a population of twenty thousand or less, in an amount of not more than one hundred thirty thousand dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In counties having a population of over twenty thousand and not over fifty thousand, in an amount of not more than two hundred sixty thousand dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In counties having a population of over fifty thousand, in an amount of not more than three hundred ninety thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each county\u8217\'3fs population used to determine the limitations of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be determined by the greater of the county\u8217\'3fs population during the most recent federal decennial census or the most recent population estimate produced by the United States census bureau.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time before the date fixed for taking action for the issuance of the bonds, a petition is filed with the auditor in the manner provided by }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{ asking that the question of issuing the bonds be submitted to the registered voters of the county, the board shall either by resolution declare the proposal to issue the bonds to have been abandoned or shall direct the county commissioner of elections to call a special election upon the question of issuing the bonds. Notice of the election and its conduct shall be in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{subsections 2, 3 and 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If no petition is filed, or if a petition is filed and the proposition of issuing the bonds is approved at an election, the board may proceed with the authorization and issuance of the bonds.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75903-c5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5903.05;}}}{ C46, 50, \'a7330.7; C54, 58, \'a7330.7; C62, 66, \'a7111A.6, 330.7; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7111A.6}}}{, }{{\f5\fs18\hyphpar0\qj{313A.35}}}{, }{{\f5\fs18\hyphpar0\qj{330.7}}}{, }{{\f5\fs18\hyphpar0\qj{346A.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.442}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7441}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a747}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 67, \'a753}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 109, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 2, \'a71, 3, 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a7123, 136, 142 \u8211\'3f 145, 154}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.5}}}{{\f5\fs12\hyphpar0\qj{, 37.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 331.402}}}{{\f5\fs12\hyphpar0\qj{, 331.441}}}{{\f5\fs12\hyphpar0\qj{, 331.443}}}{{\f5\fs12\hyphpar0\qj{, 331.445}}}{{\f5\fs12\hyphpar0\qj{, 331.461}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 3 applies July 1, 2023, for elections on propositions relating to the issuing of bonds or other indebtedness occurring on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a7136}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.443}}}{\*\bkmkstart stylerid1_2E8_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Essential county purpose bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county which proposes to carry out an essential county purpose within or without its boundaries, and to contract indebtedness and issue general obligation bonds to provide funds to pay all or any part of the cost of a project shall do so in accordance with this part.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before the board may institute proceedings for the issuance of bonds for an essential county purpose, a notice of the proposed action, including a statement of the amount and purposes of the bonds, an estimate of the annual increase in property taxes as the result of the bond issuance on a residential property with an actual value of one hundred thousand dollars, and the time and place of the meeting at which the board proposes to take action for the issuance of the bonds, shall be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{. At the meeting, the board shall receive oral or written objections from any resident or property owner of the county. After all objections have been received and considered, the board, at that meeting or a date to which it is adjourned, may take additional action for the issuance of the bonds or abandon the proposal to issue the bonds. Any resident or property owner of the county may appeal the decision of the board to take additional action to the district court of the county, within fifteen days after the additional action is taken, but the additional action of the board is final and conclusive unless the court finds that the board exceeded its authority. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ with respect to notice, hearing, and appeal, are in lieu of any other law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a board may institute proceedings for the issuance of bonds for an essential county purpose specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.441, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (18) or (19), in an amount equal to or greater than three million dollars by causing a notice of the proposal to issue the bonds, including a statement of the amount and purpose of the bonds, together with the maximum rate of interest which the bonds are to bear, and the right to petition for an election, to be published at least once in a newspaper of general circulation within the county at least ten days prior to the meeting at which it is proposed to take action for the issuance of the bonds.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time before the date fixed for taking action for the issuance of the bonds, a petition is filed with the county auditor, signed by eligible electors of the county equal in number to twenty percent of the persons in the county who voted for the office of president of the United States at the last preceding general election that had such office on the ballot, asking that the question of issuing the bonds be submitted to the registered voters of the county, the board shall either by resolution declare the proposal to issue the bonds to have been abandoned or shall direct the county commissioner of elections to call a special election upon the question of issuing the bonds. Notice of the election and its conduct shall be in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.442}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a petition is not filed, or if a petition is filed and the proposition of issuing the bonds is approved at an election, the board may proceed with the authorization and issuance of the bonds.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.443}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7442}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 100, \'a711, 21}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a7146, 154}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a737.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 331.402}}}{{\f5\fs12\hyphpar0\qj{, 331.441}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.443A}}}{\*\bkmkstart stylerid1_2E8_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restrictions on certain projects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The term of any indebtedness issued or incurred by a county that will be paid in whole or in part with moneys from the secondary road fund of the counties, the farm-to-market road fund, the county bridge construction fund, or the revitalize Iowa\u8217\'3fs sound economy fund, or any other moneys that may be allocated from the road use tax fund for use by counties, shall be subject to the provisions of sections }{{\f5\fs18\hyphpar0\qj{312.2A}}}{ and }{{\f5\fs18\hyphpar0\qj{315.4A}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 2, \'a74, 14}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a737.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.444}}}{\*\bkmkstart stylerid1_2E8_2E5_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale of bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may sell general obligation bonds at public or private sale in the manner prescribed by }}}{{\f5\fs18\hyphpar0\qj{chapter 75}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{General obligation funding or refunding bonds issued for the purposes specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.441, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ subparagraph (7), may be exchanged for the evidences of the legal indebtedness being funded or refunded, or the funding or refunding bonds may be sold in the manner prescribed by }}}{{\f5\fs18\hyphpar0\qj{chapter 75}}}{{\f5\fs18\hyphpar0\qj{ and the proceeds applied to the payment of the indebtedness. Funding or refunding bonds may bear interest at the same rate as, or at a higher or lower rate or rates of interest than the indebtedness being funded or refunded.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5278;}}}{ C46, 50, 54, 58, 62, 66, \'a7346.4; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7346.4}}}{, }{{\f5\fs18\hyphpar0\qj{346A.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.444}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7443}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a737.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.445}}}{\*\bkmkstart stylerid1_2E8_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Categories for general obligation bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board may issue general obligation bonds pursuant to a resolution adopted at a regular or special meeting by a majority of the total number of supervisors. Each subparagraph of }{{\f5\fs18\hyphpar0\qj{section 331.441, subsection 2}}}{, paragraphs }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{ and }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{, describes a separate category. Separate categories of essential county purposes and of general county purposes may be incorporated in a single notice of intention to institute proceedings for the issuance of bonds, or separate categories may be incorporated in separate notices, and after an opportunity has been provided for filing objections, or after a favorable election has been held, if required, the board may include in a single resolution and sell as a single issue of bonds, any number or combination of essential county purposes or general county purposes. If an essential county purpose is combined with a general county purpose in a single notice of intention to institute proceedings to issue bonds, then the entire issue is subject to the election requirement in }{{\f5\fs18\hyphpar0\qj{section 331.442}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.445}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7444}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a737.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 331.447}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.446}}}{\*\bkmkstart stylerid1_2E8_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form and execution \u8212\'3f negotiability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As provided by resolution of the board, general obligation bonds may:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bear dates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bear interest at rates not exceeding any limitations imposed by }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Mature in one or more installments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be in either coupon or registered form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry registration and conversion privileges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be payable as to principal and interest at times and places.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be subject to terms of redemption prior to maturity with or without premium.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be in one or more denominations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be designated with a brief reference to purpose, or if issued for a combination of purposes, be designated \u8220\'3fcounty purpose bond\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contain other provisions not in conflict with state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{General obligation bonds shall be executed by the chairperson of the board and the auditor. If coupons are attached to the bonds, they shall be executed with the original or facsimile signature of the auditor. A general obligation bond is valid and binding if it bears the signatures of the officers in office on the date of the execution of the bonds, notwithstanding that any or all persons whose signatures appear have ceased to be such officers prior to the delivery of the bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{General obligation bonds issued pursuant to this part are negotiable instruments.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7289; C97, S13, \'a7403; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5277;}}}{ C46, 50, 54, 58, 62, 66, \'a7346.3; C71, 73, \'a7345.16, 346.3, 346A.3; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7330.16}}}{, }{{\f5\fs18\hyphpar0\qj{345.16}}}{, }{{\f5\fs18\hyphpar0\qj{346.3}}}{, }{{\f5\fs18\hyphpar0\qj{346A.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.446}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7445}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a737.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.447}}}{\*\bkmkstart stylerid1_2E8_2E5_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Taxes to pay bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Taxes for the payment of general obligation bonds shall be levied in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 76}}}{{\f5\fs18\hyphpar0\qj{, and the bonds are payable from the levy of unlimited ad valorem taxes on all the taxable property within the county through its debt service fund required by }}}{{\f5\fs18\hyphpar0\qj{section 331.430}}}{{\f5\fs18\hyphpar0\qj{ except that:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount estimated and certified to apply on principal and interest for any one year shall not exceed the maximum rate of tax, if any, provided by }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ for the purpose for which the bonds were issued. If general obligation bonds are issued for different categories, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.445}}}{{\f5\fs18\hyphpar0\qj{, the maximum rate of levies, if any, for each purpose shall apply separately to that portion of the bond issue for that category and the resolution authorizing the bond issue shall clearly set forth the annual debt service requirements with respect to each purpose in sufficient detail to indicate compliance with the rate of tax levy, if any.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount estimated and certified to apply on principal and interest for any one year may only exceed the statutory rate of levy limit, if any, by the amount that the registered voters of the county have approved at a special election, which may be held at the same time as the general election and may be included in the proposition authorizing the issuance of bonds, if an election on the proposition is necessary, or may be submitted as a separate proposition at the same election or at a different election. Notice of the election shall be given as specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the proposition includes issuing bonds and increasing the levy limit, it shall be in substantially the following form:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the county of }{{\f5\fs18\hyphpar0\qj{....................}}}{, state of Iowa, be authorized to }{{\f5\fs18\hyphpar0\qj{........................................}}}{ (here state purpose of project) and issue its general obligation bonds in an amount not exceeding the amount of $}{{\f5\fs18\hyphpar0\qj{................}}}{ for that purpose, and be authorized to levy annually a tax not exceeding }{{\f5\fs18\hyphpar0\qj{............}}}{ dollars and }{{\f5\fs18\hyphpar0\qj{............}}}{ cents per thousand dollars of the assessed value of the taxable property within the county to pay the principal of and interest on the bonds?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the proposition includes only increasing the levy limit it shall be in substantially the following form:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the county of }{{\f5\fs18\hyphpar0\qj{....................}}}{, state of Iowa, be authorized to levy annually a tax not exceeding }{{\f5\fs18\hyphpar0\qj{............}}}{ dollars and }{{\f5\fs18\hyphpar0\qj{............}}}{ cents per thousand dollars of the assessed value of the taxable property within the county to pay principal and interest on the bonded indebtedness of the county for the purpose of }{{\f5\fs18\hyphpar0\qj{........................................}}}{?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statutory or voted tax levy limitation does not limit the source of payment of bonds and interest, but only restricts the amount of bonds which may be issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the sole purpose of computing the amount of bonds which may be issued as the result of the application of a statutory or voted tax levy limitation, all interest on the bonds in excess of that accruing in the first twelve months may be excluded from the first annual levy of taxes, so that the need for including more than one year\u8217\'3fs interest on the first annual levy of taxes to pay the bonds and interest does not operate to further restrict the amount of bonds which may be issued, and in certifying the annual levies, the first annual levy of taxes shall be sufficient to pay all principal of and interest on the bonds becoming due prior to the next succeeding annual levy and the full amount of the annual levy shall be entered for collection as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 76}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, \'a7309.73; C71, 73, \'a7309.73, 346A.3; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7309.73}}}{, }{{\f5\fs18\hyphpar0\qj{330.16}}}{, }{{\f5\fs18\hyphpar0\qj{346A.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.447}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7446}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a748}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7140, 209}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 2, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a737.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.448}}}{\*\bkmkstart stylerid1_2E8_2E5_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statute of limitation \u8212\'3f powers \u8212\'3f conflicts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action shall not be brought which questions the legality of general obligation bonds or the power of the county to issue the bonds or the effectiveness of any proceedings relating to the authorization and issuance of the bonds from and after sixty days from the time the bonds are ordered issued by the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The enumeration in this part of specified powers and functions is not a limitation of the powers of counties, but this part and the procedures prescribed for exercising the powers and functions enumerated in this part control in the event of a conflict with any other law.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.448}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7447}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a737.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.449}}}{\*\bkmkstart stylerid1_2E8_2E5_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prior projects preserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Projects and proceedings for the issuance of general obligation bonds commenced before July 1, 1981, may be consummated and completed as required or permitted by any statute amended or repealed by }\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1981/CH0117.pdf" }{\fldrslt \cf5 \f5 \fs18{{1981 Iowa Acts, ch. 117}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{, as though the repeal or amendment had not occurred, and the rights, duties, and interests following from such projects and proceedings remain valid and enforceable. Projects commenced prior to July 1, 1981, may be financed by the issuance of general obligation bonds under any such amended or repealed law or by the issuance of general obligation bonds under }{{\f5\fs18\hyphpar0\qj{this part}}}{. For the purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{, commencement of a project includes but is not limited to action taken by the board or an authorized officer to fix a date for a hearing in connection with any part of the project, and commencement of proceedings for the issuance of general obligation bonds includes but is not limited to action taken by the board to fix a date for either a hearing or a sale in connection with any part of the general obligation bonds, or to order any part thereof to be issued.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.449}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7448}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 34, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a7143}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a737.6}}}{{\f5\fs12\hyphpar0\qj{, 37.27}}}{{\f5\fs12\hyphpar0\qj{, 232.142}}}{{\f5\fs12\hyphpar0\qj{, 359.45}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.450 through 331.460}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 4}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E6_2E1_2E2}{REVENUE BONDS}{\*\bkmkend stylerid1_2E8_2E6_2E1_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7145A.20}}}{{\f5\fs12\qc{, 331.552}}}{{\f5\fs12\qc{, 347A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.461}}}{\*\bkmkstart stylerid1_2E8_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in this part, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCombined county enterprise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means two or more county enterprises combined and operated as a single enterprise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty enterprise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Airports and airport systems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Works and facilities useful and necessary for the collection, treatment, purification, and disposal in a sanitary manner of the liquid and solid waste, sewage, and industrial waste of the county, including sanitary disposal projects as defined in }}}{{\f5\fs18\hyphpar0\qj{section 455B.301}}}{{\f5\fs18\hyphpar0\qj{ and sanitary sewage systems, and including the acquisition, establishment, construction, purchase, equipment, improvement, extension, operation, maintenance, reconstruction, and repair of the works and facilities within or without the limits of the county, and including works and facilities to be jointly used by the county and other political subdivisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Swimming pools and golf courses, including their acquisition, establishment, construction, purchase, equipment, improvement, extension, operation, maintenance, reconstruction, and repair.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The equipment, enlargement, and improvement of a county public hospital previously established and operating under }}}{{\f5\fs18\hyphpar0\qj{chapter 347}}}{{\f5\fs18\hyphpar0\qj{, including acquisition of the necessary lands, rights-of-way, and other property, subject to approval by the board of hospital trustees. However, notice of the proposed bond issue shall be published at least once each week for two consecutive weeks and if, within thirty days following the date of the first publication, a petition requesting an election on the proposal and signed by eligible electors of the county equal to at least twenty percent of the votes cast at the preceding election for governor is filed with the county auditor, the proposal is subject to the election requirements in }}}{{\f5\fs18\hyphpar0\qj{section 331.442, subsections 2, 3, and 4}}}{{\f5\fs18\hyphpar0\qj{, for general county purpose bonds. Bonds issued under this paragraph shall mature in not more than thirty years from date of issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a county with a population of less than one hundred fifty thousand, a county hospital established under }}}{{\f5\fs18\hyphpar0\qj{chapter 37}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{347A}}}{{\f5\fs18\hyphpar0\qj{, including its acquisition, construction, equipment, enlargement, and improvement, and including necessary lands, rights-of-way, and other property. However, bonds issued under this paragraph shall mature in not more than thirty years from date of issuance, and are subject to the notice and election requirements of bonds issued under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A waterworks or single benefited water district under }}}{{\f5\fs18\hyphpar0\qj{section 357.35}}}{{\f5\fs18\hyphpar0\qj{, including land, easements, rights-of-way, fixtures, equipment, accessories, improvements, appurtenances, and other property necessary or useful for the operation of the waterworks or district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Housing for persons who are elderly or persons with disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGross revenue\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all income and receipts derived from the operation of a county enterprise or combined county enterprise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNet revenues\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means gross revenues less operating expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOperating expense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means salaries, wages, cost of maintenance and operation, materials, supplies, insurance, and all other items normally included under recognized accounting practices, but does not include allowances for depreciation in the value of physical property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPledge order\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a promise to pay out of the net revenues of a county enterprise or combined county enterprise, which is delivered to the contractors or other persons in payment of all or part of the cost of the project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProject\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the acquisition, construction, reconstruction, extending, remodeling, improving, repairing, and equipping of all or part of a county enterprise or combined county enterprise within or without the boundaries of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRates\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means rates, fees, tolls, rentals, and charges for the use of or service provided by a county enterprise or combined county enterprise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRevenue bond\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a negotiable bond issued by a county and payable from the net revenues of a county enterprise or combined county enterprise.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.461}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7460}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a749}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2}}}{a.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7330.14}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.461(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7460}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{b.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C35, \'a76066-f1, -f5, -f8; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6066.24 \u8211\'3f 6066.32;}}}{ C46, 50, 54, 58, \'a7394.1, 394.5 \u8211\'3f 394.9; C62, 66, 71, 73, \'a7394.1, 394.5 \u8211\'3f 394.9, 394.12; C75, 77, \'a7332.44; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.44}}}{, }{{\f5\fs18\hyphpar0\qj{332.52}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.461(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7460}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{c.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C35, \'a76066-f1, 6066-f3, 6066-f6 \u8211\'3f 6066-f8; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6066.24, 6066.26, 6066.29 \u8211\'3f 6066.32;}}}{ C46, 50, 54, 58, 62, 66, \'a7394.1, 394.3, 394.6 \u8211\'3f 394.9; C71, 73, \'a7394.1, 394.3, 394.6 \u8211\'3f 394.9, 394.13; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.44}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.461(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7460}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{d.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.27}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.461(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7460}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{e.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347A.1}}}{ \u8211\'3f 347A.4; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.461(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7460}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{f.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.52}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.461(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7460}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1219, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1, 3 \u8211\'3f 9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.461(2 \u8211\'3f 9)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7460}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 76, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 56, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1072, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 37, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1079, \'a713}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a76B.2D}}}{{\f5\fs12\hyphpar0\qj{, 23A.2}}}{{\f5\fs12\hyphpar0\qj{, 331.465}}}{{\f5\fs12\hyphpar0\qj{, 347.7}}}{{\f5\fs12\hyphpar0\qj{, 347A.1}}}{{\f5\fs12\hyphpar0\qj{, 357.35}}}{{\f5\fs12\hyphpar0\qj{, 358.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.462}}}{\*\bkmkstart stylerid1_2E8_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County enterprises \u8212\'3f combined county enterprises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county which proposes to establish, own, acquire by purchase, condemnation, or otherwise, lease, sell, construct, reconstruct, extend, remodel, improve, repair, equip, maintain and operate within or without its corporate limits a county enterprise or combined county enterprise financed by revenue bonds shall do so in accordance with this part.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a combined county enterprise is dissolved, each county enterprise which was a part of the combined county enterprise shall continue in existence as a separate county enterprise until it is abandoned by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A combined county enterprise may be established, but if there are obligations outstanding which by their terms are payable from the revenues of any county enterprise involved, the obligations shall be assumed by the board subject to all terms established at the time of the original issue, or refunded through the issuance of revenue bonds of the combined county enterprise as a part of the procedure for the establishment of the combined county enterprise, or funds sufficient to pay the principal of and all interest and premium, if any, on the outstanding obligations at and prior to maturity shall be set aside and pledged for that purpose. Revenues earmarked for payment of the obligations shall be handled by the board in the same manner as they were handled for the county enterprise involved. A county enterprise shall not be abandoned and a combined county enterprise shall not be dissolved so long as there are obligations outstanding which by their terms are payable from the revenues of the county enterprise or combined county enterprise unless funds sufficient to pay the principal of and all interest and premium, if any, on the outstanding obligations at and prior to maturity have been set aside and pledged for that purpose.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.462}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7461}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728M.3}}}{{\f5\fs12\hyphpar0\qj{, 358.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.463}}}{\*\bkmkstart stylerid1_2E8_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Procedure for financing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may carry out projects, borrow money, and issue revenue bonds and pledge orders to pay all or part of the cost of projects, the revenue bonds and pledge orders to be payable solely out of the net revenues of the county enterprise or combined county enterprise involved in the project. The cost of a project includes the construction contracts, interest upon the revenue bonds and pledge orders during the period or estimated period of construction and for twelve months thereafter, or for twelve months after the acquisition date, reserve funds as the board deems advisable in connection with the project and the issuance of revenue bonds and pledge orders, and the costs of engineering, architectural, technical and legal services, preliminary reports, surveys, property valuations, estimates, plans, specifications, notices, acquisition of real and personal property, consequential damages or costs, easements, rights-of-way, supervision, inspection, testing, publications, printing and sale of bonds and provisions for contingencies. The board may sell revenue bonds or pledge orders at public or private sale in the manner prescribed by }}}{{\f5\fs18\hyphpar0\qj{chapter 75}}}{{\f5\fs18\hyphpar0\qj{ and may deliver revenue bonds and pledge orders to the contractors, sellers, and other persons furnishing materials and services constituting a part of the cost of the project in payment therefor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may deliver its revenue bonds to the federal government or any agency thereof which has loaned the county money for sanitary or solid waste projects, water projects, or other projects, for which the government has a loan program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may issue revenue bonds to refund revenue bonds, pledge orders, and other obligations which are by their terms payable from the net revenues of the same county enterprise or combined county enterprise, or from a county enterprise comprising a part of the combined county enterprise, at lower, the same, or higher rates of interest. A county may sell refunding revenue bonds at public or private sale in the manner prescribed by }}}{{\f5\fs18\hyphpar0\qj{chapter 75}}}{{\f5\fs18\hyphpar0\qj{ and apply the proceeds to the payment of the obligations being refunded, and may exchange refunding revenue bonds in payment and discharge of the obligations being refunded. The principal amount of refunding revenue bonds may exceed the principal amount of the obligations being refunded to the extent necessary to pay any premium due on the call of the obligations being refunded and to fund interest accrued and to accrue on the obligations being refunded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may contract to pay not to exceed ninety-five percent of the engineer\u8217\'3fs estimated value of the acceptable work completed during the month to the contractor at the end of each month for work, material, or services. Payment may be made in warrants drawn on any fund from which payment for the work may be made. If such funds are depleted, anticipatory warrants may be issued bearing a rate of interest not exceeding that permitted by }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{ even if a collection of taxes or special assessments or income from the sale of bonds which have been authorized and are applicable to the public improvement takes place after the fiscal year in which the warrants are issued. If the board arranges for the private sale of anticipatory warrants, they may be sold and the proceeds used to pay the contractor. The warrants may also be used to pay other persons furnishing services constituting a part of the cost of the public improvement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.463}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7462}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a750}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728M.3}}}{{\f5\fs12\hyphpar0\qj{, 358.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.464}}}{\*\bkmkstart stylerid1_2E8_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revenue bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may issue revenue bonds pursuant to a resolution adopted at a regular or special meeting by a majority of the total number of members of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before the board institutes proceedings for the issuance of revenue bonds, it shall fix a time and place of meeting at which it proposes to take action, and give notice by publication in the manner directed in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{. The notice must include a statement of the time and place of the meeting, the maximum amount of the proposed revenue bonds, the purpose for which the revenue bonds will be issued, and the county enterprise or combined county enterprise whose net revenues will be used to pay the revenue bonds and interest thereon. At the meeting the board shall receive oral or written objections from any resident or property owner of the county. After all objections have been received and considered, the board, at the meeting or a date to which it is adjourned, may take additional action for the issuance of the bonds or abandon the proposal to issue bonds. Any resident or property owner of the county may appeal a decision of the board to take additional action to the district court of the county within fifteen days after the additional action is taken, but the additional action of the board is final and conclusive unless the court finds that the board exceeded its authority. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ with respect to notice, hearing, and appeal are in lieu of those contained in any other law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue bonds may bear dates, bear interest at rates not exceeding those permitted by }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{, mature in one or more installments, be in either coupon or registered form, carry registration and conversion privileges, be payable as to principal and interest at times and places, be subject to terms of redemption prior to maturity with or without premium, and be in one or more denominations, all as provided by the resolution of the board authorizing their issuance. The resolution may also prescribe additional provisions, terms, conditions, and covenants which the board deems advisable, consistent with this part, including provisions for creating and maintaining reserve funds, the issuance of additional revenue bonds ranking on a parity with such revenue bonds and additional revenue bonds junior and subordinate to such revenue bonds, and that such revenue bonds shall rank on a parity with or be junior and subordinate to any revenue bonds which may be then outstanding. Revenue bonds are a contract between the county and holders and the resolution is a part of the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue bonds shall be executed by the chairperson of the board and the auditor. If coupons are attached to the revenue bonds, they shall be executed with the original or facsimile signature of the auditor. A revenue bond is valid and binding for all purposes if it bears the signatures of the officers in office on the date of the execution of the bonds notwithstanding that any or all persons whose signatures appear have ceased to be such officers prior to the delivery of the bonds. The issuance of revenue bonds shall be recorded in the office of the treasurer, and a certificate of the recording by the treasurer shall be printed on the back of each revenue bond.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue bonds, pledge orders and warrants issued under this part are negotiable instruments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may issue pledge orders pursuant to a resolution adopted by a majority of the total number of supervisors, at a regular or special meeting, ordering their issuance and delivery in payment for all or part of the cost of a project. Pledge orders may bear interest at rates not exceeding those permitted by }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The physical properties of a county enterprise or combined county enterprise shall not be pledged or mortgaged to secure the payment of revenue bonds or pledge orders or the interest thereon.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.464}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7463}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728M.3}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 331.402}}}{{\f5\fs12\hyphpar0\qj{, 358.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.465}}}{\*\bkmkstart stylerid1_2E8_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rates for proprietary functions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may establish, impose, adjust, and provide for the collection of rates to produce gross revenues at least sufficient to pay the expenses of operation and maintenance of the county enterprise or combined county enterprise and, if revenue bonds or pledge orders are issued and outstanding under this part, shall establish, impose, adjust, and provide for the collection of rates to produce gross revenues at least sufficient to pay the expenses of operation and maintenance of the county enterprise or combined county enterprise, and to leave a balance of net revenues sufficient at all times to pay the principal of and interest on the revenue bonds and pledge orders as they become due and to maintain a reasonable reserve for the payment of the principal and interest, and a sufficient portion of net revenues shall be pledged for that purpose. Rates shall be established by ordinance. Rates or charges for the services of a county enterprise defined in }}}{{\f5\fs18\hyphpar0\qj{section 331.461, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if not paid as provided by ordinance, constitute a lien upon the premises served and may be certified to the county treasurer and collected in the same manner as taxes. The treasurer may charge five dollars for each lien certified as an administrative expense, which amount shall be added to the amount of the lien to be collected at the time of payment of the assessment from the payor and credited to the county general fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By ordinance establish, impose, adjust and provide for the collection of charges for connection to a county enterprise or combined county enterprise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contract for the use of or services provided by a county enterprise or combined county enterprise with persons whose type or quantity of use or service is unusual.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lease for a period not to exceed fifteen years all or part of a county enterprise or combined county enterprise, if the lease will not reduce the net revenues to be produced by the county enterprise or combined county enterprise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contract for a period not to exceed forty years with other governmental bodies for the use of or the services provided by the county enterprise or combined county enterprise on a wholesale basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contract for a period not to exceed forty years with persons including but not limited to other governmental bodies for the purchase or sale of water.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.465}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7464}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 73, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728M.3}}}{{\f5\fs12\hyphpar0\qj{, 358.25}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Collection of taxes, see }{{\f5\fs12\hyphpar0\qj{chapter 445}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.466}}}{\*\bkmkstart stylerid1_2E8_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records \u8212\'3f accounts \u8212\'3f funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body of each county enterprise or combined county enterprise operated on a revenue producing basis shall maintain a proper system of books, records and accounts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The gross revenues of each county enterprise or combined county enterprise shall be deposited with the treasurer and kept by the treasurer in a separate account apart from the other funds of the county and from each other. The treasurer shall apply the gross revenues of each county enterprise or combined county enterprise only as ordered by the board and in strict compliance with the orders, including the provisions, terms, conditions and covenants of any and all resolutions of the board pursuant to which revenue bonds or pledge orders are issued and outstanding.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.466}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7465}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728M.3}}}{{\f5\fs12\hyphpar0\qj{, 358.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.467}}}{\*\bkmkstart stylerid1_2E8_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pledge \u8212\'3f payment \u8212\'3f remedy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pledge of any net revenues of a county enterprise or combined county enterprise is valid and effective as to all persons including but not limited to other governmental bodies when it becomes valid and effective between the county and the holders of the revenue bonds or pledge orders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue bonds and pledge orders are payable both as to principal and interest solely out of the portion of the net revenues of the county enterprise or combined county enterprise pledged to their payment and are not a debt of or charge against the county within the meaning of any constitutional or statutory debt limitation provision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sole remedy for a breach or default of a term of a revenue bond or pledge order is a proceeding in law or in equity by suit, action, or mandamus to enforce and compel performance of the duties required by this part and of the terms of the resolution authorizing the issuance of the revenue bonds or pledge orders, or to obtain the appointment of a receiver to take possession of and operate the county enterprise or combined county enterprise, and to perform the duties required by this part and the terms of the resolution authorizing the issuance of the revenue bonds or pledge orders.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.467}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7466}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728M.3}}}{{\f5\fs12\hyphpar0\qj{, 358.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.468}}}{\*\bkmkstart stylerid1_2E8_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funds \u8212\'3f payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a county enterprise or combined county enterprise has on hand surplus funds, after making all deposits into all funds required by the terms, covenants, conditions, and provisions of outstanding revenue bonds, pledge orders, and other obligations which are payable from the revenues of the county enterprise or combined county enterprise and after complying with all of the requirements, terms, covenants, conditions and provisions of the proceedings and resolutions pursuant to which revenue bonds, pledge orders, and other obligations are issued, the board may transfer the surplus funds to any other fund of the county in accordance with applicable law, provided that a transfer shall not be made if it conflicts with any of the requirements, terms, covenants, conditions, or provisions of any resolution authorizing the issuance of revenue bonds, pledge orders, or other obligations which are payable from the revenues of the county enterprise or combined county enterprise which are then outstanding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This part does not prohibit or prevent the board from using funds derived from the issuance of general obligation bonds, the levy of special assessments and the issuance of special assessment bonds, and any other source which may be properly used for such purpose, to pay a part of the cost of a project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county shall pay for the use of or the services provided by the county enterprise or combined county enterprise as any other customer, except that the county may pay for use or service at a reduced rate or receive free use or service so long as the county complies with the provisions, terms, conditions and covenants of all resolutions pursuant to which revenue bonds or pledge orders are issued and outstanding.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.468}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7467}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728M.3}}}{{\f5\fs12\hyphpar0\qj{, 358.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.469}}}{\*\bkmkstart stylerid1_2E8_2E6_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statute of limitation \u8212\'3f powers \u8212\'3f conflicts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action shall not be brought which questions the legality of revenue bonds, the power of the board to issue revenue bonds, or the effectiveness of any proceedings relating to the authorization and issuance of revenue bonds, from and after sixty days from the time the bonds are ordered issued by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The enumeration in this part of specified powers and functions is not a limitation of the powers of counties, but this part and the procedures prescribed for exercising the powers and functions enumerated in this part control in the event of a conflict with any other law.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.469}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7468}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728M.3}}}{{\f5\fs12\hyphpar0\qj{, 358.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.470}}}{\*\bkmkstart stylerid1_2E8_2E6_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prior projects preserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Projects and proceedings for the issuance of revenue bonds, pledge orders, and other temporary obligations, commenced before July 1, 1981, may be completed as required or permitted by any statute amended or repealed by }\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1981/CH0117.pdf" }{\fldrslt \cf5 \f5 \fs18{{1981 Iowa Acts, ch. 117}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{, as though the amendment or repeal had not occurred, and the rights, duties, and interests resulting from the projects and proceedings remain valid and enforceable. Projects commenced prior to July 1, 1981, may be financed by the issuance of revenue bonds, pledge orders, and other temporary obligations under any such amended or repealed law or by the issuance of revenue bonds and pledge orders under this part. For purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{, commencement of a project includes but is not limited to action taken by the board or an authorized officer to fix a date for either a hearing or an election in connection with any part of the project, and commencement of proceedings for the issuance of revenue bonds, pledge orders, and other temporary obligations includes but is not limited to action taken by the board to fix a date for either a hearing or a sale in connection with any part of such revenue bonds, pledge orders, or other temporary obligations or to order any part thereof to be issued.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.470}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7469}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 34, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a7143}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7358.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.471}}}{\*\bkmkstart stylerid1_2E8_2E6_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County enterprise commissions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a commission established under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to manage a county enterprise or combined county enterprise. Upon receipt of a valid petition as defined in }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{ requesting that a proposal for establishment or discontinuance of a commission be submitted to the voters, or upon its own motion, the board shall submit the proposal at the next general election or at an election which includes a proposal to establish, acquire, lease, or dispose of the county enterprise or combined county enterprise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proposal for the establishment of a county enterprise commission shall specify a commission of either three or five members. If a majority of those voting approves the proposal, the board shall proceed as proposed. If a majority of those voting does not approve the proposal, the same or a similar proposal shall not be submitted to the voters of the county and the board shall not establish a commission for the same purpose for at least four years from the date of the election at which the proposal was defeated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a proposal to discontinue a commission receives a favorable majority vote, the commission is dissolved at the time provided in the proposal and shall turn over to the board the management of the county enterprise or combined county enterprise and all property relating to it.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a proposal to establish a commission receives a favorable majority vote, the commission is established at the time provided in the proposal. The board shall appoint the commission members, as provided in the proposal and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The board shall provide by resolution for staggered six-year terms for and shall set the compensation of commission members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commission member appointed to fill a vacancy occurring by reason other than the expiration of a term is appointed for the balance of the unexpired term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The title of a commission shall be appropriate to the county enterprise or combined county enterprise administered by the commission. A commission may be a party to legal action. A commission may exercise all powers of the board in relation to the county enterprise or combined county enterprise it administers, with the following exceptions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commission shall not certify taxes to be levied, pass ordinances or amendments, or issue general obligation bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The title to all property of a county enterprise or combined county enterprise shall be held in the name of the county, but the commission has all the powers and authorities of the board with respect to the acquisition by purchase, condemnation or otherwise, lease, sale or other disposition of the property, and the management, control and operation of the property, subject to the requirements, terms, covenants, conditions and provisions of any resolutions authorizing the issuance of revenue bonds, pledge orders, or other obligations which are payable from the revenues of the county enterprise or combined county enterprise, and which are then outstanding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commission shall make to the board a detailed annual report, including a complete financial statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Immediately following a regular or special meeting of a commission, the secretary of the commission shall prepare a condensed statement of the proceedings of the commission and cause the statement to be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{. The statement shall include a list of all claims allowed, showing the name of the person or firm making the claim, the reason for the claim, and the amount of the claim. If the reason for the claims is the same, two or more claims made by the same vendor, supplier, or claimant may be consolidated if the number of claims consolidated and the total consolidated claim amount are listed in the statement. However, the commission shall provide at its office upon request an unconsolidated list of all claims allowed. Salary claims must show the gross amount of the claim except that salaries paid to persons regularly employed by the commission, for services regularly performed by the persons shall be published once annually showing the gross amount of the salary. In counties having more than one hundred fifty thousand population the commission shall each month prepare in pamphlet form the statement required in this paragraph for the preceding month, and furnish copies to the public library, the daily and official newspapers of the county, the auditor, and to persons who apply at the office of the secretary, and the pamphlet shall constitute publication as required. Failure by the secretary to make publication is a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commission shall control tax revenues allocated to the county enterprise or combined county enterprise it administers and all moneys derived from the operation of the county enterprise or combined county enterprise, the sale of its property, interest on investments, or from any other source related to the county enterprise or combined county enterprise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys received by the commission shall be held by the county treasurer in a separate fund, with a separate account or accounts for each county enterprise or combined county enterprise. Moneys may be paid out of each account only at the direction of the appropriate commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commission is subject to }}}{{\f5\fs18\hyphpar0\qj{section 331.341, subsections 1, 2, 4 and 5}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 331.342}}}{{\f5\fs18\hyphpar0\qj{, in contracting for public improvements.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.471}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7470}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 42, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1018, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.321}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.472 through 331.475}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 5}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E7_2E1_2E2}{CURRENT AND NONCURRENT DEBT}{\*\bkmkend stylerid1_2E8_2E7_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.476}}}{\*\bkmkstart stylerid1_2E8_2E7_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expenditures confined to receipts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except as otherwise provided in }{{\f5\fs18\hyphpar0\qj{section 331.478}}}{, a county officer or employee shall not allow a claim, issue a warrant, or execute a contract which will result during a fiscal year in an expenditure from a county fund in excess of an amount equal to the collectible revenues in the fund for that fiscal year plus any unexpended balance in the fund from a previous year. A county officer or employee allowing a claim, issuing a warrant, or executing a contract in violation of }{{\f5\fs18\hyphpar0\qj{this section}}}{ is personally liable for the payment of the claim or warrant or the performance of the contract.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a723, 209}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.437}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.477}}}{\*\bkmkstart stylerid1_2E8_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Current debt authorized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A debt payable from resources which will have accrued in a fund by the end of the fiscal year in which the debt is incurred may be authorized only by resolution of the board. The debt may take the form of:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Anticipatory warrants subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 74}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Loans from other county funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other formal short-term debt instruments or obligations.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a724, 209}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.478}}}{\*\bkmkstart stylerid1_2E8_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Noncurrent debt authorized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may contract indebtedness and issue bonds as otherwise provided by state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpa