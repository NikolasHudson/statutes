par0\qj{; 2007 Acts, ch 215, \'a7219}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7199}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 43, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 75, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1019, \'a7125}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 130, \'a732, 35}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 100, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 12, \'a771, 73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71105, 2016, 2067, 2073}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7120, 137}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 94, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 148, \'a730, 53, 54}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a796.11}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 57 applies retroactively to January 1, 2025, to the estates of decedents dying on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 148, \'a754}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsections 25, 38, and 41 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 25, 38, and 41 stricken}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 57 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 76}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.757}}}{\*\bkmkstart stylerid1_2E9_2E8_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Temporary and full-time assistants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney may employ, with the approval of a judge of the district court, a temporary assistant to assist in the trial of a person charged with a felony. The temporary assistant shall be paid a reasonable compensation as determined by the board upon certification of the services rendered by the district judge before whom the defendant was tried.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney may appoint, with the approval of the board, an assistant county attorney to serve as a full-time prosecutor. A full-time prosecutor shall refrain from the private practice of law. The county attorney shall determine the compensation paid to a full-time prosecutor within the budget set for the county attorney\u8217\'3fs office by the board. Except in counties having a population of more than two hundred thousand, the annual salary of an assistant county attorney shall not exceed eighty-five percent of the maximum annual salary of a full-time county attorney.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7303; S13, \'a7303-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5243;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7341.7; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7341.7}}}{, }{{\f5\fs18\hyphpar0\qj{341.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.757}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7757}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7150, 209}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1267, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.758}}}{{\f5\fs12\hyphpar0\qj{, 331.903}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.758}}}{\*\bkmkstart stylerid1_2E9_2E8_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county attorney may:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer oaths and take affirmations as provided in }}}{{\f5\fs18\hyphpar0\qj{section 63A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appoint and remove deputies, clerks and assistants subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 331.757}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{331.903}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7303; S13, \'a7303-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5238, 5240;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7341.1}}}{, }{{\f5\fs18\hyphpar0\qj{341.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.758}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7758}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.759}}}{\*\bkmkstart stylerid1_2E9_2E8_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of private legal counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{At any stage of legal proceedings in which a county attorney is authorized to represent a county officer acting in the officer\u8217\'3fs official capacity, the county attorney may apply to the court for permission to withdraw from representation of the officer for cause. If the court allows the county attorney to withdraw, it shall appoint an attorney to represent the county officer. The costs of representing a county officer acting in the officer\u8217\'3fs official capacity shall be paid from the court expense fund or the general fund of the county.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.759}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 119, \'a71}}}{]}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.760 to 331.774}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 7}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E9_2E1_2E2}{RESERVED}{\*\bkmkend stylerid1_2E9_2E9_2E1_2E2}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.775 to 331.800}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 8}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E1_30_2E1_2E2}{COUNTY MEDICAL EXAMINER}{\*\bkmkend stylerid1_2E9_2E1_30_2E1_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a797B.1A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.801}}}{\*\bkmkstart stylerid1_2E9_2E1_30_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E1_30_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County medical examiner \u8212\'3f appointment, qualifications, and assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county medical examiner shall be appointed by the board for a two-year term. The term of office shall commence on the first day in January which is not a Sunday or holiday and continue for two years or until a successor is appointed and qualifies as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A vacancy shall be filled by the board for the unexpired term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To serve as a county medical examiner a person shall be licensed in this state as a doctor of medicine and surgery, a doctor of osteopathic medicine and surgery, or an osteopathic physician. The medical examiner shall be appointed by the board from lists of two or more names submitted by the medical society and the osteopathic society of the county in which the candidate resides. If names are not submitted by either society, the board may appoint any licensed physician, osteopathic physician and surgeon, or osteopathic physician of the county. If a qualified physician of the county will not serve, the board may appoint a physician from another county. If a county medical examiner is unable to serve in a particular case or for a period of time, the medical examiner shall promptly notify the chairperson of the board who shall designate some other qualified physician to serve temporarily.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may provide laboratory facilities, deputy medical examiners, and other professional, technical and clerical assistance as required by the county medical examiner in the performance of official duties. However, the requirements shall be subject to prior approval by the state medical examiner.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.1}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.801(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7800, 805}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7201, 202; R60, \'a7411, 412; C73, \'a7367, 368; C97, \'a7528, 529; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5217, 5218;}}}{ C46, 50, 54, 58, \'a7339.21, 339.22; C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.2}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.801(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7800}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[S13, \'a7520; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5206;}}}{ C46, 50, 54, 58, \'a7339.9; C62, 66, \'a7339.8; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.801(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7800}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7124.553}}}{{\f5\fs12\hyphpar0\qj{, 141A.5}}}{{\f5\fs12\hyphpar0\qj{, 142C.2}}}{{\f5\fs12\hyphpar0\qj{, 331.321}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.802}}}{\*\bkmkstart stylerid1_2E9_2E1_30_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E1_30_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deaths \u8212\'3f reported and investigated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person\u8217\'3fs death that affects the public interest as specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall be reported to the county medical examiner or the state medical examiner by the physician in attendance, any law enforcement officer having knowledge of the death, the funeral director, or any other person present. The appropriate medical examiner shall notify the city or state law enforcement agency or sheriff and take charge of the body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person\u8217\'3fs death affects the public interest as specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the county medical examiner shall conduct a preliminary investigation of the cause and manner of death, prepare a written report of the findings, promptly submit the full report to the state medical examiner on forms prescribed for that purpose, and submit a copy of the report to the county attorney.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 218.64}}}{{\f5\fs18\hyphpar0\qj{ or as otherwise provided by law, for each preliminary investigation and the preparation and submission of the required reports, the county medical examiner and medical examiner investigator shall receive from the county of appointment or the decedent\u8217\'3fs county of residence a fee determined by the board of the county of appointment plus the examiner\u8217\'3fs and investigator\u8217\'3fs actual expenses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee and expenses shall be submitted by the county medical examiner and the medical examiner investigator as a joint invoice to the county of appointment which may immediately pay the invoice. If the county of appointment pays the invoice, the county of appointment shall seek reimbursement from the decedent\u8217\'3fs county of residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the county of appointment elects not to pay an invoice under subparagraph (2), the county shall forward the joint invoice to the decedent\u8217\'3fs county of residence for payment to the county medical examiner and the medical examiner investigator. If the county medical examiner and medical examiner investigator do not receive payment from the county of the decedent\u8217\'3fs residence within sixty days of receiving the joint invoice, the county of appointment shall pay the invoice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person\u8217\'3fs death is caused by a defendant for whom a judgment of conviction and sentence is rendered under }}}{{\f5\fs18\hyphpar0\qj{section 707.2}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{707.3}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{707.4}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{707.5}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{707.6A}}}{{\f5\fs18\hyphpar0\qj{, the county of the person\u8217\'3fs residence or the county of appointment, as applicable, may recover from the defendant the fee and expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee and expenses of the county medical examiner who performs an autopsy or conducts an investigation of a person who dies after being brought into this state for emergency medical treatment by or at the direction of an out-of-state law enforcement officer or public authority shall be paid by the state. A claim for payment shall be filed with the state appeal board and, if authorized by the board, shall be paid out of moneys in the general fund of the state not otherwise appropriated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A death affecting the public interest includes, but is not limited to, any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violent death, including homicide, suicide, or accidental death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death caused by thermal, chemical, electrical, or radiation injury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death caused by criminal abortion including self-induced, or by sexual abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death related to disease thought to be virulent or contagious which may constitute a public hazard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death that has occurred unexpectedly or from an unexplained cause.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death of a person confined in a prison, jail, or correctional institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death of a person who was prediagnosed as a terminal or bedfast case who did not have a physician in attendance within the preceding thirty days; or death of a person who was admitted to and had received services from a hospice program as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135J.1}}}{{\f5\fs18\hyphpar0\qj{, if a physician or registered nurse employed by the program was not in attendance within thirty days preceding death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death of a person if the body is not claimed by a person authorized to control the deceased person\u8217\'3fs remains under }}}{{\f5\fs18\hyphpar0\qj{section 144C.5}}}{{\f5\fs18\hyphpar0\qj{, or a friend.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death of a person if the identity of the deceased is unknown.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death of a child under the age of two years if death results from an unknown cause or if the circumstances surrounding the death indicate that sudden infant death syndrome may be the cause of death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Death of a person committed or admitted to a state mental health institute, a state resource center, or the state training school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county medical examiner shall conduct the investigation in the manner required by the state medical examiner and shall determine whether the public interest requires an autopsy or other special investigation. However, if the death occurred in the manner specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ the county medical examiner shall order an autopsy, claims for the payment of which shall be filed with the state appeal board and, if authorized by the board, shall be paid out of moneys in the general fund of the state not otherwise appropriated. In determining the need for an autopsy, the county medical examiner may consider the request for an autopsy from a public official or private person, but the state medical examiner or the county attorney of the county where the death occurred may require an autopsy except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If after the county medical examiner\u8217\'3fs or state medical examiner\u8217\'3fs investigation of a deceased child the medical examiner determines that the deceased child\u8217\'3fs cause and manner of death are obvious and there are no significant legal, medical, or investigative concerns by the medical examiner, social services, or law enforcement, an autopsy shall not be required under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county medical examiner may refer a body for autopsy or further investigation pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ to any facility accredited by the national association of medical examiners. The county shall pay to the receiving facility a fee equal to an autopsy fee established by the office of the state medical examiner by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person making an autopsy shall promptly file a complete record of the findings in the office of the state medical examiner and the county attorney of the county where death occurred and the county attorney of the county where any injury contributing to or causing the death was sustained.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A summary of the findings resulting from an autopsy of a child under the age of two years whose death occurred in the manner specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ shall be transmitted immediately by the physician who performed the autopsy to the county medical examiner. The report shall be forwarded to the parent, guardian, or custodian of the child by the county medical examiner or a designee of the county medical examiner, or through the infant\u8217\'3fs attending physician. A copy of the autopsy report filed with the county attorney shall be available to the parents, guardian, or custodian upon request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The report of an investigation made by the state medical examiner or a county medical examiner and the record and report of an autopsy made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 691}}}{{\f5\fs18\hyphpar0\qj{, shall be received as evidence in any court or other proceedings, except that statements by witnesses or other persons and conclusions on extraneous matters included in the report are not admissible. The person preparing a report or record given in evidence may be subpoenaed as a witness in any civil or criminal case by any party to the cause. A copy of a record, photograph, laboratory finding, or record in the office of the state medical examiner or any medical examiner, when attested to by the state medical examiner or a staff member or the medical examiner in whose office the record, photograph, or finding is filed, shall be received as evidence in any court or other proceedings for any purpose for which the original could be received without proof of the official character of the person whose name is signed to it.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In case of a sudden, violent, or suspicious death after which the body is buried without an investigation or autopsy, the county medical examiner, upon being advised of the facts, shall notify the county attorney. The county attorney shall apply for a court order requiring the body to be exhumed in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 144}}}{{\f5\fs18\hyphpar0\qj{. Upon receipt of the court order, an autopsy shall be performed by a medical examiner or by a pathologist designated by the medical examiner and the facts disclosed by the autopsy shall be communicated to the court ordering the disinterment for appropriate action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where donation of the remains of the deceased to a medical school or similar institution equipped with facilities to perform autopsies is provided by will or directed by the person authorized to control the deceased person\u8217\'3fs remains under }}}{{\f5\fs18\hyphpar0\qj{section 144C.5}}}{{\f5\fs18\hyphpar0\qj{, any autopsy under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be performed at the direction of the school or institution, and in such a manner as to further the purpose of the donation, while serving the public interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an autopsy is ordered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the county shall reimburse the funeral director for all costs associated with the transportation of the body to and from the facility performing the autopsy at a rate equivalent to the rate of reimbursement allowed under the standard mileage rate method for computation of business expenses pursuant to the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ at the time the transportation occurs plus any other associated fees.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1, 2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7186, 187, 202, 2539; R60, \'a7396, 397, 412, 4148; C73, \'a7352, 353, 368, 3799; C97, \'a7515, 517, 526, 529, 531; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5200, 5202, 5214, 5218, 5237;}}}{ C46, 50, 54, 58, \'a7339.3, 339.5, 339.17, 339.19, 339.22, 340.19; C62, 66, \'a7339.5; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.4}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.802(1, 2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7801}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7186; R60, \'a7396; C73, \'a7352; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5200, 5201;}}}{ C46, 50, 54, 58, \'a7339.3, 339.4; C62, 66, \'a7339.4; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.6}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.802(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7801}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.7}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.802(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7801}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7187, 188, 193; R60, \'a7397, 398, 403; C73, \'a7353, 354, 359; C97, \'a7517, 518, 521; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5202, 5203, 5208;}}}{ C46, 50, 54, 58, \'a7339.5, 339.6, 339.11; C62, 66, \'a7339.6; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.8}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.802(5)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7801}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7190 \u8211\'3f 192, 199; R60, \'a7400 \u8211\'3f 402, 409; C73, \'a7356 \u8211\'3f 358, 365; C97, S13, \'a7520; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5205, 5206;}}}{ C46, 50, 54, 58, \'a7339.8, 339.9; C62, 66, \'a7339.9; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.10}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.802(6)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7801}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C62, 66, \'a7339.7; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.14}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.802(7)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7801}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.802(8)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7801}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 69, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1139, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1024, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 141, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1098, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1051, \'a717, 18, 22}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1187, \'a7137, 138}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 81, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1125, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 100, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 26, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 174, \'a745}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7141A.5}}}{{\f5\fs12\hyphpar0\qj{, 144.28}}}{{\f5\fs12\hyphpar0\qj{, 144.56}}}{{\f5\fs12\hyphpar0\qj{, 218.64}}}{{\f5\fs12\hyphpar0\qj{, 222.12}}}{{\f5\fs12\hyphpar0\qj{, 226.34}}}{{\f5\fs12\hyphpar0\qj{, 331.805}}}{{\f5\fs12\hyphpar0\qj{, 691.6}}}{{\f5\fs12\hyphpar0\qj{, 910.3A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.803}}}{\*\bkmkstart stylerid1_2E9_2E1_30_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E1_30_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Examination certificate \u8212\'3f fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon application and payment of a fee determined by the board, the county medical examiner shall provide an examination certificate to the person requesting it and file a copy of the certificate in the medical examiner\u8217\'3fs office. The certificate is not required in the case of a stillborn infant if a physician was present at the stillbirth and the cause of the stillbirth, as certified by the attending physician as provided in }{{\f5\fs18\hyphpar0\qj{chapter 144}}}{, does not require an investigation by a medical examiner.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, \'a7339.12; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.13}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.803}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7802}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7141A.5}}}{{\f5\fs12\hyphpar0\qj{, 144.56}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.804}}}{\*\bkmkstart stylerid1_2E9_2E1_30_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E1_30_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disposition of body and other property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After an investigation has been completed, including an autopsy if one is performed, the body shall be prepared for transportation. The body shall be transported by a funeral director chosen by a person authorized to control the remains of the deceased person under }}}{{\f5\fs18\hyphpar0\qj{section 144C.5}}}{{\f5\fs18\hyphpar0\qj{, for burial or other appropriate disposition. A medical examiner shall not use influence in favor of a particular funeral director. However, if a person other than a funeral director assumes custody of a dead body, the person shall secure a burial transit permit pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 144.32}}}{{\f5\fs18\hyphpar0\qj{. If no one claims a body, it shall be disposed of as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 142}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If no one is entitled by law to the property or money found on a deceased person, the property shall be deposited with the clerk of the district court who shall dispose of it as provided by law.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7200; R60, \'a7410; C73, \'a7366; C97, \'a7527, 532, 533; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5215, 5216;}}}{ C46, 50, 54, 58, \'a7339.19, 339.20; C62, 66, \'a7339.10, 339.11; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.11}}}{, }{{\f5\fs18\hyphpar0\qj{339.12}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.804}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7803}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1098, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1051, \'a719, 22}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7141A.5}}}{{\f5\fs12\hyphpar0\qj{, 144.56}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.805}}}{\*\bkmkstart stylerid1_2E9_2E1_30_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E1_30_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited actions \u8212\'3f cremation permit \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a death occurs in the manner specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.802, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the body, clothing, and any articles upon or near the body shall not be disturbed or removed from the position in which it is found, and physical or biological evidence shall not be obtained or collected from the body, without authorization from the county medical examiner or the state medical examiner except for the purpose of preserving the body from loss or destruction or permitting the passage of traffic on a highway, railroad or airport, or unless the failure to immediately remove the body might endanger life, safety, or health. A person who moves, disturbs, or conceals a body, clothing, or any articles upon or near the body or who obtains or collects physical or biological evidence in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 691}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful to embalm a body when the funeral director has reason to believe death occurred in a manner specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.802, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, when there is evidence sufficient to arouse suspicion of crime in connection with the cause of death of the deceased, or when it is the duty of a medical examiner to view the body and investigate the death of the deceased person, until the permission of a county medical examiner has been obtained. When feasible, the body shall be released to the funeral director for embalming within twenty-four hours of death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful to cremate, bury, or send out of the state the body of a deceased person when death occurred in a manner specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.802, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, until a medical examiner certifies in writing that the examiner has viewed the body, has made personal inquiry into the cause and manner of death, and all necessary autopsy or postmortem examinations have been completed. However, the body of a deceased person may be sent out of state for the purpose of an autopsy or postmortem examination if the county medical examiner certifies in writing that the out-of-state autopsy or postmortem examination is necessary or, in the case of a death which is not of public interest as specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.802, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, if the attending physician certifies to the county medical examiner that the performance of the autopsy out of state is proper.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person authorized to control the remains of a deceased person under }}}{{\f5\fs18\hyphpar0\qj{section 144C.5}}}{{\f5\fs18\hyphpar0\qj{ has requested that the body of the deceased person be cremated, a permit for cremation must be obtained from a medical examiner. Cremation permits by the medical examiner must be made on the most current forms prepared at the direction of and approved by the state medical examiner, with copies forwarded to the state medical examiner\u8217\'3fs office. Costs for the cremation permit issued by a medical examiner shall not exceed seventy-five dollars. The costs of the permit and other reasonable cremation expenses may be paid from the decedent\u8217\'3fs estate pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 633.425, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates a provision of }}}{{\f5\fs18\hyphpar0\qj{subsection 2 or 3}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a serious misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, \'a7339.12; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7339.9}}}{, }{{\f5\fs18\hyphpar0\qj{339.13}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.805}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7804}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 81, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1148, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1098, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 89, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1051, \'a720, 22}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 26, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7141A.5}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.806 through 331.900}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 9}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E11_2E1_2E2}{MISCELLANEOUS PROVISIONS}{\*\bkmkend stylerid1_2E9_2E11_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.901}}}{\*\bkmkstart stylerid1_2E9_2E11_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General duties of county officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided by state law, a county officer shall furnish to the governor or either house of the general assembly, upon their request, any information which the officer possesses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county officer shall not appear as an agent, attorney, or solicitor for another person in a matter pending before the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a county officer who is required to report the collection of fees to the board neglects or refuses to make the report, the board shall employ an expert accountant to examine the books, papers, and accounts of the delinquent officer and to make the required report. The expense of employing the expert accountant shall be charged to the delinquent officer and may be collected upon the official bond of the officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county officer, deputy officer, or employee shall not take, purchase, receive in payment, or exchange a warrant, scrip, or other evidence of the county\u8217\'3fs indebtedness or demand against the county for an amount less than the amount expressed on the face of the warrant, scrip, or other evidence of indebtedness or demand, plus the accrued interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county or township officer or employee shall not appropriate, give, or loan public funds to or in favor of an institution, school, association, or object that is under ecclesiastical or sectarian management or control unless the public funds are to be utilized for a project or program that benefits the public and does not require any religious or sectarian services, educational programs, or participation requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All reports and forms required to be submitted by a county officer to a state officer or agency shall be submitted on standardized forms furnished by the state officer or agency. The state officers and agencies which receive reports and forms from county officers shall consult with the department of management, shall devise standardized reports and forms which will permit computer processing of the information submitted, and shall distribute the standardized reports and forms to the county officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county officer, deputy officer, or employee who violates }}}{{\f5\fs18\hyphpar0\qj{subsection 4 or 5}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a7544; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5249;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7343.1}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.901(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7900}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C73, \'a7326; C97, \'a7545; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5250;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7343.2}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.901(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7900}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a7548; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5253;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7343.5}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.901(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7900}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[R60, \'a72186; C73, \'a7556; C97, \'a7596; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5255;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7343.7}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.901(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7900}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C73, \'a7552; C97, \'a7593; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5256;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7343.8}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.901(5)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7900}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7343.14}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.901(7)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7900}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[R60, \'a72188; C73, \'a7558; C97, \'a7598; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5257;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7343.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.901(8)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7900}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7152, 209}}}{; }{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710096, 10201}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1006, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.502}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.902}}}{\*\bkmkstart stylerid1_2E9_2E11_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Collection and disposition of fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise specifically provided by statute, the fees and other charges collected by the auditor, treasurer, recorder, and sheriff, and their deputies or employees, belong to the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each elective officer specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall maintain a record in the county system of each fee and charge collected. The record shall show the date, amount, payor, and type of service, and, when the fee is for recording an instrument, the names of the parties to the instrument. The record of the fees collected shall be retained for three years after audit of the county pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 11.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each elective officer specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall make a quarterly report to the board showing, by type, the fees collected during the preceding quarter. The officer shall pay at least quarterly to the county treasury the fees and charges collected, except for the county auditor\u8217\'3fs transfer fees, which shall be paid directly to the county treasurer by the county recorder. The officer shall receive a receipt and maintain a record of the date and amount of each payment into the county treasury. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the county treasurer if the county treasurer credits the fees daily to the county treasury and reports the receipts on the monthly report to the auditor and the board of supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When examining, settling, or verifying reports or accounts of fees or other monetary receipts of the county under }}}{{\f5\fs18\hyphpar0\qj{section 331.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fp\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{chapter 12B}}}{{\f5\fs18\hyphpar0\qj{, the cash on hand in the office of the county officer or employee subject to the settlement or examination need not be counted in the presence of, or by, the board of supervisors or other examining county officer. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit the actual counting of cash on hand in a county at the time of the examination or settlement if the examining authority requests the actual count.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each elective officer specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall retain overpayments of fees and other charges paid to the county in an amount of five dollars or less, unless the payor has requested a refund of the overpayment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7212; R60, \'a7423, 431; C73, \'a73785, 3796; C97, \'a7299, 480, 492, 495, 508; S13, \'a7498, 508, 550-c; SS15, \'a7479-a, 490-a, 495; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5245 \u8211\'3f 5247;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7342.1}}}{ \u8211\'3f 342.3; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.902}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7901}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1073, \'a71}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 6, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710097, 10201}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1125, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1079, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1025, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 121, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1085, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 75, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.507}}}{{\f5\fs12\hyphpar0\qj{, 331.508}}}{{\f5\fs12\hyphpar0\qj{, 331.558}}}{{\f5\fs12\hyphpar0\qj{, 331.602}}}{{\f5\fs12\hyphpar0\qj{, 331.607}}}{{\f5\fs12\hyphpar0\qj{, 331.655}}}{{\f5\fs12\hyphpar0\qj{, 558.66}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.903}}}{\*\bkmkstart stylerid1_2E9_2E11_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of deputies, assistants, and clerks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The auditor, treasurer, recorder, sheriff, and county attorney may each appoint, with approval of the board, one or more deputies, assistants, or clerks for whose acts the principal officer is responsible. The number of deputies, assistants, and clerks for each office shall be determined by the board and the number and approval of each appointment shall be adopted by a resolution recorded in the minutes of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When an appointment has been approved by the board, the principal officer making the appointment shall issue a written certificate of appointment which shall be filed and kept in the office of the auditor. A certificate of appointment may be revoked in writing by the principal officer making the appointment, which revocation shall also be filed and kept in the office of the auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each deputy officer shall give bond in an amount determined by the officer who has the authority to approve the bond of the deputy\u8217\'3fs principal officer, with sureties to be approved by that officer. Upon approval, the bond shall be filed and kept in the office of the auditor. Each deputy officer shall take the same oath as the deputy\u8217\'3fs principal officer which shall be endorsed on the certificate of appointment. The bond of a deputy sheriff shall be either a bond or liability policy as required by the sheriff with the approval of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each deputy officer, assistant and clerk shall perform the duties assigned by the principal officer making the appointment. During the absence or disability of the principal officer, the first deputy, or designee in those instances where there is no first deputy or in the absence or disability of the first deputy, shall perform the duties of the principal officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The auditor may also appoint temporary assistants as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.503}}}{{\f5\fs18\hyphpar0\qj{ and the county attorney may appoint temporary assistants or a full-time prosecutor as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.757}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum age for a person to be employed as a deputy sheriff appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is sixty-five years of age.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7411, 412, 415, 416; R60, \'a7642, 643, 646, 647, 2069; C73, \'a7766, 767, 769, 770, 1770; C97, \'a7298, 303, 481, 491, 496, 510, 2734; S13, \'a7303-a, 496; SS15, \'a7298, 481, 491, 496, 510-b, 2734-b; C24, 27, \'a75238 \u8211\'3f 5244; C31, 35, \'a75238 \u8211\'3f 5241, 5241-d1, 5242 \u8211\'3f 5244; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5238 \u8211\'3f 5241, 5241.1, 5242 \u8211\'3f 5244;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7341.1 \u8211\'3f 341.8; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7341.1}}}{ \u8211\'3f 341.9; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.903}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7902}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710098, 10201}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1061, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1173, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1183, \'a7112}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a797B.49C}}}{{\f5\fs12\hyphpar0\qj{, 97B.49G}}}{{\f5\fs12\hyphpar0\qj{, 331.502}}}{{\f5\fs12\hyphpar0\qj{, 331.503}}}{{\f5\fs12\hyphpar0\qj{, 331.553}}}{{\f5\fs12\hyphpar0\qj{, 331.603}}}{{\f5\fs12\hyphpar0\qj{, 331.652}}}{{\f5\fs12\hyphpar0\qj{, 331.758}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.904}}}{\*\bkmkstart stylerid1_2E9_2E11_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Salaries of deputies, assistants, and clerks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual base salary of the first and second deputy officer of the office of auditor, treasurer, and recorder, the deputy in charge of elections administration, the deputy in charge of the motor vehicle registration and title division, and the deputy in charge of driver\u8217\'3fs license issuance shall each be an amount not to exceed eighty-five percent of the annual salary of the deputy\u8217\'3fs principal officer. In offices where more than two deputies are required, the annual base salary of each additional deputy shall be an amount not to exceed eighty percent of the principal officer\u8217\'3fs salary. The amount of the annual base salary of each deputy shall be certified by the principal officer to the board and, if a deputy\u8217\'3fs annual base salary does not exceed the limitations specified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the board shall certify the annual base salary to the auditor. The board shall not certify a deputy\u8217\'3fs annual base salary which exceeds the limitations of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbase salary\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the basic compensation excluding overtime pay, longevity pay, shift differential pay, or other supplement pay and fringe benefits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each deputy sheriff shall receive an annual base salary as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual base salary of a first or second deputy sheriff shall not exceed eighty-five percent of the annual base salary of the sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual base salary of any other deputy sheriff shall not exceed the annual base salary of the first or second deputy sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff shall set the annual base salary of each deputy sheriff who is classified as exempt under the federal Fair Labor Standards Act of 1938, as amended, subject to the limitations specified in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The sheriff shall certify the annual base salaries of the exempt deputy sheriffs to the board and, if the limitations of paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are not exceeded, the board shall certify the annual base salaries to the county auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall set the annual base salaries of any deputy sheriffs who are not classified as exempt under the federal Fair Labor Standards Act of 1938, as amended. Upon certification by the sheriff, the board shall review, and may modify, the annual base salaries of the deputy sheriffs who are not classified as exempt. The annual base salaries set by the board are subject to the limitations specified in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbase salary\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the basic compensation excluding overtime pay, longevity pay, shift differential pay, or other supplement pay and fringe benefits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual salary of each assistant county attorney shall be determined by the county attorney within the budget set for the county attorney\u8217\'3fs office by the board. The salary of an assistant county attorney shall not exceed eighty-five percent of the maximum salary of a full-time county attorney. The county attorney shall inform the board of the full-time or part-time status of each assistant county attorney. In the case of a part-time assistant county attorney, the county attorney shall inform the board of the approximate number of hours per week the assistant county attorney shall devote to official duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall determine the compensation of extra help and clerks appointed by the principal county officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The deputy officers, assistants, clerks, and other employees of the county are also entitled to reimbursement for actual and necessary expenses incurred in the performance of their official duties.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7417; R60, \'a7648; C73, \'a7771; C97, \'a7298, 481, 491, 496; S13, \'a7496; SS15, \'a7298, 298-a, 481, 491; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5221, 5223, 5225, 5331;}}}{ C46, \'a7340.2, 340.4, 340.6, 340.12; C50, 54, 58, 62, \'a7340.2; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7340.4}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.904(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7903}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7417; R60, \'a7648; C73, \'a7771; C97, \'a7510; SS15, \'a7510-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5227;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7340.8}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.904(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7903}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a7303; S13, \'a7303-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5229;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7340.10; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7340.10}}}{, }{{\f5\fs18\hyphpar0\qj{341.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.904(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7903}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7417; R60, \'a7648; C73, \'a7771; C97, \'a7298, 481, 491, 496, 510; S13, \'a7496; SS15, \'a7298, 298-a, 481, 491, 510-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5221, 5223, 5225, 5227, 5331;}}}{ C46, \'a7340.2, 340.4, 340.6, 340.8, 340.12; C50, 54, 58, 62, \'a7340.2, 340.8; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7340.4}}}{, }{{\f5\fs18\hyphpar0\qj{340.8}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.904(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7903}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.904(5)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7903}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 34, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 123, \'a7153, 209}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 186, \'a710099, 10201}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 195, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1004, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 142, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 123, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 123, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728E.30}}}{{\f5\fs12\hyphpar0\qj{, 331.324}}}{{\f5\fs12\hyphpar0\qj{, 341A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.905}}}{\*\bkmkstart stylerid1_2E9_2E11_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County compensation board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A board of supervisors may vote to establish a county compensation board subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The county compensation board shall be composed of seven members who are residents of the county. The members of the county compensation board shall be selected as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two members shall be appointed by the board of supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall be appointed by each of the following county officers:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{the county auditor, county attorney, county recorder, county treasurer, and county sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the county compensation board shall be appointed to four-year, staggered terms of office. The members of the county compensation board shall not be officers or employees of the state or a political subdivision of the state. A term shall be effective on the first of July of the year of appointment and a vacancy shall be filled for the unexpired term in the same manner as the original appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the county compensation board shall receive no compensation, but they shall be reimbursed for their actual and necessary expenses incurred in the performance of their official duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county compensation board shall elect a chairperson and vice chairperson annually from among its membership. The county compensation board shall meet at the call of the chairperson or upon written request of a majority of its membership. The concurrence of a majority of the members of the county compensation board shall determine any matter relating to its duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors shall provide the necessary office facilities and the technical and clerical assistance requested by the county compensation board to carry out its duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The expenses of the county compensation board members, the salaries and expenses of any technical and clerical assistance, and the cost of providing any facilities shall be paid from the general fund of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A board of supervisors may dissolve a county compensation board upon a majority vote of the members of the board of supervisors. If the board of supervisors has not established or has dissolved the county compensation board, the board of supervisors shall carry out the duties as the county compensation board, including as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.907}}}{{\f5\fs18\hyphpar0\qj{. Pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.907}}}{{\f5\fs18\hyphpar0\qj{, in setting the salary of the county sheriff, the board of supervisors shall set the sheriff\u8217\'3fs salary so that it is comparable to salaries paid to professional law enforcement administrators and command officers of the state patrol, the division of criminal investigation of the department of public safety, and city police chiefs employed by cities of similar population to the population of the county.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7340A.1}}}{, }{{\f5\fs18\hyphpar0\qj{340A.4}}}{, }{{\f5\fs18\hyphpar0\qj{340A.5}}}{, }{{\f5\fs18\hyphpar0\qj{340A.7}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.905}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7904, 907}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a760}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 227, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a752, 53}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.212}}}{{\f5\fs12\hyphpar0\qj{, 331.321}}}{{\f5\fs12\hyphpar0\qj{, 331.322}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.906}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.907}}}{\*\bkmkstart stylerid1_2E9_2E11_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Compensation schedule \u8212\'3f preparation and adoption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual compensation of the auditor, treasurer, recorder, sheriff, county attorney, and supervisors shall be determined as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The county compensation board annually shall review the compensation paid to comparable officers in other counties of this state, other states, private enterprise, and the federal government. In setting the salary of the county sheriff, the county compensation board shall set the sheriff\u8217\'3fs salary so that it is comparable to salaries paid to professional law enforcement administrators and command officers of the state patrol, the division of criminal investigation of the department of public safety, and city police chiefs employed by cities of similar population to the population of the county. The county compensation board shall prepare a compensation schedule for the elected county officers for the succeeding fiscal year. The county compensation board shall provide documentation to the board of supervisors that demonstrates how the county compensation board determined the recommended compensation schedule, including by providing the applicable compensation information for comparable officers in other counties of this state, other states, private enterprise, and the federal government. A recommended compensation schedule requires a majority vote of the membership of the county compensation board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the public hearing held on the county budget as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.434}}}{{\f5\fs18\hyphpar0\qj{, the county compensation board shall submit its recommended compensation schedule for the next fiscal year to the board of supervisors for inclusion in the county budget. The board of supervisors shall review the recommended compensation schedule for the elected county officers and determine the final compensation schedule. In determining the final compensation schedule for the elected county officers, the board of supervisors may set compensation at less than the compensation provided in the current compensation schedule if the position is reduced to part-time under the recommended compensation schedule. A copy of the final compensation schedule shall be filed with the county budget at the office of the director of the department of management. The final compensation schedule takes effect on July 1 following its adoption by the board of supervisors. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcurrent compensation schedule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the compensation schedule in effect when the board of supervisors considers the recommended compensation schedule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors may adopt a decrease in compensation paid to supervisors irrespective of the county compensation board\u8217\'3fs recommended compensation schedule or other approved changes in compensation paid to other elected county officers. A decrease in compensation paid to supervisors shall be adopted by the board of supervisors no less than thirty days before the county budget is certified under }}}{{\f5\fs18\hyphpar0\qj{section 24.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The elected county officers are also entitled to receive their actual and necessary expenses incurred in performance of official duties of their respective offices. The board of supervisors may authorize the reimbursement of expenses related to an educational course, seminar, or school which is attended by a county officer after the county officer is elected, but prior to the county officer taking office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In counties having two courthouses, a principal elected county officer and the principal officer\u8217\'3fs first deputy or assistant may agree in writing to a division of their annual salaries. The division shall not allow for payment to the elected officer and the first deputy or assistant which is greater than the sum of the two salaries otherwise authorized by law. Upon certification to the board by the elected officer involved, the board shall certify to the auditor the annual salaries certified by the elected officer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1 \u8211\'3f 3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7169, 211, 213, 2536; R60, \'a7380, 381, 422, 424, 4145; C73, \'a73775, 3784, 3788, 3789, 3792, 3793, 3798; C97, \'a7297, 308, 479, 490, 495, 509; S13, \'a7297; SS15, \'a7308, 479, 490, 490-a, 495, 510-a, -c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5220, 5222, 5224, 5226, 5228, 5230;}}}{ C46, 50, 54, 58, 62, \'a7340.1, 340.3, 340.5, 340.7, 340.9, 340.11; C66, 71, 73, 75, \'a7340.1, 340.3, 340.7, 340.9; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7340.1}}}{, }{{\f5\fs18\hyphpar0\qj{340.7}}}{, }{{\f5\fs18\hyphpar0\qj{340.9}}}{, }{{\f5\fs18\hyphpar0\qj{340A.6}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.907(1 \u8211\'3f 3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7906}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7340.12}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.907(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7906}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7154, 209}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 186, \'a710100, 10201}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1095, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 227, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1074, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 35, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1184, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7126, 127}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 183, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a754}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728E.30}}}{{\f5\fs12\hyphpar0\qj{, 331.215}}}{{\f5\fs12\hyphpar0\qj{, 331.322}}}{{\f5\fs12\hyphpar0\qj{, 331.323}}}{{\f5\fs12\hyphpar0\qj{, 331.752}}}{{\f5\fs12\hyphpar0\qj{, 331.905}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.908}}}{\*\bkmkstart stylerid1_2E9_2E11_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motor vehicles required to operate on ethanol blended gasoline.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A motor vehicle purchased or used by a county to provide county services shall not operate on gasoline other than ethanol blended gasoline as defined in }{{\f5\fs18\hyphpar0\qj{section 214A.1}}}{. The motor vehicle shall also be affixed with a brightly visible sticker which notifies the traveling public that the motor vehicle is being operated on ethanol blended gasoline. However, the sticker is not required to be affixed to an unmarked vehicle used for purposes of providing law enforcement or security.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 254, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 26, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1142, \'a768}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Motor vehicle purchases, restrictions, fuel economy, see }{{\f5\fs12\hyphpar0\qj{\'a78A.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.909}}}{\*\bkmkstart stylerid1_2E9_2E11_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Multidisciplinary community services teams.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county or multicounty consortium of agencies providing health, counseling, economic assistance, education, law enforcement, or therapeutic services may establish a multidisciplinary team for the more effective planning and delivery of services to an individual or family under the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The team complies with federal regulations regarding confidentiality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The agencies comprising the team have written confidentiality standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The agencies comprising the team enter into an annual interagency agreement to comply with confidentiality standards specified in the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency initiating a multidisciplinary team obtains a signed agreement from an individual authorizing the team to share information concerning the individual or the individual\u8217\'3fs family on a confidential basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The activities of a multidisciplinary community services team shall not duplicate the activities of a multidisciplinary team for child abuse under }}}{{\f5\fs18\hyphpar0\qj{section 235A.13}}}{{\f5\fs18\hyphpar0\qj{, dependent adult abuse activities under }}}{{\f5\fs18\hyphpar0\qj{section 235B.6}}}{{\f5\fs18\hyphpar0\qj{, or child victim services provided under }}}{{\f5\fs18\hyphpar0\qj{section 915.35}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A multidisciplinary community services team shall select a chairperson and other officers as deemed necessary by the members of the team. A multidisciplinary community services team is not a governmental body as defined in }}}{{\f5\fs18\hyphpar0\qj{section 21.2}}}{{\f5\fs18\hyphpar0\qj{ and is not subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{, relating to open meetings. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{, the confidentiality of information in the possession of a multidisciplinary team which is required by law to be confidential shall be maintained except as specifically provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of a multidisciplinary community services team are expressly authorized to orally disclose personally identifying information to one another which is otherwise required by law to be confidential. Disclosure of confidential information other than oral information between team members under provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is expressly prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of a multidisciplinary community services team shall not use confidential information obtained from another team member except in the best interests of the subject of the confidential information and shall not disclose such information to another person except as otherwise authorized by law. A member of a multidisciplinary community services team who willfully uses or discloses confidential information in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a serious misdemeanor. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 903.1}}}{{\f5\fs18\hyphpar0\qj{, the penalty for a person convicted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is a fine of not more than five hundred dollars in the case of a first offense and not more than five thousand dollars in the case of each subsequent offense.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1156, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1090, \'a770, 84}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 180, \'a761}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.910}}}{\*\bkmkstart stylerid1_2E9_2E11_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interstate contracts for mental health and substance use disorder treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E9_2E11_2E11_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E11_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Purpose.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is to enable appropriate care and treatment to be provided to a person with a substance use disorder or a mental illness, across state lines from the person\u8217\'3fs state of residence, in qualified hospitals, centers, and facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E9_2E11_2E11_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E11_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdministrative services organization\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 225A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBordering state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means Illinois, Minnesota, Missouri, Nebraska, South Dakota, or Wisconsin.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReceiving agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a public or private hospital, mental health center, substance use disorder treatment and rehabilitation facility, or detoxification center, which provides substance use disorder or mental health care and treatment to a person from a state other than the state in which a hospital, center, or facility is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReceiving state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state in which a receiving agency is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSending agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a state or regional agency located in a state which sends a person to a receiving state for substance use disorder or mental health care and treatment under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSending state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state in which a sending agency is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E9_2E11_2E11_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E11_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Voluntary civil commitments.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An administrative services organization may contract with a receiving agency in a bordering state to secure substance use disorder or mental health care and treatment under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for persons who receive substance use disorder or mental health care and treatment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 125.33}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{125.91}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{229.2}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{229.22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a person who is any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serving a criminal sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On probation or parole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The subject of a presentence investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An administrative services organization may contract with a sending agency in a bordering state to provide care and treatment under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for residents of the bordering state in approved substance use disorder and mental health care and treatment hospitals, centers, and facilities in this state, except that care and treatment shall not be provided for residents of the bordering state who are involved in criminal proceedings substantially similar to the involvement described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E9_2E11_2E11_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E11_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Involuntary civil commitments.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is detained, committed, or placed on an involuntary basis under }}}{{\f5\fs18\hyphpar0\qj{section 125.75}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{125.91}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{229.6}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{229.22}}}{{\f5\fs18\hyphpar0\qj{ may be civilly committed and treated in another state pursuant to a contract under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is detained, committed, or placed on an involuntary basis under the civil commitment laws of a bordering state substantially similar to }}}{{\f5\fs18\hyphpar0\qj{section 125.75}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{125.91}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{229.6}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{229.22}}}{{\f5\fs18\hyphpar0\qj{ may be civilly committed and treated in this state pursuant to a contract under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A law enforcement officer acting under the authority of a sending state may transport a person to a receiving agency that provides substance use disorder or mental health care and treatment pursuant to a contract under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and may transport the person back to the sending state under the laws of the sending state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Court orders valid under the law of the sending state are granted recognition and reciprocity in the receiving state for a person covered by a contract under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to the extent that the court orders relate to civil commitment for substance use disorder or mental health care and treatment. Such care and treatment may include care and treatment for co-occurring substance use and mental health disorders. Such court orders are not subject to legal challenge in the courts of the receiving state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is detained, committed, or placed under the laws of a sending state and who is transferred to a receiving state under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be considered to be in the legal custody of the authority responsible for the person under the laws of the sending state with respect to the involuntary civil commitment of the person due to a mental illness or a substance use disorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While in the receiving state pursuant to a contract under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a person detained, committed, or placed under the laws of a sending state shall be subject to all laws and regulations of the receiving state, except those laws and regulations with respect to the involuntary civil commitment of the person due to a mental illness or substance use disorder. A person shall not be sent to a receiving state pursuant to a contract under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ until the receiving state has enacted a law recognizing the validity and applicability of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person receiving care and treatment pursuant to a contract under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ escapes from the receiving agency and the person at the time of the escape is subject to involuntary civil commitment under the laws of the sending state, the receiving agency shall use all reasonable means to recapture the escapee. The receiving agency shall immediately report the escape of the person to the sending agency. The receiving state has the primary responsibility for, and the authority to direct, the pursuit, retaking, and prosecution of escaped persons within its borders and is liable for the cost of such action to the extent that it would be liable for costs if its own resident escaped.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Responsibility for payment for the cost of care and treatment under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall remain with the sending agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E9_2E11_2E11_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E11_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Contract requirements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract entered into under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall, at a minimum, meet all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Describe the care and treatment to be provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish responsibility for the costs of the care and treatment, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish responsibility for the costs of transporting individuals receiving care and treatment under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Specify the duration of the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Specify the means of terminating the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identify the goals to be accomplished by the placement of a person under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E9_2E11_2E11_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E11_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Application of section.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall apply to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Detoxification services that are unrelated to substance use disorder or mental health care and treatment regardless of whether the care and treatment are provided on a voluntary or involuntary basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Substance use disorder and mental health care and treatment contracts that include emergency care and treatment provided to a resident of this state in a bordering state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 16, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a7103}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1071, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1131, \'a775}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71106}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7121 \u8211\'3f 123, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7124E.2}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph a effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsection 2, paragraph d effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 3, paragraphs a and c effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, NEW paragraph a and former paragraphs a \u8211\'3f c redesignated as b \u8211\'3f d}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, former paragraph d stricken}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraphs a and c amended}\par}}