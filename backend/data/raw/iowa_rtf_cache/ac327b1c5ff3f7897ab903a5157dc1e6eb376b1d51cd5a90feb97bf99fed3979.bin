\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.101}}}{\*\bkmkstart stylerid1_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAmendment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a revision or repeal of an existing ordinance or code of ordinances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuditor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the county auditor or a deputy auditor or employee designated by the county auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the board of supervisors of a county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBook\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecord\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fregister\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ include any mode of permanent recording including but not limited to, card files, microfilm or microfiche, electronic records and the like.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCharter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a formal document establishing the functions, powers, organization, structure, privileges, rights, and duties of county government not inconsistent with state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClerk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the clerk of the district court or the clerk\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a body of eligible electors authorized to study, review, analyze, and recommend an alternative form of county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty attorney\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the county attorney or a deputy county attorney or assistant county attorney designated by the county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMeasure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an ordinance, amendment, resolution, or motion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOrdinance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a county law of a general and permanent nature.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecorded vote\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a record, roll call vote.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecorder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the county recorder or a deputy recorder or employee designated by the county recorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResolution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmotion\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a statement of policy or an order for action to be taken.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSheriff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the county sheriff or a deputy sheriff designated by the sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState law\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the Constitution of the State of Iowa and state statutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSupervisor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a member of the board of supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTreasurer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the county treasurer or a deputy treasurer or employee designated by the county treasurer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7343.13}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.101}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7100}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1233, \'a723}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7137.104}}}{{\f5\fs12\hyphpar0\qj{, 228.1}}}{{\f5\fs12\hyphpar0\qj{, 422D.1}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.102 through 331.189}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.190}}}{\*\bkmkstart stylerid1_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County of residence }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ dispute resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty of residence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the county in this state in which, at the time a person applies for or receives services, the person is living and has established an ongoing presence with the declared, good faith intention of living for a permanent or indefinite period of time. The county of residence of a homeless person is the county in which the homeless person usually sleeps. A person maintains residency in the county or state in which the person last resided during the time period that the person is present in a different county or state receiving services in a hospital, a correctional facility, a halfway house for community-based corrections or substance use disorder treatment, a nursing facility, an intermediate care facility for persons with an intellectual disability, a residential care facility, or for the purpose of attending a college or university.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The dispute resolution process in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall apply to county of residence disputes. The dispute resolution process shall not be applicable to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disputes involving persons committed to a state facility pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 812}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disputes involving Iowa }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of criminal procedure 2.22(8)(b)}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, commitment for evaluation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disputes involving }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/12.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{chapter 12 of Iowa court rules}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, rules for involuntary hospitalization of mentally ill persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a county objects to a billing for services or a residency determination and asserts that either the person has residency in a different county or the person is not a resident of this state, the person\u8217\'3fs county of residence shall be determined as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. If the county asserts that the person has residency in a different county in this state, the county shall notify that county in writing within one hundred twenty calendar days of receiving the billing for services or of the county of residence determination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county that receives the notification under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall respond in writing to the county that provided the notification within forty-five calendar days of receiving the notification. If the parties cannot agree as to the person\u8217\'3fs county of residence within ninety calendar days of the date of notification, on motion of either of the parties, the matter shall be referred to the administrative hearings division of the department of inspections, appeals, and licensing for a contested case proceeding under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, before an administrative law judge assigned in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 10A.801}}}{{\f5\fs18\hyphpar0\qj{, to determine the person\u8217\'3fs county of residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 17A.15}}}{{\f5\fs18\hyphpar0\qj{, the administrative law judge\u8217\'3fs determination of a person\u8217\'3fs county of residence shall be considered final agency action. Judicial review of the determination may be sought in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 17A.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If following the determination of a person\u8217\'3fs county of residence under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ additional evidence becomes available that merits a change in the determination of the person\u8217\'3fs county of residence, the affected parties may change the determination of county of residence by mutual agreement. Otherwise, a party may move that the matter be reconsidered by the county, or by an administrative law judge assigned in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 10A.801}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless a petition is filed for judicial review, the administrative law judge\u8217\'3fs determination of the person\u8217\'3fs county of residence shall result in one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a county is determined to be the person\u8217\'3fs county of residence, that county shall pay any amounts due and shall reimburse the other county for any amounts paid for services provided to the person by the other county prior to the county of residence determination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it is determined that the person is not a resident of this state, neither the state nor either county shall be liable for payment of amounts due for services provided to the person prior to the determination of the person\u8217\'3fs county of residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The party that does not prevail in a contested case proceeding or a subsequent judicial review pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be liable for costs associated with the proceeding or judicial review, including reimbursement of the administrative hearings division of the department of inspections, appeals, and licensing\u8217\'3fs actual costs associated with the administrative proceeding, court costs, and reasonable attorney fees.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A payment or reimbursement pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be remitted within forty-five calendar days of the date the county of residence determination is issued by the administrative law judge or the date the court files an order determining the person\u8217\'3fs county of residence, whichever is later. After forty-five calendar days, the prevailing party may add a penalty of up to one percent per month to any amounts due.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7181, 184}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a735D.9}}}{{\f5\fs12\hyphpar0\qj{, 232.141}}}{{\f5\fs12\hyphpar0\qj{, 252.24}}}{{\f5\fs12\hyphpar0\qj{, 347.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7184}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.191 through 331.200}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E2_2E2}{ALTERNATIVE FORMS OF COUNTY GOVERNMENT}{\*\bkmkend stylerid1_2E6_2E2_2E2}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 1}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E3_2E1_2E2}{BOARD OF SUPERVISORS}{\*\bkmkend stylerid1_2E6_2E3_2E1_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7331.231}}}{{\f5\fs12\qc{, 331.233}}}{{\f5\fs12\qc{, 331.238}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.201}}}{\*\bkmkstart stylerid1_2E6_2E3_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Board membership \u8212\'3f qualifications \u8212\'3f term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall consist of three members unless the membership is increased to five as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.203}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A supervisor must be a registered voter of the county or supervisor district of the county which the supervisor represents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The office of supervisor is an elective office except that if a vacancy occurs on the board, a successor may be appointed to the unexpired term as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.14A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if the population of the county is less than one hundred twenty-five thousand based on the most recent federal decennial census and if the county does not include the main campus of an institution of higher learning governed by the state board of regents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term of office of a supervisor is four years unless a change in the supervisor district representation plan or in the number of supervisors on the board requires the election of one or two supervisors for an initial term of two years.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7303; C73, \'a7294, 299; C97, \'a7410; SS15, \'a7410; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5106;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.1}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.201}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7200}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1169, \'a764}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 57, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 15, \'a77, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.202}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.203}}}{\*\bkmkstart stylerid1_2E6_2E3_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Membership increased \u8212\'3f vote.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may by resolution, or shall upon petition of the number of eligible electors of the county as specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{, submit to the registered voters of the county at a general election a proposition to increase the number of supervisors to five.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a majority of the votes cast on the proposition is in favor of the increase to five members, the board shall be increased to five members effective on the first day in January which is not a Sunday or holiday following the next general election. The five-member board shall be elected according to the supervisor representation plan in effect in the county.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If plan \u8220\'3fone\u8221\'3f as defined in }}}{{\f5\fs18\hyphpar0\qj{section 331.206}}}{{\f5\fs18\hyphpar0\qj{ is in effect, two additional supervisors shall be elected at the next general election, one for a two-year term and one for a four-year term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If plan \u8220\'3ftwo\u8221\'3f or plan \u8220\'3fthree\u8221\'3f as defined in }}}{{\f5\fs18\hyphpar0\qj{section 331.206}}}{{\f5\fs18\hyphpar0\qj{ is in effect, the temporary county redistricting commission shall divide the county into five equal-population districts by December 15 of the year preceding the year of the next general election and at that general election, five board members shall be elected, two for initial terms of two years and three for four-year terms. The districts shall be drawn in the manner provided under }}}{{\f5\fs18\hyphpar0\qj{sections 331.209}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{331.210}}}{{\f5\fs18\hyphpar0\qj{. The terms of the three incumbent supervisors shall expire on the date that the five-member board becomes effective.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The length of term for which a person is a candidate and the date when the term begins shall be indicated on the ballot.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7303; C73, \'a7294, 299; C97, \'a7410; SS15, \'a7410; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5107;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.2}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.203}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7202}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1091, \'a72}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1104, \'a729}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1119, \'a735}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1179, \'a719}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 67, \'a753}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.201}}}{{\f5\fs12\hyphpar0\qj{, 331.209}}}{{\f5\fs12\hyphpar0\qj{, 331.210A}}}{{\f5\fs12\hyphpar0\qj{, 331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.204}}}{\*\bkmkstart stylerid1_2E6_2E3_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Membership reduced \u8212\'3f vote \u8212\'3f new members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a county having a five-member board, the board may by resolution, or shall upon petition of the number of eligible electors of the county as specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{, submit to the registered voters of the county at a general election a proposition to reduce the number of supervisors to three.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a majority of the votes cast on the proposition is in favor of the reduction to three members, the membership of the board shall remain at five until the first day in January which is not a Sunday or holiday following the next general election, at which time the terms of the five members shall expire.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the next general election following the one at which the proposition to reduce the membership of the board to three is approved, the membership of the board shall be elected according to the supervisor representation plan in effect in the county. If the supervisor representation plan includes equal-population districts, the districts shall be designated by December 15 of the year preceding the year of the next general election by the temporary county redistricting commission. The districts shall be drawn in the manner provided under }}}{{\f5\fs18\hyphpar0\qj{sections 331.209}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{331.210}}}{{\f5\fs18\hyphpar0\qj{. One member of the board shall be elected to a two-year term and the remaining two members shall be elected to four-year terms. The length of the term for which a person is a candidate and the date when the term begins shall be indicated on the ballot.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7299; C97, \'a7410; SS15, \'a7410; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5108 \u8211\'3f 5110;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.3}}}{, }{{\f5\fs18\hyphpar0\qj{331.6}}}{, }{{\f5\fs18\hyphpar0\qj{331.7}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.204}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7203}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1091, \'a73}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1104, \'a730}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1119, \'a736}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1179, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 67, \'a753}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.209}}}{{\f5\fs12\hyphpar0\qj{, 331.210A}}}{{\f5\fs12\hyphpar0\qj{, 331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.205}}}{\*\bkmkstart stylerid1_2E6_2E3_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petition and vote in certain counties \u8212\'3f exception.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2005/CH0125.pdf" }{\fldrslt \cf5 \f5 \fs18{{2005 Acts, ch 125, \'a71}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.206}}}{\*\bkmkstart stylerid1_2E6_2E3_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supervisor districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One of the following supervisor district representation plans shall be used for the election of supervisors:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plan \u8220\'3fone\u8221\'3f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Election at large without district residence requirements for the members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plan \u8220\'3ftwo\u8221\'3f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Election at large but with equal-population district residence requirements for the members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plan \u8220\'3fthree\u8221\'3f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Election from single-member equal-population districts, in which the electors of each district shall elect one member who must reside in that district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The plan used under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be selected by the board or by a special election as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.207}}}{{\f5\fs18\hyphpar0\qj{. A plan selected by the board shall remain in effect for at least six years and shall only be changed by a special election as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.207}}}{{\f5\fs18\hyphpar0\qj{. However, a county with the main campus of an institution of higher learning governed by the state board of regents shall use plan \u8220\'3fthree\u8221\'3f for the election of supervisors.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A plan selected by the board shall become effective on the first day in January which is not a Sunday or holiday following the next general election, at which time the terms of the members expire and the terms of the members elected under the requirements of the new supervisor representation plan at the general election as specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.208}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{331.209}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{331.210}}}{{\f5\fs18\hyphpar0\qj{ shall commence.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7416; S13, \'a7416; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5111;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.8}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.206}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7205}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 143, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7125}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1151, \'a71, 6}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 15, \'a71, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a749.4}}}{{\f5\fs12\hyphpar0\qj{, 331.203}}}{{\f5\fs12\hyphpar0\qj{, 331.207}}}{{\f5\fs12\hyphpar0\qj{, 331.208}}}{{\f5\fs12\hyphpar0\qj{, 331.209}}}{{\f5\fs12\hyphpar0\qj{, 331.210}}}{{\f5\fs12\hyphpar0\qj{, 331.210A}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For transition for 2026 general election for counties with the main campus of an institution of higher learning governed by the state board of regents, see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2025/CH15.pdf" }{\fldrslt \cf5 \f5 \fs12{{2025 Acts, ch 15, \'a73}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph a amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.207}}}{\*\bkmkstart stylerid1_2E6_2E3_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special election \u8212\'3f supervisor districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, upon petition of the number of eligible electors of the county as specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{, shall call a special election to be held for the purpose of selecting one of the supervisor representation plans specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.206}}}{{\f5\fs18\hyphpar0\qj{ under which the board of supervisors shall be elected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition shall be filed with the county commissioner by June 1 of an odd-numbered year, subject to }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{. The special election shall be held on the first Tuesday after the first Monday in November of the odd-numbered year. Notice of the special election shall be published once each week for three successive weeks in an official newspaper of the county, shall state the representation plans to be submitted to the electors, and shall state the date of the special election. The last in the series of publications shall occur not less than four nor more than twenty days before the election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The supervisor representation plans submitted at the special election shall be stated in substantially the following manner:}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{The individual members of the board of supervisors in }{{\f5\fs18\hyphpar0\qj{........................}}}{ county, Iowa, shall be elected:}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{Plan \u8220\'3fone\u8221\'3f. At large and without district residence requirements for the members.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{Plan \u8220\'3ftwo\u8221\'3f. At large but with equal-population district residence requirements for the members.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Plan \u8220\'3fthree\u8221\'3f. From single-member equal-population districts in which the electors of each district shall elect one member who must reside in that district.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the plan adopted by a plurality of the ballots cast in the special election is not the supervisor representation plan currently in effect in the county, the terms of the county supervisors serving at the time of the special election shall continue until the first day in January which is not a Sunday or holiday following the next general election, at which time the terms of the members shall expire and the terms of the members elected under the requirements of the new supervisor representation plan at the general election as specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.208}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{331.209}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{331.210}}}{{\f5\fs18\hyphpar0\qj{ shall commence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the plan adopted by a plurality of the ballots cast in the special election represents a change from plan \u8220\'3fone\u8221\'3f to plan \u8220\'3ftwo\u8221\'3f or \u8220\'3fthree\u8221\'3f, or from plan \u8220\'3ftwo\u8221\'3f to plan \u8220\'3fthree\u8221\'3f, as each plan is defined in }}}{{\f5\fs18\hyphpar0\qj{section 331.206}}}{{\f5\fs18\hyphpar0\qj{, the temporary county redistricting commission shall divide the county into districts as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 331.209}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{331.210}}}{{\f5\fs18\hyphpar0\qj{. The plan shall be completed not later than December 31 following the special election and shall be submitted to the state commissioner of elections. The plan shall become effective the following January 1.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, a county with a population of sixty thousand or more based on the most recent federal decennial census that elects supervisors under plan \u8220\'3fthree\u8221\'3f shall not change from plan \u8220\'3fthree\u8221\'3f to plan \u8220\'3fone\u8221\'3f or plan \u8220\'3ftwo\u8221\'3f pursuant to a special election under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless a plan \u8220\'3fone\u8221\'3f or plan \u8220\'3ftwo\u8221\'3f representation plan is adopted by a two-thirds vote of the ballots cast in the special election. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a county with the main campus of an institution of higher learning governed by the state board of regents required to use plan \u8220\'3fthree\u8221\'3f under }}}{{\f5\fs18\hyphpar0\qj{section 331.206, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A supervisor representation plan adopted at a special election shall remain in effect for at least six years.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7417; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5112;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.207}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7206}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a731}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1119, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1134, \'a793, 94, 115}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1033, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1151, \'a72, 6}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 15, \'a72, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.206}}}{{\f5\fs12\hyphpar0\qj{, 331.208}}}{{\f5\fs12\hyphpar0\qj{, 331.209}}}{{\f5\fs12\hyphpar0\qj{, 331.210}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 2, 5, and 6 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.208}}}{\*\bkmkstart stylerid1_2E6_2E3_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Plan \u8220\'3fone\u8221\'3f terms of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If plan \u8220\'3fone\u8221\'3f is selected pursuant to }{{\f5\fs18\hyphpar0\qj{section 331.206}}}{ or }{{\f5\fs18\hyphpar0\qj{331.207}}}{, the board shall be elected as provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the primary and general elections, the number of supervisors, or candidates for the offices, which constitutes the board in the county, shall be elected by the registered voters of the county at large without district residence requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In counties with three county supervisors, one person shall be elected as a member of the board for an initial term of two years and two persons shall be elected as members of the board for four years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In counties with five supervisors, two persons shall be elected as members of the board for initial terms of two years and three persons shall be elected as members of the board for four years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The determination as to whether a term of office shall be for two or four years shall be decided by lot before the primary election, and the results of the determination indicated on the ballot in the primary and general elections.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.25}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.208}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7207}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 67, \'a753}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a739.18}}}{{\f5\fs12\hyphpar0\qj{, 331.206}}}{{\f5\fs12\hyphpar0\qj{, 331.207}}}{{\f5\fs12\hyphpar0\qj{, 331.209}}}{{\f5\fs12\hyphpar0\qj{, 331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.209}}}{\*\bkmkstart stylerid1_2E6_2E3_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Plan \u8220\'3ftwo\u8221\'3f terms of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If plan \u8220\'3ftwo\u8221\'3f is selected pursuant to }{{\f5\fs18\hyphpar0\qj{section 331.206}}}{ or }{{\f5\fs18\hyphpar0\qj{331.207}}}{, the board shall be elected as provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than ninety days after the redistricting of congressional and legislative districts becomes law, or October 15 of the year immediately following each year in which the federal decennial census is taken, whichever is later, the temporary county redistricting commission shall divide the county into a number of supervisor districts corresponding to the number of supervisors in the county. However, if the plan is selected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.207}}}{{\f5\fs18\hyphpar0\qj{, the temporary county redistricting commission shall divide the county before February 15 of the election year. The supervisor districts shall be drawn, to the extent applicable, in compliance with the redistricting standards provided for senatorial and representative districts in }}}{{\f5\fs18\hyphpar0\qj{section 42.4}}}{{\f5\fs18\hyphpar0\qj{, and if a supervisor redistricting plan is challenged in court, the requirement of justifying any variance in excess of one percent contained in }}}{{\f5\fs18\hyphpar0\qj{section 42.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies to the board. If the temporary county redistricting commission adopts a supervisor redistricting plan with a variance in excess of one percent, the board shall publish the justification for the variance in one or more official newspapers as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 349}}}{{\f5\fs18\hyphpar0\qj{ within ten days after the action is taken. If more than one incumbent supervisor resides in the same supervisor district after the districts have been redrawn following the federal decennial census, the terms of office of those supervisors shall expire on the first day of January that is not a Sunday or a holiday following the next general election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each supervisor must reside in a separate supervisor district but shall be elected by the electors of the county at large. Election ballots shall be prepared to specify the district which each candidate seeks to represent and each elector may cast a vote for one candidate from each district for which a supervisor is to be chosen in the general election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the primary and general elections the number of supervisors, or candidates for the offices, which constitute the board in the county shall be elected as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Terms of supervisors shall be the same as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.208}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each temporary county redistricting commission shall notify the state commissioner of elections when the boundaries of supervisor districts are changed, shall provide a map delineating the new boundary lines, and shall certify to the state commissioner of elections the populations of the new supervisor districts as determined under the latest federal decennial census. Upon failure of a temporary county redistricting commission to make the required changes by the dates specified by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 331.203}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{331.204}}}{{\f5\fs18\hyphpar0\qj{ as determined by the state commissioner of elections, the state commissioner of elections shall make or cause to be made the necessary changes as soon as possible, and shall assess to the county the expenses incurred in so doing. Except for a representation plan drawn pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.210A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the state commissioner of elections may request the services of personnel and materials available to the legislative services agency to assist the state commissioner in making required changes in supervisor district boundaries which become the state commissioner\u8217\'3fs responsibility.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.26}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.209}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7208}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1091, \'a74, 5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 190, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1179, \'a721, 22}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 35, \'a744, 49}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1151, \'a74, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a739.18}}}{{\f5\fs12\hyphpar0\qj{, 49.3}}}{{\f5\fs12\hyphpar0\qj{, 49.7}}}{{\f5\fs12\hyphpar0\qj{, 49.8}}}{{\f5\fs12\hyphpar0\qj{, 331.203}}}{{\f5\fs12\hyphpar0\qj{, 331.204}}}{{\f5\fs12\hyphpar0\qj{, 331.206}}}{{\f5\fs12\hyphpar0\qj{, 331.207}}}{{\f5\fs12\hyphpar0\qj{, 331.210}}}{{\f5\fs12\hyphpar0\qj{, 331.210A}}}{{\f5\fs12\hyphpar0\qj{, 331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.210}}}{\*\bkmkstart stylerid1_2E6_2E3_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Plan \u8220\'3fthree\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If plan \u8220\'3fthree\u8221\'3f is selected pursuant to }{{\f5\fs18\hyphpar0\qj{section 331.206}}}{ or }{{\f5\fs18\hyphpar0\qj{331.207}}}{, the supervisor districts shall be drawn and supervisors shall be elected as provided in }{{\f5\fs18\hyphpar0\qj{section 331.209}}}{, except the boundaries of supervisor districts shall follow voting precinct lines and each member of the board and each candidate for the office shall be elected or nominated at the primary and general elections by only the electors of the district which that candidate seeks to represent.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.27}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.210}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7209}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.203}}}{{\f5\fs12\hyphpar0\qj{, 331.204}}}{{\f5\fs12\hyphpar0\qj{, 331.206}}}{{\f5\fs12\hyphpar0\qj{, 331.207}}}{{\f5\fs12\hyphpar0\qj{, 331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.210A}}}{\*\bkmkstart stylerid1_2E6_2E3_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Temporary county redistricting commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E6_2E3_2E13_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E13_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Appointment of members.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than May 15 of each year ending in one, a temporary county redistricting commission shall be established as provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for counties which have either plan \u8220\'3ftwo\u8221\'3f or plan \u8220\'3fthree\u8221\'3f supervisor representation plans. If a county has either plan \u8220\'3ftwo\u8221\'3f or plan \u8220\'3fthree\u8221\'3f supervisor representation plans and the number of members of the board is increased or decreased under }}}{{\f5\fs18\hyphpar0\qj{section 331.203}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{331.204}}}{{\f5\fs18\hyphpar0\qj{, the temporary county redistricting commission shall be established by May 15 of the year preceding the year of the next general election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall determine the size of the membership of the temporary county redistricting commission which may be three, five, or seven in number. The minimum number of members constituting a majority of the membership shall be appointed by the majority party members of the board. The remaining number of members of the temporary county redistricting commission shall be appointed by the minority party members of the board. If the members of the board are all members of one political party or if the minority members of the board are not all members of only one political party, the minority representation of the temporary county redistricting commission shall be appointed by the chair of the county central committee for the party, other than the party of the majority members of the board, which received the most votes in that county cast for its candidate for president of the United States or for governor at the last preceding general election, as the case may be. If that party\u8217\'3fs county central committee has no chair, the appointments shall be made by the chair of that party\u8217\'3fs state central committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the county board of supervisors may be appointed as a member of the temporary county redistricting commission. No person shall be appointed to the temporary county redistricting commission who is not an eligible elector of the county at the time of appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy on the temporary county redistricting commission shall be filled by the initial selecting authority within fifteen days after the vacancy occurs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the temporary county redistricting commission shall receive a per diem as specified by the board, travel expenses at the rate provided by }}}{{\f5\fs18\hyphpar0\qj{section 70A.9}}}{{\f5\fs18\hyphpar0\qj{, and reimbursement for other necessary expenses incurred in performing their duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each of the appointing authorities shall certify to the county commissioner of elections the authority\u8217\'3fs appointment of a person to serve on the temporary county redistricting commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E6_2E3_2E13_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E13_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Adoption of plans.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The temporary county redistricting commission, upon appointment, shall acquire official census population data from the latest federal decennial census including the corresponding census maps and shall use that information in drawing and adopting the county\u8217\'3fs supervisor districting plan. The commission shall draw the plan, to the extent applicable, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 42.4}}}{{\f5\fs18\hyphpar0\qj{. If the county has a plan \u8220\'3fthree\u8221\'3f supervisor representation plan, the temporary county redistricting commission shall also draw and adopt the county\u8217\'3fs corresponding precinct plan in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 49.3}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{49.4}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{49.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the temporary county redistricting commission has finished its preliminary proposed county supervisor districting plan and corresponding precinct plan, if applicable, the commission shall at the earliest feasible time make available to the public all of the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Copies of the legal description of the plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maps illustrating the plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A summary of the standards prescribed by law for development of the plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement of the population of each district included in the plan, and the relative deviation of each district population from the ideal district population.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement of the population of each precinct, if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the completion of the county\u8217\'3fs preliminary proposed plans, the temporary county redistricting commission shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As expeditiously as possible, schedule and conduct at least one public hearing on the proposed plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allow members of the public to present alternative plans at the public hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following the hearings, promptly prepare and make available to the public a report summarizing information and testimony received by the temporary county redistricting commission in the course of the hearings. The report shall include any comments and conclusions which its members deem appropriate regarding the information and testimony received at the hearings, or otherwise presented to the temporary county redistricting commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the requirements of paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ have been met, the temporary county redistricting commission shall adopt a supervisor district plan and corresponding precinct plan, if applicable, and shall submit the plan to the board of supervisors for their approval. Prior to adoption of a plan by the commission, any member of the temporary county redistricting commission may submit precinct or district plans to the commission for a vote, either independently or as an amendment to a plan presented by other members of the commission.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors shall review the plan submitted by the temporary county redistricting commission and shall approve or reject the plan. If the plan is rejected, the board shall give written reasons for the rejection of the plan and shall direct the commission to prepare a second plan. The board of supervisors may amend the second plan submitted for approval by the commission. Any amendment must be accompanied by a written statement declaring that the amendment is necessary to bring the submitted plan closer in conformity to the standards in }}}{{\f5\fs18\hyphpar0\qj{section 42.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The plan approved by the board of supervisors shall be submitted to the state commissioner of elections for approval. If the state commissioner or the Iowa ethics and campaign disclosure board finds that the plan does not meet the standards of }}}{{\f5\fs18\hyphpar0\qj{section 42.4}}}{{\f5\fs18\hyphpar0\qj{, the state commissioner shall reject the plan, and the board of supervisors shall direct the commission to prepare and adopt an acceptable plan.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of determining whether the standards of }}}{{\f5\fs18\hyphpar0\qj{section 42.4}}}{{\f5\fs18\hyphpar0\qj{ have been met, an eligible elector may file a complaint with the state commissioner of elections within fourteen days after a plan is approved by the board of supervisors of the county in which the eligible elector resides, on a form prescribed by the commissioner, alleging that the plan was drawn for improper political reasons as described in }}}{{\f5\fs18\hyphpar0\qj{section 42.4, subsection 5}}}{{\f5\fs18\hyphpar0\qj{. If a complaint is filed with the state commissioner of elections, the state commissioner shall forward the complaint to the Iowa ethics and campaign disclosure board established in }}}{{\f5\fs18\hyphpar0\qj{section 68B.32}}}{{\f5\fs18\hyphpar0\qj{ for resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after the initial proposed supervisor district plan or precinct plan has been submitted to the state commissioner for approval, it is necessary for the temporary county redistricting commission to make subsequent attempts at adopting an acceptable plan, the subsequent plans do not require public hearings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualifying county\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a county that elects supervisors under plan \u8220\'3fthree\u8221\'3f as defined in }}}{{\f5\fs18\hyphpar0\qj{section 331.206}}}{{\f5\fs18\hyphpar0\qj{, or a county with a population of one hundred eighty thousand or more that has adopted a charter for a city-county consolidated form of government or a community commonwealth form of government and which charter provides for representation by districts. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, for a qualifying county, the legislative services agency, and not the temporary county redistricting commission, shall draw a representation plan as provided by paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county subject to the requirements of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall notify the state commissioner of elections that a representation plan to be drawn pursuant to this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is required and shall submit to the state commissioner of elections the precinct plan to be used to draw the representation plan. Upon notification and submission of a precinct plan, the state commissioner of elections shall review and approve the precinct plan to be used. Following approval of the precinct plan to be used, the state commissioner of elections shall notify the legislative council which shall direct the legislative services agency to prepare a representation plan for the county.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The plan drawn by the legislative services agency shall be based upon the precinct plan adopted and approved for use by the county and shall be drawn in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 42.4}}}{{\f5\fs18\hyphpar0\qj{, to the extent applicable. After the legislative services agency has drawn the plan, the legislative services agency shall at the earliest feasible time make available to the public all of the information required to be made public by paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legislative services agency shall submit the plan to the governing body, and the governing body shall comply with the duties required by paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to the extent applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the requirements of paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ have been met, the governing body shall review the plan submitted by the legislative services agency and shall approve or reject the plan. If the plan is rejected, the governing body shall give written reasons for the rejection and shall direct the legislative services agency to prepare a second plan, as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The second plan may be amended by the governing body in accordance with the provisions of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. After receiving the second plan, the governing body shall approve either the first plan or the second plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body, after approving a plan, shall comply with the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E6_2E3_2E13_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E13_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Open meetings and public records.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Chapters 21}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{22}}}{{\f5\fs18\hyphpar0\qj{ shall apply to the temporary county redistricting commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E6_2E3_2E13_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E13_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Termination.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The terms of the members of the temporary county redistricting commission shall expire twenty days following the date the county\u8217\'3fs supervisor district plan and corresponding precinct plan, if applicable, are approved or imposed by the state commissioner of elections under }}}{{\f5\fs18\hyphpar0\qj{sections 49.7}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{331.209}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1179, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a71, 31}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1115, \'a7107}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1151, \'a75, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a749.8}}}{{\f5\fs12\hyphpar0\qj{, 68B.32A}}}{{\f5\fs12\hyphpar0\qj{, 331.209}}}{{\f5\fs12\hyphpar0\qj{, 331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.211}}}{\*\bkmkstart stylerid1_2E6_2E3_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Organization of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, at its first meeting in each year, shall choose one of its members as chairperson who shall preside at all of its meetings during the year. The board may also select a vice chairperson who shall serve during the absence of the chairperson.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The auditor shall serve as clerk to the board unless the board, with the consent of the auditor, appoints a permanent clerk. In the absence of the auditor, the auditor\u8217\'3fs designee as clerk, or the permanent clerk, the board may appoint a temporary clerk. The permanent or temporary clerk appointed by the board shall provide the auditor with all information necessary for the auditor to carry out the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 331.504}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7308, 312(1); C73, \'a7300, 303(1); C97, \'a7415, 422; SS15, \'a7422; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5116, 5130;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.13}}}{, }{{\f5\fs18\hyphpar0\qj{332.3(1)}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.211}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7210}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1004, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7244}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72777}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.212}}}{\*\bkmkstart stylerid1_2E6_2E3_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Quorum \u8212\'3f majority vote required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A majority of the members of the board constitutes a quorum to transact the official business of the county. If the board is equally divided on a question when less than the full membership is present, the question shall be continued until all of the members of the board are present.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following actions of the board require the affirmative vote of a majority of its membership:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Levying of a tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Entering into a contract for the erection of a public building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Making a settlement with a county officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Buying or selling real estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designating a new site for a county building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Changing the boundaries of a township.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appropriating money to aid in the construction of a highway or a bridge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appointing or removing an officer from office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Setting the compensation schedule of elected county officers, if the board has not established or has dissolved a county compensation board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.905}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Dissolving a county compensation board.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7308, 313; C73, \'a7297, 305; C97, \'a7413, 440; C24, 27, \'a75117, 5121; C31, 35, \'a75903-c10, 5117, 5121; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5903.10, 5117, 5121;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7330.12}}}{, }{{\f5\fs18\hyphpar0\qj{331.14}}}{, }{{\f5\fs18\hyphpar0\qj{331.18}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.212}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7211}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1094, \'a749}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.261}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.213}}}{\*\bkmkstart stylerid1_2E6_2E3_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Meetings of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall hold its first meeting of each year on the first day in January which is not a Saturday, Sunday or holiday and shall hold all subsequent meetings of the year as scheduled by the board. All meetings of the board shall be scheduled and conducted in compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a quorum of the board fails to appear at a meeting, the clerk shall adjourn the meeting from day to day until a quorum is present.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7307, 309; C73, \'a7296, 301; C97, \'a7412, 420; S13, \'a7412; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5118 \u8211\'3f 5120;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.15}}}{ \u8211\'3f 331.17; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.213}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7212}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a732}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.248}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.214}}}{\*\bkmkstart stylerid1_2E6_2E3_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vacancy of supervisor\u8217\'3fs office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The circumstances which constitute a vacancy in office under }}}{{\f5\fs18\hyphpar0\qj{section 69.2}}}{{\f5\fs18\hyphpar0\qj{ shall be treated as a resignation of the office. At its next meeting after the sixty-day absence, the board, by resolution adopted and included in its minutes, shall declare the absent supervisor\u8217\'3fs seat vacant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the physical or mental status of a supervisor is in question, the board shall decide whether a vacancy exists. The board shall comply with the notice and hearing requirements of }}}{{\f5\fs18\hyphpar0\qj{section 69.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{. After a hearing, the board, by resolution adopted and included in its minutes, may declare the supervisor\u8217\'3fs seat vacant if the board determines either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the supervisor is physically or mentally incapable of performing the duties of office and there is reasonable cause to believe that the supervisor will not be able to perform the duties of office for the remainder of the supervisor\u8217\'3fs term. To make this determination, the board shall appoint a physician and the family of the supervisor shall appoint a physician to examine the supervisor. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffamily\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the parent, spouse, or child of the supervisor. If the family does not appoint a physician, the board shall appoint two physicians to examine the supervisor. The board shall receive the report of the physicians as evidence at the hearing. The board may only declare the supervisor\u8217\'3fs seat vacant if both physicians concur that the supervisor is physically or mentally incapable of performing the duties of office and there is reasonable cause to believe that the supervisor will not be able to perform the duties of office for the remainder of the supervisor\u8217\'3fs term. However, if the physicians concur that the supervisor is mentally incapable of performing the duties of office, the board shall not declare the supervisor\u8217\'3fs seat vacant for one year from the date of the hearing if the supervisor is receiving treatment for the mental incapacity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the supervisor refuses or is unavailable for the examination required in subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A supervisor whose seat is declared vacant under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may appeal the board\u8217\'3fs decision to the district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board declares a vacancy under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and the remaining balance of the supervisor\u8217\'3fs unexpired term is two and one-half years or more, a special election shall be held to fill the office as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.14A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if the population of the county is one hundred twenty-five thousand or more based on the most recent federal decennial census or the county includes the main campus of an institution of higher learning governed by the state board of regents. However, if the population of the county is less than one hundred twenty-five thousand based on the most recent federal decennial census and if the county does not include the main campus of an institution of higher learning governed by the state board of regents, an appointment shall be made to fill the office as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.14A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7298; C97, \'a7414; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5115;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.12}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.214}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7213}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1065, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 15, \'a78, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a769.14A}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph c amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.215}}}{\*\bkmkstart stylerid1_2E6_2E3_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Compensation and expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The supervisors shall receive an annual salary or per diem compensation as determined under }}}{{\f5\fs18\hyphpar0\qj{section 331.907}}}{{\f5\fs18\hyphpar0\qj{. The annual salary or per diem shall be full payment for all services rendered to the county except for reimbursement for mileage and other expenses authorized in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A supervisor is entitled to reimbursement for mileage expenses incurred while engaged in the performance of official duties at the rate specified in }}}{{\f5\fs18\hyphpar0\qj{section 70A.9}}}{{\f5\fs18\hyphpar0\qj{. The total mileage expense for all supervisors in a county shall not exceed the product of the rate of mileage specified in }}}{{\f5\fs18\hyphpar0\qj{section 70A.9}}}{{\f5\fs18\hyphpar0\qj{ multiplied by the total number of supervisors in the county times ten thousand. The board may also authorize reimbursement for mileage and other actual expenses incurred by its members when attending an educational course, seminar, or school which is related to the performance of their official duties.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7317; C73, \'a73791; C97, \'a7469; S13, \'a7469; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5125, 5127, 5260;}}}{ C46, 50, 54, 58, 62, 66, \'a7331.22, 331.24, 343.12; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.22}}}{, }{{\f5\fs18\hyphpar0\qj{343.12}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.215}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7214, 216}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.238}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}{{\f5\fs12\hyphpar0\qj{, 331.324}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.216}}}{\*\bkmkstart stylerid1_2E6_2E3_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Membership on appointive boards, committees, and commissions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless otherwise provided by state statute, a supervisor may serve as a member of any appointive board, commission, or committee of this state, a political subdivision of this state, or a nonprofit corporation or agency receiving county funds.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7331.28}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.216}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7215}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.261}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.217 through 331.230}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 2}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E4_2E1_2E2}{ALTERNATIVE FORMS}{\*\bkmkend stylerid1_2E6_2E4_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.231}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alternative forms of county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The alternative forms of county government are as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Board of supervisor form as provided in }}}{{\f5\fs18\hyphpar0\qj{subchapter II, part 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Board-elected executive form as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.239}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Board-manager form as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.241}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Charter government form as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.246}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{City-county consolidated form as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 331.247 through 331.252}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Multicounty consolidated form as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 331.253 through 331.257}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Community commonwealth form as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 331.260 through 331.263}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a72, 31}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.232}}}{\*\bkmkstart stylerid1_2E6_2E4_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Plan for an alternative form of government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A charter to change a form of county government may be submitted to the electors of a county only by a commission established by resolution of the board upon petition of the number of eligible electors of the county equal to at least twenty-five percent of the votes cast in the county for the office of president of the United States or governor at the preceding general election or the signatures of at least ten thousand eligible electors of the county, whichever number is fewer. The board shall within ten days of the filing of a valid petition adopt such a resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The council of any city wishing to participate in a city-county consolidation charter commission must notify the board by resolution within thirty days of the creation of the commission pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. A city\u8217\'3fs participation in a city-county consolidation charter commission may be proposed by the city council adopting a resolution in favor of participation or by eligible electors of the city equal in number to at least twenty-five percent of the persons who voted at the last regular city election petitioning the council to adopt a resolution in favor of participation. The council shall within ten days of the filing of a valid petition adopt such a resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An alternative form of county government shall be submitted to the electorate by the commission in the form of a charter.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1066, \'a73, 4, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728E.40}}}{{\f5\fs12\hyphpar0\qj{, 331.260}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.233}}}{\*\bkmkstart stylerid1_2E6_2E4_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of commission members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of a commission created to study the alternative forms of county government under }}}{{\f5\fs18\hyphpar0\qj{subchapter II, part 1}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{sections 331.239}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{331.241}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{331.246}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{331.253}}}{{\f5\fs18\hyphpar0\qj{, shall be appointed within forty-five days after the adoption of the resolution creating the commission as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two members shall be appointed by each of the following officers:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{County auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{County recorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{County treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{County sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{County attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two members shall be appointed by each member of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two members shall be appointed by each state representative whose legislative district is located in the county if a majority of the constituents of that legislative district resides in the county. However, if a county does not have a state representative\u8217\'3fs legislative district which has a majority of a state representative\u8217\'3fs constituency residing in the county, the state representative having the largest plurality of constituents residing in the county shall appoint two members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only eligible electors of the county not holding a city, county, or state office shall be members of the commission. In counties having multiple state legislative districts, the districts shall be represented as equally as possible. The membership shall be bipartisan and each appointing authority under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall provide for representation of various age groups, racial minorities, economic groups, and representatives of identifiable geographically defined populations, all in reasonable relationship to the proportions in which these groups are present in the population of the commission area. A vacancy on the commission shall be filled by appointment in the same manner as the original appointment. The county auditor shall notify the appropriate appointing authority of a vacancy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legislative appointing authorities shall be considered one appointing authority for the purpose of complying with }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. The senior legislative appointing authority in terms of length of legislative service shall convene the legislative appointing authorities to consult for the purpose of complying with }}}{{\f5\fs18\hyphpar0\qj{ subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time during the commission process, the commission adopts a resolution by majority vote to prepare a charter proposing city-county consolidation or the community commonwealth form, additional members shall be appointed to the commission in order to comply with }}}{{\f5\fs18\hyphpar0\qj{section 331.233A}}}{{\f5\fs18\hyphpar0\qj{. The life of the commission shall be extended up to six months after the appointment of the additional members.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a75 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7118}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1004, \'a740}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.233A}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.233A}}}{\*\bkmkstart stylerid1_2E6_2E4_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of commission members \u8212\'3f city-county consolidation or community commonwealth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of a commission created to study city-county consolidation or the community commonwealth form shall be appointed within thirty days after the adoption of a resolution creating the commission as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One city council member shall be appointed by the city council of each city participating in the charter process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two members of the board of supervisors shall be appointed by the board of each county participating in the charter process. One supervisor must be a resident of the unincorporated area of the county for each participating county. However, if no supervisor resides in the unincorporated area, the board shall appoint a resident of the unincorporated area of the county in lieu of appointing a supervisor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall be appointed by each state legislator whose legislative district is located in the commission area if a majority of the constituents of that legislative district resides in the commission area. However, if a commission area does not have a state legislative district which has a majority of its constituents residing in the commission area, the legislative district having the largest plurality of constituents residing in the commission area shall appoint one member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An additional member shall be appointed by each city council and each county board for every twenty-five thousand residents in the participating city or unincorporated area of the county, whichever is applicable. The member shall be a resident of the city or county, as applicable. The member shall be a person who is not holding elected office at the time of the appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy on the commission shall be filled by appointment in the same manner as the original appointment. The county auditor shall notify the appropriate appointing authority of a vacancy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time during the commission process, the commission adopts a resolution by majority vote to prepare a charter proposing an alternative form other than city-county consolidation or the community commonwealth form, the resolution shall be submitted to the board of supervisors of the participating county, and the board shall proceed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.233}}}{{\f5\fs18\hyphpar0\qj{. The life of the commission shall be extended up to six months after the appointment of the new members.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1066, \'a75, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.233}}}{{\f5\fs12\hyphpar0\qj{, 331.234}}}{{\f5\fs12\hyphpar0\qj{, 331.247}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.234}}}{\*\bkmkstart stylerid1_2E6_2E4_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Organization and expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within thirty days after the appointment of the members of the commission, the county auditor shall give written notice of the date, time, and location of the first meeting of the commission. At the first meeting the commission shall organize by electing a chairperson, vice chairperson, and other officers as necessary. The commission shall adopt rules governing the conduct of its meetings, subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the commission shall serve without compensation, but they are entitled to travel and other necessary expenses relating to their duties of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall make available to the commission in-kind services such as office space, printing, supplies, and equipment and shall pay the other necessary expenses of the commission including compensation for secretarial, clerical, professional, and consultant services. The total annual expenses, not including the value of in-kind expenses, to be paid from public funds shall not exceed one hundred thousand dollars or an amount equal to thirty cents times the population of the commission area, according to the most recent certified federal census. The commission may employ staff as necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, the expenses of the commission may be paid from the general fund of the county. Expenses of the commission may also be paid from any combination of public or private funds available for that purpose. The commission\u8217\'3fs annual expenses may exceed the amount in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ only if the excess is paid from private funds. If a proposed charter is submitted to the electorate, private funds donated to the commission may be used to promote passage of the proposed charter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a city-county consolidation charter commission or a community commonwealth charter commission, the expenses of the commission shall be paid by each city and county participating in the charter process pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.233A}}}{{\f5\fs18\hyphpar0\qj{. Each participating city\u8217\'3fs share shall be its pro rata share of the expenses based upon the ratio that the population of the city bears to the total population in the county. The remainder shall be paid from the general fund of the county. The amount paid by each city and county participating in the charter process shall be deposited in a segregated account maintained by the county.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1066, \'a76, 7, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.235}}}{\*\bkmkstart stylerid1_2E6_2E4_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commission procedures and reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within sixty days after its organization, the commission shall hold at least one public hearing for the purpose of receiving information and material which will assist in the drafting of a charter. Notice of the date, time, and place of the hearing shall be given as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within seven months after the organization of the commission, the commission shall submit a preliminary report to the board, which report may include the text of the proposed charter. If a proposed charter is included in the preliminary report, the report shall also include an analysis of the fiscal impact of the proposed charter. Sufficient copies of the report shall be made available for distribution to residents of the county who request a copy. The commission shall hold at least one public hearing after submission of the preliminary report to obtain public comment. Notice of the date, time, and place of the hearing shall be given as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within twelve months after organization, the commission shall submit the final report to the board. However, a commission may adopt a motion granting itself a sixty-day extension of time for submission of its final report. If the commission recommends a charter including a form of government other than the existing form of government, the final report shall include the full text and an explanation of the proposed charter, an analysis of the fiscal impact of the proposed charter, any comments deemed desirable by the commission, and any minority reports. The final report may recommend no change to the existing form of government and that no charter be submitted to the electorate, in which case, the report shall state the reasons for and against a change in the existing form of government. The final report shall be made available to the residents of the county upon request. A summary of the final report shall be published by the commission in the official newspapers of the county and in a newspaper of general circulation in each participating city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a provision of this part is amended by enactment of the general assembly after a charter commission has submitted its final report to the board and before the proposed charter is submitted at an election, the commission may amend the proposed charter, only to the extent the charter amendment addresses the changes in the newly enacted law, and shall submit the amended proposed charter and an amended final report to the board in lieu of the original proposed charter. The amended proposed charter shall be placed on the ballot for the next general election if it is received by the board within the time set out in }}}{{\f5\fs18\hyphpar0\qj{section 331.237, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. A summary of any amendments to the proposed charter shall be published by the commission as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission is dissolved on the date of the general election at which the proposed charter is submitted to the electorate. However, if a charter proposing the city-county consolidated form or the community commonwealth form is adopted, the commission is dissolved on the date that the terms of office of the members of the governing body for the alternative form of government commence. If a charter is not recommended, the commission is dissolved upon submission of its final report to the board.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1066, \'a78, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.236}}}{\*\bkmkstart stylerid1_2E6_2E4_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Ballot requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided, the question of adopting the proposed alternative form of government shall be submitted to the electors in substantially the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Should the (charter or amendment) described below be adopted for (insert name of local government)?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ballot must contain a brief description and summary of the proposed charter or amendment.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7126}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.244}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.237}}}{\*\bkmkstart stylerid1_2E6_2E4_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Referendum \u8212\'3f effective date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a proposed charter for county government is received not less than five working days before the filing deadline for candidates for county offices specified in }}}{{\f5\fs18\hyphpar0\qj{section 44.4}}}{{\f5\fs18\hyphpar0\qj{ for the next general election, the board shall direct the county commissioner of elections to submit to the registered voters of the county at the next general election the question of whether the proposed charter shall be adopted. A summary of the proposed charter or amendment shall be published in the official county newspapers and in a newspaper of general circulation in each participating city, if applicable, at least ten but not more than twenty days before the date of the election. Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{sections 331.247}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{331.260}}}{{\f5\fs18\hyphpar0\qj{, if a majority of the votes cast on the question is in favor of the proposal, the proposal is adopted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a proposed charter for county government is adopted:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adopted charter shall take effect July 1 following the general election at which it is approved unless the charter provides a later effective date. If the adopted charter calls for a change in the form of government, officers to fill elective offices shall be elected in the general election in the even-numbered year following the adoption of the charter. Those county officers holding office at the time of the adoption of the charter shall continue in office until the general election in the even-numbered year following the adoption of the charter. If the charter provides that one or more elective offices are combined, the board of supervisors shall appoint one of the elective officers of the combined offices to serve until the general election in the even-numbered year. If the charter calls for the elimination of an elective office, that elective officer\u8217\'3fs term of office shall expire on the date the adopted charter takes effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adoption of the alternative form of county government does not alter any right or liability of the county in effect at the time of the election at which the charter was adopted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All departments and agencies shall continue to operate until replaced.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All ordinances or resolutions in effect remain effective until amended or repealed, unless they are irreconcilable with the adopted charter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the effective date of the adopted charter, the county shall adopt the alternative form by ordinance, and shall file a copy with the secretary of state, and maintain available copies for public inspection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The former governing bodies shall continue to perform their duties until the new governing body is sworn into office, and shall assist the new governing body in planning the transition to the charter government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a charter is submitted to the electorate but is not adopted, another charter shall not be submitted to the electorate for two years. If a charter is adopted, it may be amended at any time. If a charter is adopted, a proposed charter for another alternative form of county government shall not be submitted to the electorate for six years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{ do not apply to the city-county consolidated form of government or the community commonwealth form of government.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 129, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a712 \u8211\'3f 14}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1180, \'a745, 46}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 67, \'a753}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1066, \'a79, 10, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.235}}}{{\f5\fs12\hyphpar0\qj{, 331.244}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.238}}}{\*\bkmkstart stylerid1_2E6_2E4_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations to alternative forms of county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may adopt or amend an alternative form of county government subject to the requirements and limitations provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An alternative form of county government shall provide for the exercise of home rule power and authority not inconsistent with state law and may include provisions for any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A board of an odd number of members which may exceed the number of members specified in }}}{{\f5\fs18\hyphpar0\qj{sections 331.201}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{331.203}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{331.204}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A supervisor representation plan for the county which may differ from the supervisor representation plans as provided in }}}{{\f5\fs18\hyphpar0\qj{subchapter II, part 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The initial compensation for members of the board which, thereafter, shall be determined as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.215}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The method of selecting officers of the board and fixing their terms of office which may differ from the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 331.208 through 331.211}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determining meetings of the board and rules of procedure which may differ from the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 331.213}}}{{\f5\fs18\hyphpar0\qj{, except the meetings shall be scheduled and conducted in compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The combining of duties of elected officials or the elimination of elected offices and the assumption of the duties of those offices by appointed officials.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The organization of county departments, agencies, or boards. The organization plan may provide for the abolition or consolidation of a board or a commission and the assumption of its powers and duties by the board of supervisors or another officer. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the election or appointment of township trustees, a method providing for the exercise of their powers and duties by the board of supervisors or other governing body of the county or another office.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consolidating city-county government or government functions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consolidating county-county government or government functions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the board of trustees of a county hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An alternative form of county government shall provide for the partisan election of its officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ do not apply to the city-county consolidated form of government or the community commonwealth form of government.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a715 \u8211\'3f 18}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a711, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a7103}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.246}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E4_2E11_2E1_2E1}{BOARD-ELECTED EXECUTIVE FORM}{\*\bkmkend stylerid1_2E6_2E4_2E11_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.239}}}{\*\bkmkstart stylerid1_2E6_2E4_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Board-elected executive form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board-elected executive form consists of an elected board of an odd number with staggered terms of office and one elected executive whose term shall be the same as that of a member of the board. If the administrative offices of the county, excluding the county executive, are appointive under the plan, the board shall have at least five members. The board shall have a chairperson who shall be elected by the members of the board from their own number for a term established by ordinance, and who shall vote as a member of the board. The elected executive may veto ordinances and resolutions, subject to an override by a two-thirds vote of the board.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.233}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.240}}}{\*\bkmkstart stylerid1_2E6_2E4_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of executive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The executive shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enforce laws, ordinances, and resolutions of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Perform duties required by law, ordinance, or resolution of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer affairs of the county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out policies established by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recommend measures to the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Report to the board on the affairs and financial condition of the county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Execute bonds, notes, contracts, and written obligations of the board, subject to the approval of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Report to the board as the board may require.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Attend board meetings and take part in discussion, but shall not vote.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare and execute the budget adopted by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appoint, with the consent of the board, all members of county boards, except the executive may appoint without the consent of the board temporary advisory committees established by the executive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appoint and remove all employees.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7373.4}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E4_2E14_2E1_2E1}{BOARD-MANAGER GOVERNMENT}{\*\bkmkend stylerid1_2E6_2E4_2E14_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.241}}}{\*\bkmkstart stylerid1_2E6_2E4_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Board-manager form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board-manager form consists of an elected board and a manager appointed by the board, who shall be the chief administrative officer of the county government. The board shall have staggered terms of office. The chairperson shall be elected by the members of the board from their own number for a term established by ordinance and shall vote as a member of the board. If the administrative offices of the county are appointive under the plan, the board shall have at least five members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manager shall be appointed by the board and removed only by a majority vote of the membership of the board. The manager shall be responsible to the board for the administration of all county government affairs placed in the manager\u8217\'3fs charge by law, ordinance, or resolution.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a7104}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.233}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.242}}}{\*\bkmkstart stylerid1_2E6_2E4_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of manager.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The manager shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enforce laws, ordinances, and resolutions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Perform the duties required of the manager by law, ordinance, or resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer the affairs of the county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Direct, supervise, and administer all departments, agencies, and offices of the county government unit except as otherwise provided by law or ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out policies established by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare the board agenda.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recommend measures to the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Report to the board on the affairs and financial condition of the county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Execute bonds, notes, contracts, and written obligations of the board, subject to the approval of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Report to the board as the board may require.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Attend board meetings and take part in the discussion, but shall not vote.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare and present the budget to the board for its approval and execute the budget adopted by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appoint, suspend, and remove all employees of the county government except as otherwise provided by law or ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appoint members of temporary advisory committees.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.261}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.243}}}{\*\bkmkstart stylerid1_2E6_2E4_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employees of board-manager government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employees appointed by the manager or subordinates shall be administratively responsible to the manager.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board or its members shall not dictate the appointment or removal of any employee appointed by the manager or any subordinate of the manager.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for the purpose of inquiry or investigation, the board or its members shall deal with the county employees who are subject to the direction and supervision of the manager solely through the manager, and the board or its members shall not give orders to an employee under the manager\u8217\'3fs direction or supervision.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a715}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.261}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E4_2E18_2E1_2E1}{AMENDMENT TO COUNTY GOVERNMENT}{\*\bkmkend stylerid1_2E6_2E4_2E18_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.244}}}{\*\bkmkstart stylerid1_2E6_2E4_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Amendment to county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An amendment to county government organization shall only be made by submitting the question of amendment to the electors of the county government pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.236}}}{{\f5\fs18\hyphpar0\qj{. To become effective, a proposed amendment must receive an affirmative vote of a majority of the electors voting on the question. An amendment approved by the electors becomes effective pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.237}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An amendment to a county government organization may be proposed by initiative upon petition of the number of eligible electors of the county equal to at least ten percent of the votes cast at the preceding election for the office of president of the United States or governor, or by resolution adopted by the governing body. The question on amendment of county government organization shall be submitted to the electors as soon as possible after the submission of a petition or adoption of a resolution, either at a general election or at a special election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the city-county consolidated form of government or the community commonwealth form of government.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1066, \'a712, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.245}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations on amendments to county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The electors of a county who have adopted an amendment to county government may not vote on the question of amending the county government for two years. An amendment shall not include an alternative form of county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the city-county consolidated form of government or the community commonwealth form of government.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a713, 31}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a7104}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7373.4}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E4_2E21_2E1_2E1}{CHARTER FORM}{\*\bkmkend stylerid1_2E6_2E4_2E21_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.246}}}{\*\bkmkstart stylerid1_2E6_2E4_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Charter form of government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The charter form of government shall be specified in a proposed charter written by a charter committee. The proposed charter shall establish an elected legislative body. The charter shall specify the number of members and term of office pursuant to }{{\f5\fs18\hyphpar0\qj{section 331.238}}}{. If the administrative offices of the county, excluding an elected county executive, are appointive under the charter, the board shall have at least five members. The charter may establish legislative or administrative organizational structure. The charter may include the provisions necessary to permit an orderly transition to the charter form of government. However, the provisions shall be limited in scope consistent with the intent of, and in accordance with, }{{\f5\fs18\hyphpar0\qj{section 331.238}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a718}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.233}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E4_2E23_2E1_2E1}{CITY-COUNTY CONSOLIDATION}{\*\bkmkend stylerid1_2E6_2E4_2E23_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.247}}}{\*\bkmkstart stylerid1_2E6_2E4_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{City-county consolidated form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commission appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.233A}}}{{\f5\fs18\hyphpar0\qj{ may propose a charter under which a county and one or more cities within the county may unite to form a single unit of local government, or may propose a charter under which a county and one or more cities within the county may create a unified government empowered to govern a city and a county with each retaining the separate status and power of a city or a county for all purposes and constituting separate political subdivisions under combined governance. Either option proposed shall be referred to as a city-county consolidated form of government. If more than fifty percent of the population of a city resides within the affected county, it is a city within the county for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and may continue its status as a city within the county even if the population of such city falls below the more than fifty percent threshold in a future census.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A majority vote by the charter commission is required for the submission to the electorate of a proposed charter for a city-county consolidated form of government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city-county consolidated form of government does not need to include more than one city. A city shall not be included unless the city participates in the commission process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adoption of the proposed consolidation charter requires the approval of a majority of the votes cast in the entire county and requires the approval of a majority of the votes cast in one or more cities named on the ballot. The consolidation charter shall be effective in regard to a city named on the ballot only if a majority of the votes cast in that city approves the consolidation charter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adopted charter takes effect July 1 following the general election at which it is approved unless the charter provides a later effective date. If the adopted charter calls for a change in the form of government, officers to fill elective offices created by the charter shall be elected in the general election in the even-numbered year following the adoption of the charter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may request to join an existing city-county consolidated government by resolution of the city council or upon petition of eligible electors of the city equal in number to at least twenty-five percent of the persons who voted at the last regular city election. Within fifteen days after receiving a valid petition, the city council of the petitioning city shall adopt a resolution in favor of participation and shall, within ten days of adoption, forward the resolution to the governing body of the city-county consolidated government. If a majority of the governing body of the city-county consolidated government approves the resolution, the question of joining the city-county consolidated government shall be submitted to the electorate of the petitioning city within sixty days after approval of the resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a charter is adopted, it may be amended at any time by one of the following methods:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body of the city-county consolidated government, by resolution, may submit a proposed amendment to the voters, and the proposed amendment becomes effective only upon approval by a majority of those voting on the proposed amendment within the city-county consolidated area.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body of the city-county consolidated government, by ordinance, may amend the charter. However, within thirty days following publication of the ordinance, if a petition valid under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{ is filed with the governing body of the city-county consolidated government, the governing body must submit the charter amendment to the voters and, in such event, the amendment becomes effective only upon approval of a majority of those voting on the proposed amendment within the city-county consolidated area.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a petition valid under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{ is filed with the governing body of the city-county consolidated government, proposing an amendment to the charter, the governing body must submit the proposed amendment to the voters and, in such an event, the amendment becomes effective only upon approval of a majority of those voting on the proposed amendment within the city-county consolidated area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proposed amendment shall be submitted at the general election. However, if the amendment is proposed pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), the proposed amendment may be submitted at a special election if the resolution submitting the amendment to the voters is adopted by a two-thirds majority of the membership of the governing body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an election is held, the governing body shall submit the question of amending the charter to the electors in substantially the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Should the amendment described below be adopted for the city-county consolidated charter of (insert name of county and of each consolidated city)?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ballot must contain a brief description and summary of the proposed amendment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An amendment shall not adopt an alternative form of county government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if an amendment to a charter proposes to increase or decrease the number of members on the governing body, the amendment shall be submitted to the voters at a general election.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a714, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.237}}}{{\f5\fs12\hyphpar0\qj{, 331.260}}}{{\f5\fs12\hyphpar0\qj{, 331.262}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.248}}}{\*\bkmkstart stylerid1_2E6_2E4_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Charter of consolidation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The charter commission proposing a city-county consolidated form of government shall prepare, adopt, and cause to be submitted to the voters the charter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The charter for a city-county consolidated form of government shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for adjustment of existing bonded indebtedness and other obligations in a manner which will provide for a fair and equitable burden of taxation for debt service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for establishment of service areas, except that formation of a city-county consolidated form of government shall not affect the assignment of electric utility service territories pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 476}}}{{\f5\fs18\hyphpar0\qj{, and shall not affect the rights of a city to grant a franchise under }}}{{\f5\fs18\hyphpar0\qj{chapter 364}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the transfer or other disposition of property and other rights, claims, assets, and franchises of the county and each city consolidated under the alternative form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide the official name of the city-county consolidated government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the transfer, reorganization, abolition, absorption, and adjustment of boundaries of all existing boards, bureaus, commissions, agencies, special districts, and political subdivisions of the city-county consolidated government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the exercise of home rule power and authority not inconsistent with state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for a governing body of an odd number of members, not less than five, but which may exceed the number of members specified in }}}{{\f5\fs18\hyphpar0\qj{sections 331.201}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{331.203}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{331.204}}}{{\f5\fs18\hyphpar0\qj{. The titles of the members of the governing body shall be determined by the charter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for a representation plan for the governing body which representation plan may differ from the representation plans provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.206}}}{{\f5\fs18\hyphpar0\qj{ and in }}}{{\f5\fs18\hyphpar0\qj{chapter 372}}}{{\f5\fs18\hyphpar0\qj{. If the plan calls for representation by districts and the charter has been approved in a county whose population is one hundred eighty thousand or more, the plan shall be drawn pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.210A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The initial representation plan for such a county shall be drawn as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.210A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, within one hundred twenty days after the election at which the charter is approved. For the initial representation plan, the charter commission shall assume the role of the governing body for purposes of this paragraph and }}}{{\f5\fs18\hyphpar0\qj{section 331.210A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the initial compensation for members of the governing body and for a method of changing the compensation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The charter may grant the legislative body of the consolidated government the authority to transfer, reorganize, and provide a method for adjusting the boundaries of the entities within the consolidated government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consolidation charter may include other provisions which the commission elects to include and which are not irreconcilable with state law. These provisions may include but are not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for a method of selecting officers of the governing body and fixing their terms of office which may differ from the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 331.208 through 331.211}}}{{\f5\fs18\hyphpar0\qj{ and the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 372}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for meetings of the governing body and rules of procedure which may differ from the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 331.213}}}{{\f5\fs18\hyphpar0\qj{, except that the meetings shall be scheduled and conducted in compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for combining the duties of elected officials of the county, for eliminating elected offices and the assumption of the duties of those offices by appointed officials, and for adding to, deleting from, or otherwise changing the duties of officials, elected or otherwise, of the county and each consolidated city. If the charter provides that one or more elective offices are combined, the board of supervisors shall appoint one of the elective officers of the combined offices to serve until new officers have been elected at the general election in the even-numbered year and have qualified for office. If the charter calls for the elimination of an elective office, that elective officer\u8217\'3fs term of office shall expire on the date specified in the charter.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the organization of city and county departments, agencies, or boards. The organization plan may provide for the abolition or consolidation of a department, agency, board, or commission and the assumption of its powers and duties by the governing body or by another department, agency, board, or commission.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for a method for the governing body or another office to exercise the powers and duties of the township trustees, in lieu of their election or appointment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for a chief executive officer, a method of selecting that officer, the compensation for that officer, a method of changing the compensation, and the powers and duties of that officer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the charter provides for a chief executive office, provide for the appointment of a chief executive officer pro tem, the compensation for that officer, a method of changing the compensation, and the manner in which that officer would exercise the powers and duties of the chief executive officer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the appointment of a city manager, a method for determining and changing the compensation for the city manager, and the powers and duties of the city manager.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the board of trustees of a county hospital or to the board of trustees of a city hospital.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a721, 22}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a715 \u8211\'3f 17, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.249}}}{\*\bkmkstart stylerid1_2E6_2E4_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Effect of consolidation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city-county consolidated form of government under which a county and one or more cities within the county unite to form a single unit of local government shall create a unified government which includes a municipal corporation and a county. The consolidated unit shall have the separate status of a county and a city for all purposes and shall constitute two political subdivisions, a consolidated city and a county, under combined governance. The consolidated unit shall retain one separate constitutional debt limitation with respect to its status as a city and a separate constitutional debt limitation with respect to its status as a county.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body of a city-county consolidated form of government under which a county and one or more cities within the county create a unified government empowered to govern a city and a county shall have, with respect to the county, the power and authority of the board of supervisors of a county, and, with respect to each city, the power and authority of the city council of a city. Each consolidated city and the county constitute separate political subdivisions. Each consolidated city and the county shall each retain a separate constitutional debt limitation and shall each have the authority to issue bonds and incur financial obligations in accordance with the provisions of state law applicable to a city or a county, respectively.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city-county consolidated form of government may include an area which is located in another county, but which is within the corporate boundaries of one of the consolidated cities. Services may be provided in the extra-county area and taxes to fund those services may be collected in the extra-county area by the consolidated government, to the extent permitted by the Constitution of the State of Iowa. In addition to the right to vote in the county of residence, electors residing in the extra-county area shall have the right to vote on any matter related to the city-county consolidated government, including election of its governing body and its chief executive officer, if any.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a city-county consolidation charter is proposed, within ninety days following the final report of the commission, a resident or property owner of the commission area proposed to be consolidated may bring an action in district court for declaratory judgment to determine the legality of the proposed charter and to otherwise declare the effect of the charter. The court shall expedite its review and determination in this matter. The referendum on the proposed charter shall be stayed during pendency of the action and for such additional time during which the proposed charter or its enabling legislation does not conform to the Constitution or laws of the State of Iowa. If in its final judgment the court determines that the proposed charter fails to conform to the Constitution or laws of this state, the commission shall have a period of six months in which to revise and resubmit the proposed charter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All provisions of law authorizing contributions of any kind, in money or otherwise, from the state or federal government to counties and cities shall remain in full force with respect to each city and the county comprising a city-county consolidated government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adoption of a charter for a city-county consolidated government does not alter any right or liability of the county or consolidated city in effect at the time of the election at which the charter was adopted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All departments and agencies of the county and of each consolidated city shall continue to operate until their authority to operate is superseded by action of the governing body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the effective date of the adopted charter, the county and each participating city shall adopt the city-county consolidated form of government by ordinance, and shall file a copy with the secretary of state and maintain available copies for public inspection. The county shall provide each participating city with a copy of the county\u8217\'3fs ordinance. Each participating city shall provide a copy of that city\u8217\'3fs ordinance to the county and to the other participating cities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the governing body of the county shall continue in office after the effective date of the charter until the members of the governing body and the chief executive officer, if any, of the city-county consolidated government have been elected and qualified, at which time the offices of the former governing body of the county shall be abolished and the terms of the members of the former governing body shall be terminated. Members of the governing body and the mayor of each consolidated city shall continue in office after the effective date of the charter until the members of the governing body of the city-county consolidated government and the chief executive officer, if any, have been elected and qualified, at which time the office of mayor and of the former governing body of each consolidated city shall be abolished and the term of the members of each governing body and the term of each mayor shall be terminated.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During the period between the effective date of the charter and the election and qualification of the members of the governing body of the city-county consolidated government and the election and qualification of the chief executive officer, if any, the former governing bodies of the county and each city and the mayor of each city shall continue to exercise the power of, and to perform the duties for, their respective county and city. The charter shall provide that these incumbent officers assist in planning and carrying out the transition to the city-county consolidated form of government. The board of supervisors shall include in its budget for the fiscal year in which the charter becomes effective funds sufficient to provide for the operating expenses of a transition committee and for expenses incurred in initially establishing districts if the charter provides for representation by districts and for salaries for newly elected officers of the city-county consolidated government, after consultation with the transition committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a city-county consolidation charter is submitted to the electorate but is not adopted, another charter shall not be submitted to the electorate for at least two years from the date of the election at which the charter was rejected. If a city-county consolidation charter is adopted, a proposed charter for another alternative form of county government shall not be submitted to the electorate for at least six years from the date of the election at which the charter was adopted.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a723, 24}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a718, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.250}}}{\*\bkmkstart stylerid1_2E6_2E4_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General powers of consolidated local governments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The consolidation charter shall provide for the delivery of services to specified areas of the county and of each consolidated city. The governing body of the consolidated government shall supervise the administration of the provision of services in each of the designated service areas and shall have the authority to determine the boundaries of the service areas. For each service provided by the consolidated government, the consolidated government shall assume the same statutory rights, powers, and duties relating to the provision of the service as if the county or the member city were itself providing the service to its citizens.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1066, \'a719, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.251}}}{\*\bkmkstart stylerid1_2E6_2E4_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules, ordinances, and resolutions of consolidated government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each rule, ordinance, or resolution in force within a county or within a city on the effective date of the charter shall remain in force within that county or within that city until superseded by action of the new governing body, unless the rule, ordinance, or resolution is in conflict with a provision of the charter, in which case, the charter provision shall supersede the conflicting rule, ordinance, or resolution. The governing body of a participating city or county in office on the effective date of the charter shall retain its powers to adopt motions, resolutions, or ordinances provided that such motions, resolutions, or ordinances do not conflict with the provisions of the charter. Ordinances and resolutions relating to public improvements to be paid for in whole or in part by special assessments shall remain in effect until paid in full.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a charter creating a city-county consolidated form of government provides for a chief executive officer with the power to veto an ordinance, an amendment to an ordinance, or a resolution, the governing body shall adopt legislation in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 380}}}{{\f5\fs18\hyphpar0\qj{. If a charter creating a city-county consolidated form of government does not provide for a chief executive officer, the governing body shall adopt legislation in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 331.302}}}{{\f5\fs18\hyphpar0\qj{. However, a charter may provide that approval of certain ordinances, amendments, or resolutions shall require the affirmative vote of more than a majority of all members of the governing body.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a723}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1066, \'a720, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.252}}}{\*\bkmkstart stylerid1_2E6_2E4_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form of ballot }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ city-county consolidation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The question of city-county consolidation shall be submitted to the electors in substantially the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Should the charter described below be adopted for (insert name of county and each city proposing to consolidate)?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ballot must contain a brief description and summary of the proposed charter.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a721, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7128}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.260}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}{{\f5\fs12\hyphpar0\qj{, 373.4}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E4_2E3_30_2E1_2E1}{MULTICOUNTY CONSOLIDATION}{\*\bkmkend stylerid1_2E6_2E4_2E3_30_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.253}}}{\*\bkmkstart stylerid1_2E6_2E4_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Requirements for multicounty government consolidation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consolidation may be placed on the ballot only by a joint report by two or more counties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A final report must contain a consolidation charter if multicounty consolidation is recommended. The consolidation charter must conform to the provisions and requirements in accordance with this part.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a727}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.233}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.254}}}{\*\bkmkstart stylerid1_2E6_2E4_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Charter of consolidation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When multicounty consolidation is recommended, the consolidation charter shall provide for all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adjustment of existing bonded indebtedness and other obligations in a manner which assures a fair and equitable burden of taxation for debt service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishment of subordinate service districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transfer or other disposition of property and other rights, claims, assets, and franchises of the counties consolidated under the charter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The official name of the consolidated county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transfer, reorganization, abolition, absorption, and adjustment of boundaries of existing boards, subordinate service districts, local improvement districts, and agencies of the consolidated counties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The merger of the elective offices of each consolidating county with the election of new officers within sixty days after the effective date of the charter. The elections shall be conducted by the county commissioner of elections of each county. No primary election shall be held. Nominations shall be made pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 43.78}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapters 44}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{45}}}{{\f5\fs18\hyphpar0\qj{, as applicable, except that the filing deadline shall be forty days before the election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The merger of the appointive offices of each consolidating county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consolidation charter may include other provisions that are not inconsistent with state law.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a728, 29}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1180, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a722, 23, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.255}}}{\*\bkmkstart stylerid1_2E6_2E4_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form of ballot }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ multicounty consolidation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The question of multicounty consolidation shall be submitted to the electors in substantially the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Should the consolidation charter described below be adopted for (name of applicable county)?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ballot must contain a brief description and summary of the proposed charter.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1229, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 256, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7129}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.257}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.256}}}{\*\bkmkstart stylerid1_2E6_2E4_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Joining existing multicounty consolidated government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A county may join an existing multicounty consolidated government by resolution of the board of supervisors or upon petition of eligible electors of the county equal in number to at least twenty-five percent of the persons who voted at the last general election for the office of governor or president of the United States, whichever is fewer. Within fifteen days after receiving a valid petition, the board of the petitioning county shall adopt a resolution in favor of participation and shall immediately forward the resolution to the legislative body of the multicounty consolidated government. If a majority of the multicounty consolidated board of supervisors approves the resolution, the question of joining the multicounty consolidated government shall be submitted to the electorate of the petitioning county within sixty days after approval of the resolution.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a731}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.257}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.257}}}{\*\bkmkstart stylerid1_2E6_2E4_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Recognition of change in boundaries by general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a charter for multicounty consolidation is adopted pursuant to }{{\f5\fs18\hyphpar0\qj{section 331.255}}}{ or if the question of joining a multicounty consolidated government is approved pursuant to }{{\f5\fs18\hyphpar0\qj{section 331.256}}}{, the general assembly next convening following the election required by }{{\f5\fs18\hyphpar0\qj{section 331.255}}}{ or }{{\f5\fs18\hyphpar0\qj{331.256}}}{ shall pass legislation recognizing the change in boundaries of the counties where the question of multicounty consolidation was approved. The boundaries recognized in the legislation shall conform to the boundaries contained in the consolidation charter. The legislation shall contain the official name of the consolidated county as that name is given in the consolidation charter.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1066, \'a724, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.258 and 331.259}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E4_2E37_2E1_2E1}{COMMUNITY COMMONWEALTH}{\*\bkmkend stylerid1_2E6_2E4_2E37_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.260}}}{\*\bkmkstart stylerid1_2E6_2E4_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Community commonwealth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county and one or more cities or townships within the county, a contiguous county, and a city or a township within a contiguous county may unite to establish an alternative form of local government for the purpose of making more efficient use of their resources by providing for the delivery of regional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A charter proposing a community commonwealth as an alternative form of government may be submitted to the voters only by a commission established under }}}{{\f5\fs18\hyphpar0\qj{section 331.232}}}{{\f5\fs18\hyphpar0\qj{. A majority vote by the commission is required for the submission of a charter proposing a community commonwealth as an alternative form of local government. The commission submitting a community commonwealth form of government shall issue a final report and proposal. Adoption of the proposed community commonwealth charter requires the approval of a majority of the votes cast in the entire county and requires the approval of a majority of the votes cast in one or more cities named on the ballot. A city named on the ballot is included in the community commonwealth only if the proposed community commonwealth charter is approved by a majority of the votes cast in the city.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The question of forming a community commonwealth shall be submitted to the electorate in substantially the same form as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.252}}}{{\f5\fs18\hyphpar0\qj{. The effective date of the charter and election of new officers of the community commonwealth shall be as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.247, subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a725, 31}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728E.40}}}{{\f5\fs12\hyphpar0\qj{, 331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.237}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.261}}}{\*\bkmkstart stylerid1_2E6_2E4_2E39_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E39_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Charter \u8212\'3f community commonwealth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The community commonwealth charter shall provide for the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The official name of the community commonwealth government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An elective legislative body established in the manner provided for county boards of supervisors under }}}{{\f5\fs18\hyphpar0\qj{sections 331.201 through 331.216}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 331.248, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the initial compensation for members of that body, and for a method of changing the compensation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appointment of a manager pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 331.241 through 331.243}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adjustment of existing bonded indebtedness and other obligations to the extent it relates to the delivery of services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transfer or other disposition of property and other rights, claims, assets, and franchises as they relate to the delivery of services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transfer, reorganization, abolition, adjustment, and absorption of existing boards, existing subordinate service districts, local improvement districts, and agencies of the participating county and cities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A system of delivery of services to the entire community commonwealth pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.263}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A formula for the transfer of taxing authority from member cities to the community commonwealth governing body to fund the delivery of regional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transfer into the community commonwealth of areawide services which had been provided by other boards, commissions, and local governments, except that formation of a community commonwealth shall not affect the assignment of electric utility service territories pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 476}}}{{\f5\fs18\hyphpar0\qj{, and shall not affect the rights of a city to grant a franchise under }}}{{\f5\fs18\hyphpar0\qj{chapter 364}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A process by which the governing body of the community commonwealth and the governing bodies of the member cities provide by mutual agreement for the delivery of specified services to the community commonwealth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The partisan election of community commonwealth government officials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The community commonwealth charter may include other provisions which the commission elects to include and which are not irreconcilable with state law, including, but not limited to, those provisions in }}}{{\f5\fs18\hyphpar0\qj{section 331.248, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a726, 27, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728E.40}}}{{\f5\fs12\hyphpar0\qj{, 331.231}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.262}}}{\*\bkmkstart stylerid1_2E6_2E4_2E4_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E4_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adoption of charter \u8212\'3f effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As a political subdivision of the state, the community commonwealth unit of local government shall have the statutory and constitutional status of a county and of a city to the extent the community commonwealth governing body assumes the powers and duties of cities as those powers and duties relate to the delivery of services. For each service provided by the community commonwealth, the community commonwealth shall assume the same statutory rights, powers, and duties relating to the provision of the service as if the member city were itself providing the service to its citizens.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On its effective date, the community commonwealth charter operates to replace the existing county government structure. The governments of participating cities shall remain in existence to render those services not transferred to the community commonwealth government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adoption of the community commonwealth form of government does not alter any right or liability of the county or member city in effect at the time of the election at which the charter was adopted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All departments and agencies of the county and of each member city shall continue to operate until their authority to operate is superseded by action of the governing body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All ordinances or resolutions in effect remain effective until amended or repealed, unless they are irreconcilable with the adopted charter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the effective date of the adopted charter, the county shall adopt the community commonwealth form of government by ordinance, and shall file a copy with the secretary of state and maintain available copies for public inspection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the governing body of the county and of each member city shall continue in office until the members of the governing body of the community commonwealth have been elected and sworn into office, at which time the offices of the former governing bodies shall be abolished, and the terms of the members of the former governing bodies shall be terminated. During the period between the effective date of the charter and the election and qualification of the elected members of the new governing body, the former governing bodies of each member city and of the county shall continue to perform their duties and shall assist in planning the transition to the community commonwealth form of government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a community commonwealth charter is submitted to the electorate but is not adopted, another charter shall not be submitted to the electorate for at least two years from the date of the election at which the charter was rejected. If a community commonwealth charter is adopted, a proposed charter for another alternative form of county government shall not be submitted to the electorate for at least six years from the date of the election at which the charter was adopted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a community commonwealth charter is adopted, the charter may be amended at any time. The charter shall be amended in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.247, subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city or county wishing to terminate its membership in the community commonwealth government must do so pursuant to the existing charter procedure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 372}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city or county may join an existing community commonwealth government by resolution of the board or council, whichever is applicable, or upon petition of eligible electors of the city or county, whichever is applicable, equal in number to at least twenty-five percent of the persons who voted at the last general election for the office of governor or president of the United States, whichever is fewer. Within fifteen days after receiving a valid petition, the applicable governing body shall adopt a resolution in favor of participation and shall immediately forward the resolution to the governing body of the community commonwealth. If a majority of the community commonwealth governing body approves the resolution, the question of joining the community commonwealth shall be submitted to the electorate of the petitioning city or county within sixty days after approval of the resolution.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1066, \'a728, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7130}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728E.40}}}{{\f5\fs12\hyphpar0\qj{, 331.231}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.263}}}{\*\bkmkstart stylerid1_2E6_2E4_2E41_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E41_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Service delivery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body of the community commonwealth government shall administer the provision of services in each of the designated service areas and shall have the authority to determine the boundaries of the service areas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body of the community commonwealth shall have the authority to levy county taxes and shall have the authority to levy city taxes to the extent the city tax levy authority is transferred by the charter to the community commonwealth. A city participating in the community commonwealth shall transfer a portion of the city\u8217\'3fs tax levy authorized under }}}{{\f5\fs18\hyphpar0\qj{section 384.1}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{384.12}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable, to the governing body of the community commonwealth. The maximum rates of taxes authorized to be levied under }}}{{\f5\fs18\hyphpar0\qj{sections 384.1}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{384.12}}}{{\f5\fs18\hyphpar0\qj{ by a city participating in the community commonwealth shall be reduced by an amount equal to the rates of the same or similar taxes levied in the city by the governing body of the community commonwealth.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 256, \'a735}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.231}}}{{\f5\fs12\hyphpar0\qj{, 331.261}}}{{\f5\fs12\hyphpar0\qj{, 372.1}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.264 through 331.300}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER III}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E2_2E2}{POWERS AND DUTIES OF A COUNTY}{\*\bkmkend stylerid1_2E7_2E2_2E2}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 1}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E3_2E1_2E2}{GENERAL POWERS AND DUTIES}{\*\bkmkend stylerid1_2E7_2E3_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.301}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General powers and limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may, except as expressly limited by the Constitution of the State of Iowa, and if not inconsistent with the laws of the general assembly, exercise any power and perform any function it deems appropriate to protect and preserve the rights, privileges, and property of the county or of its residents, and to preserve and improve the peace, safety, health, welfare, comfort, and convenience of its residents. This grant of home rule powers does not include the power to enact private or civil law governing civil relationships, except as incident to an exercise of an independent county power, or to enact private or civil law which violates }}}{{\f5\fs18\hyphpar0\qj{section 675.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A power of a county is vested in the board, and a duty of a county shall be performed by or under the direction of the board except as otherwise provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The enumeration of a specific power of a county, the repeal of a grant of power, or the failure to state a specific power does not limit or restrict the general grant of home rule power conferred by the Constitution and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A county may exercise its general powers subject only to limitations expressly imposed by a state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An exercise of a county power is not inconsistent with a state law unless it is irreconcilable with the state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall substantially comply with a procedure established by a state law for exercising a county power unless a state law provides otherwise. If a procedure is not established by state law, a county may determine its own procedure for exercising the power.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not set standards and requirements which are lower or less stringent than those imposed by state law, but may set standards and requirements which are higher or more stringent than those imposed by state law, unless a state law provides otherwise.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not impose any fee or charge on any individual or business licensed by the plumbing and mechanical systems board for the right to perform plumbing, mechanical, HVAC, refrigeration, sheet metal, or hydronic systems work within the scope of the license. This paragraph does not prohibit a county from charging fees for the issuance of permits for, and inspections of, work performed in its jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt an ordinance, motion, resolution, or amendment that sets standards or requirements regarding the sale or marketing of consumer merchandise that are different from, or in addition to, any state law. For purposes of this paragraph:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConsumer merchandise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means merchandise offered for sale or lease, or provided with a sale or lease, primarily but not exclusively for personal, family, or household purposes, and includes any container used for consuming, carrying, or transporting such merchandise.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fContainer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a bag, cup, package, container, bottle, or other packaging that is all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designed to be either reusable or single-use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Made of cloth, paper, plastic, including foamed or expanded plastic, cardboard, corrugated material, aluminum, glass, or postconsumer recycled or similar material or substrates, including coated, laminated, or multilayer substrates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designed for consuming, transporting, or protecting merchandise, food, or beverages from or at a food service or retail facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ordinance, motion, resolution, or amendment adopted prior to March 30, 2017, that violates this paragraph is void and unenforceable on and after March 30, 2017.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to county solid waste or recycling collection or county solid waste or recycling programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt an ordinance, motion, resolution, or amendment, or use any other means, that restricts an owner of real property from refinancing existing debt on, selling, or otherwise transferring title to the property by requiring the owner to take or show compliance with any action with respect to the property or pay any fee before, during, or after refinancing existing debt on, selling, or otherwise transferring title to the property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not levy a tax unless specifically authorized by a state statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county is a body corporate for civil and political purposes and shall have a seal as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.552, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supervisors and other county officers may administer oaths and take affirmations as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 63A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to the general grant of home rule power conferred by the Constitution of the State of Iowa and if not inconsistent with the laws of the general assembly, a county that has designated more than one city to be a county seat may consolidate or reduce the number of county seats by ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may enter into leases or lease-purchase contracts for real or personal property in accordance with the following terms and procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall lease or lease-purchase property only for a term which does not exceed the economic life of the property, as determined by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lease or lease-purchase contract entered into by a county may contain provisions similar to those sometimes found in leases between private parties, including, but not limited to, the obligation of the lessee to pay any of the costs of operation or ownership of the leased property and the right to purchase the leased property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision of a lease or lease-purchase contract which stipulates that a portion of the rent payments be applied as interest is subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{. Other laws relating to interest rates do not apply. }}}{{\f5\fs18\hyphpar0\qj{Chapter 75}}}{{\f5\fs18\hyphpar0\qj{ is not applicable. A county enterprise is a separate entity under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, whether it is governed by the board or another governing body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board must follow substantially the same authorization procedure required for the issuance of general obligation bonds issued for the same purpose to authorize a lease or a lease-purchase contract made payable from the debt service fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may authorize a lease or lease-purchase contract which is payable from the general fund if the contract would not cause the total of lease and lease-purchase payments due from the general fund of the county in any single future fiscal year for all lease or lease-purchase contracts in force on the date of the authorization, excluding payments to exercise purchase options or to pay the expenses of operation or ownership of the property, to exceed ten percent of the last certified general fund budget amount in accordance with the following procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board must follow substantially the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 331.443}}}{{\f5\fs18\hyphpar0\qj{ to authorize a lease or lease-purchase contract for personal property which is payable from the general fund. The board must follow substantially the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 331.443}}}{{\f5\fs18\hyphpar0\qj{ to authorize a lease or lease-purchase contract for real property which is payable from the general fund if the principal amount of the lease-purchase contract does not exceed the following limits:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five hundred twenty thousand dollars in a county having a population of twenty-five thousand or less.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six hundred fifty thousand dollars in a county having a population of more than twenty-five thousand but not more than fifty thousand.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seven hundred eighty thousand dollars in a county having a population of more than fifty thousand but not more than one hundred thousand.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One million forty thousand dollars in a county having a population of more than one hundred thousand but not more than two hundred thousand.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(v)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One million three hundred thousand dollars in a county having a population of more than two hundred thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, if the principal amount of a lease or lease-purchase contract pursuant to this subparagraph (1) is less than thirty-two thousand five hundred dollars, the board may authorize the lease or lease-purchase contract without following the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 331.443}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board must follow the following procedures to authorize a lease or lease-purchase contract for real property which is payable from the general fund if the principal amount of the lease or lease-purchase contract exceeds the limits set forth in subparagraph (1):}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board must institute proceedings for entering into a lease or lease-purchase contract payable from the general fund by causing a notice of the meeting to discuss entering into the lease or lease-purchase contract, including a statement of the principal amount and purpose of the lease or lease-purchase and the right to petition for an election, to be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{ at least ten days prior to the discussion meeting. No sooner than thirty days following the discussion meeting shall the board hold a meeting at which it is proposed to take action to enter into the lease or lease-purchase contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time before the end of the thirty-day period after which a meeting may be held to take action to enter into the lease or lease-purchase contract, a petition is filed with the auditor in the manner provided by }}}{{\f5\fs18\hyphpar0\qj{section 331.306}}}{{\f5\fs18\hyphpar0\qj{, asking that the question of entering into the lease or lease-purchase contract be submitted to the registered voters of the county, the board shall either by resolution declare the proposal to enter into the lease or lease-purchase contract to have been abandoned or shall direct the county commissioner of elections to call a special election upon the question of entering into the lease or lease-purchase contract. However, for purposes of this subparagraph (2), the petition shall not require signatures in excess of one thousand persons.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The question to be placed on the ballot shall be stated affirmatively in substantially the following manner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the county of }{{\f5\fs18\hyphpar0\qj{................}}}{ enter into a lease or lease-purchase contract in an amount of $ }{{\f5\fs18\hyphpar0\qj{................}}}{ for the purpose of }{{\f5\fs18\hyphpar0\qj{................}}}{?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of the election and its conduct shall be in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.442, subsections 2 through 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a petition is not filed or if a petition is filed and the proposition of entering into a lease or lease-purchase contract is approved at the election, the board may proceed and enter into the lease or lease-purchase contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body may authorize a lease or lease-purchase contract payable from the net revenues of a county enterprise or combined county enterprise by following the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 331.464}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lease or lease-purchase contract to which a county is a party or in which a county has a participatory interest is an obligation of a political subdivision of this state for the purposes of }}}{{\f5\fs18\hyphpar0\qj{chapters 502}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{636}}}{{\f5\fs18\hyphpar0\qj{, and is a lawful investment for banks, trust companies, savings associations, investment companies, insurance companies, insurance associations, executors, guardians, trustees, and any other fiduciaries responsible for the investment of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Property that is lease-purchased by a county is exempt under }}}{{\f5\fs18\hyphpar0\qj{section 427.1, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract for construction by a private party of property to be lease-purchased by a county is a contract for a public improvement and is subject to }}}{{\f5\fs18\hyphpar0\qj{section 331.341, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may enter into insurance agreements obligating the county to make payments beyond its current budget year to procure or provide for a policy of insurance, a self-insurance program, or a local government risk pool to protect the county against tort liability, loss of property, or any other risk associated with the operation of the county. Such a self-insurance program or local government risk pool is not insurance and is not subject to regulation under }}}{{\f5\fs18\hyphpar0\qj{chapters 505 through 523C}}}{{\f5\fs18\hyphpar0\qj{. However, those self-insurance plans regulated pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 509A.14}}}{{\f5\fs18\hyphpar0\qj{ shall remain subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 509A.14}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to that section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors may credit funds to a reserve for the purposes authorized by }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{; }}}{{\f5\fs18\hyphpar0\qj{section 331.424, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (5); and }}}{{\f5\fs18\hyphpar0\qj{section 331.441, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. Moneys credited to the reserve, and interest earned on such moneys, shall remain in the reserve until expended for purposes authorized by }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{; }}}{{\f5\fs18\hyphpar0\qj{section 331.424, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (5); or }}}{{\f5\fs18\hyphpar0\qj{section 331.441, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors may waive a tax penalty, interest, or costs related to the collection of a tax if the board finds that a clerical error resulted in the penalty, interest, or cost. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to bonded special assessments without the approval of the affected taxing jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county may establish a department of public works. The department shall be administered by the county engineer or other person appointed by the board of supervisors. In addition to other duties assigned by the board, the department shall provide technical assistance to political subdivisions in the county including special districts relating to their physical infrastructure and may provide managerial and administrative services for special districts and combined special districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may adopt and enforce an ordinance requiring the construction of a storm shelter at a manufactured home community or mobile home park which is constructed after July 1, 1999. In lieu of requiring construction of a storm shelter, a county may require a community or park owner to provide a plan for the evacuation of community or park residents to a safe place of shelter in times of severe weather including tornadoes and high winds if the county determines that a safe place of shelter is available within a reasonable distance of the manufactured home community or mobile home park for use by community or park residents. Each evacuation plan prepared pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be filed with, and approved by, the local emergency management agency. If construction of a storm shelter is required, an ordinance adopted or enforced pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not include any of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the size of the storm shelter be larger than the equivalent of seven square feet for each manufactured or mobile home space in the manufactured home community or mobile home park.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the storm shelter include a restroom if the shelter is used exclusively as a storm shelter.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the storm shelter exceed the construction specifications approved by a licensed professional engineer and presented by the owner of the manufactured home community or mobile home park.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the shelter be located any closer than one thousand three hundred twenty feet from any manufactured or mobile home in the manufactured home community or mobile home park.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufactured home community\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as land-leased community defined in }}}{{\f5\fs18\hyphpar0\qj{sections 335.30A}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{414.28A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufactured home community or mobile home park\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a manufactured home community or mobile home park as defined in }}}{{\f5\fs18\hyphpar0\qj{section 562B.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fStorm shelter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a single structure or multiple structures designed to provide persons with temporary protection from a storm.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors may by ordinance or resolution prohibit or limit the use of consumer fireworks or display fireworks, as described in }}}{{\f5\fs18\hyphpar0\qj{section 727.2}}}{{\f5\fs18\hyphpar0\qj{, on any day other than July 3, July 4, and December 31 in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 727.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, if the board determines that the use of such devices would constitute a threat to public safety or private property, or if the board determines that the use of such devices would constitute a nuisance to neighboring landowners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fshort-term rental property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any individually or collectively owned single-family house or dwelling unit; any unit or group of units in a condominium, cooperative, or timeshare; or an owner-occupied residential home that is offered for a fee for thirty days or less. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fShort-term rental property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a unit that is used for any retail, restaurant, banquet space, event center, or other similar use.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or enforce any regulation, restriction, or other ordinance, including a conditional use permit requirement, relating to short-term rental properties within the county. A short-term rental property shall be classified as a residential land use for zoning purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a county may enact or enforce an ordinance that regulates, prohibits, or otherwise limits short-term rental properties for the following primary purposes if enforcement is performed in the same manner as enforcement applicable to similar properties that are not short-term rental properties:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Protection of public health and safety related to fire and building safety, sanitation, or traffic control.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Residential use and zoning purposes related to noise, property maintenance, or nuisance issues.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Limitation or prohibition of use of property to house sex offenders; to manufacture, exhibit, distribute, or sell illegal drugs, liquor, pornography, or obscenity; or to operate an adult-oriented entertainment establishment as described in }}}{{\f5\fs18\hyphpar0\qj{section 239B.5, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide the county with an emergency contact for a short-term rental property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not require a license or permit fee for a short-term rental property in the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt, enforce, or otherwise administer an ordinance, motion, resolution, or amendment, or use any other means, to restrict, impede, regulate, or prohibit, intentionally or effectively, any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provision of natural gas service by a public utility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 476.1}}}{{\f5\fs18\hyphpar0\qj{, a competitive natural gas provider as defined in }}}{{\f5\fs18\hyphpar0\qj{section 476.86}}}{{\f5\fs18\hyphpar0\qj{, or a retail propane marketer or retail propane dispenser as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 101C.2}}}{{\f5\fs18\hyphpar0\qj{ to a person, business, municipality, or other wholesale or retail customer within or outside the county.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purchase of natural gas or propane from a competitive natural gas provider as defined in }}}{{\f5\fs18\hyphpar0\qj{section 476.86}}}{{\f5\fs18\hyphpar0\qj{ or a retail propane marketer or retail propane dispenser as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 101C.2}}}{{\f5\fs18\hyphpar0\qj{, or the receipt of natural gas or propane service from a public utility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 476.1}}}{{\f5\fs18\hyphpar0\qj{, by any person, business, municipality, or other wholesale or retail customer within or outside the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply to an ordinance, motion, resolution, or amendment that regulates a retail propane marketer or retail propane dispenser, as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 101C.2}}}{{\f5\fs18\hyphpar0\qj{, adopted before July 1, 2021.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt an ordinance, motion, resolution, or amendment, or use any other means, that requires the owner of real property to implement a policy relating to the use of facial coverings that is more stringent than a policy imposed by the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or enforce an ordinance, motion, resolution, or amendment imposing any requirement to obtain a permit or license, or to pay a fee, for an eligible business operated on an occasional basis for no more than eighty-nine calendar days in a calendar year by a person or persons under the age of eighteen. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3feligible business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an on-site transactional business traditionally operated exclusively by a person under the age of eighteen, including a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstand operated by a minor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as defined in }}}{{\f5\fs18\hyphpar0\qj{section 137F.1}}}{{\f5\fs18\hyphpar0\qj{, that a person under the age of eighteen is not otherwise prohibited by law from operating.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not require the payment of a penalty, fine, or fee due to a resident\u8217\'3fs noncompliance with rules adopted by the county sanitarian regarding periodic septic tank pumping as part of routine maintenance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fenergy benchmarking\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means requiring a decrease in the average energy use of a property or requiring the average energy use of a property to be less than the average energy use of a similarly situated property. A county shall not adopt or enforce an ordinance, motion, resolution, or amendment to require energy benchmarking requirements for a private property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless expressly authorized by state law, a county shall not adopt, enforce, or maintain an ordinance, order, or rule for the purpose of making payments to individuals under a guaranteed income program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general shall send a cease and desist order to any county that adopts or enforces an ordinance, order, or rule in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the county fails to comply with the cease and desist order, the attorney general shall bring an action in the name of the state for injunctive relief against any county that has adopted an ordinance, order, or rule in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fguaranteed income program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a program under which individuals are provided with regular periodic cash payments that are unearned and that may be used for any purpose, but does not include a program under which an individual is required to perform work or attend training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A guaranteed income program operating prior to or on May 1, 2024, may remain in effect until January 1, 2025, or until expiration of the program, whichever is earlier. A county shall not start a guaranteed income program or extend an existing guaranteed income program after May 1, 2024.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConstruction site\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as used in a storm water general permit adopted by rule pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455B.103A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTopsoil\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as used in a storm water general permit adopted by rule pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455B.103A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or enforce an ordinance, motion, resolution, or amendment relating to the preservation, compaction, placement, or depth of topsoil at a construction site that is more restrictive than those requirements provided in the national pollutant discharge elimination system general permit no. 2 as issued by the department of natural resources. A county may develop standards to evaluate topsoil quantities before and after construction and ensure compliance with general permit no. 2. A county may request that the department of natural resources review the soil of a construction site to verify that the national pollutant discharge elimination system general permit no. 2 as issued by the department of natural resources is proper for the construction site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may adopt or enforce an ordinance, motion, resolution, or amendment that regulates storm water runoff at a construction site only to the extent that such regulation for rainfall events having a return frequency ranging from five through one hundred years does not require a post-construction storm water flow rate that is more restrictive than the existing flow rate of a rainfall event having a return frequency of five years, with all such runoff rates based on the actual existing condition of the site at the time the construction commences.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may adopt or enforce an ordinance, motion, resolution, or amendment that regulates storm water runoff from upstream properties adjacent to a construction site to the extent that storm water runoff shall be allowed to pass through downstream storm water basins at the same flow rates as off-site storm water runoff entering the construction site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may impose a storm water runoff requirement that is more restrictive than what is allowed or required by this paragraph at the construction site if the county meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county pays for all study, design, and engineering costs for implementing the more restrictive storm water runoff requirement that includes an analysis by a licensed professional engineer of the difference in costs between the requirements of this paragraph and the more restrictive county storm water runoff requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county pays for the difference of costs between the requirements of this paragraph and the more restrictive requirement imposed by the county for installation of equipment or practices required for a property owner to comply with the storm water runoff requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the storm water runoff requirement results in the county using a person\u8217\'3fs private property, whether by easement or otherwise taking an interest in the property, the county pays the property owner the fair market value of the property taken for any additional land required beyond the requirements of this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not impose a special assessment or otherwise recover the costs from the property owner for the portion of the costs attributable to the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs attributable to the county shall only apply to the storm water management practices addressed in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt, enforce, or otherwise administer an ordinance, motion, resolution, or building code that prohibits or limits, either directly or indirectly, the use of a specific style of exterior cladding or finish materials for residential buildings in a manner that is more restrictive than the state building code as adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 103A.7}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a county from regulating the use of a specific style of exterior cladding or finish materials for a residential building that meets any of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The building is located in an area designated and declared as a state or local historic district under applicable law.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The building is designated as a local, state, or national historic landmark.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The building is in a common interest community as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 499C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The building is located on a property that is governed by a policy of regulation of an overlay or special purpose zoning district that is adopted pursuant to applicable law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fresidential building\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any single or multifamily residential dwelling and includes single-family and two-family dwellings and townhouses, condominiums and apartments with a maximum of twelve units per building, and all secondary structures to such a single or multifamily residential dwelling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or enforce an ordinance, motion, resolution, or amendment that imposes restrictions, qualifications, or requirements on developers, contractors, or subcontractors related to a developer\u8217\'3fs or contractor\u8217\'3fs employee compensation or training beyond what is expressly authorized by state law. A county shall not make receipt of any incentives, or the eligibility for such incentives, contingent upon compliance with any such restrictions, qualifications, or requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or continue in effect any regulation, including in the form of an ordinance or resolution, that governs fuel-powered equipment as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 214A, subchapter IV}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{29.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall allow a minimum of one accessory dwelling unit on the same lot as a single family residence in accordance with the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accessory dwelling unit shall comply with all applicable building regulations as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 103A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accessory dwelling unit shall not exceed one thousand square feet or fifty percent of the size of the single family residence, whichever is larger.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accessory dwelling unit shall be prohibited or limited only to the extent that a state historic building code restriction, as adopted by a county in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 103A.43, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a deed restriction, or a rule of a common interest community, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 499C.1}}}{{\f5\fs18\hyphpar0\qj{, limits or prohibits the construction or use of an accessory dwelling unit. The imposition of an ordinance, motion, resolution, or amendment regulating accessory dwelling units that is more restrictive when applied to a common interest community than when applied to a single family residence is prohibited.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a manufactured home as defined in }}}{{\f5\fs18\hyphpar0\qj{section 435.1, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or a mobile home as defined in }}}{{\f5\fs18\hyphpar0\qj{section 435.1, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, is used as an accessory dwelling unit, the manufactured home or mobile home shall be converted to real property by being placed on a permanent foundation and assessed for real estate taxes pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 435.26}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or by state law, a county shall not impose any of the following limitations or restrictions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requirements related to the placement or appearance of an accessory dwelling unit that are more restrictive than those imposed on a single family residence including but not limited to the following: maximum building heights; minimum setback requirements; minimum lot sizes; minimum building frontages; maximum lot coverages; density requirements; and aesthetic or architectural standards or requirements. Additionally, a county shall not require an accessory dwelling unit to match the exterior design, roof pitch, or finishing materials of the single family residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulations on the use of an accessory dwelling unit as a rental property that are more restrictive than those provided for in }}}{{\f5\fs18\hyphpar0\qj{subsection 18}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 562A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A requirement that the lot containing a single family residence and an accessory dwelling unit have additional parking beyond that required for a single family residence or payment of a fee in lieu of providing additional parking.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Restrictions on the occupancy of either the single family residence or the accessory dwelling unit by any of the following manners: requiring the property owner to be a resident; requiring a familial, marital, or employment relationship to exist between the occupants of the single family residence and the occupants of the accessory dwelling unit; or restricting the occupancy of an accessory dwelling unit based on income or age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement of new or separate utility lines between the accessory dwelling unit and public utility service connections. However, if full utility access that includes a separate metering system for billing purposes cannot be provided to the accessory dwelling unit, then the county can require new or separate utility lines.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Imposition of a different county impact fee structure or development standard for an accessory dwelling unit than those used for the single family residence on the same lot.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement of improvements or repairs to public streets or sidewalks beyond those imposed on the single family residence on the same lot.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall approve an accessory dwelling unit permit application that meets the requirements set forth in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and by state law without discretionary review or hearing and consistent with the time frame assigned to the approval of a single family residence. An accessory dwelling unit permit application shall not have a review timeline or schedule in excess of a county\u8217\'3fs normal review schedule for a single family residence. If the county denies an accessory dwelling unit permit, the reason for denial shall be provided in writing to the applicant and include any remedy necessary to secure approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county ordinance, motion, resolution, or amendment regulating accessory dwelling units in a manner that conflicts with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is void. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ prohibits a county from adopting an ordinance, motion, resolution, or amendment that is more permissive than the requirements provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of}}}{{\f5\fs18\hyphpar0\qj{ this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAccessory dwelling unit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an additional residential dwelling unit located on the same lot as a single family residence that is either attached to or detached from the single family residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDetached\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes being part of any accessory structure such as a detached garage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDwelling unit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 562A.6, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSingle family residence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 562A.6, subsection 15}}}{{\f5\fs18\hyphpar0\qj{, except to the extent that a single family residence may share utility lines with the accessory dwelling unit if full utility access that includes a separate metering system for billing purposes can be provided to the accessory dwelling unit.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a793; R60, \'a7221; C73, \'a7279; C97, \'a7394; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5128;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.1}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.301}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7300}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 156, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1211, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 101, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1138, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1204, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 206, \'a78, 12}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 186, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 143, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a79, 16}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1119, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 100, \'a78, 21}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7131, 132, 177}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 100, \'a713, 15}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 77, \'a733, 36}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 20, \'a71, 5}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 115, \'a76, 12}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1013, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1075, \'a710, 12, 13}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a771, 72, 74}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a71, 93}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a7147}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 44, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 139, \'a729, 31}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 179, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1024, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1153, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a7138, 154}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 147, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1003, \'a71, 7, 8}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1011, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a737, 47}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1109, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1174, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 6, \'a721, 23}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 26, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 38, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 81, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713.2}}}{{\f5\fs12\hyphpar0\qj{, 346.27}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See also Iowa Constitution, Art. III, \'a739A}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See Code editor\u8217\'3fs note on simple harmonization at the beginning of this Code volume}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 17 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsections 27 \u8211\'3f 29}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.302}}}{\*\bkmkstart stylerid1_2E7_2E3_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County legislation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall exercise a power or perform a duty only by the passage of a motion, a resolution, an amendment, or an ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a violation of an ordinance a county shall not provide a penalty in excess of the maximum fine and term of imprisonment for a simple misdemeanor under }}}{{\f5\fs18\hyphpar0\qj{section 903.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The crime services surcharge required by }}}{{\f5\fs18\hyphpar0\qj{section 911.1}}}{{\f5\fs18\hyphpar0\qj{ shall be added to a county fine and is not a part of the county\u8217\'3fs penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The subject matter of an ordinance or amendment shall be generally described in its title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An amendment to an ordinance or to a code of ordinances shall specifically repeal the ordinance or code, or the section, subsection, paragraph, or subpart to be amended, and shall set forth the ordinance, code, section, subsection, paragraph, or subpart as amended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county may by ordinance adopt by reference any portion of the Code of Iowa in effect at the time of the adoption in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 380.8}}}{{\f5\fs18\hyphpar0\qj{ for adoption of a proposed code of ordinances containing a proposed new ordinance or amendment, subject to the following limitations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ordinance shall describe the subject matter and identify the portion of the Code of Iowa adopted by chapter, section, and subsection or other subpart, as applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A portion of the Code of Iowa may be adopted by reference only if the criminal penalty provided by the law adopted does not exceed the maximum fine and term of imprisonment for a simple misdemeanor under }}}{{\f5\fs18\hyphpar0\qj{section 903.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amendments or other changes to those portions of the Code of Iowa which have been adopted by reference shall serve as an automatic modification of the applicable ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ordinance which adopts by reference any portion of the Code of Iowa may provide that violations of the ordinance are county infractions and subject to the limitations of }}}{{\f5\fs18\hyphpar0\qj{section 331.307}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proposed ordinance or amendment shall be considered and voted on for passage at two meetings of the board prior to the meeting at which it is to be finally passed, unless this requirement is suspended by a recorded vote of not less than a majority of the supervisors.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, if a summary of the proposed ordinance or amendment is published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{ prior to its first consideration and copies are available at the time of publication at the office of the auditor, the ordinance or amendment shall be considered and voted on for passage at one meeting prior to the meeting at which it is to be finally passed, unless this requirement is suspended by a recorded vote of not less than a majority of the supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Passage of an ordinance, amendment, or resolution requires an affirmative vote of not less than a majority of the supervisors. Each supervisor\u8217\'3fs vote on an ordinance, amendment, or resolution shall be recorded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resolution becomes effective upon passage and an ordinance or amendment becomes a law when a summary of the ordinance or the complete text of the ordinance is published, unless a subsequent effective date is provided within the measure. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsummary\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean a narrative description of the terms and conditions of an ordinance setting forth the main points of the ordinance in a manner calculated to inform the public in a clear and understandable manner the meaning of the ordinance and which shall provide the public with sufficient notice to conform to the desired conduct required by the ordinance. The description shall include the title of the ordinance, an accurate and intelligible abstract or synopsis of the essential elements of the ordinance, a statement that the description is a summary, the location and the normal business hours of the office where the ordinance may be inspected, when the ordinance becomes effective, and the full text of any provisions imposing fines, penalties, forfeitures, fees, or taxes. Legal descriptions of property set forth in ordinances shall be described in full, provided that maps or charts may be substituted for legal descriptions when they contain sufficient detail to clearly define the area with which the ordinance is concerned. The narrative description shall be written in a clear and coherent manner and shall, to the extent possible, avoid the use of technical or legal terms not generally familiar to the public. When necessary to use technical or legal terms not generally familiar to the public, the narrative description shall include definitions of those terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The auditor shall promptly record each measure, publish a summary of all ordinances or a complete text of the ordinances and amendments as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{, authenticate all measures except motions with signature and certification as to time and manner of publication, if any, and maintain for public use copies of all effective ordinances and codes. A copy of the complete text of an ordinance or amendment shall also be available for distribution to the public at the office of the county auditor. The auditor\u8217\'3fs certification is presumptive evidence of the facts stated therein.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At least once every five years, the board shall compile a code of ordinances containing all of the county ordinances in effect.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a proposed code of ordinances contains only existing ordinances edited and compiled without change in substance, the board may adopt the code by ordinance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a proposed code of ordinances contains a proposed new ordinance or amendment, the board shall hold a public hearing on the proposed code before adoption. The auditor shall publish notice of the hearing as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{. Copies of the proposed code of ordinances shall be available at the auditor\u8217\'3fs office and the notice shall so state. Within thirty days after the hearing, the board may adopt the proposed code of ordinances which becomes law upon publication of the ordinance adopting it. If the board substantially amends the proposed code of ordinances after a hearing, notice and hearing shall be repeated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ordinances and amendments which become effective after adoption of a code of ordinances may be compiled as a supplement to the code, and upon adoption of the supplement by resolution, become part of the code of ordinances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adopted code of ordinances is presumptive evidence of the passage, publication, and content of the ordinances therein as of the date of the auditor\u8217\'3fs certification of the ordinance adopting the code or supplement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The compensation paid to a newspaper for a publication required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not exceed the fee provided in }}}{{\f5\fs18\hyphpar0\qj{section 618.11}}}{{\f5\fs18\hyphpar0\qj{. The compensation paid to a newspaper for publication of the complete text of an ordinance shall not exceed three-fourths of the fee provided in }}}{{\f5\fs18\hyphpar0\qj{section 618.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may adopt the provisions of a statewide or nationally recognized standard code or portions of any such code by an ordinance which identifies the code by subject matter, source, and date, and incorporates the provisions either by reference or by setting them forth in full. The code or portion shall be adopted only after notice and hearing in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Immediately after the effective date of a measure establishing a zoning district, building lines, or fire limits, the auditor shall certify the measure and a plat showing the district, lines, or limits, to the recorder. The recorder shall record the measure and plat in the miscellaneous record or other book provided for special records, and shall index the record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A measure voted upon is not invalid because a supervisor has a conflict of interest, unless the vote of the supervisor was decisive to passage of the measure. If a majority or unanimous vote of the board is required by statute, the majority or vote shall be computed on the basis of the number of supervisors not disqualified by reason of conflict of interest. However, a majority of all supervisors is required for a quorum. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the statement of a supervisor that the supervisor declines to vote by reason of conflict of interest is conclusive and shall be entered of record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A valid measure adopted by a county prior to July 1, 1981, remains valid unless the measure is irreconcilable with a state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not provide a civil penalty in excess of seven hundred fifty dollars for the violation of an ordinance which is classified as a county infraction or if the infraction is a repeat offense, a civil penalty not to exceed one thousand dollars for each repeat offense. A county infraction is not punishable by imprisonment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C31, 35, \'a75903-c9; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5903.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7330.11}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.302(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7301}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a71349; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5587, 7180;}}}{ C46, \'a7361.7, 444.19; C50, 54, 58, \'a7358A.26, 361.7, 444.19; C62, 66, 71, 73, 75, \'a7332.30, 358A.26, 444.19; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.30}}}{, }{{\f5\fs18\hyphpar0\qj{332.51}}}{, }{{\f5\fs18\hyphpar0\qj{358A.26}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.302(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7301}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3 \u8211\'3f 5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.302(3 \u8211\'3f 5)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7301}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7329.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.302(6)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7301}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{7 \u8211\'3f 10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.302(7 \u8211\'3f 10)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7301}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7358A.25}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.302(11)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7301}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12 \u8211\'3f 14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.302(12 \u8211\'3f 14)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7301}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1202, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 145, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1098, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1144, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 153, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1111, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 21, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a72, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321P.2}}}{{\f5\fs12\hyphpar0\qj{, 331.251}}}{{\f5\fs12\hyphpar0\qj{, 331.304A}}}{{\f5\fs12\hyphpar0\qj{, 335.6}}}{{\f5\fs12\hyphpar0\qj{, 368.26}}}{{\f5\fs12\hyphpar0\qj{, 455B.146}}}{{\f5\fs12\hyphpar0\qj{, 455B.175}}}{{\f5\fs12\hyphpar0\qj{, 455B.192}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See also }{{\f5\fs12\hyphpar0\qj{Iowa Constitution, Art. III, \'a739A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.303}}}{\*\bkmkstart stylerid1_2E7_2E3_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General duties of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep record books as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fminute book\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ which records all orders and decisions other than those relating to drainage districts. The minute book or a separate index book must contain an alphabetical index by subject matter categories of the proceedings shown by the minutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwarrant book\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ which records each warrant drawn in the order of issuance by number, date, amount, and name of drawee, and refers to the order in the minute book authorizing its drawing. The board may authorize the auditor to issue checks in lieu of warrants. If the issuance of checks is authorized, the word \u8220\'3fcheck\u8221\'3f shall be substituted for the word \u8220\'3fwarrant\u8221\'3f in those sections of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapters 6B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{35B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{336}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{349}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{350}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{427B}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{468}}}{{\f5\fs18\hyphpar0\qj{ in which the issuance of a check is authorized in lieu of a warrant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fclaim register\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ which records all claims for money filed against the county. Claims shall be numbered consecutively in order of filing and entered alphabetically by the claimant\u8217\'3fs name. The claim register shall show the date of filing, the number of the claim and its general nature, and the action of the board on the claim including the fund against which it is allowed if it is allowed. The claims allowed at each meeting shall be listed in the minute book by claim number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintain its records in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Act upon applications for cigarette tax permits in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 453A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Act upon applications for retail alcohol licenses in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 123.32}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Select official newspapers and cause official publications to be made in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapters 349}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{618}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules relating to the labor of prisoners in the county jail in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 356.16 through 356.19}}}{{\f5\fs18\hyphpar0\qj{, and may establish the cost of board and provide for the transportation of certain prisoners in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 356.30}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Divide the county into townships, and proceed upon a petition to divide, dissolve or change the name of a township in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 359}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approve the written investment policy for the county required under }}}{{\f5\fs18\hyphpar0\qj{section 12B.10B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cause on-site inspections of pipeline construction projects as required in }}}{{\f5\fs18\hyphpar0\qj{section 479.29, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and the board may petition for rules as provided in that section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Defend, save harmless, and indemnify its officers, employees, and agents against tort claims, and may settle the claims, in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 670.8}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{670.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Perform other duties as required by law.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7318; C73, \'a7308; C97, \'a7442; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5122, 5123;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7331.19}}}{, }{{\f5\fs18\hyphpar0\qj{331.20}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.303}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7302}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a733}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710069, 10201}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1156, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 204, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 45, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1019, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7195}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a7100, 102}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.504}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.304}}}{\*\bkmkstart stylerid1_2E7_2E3_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Procedural limitations on general county powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a county proposes to exercise any of the following powers, it shall do so in accordance with the following limitations:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to act jointly with other political subdivisions or public or private agencies shall be exercised in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{28I}}}{{\f5\fs18\hyphpar0\qj{ or other applicable state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to adopt, administer, and enforce the state building code shall be exercised in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 103A}}}{{\f5\fs18\hyphpar0\qj{. The power to adopt by ordinance, administer, and enforce a county building code, is subject to the following restrictions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county building code shall not apply within the incorporated area of a city except at the option of the city, and shall not apply within a city\u8217\'3fs two-mile limit referred to in }}}{{\f5\fs18\hyphpar0\qj{section 414.23}}}{{\f5\fs18\hyphpar0\qj{, to the extent that the city has adopted a building code within the two-mile limit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county building code shall not apply to farm houses or other farm buildings which are primarily adapted for use for agricultural purposes, while so used or under construction for that use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not license elevator inspectors or regulate elevator conveyances except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 89A.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to adopt airport zoning regulations applicable to airport hazard areas shall be exercised in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 329}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to adopt county zoning regulations shall be exercised in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 335}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may file a petition with the city development board as provided in }}}{{\f5\fs18\hyphpar0\qj{section 368.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to take private property for public use shall only be exercised by counties for public purposes which are reasonable and necessary as an incident to the powers and duties conferred upon counties, and in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapters 6A}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{6B}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{Section 306.19}}}{{\f5\fs18\hyphpar0\qj{ is also applicable to condemnation of right-of-way for secondary roads. }}}{{\f5\fs18\hyphpar0\qj{Sections 306.27 through 306.37}}}{{\f5\fs18\hyphpar0\qj{ are applicable to the condemnation of right-of-way that is contiguous to existing road right-of-way and necessary for the maintenance, safety improvement, or upgrade of the existing secondary road.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, upon application, may grant permits for the use of display fireworks as provided in }}}{{\f5\fs18\hyphpar0\qj{section 727.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or enforce any ordinance imposing any registration or licensing system or registration or license fees for or relating to owner-occupied manufactured or mobile homes including the lots, lands, or manufactured home community or mobile home park upon or in which they are located. A county shall not adopt or enforce any ordinance imposing any registration or licensing system, or registration or license fees, or safety or sanitary standards for rental manufactured or mobile homes unless similar registration or licensing system, or registration or license fees, or safety or sanitary standards are required for other rental properties intended for human habitation. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not preclude the investigation and abatement of a nuisance or the enforcement of a tiedown system, or the enforcement of any rules of the department of health and human services or local board of health if those rules apply to other rental properties or to owner-occupied housing intended for human habitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or enforce any ordinance imposing any limitation on the amount of rent that can be charged for leasing private residential or commercial property. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prevent the right of a county to manage and control residential property in which the county has a property interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or enforce any ordinance or regulation in violation of }}}{{\f5\fs18\hyphpar0\qj{section 562A.27B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{562B.25B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt, enforce, or otherwise administer an ordinance, motion, resolution, or amendment providing for any terms or conditions of employment that exceed or conflict with the requirements of federal or state law relating to a minimum or living wage rate, any form of employment leave, hiring practices, employment benefits, scheduling practices, or other terms or conditions of employment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ordinance, motion, resolution, or amendment adopted prior to March 30, 2017, that violates }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is void and unenforceable on and after March 30, 2017.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or enforce an ordinance or regulation that prohibits an owner, lessor, sublessor, managing agent, or other person having the right to lease, sublease, or rent out a dwelling unit from refusing to lease or rent out the dwelling unit to a person because of the person\u8217\'3fs use of a federal housing choice voucher issued by the United States department of housing and urban development. Such an ordinance or regulation in effect on January 1, 2021, is void and unenforceable on and after January 1, 2023. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdwelling unit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 562A.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1, 2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.304(1, 2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7303}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C50, 54, 58, 62, \'a7358A.3; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.3(22)}}}{, }{{\f5\fs18\hyphpar0\qj{358A.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.304(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7303}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4 \u8211\'3f 7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.304(4 \u8211\'3f 7)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7303}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[S13, \'a71644-a, -e, 2024-f; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7806;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7471.4}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.304(8)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7303}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.304(9)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7303}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71116}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 171, \'a733, 42}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1083, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 16, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 99, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1120, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 20, \'a72, 5}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 115, \'a77, 12}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 49, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71082}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7424}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.304A}}}{\*\bkmkstart stylerid1_2E7_2E3_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations on county legislation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAerobic structure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fanimal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fanimal feeding operation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fanimal feeding operation structure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmanure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 459.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty legislation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any ordinance, motion, resolution, or amendment adopted by a county pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.302}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not adopt or enforce county legislation regulating a condition or activity occurring on land used for the production, care, feeding, or housing of animals unless the regulation of the production, care, feeding, or housing of animals is expressly authorized by state law. County legislation adopted in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is void and unenforceable and any enforcement activity conducted in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is void. A condition or activity occurring on land used for the production, care, feeding, or housing of animals includes but is not limited to the construction, operation, or management of an animal feeding operation, an animal feeding operation structure, or aerobic structure, and to the storage, handling, or application of manure or egg washwater.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1209, \'a79, 53}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.305}}}{\*\bkmkstart stylerid1_2E7_2E3_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Publication of notices \u8212\'3f electronic delivery authorization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided by state law, if notice of an election, hearing, or other official action is required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the board shall publish the notice at least once, not less than four nor more than twenty days before the date of the election, hearing, or other action, in one or more newspapers which meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 618.14}}}{{\f5\fs18\hyphpar0\qj{. Notice of an election shall also comply with }}}{{\f5\fs18\hyphpar0\qj{section 49.53}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board is required or authorized by law to publish a notice or any other information regarding the county budget or a county property tax levy, the county shall also provide the notice or information by electronic means to all persons who have by electronic or other means authorized the receipt of such items under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorization to receive notices or other information by electronic means under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall continue until revoked in writing by the person. Such revocation may be provided to the board electronically in a manner approved by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Electronic means includes delivery to an electronic mail address or by other electronic means reasonably calculated to apprise the person of the information that is being provided, as designated by the authorizing person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information compiled or possessed by the board for the purposes of complying with authorizations for delivery by electronic means including but not limited to taxpayer electronic mail addresses, post office addresses, revocations, and passwords or other methods of protecting taxpayer information are not public records and are not subject to disclosure under }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7312(23); C73, \'a7303(24); C97, \'a7423; SS15, \'a7423; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5261;}}}{ C46, 50, 54, 58, \'a7330.18, 345.1; C62, 66, \'a7111A.6, 330.18, 345.1; C71, \'a7111A.6, 313A.35, 330.18, 345.1; C73, \'a7111A.6, 313A.35, 330.18, 345.1, 361.5; C75, 77, 79, \'a7111A.6, 313A.35, 330.18, 332.3(13), 345.1, 361.5; }{{\f5\fs18\hyphpar0\qj{C81, \'a7111A.6}}}{, }{{\f5\fs18\hyphpar0\qj{313A.35}}}{, }{{\f5\fs18\hyphpar0\qj{330.18}}}{, }{{\f5\fs18\hyphpar0\qj{332.3(13)}}}{, }{{\f5\fs18\hyphpar0\qj{345.1}}}{, }{{\f5\fs18\hyphpar0\qj{361.5}}}{, }{{\f5\fs18\hyphpar0\qj{444.9(2)}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.305}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7304}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 132, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a76B.11}}}{{\f5\fs12\hyphpar0\qj{, 28J.21}}}{{\f5\fs12\hyphpar0\qj{, 69.14A}}}{{\f5\fs12\hyphpar0\qj{, 137.104}}}{{\f5\fs12\hyphpar0\qj{, 306.30}}}{{\f5\fs12\hyphpar0\qj{, 309.65}}}{{\f5\fs12\hyphpar0\qj{, 311.12}}}{{\f5\fs12\hyphpar0\qj{, 330.18}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 331.302}}}{{\f5\fs12\hyphpar0\qj{, 331.361}}}{{\f5\fs12\hyphpar0\qj{, 331.402}}}{{\f5\fs12\hyphpar0\qj{, 331.425}}}{{\f5\fs12\hyphpar0\qj{, 331.442}}}{{\f5\fs12\hyphpar0\qj{, 331.443}}}{{\f5\fs12\hyphpar0\qj{, 331.447}}}{{\f5\fs12\hyphpar0\qj{, 331.464}}}{{\f5\fs12\hyphpar0\qj{, 331.471}}}{{\f5\fs12\hyphpar0\qj{, 331.479}}}{{\f5\fs12\hyphpar0\qj{, 335.5}}}{{\f5\fs12\hyphpar0\qj{, 335.6}}}{{\f5\fs12\hyphpar0\qj{, 336.13}}}{{\f5\fs12\hyphpar0\qj{, 336.16}}}{{\f5\fs12\hyphpar0\qj{, 350.5}}}{{\f5\fs12\hyphpar0\qj{, 357.4}}}{{\f5\fs12\hyphpar0\qj{, 357C.3}}}{{\f5\fs12\hyphpar0\qj{, 357E.4}}}{{\f5\fs12\hyphpar0\qj{, 357H.3}}}{{\f5\fs12\hyphpar0\qj{, 357H.10}}}{{\f5\fs12\hyphpar0\qj{, 358.4}}}{{\f5\fs12\hyphpar0\qj{, 358.6}}}{{\f5\fs12\hyphpar0\qj{, 358.27}}}{{\f5\fs12\hyphpar0\qj{, 358.29}}}{{\f5\fs12\hyphpar0\qj{, 358.30A}}}{{\f5\fs12\hyphpar0\qj{, 358.33}}}{{\f5\fs12\hyphpar0\qj{, 358C.5}}}{{\f5\fs12\hyphpar0\qj{, 358C.7}}}{{\f5\fs12\hyphpar0\qj{, 358C.18}}}{{\f5\fs12\hyphpar0\qj{, 358C.21}}}{{\f5\fs12\hyphpar0\qj{, 358C.22}}}{{\f5\fs12\hyphpar0\qj{, 359.7}}}{{\f5\fs12\hyphpar0\qj{, 404.2}}}{{\f5\fs12\hyphpar0\qj{, 404B.2}}}{{\f5\fs12\hyphpar0\qj{, 404B.3}}}{{\f5\fs12\hyphpar0\qj{, 427B.26}}}{{\f5\fs12\hyphpar0\qj{, 461A.31A}}}{{\f5\fs12\hyphpar0\qj{, 468.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.306}}}{\*\bkmkstart stylerid1_2E7_2E3_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petitions of eligible electors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a petition of the voters is authorized by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the petition is valid if signed by eligible electors of the county equal in number to at least ten percent of the votes cast in the county for the office of president of the United States or governor at the preceding general election, unless otherwise provided by state law. The petition shall include the signatures of the petitioners, a statement of their place of residence, and the date on which they signed the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Petitions authorized by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be filed with the board of supervisors not later than eighty-two days before the date of the general election if the question is to be voted upon at the general election. If the petition is found to be valid, the board of supervisors shall, not later than sixty-nine days before the general election, notify the county commissioner of elections to submit the question to the registered voters at the general election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A petition shall be examined before it is accepted for filing. If it appears valid on its face it shall be accepted for filing. If it lacks the required number of signatures it shall be returned to the petitioners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Petitions which have been accepted for filing are valid unless written objections are filed. Objections must be filed with the county auditor within five working days after the petition was filed. The objection process in }}}{{\f5\fs18\hyphpar0\qj{section 44.7}}}{{\f5\fs18\hyphpar0\qj{ shall be followed for objections filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7299; C97, \'a7410; SS15, \'a7410; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5107, 5108;}}}{ C46, 50, 54, \'a7330.17, 331.2; C58, 62, 66, \'a7111A.2, 330.17, 331.2; C71, 73, 75, 77, 79, \'a7111A.2, 330.17, 331.2, 331.9; }{{\f5\fs18\hyphpar0\qj{C81, \'a7111A.2}}}{, }{{\f5\fs18\hyphpar0\qj{174.10}}}{, }{{\f5\fs18\hyphpar0\qj{330.17}}}{, }{{\f5\fs18\hyphpar0\qj{331.2}}}{, }{{\f5\fs18\hyphpar0\qj{331.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.306}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7305}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 136, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1180, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a7121}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a769.14A}}}{{\f5\fs12\hyphpar0\qj{, 99F.7}}}{{\f5\fs12\hyphpar0\qj{, 330.17}}}{{\f5\fs12\hyphpar0\qj{, 331.203}}}{{\f5\fs12\hyphpar0\qj{, 331.204}}}{{\f5\fs12\hyphpar0\qj{, 331.207}}}{{\f5\fs12\hyphpar0\qj{, 331.247}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 331.402}}}{{\f5\fs12\hyphpar0\qj{, 331.441}}}{{\f5\fs12\hyphpar0\qj{, 331.442}}}{{\f5\fs12\hyphpar0\qj{, 331.471}}}{{\f5\fs12\hyphpar0\qj{, 350.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.307}}}{\*\bkmkstart stylerid1_2E7_2E3_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County infractions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county infraction is a civil offense punishable by a civil penalty of not more than seven hundred fifty dollars for each violation or if the infraction is a repeat offense a civil penalty not to exceed one thousand dollars for each repeat offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county by ordinance may provide that a violation of an ordinance is a county infraction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county shall not provide that a violation of an ordinance is a county infraction if the violation is a felony, an aggravated misdemeanor, or a serious misdemeanor under state law or if the violation is a simple misdemeanor under }}}{{\f5\fs18\hyphpar0\qj{chapters 687 through 747}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer authorized by a county to enforce a county code or regulation may issue a civil citation to a person who commits a county infraction. The citation may be served by personal service as provided in }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.305}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, by certified mail addressed to the defendant at the defendant\u8217\'3fs last known mailing address, return receipt requested, or by publication in the manner as provided in }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.310}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{ and subject to the conditions of }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.311}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. A copy of the citation shall be retained by the issuing officer, and one copy shall be sent to the clerk of the district court. The citation shall serve as notification that a civil offense has been committed and shall contain the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and address of the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name or description of the infraction attested to by the officer issuing the citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location and time of the infraction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of civil penalty to be assessed or the alternate relief sought, or both.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manner, location, and time in which the penalty may be paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The time and place of court appearance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The penalty for failure to appear in court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In proceedings before the court for a county infraction:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The matter shall be tried before a magistrate or district associate judge in the same manner as a small claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county has the burden of proof that the county infraction occurred and that the defendant committed the infraction. The proof shall be by clear, satisfactory, and convincing evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall ensure that the defendant has received a copy of the charges and that the defendant understands the charges. The defendant may question all witnesses who appear for the county and produce evidence or witnesses on the defendant\u8217\'3fs behalf.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant may be represented by counsel of the defendant\u8217\'3fs own selection and at the defendant\u8217\'3fs own expense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant may answer by admitting or denying the infraction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a county infraction is proven, the court shall enter judgment against the defendant. If the infraction is not proven, the court shall dismiss it.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 602.8106, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, penalties or forfeitures collected by the court for county infractions shall be remitted to the county in the same manner as fines and forfeitures are remitted to cities for criminal violations under }}}{{\f5\fs18\hyphpar0\qj{section 602.8106}}}{{\f5\fs18\hyphpar0\qj{. If the person named in the citation is served as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and fails without good cause to appear in response to the civil citation, judgment shall be entered against the person cited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person against whom judgment is entered, shall pay court costs and fees as in small claims under }}}{{\f5\fs18\hyphpar0\qj{chapter 631}}}{{\f5\fs18\hyphpar0\qj{. If the action is dismissed, the county is liable for the court costs and court fees. Where the action is disposed of without payment, or provision for assessment, of court costs, the clerk shall at once enter judgment for costs against the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seeking a civil penalty as authorized in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not preclude a county from seeking alternative relief from the court in the same action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When judgment has been entered against a defendant, the court may do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Impose a civil penalty by entry of a personal judgment against the defendant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Direct that payment of the civil penalty be suspended or deferred under conditions imposed by the court.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Grant appropriate alternative relief ordering the defendant to abate or cease the violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorize the county to abate or correct the violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Order that the county\u8217\'3fs costs for abatement or correction of the violation be entered as a personal judgment against the defendant or assessed against the property where the violation occurred, or both.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a defendant willfully violates the terms of an order imposed by the court, the failure is contempt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The magistrate or district associate judge shall have jurisdiction to assess or enter judgment for costs of abatement or correction in an amount not to exceed the jurisdictional amount for a money judgment in a civil action pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 631.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, for magistrates and }}}{{\f5\fs18\hyphpar0\qj{section 602.6306, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for district associate judges. If the county seeks abatement or correction costs in excess of those amounts, the case shall be referred to the district court for hearing and entry of an appropriate order. The procedure for hearing in the district court shall be the same procedure as that for a small claims appeal pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 631.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant or the county may file a motion for a new trial or may appeal the decision of the magistrate or district associate judge to the district court. The procedure on appeal shall be the same as for a small claim pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 631.13}}}{{\f5\fs18\hyphpar0\qj{. A factual determination made by the trial court, supported by substantial evidence as shown in the record, is binding for purposes of appeal relating to the violation at issue, but shall not be admissible or binding as to any future violation for the same or similar ordinance provision by the same defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not preclude a peace officer of a county from issuing a criminal citation for a violation of a county code or regulation if criminal penalties are also provided for the violation. Each day that a violation occurs or is permitted by the defendant to exist, constitutes a separate offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance of a civil citation for a county infraction or the ensuing court proceedings do not provide an action for false arrest, false imprisonment, or malicious prosecution.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1202, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 99, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 150, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1144, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7133}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7137.117}}}{{\f5\fs12\hyphpar0\qj{, 331.302}}}{{\f5\fs12\hyphpar0\qj{, 455B.146}}}{{\f5\fs12\hyphpar0\qj{, 455B.175}}}{{\f5\fs12\hyphpar0\qj{, 455B.192}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.308}}}{\*\bkmkstart stylerid1_2E7_2E3_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Neglected animals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A county may rescue, provide maintenance, or dispose of neglected livestock or another animal, as provided in }{{\f5\fs18\hyphpar0\qj{chapters 717}}}{ and }{{\f5\fs18\hyphpar0\qj{717B}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain