\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A registration fee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 462A.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A writing fee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 462A.53}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A transfer and writing fee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 462A.44}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For issuance of hunting, fishing, and fur harvester licenses:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fees specified in rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The writing fee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 483A.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state migratory game bird fee as provided in rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 483A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the issuance of snowmobile registrations and nonresident user permits, the fees specified in }}}{{\f5\fs18\hyphpar0\qj{sections 321G.4}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321G.4B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the issuance of all-terrain vehicle registrations and user permits, the fees specified in }}}{{\f5\fs18\hyphpar0\qj{sections 321I.4}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321I.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county fee of four dollars for a certified copy of a birth record, death record, or marriage certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For filing an application for the license to marry, thirty-five dollars, which includes payment for one certified copy of the original certificate of marriage, to be issued following filing of the original certificate of marriage, four dollars of which shall be retained by the county pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. For issuing an application for an order of the district court authorizing the validation of a license to marry before the expiration of three days from the date of issuance of the license, five dollars. The district court shall authorize the early validation of a marriage license without the payment of any fees imposed in this paragraph upon showing that the applicant is unable to pay the fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other fees as provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, the county shall not be required to pay the fees required in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.605}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7604}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 159, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1005, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 124, \'a711, 26}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1034, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1020, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1199, \'a73, 4, 27}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 96, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 141, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1140, \'a743, 49}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1132, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1030, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7137}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1159, \'a712, 13, 28}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1093, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7144.36}}}{{\f5\fs12\hyphpar0\qj{, 144.46}}}{{\f5\fs12\hyphpar0\qj{, 232.2}}}{{\f5\fs12\hyphpar0\qj{, 331.604}}}{{\f5\fs12\hyphpar0\qj{, 331.610}}}{{\f5\fs12\hyphpar0\qj{, 501B.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.605A}}}{\*\bkmkstart stylerid1_2E9_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Document management fee.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0027.pdf" }{\fldrslt \cf5 \f5 \fs18{{2009 Acts, ch 27, \'a739}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.605B}}}{\*\bkmkstart stylerid1_2E9_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees collected \u8212\'3f audit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder shall make available any information required by the county or state auditor concerning the fees collected under }}}{{\f5\fs18\hyphpar0\qj{section 331.604, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for the purposes of determining the amount of fees collected and the uses for which such fees are expended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A recorder or the governing board of the county land record information system shall collect only statutorily authorized fees for land records management. The governing board of the county land record information system shall not collect a fee for viewing, accessing, or printing documents in the county land record information system unless specifically authorized by statute. The governing board of the county land record information system may collect a fee of not more than three dollars per recorded document for using the system to process electronic documents for recording. An additional service charge may be added for credit or debit card payments. Fees collected for the processing of electronic documents for recording may be used for the purposes specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.604}}}{{\f5\fs18\hyphpar0\qj{ and for the purposes of development, operation, and maintenance of the county land record information system and internet sites, systems for electronic filing for recording, associated payment systems, security systems, the land records databases, methods for searching the databases, processes for the redaction of personally identifiable information posted for public online access, and processes for the integration of land records information with other property information systems.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 151, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1158, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 27, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 159, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 164, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.605C}}}{\*\bkmkstart stylerid1_2E9_2E5_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Electronic transaction fee \u8212\'3f audit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0027.pdf" }{\fldrslt \cf5 \f5 \fs18{{2009 Acts, ch 27, \'a739}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.606}}}{\*\bkmkstart stylerid1_2E9_2E5_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General filing requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to other requirements specified by law, the recorder shall note in the county system the date of filing of each instrument, the number and character of the instrument, and the name of each grantor and grantee named in the instrument. In numbering the instruments, the recorder may start with the number one immediately following the date of annual settlement with the board and continue to number them consecutively until the next annual settlement with the board or the recorder may start with number one on the first working day of the calendar year and continue to number the instruments consecutively until the last working day of the calendar year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder shall also note in the index the exact time of the filing of each instrument.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county recorder may give the county sheriff the records filed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ pertaining to the sale and registration of weapons or may dispose of those records if the sheriff does not wish to receive the records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder shall permanently archive an unaltered version of each recorded document or instrument. A document or instrument may be archived in its original format, as an electronic document, or in another format suitable for preserving information in the document or instrument. A person may view and copy an original or unaltered document or instrument in the office of the recorder.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7498; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5178, 5246;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7335.15}}}{, }{{\f5\fs18\hyphpar0\qj{342.23}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.606}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7605}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1021, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1015, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 44, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 179, \'a7130}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 159, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7179}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.606A}}}{\*\bkmkstart stylerid1_2E9_2E5_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Document content \u8212\'3f personally identifiable information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E9_2E5_2E12_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E12_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonally identifiable information\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one or more of the following specific unique identifiers when combined with an individual\u8217\'3fs name:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Social security number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Checking, savings, or share account number, credit, debit, or charge card number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPreparer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the person or entity who creates, drafts, edits, revises, or last changes the documents that are recorded with the recorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRedact\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fredaction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the process of permanently removing all or a portion of personally identifiable information from documents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E9_2E5_2E12_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E12_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Inclusion of personally identifiable information.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The preparer of a document shall not include an individual\u8217\'3fs personally identifiable information in a document that is prepared and presented for recording in the office of the recorder. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to documents that were executed by an individual prior to July 1, 2007.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E9_2E5_2E12_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E12_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Redaction from electronic documents.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personally identifiable information that is contained in electronic documents that are displayed for public access on an internet site, or which are transferred to any person, shall be redacted prior to displaying or transferring the documents. Each recorder that displays electronic documents and the county land record information system that displays electronic documents on behalf of a county shall implement a system for redacting personally identifiable information. The recorder and the governing board of the county land record information system shall establish a procedure by which individuals may request that personally identifiable information contained in an electronic document displayed on an internet site be redacted, at no fee to the requesting individual. The requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be fully implemented not later than December 31, 2011.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E9_2E5_2E12_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E12_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Dissemination of documents.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons who have contracted with a county recorder or the governing board of the county land record information system to redact personally identifiable information from electronic documents pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall not sell, transfer, or otherwise disseminate the electronic documents in an unaltered or redacted form, except as provided for in the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E9_2E5_2E12_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E12_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Liability of preparer.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A preparer who, in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, enters personally identifiable information in a document that is prepared and presented for recording is liable to the individual whose personally identifiable information appears in the recorded public document for actual damages of up to five hundred dollars for each act of recording.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E9_2E5_2E12_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E12_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Applicability.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a preparer of a state or federal tax lien or release, a military separation or discharge record, or a death certificate that is prepared for recording in the office of county recorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a military separation or discharge record, a birth record, a death certificate, or marriage certificate unless such record or certificate is incorporated within another document or instrument that is recorded and displayed for public access on an internet site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a military separation or discharge record or a death certificate is recorded in the office of the county recorder, the military separation or discharge record or the death certificate shall not be displayed for public access on an internet site, public access terminal or other medium, or be transferred to any person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E9_2E5_2E12_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E12_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Limitation of liability.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county land record information system is a unit of local government for purposes of }}}{{\f5\fs18\hyphpar0\qj{chapter 670}}}{{\f5\fs18\hyphpar0\qj{, relating to tort liability of governmental subdivisions. However, persons who have contracted with the governing board of the county land record information system to carry out the duties of the board are not employees for purposes of }}}{{\f5\fs18\hyphpar0\qj{chapter 670}}}{{\f5\fs18\hyphpar0\qj{, relating to tort liability of governmental subdivisions.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1113, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 123, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 159, \'a76 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a791, 92, 257}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.606B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.606B}}}{\*\bkmkstart stylerid1_2E9_2E5_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Document or document formatting standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{, the county recorder shall refuse any document or instrument presented for recording that does not meet the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each document or instrument shall consist of one or more individual pages not permanently bound or in a continuous form. The document or instrument shall not have any attachment stapled or otherwise affixed to any page except as necessary to comply with statutory requirements. However, the individual pages of a document or instrument may be stapled together for presentation for recording. A label that is firmly attached with a bar code or return address may be accepted for recording.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All preprinted text shall be at least eight point in size and no more than twenty characters and spaces per inch. All other text typed or computer generated, including but not limited to all names of parties to an agreement, shall be at least ten point in size and no more than sixteen characters and spaces per inch. If a document or instrument, other than a plat or survey or a drawing related to a plat or survey, presented for recording contains type smaller than eight point type for the preprinted text and ten point type for all other text, the document or instrument shall be accompanied by an exact typewritten or printed copy that meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each document shall be of sufficient legibility to produce a clear reproduction. If a document or instrument, other than a plat or survey or a drawing related to a plat or survey, is not sufficiently legible to produce a clear reproduction, the document or instrument shall be accompanied by an exact typewritten or printed copy that meets the type size requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and shall be recorded contemporaneously as additional pages of the document or instrument.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each document or instrument, other than a plat or survey or a drawing related to a plat or survey, shall be on white paper of not less than twenty-pound weight without watermarks or other visible inclusions. All text within the document or instrument shall be of sufficient color and clarity to ensure that the text is readable when reproduced from the record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All signatures on a document or instrument shall be in black or dark blue ink and of sufficient color and clarity to ensure that the signatures are readable when the document or instrument is reproduced from the record. The corresponding name shall be typed, printed, or stamped beneath the original signature. The typing or printing of a name or the application of an embossed or inked stamp shall not cover or otherwise materially interfere with any part of the document or instrument except where provided by law. Failure to print or type signatures as provided in this paragraph does not invalidate the document or instrument.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The first page of each document or instrument, other than a plat or survey or a drawing related to a plat or survey, shall have a top margin of at least three inches of vertical space from left to right which shall be reserved for the recorder\u8217\'3fs use. All other margins on the document or instrument shall be a minimum of three-fourths of one inch. Nonessential information including but not limited to form numbers, page numbers, or customer notations may be placed in a margin except the top margin. The recorder shall not incur any liability for not showing a seal or information that extends beyond the margin of the permanent archival record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each document or instrument presented for recording shall meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 331.606A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each document or instrument, other than a plat or survey or a drawing related to a plat or survey, that is presented for recording shall contain the following information on the first page below the three-inch margin:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name, address, and telephone number of the individual who prepared the document.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any instrument of conveyance, the name of the taxpayer and a complete mailing address.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A return address.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The title of the document or instrument.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All grantors\u8217\'3f names.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All grantees\u8217\'3f names.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any address required by statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legal description of the property and parcel identification number, if required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A document or instrument number for statutory requirements, if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If insufficient space exists on the first page for all of the information described in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the page reference of the document or instrument where the information is located shall be noted on the first page.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each document or certificate prepared by a licensed professional land surveyor and presented for recording, including a plat of survey or a drawing related to a plat of survey, shall contain an index legend. However, this requirement shall not apply to a United States public land survey corner certificate described in }}}{{\f5\fs18\hyphpar0\qj{section 355.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each document or certificate prepared by a licensed professional land surveyor and presented for recording, including a plat of survey or a drawing related to a plat of survey, shall include a blank rectangular space three and three-fourth inches in width and two and one-half inches in height reserved and delineated for the county recorder\u8217\'3fs use, unless the document is attached to a cover sheet approved by the governing board of the county land record information system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder may record the following documents or instruments which are exempt from the format requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A document or instrument that was signed before July 1, 2005.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A military separation document or instrument.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A document or instrument executed outside the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified copy of a document or instrument issued by a governmental agency, including a vital record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A document or instrument where one of the original parties is deceased or otherwise incapacitated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A document or instrument formatted to meet court requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A federal tax lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A filing under the uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A groundwater hazard statement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 558.69}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A document or instrument rejected for recording by a recorder shall be returned to the preparer or presenter accompanied by an explanation of the reason for rejection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On and after July 1, 2005, a document or instrument that does not conform to the format standards specified in }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 3}}}{{\f5\fs18\hyphpar0\qj{ shall not be accepted for recording except upon payment of an additional recording fee of ten dollars per document or instrument. The requirement applies only to documents or instruments dated on or after July 1, 2005, and does not apply to those documents or instruments specifically exempted in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On and after July 1, 2009, a document or instrument that does not conform to the format standards specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not be accepted for recording. This paragraph applies only to documents or instruments dated on or after July 1, 2009, and does not apply to those documents or instruments specifically exempted in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1069, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7372}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1031, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 27, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 159, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1064, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1093, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\q