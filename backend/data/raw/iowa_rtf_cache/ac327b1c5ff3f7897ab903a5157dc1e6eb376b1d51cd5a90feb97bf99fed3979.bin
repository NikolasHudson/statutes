fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.424A}}}{\*\bkmkstart stylerid1_2E8_2E4_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County mental health and disabilities services fund.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by its own terms; }}}{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 177, \'a799}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.424B}}}{\*\bkmkstart stylerid1_2E8_2E4_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cemetery levy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board may levy annually a tax not to exceed six and three-fourths cents per thousand dollars of the assessed value of all taxable property in the county to repair and maintain all cemeteries under the jurisdiction of the board including pioneer cemeteries and to pay other expenses of the board or the cemetery commission as provided in }{{\f5\fs18\hyphpar0\qj{section 331.325}}}{. The proceeds of the tax levy shall be credited to the county general fund.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1182, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1119, \'a7158}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.422}}}{{\f5\fs12\hyphpar0\qj{, 331.434}}}{{\f5\fs12\hyphpar0\qj{, 331.435}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.424C}}}{\*\bkmkstart stylerid1_2E8_2E4_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Emergency services fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A county that is providing fire protection service or emergency medical service to a township pursuant to }{{\f5\fs18\hyphpar0\qj{section 331.385}}}{ shall establish an emergency services fund and may certify taxes for levy in the township not to exceed the amounts authorized in }{{\f5\fs18\hyphpar0\qj{section 359.43}}}{. The county has the authority to use a portion of the taxes levied and deposited in the fund for the purpose of accumulating moneys to carry out the purposes of }{{\f5\fs18\hyphpar0\qj{section 359.43, subsection 4}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1117, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 44, \'a763}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1146, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 74, \'a72, 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.385}}}{{\f5\fs12\hyphpar0\qj{, 331.421}}}{{\f5\fs12\hyphpar0\qj{, 331.422}}}{{\f5\fs12\hyphpar0\qj{, 331.434}}}{{\f5\fs12\hyphpar0\qj{, 331.435}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.425}}}{\*\bkmkstart stylerid1_2E8_2E4_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additions to levies \u8212\'3f special levy election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board may certify an addition to a levy in excess of the amounts otherwise permitted under }{{\f5\fs18\hyphpar0\qj{sections 331.423}}}{ and }{{\f5\fs18\hyphpar0\qj{331.424}}}{ if the proposition to certify an addition to a levy has been submitted at a special levy election and received a favorable majority of the votes cast on the proposition. A special levy election is subject to the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The election shall be held only if the board gives notice to the county commissioner of elections, not later than February 15, that the election is to be held.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The election shall be held on the first Tuesday in March and be conducted by the county commissioner of elections in accordance with the law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proposition to be submitted shall be substantially in the following form:}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{Vote for only one of the following:}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the county of }{{\f5\fs18\hyphpar0\qj{................................}}}{ levy an additional tax at a rate of $}{{\f5\fs18\hyphpar0\qj{............}}}{ each year for }{{\f5\fs18\hyphpar0\qj{............}}}{ years beginning next July 1 in excess of the statutory limits otherwise applicable for the (general county services or rural county services) fund?}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri1084\li1084{\f5\fs18\hyphpar0\qc}{or}{\f5\fs18\hyphpar0\qc}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county of }{{\f5\fs18\hyphpar0\qj{................................}}}{ shall continue the (general county services or rural county services fund) under the maximum rate of $}{{\f5\fs18\hyphpar0\qj{............}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The canvass shall be held on the second day that is not a holiday following the special levy election, and shall begin no earlier than 1:00 p.m. on that day.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of the proposed special levy election shall be published at least twice in a newspaper as specified in }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{ prior to the date of the special levy election. The first notice shall appear as early as practicable after the board has decided to seek a special levy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the addition to a levy approved under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is due to unusual circumstances resulting from the following, the duration of such approval at election shall not exceed the following period of years:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unusual problems relating to major new functions required by state law, three years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unusual need for a new program which will provide substantial benefit to county residents, if the county establishes the need and the amount of necessary increased cost, one year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an election to approve an addition to a levy for a reason specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or as the result of a natural disaster, the ballot shall include a statement of the major reasons for the difference between the proposed basic tax rate and the maximum basic tax rate, including a description of the major new functions required by state law and the specific new costs to the county to implement the new functions, a description of the new program that will provide substantial benefits to county residents and specific new costs to the county for the program, or the conditions and damage resulting from the natural disaster that the county must remedy.}}}\par}{}{}{\pard\plain\f5\fs18\h