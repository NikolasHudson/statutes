Acts, ch 45, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 24, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7252}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1092, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 167, \'a755, 66}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a715, 16, 31}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1018, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1118, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1110, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1141, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1098, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1102, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7207}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 147, \'a749, 54}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72510}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7119, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7176A.12}}}{{\f5\fs12\hyphpar0\qj{, 260C.17}}}{{\f5\fs12\hyphpar0\qj{, 260C.22}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 347.12}}}{{\f5\fs12\hyphpar0\qj{, 347A.1}}}{{\f5\fs12\hyphpar0\qj{, 359.21}}}{{\f5\fs12\hyphpar0\qj{, 446.29}}}{{\f5\fs12\hyphpar0\qj{, 446.30}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsection 13 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 13 stricken}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.553}}}{\*\bkmkstart stylerid1_2E9_2E4_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer may:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer oaths and take affirmations as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 63A.2}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{421.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 331.903}}}{{\f5\fs18\hyphpar0\qj{, appoint and remove deputies, clerks and assistants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require that payment be made by guaranteed funds for tax sale redemptions, issuance of plat clearances, issuance of tax clearances for mobile homes, payments of taxes or assessments made within the thirty days prior to the annual tax sale or any adjournment of the tax sale, and any other payment which is to be collected by the county treasurer. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fguaranteed funds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means cash, cashier\u8217\'3fs check, money order, travelers\u8217\'3f check, or certified check.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Charge five dollars, as an administrative expense, for every rate, charge, rental, or special assessment certified as a lien to the treasurer for collection. This amount shall be added to the amount of the lien, collected at the time of payment from the payor, and credited to the county general fund. If the amount of the lien is paid in annual installments, an administrative expense charge shall be added to each annual installment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Accept credit cards and electronic transfers of funds in payment of moneys due to the county, including but not limited to credits and reimbursements received from the state, tax payments, and tax sale redemptions. A county treasurer may adjust fees to reflect the cost of processing such payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require a payor or an agent of a payor to make payment by electronic transfer of the funds through the county treasurer\u8217\'3fs authorized internet site when the payment totals fifty thousand dollars or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Treat a payment made by electronic funds transfer as if it were a paper check for purposes of }}}{{\f5\fs18\hyphpar0\qj{section 554.3512}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to an agreement under }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{, collect delinquent parking fines on behalf of a city in conjunction with renewal of motor vehicle registrations pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.40}}}{{\f5\fs18\hyphpar0\qj{. If the agreement provides for a fee to be paid to or retained by the county treasurer from the collection of parking fines, such fees shall be credited to the county general fund. Fines collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be remitted biannually to the city. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 28E.10}}}{{\f5\fs18\hyphpar0\qj{, a county treasurer may utilize the state department of transportation\u8217\'3fs vehicle registration and titling system to facilitate the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7411; R60, \'a7642; C73, \'a7766; C97, SS15, \'a7491; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5238, 5240;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7341.1}}}{, }{{\f5\fs18\hyphpar0\qj{341.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.553}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7552}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 57, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1043, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 18, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1092, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 34, \'a77, 8, 26}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 54, \'a79, 12}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7257}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.40}}}{{\f5\fs12\hyphpar0\qj{, 321.236}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For definitions applicable to subsection 3, see }{{\f5\fs12\hyphpar0\qj{\'a7445.1}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.554}}}{\*\bkmkstart stylerid1_2E9_2E4_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties relating to warrants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a warrant, scrip, or other evidence of the county\u8217\'3fs indebtedness, the treasurer shall endorse on it the date of payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer shall enter into the county system the warrant number, date paid, and interest paid, if any.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer shall return the paid warrants to the auditor. The original warrant shall be preserved for at least two years. The requirement that the original warrant be preserved is satisfied by preservation of the warrant in electronic form if the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 554D.113}}}{{\f5\fs18\hyphpar0\qj{ are met. The treasurer shall make monthly reports to show for each warrant the number, date, drawee\u8217\'3fs name, when paid, to whom paid, original amount, and interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a warrant legally drawn on the county treasury is presented for payment and not paid because of a deficiency, the treasurer shall carry out duties relating to the endorsement and payment of interest on the amount of deficiency as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 74}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the requirements and procedures specified in }}}{{\f5\fs18\hyphpar0\qj{sections 74.1}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{74.2}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{74.3}}}{{\f5\fs18\hyphpar0\qj{, when warrants other than anticipatory warrants are presented for payment and not paid for want of funds or are only partially paid, the treasurer may issue a warrant order for an amount equal to the unpaid warrants drawn on a fund. The warrant order shall be dated and include the fund name, amount, and the rate of interest established under }}}{{\f5\fs18\hyphpar0\qj{section 74A.6}}}{{\f5\fs18\hyphpar0\qj{. The warrant order shall be endorsed by the treasurer, \u8220\'3fnot paid for want of funds\u8221\'3f, and include the treasurer\u8217\'3fs signature. The treasurer shall keep a list of all warrants comprising a warrant order and shall submit a duplicate copy of the warrant order to the auditor. The procedures of }}}{{\f5\fs18\hyphpar0\qj{sections 74.4 through 74.7}}}{{\f5\fs18\hyphpar0\qj{ apply to warrant orders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a check, other than a warrant, outstanding for more than one year shall be canceled, removed from the list of outstanding checks, deposited to the account on which the check was written, and credited as unclaimed fees and trusts. The treasurer shall maintain a list of the checks for one year after cancellation. A person may claim the amount of the canceled treasurer\u8217\'3fs check for a period of one year after cancellation upon proper proof of ownership by filing a claim with the county auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A warrant outstanding for more than one year shall be canceled by the auditor and the amount of the warrant shall be credited to the fund upon which the warrant was drawn. A person may file a claim with the auditor for the amount of the canceled warrant within one year of the date of the cancellation, and upon showing of proper proof that the claim is true and unpaid, the auditor shall issue a warrant drawn upon the fund from which the original canceled warrant was drawn. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to warrants issued upon drainage or levee district funds or any fund upon which the county treasurer has issued a warrant order or stamped a warrant for want of funds.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[R60, \'a72187; C73, \'a7557; C97, \'a7597; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5158;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7334.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.554(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7553}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7154, 490; R60, \'a7362, 755; C73, \'a7329; C97, \'a7485; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5162;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7334.5}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.554(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7553}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7155; R60, \'a7363; C73, \'a7330; C97, \'a7486; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5163;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7334.6}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.554(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7553}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7159, 160; R60, \'a7365, 366; C73, \'a7332, 333; C97, \'a7488; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5164;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7334.7}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.554(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7553}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.554(5)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7553}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1048, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a7456; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5169;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7334.12}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.554(6)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7553}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 65, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 123, \'a7147, 209}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 57, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1084, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1232, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 45, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7208}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a774.4}}}{{\f5\fs12\hyphpar0\qj{, 74.6}}}{{\f5\fs12\hyphpar0\qj{, 74.7}}}{{\f5\fs12\hyphpar0\qj{, 331.427}}}{{\f5\fs12\hyphpar0\qj{, 331.558}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.555}}}{\*\bkmkstart stylerid1_2E9_2E4_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fund management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During each term of office, the treasurer shall keep a separate account of the taxes levied for state, county, school, highway, or other purposes and of all other funds created by law whether of regular, special, or temporary nature. The treasurer shall not pay out or use the money in a fund for any purpose except as specifically authorized by law. The treasurer shall be charged with the amount of tax or other funds collected or received by the treasurer and shall be credited with the amount of taxes or other funds disbursed from each account as authorized by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.153}}}{{\f5\fs18\hyphpar0\qj{, on or before the fifteenth day of each month, the treasurer shall prepare sworn statements of the amount of money held by the treasurer on the last day of the preceding month belonging to the state treasury and mail a copy of the statement and the remittance to the treasurer of state. Another copy of the statement shall be mailed to the director of the department of administrative services. However, in lieu of mailing the remittance to the treasurer of state, the treasurer may deposit the remittance to the credit of the treasurer of state in an interest-bearing account in a bank in the county as designated by the treasurer of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a treasurer fails to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the treasurer shall forfeit for each failure a sum of not less than one hundred dollars nor more than five hundred dollars to be recovered in an action against the treasurer\u8217\'3fs bond brought in the name of the director of the department of administrative services or the treasurer of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer shall make a complete settlement with the county semiannually and when the treasurer leaves office as provided in }}}{{\f5\fs18\hyphpar0\qj{section 12B.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer shall maintain custody of all public moneys in the treasurer\u8217\'3fs possession and deposit or invest the moneys as provided in }}}{{\f5\fs18\hyphpar0\qj{section 12B.10}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 12C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer shall keep all funds invested to the extent practicable and may invest the funds jointly with one or more counties, judicial district departments of correctional services, cities, city utilities, or rural water districts created under }}}{{\f5\fs18\hyphpar0\qj{chapter 357A}}}{{\f5\fs18\hyphpar0\qj{ pursuant to a joint investment agreement. All investments of funds shall be subject to }}}{{\f5\fs18\hyphpar0\qj{sections 12B.10}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{12B.10A}}}{{\f5\fs18\hyphpar0\qj{ and other applicable law.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7156, 161; R60, \'a7364, 367, 799; C73, \'a7331, 334, 914; C97, \'a7487, 489, 1459; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5165, 5166, 5168;}}}{ C46, 50, 54, \'a7334.8, 334.9 \u8211\'3f 334.11; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7334.8}}}{, }{{\f5\fs18\hyphpar0\qj{334.9}}}{, }{{\f5\fs18\hyphpar0\qj{334.11}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.555}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7554}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 105, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1084, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1233, \'a726}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1156, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 77, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.556}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.557}}}{\*\bkmkstart stylerid1_2E9_2E4_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties relating to vehicle registrations and certificates of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue, renew, and replace lost or damaged vehicle registration cards or plates and issue and transfer certificates of title for vehicles as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.17 through 321.20B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.22 through 321.26}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.28 through 321.32}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.34}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.35}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{321.37 through 321.52}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collect, pay to the state, or refund registration fees as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.105 through 321.106}