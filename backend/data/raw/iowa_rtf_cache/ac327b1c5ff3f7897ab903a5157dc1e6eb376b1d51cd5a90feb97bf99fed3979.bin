}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1043, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1118, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 123, \'a72, 13, 16, 22, 23}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 151, \'a71, 29}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1158, \'a75, 28}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 41, \'a71, 36}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7210}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a730, 38}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a729, 48, 49}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 156, \'a740}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For future strike of subsection 24, effective July 1, 2029, see }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 177, \'a7111, 120}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 strike of former subsection 15 applies retroactively to assessment years beginning on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a738}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 11 applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 stricken and subsections 3 \u8211\'3f 26 renumbered as 2 \u8211\'3f 25}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.560 through 331.600}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 3}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E5_2E1_2E2}{COUNTY RECORDER}{\*\bkmkend stylerid1_2E9_2E5_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.601}}}{\*\bkmkstart stylerid1_2E9_2E5_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Office of county recorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The office of recorder is an elective office except that if a vacancy occurs in the office, a successor shall be elected or appointed to the unexpired term as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 69}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person elected or appointed to the office of recorder shall qualify by taking the oath of office as provided in }}}{{\f5\fs18\hyphpar0\qj{section 63.10}}}{{\f5\fs18\hyphpar0\qj{ and giving bond as provided in }}}{{\f5\fs18\hyphpar0\qj{section 64.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term of office of the recorder is four years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In counties in which the office of county recorder has been abolished, the board of supervisors shall reassign the duties of the county recorder who also serves as the county registrar pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 144}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a796, 239; R60, \'a7224, 473; C73, \'a7589; C97, \'a71072; S13, \'a71072; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{520;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a739.17}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.601}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7600}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 124, \'a79, 26}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1033, \'a747}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.601A}}}{\*\bkmkstart stylerid1_2E9_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in this part, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBatch basis\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the delivery of an accumulation of electronic documents or records recorded or maintained by the county recorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDocument\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3finstrument\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a writing or drawing presented to the recorder for recording, consisting of one or more pages of text and attachments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectronic document\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a document or instrument that is received, processed, disseminated, or maintained in an electronic format. The submission of an electronic document through the county land record information system electronic submission service shall be equivalent to delivery of a document through the United States postal service or by personal delivery at designated offices in each county. Persons who submit electronic documents for recording are responsible for ensuring that the electronic documents comply with all requirements for recording.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFile or submit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the act of delivering a document or instrument to a recording office for recording into the public records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGrantor and grantee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the names of the transferor and transferee in the transaction used to create the recording index.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLegible\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means capable of being read or deciphered without magnification regardless of the recording process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a writing, printing, or drawing, other than a plat or survey or a drawing related to a plat or survey, occurring on one side only and covering all or part of such side, and not larger than eight and one-half inches in width and fourteen inches in length.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecord\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a process whether by manual, mechanical, electronic, optical, magnetic, microfilm, or other methods of storage, after filing or submission, to incorporate a document or instrument into the public record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTransaction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a specific legal action in the form of or evidenced by one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A title or caption including but not limited to a deed, deed of trust, mortgage, or power of attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A subsequent reference to an original document or instrument including but not limited to an assignment or release or satisfaction of mortgage.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1069, \'a71, 4}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 159, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.602}}}{\*\bkmkstart stylerid1_2E9_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The recorder shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Record all documents or instruments presented to the recorder\u8217\'3fs office for recordation upon payment of the proper fees and compliance with other recording requirements as provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rerecord an instrument without fee upon presentation of the original instrument by the owner if an error is made in recording the instrument. The recorder shall also note on the new record a reference to the original record and on the original record a reference to the new record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an error is made in indexing an instrument, reindex the instrument without fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~