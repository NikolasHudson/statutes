9, }{{\f5\fs18\hyphpar0\qj{81, \'a739.17}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.551}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7550}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1033, \'a746}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.552}}}{\*\bkmkstart stylerid1_2E9_2E4_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Receive all money payable to the county unless otherwise provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disburse money owed or payable by the county on warrants or checks drawn and signed by the auditor and sealed with the official county seal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep a true account of all receipts and disbursements of the county, which account shall be available for inspection by the board at any reasonable time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep the official county seal provided by the county. The official seal shall be an impression seal on the face of which shall appear the name of the county, the word \u8220\'3fcounty\u8221\'3f, which may be abbreviated, and the word \u8220\'3fIowa\u8221\'3f. A county shall have only one official county seal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Account for, report, and pay into the state treasury any money, property, or securities received on behalf of the state as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 8A.506 through 8A.508}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Account for and report to the board the amount of swampland indemnity funds received from the treasurer of state under }}}{{\f5\fs18\hyphpar0\qj{section 12.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Register and call tax anticipatory warrants issued for a memorial hospital as provided under }}}{{\f5\fs18\hyphpar0\qj{section 37.30}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serve on a nomination appeals commission to hear nomination objections filed with the county commissioner of elections as provided in }}}{{\f5\fs18\hyphpar0\qj{section 44.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep on file the bond and oath of the auditor as provided in }}}{{\f5\fs18\hyphpar0\qj{section 64.23}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serve as treasurer of an area hospital located outside the corporate limits of a city as provided in }}}{{\f5\fs18\hyphpar0\qj{section 145A.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Register and call anticipatory warrants related to the sale of limestone as provided in }}}{{\f5\fs18\hyphpar0\qj{section 353.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transfer funds to pay the expenses of creating or changing the boundaries of a school district as provided in }}}{{\f5\fs18\hyphpar0\qj{section 275.26}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transfer funds to pay tuition expenses owed by a debtor school district to a creditor school district as provided in }}}{{\f5\fs18\hyphpar0\qj{section 282.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pay to the treasurers of the school corporations located in the county the taxes and other moneys due as provided in }}}{{\f5\fs18\hyphpar0\qj{section 298.11}}}{{\f5\fs18\hyphpar0\qj{ and send amounts collected for each fund of a school corporation for direct deposit into the depository and account designated as provided in }}}{{\f5\fs18\hyphpar0\qj{section 298.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pay monthly to the treasurer of state proceeds of public lands sold and escheated estates as provided in }}}{{\f5\fs18\hyphpar0\qj{section 257B.2}}}{{\f5\fs18\hyphpar0\qj{ and pay annually on February 1 interest collected from public lands sold on credit as provided in }}}{{\f5\fs18\hyphpar0\qj{section 257B.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintain a permanent school fund account and records of school funds received as provided in }}}{{\f5\fs18\hyphpar0\qj{section 257B.31}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out duties relating to the sale and redemption of anticipatory certificates for secondary road construction as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 309.50 through 309.55}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out duties relating to the establishment of secondary road assessment districts as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 311}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out duties relating to the sale and redemption of county bonds as provided in }}}{{\f5\fs18\hyphpar0\qj{subchapter IV, parts 3 and 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notify the chairperson of the county hospital board of trustees and pay to the hospital treasurer the tax revenue collected for the county hospital during the preceding month as provided in }}}{{\f5\fs18\hyphpar0\qj{section 347A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collect a fee of twenty dollars for issuing a tax sale certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out duties relating to the condemnation of property as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.656, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out duties relating to the funding of drainage districts as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 468, subchapter I, parts 1 through 5}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 468, subchapter II, parts 1, 5, and 6}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 468, subchapter III}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapter 468, subchapter IV, parts 1 and 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collect and disburse funds for soil and water conservation districts as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 161A.33}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{161A.34}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Credit the remainder of funds received from a hotelkeeper\u8217\'3fs sale to satisfy a lien to the county general fund as provided in }}}{{\f5\fs18\hyphpar0\qj{section 583.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designate the newspapers in which the official notices of the treasurer\u8217\'3fs office are to be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 618.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{29.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Send, before the fifteenth day of each month, the amount of tax revenue, special assessments, and other moneys collected for each tax-certifying or tax-levying public agency in the county for direct deposit into the depository or financial institution and account designated by the governing body of the public agency. The treasurer shall send notice to the chairperson or other designated officer of the public agency stating the amount deposited, the date, the amount to be credited to each fund according to the budget, and the source of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{30.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out other duties as required by law and duties assigned pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.323}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{31.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collect all penalties that have accrued prior to April 1, 1992, on unpaid taxes, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{, and process them as interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{32.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{File with the county auditor the name of a designated employee, if other than the first deputy treasurer, authorized to perform the duties of the treasurer during the absence or disability of the treasurer and the name of any employee authorized to sign, on behalf of the treasurer, any form, notice, or document requiring the signature of the treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{33.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out duties relating to warrant lists provided by the county auditor pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.506, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{34.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Destroy tax sale redemption certificates and all associated tax sale records after ten years have elapsed from the end of the fiscal year in which the certificate was redeemed. If a tax sale certificate of purchase is canceled as required by }}}{{\f5\fs18\hyphpar0\qj{section 446.37}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{448.1}}}{{\f5\fs18\hyphpar0\qj{, all associated tax sale records shall be destroyed after ten years have elapsed from the end of the fiscal year in which the tax sale certificate of purchase was canceled. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies to documents described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ that are in existence before, on, or after July 1, 2003.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{35.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Destroy special assessment records required by }}}{{\f5\fs18\hyphpar0\qj{section 445.11}}}{{\f5\fs18\hyphpar0\qj{ within the county system after ten years have elapsed from the end of the fiscal year in which the special assessment was paid in full. The county treasurer shall also destroy the resolution of necessity, plat, and schedule of assessments required by }}}{{\f5\fs18\hyphpar0\qj{section 384.51}}}{{\f5\fs18\hyphpar0\qj{ after ten years have elapsed from the end of the fiscal year in which the entire schedule was paid in full. This paragraph applies to documents described in this paragraph that are in existence before, on, or after July 1, 2003.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Destroy assessment records required by }}}{{\f5\fs18\hyphpar0\qj{chapter 468}}}{{\f5\fs18\hyphpar0\qj{ within the county system after ten years have elapsed from the end of the fiscal year in which the assessment was paid in full. The county treasurer shall also destroy the accompanying documents including any resolutions, plats, or schedule of assessments after ten years have elapsed from the end of the fiscal year in which the entire schedule was paid in full. This paragraph applies to documents described in this paragraph that are in existence before, on, or after July 1, 2014.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{36.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Destroy mobile home and manufactured home tax lists after ten years have elapsed from the end of the fiscal year in which the list was created. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies to mobile home and manufactured home tax lists and associated documents in existence before, on, or after July 1, 2003.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1 \u8211\'3f 3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a7152; R60, \'a7360; C73, \'a7327; C97, \'a7482; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5156;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7334.1}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.552(1 \u8211\'3f 3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7551}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5157;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7334.2}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.552(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7551}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5 \u8211\'3f 15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.552(5 \u8211\'3f 17)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7551}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.552(18)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7551}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1195, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{17 \u8211\'3f 20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.552(19 \u8211\'3f 22)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7551}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C73, \'a7290; C97, S13, \'a7404; C24, 27, 31, 35, 39, \'a7