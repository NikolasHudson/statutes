cts, ch 133, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1137, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7212}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72015}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a754}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.654}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.654}}}{\*\bkmkstart stylerid1_2E9_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Faithful discharge of duties \u8212\'3f penalty for disobedience.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{section 331.652, subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 331.653, subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, do not relieve a sheriff or deputy sheriff from the full and faithful discharge of all duties required of the officer by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The disobedience of a sheriff or deputy sheriff to the command of a legal process is a contempt of the court from which the process is issued and is punishable as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 665}}}{{\f5\fs18\hyphpar0\qj{. The sheriff or deputy sheriff is also liable to action by any person injured by the disobedience.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7171; R60, \'a7384; C73, \'a7338; C97, \'a7500; S13, \'a7499-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5185, 5186;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7337.5}}}{, }{{\f5\fs18\hyphpar0\qj{337.6}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.654}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7653}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.655}}}{\*\bkmkstart stylerid1_2E9_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees \u8212\'3f mileage \u8212\'3f expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff shall collect the following fees:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For serving a notice and returning it, for the first person served, thirty dollars, and for each additional person, thirty dollars, except that the fee for serving additional persons in the same household shall be twenty dollars for each additional service, or if the service of notice cannot be made or several attempts are necessary, the repayment of all necessary expenses actually incurred by the sheriff while attempting in good faith to serve the notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each warrant served, thirty-five dollars, and the repayment of necessary expenses incurred in executing the warrant, as sworn to by the sheriff, or if service of the warrant cannot be made, the repayment of all necessary expenses actually incurred by the sheriff while attempting in good faith to serve the warrant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For serving and returning a subpoena, for each person served, thirty-five dollars, and the necessary expenses incurred while serving subpoenas in criminal cases or cases relating to hospitalization of persons with mental illness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For summoning a grand or trial jury, all necessary and actual expenses incurred by the sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For summoning a jury to assess the damages to the owners of lands taken for works of internal improvement, two hundred dollars per day, and necessary expenses incurred. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not allow a sheriff to make separate charges for different assessments which can be made by the same jury and completed in one day of ten hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For serving an execution, attachment, order for the delivery of personal property, injunction, or any order of court, and returning it, thirty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For making and executing a certificate or deed for lands sold on execution, fifty dollars, or for making and executing a bill of sale for personal property sold, thirty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the time necessarily employed in making an inventory of personal property attached or levied upon, twenty dollars per hour.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a copy of any paper required by law, made by the sheriff, fifty cents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Mileage at the rate specified in }}}{{\f5\fs18\hyphpar0\qj{section 70A.9}}}{{\f5\fs18\hyphpar0\qj{ in all cases required by law, going and returning. Mileage fees do not apply where provision is made for expenses, and both mileage and expenses shall not be allowed for the same services and for the same trip. If the sheriff transports one or more persons by auto to a state institution or any other destination required by law or if one or more legal papers are served on the same trip, the sheriff is entitled to one mileage, the mileage cost of which shall be prorated to the persons transported or papers served. However, in serving original notices in civil cases and in serving and returning a subpoena, the sheriff shall be allowed mileage in each action where the original notice or subpoena is served, with a minimum mileage of one dollar for each service. The sheriff may refuse to serve any legal processes in civil cases until the fees and estimated mileage for service have been paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For setting a sale of property, seventy-five dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For conveying one or more persons to a state, county, or private institution by order of court or commission, necessary expenses for the sheriff and the person conveyed and twenty-five dollars per hour for the time necessarily employed in going to and from the institution, the expenses and hourly rate to be charged and accounted for as fees. If the sheriff needs assistance in taking a person to an institution, the assistance shall be furnished at the expense of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For serving a warrant for the seizure of intoxicating liquors, ten dollars; for the removal and custody of the liquor, actual expenses; for the destruction of the liquor under the order of the court, ten dollars and actual expenses; for posting and leaving notices in these cases, ten dollars and actual expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For posting a notice or advertisement, ten dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For delivering prisoners under a change of venue, the fee authorized under }}}{{\f5\fs18\hyphpar0\qj{section 815.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the necessary time employed in attending the service of a writ, twenty-five dollars per hour.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The mileage fees allowed by law may be retained by the sheriff as an addition to the sheriff\u8217\'3fs annual salary. In counties having a population of one hundred thousand or more, the county may contract with the sheriff for the use of an automobile on a monthly basis in lieu of payment of mileage in the service of criminal processes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff shall keep an accurate record of the fees collected in the county system, make a quarterly report of the fees collected to the board, and pay the fees belonging to the county into the county treasury as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.902}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff shall deposit funds collected and held by the sheriff in an approved depository as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 12C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C51, \'a72536; R60, \'a71570, 4145; C73, \'a73788, 3789, 3807; C97, S13, \'a7511; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5191;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7337.11}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.655(1)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7654}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C24, \'a75192; C27, 31, 35, \'a75191-a1, 5192; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5191.2, 5192;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7337.13}}}{, }{{\f5\fs18\hyphpar0\qj{337.14}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.655(2)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7654}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, S13, \'a7508; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5246, 5247;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7342.2}}}{, }{{\f5\fs18\hyphpar0\qj{342.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.655(3)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7654}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[}{{\f5\fs18\hyphpar0\qj{S81, \'a7331.655(4)}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7654}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 198, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 118, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1133, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a785}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 92, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1080, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a7102}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 137, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a722}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.652}}}{{\f5\fs12\hyphpar0\qj{, 815.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.656}}}{\*\bkmkstart stylerid1_2E9_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Management of condemnation funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sheriff receiving funds from a condemnation proceeding shall list the funds in detail in a book kept for that purpose. The sheriff shall pay the funds to the persons entitled to them upon final adjudication of a condemnation case. If the funds are held after final adjudication of the case until the end of the fiscal year, the funds shall be paid to the treasurer as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than July 1 of each year, the sheriff shall make a detailed report under oath of all funds received and in the sheriff\u8217\'3fs possession from condemnation proceedings which have been finally adjudicated. The report shall include the names of the parties to whom the funds belong, when the funds were received, and a description of the property condemned. The report shall be filed with the treasurer and the amount of the condemnation funds specified in the report shall be paid to the treasurer. The sheriff shall be given a detailed receipt for the funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the sheriff possesses condemnation funds which have not been finally adjudicated, the sheriff shall prepare a detailed report of those funds, including the same information as required in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, which report shall be filed with the auditor for examination and audit by the board. When a sheriff\u8217\'3fs term of office expires, the sheriff shall pay the condemnation funds which are not finally adjudicated to the sheriff\u8217\'3fs successor. The outgoing sheriff shall receive a detailed receipt for the funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer shall keep a record of the condemnation funds received from the sheriff in a book kept for that purpose. The book shall include a list of the names of persons to whom the funds are due, a description of the property condemned, and the amount due for each property item. The treasurer shall pay the amount due to each person from the condemnation fund on warrants ordered by the board and issued by the auditor. The treasurer and the bond sureties of the treasurer are liable for the condemnation funds in the same manner as for other funds received by the treasurer in an official capacity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff and the bond sureties of the sheriff are liable for the condemnation funds received by the sheriff until the funds are paid to the persons to which the funds are due, the treasurer, or the sheriff\u8217\'3fs successor as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5193 \u8211\'3f 5197;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7337.15}}}{ \u8211\'3f 337.19; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.656}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7655}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.552}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.657}}}{\*\bkmkstart stylerid1_2E9_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Standard uniforms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff and the full-time deputy sheriffs shall wear the standard uniform and display a standard badge of office when on duty except:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff may designate other apparel to be worn when the sheriff or a deputy sheriff is engaged in assignments involving special investigation, civil process, court duties, jail duties, and the handling of persons with mental illness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A district court judge, district associate judge, or judicial magistrate may direct that deputy sheriffs who act as bailiffs dress in wearing apparel other than the standard uniform while the court is in session.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Special deputy sheriffs appointed by the sheriff are excluded from the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The standard uniforms and accessories required by the sheriff for the proper outfitting of the sheriff and the sheriff\u8217\'3fs full-time deputies under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be provided by the county. The uniforms and accessories issued to the sheriff and the sheriff\u8217\'3fs deputies remain the property of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The colors and design of the standard uniform for the sheriffs and deputy sheriffs shall be designated by rule of the commissioner of public safety after consideration of the recommendations of the Iowa state association of sheriffs and deputy sheriffs. The uniform shall include standard shirts, shoulder patches, badges, nameplates, hats, trousers, neckties, jackets, socks, shoes and boots, and leather goods. The uniforms shall be readily distinguishable from the uniforms of other law enforcement agencies of the state. The rules shall allow for appropriate individual county designations on the uniforms. The rules shall be adopted and may be amended in compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, \'a7332.10; C75, 77, 79, \'a7332.10, 337A.1, 337A.2, 337A.4, 337A.6; }{{\f5\fs18\hyphpar0\qj{C81, \'a7337A.1}}}{, }{{\f5\fs18\hyphpar0\qj{337A.2}}}{, }{{\f5\fs18\hyphpar0\qj{337A.4}}}{, }{{\f5\fs18\hyphpar0\qj{337A.6}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.657}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7656}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1129, \'a7113}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1137, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.322}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.658}}}{\*\bkmkstart stylerid1_2E9_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Care of prisoners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff shall provide board and care for prisoners in the sheriff\u8217\'3fs custody in the county jail without personal compensation except for the sheriff\u8217\'3fs annual salary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county shall pay the costs of the board and care of the prisoners in the county jail, which costs, in the board\u8217\'3fs judgment, are necessary to enable the sheriff to carry out the sheriff\u8217\'3fs duties under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The board may determine the manner in which meals are provided for the prisoners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff is accountable to the board for fees due or collected for boarding, lodging, and providing other services for prisoners in the sheriff\u8217\'3fs custody under the order of another state or a federal court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff shall allow access by the board at any reasonable time to the county jail and to supplies provided by the county for the purpose of inspecting the jail and determining whether the supplies are used for the purpose of boarding and caring for prisoners as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a72536; R60, \'a74145; C73, \'a73788; C24, 27, \'a75197-d1; C31, 35, \'a75197-d1 \u8211\'3f 5197-d3, 5197-d9; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5191, 5197.01 \u8211\'3f 5197.03, 5197.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7337.11, 338.1 \u8211\'3f 338.3, 338.9; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7338.1}}}{ \u8211\'3f }{{\f5\fs18\hyphpar0\qj{338.3}}}{, }{{\f5\fs18\hyphpar0\qj{338.9}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.658}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7657}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1117, \'a71, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.322}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.659}}}{\*\bkmkstart stylerid1_2E9_2E6_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for a civil claim for reimbursement under }}}{{\f5\fs18\hyphpar0\qj{section 356.7}}}{{\f5\fs18\hyphpar0\qj{, a sheriff or a deputy sheriff shall not:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appear in any court as an attorney or legal counsel for another party.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make or prepare a writing, document or process to commence a legal action or proceeding.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Use a writing, document or process prepared by the sheriff or deputy sheriff in a legal action or proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The document, writing, or process prepared or made by a sheriff or a deputy sheriff in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sheriff or a deputy sheriff shall not be the purchaser, directly or indirectly, of property which is being sold by the sheriff or deputy sheriff under process of law. A purchase made in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is void.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7175, 176; R60, \'a7388, 389; C73, \'a7342, 343; C97, \'a7546, 547; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5251, 5252;}}}{ C46, 50, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7343.3}}}{, }{{\f5\fs18\hyphpar0\qj{343.4}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.659}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7658}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a759, 64}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.660}}}{\*\bkmkstart stylerid1_2E9_2E6_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appropriation \u8212\'3f Indian settlement officer.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0179.pdf" }{\fldrslt \cf5 \f5 \fs18{{2009 Acts, ch 179, \'a714}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.661}}}{\*\bkmkstart stylerid1_2E9_2E6_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Multicounty office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two or more county boards of supervisors may adopt resolutions proposing to share the services of a county sheriff. The resolutions shall also propose that the question of establishing the office of multicounty sheriff be submitted to the electorate of the counties proposing to share the services of a county sheriff. The proposal is adopted in those counties where a majority of the electors voting approves the proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county sheriff shall be elected by a majority of the votes cast for the office of county sheriff in all of the counties which the county sheriff will serve. The election shall be conducted in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 47.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The office of multicounty sheriff is created effective on January 1 of the year following the next general election at which the county sheriff is elected as provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 39.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 189, \'a71}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.662 to 331.700}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 5}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E7_2E1_2E2}{RESERVED}{\*\bkmkend stylerid1_2E9_2E7_2E1_2E2}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{331.701 to 331.750}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 6}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E8_2E1_2E2}{COUNTY ATTORNEY}{\*\bkmkend stylerid1_2E9_2E8_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.751}}}{\*\bkmkstart stylerid1_2E9_2E8_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Office of county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The office of county attorney is an elective office except that if a vacancy occurs in the office, a successor shall be elected or appointed to the unexpired term as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 69}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person elected or appointed to the office of county attorney shall be a registered voter of the county, be admitted to the practice of law in the courts of this state as provided by law, qualify by taking the oath of office as provided in }}}{{\f5\fs18\hyphpar0\qj{section 63.10}}}{{\f5\fs18\hyphpar0\qj{, and give bond as provided in }}}{{\f5\fs18\hyphpar0\qj{section 64.8}}}{{\f5\fs18\hyphpar0\qj{. A person is not qualified for the office of county attorney while the person\u8217\'3fs license to practice law in this or any other state is suspended or revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term of office of the county attorney is four years.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a796, 239; R60, \'a7224; C97, \'a71072; S13, \'a7308-b, 1072; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{520, 5179;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a739.17}}}{, }{{\f5\fs18\hyphpar0\qj{336.1}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.751}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7750}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1169, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1033, \'a748}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.752}}}{\*\bkmkstart stylerid1_2E9_2E8_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Full-time or part-time attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may provide that the county attorney is a full-time or part-time county officer in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A full-time county attorney shall refrain from the private practice of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may provide, by resolution, that the county attorney shall be a full-time county officer. The resolution shall include an effective date which shall not be less than sixty days from the date of adoption. However, if the county attorney or county attorney-elect objects to the full-time status, the effective date of the change to a full-time status shall be delayed until January 1 of the year following the next general election at which a county attorney is elected. The board shall not adopt a resolution changing the status of the county attorney between March 1 and the date of the general election of the year in which the county attorney is regularly elected as provided in }}}{{\f5\fs18\hyphpar0\qj{section 39.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may change the status of a full-time county attorney to a part-time county attorney by following the same procedures as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. If the incumbent county attorney objects to the change in status, the change shall be delayed until January 1 following the next election of a county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resolution changing the full-time or part-time status of a county attorney may take effect at any time before the sixty days expire upon agreement of the board of supervisors and the affected county attorney or county attorney-elect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The resolution changing the status of a county attorney shall state the initial annual salary to be paid to the county attorney when the full-time or part-time status is effective. The annual salary specified in the resolution shall remain effective until changed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.907}}}{{\f5\fs18\hyphpar0\qj{. Except in counties having a population of more than two hundred thousand, the annual salary of a full-time county attorney shall be an amount which is between forty-five percent and one hundred percent of the annual salary received by a district court judge.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7332.61}}}{ \u8211\'3f 332.63; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.752}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7751, 752}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1267, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1173, \'a728}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7236.3B}}}{{\f5\fs12\hyphpar0\qj{, 236A.5}}}{{\f5\fs12\hyphpar0\qj{, 331.323}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.753}}}{\*\bkmkstart stylerid1_2E9_2E8_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Multicounty office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If two or more counties agree, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{, to share the services of a county attorney, the county attorney shall be elected by a majority of the votes cast for the office of county attorney in all of the counties which the county attorney will serve as provided in the agreement. The election shall be conducted in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 47.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The effective date of the agreement shall be January 1 of the year following the next general election at which the county attorney is elected as provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 39.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7336.6}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.753}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7753}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.323}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.754}}}{\*\bkmkstart stylerid1_2E9_2E8_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Absence or disqualification of county attorney and assistants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In case of absence, sickness, or disability of the county attorney and the assistant county attorneys, the board of supervisors may appoint an attorney to act as county attorney. Upon application of the county attorney or the attorney general, the chief judge or the chief judge\u8217\'3fs designee may appoint an attorney to act temporarily as county attorney until the board has had sufficient time to appoint an acting county attorney. As an alternative, upon the application of the county attorney or the attorney general, the chief judge or the chief judge\u8217\'3fs designee may appoint the attorney general to temporarily act as county attorney if the attorney general consents to the appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the county attorney and all assistant county attorneys are disqualified because of a conflict of interest from performing duties and conducting official business in a juvenile, criminal, contempt, or commitment proceeding which requires the attention of the county attorney, the chief judge or the chief judge\u8217\'3fs designee, upon application by the county attorney or the attorney general certifying that there is a bona fide reason for the disqualification based upon a principle of law or court rule, may appoint an attorney to act as county attorney in the proceeding. As an alternative, upon application of the county attorney or attorney general certifying that there is a bona fide reason for the disqualification, the chief judge or the chief judge\u8217\'3fs designee may appoint the attorney general to act as county attorney in the proceeding if the attorney general consents to the appointment. If the attorney general does not consent to the appointment, the chief judge or the chief judge\u8217\'3fs designee may appoint an attorney designated by the attorney general.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon any application of the attorney general pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{, the county attorney shall be given notice and shall be provided an opportunity to file an objection prior to the appointment of any attorney. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply if giving notice would jeopardize a criminal investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may appoint an attorney to act as county attorney in a civil proceeding if the county attorney and all assistant county attorneys are disqualified because of a conflict of interest from performing duties and conducting official business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A temporary or acting county attorney has the same authority and is subject to the same responsibilities as a county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A temporary or acting county attorney shall receive a reasonable compensation as determined by the board for services rendered in proceedings before a judicial magistrate or rendered on behalf of a county officer or employee. If the proceedings are held before a district associate judge or a district judge, the judge shall determine a reasonable compensation for the temporary or acting county attorney. If the proceedings are held before an associate juvenile judge or a judicial hospitalization referee, the temporary or acting county attorney shall be compensated at a rate approved by the judge who appointed the associate juvenile judge or referee. The compensation shall be paid from funds to be appropriated to the office of county attorney by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 6}}}{{\f5\fs18\hyphpar0\qj{, upon request by a county attorney, the attorney general or an assistant attorney general may act as county attorney in a criminal proceeding, on behalf of the state, without appointment by the board, the chief judge, or the chief judge\u8217\'3fs designee.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7304; C24, \'a713675; C27, 31, 35, \'a75180-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5180.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7336.3}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.754}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7754}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1066, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1124, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1057, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1052, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.755}}}{\*\bkmkstart stylerid1_2E9_2E8_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited actions \u8212\'3f outside counsel authorized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county attorney shall not:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Accept a fee or reward from or on behalf of a person for services rendered in a prosecution or the conduct of official business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Engage directly or indirectly as an attorney or an agent for a party other than the state or the county in an action or proceeding arising in the county that is based upon substantially the same facts as a prosecution or proceeding that has been commenced or prosecuted by the county attorney in the name of the state or the county. This prohibition also applies to the members of a law firm with which the county attorney is associated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Receive assistance from another attorney who is interested in any civil action in which a recovery is asked based upon matters involved in a criminal prosecution commenced or prosecuted by the county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A board of supervisors may, with a majority vote of the board, obtain outside counsel to represent the board of supervisors or any other county official.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7305; C24, \'a713677; C27, 31, 35, \'a71580-a3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5180.3;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7336.5}}}{; }{{\f5\fs18\hyphpar0\qj{S81, \'a7331.755}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a7755}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 100, \'a71, 2}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{331.756}}}{\*\bkmkstart stylerid1_2E9_2E8_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of the county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county attorney shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Diligently enforce or cause to be enforced in the county, state laws and county ordinances, violations of which may be commenced or prosecuted in the name of the state, county, or as county attorney, except as otherwise provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appear for the state and the county in all cases and proceedings in the courts of the county to which the state or the county is a party, except actions or proceedings resulting from a change of venue from another county, and appear in the appellate courts in all cases in which the county is a party, and appear in all actions or proceedings which are transferred on a change of venue to another county or which require the impaneling of a jury from another county and in which the county or the state is a party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prosecute all preliminary hearings for charges triable upon indictment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prosecute misdemeanors under }}}{{\f5\fs18\hyphpar0\qj{chapter 664A}}}{{\f5\fs18\hyphpar0\qj{. The county attorney shall prosecute other misdemeanors when not otherwise engaged in the performance of other official duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enforce all forfeited bonds and recognizances and prosecute all proceedings necessary for the recovery of debts, revenues, moneys, fines, penalties, restitution of court-appointed attorney fees ordered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 815.9}}}{{\f5\fs18\hyphpar0\qj{, including the expense of a public defender, and forfeitures accruing to the state, the county or a road district in the county, and all suits in the county against public service corporations which are brought in the name of the state. To assist in this duty, the county attorney may procure a designee to assist with collection efforts.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the designee is a professional collection services agency, the county attorney shall file with the clerk of the district court an indication of the satisfaction of each obligation to the full extent of all moneys collected in satisfaction of that obligation, including all fees and compensation retained by the designee incident to the collection and not paid into the office of the clerk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before a county attorney designates another county official or agency to assist with collection of debts, revenues, moneys, fines, penalties, restitution of court-appointed attorney fees ordered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 815.9}}}{{\f5\fs18\hyphpar0\qj{, including the expense of a public defender, and forfeitures, the board of supervisors of the county must approve the designation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All fines, penalties, court costs, fees, and restitution for court-appointed attorney fees ordered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 815.9}}}{{\f5\fs18\hyphpar0\qj{, including the expenses of a public defender which are delinquent as defined in }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{ may be collected by the county attorney or the county attorney\u8217\'3fs designee. The county attorney or the county attorney\u8217\'3fs designee may collect delinquent obligations under an installment agreement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.210B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdesignee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a professional collection services agency operated by a person or organization, including a private attorney, that is generally considered to have knowledge and special abilities not generally possessed by the state, a local government, or another county official or agency, or a county attorney or a county attorney\u8217\'3fs designee in another county where the fine, penalty, surcharge, or court cost was not imposed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Commence, prosecute, and defend all actions and proceedings in which a county officer, in the officer\u8217\'3fs official capacity, or the county is interested or a party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Give advice or a written opinion, without compensation, to the board and other county officers and to township officers, when requested by an officer, upon any matters in which the state, county, or township is interested, or relating to the duty of the officer in any matters in which the state, county, or township may have an interest, but the county attorney shall not appear before the board at a hearing in which the state or county is not interested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Attend the grand jury when necessary for the purpose of examining witnesses before it or giving it legal advice. The county attorney shall procure subpoenas or other process for witnesses and prepare all informations and bills of indictment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Give a receipt to all persons from whom the county attorney receives money in an official capacity and file a duplicate receipt with the county auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make reports relating to the duties and the administration of the county attorney\u8217\'3fs office to the governor when requested by the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cooperate with the auditor of state to secure correction of a financial irregularity as provided in }}}{{\f5\fs18\hyphpar0\qj{section 11.53}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit reports as to the condition and operation of the county attorney\u8217\'3fs office when required by the attorney general as provided in }}}{{\f5\fs18\hyphpar0\qj{section 13.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hear and decide objections to a nomination filed with the county election commissioner as provided in }}}{{\f5\fs18\hyphpar0\qj{section 44.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review the report and recommendations of the Iowa ethics and campaign disclosure board and proceed to institute the recommended actions or advise the board that prosecution is not merited, as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 68B.32C}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{68B.32D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prosecute or assist in the prosecution of actions to remove public officers from office as provided in }}}{{\f5\fs18\hyphpar0\qj{section 66.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Institute legal proceedings against persons who violate laws administered under }}}{{\f5\fs18\hyphpar0\qj{chapter 10A, subchapter II}}}{{\f5\fs18\hyphpar0\qj{, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 10A.210}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Investigate complaints and prosecute violations of child labor laws as provided in }}}{{\f5\fs18\hyphpar0\qj{section 92.22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prosecute violations of employment security laws and rules as provided in }}}{{\f5\fs18\hyphpar0\qj{section 96.17, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assist, at the request of the director of revenue, in the enforcement of cigar and tobacco tax laws as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 453A.32}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\h