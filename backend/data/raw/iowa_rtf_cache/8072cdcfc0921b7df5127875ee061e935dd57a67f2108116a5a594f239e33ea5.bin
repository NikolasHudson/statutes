\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F169A}{\*\bkmkend codeChapter_5F169A}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 169A}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{MARKING AND BRANDING OF LIVESTOCK}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7169C.3}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAnimal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a creature belonging to the bovine, caprine, equine, ovine, or porcine species; ostriches, rheas, or emus; farm deer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 170.1}}}{{\f5\fs18\hyphpar0\qj{; or poultry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBrand\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an identification mark that is burned into the hide of a live animal by a hot iron or another method approved by the secretary. A brand shall include a cryo-brand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fComputer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 22.3A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCryo-brand\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a brand produced by application of extreme cold temperature.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIdentification device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a device which when installed is designed to store information regarding an animal or the animal\u8217\'3fs owner in an electronic format which may be accessed by a computer for purposes of reading or manipulating the information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInstall\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means to place an identification device onto or beneath the hide or skin of an animal, including but not limited to fixing the device into the ear of an animal or implanting the device beneath the skin of the animal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLivestock\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means horses, cattle, sheep, mules, or asses.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7635}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 60, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1208, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 149, \'a72, 23}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Further definitions; see }{{\f5\fs12\hyphpar0\qj{\'a7159.1}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adoption of brand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person owning livestock may adopt a brand for the purpose of branding the livestock. The person shall have the exclusive right to use the brand in this state, after recording the brand as provided in }{{\f5\fs18\hyphpar0\qj{sections 169A.4}}}{ and }{{\f5\fs18\hyphpar0\qj{169A.6}}}{ or }{{\f5\fs18\hyphpar0\qj{169A.9}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 60, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Must be recorded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Evidence of an animal\u8217\'3fs ownership shall not be established in court by the animal\u8217\'3fs brand, unless the animal is livestock, the brand complies with the requirements of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and the brand is recorded as provided in }{{\f5\fs18\hyphpar0\qj{sections 169A.4}}}{ and }{{\f5\fs18\hyphpar0\qj{169A.6}}}{ or }{{\f5\fs18\hyphpar0\qj{169A.9}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 60, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Recording \u8212\'3f fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person desiring to adopt a brand shall forward to the secretary a brand application on forms approved by the secretary and providing for the desired brand, together with a recording fee of twenty-five dollars. Upon receipt, the secretary shall file the application and fee, unless the brand is of record of another person or conflicts with or closely resembles the brand of another person. If the secretary determines that such brand is of record or conflicts with or closely resembles the brand of another person, the secretary shall not record it but shall return the facsimile and fee to the forwarding person. However, the secretary shall renew a conflicting brand if the brand was originally recorded prior to July 1, 1996, and the brand is renewed as provided in }{{\f5\fs18\hyphpar0\qj{section 169A.13}}}{. The department may notify each owner of a conflicting brand that the owner may record a nonconflicting brand. The power of examination, approval, acceptance, or rejection shall be vested in the secretary. The secretary shall file all brands offered for record pending the examination provided for in }{{\f5\fs18\hyphpar0\qj{this section}}}{. The secretary shall make such examination as promptly as possible. If the brand is accepted, the brand\u8217\'3fs ownership shall vest in the person recording it from the date of filing.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7921 \u8211\'3f 923; R60, \'a71556 \u8211\'3f 1558; C73, \'a71480, 1481, 3809; C97, \'a72335, 2336; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2977, 2978;}}}{ C46, 50, 54, 58, 62, \'a7187.2, 187.3; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1119, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 183, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1050, \'a761, 65}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7169A.2}}}{{\f5\fs12\hyphpar0\qj{, 169A.3}}}{{\f5\fs12\hyphpar0\qj{, 169A.5}}}{{\f5\fs12\hyphpar0\qj{, 169A.8}}}{{\f5\fs12\hyphpar0\qj{, 169A.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Effect of record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The recording provided for in }{{\f5\fs18\hyphpar0\qj{sections 169A.4}}}{ and }{{\f5\fs18\hyphpar0\qj{169A.6}}}{ or }{{\f5\fs18\hyphpar0\qj{169A.9}}}{ shall secure the brand to the person and shall be considered personal property of said owner.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certified copy furnished.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As soon as the brand is recorded by the secretary, the secretary shall furnish the owner of the brand with a certified copy of the record of the brand.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 60, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7169A.2}}}{{\f5\fs12\hyphpar0\qj{, 169A.3}}}{{\f5\fs12\hyphpar0\qj{, 169A.5}}}{{\f5\fs12\hyphpar0\qj{, 169A.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unlawful use of brand \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not use any brand for branding livestock, unless the brand has been recorded as provided by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. A person may use an unrecorded hot brand or an unrecorded cryo-brand, consisting only of Arabic numerals, if the person uses the unrecorded brand in conjunction with the person\u8217\'3fs recorded brand, and only for purposes of identifying animals within a herd. However, the unrecorded brand shall not be evidence of ownership. A person convicted of violating }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be guilty of an aggravated misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 60, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale or assignment of brand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any brand recorded as provided in }{{\f5\fs18\hyphpar0\qj{section 169A.4}}}{ shall be the property of the person causing such record to be made and shall be subject to sale, assignment, transfer, devise, and descent as personal property. Instruments of writing, evidencing the sale, assignment, or transfer of such brand shall be recorded by the secretary and the fee for recording such sale, assignment, or transfer shall be in an amount established by rule of the secretary pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{, which amount shall be based upon the administrative costs of maintaining the brand program provided for by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certified copy to new owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As soon as instruments of writing evidencing the sale, assignment, or transfer of a brand have been recorded by the secretary, the secretary shall furnish such new owner one certified copy of such sale, assignment, or transfer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7169A.2}}}{{\f5\fs12\hyphpar0\qj{, 169A.3}}}{{\f5\fs12\hyphpar0\qj{, 169A.5}}}{{\f5\fs12\hyphpar0\qj{, 169A.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Evidence of ownership \u8212\'3f investigations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a suit at law or equity or in any criminal proceedings in which the title to an animal is an issue, the following shall be admissible as evidence:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified copy of a record as provided for in }}}{{\f5\fs18\hyphpar0\qj{section 169A.6}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{169A.9}}}{{\f5\fs18\hyphpar0\qj{. The certified copy shall be prima facie evidence of the ownership of livestock by the person in whose name the brand is recorded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information stored in an identification device which identifies the owner of an animal. The information shall be prima facie evidence of the ownership of the animal, if all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The identification device meets applicable design standards adopted by the international standard organization, or which may be adopted by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The identification device is installed according to manufacturer\u8217\'3fs requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information is not in conflict with a certified copy of a record as provided for in }}}{{\f5\fs18\hyphpar0\qj{section 169A.6}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{169A.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The results of a sheriff\u8217\'3fs investigation as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A dispute involving the custody or ownership of an animal branded or subject to electronic identification under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be investigated, on request, by the sheriff of the county where the animal is located. The sheriff may call upon the services of an authorized person, approved by the secretary, in reading the brands on animals. The cost of the services shall be paid by the person requesting the investigation. The results of the sheriff\u8217\'3fs investigation are a public record.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 60, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1208, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Publication of brands list.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The secretary from time to time shall publish on the internet a list of all brands on record at the time of the publication. The publication shall contain a facsimile of all brands recorded and the owner\u8217\'3fs name and post office address. The records shall be arranged in convenient form for reference. }\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 60, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1095, \'a760}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.12}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2001/CH0183.pdf" }{\fldrslt \cf5 \f5 \fs18{{2001 Acts, ch 183, \'a723}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.13}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Renewal of brand and fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each owner of a brand which is recorded pursuant to }{{\f5\fs18\hyphpar0\qj{section 169A.4}}}{ shall renew the brand every five years after originally recording the brand and pay a renewal fee. The amount of the renewal fee is twenty-five dollars. The secretary shall notify every owner of a brand of record at least thirty days prior to the date of the renewal period. If the owner of a brand of record does not renew the brand and pay the renewal fee within six months after it is due, the owner shall forfeit the brand and the brand shall no longer be recorded. A forfeited brand shall not be issued to any other person for five years following date of forfeiture.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 60, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1034, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 183, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1119, \'a724}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7169A.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.13A}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Branding administration fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A branding administration fund is created in the state treasury under the control of the department. The fund is composed of moneys collected in fees as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, moneys appropriated by the general assembly, and moneys available to and obtained or accepted by the department from the United States or private sources for placement in the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund is subject to warrants written by the director of the department of administrative services, drawn upon the written requisition of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund are appropriated to the department for the exclusive purpose of supporting the administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 8.33}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to moneys in the fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7}}}{{\f5\fs18\hyphpar0\qj{, moneys earned as income, including as interest, from the fund shall remain in the fund until expended as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 183, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tampering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not do any of the following to an animal:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Brand, attempt to brand, or cause to be branded livestock, without authorization from the owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Efface, deface, or obliterate or attempt to efface, deface, or obliterate a brand, without authorization from the owner of the livestock.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Brand, attempt to brand, or cause to be branded a recorded brand on livestock, without authorization of the owner of the brand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Install an electronic device or remove or damage an installed electronic device, without authorization from the owner of an animal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person violating }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a fraudulent practice as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 714}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7187.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7169A.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1208, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7169.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.15}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1995/CH0060.pdf" }{\fldrslt \cf5 \f5 \fs18{{95 Acts, ch 60, \'a710}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{169A.16}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1996/CH1119.pdf" }{\fldrslt \cf5 \f5 \fs18{{96 Acts, ch 1119, \'a72}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}}