\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F57_30A}{\*\bkmkend codeChapter_5F57_30A}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 570A}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{AGRICULTURAL SUPPLY DEALER LIEN}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{570A.1}}}{\*\bkmkstart stylerid1_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural chemical\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a fertilizer or agricultural chemical which is applied to crops or land which is used for the raising of crops, including but not limited to fertilizer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 200.3}}}{{\f5\fs18\hyphpar0\qj{, and pesticide as defined in }}}{{\f5\fs18\hyphpar0\qj{section 206.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural purpose\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a purpose related to the production, harvest, marketing, or transportation of agricultural products by a person who cultivates, plants, propagates or nurtures the agricultural products including agricultural, horticultural, viticultural, and dairy products, livestock, wildlife, poultry, bees, forest products, fish and shellfish, and any other products raised or produced on farms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural supply\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an agricultural chemical, seed, feed, or a petroleum product that is used for an agricultural purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural supply dealer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdealer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person engaged in the retail sale of agricultural chemicals, seed, feed, or petroleum products used for an agricultural purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural supply dealer lien\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flien\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the agricultural supply dealer lien created in }}}{{\f5\fs18\hyphpar0\qj{section 570A.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCertified request\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a request delivered by certified mail or registered certified mail, in person if in writing and signed and dated by the respective parties, or in the manner provided by the Iowa rules of civil procedure for the personal service of original notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFarmer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person engaged in a business which has an agricultural purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFeed\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a commercial feed, feed ingredient, mineral feed, drug, animal health product, or customer-formula feed which is used for the feeding of livestock, including but not limited to feed as defined in }}}{{\f5\fs18\hyphpar0\qj{section 198.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinancial history\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the record of a person\u8217\'3fs current loans, the date of a person\u8217\'3fs loans, the amount of the loans, the person\u8217\'3fs payment record on the loans, current liens against the person\u8217\'3fs property, and the person\u8217\'3fs most recent financial statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinancial institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a bank, credit union, insurance company, mortgage banking company or savings and loan association, industrial loan company, production credit association, farmer\u8217\'3fs home administration, or like institution which operates or has a place of business in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLabor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means labor performed in the application, delivery, or preparation of a product defined in }}}{{\f5\fs18\hyphpar0\qj{subsections 1, 8, 14, and 16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLetter of credit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an engagement by a financial institution to honor drafts or other demands for payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLivestock\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an animal belonging to the bovine, caprine, equine, ovine, or porcine species, ostriches, rheas, emus, poultry, or fish or shellfish.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPetroleum product\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a motor fuel or special fuel which is used in the production of crops or livestock, including but not limited to motor fuel as defined in }}}{{\f5\fs18\hyphpar0\qj{section 452A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSale on a credit basis\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a transaction in which the purchase price is due on a date after the date of the sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSeed\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means agricultural seeds which are used in the production of crops, including but not limited to agricultural seed as defined in }}}{{\f5\fs18\hyphpar0\qj{section 199.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1072, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 204, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 43, \'a713}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 82, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7414.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{570A.2}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Financial institution memorandum to agricultural supply dealers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the receipt of a certified request of an agricultural supply dealer, prior to or upon a sale on a credit basis of an agricultural supply to a farmer, a financial institution which has either a security interest in collateral owned by the farmer or an outstanding loan to the farmer for an agricultural purpose shall issue within four business days a memorandum which states whether or not the farmer has a sufficient net worth or line of credit to assure payment of the purchase price on the terms of the sale. The certified request submitted by the agricultural supply dealer shall state the amount of the purchase and the terms of sale and shall be accompanied by a waiver of confidentiality signed by the farmer, and a fifteen dollar fee. The waiver of confidentiality and the certified request may be combined and submitted as one document. If the financial institution states in its memorandum that the farmer has a sufficient net worth or line of credit to assure payment of the purchase price, the memorandum is an irrevocable and unconditional letter of credit to the benefit of the agricultural supply dealer for a period of thirty days following the date on which the final payment is due for the amount of the purchase price which remains unpaid. If the financial institution does not state in its memorandum that the farmer has a sufficient net worth or line of credit to assure payment of the purchase price, the financial institution shall transmit the relevant financial history which it holds on the person. This financial history shall remain confidential between the financial institution, the agricultural supply dealer, and the farmer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If within four business days of receipt of a certified request a financial institution fails to issue a memorandum upon the request of an agricultural supply dealer and the request from the agricultural supply dealer was proper under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or if the memorandum from the financial institution is incomplete, or if the memorandum from the financial institution states that the farmer does not have a sufficient net worth or line of credit to assure payment of the purchase price, the agricultural supply dealer may decide to make the sale and secure the lien provided in }}}{{\f5\fs18\hyphpar0\qj{section 570A.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon an action to enforce a lien secured under }}}{{\f5\fs18\hyphpar0\qj{section 570A.3}}}{{\f5\fs18\hyphpar0\qj{ against the interest of a financial institution secured to the same collateral as that of the lien, it shall be an affirmative defense to a financial institution and complete proof of the superior priority of the financial institution\u8217\'3fs lien that the financial institution either did not receive a certified request and a waiver signed by the farmer, or received the request and a waiver signed by the farmer and provided the full and complete relevant financial history which it held on the farmer making the purchase from the agricultural supply dealer on which the lien is based and that financial history reasonably indicated that the farmer did not have a sufficient net worth or line of credit to assure payment of the purchase price.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1072, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 204, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1168, \'a758}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 82, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7570A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{570A.3}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lien created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An agricultural supply dealer who provides an agricultural supply to a farmer shall have an agricultural lien as provided in }{{\f5\fs18\hyphpar0\qj{section 554.9102}}}{. The agricultural supply dealer is a secured party and the farmer is a debtor for purposes of }{{\f5\fs18\hyphpar0\qj{chapter 554, article 9}}}{. The amount of the lien shall be the amount owed to the agricultural supply dealer for the retail cost of the agricultural supply, including labor provided. The lien applies to all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Crops which are produced upon the land to which the agricultural chemical was applied, produced from the seed provided, or produced using the petroleum product provided. The lien shall not apply to any crops so produced upon the land after four hundred ninety days from the date that the farmer purchased the agricultural supply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Livestock consuming the feed. However, the lien does not apply to that portion of the livestock of a farmer who has paid all amounts due from the farmer for the retail cost, including labor, of the feed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1072, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 204, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 82, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7570A.1}}}{{\f5\fs12\hyphpar0\qj{, 570A.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{570A.4}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Perfecting the lien \u8212\'3f filing requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except as provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{, a financing statement filed to perfect an agricultural supply dealer lien shall be governed by }{{\f5\fs18\hyphpar0\qj{chapter 554, article 9, part 5}}}{, in the same manner as any other financing statement.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The lien becomes effective at the time that the farmer purchases the agricultural supply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to perfect the lien, the agricultural supply dealer must file a financing statement in the office of the secretary of state as provided in }}}{{\f5\fs18\hyphpar0\qj{section 554.9308}}}{{\f5\fs18\hyphpar0\qj{ within thirty-one days after the date that the farmer purchases the agricultural supply. The financing statement shall meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 554.9502, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and include all applicable information described in }}}{{\f5\fs18\hyphpar0\qj{section 554.9516}}}{{\f5\fs18\hyphpar0\qj{. Filing a financing statement as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ satisfies all requirements for perfection of an agricultural lien as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 554, article 9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1072, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 204, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1275, \'a740}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 267, \'a7630}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a7177, 187}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 82, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7570A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{570A.5}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Priority of lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except as provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{, an agricultural supply dealer lien that is effective or perfected as provided in }{{\f5\fs18\hyphpar0\qj{section 570A.4}}}{ shall be subject to the rules of priority as provided in }{{\f5\fs18\hyphpar0\qj{section 554.9322}}}{. For an agricultural supply dealer lien that is perfected under }{{\f5\fs18\hyphpar0\qj{section 570A.4}}}{, all of the following shall apply:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The lien shall have priority over a lien or security interest that applies subsequent to the time that the agricultural supply dealer lien is perfected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 570A.2, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the lien shall have equal priority to a lien or security interest which is perfected prior to the time that the agricultural supply dealer lien is perfected. However, a landlord\u8217\'3fs lien that is perfected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 570.1}}}{{\f5\fs18\hyphpar0\qj{ shall have priority over a conflicting agricultural supply dealer lien as provided in }}}{{\f5\fs18\hyphpar0\qj{section 570.1}}}{{\f5\fs18\hyphpar0\qj{, and a harvester\u8217\'3fs lien that is perfected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 571.3}}}{{\f5\fs18\hyphpar0\qj{ shall have priority over a conflicting agricultural supply dealer lien as provided in }}}{{\f5\fs18\hyphpar0\qj{section 571.3A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lien in livestock feed shall have priority over an earlier perfected lien or security interest to the extent of the difference between the acquisition price of the livestock and the fair market value of the livestock at the time the lien attaches or the sale price of the livestock, whichever is greater.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1072, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 82, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1086, \'a792, 93}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{570A.6}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement of lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An agricultural supply dealer may enforce an agricultural supply dealer lien in the manner provided for agricultural liens pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 554, article 9, part 6}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1072, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1149, \'a7178, 187}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 82, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1086, \'a794}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{570A.7 through 570A.11}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0082.pdf" }{\fldrslt \f5 \fs18{{2003 Acts, ch 82, \'a78}}}}}}{{\f5\fs18\qj{2003 Acts, ch 82, \'a78}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}}