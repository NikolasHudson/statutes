0\ri1445\li1445{title; transferred from chapter 172C in Code 1993}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{9H.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fActively engaged in farming\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that a natural person who is a shareholder and an officer, director or employee of the corporation or who is a member or manager of the limited liability company either:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inspects the production activities periodically and furnishes at least half of the value of the tools and pays at least half the direct cost of production; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regularly and frequently makes or takes an important part in making management decisions substantially contributing to or affecting the success of the farm operation; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Performs physical work which significantly contributes to crop or livestock production.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural land\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means land suitable for use in farming.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthorized farm corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a corporation other than a family farm corporation founded for the purpose of farming and the ownership of agricultural land in which:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The stockholders do not exceed twenty-five in number; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The stockholders are all natural persons or persons acting in a fiduciary capacity for the benefit of natural persons or nonprofit corporations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthorized limited liability company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a limited liability company other than a family farm limited liability company founded for the purpose of farming and the ownership of agricultural land in which all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members do not exceed twenty-five in number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members are all natural persons or persons acting in a fiduciary capacity for the benefit of natural persons or nonprofit corporations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthorized trust\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a trust other than a family trust in which:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The beneficiaries do not exceed twenty-five in number; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The beneficiaries are all natural persons, who are not acting as a trustee or in a similar capacity for a trust as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 24}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or persons acting in a fiduciary capacity, or nonprofit corporations; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Its income is not exempt from taxation under the laws of either the United States or the state of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthorized unincorporated nonprofit association\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an unincorporated nonprofit association to which all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members do not exceed twenty-five in number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members are all natural persons or persons acting in a fiduciary capacity for the benefit of a natural person or unincorporated nonprofit association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBeneficial ownership\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes interests held by a nonresident alien individual directly or indirectly holding or acquiring a ten percent or greater share in the partnership, limited partnership, corporation, limited liability company, or trust, or directly or indirectly through two or more such entities. In addition, the term beneficial ownership shall include interests held by all nonresident alien individuals if the nonresident alien individuals in the aggregate directly or indirectly hold or acquire twenty-five percent or more of the partnership, limited partnership, corporation, limited liability company, or trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCorporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a domestic or foreign corporation subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 490}}}{{\f5\fs18\hyphpar0\qj{, a nonprofit corporation, or a cooperative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFamily farm corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a corporation:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Founded for the purpose of farming and the ownership of agricultural land in which the majority of the voting stock is held by and the majority of the stockholders are persons related to each other as spouse, parent, grandparent, lineal ascendants of grandparents or their spouses and other lineal descendants of the grandparents or their spouses, or persons acting in a fiduciary capacity for persons so related;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of its stockholders are natural persons or persons acting in a fiduciary capacity for the benefit of natural persons or family trusts as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 13}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sixty percent of the gross revenues of the corporation over the last consecutive three-year period comes from farming.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFamily farm limited liability company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a limited liability company which meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The limited liability company is founded for the purpose of farming and the ownership of agricultural land in which the majority of the members are persons related to each other as spouse, parent, grandparent, lineal ascendants of grandparents or their spouses and other lineal descendants of the grandparents or their spouses, or persons acting in a fiduciary capacity for persons so related.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of the members of the limited liability company are natural persons or persons acting in a fiduciary capacity for the benefit of natural persons or family trusts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sixty percent of the gross revenues of the limited liability company over the last consecutive three-year period comes from farming.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFamily farm limited partnership\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a limited partnership which meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The limited partnership is formed for the purpose of farming and the ownership of agricultural land in which the general partner and a majority of the partnership interest is held by and the majority of limited partners are persons related to each other as spouse, parent, grandparent, lineal ascendants of grandparents or their spouses and other lineal descendants of the grandparents or their spouses, or persons acting in a fiduciary capacity for persons so related.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general partner manages and supervises the day-to-day farming operations on the agricultural land.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of the limited partners are natural persons or persons acting in a fiduciary capacity for the benefit of natural persons or family trusts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sixty percent of the gross revenues of the partnership over the last consecutive three-year period comes from farming.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFamily farm unincorporated nonprofit association\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an unincorporated nonprofit association to which all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The association is founded for the purpose of farming and the ownership of agricultural land and the majority of the members are persons related to each other as spouse, parent, grandparent, lineal ascendants of grandparents or their spouses and other lineal descendants of the grandparents or their spouses, or persons acting in a fiduciary capacity for persons so related.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of its members are natural persons or persons acting in a fiduciary capacity for the benefit of natural persons or family trusts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sixty percent of the gross revenues of the unincorporated nonprofit association over the last consecutive three-year period comes from farming.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFamily trust\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a trust:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In which a majority interest in the trust is held by and the majority of the beneficiaries are persons related to each other as spouse, parent, grandparent, lineal ascendants of grandparents or their spouses and other lineal descendants of the grandparents or their spouses, or persons acting in a fiduciary capacity for persons so related; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In which all the beneficiaries are natural persons, who are not acting as a trustee or in a similar capacity for a trust, as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 24}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or persons acting in a fiduciary capacity, or nonprofit corporations; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the trust is established on or after July 1, 1988, the trust must be established for the purpose of farming and sixty percent of the gross revenues of the trust over the last consecutive three-year period must come from farming.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFarming\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the cultivation of land for the production of agricultural crops, the raising of poultry, the production of eggs, the production of milk, the production of fruit or other horticultural crops, grazing or the production of livestock. Farming shall not include the production of timber, forest products, nursery products, or sod and farming shall not include a contract where a processor or distributor of farm products or supplies provides spraying, harvesting or other farm services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFiduciary capacity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an undertaking to act as executor, administrator, personal representative, guardian, conservator or receiver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGrantor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a natural person, other than a nonresident alien as defined under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, who is the creator of a revocable trust or a trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndirect\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means to act or attempt to accomplish an act through an interest in a business association, through one or more affiliates or intermediaries, or by any method other than a direct approach, including by any circuitous or oblique method.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLimited liability company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a limited liability company as defined in }}}{{\f5\fs18\hyphpar0\qj{section 489.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLimited partnership\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a limited partnership as defined in }}}{{\f5\fs18\hyphpar0\qj{section 488.102}}}{{\f5\fs18\hyphpar0\qj{, or a limited liability limited partnership under }}}{{\f5\fs18\hyphpar0\qj{chapter 488}}}{{\f5\fs18\hyphpar0\qj{, which owns or leases agricultural land or is engaged in farming.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNonprofit corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation as defined in }}}{{\f5\fs18\hyphpar0\qj{section 504.141}}}{{\f5\fs18\hyphpar0\qj{ that is not a foreign corporation as described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A foreign corporation as defined in }}}{{\f5\fs18\hyphpar0\qj{section 504.141}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNonresident alien\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who is not a citizen of the United States and who is not domiciled in the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation incorporated under the law of any foreign country.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation organized in the United States, beneficial ownership of which is held, directly or indirectly, by nonresident alien individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trust organized in the United States or elsewhere if beneficial ownership is held, directly or indirectly, by nonresident alien individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A partnership or limited partnership organized in the United States or elsewhere if beneficial ownership is held, directly or indirectly, by nonresident alien individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A limited liability company organized in the United States or elsewhere, beneficial ownership of which is held, directly or indirectly, by nonresident alien individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRevocable trust\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a trust which provides that the grantor retains the power to amend, modify, or revoke the trust at any time prior to the death of the grantor, regardless of whether, subsequent to the execution of the revocable trust and at any time prior to death, the grantor is legally competent to exercise the power to amend, modify, or revoke the trust and regardless of when the trust is created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTestamentary trust\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a trust created by devising or bequeathing property in trust in a will as such terms are used in the Iowa trust code as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 633A}}}{{\f5\fs18\hyphpar0\qj{. Testamentary trust includes a revocable trust that has not been revoked prior to the grantor\u8217\'3fs death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTrust\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a fiduciary relationship with respect to property, subjecting the person by whom the property is held to equitable duties to deal with the property for the benefit of another person, which arises as a result of a manifestation of an intention to create it. Trust does not include a person acting in a fiduciary capacity, as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 15}}}{{\f5\fs18\hyphpar0\qj{, or a revocable trust. A trust includes a legal entity holding property as trustee, agent, escrow agent, attorney in fact, and in any similar capacity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnincorporated nonprofit association\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 501B.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7172C.1}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1103, \'a71108}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1191, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 172, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1151, \'a72 \u8211\'3f 4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a79H.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 39, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1153, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 169, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1024, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1048, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1095, \'a71 \u8211\'3f 3, 10 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 115, \'a711, 16, 19}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1049, \'a7191}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7350, 351, 394, 400}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 38, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1162, \'a7123, 154, 155}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1112, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1136, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a79H.4}}}{{\f5\fs12\hyphpar0\qj{, 9H.5}}}{{\f5\fs12\hyphpar0\qj{, 10.1}}}{{\f5\fs12\hyphpar0\qj{, 10B.1}}}{{\f5\fs12\hyphpar0\qj{, 10D.1}}}{{\f5\fs12\hyphpar0\qj{, 15E.202}}}{{\f5\fs12\hyphpar0\qj{, 16.58}}}{{\f5\fs12\hyphpar0\qj{, 68A.406}}}{{\f5\fs12\hyphpar0\qj{, 161A.42}}}{{\f5\fs12\hyphpar0\qj{, 202.1}}}{{\f5\fs12\hyphpar0\qj{, 425A.2}}}{{\f5\fs12\hyphpar0\qj{, 428A.1}}}{{\f5\fs12\hyphpar0\qj{, 468.327}}}{{\f5\fs12\hyphpar0\qj{, 476C.1}}}{{\f5\fs12\hyphpar0\qj{, 501.101}}}{{\f5\fs12\hyphpar0\qj{, 511.8A}}}{{\f5\fs12\hyphpar0\qj{, 558.44}}}{{\f5\fs12\hyphpar0\qj{, 561.22}}}{{\f5\fs12\hyphpar0\qj{, 579B.1}}}{{\f5\fs12\hyphpar0\qj{, 654.2A}}}{{\f5\fs12\hyphpar0\qj{, 654.14}}}{{\f5\fs12\hyphpar0\qj{, 654.19}}}{{\f5\fs12\hyphpar0\qj{, 654A.1}}}{{\f5\fs12\hyphpar0\qj{, 654A.4}}}{{\f5\fs12\hyphpar0\qj{, 654B.1}}}{{\f5\fs12\hyphpar0\qj{, 673A.3}}}{{\f5\fs12\hyphpar0\qj{, 715E.1}}}{{\f5\fs12\hyphpar0\qj{, 717A.1}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{9H.2 and 9H.3}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{9H.3A}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalties \u8212\'3f injunctive relief.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The courts of this state may prevent and restrain violations of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ through the issuance of an injunction. The attorney general or a county attorney shall institute suits on behalf of the state to prevent and restrain violations of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 115, \'a712, 19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{9H.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restrictions on certain corporations, limited liability companies, trusts, and unincorporated nonprofit associations \u8212\'3f exceptions \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation, limited liability company, trust, or unincorporated nonprofit association, other than a family farm corporation, authorized farm corporation, family farm limited liability company, authorized limited liability company, family trust, authorized trust, revocable trust, testamentary trust, family farm unincorporated nonprofit association, or authorized unincorporated nonprofit association shall not, either directly or indirectly, acquire or otherwise obtain or lease any agricultural land in this state. However, the restrictions provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A bona fide encumbrance taken for purposes of security.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agricultural land acquired for research or experimental purposes. Agricultural land is used for research or experimental purposes if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Research and experimental activities are undertaken on the agricultural land and commercial sales of products produced from farming the agricultural land do not occur or are incidental to the research or experimental purposes of the corporation or limited liability company. Commercial sales are incidental to the research or experimental purposes of the corporation or limited liability company when such sales are less than twenty-five percent of the gross sales of the primary product of the research.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The agricultural land is used for the primary purpose of testing, developing, or producing seeds or plants for sale or resale to farmers as seed stock. Grain which is not sold as seed stock is an incidental sale and must be less than twenty-five percent of the gross sales of the primary product of the research and experimental activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The agricultural land is used by a corporation or limited liability company, including any trade or business which is under common control, as provided in 26 U.S.C. \'a7414 for the primary purpose of testing, developing, or producing animals for sale or resale to farmers as breeding stock. However, after July 1, 1989, to qualify under this subparagraph division, the following conditions must be satisfied:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation or limited liability company must not hold the agricultural land other than as a lessee. The term of the lease must be for not more than twelve years. The corporation or limited liability company shall not renew a lease. The corporation or limited liability company shall not enter into a lease under this subparagraph subdivision, if the corporation or limited liability company has ever entered into another lease under this subparagraph (3), whether or not the lease is in effect. However, this subparagraph subdivision does not apply to a nonprofit corporation as defined in }}}{{\f5\fs18\hyphpar0\qj{section 9H.1, subsection 20}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A term or condition of sale, including resale, of breeding stock must not relate to the direct or indirect control by the corporation or limited liability company of the breeding stock or breeding stock progeny subsequent to the sale.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of acres of agricultural land held by the corporation or limited liability company must not exceed six hundred forty acres.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation or limited liability company must deliver a copy of the lease to the secretary of state. The secretary of state shall notify the lessee of receipt of the copy of the lease. However, this subparagraph division does not apply to a nonprofit corporation as defined in }}}{{\f5\fs18\hyphpar0\qj{section 9H.1, subsection 20}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Culls and test animals may be sold under this subparagraph (3). For a three-year period beginning on the date that the corporation or limited liability company acquires an interest in the agricultural land, the gross sales for any year shall not be greater than five hundred thousand dollars. After the three-year period ends, the gross sales for any year shall not be greater than twenty-five percent of the gross sales for that year of the breeding stock, or five hundred thousand dollars, whichever is less.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agricultural land, including a leasehold interest, acquired by a nonprofit corporation as defined in }}}{{\f5\fs18\hyphpar0\qj{section 9H.1, subsection 20}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, including land acquired and operated by or for a state university for research, experimental, demonstration, foundation seed increase or test purposes and land acquired and operated by or for nonprofit corporations organized specifically for research, experimental, demonstration, foundation seed increase or test purposes in support of or in conjunction with a state university.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agricultural land acquired by a corporation or limited liability company for immediate or potential use in nonfarming purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agricultural land acquired by a corporation or limited liability company by process of law in the collection of debts, or pursuant to a contract for deed executed prior to August 15, 1975, or by any procedure for the enforcement of a lien or claim thereon, whether created by mortgage or otherwise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipal corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agricultural land which is acquired by a trust company or bank in a fiduciary capacity or as trustee for a family trust, authorized trust or testamentary trust or for nonprofit corporations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation or its subsidiary organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 490}}}{{\f5\fs18\hyphpar0\qj{ or a limited liability company organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 489}}}{{\f5\fs18\hyphpar0\qj{ and to which }}}{{\f5\fs18\hyphpar0\qj{section 312.8}}}{{\f5\fs18\hyphpar0\qj{ is applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agricultural land held or leased by a corporation on July 1, 1975, as long as the corporation holding or leasing the land on this date continues to hold or lease such agricultural land.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agricultural land held or leased by a trust on July 1, 1977, as long as the trust holding or leasing such land on this date continues to hold or lease such agricultural land.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agricultural land acquired by a trust for immediate use in nonfarming purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agricultural land that is owned, leased, or otherwise held by an unincorporated nonprofit association on July 1, 2010, as long as the unincorporated nonprofit association continues to hold or lease such agricultural land.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation, limited liability company, trust, or unincorporated nonprofit association, other than a family farm corporation, authorized farm corporation, family farm limited liability company, authorized limited liability company, family trust, authorized trust, revocable trust, testamentary trust, family farm unincorporated nonprofit association, or authorized unincorporated nonprofit association, violating }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be assessed a civil penalty of not more than twenty-five thousand dollars and shall divest itself of any land held in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ within one year after judgment. The courts of this state may prevent and restrain violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ through the issuance of an injunction. The attorney general or a county attorney shall institute suits on behalf of the state to prevent and restrain violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7172C.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 311, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 172, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a79H.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 39, \'a77 \u8211\'3f 13}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1153, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1049, \'a7191}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7394}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7116}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1162, \'a7124, 154, 155}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1112, \'a735 \u8211\'3f 37}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1136, \'a72, 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a79I.3}}}{{\f5\fs12\hyphpar0\qj{, 10.3}}}{{\f5\fs12\hyphpar0\qj{, 10.5}}}{{\f5\fs12\hyphpar0\qj{, 10.7}}}{{\f5\fs12\hyphpar0\qj{, 10.10}}}{{\f5\fs12\hyphpar0\qj{, 10B.7}}}{{\f5\fs12\hyphpar0\qj{, 15E.207}}}{{\f5\fs12\hyphpar0\qj{, 501.103}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional exceptions to restrictions for entities organized under chapters }{{\f5\fs12\hyphpar0\qj{10}}}{, }{{\f5\fs12\hyphpar0\qj{10D}}}{, and }{{\f5\fs12\hyphpar0\qj{501}}}{; requirements; see \'a7}{{\f5\fs12\hyphpar0\qj{10.3}}}{, }{{\f5\fs12\hyphpar0\qj{10D.2}}}{, and }{{\f5\fs12\hyphpar0\qj{501.103}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{9H.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restrictions on authorized farm corporations, authorized limited liability companies, authorized trusts, limited partnerships, and authorized unincorporated nonprofit associations \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized farm corporation, authorized limited liability company, or authorized trust shall not, on or after July 1, 1987, a limited partnership other than a family farm limited partnership shall not, on or after July 1, 1988, and an authorized unincorporated nonprofit association shall not, on or after July 1, 2010, either directly or indirectly, acquire or otherwise obtain or lease agricultural land, if the total agricultural land either directly or indirectly owned or leased by the authorized farm corporation, authorized limited liability company, limited partnership, authorized trust, or authorized unincorporated nonprofit association would then exceed one thousand five hundred acres.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, the restrictions provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ do not apply to agricultural land that is leased by an authorized farm corporation, authorized trust, limited partnership, or authorized unincorporated nonprofit association to the immediate prior owner of the land for the purpose of farming, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 9H.1}}}{{\f5\fs18\hyphpar0\qj{. Upon cessation of the lease to the immediate prior owner, the authorized farm corporation, authorized trust, limited partnership, or authorized unincorporated nonprofit association shall, within three years following the date of the cessation, sell or otherwise dispose of the agricultural land leased to the immediate prior owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ also does not apply to land that is held or acquired and maintained by an authorized farm corporation, authorized trust, limited partnership, or authorized unincorporated nonprofit association to protect significant elements of the state\u8217\'3fs natural open space heritage, including but not limited to significant river, lake, wetland, prairie, forest areas, other biologically significant areas, land containing significant archaeological, historical, or cultural value, or fish or wildlife habitats, as defined in rules adopted by the department of natural resources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not, after July 1, 1988, become a stockholder of an authorized farm corporation, a beneficiary of an authorized trust, a member of an authorized limited liability company, or a limited partner in a limited partnership which owns or leases agricultural land if the person is also any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A stockholder of an authorized farm corporation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A beneficiary of an authorized trust.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A limited partner in a limited partnership which owns or leases agricultural land.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of an authorized limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to limited partners in a family farm limited partnership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not, after July 1, 2010, become a member of an authorized unincorporated nonprofit association that owns or leases agricultural land if the person is also any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A stockholder of an authorized farm corporation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A beneficiary of an authorized trust.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A limited partner in a limited partnership which owns or leases agricultural land.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of an authorized limited liability company.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of another authorized unincorporated nonprofit association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not, after July 1, 2010, become a stockholder of an authorized farm corporation, a beneficiary of an authorized trust, a limited partner in a limited partnership, or a member of an authorized limited liability company that owns or leases agricultural land, if the person is a member of an authorized unincorporated nonprofit association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to limited partners in a family farm limited partnership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized farm corporation, authorized trust, authorized limited liability company, limited partnership, or authorized unincorporated nonprofit association violating }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be assessed a civil penalty of not more than twenty-five thousand dollars and shall divest itself of any land held in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ within one year after judgment. A civil penalty of not more than one thousand dollars may be imposed on a person who becomes a stockholder of an authorized farm corporation, beneficiary of an authorized trust, member of an authorized limited liability company, limited partner in a limited partnership, or member in an authorized unincorporated nonprofit association in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The person shall divest the interest held by the person in the corporation, trust, limited liability company, limited partnership, or authorized unincorporated nonprofit association to comply with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The court may determine the method of divesting an interest held by a person found to be in violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. A financial gain realized by a person who disposes of an interest held in violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be forfeited to the state\u8217\'3fs general fund. All court costs and fees shall be paid by the person holding the interest in violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The courts of this state may prevent and restrain violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ through the issuance of an injunction. The attorney general or a county attorney shall institute suits on behalf of the state to prevent and restrain violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fauthorized trust\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a revocable trust.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 146, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS87, \'a7172C.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1191, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 172, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a79H.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 39, \'a714 \u8211\'3f 16}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1153, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1112, \'a738 \u8211\'3f 40}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a710.3}}}{{\f5\fs12\hyphpar0\qj{, 10.5}}}{{\f5\fs12\hyphpar0\qj{, 10.7}}}{{\f5\fs12\hyphpar0\qj{, 10.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{9H.5A}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0115.pdf" }{\fldrslt \cf5 \f5 \fs18{{2003 Acts, ch 115, \'a717, 19}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}}