\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F477}{\*\bkmkend codeChapter_5F477}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 477}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{TELEGRAPH AND TELEPHONES \u8212\'3f CABLE SYSTEMS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7476.27}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E1_2E2}{GENERAL PROVISIONS}{\*\bkmkend stylerid1_2E5_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Right-of-way.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person, firm, and corporation, within or without the state, may construct a telegraph or telephone line or cable system along the public roads of the state, or across or under the rivers or over, under, or through any lands belonging to the state or any private individual, and may erect or install necessary fixtures. However, construction of a telegraph or telephone line or cable system along a primary road is subject to rules adopted by the state department of transportation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7780; R60, \'a71348; C73, \'a71324; C97, \'a72158; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8300;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.1; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1173, \'a71}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Authorization in cities, }{{\f5\fs12\hyphpar0\qj{\'a7364.2}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.2}}}{\*\bkmkstart stylerid1_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Removal of lines and cable systems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When any road along which the telegraph or telephone line or cable system has been constructed or installed is changed, the person, firm or corporation shall, upon ninety days\u8217\'3f notice in writing, remove the telegraph or telephone lines or cable system to the road as established. The notice may be served upon any agent or operator in the employ of the person, firm or corporation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a71324; C97, \'a72158; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8301;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.2; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1173, \'a72}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Removal from highway, }{{\f5\fs12\hyphpar0\qj{\'a7318.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.3}}}{\*\bkmkstart stylerid1_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Construction \u8212\'3f installation \u8212\'3f damages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The fixtures shall not be constructed or installed in a manner which causes inconvenience to the public in the use of any road or in the navigation of any stream; nor shall they be erected or installed on the private grounds of any individual without paying the individual a just equivalent for the damage the individual sustains by the construction or installation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7781; R60, \'a71349; C73, \'a71325; C97, \'a72159; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8302;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.3; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1173, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.4}}}{\*\bkmkstart stylerid1_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Condemnation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the person over or through whose lands this telegraph or telephone line or cable system passes claims more damages than the proprietor of the line or cable system is willing to pay, the amount of damages sustained may be determined in the same manner as provided for taking private property for works of internal improvement.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7782; R60, \'a71350; C73, \'a71326; C97, \'a72160; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8303;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.4; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1173, \'a74}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Condemnation procedure, }{{\f5\fs12\hyphpar0\qj{chapter 6B}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.5}}}{\*\bkmkstart stylerid1_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Equal facilities \u8212\'3f delay.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the proprietor of any telegraph or telephone line within the state, or the person having the control and management thereof, refuses to furnish equal facilities to the public and to all connecting lines for the transmission of communications in accordance with the nature of the business which it undertakes to carry on, or to transmit the same with fidelity and without unreasonable delay, the law in relation to limited partnerships, corporations, and to the taking of private property for works of internal improvement, shall no longer apply to them, and property taken for the use thereof without the consent of the owner may be recovered by the owner.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7783; R60, \'a71351; C73, \'a71327; C97, \'a72161; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8304;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.5; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a763}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.6}}}{\*\bkmkstart stylerid1_2E5_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Delay \u8212\'3f willful error \u8212\'3f revealing contents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person employed in transmitting messages by telegraph or telephone must do so with fidelity and without unreasonable delay, and if anyone willfully fails thus to transmit them, or intentionally transmits a message erroneously, or makes known the contents of any message sent or received to any person except the person to whom it is addressed, or such person\u8217\'3fs agent or attorney, or willfully and wrongfully takes or receives any telegraph or telephone message, the person is guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7784; R60, \'a71352; C73, \'a71328; C97, \'a72162; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8305;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.6; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.7}}}{\*\bkmkstart stylerid1_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mistakes and delays.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The proprietor of a telegraph or telephone line is liable for all mistakes in transmitting or receiving messages made by any person in the proprietor\u8217\'3fs employment, or for any unreasonable delay in their transmission or delivery, and for all damages resulting from failure to perform the foregoing or any other duty required by law, the provisions of any contract to the contrary notwithstanding.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7785; R60, \'a71353; C73, \'a71329; C97, \'a72163; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8306;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.7; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.7}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7477.9A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.8}}}{\*\bkmkstart stylerid1_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Negligence presumed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In any action against any telegraph or telephone company for damages caused by erroneous transmission of a message, or by unreasonable delay in delivery of a message, negligence on the part of the telegraph or telephone company shall be presumed upon proof of erroneous transmission or of unreasonable delay in delivery, and the burden of proof that such error or delay was not due to negligence upon its part shall rest upon such company.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72164; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8307;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.8; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.9}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presentation of claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No action for the recovery of such damages shall be maintained unless a claim therefor is presented in writing to such company, officer or agent thereof within sixty days from time cause of action accrues.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72164; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8308;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.9; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.9A}}}{\*\bkmkstart stylerid1_2E5_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deregulated services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A telegraph or telephone company whose services are deregulated by the commission under }}}{{\f5\fs18\hyphpar0\qj{section 476.1D}}}{{\f5\fs18\hyphpar0\qj{ may use public notice as a means of conveying terms and conditions to customers where identification of those customers is infeasible or impractical. Public notice may also be used to convey changes in terms and conditions, other than price increases or limitations of liability, to all other customers, but only if those customers were put on notice that this means would be used to convey subsequent changes. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 477.7}}}{{\f5\fs18\hyphpar0\qj{, when services are deregulated by the commission under }}}{{\f5\fs18\hyphpar0\qj{section 476.1D}}}{{\f5\fs18\hyphpar0\qj{, a telegraph or telephone company, in any contract, agreement, or by means of public notice, may reasonably limit its liability under }}}{{\f5\fs18\hyphpar0\qj{section 477.7}}}{{\f5\fs18\hyphpar0\qj{ in the course of providing the deregulated communications services to its customers, except for acts of willful misconduct. However, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not allow a greater limitation on liability than exists in any contract or approved tariff as of the effective date of the deregulation of the services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A telephone company whose services are subject to regulation by the commission with respect to terms and conditions, but not rates, shall give notice of rate changes to customers.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 321, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a798}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1099, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369}}}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E1_2E2}{RECIPROCAL SERVICE}{\*\bkmkend stylerid1_2E6_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.10}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal exchange\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, within the meaning of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, shall refer to a telephone line or lines or to a telephone switchboard or switchboards operating by virtue of a franchise granted by a city furnishing telephonic communication between two or more members of the public within the same city, village, community, locality or neighborhood, which said line or lines or switchboard or switchboards shall be under the same management and control.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal exchange\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ within the meaning of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall not include or refer to privately owned or leased lines or switchboards, operated and used by members of the public other than telephone or telegraph companies as a public utility by which the public is offered telephonic service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal exchange company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ within the meaning of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, shall refer to any one or more individuals, firms or corporations operating one or more local exchanges as defined in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLong distance company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ within the meaning of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall refer to and include one or more persons, firms or corporations operating connecting lines between two or more local exchanges, one or more of which local exchanges are owned by a local telephone company other than such person, firm or corporation, over which line or lines telephonic communication is had between members of the public connected with said local exchanges.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a78308-f1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8308.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.10; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 90, \'a7142}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7423.3}}}{{\f5\fs12\hyphpar0\qj{, 714A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.11}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Facilities to local exchange.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Long distance companies shall furnish equal facilities to any local exchange within the state desiring same, and to that end shall immediately make, or at the option of the long distance company, shall immediately permit to be made under its direction and at reasonably accessible places to be designated by such long distance company, the necessary connections between said local exchange and said long distance company telephone system to effect the furnishing of equal facilities to such local exchange.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a78308-f2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8308.2;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.11; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.12}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Transmission of messages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{After such connection has been made said long distance company shall transmit communications and messages to, from and through all local exchanges connected with its system when requested, with fidelity and equality and without discrimination or unreasonable delay.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a78308-f3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8308.3;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.12; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.13}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Facilities to long distance companies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A connected local exchange company shall accept and furnish telephonic connection for all messages offered over the lines or through the system of any long distance company without discrimination or unreasonable delay, and with equality.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a78308-f4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8308.4;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.13; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{477.14}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations \u8212\'3f effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Should any local exchange company or long distance company refuse or fail to furnish the connection or service above required, the law in relation to limited partnerships, corporations, or the taking of private property for works of internal improvement shall no longer apply to them and property taken for the use thereof without the consent of the owner may be recovered by the owner.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a78308-f5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8308.5;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7488.14; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7477.14}}}{]}\par}}