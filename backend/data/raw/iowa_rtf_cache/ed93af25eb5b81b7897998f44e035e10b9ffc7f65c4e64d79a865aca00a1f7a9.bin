\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F299}{\*\bkmkend codeChapter_5F299}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 299}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{COMPULSORY EDUCATION}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7135.105D}}}{{\f5\fs12\qc{, 232C.4}}}{{\f5\fs12\qc{, 234.4}}}{{\f5\fs12\qc{, 256.9}}}{{\f5\fs12\qc{, 256B.6}}}{{\f5\fs12\qc{, 274.3}}}{{\f5\fs12\qc{, 299A.1}}}{{\f5\fs12\qc{, 714.19}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Attendance requirements }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ attendance policies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 299.2}}}{{\f5\fs18\hyphpar0\qj{, the parent, guardian, or legal or actual custodian of a child who is of compulsory attendance age shall cause the child to attend some public school or an accredited nonpublic school, or place the child under competent private instruction or independent private instruction in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 299A}}}{{\f5\fs18\hyphpar0\qj{, during a school year, as defined under }}}{{\f5\fs18\hyphpar0\qj{section 279.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a public school district or the governing body of an accredited nonpublic school shall set the number of days or hours of required attendance for the schools under its control.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a public school district or the governing body of an accredited nonpublic school may, by resolution, require attendance for the entire time when the schools are in session in any school year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a public school district shall adopt a policy related to absenteeism and truancy. The policy may contain attendance requirements that are more stringent than the attendance requirements established under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a public school district shall adopt a policy or rules relating to children who are chronically absent. The policy or rules must contain provisions that clearly explain all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{How the board of directors determines whether a child is chronically absent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The different interventions that the board of directors may use when a child is chronically absent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The different penalties associated with a child being chronically absent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy or rules adopted by the board of directors of a public school district pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ must not apply to any child:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who has completed the requirements for graduation in a public school district or has obtained a high school equivalency diploma under }}}{{\f5\fs18\hyphpar0\qj{chapter 259A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who is excused for sufficient reason by any court of record or judge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While attending religious services or receiving religious instructions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who is unable to attend school due to legitimate medical reasons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who has an individualized education program that affects the child\u8217\'3fs attendance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who has a plan under section 504 of the federal }}}{{\f5\fs18\hyphpar0\qj{Rehabilitation Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7794}}}{{\f5\fs18\hyphpar0\qj{, that affects the child\u8217\'3fs attendance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who is a military applicant undergoing military entrance processing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who is engaged in military service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who is traveling to attend a funeral.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who is traveling to attend a wedding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While attending a course in religious instruction pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 299.1D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policy or rules adopted by the board of directors of a public school district pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ must describe how the exceptions described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may be met by a child and must give reasonable consideration to travel time.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4410;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 17, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 6, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1087, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1259, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 200, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a783, 85, 91}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1152, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 52, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 143, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7234.4}}}{{\f5\fs12\hyphpar0\qj{, 279.10}}}{{\f5\fs12\hyphpar0\qj{, 299.1D}}}{{\f5\fs12\hyphpar0\qj{, 299.2}}}{{\f5\fs12\hyphpar0\qj{, 299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.8}}}{{\f5\fs12\hyphpar0\qj{, 299.11}}}{{\f5\fs12\hyphpar0\qj{, 299A.1}}}{{\f5\fs12\hyphpar0\qj{, 321.178A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See Code editor\u8217\'3fs note on simple harmonization at the beginning of this Code volume}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4, paragraph b, NEW subparagraphs (7) \u8211\'3f (11)}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4, NEW paragraph c}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Compulsory attendance age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{ subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{, a child who has reached the age of six and is under sixteen years of age by September 15 is of compulsory attendance age. However, if a child enrolled in a school district or accredited nonpublic school reaches the age of sixteen on or after September 15, the child remains of compulsory age until the end of the regular school calendar.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who has reached the age of five by September 15 and who is enrolled in a school district shall be considered to be of compulsory attendance age unless the parent or guardian of the child notifies the school district in writing of the parent\u8217\'3fs or guardian\u8217\'3fs intent to remove the child from enrollment in the school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who has reached the age of four by September 15 and who is enrolled in the statewide preschool program under }}}{{\f5\fs18\hyphpar0\qj{chapter 256C}}}{{\f5\fs18\hyphpar0\qj{ shall be considered to be of compulsory attendance age unless the parent or guardian of the child submits written notice to the school district implementing the program of the parent\u8217\'3fs or guardian\u8217\'3fs intent to remove the child from enrollment in the preschool program.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 110, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1119, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 78, \'a72, 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256C.3}}}{{\f5\fs12\hyphpar0\qj{, 299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.11}}}{{\f5\fs12\hyphpar0\qj{, 299A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.1B}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Failure to attend }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ driver\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person who is of compulsory attendance age who does not meet the requirements for an exception under }{{\f5\fs18\hyphpar0\qj{section 299.2}}}{, who does not attend a public school or an accredited nonpublic school, who is not receiving competent private instruction or independent private instruction in accordance with the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 299A}}}{, and who does not attend an alternative school or adult education classes, shall not receive an intermediate or full driver\u8217\'3fs license until age eighteen.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1172, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a792}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.11}}}{{\f5\fs12\hyphpar0\qj{, 299A.1}}}{{\f5\fs12\hyphpar0\qj{, 321.213B}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Restricted work license, see }{{\f5\fs12\hyphpar0\qj{\'a7321.178}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.1C}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county attorney of the county in which the public school\u8217\'3fs or accredited nonpublic school\u8217\'3fs central administrative office is located shall be responsible for the enforcement of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, as described in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Actions instituted by a county attorney pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be instituted in the county in which the public school\u8217\'3fs or accredited nonpublic school\u8217\'3fs central administrative office is located.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1152, \'a715}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.11}}}{{\f5\fs12\hyphpar0\qj{, 299A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.1D}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Absences related to courses in religious instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 299.1}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a child while the child is attending a course in religious instruction that is provided by a private organization if all of the following requirements are satisfied:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or legal or actual custodian of the child, if the child is not an emancipated minor, or the child, if the child is an emancipated minor, must submit a notification to the public school or accredited nonpublic school informing the school that the child will attend a course in religious instruction during the school day.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The course in religious instruction must not require the child to be absent from school for more than five hours per week.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The private organization that provides the course in religious instruction must maintain attendance records and must make the attendance records available to the school district or accredited nonpublic school to verify when the child is attending a course in religious instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transportation related to the course in religious instruction must be provided by the private organization, the child\u8217\'3fs parent, guardian, or legal or actual custodian, or the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The private organization must make provisions for and assume liability for the child while the child is attending the course in religious instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The school district or accredited nonpublic school must not expend any moneys related to the course in religious instruction, not including de minimis administrative costs associated with processing notifications received under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and tracking the child\u8217\'3fs attendance to ensure compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The course in religious instruction must not be held on school district property unless authorized by the board of directors of the school district pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 297.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child must agree to make up any school work that the child does not complete while attending the course in religious instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each school district and each accredited nonpublic school shall, upon the request of a child\u8217\'3fs parent, guardian, or legal or actual custodian, if the child is not an emancipated minor, or the child, if the child is an emancipated minor, excuse the child from attendance for at least one hour per week, but for not more than five hours per week, so that the child can attend a course in religious instruction if all of the requirements under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ are satisfied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child\u8217\'3fs parent, guardian, or legal or actual custodian of the child, if the child is not an emancipated minor, or the child, if the child is an emancipated minor, who alleges that a school district has violated }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may bring a civil action for injunctive relief and actual damages against the school district. If the child\u8217\'3fs parent, guardian, or legal or actual custodian, or the child, is the prevailing party in a civil action instituted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the court shall award reasonable court costs and attorney fees to the child\u8217\'3fs parent, guardian, or legal or actual custodian, or the child, as applicable.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 143, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 159, \'a713}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.1}}}{{\f5\fs12\hyphpar0\qj{, 299.2}}}{{\f5\fs12\hyphpar0\qj{, 299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.11}}}{{\f5\fs12\hyphpar0\qj{, 299.12}}}{{\f5\fs12\hyphpar0\qj{, 299A.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.2}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 299.1}}}{ shall not apply to any child:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who has completed the requirements for graduation in an accredited school or has obtained a high school equivalency diploma under }}}{{\f5\fs18\hyphpar0\qj{chapter 259A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who is excused for sufficient reason by any court of record or judge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While attending religious services or receiving religious instructions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who is attending a private college preparatory school accredited or probationally accredited under }}}{{\f5\fs18\hyphpar0\qj{section 256.11, subsection 13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who has been excused under }}}{{\f5\fs18\hyphpar0\qj{section 299.22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Who is exempted under }}}{{\f5\fs18\hyphpar0\qj{section 299.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While attending a course in religious instruction pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 299.1D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4411;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71490}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 143, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.1}}}{{\f5\fs12\hyphpar0\qj{, 299.1B}}}{{\f5\fs12\hyphpar0\qj{, 299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.8}}}{{\f5\fs12\hyphpar0\qj{, 299.11}}}{{\f5\fs12\hyphpar0\qj{, 299A.1}}}{{\f5\fs12\hyphpar0\qj{, 321.178}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 7}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.3}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports from accredited nonpublic schools.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Within ten days from receipt of notice from the secretary of the school district within which an accredited nonpublic school is conducted, the principal of the accredited nonpublic school shall, once during each school year, and at any time when requested in individual cases, furnish to the secretary of the public school district, within which the accredited nonpublic school is located, a certificate and report in duplicate on forms provided by the public school district of the names and ages of each pupil of the accredited nonpublic school who is of compulsory attendance age and the grade level of each pupil, during the preceding year and from the time of the last preceding report to the time at which a report is required. In addition, the report shall identify all students of compulsory attendance age who were truant as defined by law or school policy and the number of days of truancy for the period covered by the report, and children who dropped out, withdrew from enrollment, or transferred to another Iowa school and the date their attendance ceased at the accredited nonpublic school. The secretary shall retain one of the reports and file the other with the secretary of the area education agency.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4412;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 101, \'a7207}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.11}}}{{\f5\fs12\hyphpar0\qj{, 299A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.4}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports as to private instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent, guardian, or legal custodian of a child who is of compulsory attendance age, who places the child under competent private instruction under }}}{{\f5\fs18\hyphpar0\qj{section 299A.2}}}{{\f5\fs18\hyphpar0\qj{, not in an accredited school or a home school assistance program operated by a school district or accredited nonpublic school, shall furnish a report in duplicate on forms provided by the public school district, to the district by September 1 of the school year in which the child will be under competent private instruction. The secretary shall retain and file one copy and forward the other copy to the district\u8217\'3fs area education agency. The report shall state the name and age of the child, the period of time during which the child has been or will be under competent private instruction for the year, an outline of the course of study, texts used, and the name and address of the instructor. The parent, guardian, or legal custodian of a child, who is placing the child under competent private instruction for the first time, shall also provide the district with evidence that the child has had the immunizations required under }}}{{\f5\fs18\hyphpar0\qj{section 139A.8}}}{{\f5\fs18\hyphpar0\qj{, and, if the child is elementary school age, a blood lead test in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 135.105D}}}{{\f5\fs18\hyphpar0\qj{. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3foutline of course of study\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include subjects covered, lesson plans, and time spent on the areas of study.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A home school assistance program operated by a school district or accredited nonpublic school shall furnish a report on forms provided by the department. The report shall, at a minimum, state the name and age of the child and the period of time during the school year in which the child has been or will be under competent private instruction by the home school assistance program.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4413;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1259, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 200, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1135, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1066, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 79, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a7110}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a784 \u8211\'3f 86}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.11}}}{{\f5\fs12\hyphpar0\qj{, 299A.1}}}{{\f5\fs12\hyphpar0\qj{, 299A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.5}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Proof of mental or physical condition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The parent, guardian, or legal or actual custodian of a child who is of compulsory attendance age, who is physically or mentally unable to attend school, or whose presence in school would be injurious to the health of other pupils, shall furnish proofs by certificate under }{{\f5\fs18\hyphpar0\qj{sections 256B.6}}}{ and }{{\f5\fs18\hyphpar0\qj{256B.7}}}{ as to the physical or mental condition of the child.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4414;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1259, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7282.3}}}{{\f5\fs12\hyphpar0\qj{, 299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.11}}}{{\f5\fs12\hyphpar0\qj{, 299.22}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.5A}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mediation.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1152, \'a721}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.6}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ community service or fine or imprisonment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who violates the terms of an absenteeism prevention plan entered into under }}}{{\f5\fs18\hyphpar0\qj{section 299.12}}}{{\f5\fs18\hyphpar0\qj{, who is referred for prosecution under }}}{{\f5\fs18\hyphpar0\qj{section 299.12}}}{{\f5\fs18\hyphpar0\qj{ and is convicted of a violation of any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 299.1 through 299.5}}}{{\f5\fs18\hyphpar0\qj{, who violates any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 299.1 through 299.5}}}{{\f5\fs18\hyphpar0\qj{, or who refuses to participate in a school engagement meeting under }}}{{\f5\fs18\hyphpar0\qj{section 299.12}}}{{\f5\fs18\hyphpar0\qj{, commits a public offense.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A first offense is a simple misdemeanor and a conviction is punishable by imprisonment not exceeding ten days or a fine not exceeding one hundred dollars. The court may order the person to perform not more than forty hours of unpaid community service instead of any fine or imprisonment. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A second offense is a serious misdemeanor and a conviction is punishable by imprisonment not exceeding twenty days or a fine not exceeding five hundred dollars, or both a fine and imprisonment. The court may order the person to perform unpaid community service instead of any fine or imprisonment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A third or subsequent offense is a serious misdemeanor and a conviction is punishable by imprisonment not exceeding thirty days or a fine not exceeding one thousand dollars, or both a fine and imprisonment. The court may order the person to perform unpaid community service instead of any fine or imprisonment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If community service is imposed as part of a sentencing order, the court may require that part or all of the service be performed for a public school district or nonpublic school if the court finds that service in the school is appropriate under the circumstances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a parent, guardian, or legal or actual custodian of a child who is truant, has made reasonable efforts to comply with the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 299.1 through 299.5}}}{{\f5\fs18\hyphpar0\qj{, but is unable to cause the child to attend school, the parent, guardian, or legal or actual custodian may file an affidavit listing the reasonable efforts made by the parent, guardian, or legal or actual custodian to cause the child\u8217\'3fs attendance and the parent, guardian, or legal or actual custodian shall not be criminally liable for the child\u8217\'3fs nonattendance.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4415;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1259, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 200, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 174, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1043, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1152, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.6A}}}{{\f5\fs12\hyphpar0\qj{, 299.12}}}{{\f5\fs12\hyphpar0\qj{, 299A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.6A}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil penalty \u8212\'3f distribution of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of a criminal proceeding under }}}{{\f5\fs18\hyphpar0\qj{section 299.6}}}{{\f5\fs18\hyphpar0\qj{, a county attorney may bring a civil action against a parent, guardian, or legal or actual custodian of a child who is of compulsory attendance age, has not completed educational requirements, and is truant, if the parent, guardian, or legal or actual custodian has failed to cause the child to attend a public school or an accredited nonpublic school, or to place the child under competent private instruction or independent private instruction in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If the court finds that the parent, guardian, or legal or actual custodian has failed to cause the child to attend as required in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court shall assess a civil penalty of not less than one hundred but not more than one thousand dollars for each violation established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Funds received from civil penalties assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be paid to the school district of residence or school district of enrollment, if open enrolled, of the person against whom the court assessed the penalty. The school district shall use moneys received under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to support programs for students who meet the definition of at-risk children adopted by the department of education.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 174, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1043, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a763}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.7}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Custody of records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All such certificates, reports, and proofs shall be filed and preserved in the office of the secretary of the school corporation as a part of the records of the office, and the secretary shall furnish certified copies thereof to any person requesting the same.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-b, -c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4416;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.8}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{\u8220\'3fTruant\u8221\'3f defined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any child of compulsory attendance age, to whom the exceptions described in }{{\f5\fs18\hyphpar0\qj{section 299.1, subsection 4}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{, or }{{\f5\fs18\hyphpar0\qj{section 299.2}}}{ do not apply, who has been absent from school, for any reason, for at least twenty percent of the days or hours in the grading period, shall be deemed to be a truant. A finding that a child is truant, however, shall not by itself mean that the child is a child in need of assistance within the meaning of }{{\f5\fs18\hyphpar0\qj{chapter 232}}}{ and shall not be the sole basis for a child in need of assistance petition.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-e; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4417;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1152, \'a717}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7282.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.9}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Truants \u8212\'3f rules for punishment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board of directors of a public school district or the authorities in charge of an accredited nonpublic school shall prescribe reasonable rules for the punishment of truants.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-d, -h; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4418;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.10}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Truancy officers \u8212\'3f appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of each school district may appoint a truancy officer. The board of each school district, which does not appoint a truancy officer for the district, shall designate a suitable person to collect information on the numbers of children in the district who are truant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may appoint a member of the police force, marshal, teacher, school official, or other suitable person to serve as the district truancy officer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-e; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4419;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a7150}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.11}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of truancy officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The truancy officer may take into custody without warrant any apparently truant child and place the child in the charge of the school principal, or the principal\u8217\'3fs designee, designated by the board of directors of the school district in which the child resides, or in the charge of any nonpublic school or any authority providing competent private instruction or independent private instruction as defined in }}}{{\f5\fs18\hyphpar0\qj{section 299A.1}}}{{\f5\fs18\hyphpar0\qj{, designated by the parent, guardian, or legal or actual custodian; but if it is other than a public school, the instruction and maintenance of the child shall be without expense to the school district. If a child is taken into custody under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the truancy officer shall make every reasonable attempt to immediately notify the parent, guardian, or legal or actual custodian of the child\u8217\'3fs location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The truancy officer shall promptly institute proceedings against any person violating any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 299.1 through 299.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-e, -f; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4420;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a795}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1152, \'a718}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.12}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Failure to attend.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E22_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E22_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChronically absent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any absence from school for more than ten percent of the days or hours in the grading period established by a public school; provided, however, that an absence from school that is related to attending a course in religious instruction pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 299.1D}}}{{\f5\fs18\hyphpar0\qj{ shall not count toward this amount.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchool official\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an employee of a public school whose job duties involve identifying children who are at risk for becoming chronically absent, creating interventions to limit the rate of student absenteeism, and participating in the legal process related to student absenteeism.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E22_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E22_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Chronic absenteeism.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a child becomes chronically absent, a school official shall send a notice by ordinary mail or electronic mail to the county attorney of the county in which the public school\u8217\'3fs central administrative office is located, and a notice to the child\u8217\'3fs parent, guardian, or legal or actual custodian of the child, if the child is not an emancipated minor, or to the child, if the child is an emancipated minor, that includes information related to the child\u8217\'3fs absences from school and the policies and disciplinary processes associated with additional absences. The notice the school official sends to the child\u8217\'3fs parent, guardian, or legal or actual custodian of the child, if the child is not an emancipated minor, or to the child, if the child is an emancipated minor, may be sent by ordinary mail, electronic mail, or electronic message, or may be delivered in person. The school shall maintain a copy of the notice until the child graduates, turns twenty-one years of age, or is no longer enrolled in the school, whichever occurs first.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school official may send the notice described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ prior to a child at risk of becoming chronically absent if all of the following requirements are satisfied:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney of the county in which the public school\u8217\'3fs central administrative office is located and the board of directors of the public school agree to the amount of absences that will lead to the school official sending the notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of absences that will lead to the school official sending the notice is described in the school\u8217\'3fs student handbook.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E22_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E22_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{School engagement meeting.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a child is absent from school for greater than or equal to fifteen percent of the days or hours in the grading period, a school official shall attempt to find the cause for the child\u8217\'3fs absences. If the school official determines that the child\u8217\'3fs absences are negatively affecting the child\u8217\'3fs academic progress, the school official shall initiate and participate in a school engagement meeting. The purpose of the school engagement meeting is to identify the child\u8217\'3fs barriers to attendance and the interventions that may be used to improve the child\u8217\'3fs attendance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school official may initiate and participate in a school engagement meeting as provided in subparagraph (1) prior to a child being absent from school for greater than or equal to fifteen percent of the days or hours in a school calendar.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of the following individuals shall participate in the school engagement meeting:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child\u8217\'3fs parent, guardian, or legal or actual custodian, if the child is not an emancipated minor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school official.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During the school engagement meeting, the participants shall create and sign an agreement that shall be known as an absenteeism prevention plan. Each participant signing the absenteeism prevention plan shall receive a copy of the plan. The absenteeism prevention plan shall identify the causes of the child\u8217\'3fs absences and the future responsibilities of each participant related to the child\u8217\'3fs attendance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school official shall monitor the participants\u8217\'3f compliance with the terms of the absenteeism prevention plan. The school official shall contact the participants at least once each week during the remainder of the school calendar to monitor the performance of the participants under the plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During the school engagement meeting, the participants may initiate referrals to any services or counseling that the participants believe may be appropriate under the circumstances to improve the child\u8217\'3fs attendance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the participants in the school engagement meeting fail to enter into an absenteeism prevention plan, or if the child or the child\u8217\'3fs parent, guardian, or legal or actual custodian violates a term of the absenteeism prevention plan or fails to participate in the school engagement meeting, the county attorney may initiate a proceeding under }}}{{\f5\fs18\hyphpar0\qj{section 299.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ is not applicable to a child who is receiving competent private instruction or independent private instruction in accordance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 299A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 41, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 174, \'a75, 7}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1043, \'a77, 8, 10}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1152, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 52, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 143, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.6}}}{{\f5\fs12\hyphpar0\qj{, 299.13}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph a amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph a amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph a, subparagraph (1) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.13}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not disseminate or redisseminate information shared with the person pursuant to }{{\f5\fs18\hyphpar0\qj{section 299.12}}}{, unless specifically authorized to do so by }{{\f5\fs18\hyphpar0\qj{section 217.30}}}{ or }{{\f5\fs18\hyphpar0\qj{299.12}}}{. Unless a prohibited dissemination or redissemination of information is subject to injunction or sanction under other state or federal law, an action for judicial enforcement may be brought in accordance with }{{\f5\fs18\hyphpar0\qj{this section}}}{. An aggrieved person, the attorney general, or a county attorney may seek judicial enforcement of the requirements of }{{\f5\fs18\hyphpar0\qj{this section}}}{ in an action brought against the public school or accredited nonpublic school or any other person who has been granted access to information pursuant to }{{\f5\fs18\hyphpar0\qj{section 299.12}}}{. Suits to enforce }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be brought in the district court for the county in which the information was disseminated or redisseminated. Upon a finding by a preponderance of the evidence that a person has violated }{{\f5\fs18\hyphpar0\qj{this section}}}{, the court shall issue an injunction punishable by civil contempt ordering the person in violation of }{{\f5\fs18\hyphpar0\qj{this section}}}{ to comply with the requirements of, and to refrain from any violations of, }{{\f5\fs18\hyphpar0\qj{section 299.12}}}{ with respect to the dissemination or redissemination of information shared with the person pursuant to }{{\f5\fs18\hyphpar0\qj{section 299.12}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 174, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1043, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1152, \'a720}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.14}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.15}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports by school officers and employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All school officers and employees shall promptly report to the secretary of the school corporation any violations of the truancy law of which they have knowledge, and the secretary shall inform the president of the board of directors who shall, if necessary, call a meeting of the board to take such action thereon as the facts justify.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72823-g; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4424;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.16}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Failure to attend \u8212\'3f report.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0054.pdf" }{\fldrslt \cf5 \f5 \fs18{{2009 Acts, ch 54, \'a714}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.17}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.18}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Education of certain children who are deaf or hard of hearing, blind, or have severe disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Children who are of compulsory attendance age and who are so deaf or hard of hearing, or blind, or have such severe disabilities so as to be unable to obtain an education in the public or accredited nonpublic schools shall be sent to the appropriate state-operated school, or shall receive appropriate special education under }{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{, unless exempted, and any person having such a child under the person\u8217\'3fs control or custody shall see that the child attends the state-operated school or special education program during the scholastic year.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72718-c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4427;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.18}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1102, \'a721}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.19}}}{{\f5\fs12\hyphpar0\qj{, 299.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.19}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Proceeding against parent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the failure of a person having the custody and control of a child who is blind, deaf or hard of hearing, or has severe disabilities to require the child\u8217\'3fs attendance as provided in }{{\f5\fs18\hyphpar0\qj{section 299.18}}}{, the state board of regents may make application to the district court or the juvenile court of the county in which the person resides for an order requiring the person to compel the attendance of the child at the proper state-operated school.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72718-d, -e; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4428;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a777}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1102, \'a722}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.20}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the filing of the application mentioned in }{{\f5\fs18\hyphpar0\qj{section 299.19}}}{, the time of hearing shall be determined by the juvenile court or the district court. If, upon hearing, the court determines that the person required to appear has the custody and control of a child who should be required to attend a state-operated school under }{{\f5\fs18\hyphpar0\qj{section 299.18}}}{, the court shall make an order requiring the person to keep the child in attendance at the state-operated school.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4429;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.20}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a718}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.21}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contempt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A failure to comply with the order of the court shall subject the person against whom the order is made to punishment the same as in ordinary contempt cases.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4430;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.21}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Contempts, }{{\f5\fs12\hyphpar0\qj{chapter 665}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.22}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When deaf or hard of hearing and blind children excused.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Attendance at the state-operated school may be excused when the superintendent of the state-operated school certifies that an interdisciplinary staffing team has determined, pursuant to the requirements of }{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{, that the child is efficiently taught for the scholastic year in an accredited nonpublic or other school devoted to the instruction, by a private tutor, in the public schools, or is shown to be physically or mentally unable to attend school under }{{\f5\fs18\hyphpar0\qj{section 299.5}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72718-f; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4431;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.22}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 200, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1102, \'a723}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7299.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.23}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Agent of state board of regents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state board of regents may employ an agent to aid in the enforcement of law relative to the education of deaf or hard-of-hearing children and blind children. The agent shall seek out children who should be in attendance at the state schools but who are not, and require such attendance. The agent shall institute proceedings against persons who violate the provisions of said law. The agent shall be allowed compensation at a rate fixed by the board of regents, and necessary traveling and hotel expenses while away from home in the performance of duty.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4432;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.23}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1102, \'a724}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{299.24}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Religious groups exempted from school standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When members or representatives of a local congregation of a recognized church or religious denomination established for ten years or more within the state of Iowa prior to July 1, 1967, which professes principles or tenets that differ substantially from the objectives, goals, and philosophy of education embodied in standards set forth in }{{\f5\fs18\hyphpar0\qj{section 256.11}}}{, and rules adopted in implementation thereof, file with the director of the department of education proof of the existence of such conflicting tenets or principles, together with a list of the names, ages, and post office addresses of all persons of compulsory school age desiring to be exempted from the compulsory education law and the educational standards law, whose parents or guardians are members of the congregation or religious denomination, the director, subject to the approval of the state board of education, may exempt the members of the congregation or religious denomination from compliance with any or all requirements of the compulsory education law and the educational standards law for two school years. When the exemption has once been granted, renewal of such exemptions for each succeeding school year may be conditioned by the director, with the approval of the board, upon proof of achievement in the basic skills of arithmetic, the communicative arts of reading, writing, grammar, and spelling, and an understanding of United States history, history of Iowa, and the principles of American government, by persons of compulsory school age exempted in the preceding year, which shall be determined on the basis of tests or other means of evaluation selected by the director with the approval of the state board. The testing or evaluation, if required, shall be accomplished prior to submission of the request for renewal of the exemption. Renewal requests shall be filed with the director on or before April 15 of the school year preceding the school year for which the applicants desire exemption.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7299.24}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a721, 22}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a726}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7280.3}}}{{\f5\fs12\hyphpar0\qj{, 299.2}}}\par}}