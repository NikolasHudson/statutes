\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F97}{\*\bkmkend codeChapter_5F97}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 97}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{OLD-AGE AND SURVIVORS\u8217\'3f INSURANCE SYSTEM}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a797C.19}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{97.1 through 97.49}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1953/CH0071.pdf" }{\fldrslt \f5 \fs18{{53 Acts, ch 71, \'a71}}}}}}{{\f5\fs18\qj{53 Acts, ch 71, \'a71}}}{, except as indicated herein. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{97.50}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Repeal of prior law \u8212\'3f rights preserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Chapter 97, Code 1950}}}{, as amended by the Fifty-fourth General Assembly, is hereby repealed, subject to the provisions which follow:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person being paid any benefits under the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 97.13 through 97.18, Code 1950}}}{{\f5\fs18\hyphpar0\qj{, as amended, as of June 30, 1953, shall continue to receive such benefits as though that chapter had not been repealed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who became entitled to any benefits under the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 97.13 through 97.19, Code 1950}}}{{\f5\fs18\hyphpar0\qj{, as amended, through the retirement or death of any person prior to June 30, 1953, shall be paid the same benefits upon proper application, subsequent to June 30, 1953, as though that chapter had not been repealed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any individual who was, as of June 30, 1953, a fully insured individual as defined in }}}{{\f5\fs18\hyphpar0\qj{section 97.45, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, and who would be a fully insured individual at age sixty-five, on the basis of service prior to June 30, 1953 (but who is not under public employment as of such date), shall be entitled to receive, in the event of the individual\u8217\'3fs reaching sixty-five years of age after June 30, 1953, not less than the same individual primary benefit the individual would have received under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 97.13}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, had the individual been eligible for retirement as of that date as though }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, had not been repealed. Any individual who was as of June 30, 1953, a fully insured individual as defined in }}}{{\f5\fs18\hyphpar0\qj{section 97.45, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, and who would be fully insured at age of sixty-five, on the basis of service prior to June 30, 1953, and who is as of June 30, 1953, under public employment, and also under coverage of a federal civil service retirement plan, shall be entitled to receive after reaching sixty-five years of age, provided the individual is no longer in public employment, not less than the same individual primary benefit the individual would have received under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 97.13}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, had the individual been eligible for retirement as of that date, as though }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, had not been repealed; and any wife, widow, child or other dependent of such individual would become entitled to any benefits as provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, after June 30, 1953, shall be entitled to receive benefits as provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as though that chapter had not been repealed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any wife, widow, child, or other dependent of any fully insured individual who left employment or died prior to June 30, 1953, who would become entitled to any benefit as provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, after June 30, 1953, shall be entitled to receive benefits as provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, as though that chapter had not been repealed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any currently insured individual under the terms of }}}{{\f5\fs18\hyphpar0\qj{subsection 7 of section 97.45}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, who is not in Iowa public employment as of June 30, 1953, shall continue to be a currently insured individual against death for the period designated in said subsection and the provisions of coverage for benefit purposes under said subsection shall apply to such individuals as they would have applied as though }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, had not been repealed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, \'a797.13 \u8211\'3f 97.19; C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a797.50}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a750}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a797.53}}}{{\f5\fs12\hyphpar0\qj{, 97B.1A}}}{{\f5\fs12\hyphpar0\qj{, 97B.42}}}{{\f5\fs12\hyphpar0\qj{, 97B.43}}}{{\f5\fs12\hyphpar0\qj{, 97B.56}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{97.51}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special fund created \u8212\'3f refunds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{There is hereby created as a special fund, separate and apart from all other public moneys or funds of this state, the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa Old-Age and Survivors\u8217\'3f Insurance Liquidation Fund\u8221\'3f}}}{, this fund to consist of all unexpended moneys collected under the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 97}}}{, Code 1950, as amended, together with all interest thereon, and also to include all securities and other assets acquired by and through the use of the moneys belonging to the Iowa old-age and survivors\u8217\'3f insurance trust fund, and any other moneys that may be paid into this fund. There is hereby transferred to the Iowa old-age and survivors\u8217\'3f insurance liquidation fund all funds and assets of the old-age and survivors\u8217\'3f insurance trust fund created by the provisions of }{{\f5\fs18\hyphpar0\qj{section 97.5}}}{, Code 1950. There shall also be deposited in the Iowa old-age and survivors\u8217\'3f insurance liquidation fund all receipts after June 30, 1953, as a result of the collection of taxes or other moneys, as provided by }{{\f5\fs18\hyphpar0\qj{section 97.8}}}{, Code 1950.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state is the custodian and trustee of this fund and shall administer the fund in accordance with the directions of the Iowa public employees\u8217\'3f retirement system created in }}}{{\f5\fs18\hyphpar0\qj{section 97B.1}}}{{\f5\fs18\hyphpar0\qj{. It is the duty of the trustee:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To hold said trust funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Under the direction of the system and as designated by the system, invest such portion of said trust funds as are not needed for current payment of benefits, in interest-bearing securities issued by the United States, or interest-bearing bonds issued by the state of Iowa, or bonds issued by counties, school districts or general obligations or limited levy bonds issued by municipal corporations in this state as authorized by law; also to sell and dispose of same when needed for the payment of benefits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To disburse the trust funds upon warrants drawn by the director of the department of administrative services pursuant to the order of the system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys which are paid or deposited into this fund are hereby appropriated and made available to the system to be used only for the purposes herein provided:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be used by the system for the payment of claims for benefits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be used by the system for the payment in accordance with any agreement with the federal social security administration of amounts required to obtain retroactive federal social security coverage of Iowa public employees, dating from January 1, 1951, and for the payment of refunds which were authorized by the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 97.7}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, and for the payment of such other refunds to employees as may be authorized by the general assembly, and such other purposes as may be authorized by the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The system shall administer the Iowa old-age and survivors\u8217\'3f insurance liquidation fund and shall also administer all other provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any public employee subject to coverage under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, in public service as of June 30, 1953, and who has not applied for and qualified for benefit payments under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, who had contributed to the Iowa old-age and survivors\u8217\'3f insurance fund prior to the repeal of }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, shall be entitled to a refund of contributions paid into the Iowa old-age and survivors\u8217\'3f insurance fund by such employee without interest, but there shall be deducted from the amount of any such refund any amount which has been or will be paid in the employee\u8217\'3fs behalf as the employee\u8217\'3fs contribution as an employee to obtain retroactive federal social security coverage. Any former public employee not in public service as of June 30, 1953, who has contributed to the Iowa old-age and survivors\u8217\'3f insurance fund, the employee\u8217\'3fs beneficiaries or estate, when no benefit has been paid under }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, based upon such employee\u8217\'3fs prior record, shall be entitled to a refund of seventy-five percent of all contributions paid by the employee into said fund, without interest. The system shall prescribe rules in regard to the granting of such refunds. In the event of such refund any individual receiving the same shall be deemed to have waived any and all rights in behalf of the individual or any beneficiary or the individual\u8217\'3fs estate to further benefits under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any employee in public service as of June 30, 1953, may, in lieu of receiving the cash refund of the employee\u8217\'3fs contributions, elect to come under the coverage of any new retirement system which may be created by the general assembly, to which the employee is eligible, with credits toward future benefits in consideration of the employee\u8217\'3fs prior contributions and length of service, and may direct the transfer of the amount payable to the employee to the assets of such new retirement system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the payment of any benefits in the future, as a result of the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, the system shall follow the same procedure as provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, as though said chapter had not been repealed, except the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{section 97.21}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, shall not be applicable, but no primary benefit, based upon employment prior to June 30, 1953, shall be paid to any individual for any month during which the individual receives compensation for work in any position which would have been subject to coverage under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, if the individual\u8217\'3fs earnings for such month exceed one hundred dollars, nor shall any benefit be paid to a wife or dependent of such employee for such months, except that after a retired member reaches the age of seventy-two years, the member, the member\u8217\'3fs wife and dependents shall be entitled to the benefits of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ regardless of the amount earned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning July 1, 1975, any person receiving benefits under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, as amended, shall receive a monthly increase in benefits equal to one hundred percent of the monthly benefits received for June 1975 or for which the person was eligible to receive for June 1975. Any person who becomes eligible for benefits under }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, on or after July 1, 1975, shall receive the same percentage increase.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Effective July 1, 1980, a person receiving benefits, or who becomes eligible to receive benefits, on or after July 1, 1980, under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall receive the monthly increase in benefits provided in }}}{{\f5\fs18\hyphpar0\qj{section 97B.49G, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is appropriated from the general fund of the state to the Iowa old-age and survivors\u8217\'3f insurance liquidation fund from funds not otherwise appropriated an amount sufficient to finance the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Effective July 1, 1984, a person receiving benefits, on or after July 1, 1984, under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall receive a monthly increase in benefits equal to ten percent of the monthly benefits received for June 1984 or which the person was eligible to receive for June 1984, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A person who becomes eligible for benefits under }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, on or after July 1, 1984, shall receive the ten percent increase.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person eligible to receive benefits under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ on June 30, 1984, may elect in writing to the Iowa department of job service* not to receive the monthly benefit increase granted in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is appropriated annually from the general fund of the state to the Iowa old-age and survivors\u8217\'3f insurance liquidation fund from funds not otherwise appropriated an amount sufficient to pay the benefit increases provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Effective July 1, 1992, a person receiving benefits, on or after July 1, 1992, under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall receive a monthly increase in benefits of ten dollars per month. A person who becomes eligible for benefits under }}}{{\f5\fs18\hyphpar0\qj{chapter 97}}}{{\f5\fs18\hyphpar0\qj{, Code 1950, on or after July 1, 1992, shall receive the ten dollar increase.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is appropriated annually from the general fund of the state to the Iowa old-age and survivors\u8217\'3f insurance liquidation fund from funds not otherwise appropriated an amount sufficient to pay the benefit increases provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, \'a797.5, 97.7 \u8211\'3f 97.9, 97.12, 97.23, 97.35; C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{