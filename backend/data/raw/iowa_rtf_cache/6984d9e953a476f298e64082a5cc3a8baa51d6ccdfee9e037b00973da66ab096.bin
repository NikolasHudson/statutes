\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F4_303}{\*\bkmkend codeChapter_5F4_303}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 403}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{URBAN RENEWAL}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a76A.22}}}{{\f5\fs12\qc{, 15J.4}}}{{\f5\fs12\qc{, 331.403}}}{{\f5\fs12\qc{, 331.441}}}{{\f5\fs12\qc{, 357H.4}}}{{\f5\fs12\qc{, 384.22}}}{{\f5\fs12\qc{, 384.24}}}{{\f5\fs12\qc{, 419.17}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall be known and may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUrban Renewal Law\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Declaration of policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is hereby found and declared that there exist in municipalities of the state slum and blighted areas, as defined in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, which constitute a serious and growing menace, injurious to the public health, safety, morals, and welfare of the residents of the state; that the existence of such areas contributes substantially and increasingly to the spread of disease and crime, constitutes an economic and social liability imposing onerous municipal burdens which decrease the tax base and reduce tax revenues, substantially impairs or arrests the sound growth of municipalities, retards the provision of housing accommodations, aggravates traffic problems and substantially impairs or arrests the elimination of traffic hazards and the improvement of traffic facilities; and that the prevention and elimination of slums and blighted areas is a matter of state policy and state concern in order that the state and its municipalities shall not continue to be endangered by areas which are focal centers of disease, promote juvenile delinquency and consume an excessive proportion of state revenues because of the extra services required for police, fire, accident, hospitalization, and other forms of public protection, services, and facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is further found and declared that certain slum or blighted areas, or portions thereof, may require acquisition, clearance, and disposition subject to use restrictions, as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, since the prevailing condition of decay may make impracticable the reclamation of the area by conservation or rehabilitation; that other areas or portions thereof may, through the means provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, be susceptible of conservation or rehabilitation in such a manner that the conditions and evils hereinbefore enumerated may be eliminated, remedied or prevented; and that fringe areas can be conserved and rehabilitated through appropriate public action as herein authorized, and through the cooperation and voluntary action of the owners and tenants of property in such areas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is further found and declared that there exists in this state the continuing need for programs to alleviate and prevent conditions of unemployment and a shortage of housing; and that it is accordingly necessary to assist and retain local industries and commercial enterprises to strengthen and revitalize the economy of this state and its municipalities; that accordingly it is necessary to provide means and methods for the encouragement and assistance of industrial and commercial enterprises in locating, purchasing, constructing, reconstructing, modernizing, improving, maintaining, repairing, furnishing, equipping, and expanding in this state and its municipalities, for the provision of public improvements related to housing and residential development, and for the construction of housing for low and moderate income families; that accordingly it is necessary to authorize local governing bodies to designate areas of a municipality as economic development areas for commercial and industrial enterprises, public improvements related to housing and residential development, or construction of housing for low and moderate income families; and that it is also necessary to encourage the location and expansion of commercial enterprises to more conveniently provide needed services and facilities of the commercial enterprises to municipalities and the residents of the municipalities. Therefore, the powers granted in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ constitute the performance of essential public purposes for this state and its municipalities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is further found and declared that the powers conferred by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ are for public uses and purposes for which public money may be expended and for which the power of eminent domain, to the extent authorized, and police power exercised; and that the necessity in the public interest for the provisions herein enacted is hereby declared as a matter of legislative determination.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 66, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 186, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1204, \'a713}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2006/CH1001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2006 Acts, 1st Ex, ch 1001, \'a734, 49}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7209}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Municipal program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The local governing body of a municipality may formulate for the municipality a workable program for utilizing appropriate private and public resources to eliminate slums and prevent the development or spread of slums and urban blight and to encourage needed urban rehabilitation. Such workable program may include, without limitation, provisions for:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prevention of the spread of blight into areas of the municipality which are free from blight, through diligent enforcement of housing, zoning and occupancy controls and standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rehabilitation or conservation of slum or blighted areas or portions thereof by replanning, by removing congestion, by providing parks, playgrounds and other public improvements, by encouraging voluntary rehabilitation and by compelling the repair and rehabilitation of deteriorated or deteriorating structures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clearance of slum and blighted areas or portions thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The redevelopment of slum and blighted areas by approval of urban renewal plans.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.3}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7403.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Resolution of necessity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A municipality shall not exercise the authority conferred upon municipalities by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ until after its local governing body has adopted a resolution finding that:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One or more slum, blighted or economic development areas exist in the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rehabilitation, conservation, redevelopment, development, or a combination thereof, of the area is necessary in the interest of the public health, safety, or welfare of the residents of the municipality.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 66, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7210}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7403.14}}}{{\f5\fs12\hyphpar0\qj{, 403.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Urban renewal plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality shall not approve an urban renewal project for an urban renewal area unless the governing body has, by resolution, determined the area to be a slum area, blighted area, economic development area or a combination of those areas, and designated the area as appropriate for an urban renewal project. The local governing body shall not approve an urban renewal plan until a general plan for the municipality has been prepared. For this purpose and other municipal purposes, authority is vested in every municipality to prepare, to adopt and to revise from time to time, a general plan for the physical development of the municipality as a whole, giving due regard to the environs and metropolitan surroundings. A municipality shall not acquire real property for an urban renewal project unless the local governing body has approved the urban renewal project in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The municipality may itself prepare or cause to be prepared an urban renewal plan; or any person or agency, public or private, may submit such a plan to a municipality. Prior to its approval of an urban renewal plan, the local governing body shall submit such plan to the planning commission of the municipality, if any, for review and recommendations as to its conformity with the general plan for the development of the municipality as a whole. The planning commission shall submit its written recommendations with respect to the proposed urban renewal plan to the local governing body within thirty days after receipt of the plan for review. Upon receipt of the recommendations of the planning commission or, if no recommendations are received within the thirty days, then, without such recommendations, the local governing body may proceed with the hearing on the proposed urban renewal plan prescribed by }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to its approval of an urban renewal plan which provides for a division of revenue pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{, the municipality shall mail the proposed plan by regular mail to the affected taxing entities. The municipality shall include with the proposed plan notification of a consultation to be held between the municipality and affected taxing entities prior to the public hearing on the urban renewal plan. If the proposed urban renewal plan or proposed urban renewal project within the urban renewal area includes the use of taxes resulting from a division of revenue under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ for a public building, including but not limited to a police station, fire station, administration building, swimming pool, hospital, library, recreational building, city hall, or other public building that is exempt from taxation, including the grounds of, and the erection, equipment, remodeling, or reconstruction of, and additions or extensions to, such a building, the municipality shall include with the proposed plan notification an analysis of alternative development options and funding for the urban renewal area or urban renewal project and the reasons such options would be less feasible than the proposed urban renewal plan or proposed urban renewal project. A copy of the analysis required in this subparagraph shall be included with the urban renewal report required under }}}{{\f5\fs18\hyphpar0\qj{section 331.403}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{384.22}}}{{\f5\fs18\hyphpar0\qj{, as applicable, and filed by December 1 following adoption of the urban renewal plan or project.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each affected taxing entity may appoint a representative to attend the consultation. The consultation may include a discussion of the estimated growth in valuation of taxable property included in the proposed urban renewal area, the fiscal impact of the division of revenue on the affected taxing entities, the estimated impact on the provision of services by each of the affected taxing entities in the proposed urban renewal area, and the duration of any bond issuance included in the plan. The designated representative of the affected taxing entity may make written recommendations for modification to the proposed division of revenue no later than seven days following the date of the consultation. The representative of the municipality shall, no later than seven days prior to the public hearing on the urban renewal plan, submit a written response to the affected taxing entity addressing the recommendations for modification to the proposed division of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local governing body shall hold a public hearing on an urban renewal plan after public notice thereof by publication in a newspaper having a general circulation in the area of operation of the municipality. The notice shall describe the time, date, place and purpose of the hearing, shall generally identify the urban renewal area covered by the plan, and shall outline the general scope of the urban renewal activities under consideration. A copy of the notice shall be sent by ordinary mail to each affected taxing entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following such hearing, the local governing body may approve an urban renewal plan if it finds that:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A feasible method exists for the location of families who will be displaced from the urban renewal area into decent, safe and sanitary dwelling accommodations within their means and without undue hardship to such families.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The urban renewal plan conforms to the general plan of the municipality as a whole; provided, that if the urban renewal area consists of an area of open land to be acquired by the municipality, such area shall not be so acquired except:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it is to be developed for residential uses, the local governing body shall determine that a shortage of housing of sound standards and design with decency, safety, and sanitation exists in the municipality; that the acquisition of the area for residential uses is an integral part of and essential to the program of the municipality; and that one or more of the following conditions exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the need for housing accommodations has been or will be increased as a result of the clearance of slums in other areas, including other portions of the urban renewal area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That conditions of blight in the municipality and the shortage of decent, safe, and sanitary housing cause or contribute to an increase in and spread of disease and crime, so as to constitute a menace to the public health, safety, morals, or welfare.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the provision of public improvements related to housing and residential development will encourage housing and residential development which is necessary to encourage the retention or relocation of industrial and commercial enterprises in this state and its municipalities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The acquisition of the area is necessary to provide for the construction of housing for low and moderate income families.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it is to be developed for nonresidential uses, the local governing body shall determine that such nonresidential uses are necessary and appropriate to facilitate the proper growth and development of the community in accordance with sound planning standards and local community objectives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The acquisition of open land authorized in subparagraph (1), subparagraph divisions (a) and (b) may require the exercise of governmental action, as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, because of defective or unusual conditions of title, diversity of ownership, tax delinquency, improper subdivisions, outmoded street patterns, deterioration of site, economic disuse, unsuitable topography or faulty lot layouts, or because of the need for the correlation of the area with other areas of a municipality by streets and modern traffic requirements, or any combination of such factors or other conditions which retard development of the area. If such governmental action involves the exercise of eminent domain authority, the municipality is subject to the limitations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapters 6A}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{6B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, an urban renewal plan may be modified at any time. However, if the urban renewal plan is modified after the lease or sale by the municipality of real property in the urban renewal project area, such modification may be conditioned upon such approval of the owner, lessee, or successor in interest as the municipality may deem advisable, and in any event such modification shall be subject to such rights at law or in equity as a lessee or purchaser, or a lessee\u8217\'3fs or purchaser\u8217\'3fs successor or successors in interest, may be entitled to assert.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality shall not approve an urban renewal project for an urban renewal area unless the governing body has amended or modified the adopted urban renewal plan to include the urban renewal project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The municipality shall comply with the notification, consultation, and hearing process provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ prior to the approval of any amendment or modification to an adopted urban renewal plan if such amendment or modification provides for refunding bonds or refinancing resulting in an increase in debt service or provides for the issuance of bonds or other indebtedness, to be funded primarily in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{, or if such amendment or modification provides for the inclusion and approval of an urban renewal project under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. However, the review and recommendation process conducted by the municipality\u8217\'3fs planning commission under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not be required when amending or modifying an adopted urban renewal plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once determined to be a blighted area, a slum area, or an economic development area by a municipality, an urban renewal area shall not be redetermined by the municipality throughout the duration of the urban renewal area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the approval by a municipality of an urban renewal plan or of any modification thereof, such plan or modification shall be deemed to be in full force and effect for the respective urban renewal area, and the municipality may then cause such plan or modification to be carried out in accordance with its terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, where the local governing body certifies that an area is in need of redevelopment or rehabilitation as a result of a flood, fire, hurricane, earthquake, storm, or other catastrophe respecting which the governor of the state has certified the need for disaster assistance under Pub. L. No. 81-875, Eighty-first Congress, 64 Stat. 1109, codified at 42 U.S.C. \'a71855 \u8211\'3f 1855g or other federal law, the local governing body may approve an urban renewal plan and an urban renewal project with respect to such area without regard to the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ and without regard to provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ requiring notification and consultation, a general plan for the municipality, and a public hearing on the urban renewal plan or project.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 66, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1182, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1204, \'a714 \u8211\'3f 16}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 171, \'a735, 41, 42}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a797}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2006 Acts, 1st Ex, ch 1001, \'a735, 36, 49}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7157, 180}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1124, \'a713, 14}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7403.14}}}{{\f5\fs12\hyphpar0\qj{, 403.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers of municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be liberally interpreted to achieve the purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Every municipality shall have all the powers necessary or convenient to carry out and effectuate the purposes and provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, including the following powers in addition to others herein granted:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To undertake and carry out urban renewal projects within its area of operation, to make and execute contracts and other instruments necessary or convenient to the exercise of its powers under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and to disseminate slum clearance and urban renewal information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To arrange or contract for the furnishing or repair by any person of services, privileges, works, streets, roads, public utilities or other facilities for or in connection with an urban renewal project; to install, construct, and reconstruct streets, utilities, parks, playgrounds, and other public improvements; and to agree to any conditions, that it may deem reasonable and appropriate, attached to federal financial assistance and imposed pursuant to federal law relating to the determination of prevailing salaries or wages or compliance with labor standards, in the undertaking or carrying out of an urban renewal project; and to include in any contract let in connection with such a project, provisions to fulfill such of said conditions as it may deem reasonable and appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within its area of operation, to enter into any building or property in any urban renewal area in order to make inspections, surveys, appraisals, soundings or test borings, and to obtain an order for this purpose from a court of competent jurisdiction in the event entry is denied or resisted; to acquire by purchase, lease, option, gift, grant, bequest, devise, eminent domain or otherwise, any real property, or personal property for administrative purposes, together with any improvements thereon; to hold, improve, clear or prepare for redevelopment any such property; to mortgage, pledge, hypothecate or otherwise encumber or dispose of any real property; to insure or provide for the insurance of any real or personal property or operations of the municipality against any risks or hazards, including the power to pay premiums on any such insurance; and to enter into any contracts necessary to effectuate the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. A municipality or other public body exercising powers under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ with respect to the acquisition, clearance, or disposition of property shall not be restricted by any other statutory provision in the exercise of such powers unless such statutory provision specifically states its application to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or unless }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ specifically applies restrictions contained in another statutory provision to the powers that may be exercised under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To invest any urban renewal project funds held in reserves or sinking funds, or any such funds not required for immediate disbursement, in property or securities in which a state bank may legally invest funds subject to its control; to redeem such bonds as have been issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.9}}}{{\f5\fs18\hyphpar0\qj{ at the redemption price established therein, or to purchase such bonds at less than redemption price, all such bonds so redeemed or purchased to be canceled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To borrow money and to apply for and accept advances, loans, grants, contributions and any other form of financial assistance from the federal government, the state, county, or other public body, or from any sources, public or private, for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and to give such security as may be required, and to enter into and carry out contracts in connection therewith. A municipality may include in any contract, for financial assistance with the federal government for an urban renewal project, such conditions imposed pursuant to federal laws as the municipality may deem reasonable and appropriate and which are not inconsistent with the purposes of the chapter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within its area of operation, to make or have made all surveys and planning necessary to the carrying out of the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and to contract with any person in making and carrying out of such planning, and to adopt or approve, modify and amend such planning. Such planning may include, without limitation:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A general plan for the locality as a whole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Urban renewal plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Preliminary plans outlining urban renewal activities for neighborhoods to embrace two or more urban renewal areas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Planning for carrying out a program of voluntary or compulsory repair and rehabilitation of buildings and improvements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Planning for the enforcement of state and local laws, codes and regulations relating to the use of land and the use and occupancy of buildings and improvements and to the compulsory repair, rehabilitation, demolition, or removal of buildings and improvements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appraisals, title searches, surveys, studies, and other planning and work necessary to prepare for the undertaking of urban renewal projects. The municipality is authorized to develop, test, and report methods and techniques, and carry out demonstrations and other activities, for the prevention and the elimination of slums and urban blight and to apply for, accept and utilize grants of funds from the federal government for such purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To plan for the relocation of persons, including families, business concerns and others, displaced by an urban renewal project, and to make relocation payments to or with respect to such persons for moving expenses and losses of property for which reimbursement or compensation is not otherwise made, including the making of such payments financed by the federal government. Other provisions of the Code notwithstanding, in making such payments on projects not federally funded, the municipality may pay relocation assistance benefits in the amounts authorized by the Uniform Relocation Assistance and Real Property Acquisition Policies Act of 1970, Pub. L. No. 91-646, as amended by the Uniform Relocation Act Amendments of 1987, Tit. IV, Pub. L. No. 100-17.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To appropriate such funds and make such expenditures as may be necessary to carry out the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and to levy taxes and assessments for such purposes; to zone or rezone any part of the municipality or make exceptions from building regulations; and to enter into agreements, respecting action to be taken by such municipality pursuant to any of the powers granted by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, with an urban renewal agency vested with urban renewal project powers under }}}{{\f5\fs18\hyphpar0\qj{section 403.14}}}{{\f5\fs18\hyphpar0\qj{, which agreements may extend over any period, notwithstanding any provision of rule of law to the contrary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To close, vacate, plan or replan streets, roads, sidewalks, ways or other places; and to plan or replan any part of the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within its area of operation, to organize, coordinate and direct the administration of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ as they apply to such municipality in order that the objective of remedying slum and blighted areas, and preventing the causes thereof, within such municipality, may be most effectively promoted and achieved; and to establish such new office or offices of the municipality, or to reorganize existing offices, in order to carry out such purpose most effectively.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To exercise all or any part of combination of powers herein granted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To approve urban renewal plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To sell and convey real property in furtherance of an urban renewal project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To supplement the rent required to be paid by any family residing in the municipality forced to relocate by reason of any governmental activity, provided it is necessary to do so in order to house such family in decent, safe and sanitary housing and provided further that such family does not have sufficient means, as determined by the municipality, to pay the required rent for such housing. Any such rent supplement for any such family shall not continue for more than five years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To acquire by purchase, gift or condemnation real property within its area of operation for the relocation of railroad passenger and freight depots, tracks, and yard and other railroad facilities and to sell or exchange and convey such real property to railroads.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To acquire or dispose of by purchase, construction, or lease, or otherwise to deal in air rights, and facilities or easements for lateral or vertical support of land or structures of any kind.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to applicable state or federal regulations in effect at the time of the municipal action, accept contributions, grants, and other financial assistance from the state or federal government to be used upon a finding of public purpose for grants, loans, loan guarantees, interest supplements, technical assistance, or other assistance as necessary or appropriate to private persons for an urban renewal project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide in an urban renewal plan for the exclusion from taxation of value added to real estate during the process of construction for development or redevelopment. The exclusion may be limited as to the scope of exclusion, territory, or class of property affected. However, the value added during construction shall not be eligible for exclusion from taxation for more than two years and the exclusion shall not be applied to a facility which has been more than eighty percent completed as of the most recent date of assessment. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ permits the elimination only of those taxes which are levied against assessments made during the construction of the development or redevelopment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality, upon entering into a development or redevelopment agreement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.8, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or as otherwise permitted in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, may enter into a written assessment agreement with the developer of taxable property in the urban renewal area which establishes a minimum actual value of the land and completed improvements to be made on the land until a specified termination date which shall not be later than the date after which the tax increment will no longer be remitted to the municipality pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{. The assessment agreement shall be presented to the appropriate assessor. The assessor shall review the plans and specifications for the improvements to be made and if the minimum actual value contained in the assessment agreement appears to be reasonable, the assessor shall execute the following certification upon the agreement:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{The undersigned assessor, being legally responsible for the assessment of the above described property upon completion of the improvements to be made on it, certifies that the actual value assigned to that land and improvements upon completion shall not be less than $}{{\f5\fs18\hyphpar0\qj{....................................}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This assessment agreement with the certification of the assessor and a copy of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be filed in the office of the county recorder of the county where the property is located. Upon completion of the improvements, the assessor shall value the property as required by law, except that the actual value shall not be less than the minimum actual value contained in the assessment agreement. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit the assessor from assigning a higher actual value to the property or prohibit the owner from seeking administrative or legal remedies to reduce the actual value assigned except that the actual value shall not be reduced below the minimum actual value contained in the assessment agreement. An assessor, county auditor, board of review, director of revenue, or court of this state shall not reduce or order the reduction of the actual value below the minimum actual value in the agreement during the term of the agreement regardless of the actual value which may result from the incomplete construction of improvements, destruction or diminution by any cause, insured or uninsured, except in the case of acquisition or reacquisition of the property by a public entity. Recording of an assessment agreement complying with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ constitutes notice of the assessment agreement to a subsequent purchaser or encumbrancer of the land or any part of it, whether voluntary or involuntary, and is binding upon a subsequent purchaser or encumbrancer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 48, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1210, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1209, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1204, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7160}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2006 Acts, 1st Ex, ch 1001, \'a737, 49}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7132 \u8211\'3f 134}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a765}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7403.8}}}{{\f5\fs12\hyphpar0\qj{, 403.14}}}{{\f5\fs12\hyphpar0\qj{, 427B.19D}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 6, paragraphs a, b, c, d, and e amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Condemnation of property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality shall have the right to acquire by condemnation any interest in real property, including a fee simple title thereto, which it may deem necessary for or in connection with an urban renewal project under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, subject to the limitations on eminent domain authority in }}}{{\f5\fs18\hyphpar0\qj{chapter 6A}}}{{\f5\fs18\hyphpar0\qj{. However, a municipality shall not condemn agricultural land included within an economic development area for any use unless the owner of the agricultural land consents to condemnation or unless the municipality determines that the land is necessary or useful for any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a city utility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 362.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a city franchise conferred the authority to condemn private property under }}}{{\f5\fs18\hyphpar0\qj{section 364.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a combined utility system as defined in }}}{{\f5\fs18\hyphpar0\qj{section 384.80}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality shall exercise the power of eminent domain in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 6B}}}{{\f5\fs18\hyphpar0\qj{. Property already devoted to a public use may be acquired in like manner. However, real property belonging to the state, or any political subdivision of this state, shall not be acquired without its consent, and real property or any right or interest in the property owned by any public utility company, pipeline company, railway or transportation company vested with the right of eminent domain under the laws of this state shall not be acquired without the consent of the company, or without first securing, after due notice to the company and after hearing, a certificate authorizing condemnation of the property from the board, commission, or body having the authority to grant a certificate authorizing condemnation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a condemnation proceeding, if a municipality proposes to take a part of a lot or parcel of real property, the municipality shall also take the remaining part of the lot or parcel if requested by the owner.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 66, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 171, \'a736, 41, 42}}}{; }\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2006.1/CH1001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2006 Acts, 1st Ex, ch 1001, \'a738, 49}}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale or lease of property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality may sell, lease or otherwise transfer real property or any interest in real property acquired by it, and may enter into contracts for such purposes, in an urban renewal area for residential, recreational, commercial, industrial or other uses, or for public use, subject to covenants, conditions and restrictions, including covenants running with the land, it deems to be necessary or desirable to assist in preventing the development or spread of future slums or blighted areas, or to otherwise carry out the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, the sale, lease, other transfer, or retention, and any agreement relating to it, may be made only after the approval of the urban renewal plan by the local governing body. The purchasers or lessees and their successors and assigns shall devote the real property only to the uses specified in the urban renewal plan, and they may be obligated to comply with other requirements the municipality determines to be in the public interest, including the requirement to begin within a reasonable time any improvements on the real property required by the urban renewal plan. The real property or interest shall be sold, leased, otherwise transferred, or retained at not less than its fair value for uses in accordance with the urban renewal plan except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. In determining the fair value of real property for uses in accordance with the urban renewal plan, a municipality shall take into account and give consideration to the uses provided in the plan; the restrictions upon, and the covenants, conditions and obligations assumed by the purchaser or lessee or by the municipality retaining the property; and the objectives of the plan for the prevention of the recurrence of slum or blighted areas. The municipality in an instrument of conveyance to a private purchaser or lessee may provide that the purchaser or lessee shall not sell, lease or otherwise transfer the real property, without the prior written consent of the municipality, until the purchaser or lessee has completed the construction of any or all improvements which the purchaser or lessee has become obligated to construct. Real property acquired by a municipality which, in accordance with the urban renewal plan, is to be transferred, shall be transferred as rapidly as feasible in the public interest, consistent with the carrying out of the urban renewal plan. A contract for a transfer under the urban renewal plan, or a part or parts of the contract or plan as the municipality determines, may be recorded in the land records of the county in a manner to afford actual or constructive notice of the contract or plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality may dispose of real property in an urban renewal area to private persons only under reasonable competitive bidding procedures it shall prescribe, or as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A municipality, by public notice by publication in a newspaper having a general circulation in the community, thirty days prior to the execution of a contract to sell, lease or otherwise transfer real property, and prior to the delivery of an instrument of conveyance with respect to the real property under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, may invite proposals from and make available all pertinent information to any persons interested in undertaking to redevelop or rehabilitate an urban renewal area, or a part of the area. The notice shall identify the area, or portion of the area, and shall state that proposals shall be made by those interested within thirty days after the date of publication of the notice, and that further information available may be obtained at the office designated in the notice. The municipality shall consider all redevelopment or rehabilitation proposals, and the financial and legal ability of the persons making the proposals to carry them out, and the municipality may negotiate with any persons for proposals concerning the purchase, lease or other transfer of real property acquired by the municipality in the urban renewal area. The municipality may accept the proposal it deems to be in the public interest and in furtherance of the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, a notification of intention to accept the proposal shall be filed with the governing body not less than thirty days prior to the acceptance. Thereafter, the municipality may execute a contract in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and may deliver deeds, leases and other instruments and may take all steps necessary to effectuate the contract.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to real property disposed of for the purpose of development or redevelopment as an industrial building or facility, facilities for use as a center for export for international trade, a home office or regional office facility for a multistate business or which meets the criteria set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement that real property or an interest in real property transferred or retained for the purpose of a development or redevelopment be sold, leased, otherwise transferred, or retained at not less than its fair market value does not apply if the developer enters into a written assessment agreement with the municipality pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.6, subsections 18 and 19}}}{{\f5\fs18\hyphpar0\qj{, and the minimum actual value contained in the assessment agreement would indicate that there will be sufficient taxable valuations to permit the collection of incremental taxes as provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2,}}}{{\f5\fs18\hyphpar0\qj{ to cause the indebtedness and other costs incurred by the municipality with respect to the property or interest transferred or retained to be repayable as to principal within four tax years following the commencement of full operation of the development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality may temporarily operate and maintain real property acquired in an urban renewal area pending the disposition of the property as authorized in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, without regard to the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ above, for such uses and purposes as may be deemed desirable, even though not in conformity with the urban renewal plan.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1210, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1144, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a782}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7403.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality shall have power to periodically issue bonds in its discretion to pay the costs of carrying out the purposes and provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to the payment of principal and interest upon any advances for surveys and planning, and the payment of interest on bonds, authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, not to exceed three years from the date the bonds are issued. The municipality shall have power to issue refunding bonds for the payment or retirement of such bonds previously issued by the municipality. Said bonds shall be payable solely from the income and proceeds of the fund and portion of taxes referred to in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and revenues and other funds of the municipality derived from or held in connection with the undertaking and carrying out of urban renewal projects under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The municipality may pledge to the payment of the bonds the fund and portion of taxes referred to in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and may further secure the bonds by a pledge of any loan, grant, or contribution from the federal government or other source in aid of any urban renewal projects of the municipality under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or by a mortgage of any such urban renewal projects, or any part thereof, title which is vested in the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not constitute an indebtedness within the meaning of any constitutional or statutory debt limitation or restriction, and shall not be subject to the provisions of any other law or charter relating to the authorization, issuance or sale of bonds. Bonds issued under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ are declared to be issued for an essential public and governmental purpose and, together with interest thereon and income therefrom, shall be exempted from all taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be authorized by resolution or ordinance of the local governing body and may be issued in one or more series and shall bear such date or dates, be payable upon demand or mature at such time or times, bear interest at such rate or rates not exceeding that permitted by }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{, be in such denomination or denominations, be in such form either coupon or registered, carry such conversion or registration privileges, have such rank or priority, be executed in such manner, be payable in such medium of payment, at such place or places, and be subject to such terms of redemption, with or without premium, be secured in such manner, and have such other characteristics, as may be provided by such resolution or trust indenture or mortgage issued pursuant thereto.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before the local governing body may institute proceedings for the issuance of bonds under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a notice of the proposed action, including a statement of the amount and purposes of the bonds and the time and place of the meeting at which the local governing body proposes to take action for the issuance of the bonds, must be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{. At the meeting, the local governing body shall receive oral or written objections from any resident or property owner of the municipality. After all objections have been received and considered, the local governing body, at that meeting or any subsequent meeting, may take additional action for the issuance of the bonds or abandon the proposal to issue the bonds. Any resident or property owner of the municipality may appeal the decision of the local governing body to take additional action to the district court of the county in which any part of the municipality is located, within fifteen days after the additional action is taken. The additional action of the local governing body is final and conclusive unless the court finds that the municipality exceeded its authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such bonds may be sold at not less than ninety-eight percent of par at public or private sale, or may be exchanged for other bonds at not less than ninety-eight percent of par.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In case any of the public officials of the municipality whose signatures appear on any bonds or coupons issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall cease to be such officials before the delivery of such bonds, such signatures shall, nevertheless, be valid and sufficient for all purposes, the same as if such officials had remained in office until such delivery. Any provision of any law to the contrary notwithstanding, any bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be fully negotiable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any suit, action, or proceeding involving the validity or enforceability of any bond issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the security therefor, any such bond reciting in substance that it has been issued by the municipality in connection with an urban renewal project, as defined in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall be conclusively deemed to have been issued for such purpose and such project shall be conclusively deemed to have been planned, located, and carried out in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1204, \'a718, 19}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7211}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7403.6}}}{{\f5\fs12\hyphpar0\qj{, 403.12}}}{{\f5\fs12\hyphpar0\qj{, 403.19}}}{{\f5\fs12\hyphpar0\qj{, 422.7(2)(s)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bonds as legal investment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All banks, trust companies, savings associations, investment companies, and other persons carrying on an investment business; all insurance companies, insurance associations, and other persons carrying on an insurance business; and all executors, administrators, curators, trustees, and other fiduciaries, may legally invest any sinking funds, moneys, or other funds belonging to them or within their control in any bonds or other obligations issued by a municipality pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or those issued by any urban renewal agency vested with urban renewal project powers under }{{\f5\fs18\hyphpar0\qj{section 403.14}}}{. Such bonds and other obligations shall be authorized security for all public deposits. It is the purpose of }{{\f5\fs18\hyphpar0\qj{this section}}}{ to authorize any persons, political subdivisions and officers, public or private, to use any funds owned or controlled by them for the purchase of any such bonds or other obligations. Nothing contained in }{{\f5\fs18\hyphpar0\qj{this section}}}{ with regard to legal investments shall be construed as relieving any person of any duty of exercising reasonable care in selecting securities.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1204, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a778}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemptions from legal process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All property of a municipality, including funds, owned or held by it for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be exempt from levy and sale by virtue of an execution. Execution or other judicial process shall not issue against the property and a judgment against a municipality shall not be a charge or lien upon such property. However, the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to or limit the right of obligees to pursue any remedies for the enforcement of any pledge or lien given pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ by a municipality on its rents, fees, grants or revenues from urban renewal projects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The property of a municipality, acquired or held for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, is declared to be public property used for essential public and governmental purposes, and such property shall be exempt from all taxes of the municipality, the county, the state, or any political subdivision thereof. However, such tax exemption shall terminate when the municipality sells, leases or otherwise disposes of such property in an urban renewal area to a purchaser or lessee which is not a public body entitled to tax exemption with respect to such property.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 34, \'a790}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.12}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Urban renewal project \u8212\'3f powers of municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of aiding in the planning, undertaking or carrying out of an urban renewal project located within the area in which it is authorized to act, any public body may, upon such terms, with or without consideration, as it may determine:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Dedicate, sell, convey, or lease any of its interest in any property, or grant easements, licenses, or other rights or privileges therein to a municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Incur the entire expense of any public improvements made by such public body in exercising the powers granted in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Do any and all things necessary to aid or cooperate in the planning or carrying out of an urban renewal project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lend, grant, or contribute funds to a municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter into agreements, which may extend over any period, notwithstanding any provision or rule of law to the contrary, with a municipality or other public body respecting action to be taken pursuant to any of the powers granted by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, including the furnishing of funds or other assistance in connection with an urban renewal project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cause public buildings and public facilities, including parks, playgrounds, and recreational, community, educational, water, sewer, or drainage facilities, or any other works which it is otherwise empowered to undertake to be furnished.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Furnish, dedicate, close, vacate, pave, install, grade, regrade, plan, or replan streets, roads, sidewalks, ways, or other places.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plan or replan, or zone or rezone any part of the public body or make exceptions from building regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cause administrative and other services to be furnished to the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time title to or possession of any urban renewal project is held by any public body or governmental agency, including any agency or instrumentality of the United States, other than the municipality, which is authorized by law to engage in the undertaking, carrying out, or administration of urban renewal projects, the provisions of the agreements referred to in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall inure to the benefit of and may be enforced by such public body or governmental agency. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmunicipality\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall also include an urban renewal agency vested with all of the urban renewal project powers pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 403.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any sale, conveyance, lease or agreement provided for in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be made by a public body without appraisal, public notice, advertisement or public bidding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of aiding in the planning, undertaking or carrying out of an urban renewal project of an urban renewal agency, a municipality may, in addition to its other powers and upon such terms, with or without consideration, as it may determine, do and perform any or all of the actions or things which, by the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a public body is authorized to do or perform, including the furnishing of financial and other assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or for the purpose of aiding in the planning, undertaking, or carrying out of an urban renewal project of a municipality, a municipality may, in addition to any authority to issue bonds pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.9}}}{{\f5\fs18\hyphpar0\qj{, issue and sell its general obligation bonds. Any bonds issued by a municipality pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ must be issued, in the case of a city, by resolution of the council in the manner and within the limitations prescribed by }}}{{\f5\fs18\hyphpar0\qj{chapter 384, subchapter III}}}{{\f5\fs18\hyphpar0\qj{, or in the case of a county, by resolution of the board of supervisors in the manner and within the limitations prescribed by }}}{{\f5\fs18\hyphpar0\qj{chapter 331, subchapter IV, part 3}}}{{\f5\fs18\hyphpar0\qj{. Bonds issued pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ must be sold in the manner prescribed by }}}{{\f5\fs18\hyphpar0\qj{chapter 75}}}{{\f5\fs18\hyphpar0\qj{. The additional power granted in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for the financing of public undertakings and activities by municipalities within an urban renewal area shall not be construed as a limitation of the existing powers of municipalities.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1182, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a7157}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a766}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.441}}}{{\f5\fs12\hyphpar0\qj{, 384.24}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraphs a, b, c, d, e, f, g, and h amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.13}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presumption of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any instrument executed by a municipality and purporting to convey any right, title, or interest in any property under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be conclusively presumed to have been executed in compliance with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ insofar as title or other interest of any bona fide purchasers, lessees, or transferees of such property is concerned.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 30, \'a767}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.14}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Urban renewal agency powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality may itself exercise its urban renewal project powers, as defined in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or may, if the local governing body by resolution determines such action to be in the public interest, elect to have such powers exercised by the urban renewal agency, if one exists or is subsequently established in the community. In the event the local governing body makes such determination, the urban renewal agency shall be vested with all of the urban renewal project powers in the same manner as though all such powers were conferred on such agency instead of the municipality. If the local governing body does not elect to make such determination, the municipality in its discretion may exercise its urban renewal project powers through a board or commissioner, or through such officers of the municipality as the local governing body may by resolution determine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3furban renewal project powers\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the rights, powers, functions and duties of a municipality under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, except the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to determine an area to be a slum or blighted area or combination thereof and to designate such area as appropriate for an urban renewal project and to hold any public hearings required with respect thereto.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to approve urban renewal plans and modifications thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to establish a general plan for the locality as a whole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to formulate a workable program under }}}{{\f5\fs18\hyphpar0\qj{section 403.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to make the determinations and findings provided for in }}}{{\f5\fs18\hyphpar0\qj{section 403.4}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 403.5, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to issue general obligation bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to appropriate funds, to levy taxes and assessments, and to exercise other powers provided for in }}}{{\f5\fs18\hyphpar0\qj{section 403.6, subsection 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7212}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a768}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7403.6}}}{{\f5\fs12\hyphpar0\qj{, 403.10}}}{{\f5\fs12\hyphpar0\qj{, 403.12}}}{{\f5\fs12\hyphpar0\qj{, 403.15}}}{{\f5\fs12\hyphpar0\qj{, 403.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraphs a, b, c, d, e, and f amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.15}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Agency created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is hereby created in each municipality a public body corporate and politic to be known as the \u8220\'3furban renewal agency\u8221\'3f of the municipality. An urban renewal agency shall not transact any business or exercise its powers under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ until or unless the local governing body has made the finding prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 403.4}}}{{\f5\fs18\hyphpar0\qj{, and has elected to have the urban renewal project powers exercised by an urban renewal agency as provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the urban renewal agency is authorized to transact business and exercise powers pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the mayor or chairperson of the board, as applicable, by and with the advice and consent of the local governing body, shall appoint a board of commissioners of the urban renewal agency, which board shall consist of five commissioners. In cities having a population of more than one hundred thousand, the city council may establish, by ordinance, the number of commissioners at not less than five. The term of office of each such commissioner shall be one year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commissioner shall receive no compensation for services, but shall be entitled to the necessary expenses, including traveling expenses, incurred in the discharge of the commissioner\u8217\'3fs duties. Each commissioner shall hold office until a successor has been appointed and has qualified. A certificate of the appointment or reappointment of any commissioner shall be filed with the clerk of the municipality, and such certificate shall be conclusive evidence of the due and proper appointment of such commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The powers of an urban renewal agency shall be exercised by the commissioners thereof. A majority of the commissioners shall constitute a quorum for the purpose of conducting business and exercising the powers of the agency, and for all other purposes. Action may be taken by the agency upon a vote of a majority of the commissioners present, unless in any case the bylaws shall require a larger number. Any persons may be appointed as commissioners if they reside within the area of operation of the agency, which area shall be conterminous with the area of operation of the municipality, and if they are otherwise eligible for such appointments under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The mayor or chairperson of the board, as applicable, shall designate a chairperson and vice chairperson from among the commissioners. An agency may employ an executive director, technical experts and such other agents and employees, permanent and temporary, as it may require, and the agency may determine their qualifications, duties, and compensation. For such legal service as it may require, an agency may employ or retain its own counsel and legal staff. An agency authorized to transact business and exercise powers under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall file, with the local governing body, on or before September 30 of each year, a report of its activities for the preceding fiscal year, which report shall include a complete financial statement setting forth its assets, liabilities, income and operating expense as of the end of such fiscal year. At the time of filing the report, the agency shall publish in a newspaper of general circulation in the city or county, as applicable, a notice to the effect that such report has been filed with the municipality, and that the report is available for inspection during business hours in the office of the city clerk or county auditor, as applicable, and in the office of the agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For inefficiency, or neglect of duty, or misconduct in office, a commissioner may be removed only after a hearing, and after the commissioner shall have been given a copy of the charges at least ten days prior to such hearing, and after the commissioner shall have had an opportunity to be heard in person or by counsel.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 214, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 114, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7242}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7403.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.16}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Personal interest prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include resolutions advisory to the local governing body or agency by any citizens group, board, body, or commission designated to serve a purely advisory approving or recommending function under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAction affecting such property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes only that action directly and specifically affecting such property as a separate property but shall not include any action, any benefits of which accrue to the public generally, or which affects all or a substantial portion of the properties included or planned to be included in such a project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fParticipation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include discussion or debate preliminary to a vote of a local governing body or agency upon proposed ordinances or resolutions relating to such a project or any abstention from such a vote.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public official or employee of a municipality, or board or commission of a municipality, and a commissioner or employee of an urban renewal agency, which has been vested by a municipality with urban renewal project powers under }}}{{\f5\fs18\hyphpar0\qj{section 403.14}}}{{\f5\fs18\hyphpar0\qj{, shall not voluntarily acquire any personal interest, whether direct or indirect, in any urban renewal project, or in any property included or planned to be included in any urban renewal project of such municipality, or in any contract or proposed contract in connection with such urban renewal project. Where an acquisition is not voluntary, the interest acquired shall be immediately disclosed in writing to the local governing body, and such disclosure shall be entered upon the minutes of the governing body. If any such official, commissioner, or employee presently owns or controls, or has owned or controlled within the preceding two years, any interest proscribed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, whether direct or indirect, in any property which the official, commissioner, or employee knows is included or planned to be included in an urban renewal project, the official, commissioner, or employee shall immediately disclose this fact in writing to the local governing body, and such disclosure shall be entered upon the minutes of the governing body. Any such official, commissioner, or employee with an interest proscribed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not participate in any action by the municipality, or board or commission of the municipality, or urban renewal agency affecting such property, which is proscribed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employment by a public body, its agencies, or institutions or by any other person having an interest proscribed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be deemed an interest by the employee or of any ownership or control by the employee of interests of the employee\u8217\'3fs employer. Such an employee may participate in an urban renewal project so long as any benefits of such participation accrue to the public generally, such participation affects all or a substantial portion of the properties included or planned to be included in such a project, or such participation promotes the public purposes of such project, and shall limit only that participation by an employee which directly or specifically affects property in which an employer of an employee has an interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The designation of a bank or trust company as depository, paying agent, or agent for investment of funds shall not be deemed a matter of interest or personal interest proscribed by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Stock ownership in a corporation having such an interest shall not be deemed an indicia of an interest, or of ownership or control by the person owning such stocks, proscribed by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ when less than five percent of the outstanding stock of the corporation is owned or controlled directly or indirectly by such person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The limitations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to permit action by a public official, commissioner, or employee where any benefits of such an action accrue to the public generally, the action affects all or a substantial portion of the properties included or planned to be included in such a project, or the action promotes the public purposes of such project. The limitations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to limit only that action by a public official, commissioner, or employee which directly or specifically affects property in which such official, commissioner, or employee has an interest or in which an employer of such official, commissioner, or employee has an interest. Any disclosure required to be made by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the local governing body shall concurrently be made to an urban renewal agency which has been vested with urban renewal project powers by the municipality pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 403.14}}}{{\f5\fs18\hyphpar0\qj{. A commissioner or other officer of any urban renewal agency, board, or commission exercising powers pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not hold any other public office under the municipality, other than the commissionership or office with respect to such urban renewal agency, board, or commission. Any violation of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall constitute misconduct in office, but an ordinance or resolution of a municipality or agency shall not be invalid by reason of a vote or votes cast in violation of the standards of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the vote or votes were decisive in the passage of the ordinance or resolution.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.16}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7213}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7243}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1032, \'a756}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.17}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The following terms wherever used or referred to in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, shall have the following meanings, unless a different meaning is clearly indicated by the context:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAffected taxing entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a city, county, or school district which levied or certified for levy a property tax on any portion of the taxable property located within the urban renewal area in the fiscal year beginning prior to the calendar year in which a proposed urban renewal plan is submitted to the local governing body for approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3furban renewal agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean a public agency created by }}}{{\f5\fs18\hyphpar0\qj{section 403.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural land\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means real property owned by a person in tracts of ten acres or more and not laid off into lots of less than ten acres or divided by streets and alleys into parcels of less than ten acres, and that has been used for the production of agricultural commodities during three out of the past five years. Such use of property includes but is not limited to the raising, harvesting, handling, drying, or storage of crops used for feed, food, seed, or fiber; the care or feeding of livestock; the handling or transportation of crops or livestock; the storage, treatment, or disposal of livestock manure; and the application of fertilizers, beneficial substances, pesticides, and herbicides on crops. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural land\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes land on which is located farm residences or outbuildings used for agricultural purposes and land on which is located facilities, structures, or equipment for agricultural purposes. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgricultural land\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes land taken out of agricultural production for purposes of environmental protection or preservation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fArea of operation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of a city means the area within the corporate limits of the city and, with the consent of the county, the area within two miles of such limits, except that it does not include any area which lies within the territorial boundaries of another incorporated city, unless a resolution has been adopted by the governing body of the city declaring a need to be included in the area. The }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3farea of operation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of a county means an area outside the corporate limits of a city. However, in that area outside a city\u8217\'3fs boundary but within two miles of the city\u8217\'3fs boundary, a joint agreement between the city and the county is required allowing the county to proceed with the activities authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. In addition, a county may proceed with activities authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in an area inside the boundaries of a city, provided a joint agreement is entered into with respect to such activities between a city and a county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBlighted area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an area of a municipality within which the local governing body of the municipality determines that the presence of a substantial number of slum, deteriorated, or deteriorating structures; defective or inadequate street layout; faulty lot layout in relation to size, adequacy, accessibility, or usefulness; insanitary or unsafe conditions; deterioration of site or other improvements; diversity of ownership, tax or special assessment delinquency exceeding the fair value of the land; defective or unusual conditions of title; or the existence of conditions which endanger life or property by fire and other causes; or any combination of these factors; substantially impairs or arrests the sound growth of a municipality, retards the provision of housing accommodations, or constitutes an economic or social liability and is a menace to the public health, safety, or welfare in its present condition and use. A disaster area referred to in }}}{{\f5\fs18\hyphpar0\qj{section 403.5, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, constitutes a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fblighted area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBlighted area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include real property assessed as agricultural property for purposes of property taxation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean a board, commission, department, division, office, body, or other unit of the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBonds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean any bonds, including refunding bonds, notes, interim certificates, certificates of indebtedness, debentures, or other obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChairperson of the board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the chairperson of the board of supervisors or other legislative body charged with governing a county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClerk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean the clerk or other official of the municipality who is the custodian of the official records of such municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEconomic development area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an area of a municipality designated by the local governing body as appropriate for commercial and industrial enterprises, public improvements related to housing and residential development, or construction of housing and residential development for low and moderate income families, including single or multifamily housing. If an urban renewal plan for an urban renewal area is based upon a finding that the area is an economic development area and that no part contains slum or blighted conditions, then the division of revenue provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ and stated in the plan shall be limited to twenty years from the calendar year following the calendar year in which the municipality first certifies to the county auditor the amount of any loans, advances, indebtedness, or bonds which qualify for payment from the division of revenue provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{. Such designated area shall not include agricultural land, including land which is part of a century farm, unless the owner of the agricultural land or century farm agrees to include the agricultural land or century farm in the urban renewal area. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcentury farm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a farm in which at least forty acres of such farm have been held in continuous ownership by the same family for one hundred years or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal government\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the United States or any agency or instrumentality, corporate or otherwise, of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHousing and residential development\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means single or multifamily dwellings to be constructed in an area with respect to which the local governing body of the municipality determines that there is an inadequate supply of affordable, decent, safe, and sanitary housing and that providing such housing is important to meeting any or all of the following objectives:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{retaining existing industrial or commercial enterprises; attracting and encouraging the location of new industrial or commercial enterprises; meeting the needs of special elements of the population, such as the elderly or persons with disabilities; and providing housing for various income levels of the population which may not be adequately served.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal governing body\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the council, board of supervisors, or other legislative body charged with governing the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLow or moderate income families\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those families, including single person households, earning no more than eighty percent of the higher of the median family income of the county or the statewide nonmetropolitan area as determined by the latest United States department of housing and urban development, section 8 income guidelines.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMayor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean the mayor of a municipality, or other officer or body having the duties customarily imposed upon the executive head of a municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMunicipality\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any city or county in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fObligee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include any bondholder, agents, or trustees for any bondholders, or any lessor demising to the municipality property used in connection with an urban renewal project, or any assignee or assignees of such lessor\u8217\'3fs interest or any part thereof, and the federal government, when it is a party to any contract with the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean any individual, firm, partnership, corporation, company, association, joint stock association; and shall include any trustee, receiver, assignee, or other person acting in a similar representative capacity for an individual or such entities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic body\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean the state or any political subdivision thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean any officer who is in charge of any department or branch of the government of the municipality relating to health, fire, building regulations, or to other activities concerning dwellings in the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReal property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include all lands, including improvements and fixtures thereon, and property of any nature appurtenant thereto, or used in connection therewith, and every estate, interest, right and use, legal or equitable, therein, including terms for years and liens by way of judgment, mortgage or otherwise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSlum area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean an area in which there is a predominance of buildings or improvements, whether residential or nonresidential, which:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{by reason of dilapidation, deterioration, age or obsolescence; by reason of inadequate provision for ventilation, light, air, sanitation, or open spaces; by reason of high density of population and overcrowding; by reason of the existence of conditions which endanger life or property by fire and other causes; or which by any combination of such factors, is conducive to ill health, transmission of disease, infant mortality, juvenile delinquency, or crime, and which is detrimental to the public health, safety, morals, or welfare. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSlum area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include real property assessed as agricultural property for purposes of property taxation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUrban renewal area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a slum area, blighted area, economic development area, or combination of the areas, which the local governing body designates as appropriate for an urban renewal project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUrban renewal plan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a plan for the development, redevelopment, improvement, or rehabilitation of a designated urban renewal area, as it exists from time to time. The plan shall meet the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conform to the general plan for the municipality as a whole except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.5, subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be sufficiently complete to indicate the real property located in the urban renewal area to be acquired for the proposed development, redevelopment, improvement, or rehabilitation, and to indicate any zoning district changes, existing and future land uses, and the local objectives respecting development, redevelopment, improvement, or rehabilitation related to the future land uses plan, and need for improved traffic, public transportation, public utilities, recreational and community facilities, and other public improvements within the urban renewal area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the plan includes a provision for the division of taxes as provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{, the plan shall also include a list of the current general obligation debt of the municipality, the current constitutional debt limit of the municipality, and the proposed amount of indebtedness to be incurred, including loans, advances, indebtedness, or bonds which qualify for payment from the special fund referred to in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUrban renewal project\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may include undertakings and activities of a municipality in an urban renewal area for the elimination and for the prevention of the development or spread of slums and blight, may include the designation and development of an economic development area in an urban renewal area, and may involve slum clearance and redevelopment in an urban renewal area, or rehabilitation or conservation in an urban renewal area, or any combination or part thereof in accordance with an urban renewal program. The undertakings and activities may include:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Acquisition of a slum area, blighted area, economic development area, or portion of the areas;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Demolition and removal of buildings and improvements;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Installation, construction, or reconstruction of streets, utilities, parks, playgrounds, and other improvements necessary for carrying out in the urban renewal area the urban renewal objectives of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in accordance with the urban renewal plan;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disposition of any property acquired in the urban renewal area, including sale, initial leasing, or retention by the municipality itself, at its fair value for uses in accordance with the urban renewal plan;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carrying out plans for a program of voluntary or compulsory repair and rehabilitation of buildings or other improvements in accordance with the urban renewal plan;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Acquisition of any other real property in the urban renewal area, where necessary to eliminate unhealthful, insanitary, or unsafe conditions, or to lessen density, eliminate obsolete or other uses detrimental to the public welfare, or otherwise to remove or prevent the spread of blight or deterioration, or to provide land for needed public facilities;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sale and conveyance of real property in furtherance of an urban renewal project;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Expenditure of proceeds of bonds issued before October 7, 1986, for the construction of parking facilities on city blocks adjacent to an urban renewal area.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 66, \'a75 \u8211\'3f 9}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1237, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 104, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 299, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 186, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 214, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1182, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1050, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1204, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 171, \'a737, 38, 41, 42}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7161}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1124, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 134, \'a723}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715A.1}}}{{\f5\fs12\hyphpar0\qj{, 368.26}}}{{\f5\fs12\hyphpar0\qj{, 403A.22}}}{{\f5\fs12\hyphpar0\qj{, 404.1}}}{{\f5\fs12\hyphpar0\qj{, 423B.10}}}{{\f5\fs12\hyphpar0\qj{, 437A.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 and 1994 amendments to subsections 4, 5, 10, 14, 22, and 24 apply to plans approved on or after January 1, 1995, except that the century farm amendment to subsection 10 applies to plans approved on or after July 1, 1994; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/94/CH1182.pdf" }{\fldrslt \cf5 \f5 \fs12{{94 Acts, ch 1182, \'a715}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 and 1999 amendments to subsection 10 apply to state highway construction projects approved for commencement by the transportation commission on or after July 1, 1999, and to all other condemnation proceedings in which the application for condemnation is filed on or after July 1, 1999; see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/99/CH0171.pdf" }{\fldrslt \cf5 \f5 \fs12{{99 Acts, ch 171, \'a742}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{1999 amendment to subsection 10 applies to urban renewal areas established on or after July 1, 1999, and to agricultural land included in an urban renewal area established before July 1, 1999, if the land is so included by amendment to the urban renewal plan adopted on or after that date; see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/99/CH0171.pdf" }{\fldrslt \cf5 \f5 \fs12{{99 Acts, ch 171, \'a741}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.18}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rule of construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Insofar as the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may be inconsistent with the provisions of any other law, the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be controlling. The powers conferred by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be in addition and supplemental to the powers conferred by any other law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.18}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.19}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Division of revenue from taxation \u8212\'3f tax increment financing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A municipality may provide by ordinance that taxes levied on taxable property in an urban renewal area each year by or for the benefit of the state, city, county, school district, or other taxing district, shall be divided as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, that portion of the taxes which would be produced by the rate at which the tax is levied each year by or for each of the taxing districts upon the total sum of the assessed value of the taxable property in the urban renewal area, as shown on the assessment roll as of January 1 of the calendar year preceding the first calendar year in which the municipality certifies to the county auditor the amount of loans, advances, indebtedness, or bonds payable from the division of property tax revenue, or on the assessment roll last equalized prior to the date of initial adoption of the urban renewal plan if the plan was adopted prior to July 1, 1972, shall be allocated to and when collected be paid into the fund for the respective taxing district as taxes by or for the taxing district into which all other property taxes are paid. However, the municipality may choose to divide that portion of the taxes which would be produced by levying the municipality\u8217\'3fs portion of the total tax rate levied by or for the municipality upon the total sum of the assessed value of the taxable property in the urban renewal area, as shown on the assessment roll as of January 1 of the calendar year preceding the effective date of the ordinance and if the municipality so chooses, an affected taxing entity may allow a municipality to divide that portion of the taxes which would be produced by levying the affected taxing district\u8217\'3fs portion of the total tax rate levied by or for the affected taxing entity upon the total sum of the assessed value of the taxable property in the urban renewal area, as shown on the assessment roll as of January 1 of the calendar year preceding the effective date of the ordinance. This choice to divide a portion of the taxes shall not be construed to change the effective date of the division of property tax revenue with respect to an urban renewal plan in existence on July 1, 1994.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of allocating taxes levied by or for any taxing district which did not include the territory in an urban renewal area on the effective date of the ordinance or initial adoption of the plan, but to which the territory has been annexed or otherwise included after the effective date, the assessment roll applicable to property in the annexed territory as of January 1 of the calendar year preceding the effective date of the ordinance, which amends the plan to include the annexed area, shall be used in determining the assessed valuation of the taxable property in the annexed area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of dividing taxes under }}}{{\f5\fs18\hyphpar0\qj{section 260E.4}}}{{\f5\fs18\hyphpar0\qj{, the applicable assessment roll for purposes of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be the assessment roll as of January 1 of the calendar year preceding the first written agreement providing that all or a portion of program costs are to be paid for by incremental property taxes. The community college shall file a copy of the agreement with the appropriate assessor. The assessor may, within fourteen days of such filing, physically inspect the applicable taxable business property. If upon such inspection the assessor determines that there has been a change in the value of the property from the value as shown on the assessment roll as of January 1 of the calendar year preceding the filing of the agreement and such change in value is due to new construction, additions or improvements to existing structures, or remodeling of existing structures for which a building permit was required, the assessor shall promptly determine the value of the property as of the inspection in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 441}}}{{\f5\fs18\hyphpar0\qj{ and that value shall be included for purposes of the jobs training project in the assessed value of the employer\u8217\'3fs taxable business property as shown on the assessment roll as of January 1 of the calendar year preceding the filing of the agreement. The assessor, within thirty days of such filing, shall notify the community college and the employer or business of that valuation which shall be included in the assessed valuation for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 260E.4}}}{{\f5\fs18\hyphpar0\qj{. The value determined by the assessor shall reflect the change in value due solely to new construction, additions or improvements to existing structures, or remodeling of existing structures for which a building permit was required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That portion of the taxes each year in excess of such amount shall be allocated to and when collected be paid into a special fund of the municipality to pay the principal of and interest on loans, moneys advanced to, or indebtedness, whether funded, refunded, assumed, or otherwise, including bonds issued under the authority of }}}{{\f5\fs18\hyphpar0\qj{section 403.9, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, incurred by the municipality to finance or refinance, in whole or in part, an urban renewal project within the area, and to provide assistance for low and moderate income family housing as provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.22}}}{{\f5\fs18\hyphpar0\qj{. However, except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, taxes for the regular and voter-approved physical plant and equipment levy of a school district imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 298.2}}}{{\f5\fs18\hyphpar0\qj{ and taxes for the instructional support program of a school district imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 257.19}}}{{\f5\fs18\hyphpar0\qj{, taxes for the payment of bonds and interest of each taxing district, and taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{section 346.27, subsection 22}}}{{\f5\fs18\hyphpar0\qj{, related to joint county-city buildings shall be collected against all taxable property within the taxing district without limitation by the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ All or a portion of the taxes for the physical plant and equipment levy shall be paid by the school district to the municipality if the auditor certifies to the school district by July 1 the amount of such levy that is necessary to pay the principal and interest on bonds issued by the municipality to finance an urban renewal project, which bonds were issued before July 1, 2001. Indebtedness incurred to refund bonds issued prior to July 1, 2001, shall not be included in the certification. Such school district shall pay over the amount certified by November 1 and May 1 of the fiscal year following certification to the school district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All or a portion of the taxes for the instructional support program levy of a school district shall be paid by the school district to the municipality if the auditor, pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 11}}}{{\f5\fs18\hyphpar0\qj{, certifies to the school district by July 1 the amount of such levy that is necessary to pay the principal and interest on bonds issued or other indebtedness incurred by the municipality to finance an urban renewal project if such bonds or indebtedness were issued or incurred on or before April 24, 2012. Such school district shall pay over the amount certified by November 1 and May 1 of the fiscal year following certification to the school district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of payment to a municipality under subparagraph division (a), a school district may by resolution of the board of directors of the school district approve at a regular meeting of the board of directors the payment of all or a portion of the instructional support program property tax revenue excluded under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to the municipality for the payment of principal and interest on such bonds issued or such other indebtedness incurred by the municipality before, on, or after April 24, 2012.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless and until the total assessed valuation of the taxable property in an urban renewal area exceeds the total assessed value of the taxable property in such area as shown by the last equalized assessment roll referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, all of the taxes levied and collected upon the taxable property in the urban renewal area shall be paid into the funds for the respective taxing districts as taxes by or for the taxing districts in the same manner as all other property taxes. When such loans, advances, indebtedness, and bonds, if any, and interest thereon, have been paid, all moneys thereafter received from taxes upon the taxable property in such urban renewal area shall be paid into the funds for the respective taxing districts in the same manner as taxes on all other property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In those instances where a school district has entered into an agreement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 279.64}}}{{\f5\fs18\hyphpar0\qj{ for sharing of school district taxes levied and collected from valuation described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and released to the school district, the school district shall transfer the taxes as provided in the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The portion of taxes mentioned in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ and the special fund into which they shall be paid, may be irrevocably pledged by a municipality for the payment of the principal and interest on loans, advances, bonds issued under the authority of }}}{{\f5\fs18\hyphpar0\qj{section 403.9, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or indebtedness incurred by a municipality to finance or refinance, in whole or in part, the urban renewal project within the area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ the word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftaxes\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes, but is not limited to, all levies on an ad valorem basis upon land or real property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ordinance adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ providing for a division of revenue shall be filed in the office of the county auditor of each county where the property that is subject to the ordinance is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality shall certify to the county auditor on or before December 1 the amount of loans, advances, indebtedness, or bonds, including interest negotiated on such loans, advances, indebtedness, or bonds, which qualify for payment from the special fund referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for each urban renewal area in the municipality, and the filing of the certificate shall make it a duty of the auditor to provide for the division of taxes in each subsequent year without further certification, except as provided in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, until the amount of the loans, advances, indebtedness, or bonds is paid to the special fund. Such certification shall include all amounts which qualify for payment from the special fund referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ during the next fiscal year and all amounts which qualify for payment from the special fund in any subsequent fiscal year. If any loans, advances, indebtedness, or bonds are issued which qualify for payment from the special fund and which are in addition to amounts already certified, the municipality shall certify the amount of the additional obligations on or before December 1 of the year such obligations were issued, and the filing of the certificate shall make it a duty of the auditor to provide for the division of taxes in each subsequent year without further certification, except as provided in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, until the amount of the loans, advances, indebtedness, or bonds is paid to the special fund. Any subsequent certifications under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not include amounts previously certified.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certification made under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the date that the individual loans, advances, indebtedness, or bonds were initially approved by the governing body of the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the amount certified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is reduced by payment from sources other than the division of taxes, by a refunding or refinancing of the obligation which results in lowered principal and interest on the amount of the obligation, or for any other reason, the municipality on or before December 1 of the year the action was taken which resulted in the reduction shall certify the amount of the reduction to the county auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any year, the county auditor shall, upon receipt of a certified request from a municipality filed on or before December 1, increase the amount to be allocated under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ in order to reduce the amount to be allocated in the following fiscal year to the special fund, to the extent that the municipality does not request allocation to the special fund of the full portion of taxes which could be collected. Upon receipt of a certificate from a municipality, the auditor shall mail a copy of the certificate to each affected taxing district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3findebtedness\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to written agreements whereby the municipality agrees to exempt, rebate, refund, or reimburse property taxes, provide a grant for property taxes paid, or make a direct payment of taxes, with moneys in the special fund referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and bonds, notes, or other obligations that are secured by or subject to payment from moneys appropriated by the municipality from moneys in the special fund referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tax collections within each taxing district may be allocated to the entire taxing district including the taxes on the valuations determined under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and to the special fund created under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ in the proportion of their taxable valuations determined as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any fiscal year, a municipality may certify to the county auditor for physical plant and equipment revenue necessary for payment of principal and interest on bonds issued prior to July 1, 2001, only if the municipality certified for such revenue for the fiscal year beginning July 1, 2000. A municipality shall not certify to the county auditor for a school district more than the amount the municipality certified for the fiscal year beginning July 1, 2000. If for any fiscal year a municipality fails to certify to the county auditor for a school district by July 1 the amount of physical plant and equipment revenue necessary for payment of principal and interest on such bonds, as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the school district is not required to pay over the revenue to the municipality. If a school district and a municipality are unable to agree on the amount of physical plant and equipment revenue certified by the municipality for the fiscal year beginning July 1, 2001, either party may request that the state appeal board review and finally pass upon the amount that may be certified. Such appeals must be presented in writing to the state appeal board no later than July 31 following certification. The burden shall be on the municipality to prove that the physical plant and equipment levy revenue is necessary to pay principal and interest on bonds issued prior to July 1, 2001. A final decision must be issued by the state appeal board no later than the following October 1.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys from any source deposited into the special fund created in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be expended for or otherwise used in connection with an urban renewal project approved on or after July 1, 2012, that includes the relocation of a commercial or industrial enterprise not presently located within the municipality, unless one of the following occurs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local governing body of the municipality where the commercial or industrial enterprise is currently located and the local governing body of the municipality where the commercial or industrial enterprise is proposing to relocate have either entered into a written agreement concerning the relocation of the commercial or industrial enterprise or have entered into a written agreement concerning the general use of economic incentives to attract commercial or industrial development within those municipalities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local governing body of the municipality where the commercial or industrial enterprise is proposing to relocate finds that the use of deposits into the special fund for an urban renewal project that includes such a relocation is in the public interest. A local governing body\u8217\'3fs finding that an urban renewal project that includes a commercial or industrial enterprise relocation is in the public interest shall include written verification from the commercial or industrial enterprise that the enterprise is actively considering moving all or a part of its operations to a location outside the state and a specific finding that such an out-of-state move would result in a significant reduction in either the enterprise\u8217\'3fs total employment in the state or in the total amount of wages earned by employees of the enterprise in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frelocation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the closure or substantial reduction of an enterprise\u8217\'3fs existing operations in one area of the state and the initiation of substantially the same operation in the same county or a contiguous county in the state. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit an enterprise from expanding its operations in another area of the state provided that existing operations of a similar nature are not closed or substantially reduced.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest or earnings received on amounts deposited into the special fund created in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the net proceeds from the sale of assets purchased using amounts deposited into the special fund created in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be credited to the special fund and shall be used solely for the purposes specified in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the special fund created in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be transferred to another fund of the municipality except for the payment of loans, advances, indebtedness, or bonds that qualify for payment from the special fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any fiscal year, a municipality may certify to the county auditor for instructional support program property tax revenue necessary for payment of principal and interest on bonds issued or other indebtedness incurred for an urban renewal project on or before April 24, 2012. If for any fiscal year a municipality fails to certify to the county auditor by July 1 the amount of instructional support program property tax revenue necessary for payment of principal and interest on such bonds, as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the school district is not required to pay over the revenue to the municipality. If a school district and a municipality are unable to agree on the amount of instructional support program property tax revenue certified by the municipality, either party may request that the state appeal board review and finally pass upon the amount that may be certified. Such appeals must be presented in writing to the state appeal board no later than July 31 following certification. The burden shall be on the municipality to prove that the instructional support program property tax revenue is necessary to pay principal and interest on the applicable bonds. A final decision must be issued by the state appeal board no later than the following October 1.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7403.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 240, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1144, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 214, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1182, \'a710 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1047, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1180, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1204, \'a722, 23}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1054, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a740, 41, 47}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1131, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1156, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 50, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1060, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1124, \'a716 \u8211\'3f 21, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a72.48}}}{{\f5\fs12\hyphpar0\qj{, 24.21}}}{{\f5\fs12\hyphpar0\qj{, 260E.2}}}{{\f5\fs12\hyphpar0\qj{, 260E.4}}}{{\f5\fs12\hyphpar0\qj{, 279.64}}}{{\f5\fs12\hyphpar0\qj{, 298.3}}}{{\f5\fs12\hyphpar0\qj{, 331.403}}}{{\f5\fs12\hyphpar0\qj{, 331.441}}}{{\f5\fs12\hyphpar0\qj{, 357H.9}}}{{\f5\fs12\hyphpar0\qj{, 384.22}}}{{\f5\fs12\hyphpar0\qj{, 403.5}}}{{\f5\fs12\hyphpar0\qj{, 403.6}}}{{\f5\fs12\hyphpar0\qj{, 403.8}}}{{\f5\fs12\hyphpar0\qj{, 403.9}}}{{\f5\fs12\hyphpar0\qj{, 403.17}}}{{\f5\fs12\hyphpar0\qj{, 403.20}}}{{\f5\fs12\hyphpar0\qj{, 403.22}}}{{\f5\fs12\hyphpar0\qj{, 403.23}}}{{\f5\fs12\hyphpar0\qj{, 423B.7}}}{{\f5\fs12\hyphpar0\qj{, 423B.10}}}{{\f5\fs12\hyphpar0\qj{, 427B.17}}}{{\f5\fs12\hyphpar0\qj{, 427B.19}}}{{\f5\fs12\hyphpar0\qj{, 427B.19A}}}{{\f5\fs12\hyphpar0\qj{, 427B.19C}}}{{\f5\fs12\hyphpar0\qj{, 437A.15}}}{{\f5\fs12\hyphpar0\qj{, 437B.11}}}{{\f5\fs12\hyphpar0\qj{, 441.21A}}}{{\f5\fs12\hyphpar0\qj{, 455H.309}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.19A}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Targeted jobs withholding credit }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ pilot project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBusiness\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an enterprise that is located in this state and that is operated for profit and under a single management. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBusiness\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes professional services and industrial enterprises, including but not limited to medical treatment facilities, manufacturing facilities, corporate headquarters, and research facilities. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBusiness\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a retail operation, a government entity, or a business which closes or substantially reduces its operation in one area of this state and relocates substantially the same operation to another area of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmployee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the individual employed in a targeted job that is subject to a withholding agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmployer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business creating or retaining targeted jobs in a pilot project city pursuant to a withholding agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPilot project city\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a city that has applied and been approved as a pilot project city pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fQualifying investment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a capital investment in real property including the purchase price of land and existing buildings, site preparation, building construction, and long-term lease costs. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fQualifying investment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also means a capital investment in depreciable assets. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flong-term lease costs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those costs incurred or expected to be incurred under a lease during the duration of a withholding agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRetained job\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a full-time equivalent position in existence at the time an employer applies to the authority for approval of a withholding agreement and which remains continuously filled and which is at risk of elimination if the project for which the employer is seeking assistance under the withholding agreement does not proceed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTargeted job\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a job in a business which is or will be located in a pilot project city that pays a wage at least equal to the countywide average wage. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTargeted job\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes new or retained jobs from Iowa business expansions or retentions within the city limits of the pilot project city and those jobs resulting from established out-of-state businesses, as defined by the economic development authority, moving to or expanding in Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWithholding agreement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the agreement between a pilot project city, the economic development authority, and an employer concerning the targeted jobs withholding credit authorized in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An eligible city may apply for designation as a pilot project city pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. An eligible city is a city that contains three or more census tracts and is located in a county meeting one of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county that borders Nebraska.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county that borders South Dakota.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county that borders a state other than Nebraska or South Dakota.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The economic development authority shall approve four eligible cities as pilot project cities, one pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), one pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), and two pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3). If two eligible cities are approved which are located in the same county and the county has a population of less than forty-five thousand, the two approved eligible cities shall be considered one pilot project city. If more than two cities meeting the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), apply to be designated as a pilot project city, the economic development authority shall determine which two cities hold the most potential to create new jobs or generate the greatest capital within their areas. Applications from eligible cities filed on or after October 1, 2006, shall not be considered.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a pilot project city does not enter into a withholding agreement within one year of its approval as a pilot project city, the city shall lose its status as a pilot project city. If two pilot project cities are located in the same county, the loss of status by one pilot project city shall not cause the second pilot project city in the county to lose its status as a pilot project city. Upon such occurrence, the economic development authority shall take applications from other eligible cities to replace that city. Another city shall be designated within six months.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pilot project city may provide by resolution for the deposit into a designated withholding project fund of the targeted jobs withholding credit described in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The targeted jobs withholding credit shall be based upon the wages paid to employees pursuant to a withholding agreement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An amount equal to three percent of the gross wages paid by an employer to each employee under a withholding agreement shall be credited from the payment made by the employer pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 422.16}}}{{\f5\fs18\hyphpar0\qj{. If the amount of the withholding by the employer is less than three percent of the gross wages paid to the employees covered by the withholding agreement, the employer shall receive a credit against other withholding taxes due by the employer or may carry the credit forward for up to ten years or until depleted, whichever is the earlier. The employer shall remit the amount of the credit quarterly, in the same manner as withholding payments are reported to the department of revenue, to the pilot project city to be allocated to and when collected paid into a designated withholding project fund for the project. All amounts so deposited shall be used or pledged by the pilot project city for a project related to the employer pursuant to the withholding agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pilot project city and the economic development authority shall enter into a withholding agreement with each employer concerning the targeted jobs withholding credit. The withholding agreement shall provide for the total amount of withholding credits awarded, as negotiated by the economic development authority, the pilot project city, and the employer. An agreement shall not provide for an amount of withholding credits that exceeds the amount of the qualifying investment made in the project. An agreement shall not be entered into with a business currently located in this state unless the business either creates or retains ten jobs or makes a qualifying investment of at least one million dollars within the pilot project city. The withholding agreement may have a term of years negotiated by the economic development authority, the pilot project city, and the employer, of up to ten years. A withholding agreement specifying a term of years or a total amount of withholding credits shall terminate upon the expiration of the term of years specified in the agreement or upon the award of the total amount of withholding credits specified in the agreement, whichever occurs first. An employer shall not be obligated to enter into a withholding agreement. An agreement shall not be entered into with an employer not already located in a pilot project city when another Iowa community is competing for the same project and both the pilot project city and the other Iowa community are seeking assistance from the authority.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pilot project city and the economic development authority shall not enter into a withholding agreement after June 30, 2027.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer, in conjunction with the pilot project city, shall provide on an annual basis to the economic development authority information documenting the total amount of payments and receipts under a withholding agreement, including all agreements with an employer to suspend, abate, exempt, rebate, refund, or reimburse property taxes, to provide a grant for property taxes paid or a grant not related to property taxes, or to make a direct payment of taxes, with moneys in the withholding project fund. The economic development authority shall verify the information provided and determine whether the pilot project city and the employer are in compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the rules adopted by the economic development authority to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The economic development authority board, on behalf of the authority, shall have the authority to approve or deny a withholding agreement according to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Each withholding agreement, and the total amount of withholding credits allowed under the withholding agreement, shall be approved by the economic development authority board after taking into account the incentives or assistance received by or to be received by the employer under other economic development programs. The economic development authority board shall only deny an agreement if the agreement fails to meet the requirements of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or the local match requirements in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or if an employer is not in good standing as to prior or existing agreements with the economic development authority. The authority shall have the authority to negotiate a withholding agreement and may suggest changes to any of the terms of the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A withholding agreement shall be disclosed to the public and shall contain but is not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the adopted local development agreement between the pilot project city and the employer that outlines local incentives or assistance for the project using urban renewal or urban revitalization incentives, if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list of any other amounts of incentives or assistance the employer may be receiving from other economic development programs, including grants, loans, forgivable loans, and tax credits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The approval of local participating authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of local incentives or assistance received for each project of the employer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer shall certify to the department of revenue that the targeted jobs withholding credit is in accordance with the withholding agreement and shall provide other information the department may require. Notice of any withholding agreement shall be provided promptly to the department of revenue following execution of the agreement by the pilot project city and the employer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following termination of the withholding agreement, the employer credits shall cease and any money received by the pilot project city after termination shall be remitted to the treasurer of state to be deposited into the general fund of the state. Notice shall be provided promptly to the department of revenue following termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to rules adopted by the economic development authority, the employer shall provide on an annual basis to the economic development authority information documenting the employer\u8217\'3fs compliance with each requirement of the withholding agreement, including but not limited to the number of jobs created or retained and the amount of investment made by the employer. The economic development authority shall, in response to receiving such information from the employer, assess the level of compliance by each employer and provide to the pilot project city recommendations for either maintaining employer compliance with the withholding agreement or terminating the agreement for noncompliance under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The economic development authority shall also provide each such assessment and recommendation report to the department of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the economic development authority, following an eighteen-month performance period beginning on the date the withholding agreement is approved by the authority board, determines that the employer ceases to meet the requirements of the withholding agreement relating to retaining jobs, if applicable, the agreement shall be terminated by the economic development authority and the pilot project city and any withholding credits for the benefit of the employer shall cease. If the economic development authority, following a three-year performance period beginning on the date the withholding agreement is approved by the authority board, determines that the employer has not or is incapable of meeting the requirements of the withholding agreement relating to creating jobs, if applicable, or the requirement of the withholding agreement relating to the qualifying investment prior to the end of the withholding agreement, the economic development authority may reduce the future benefits to the employer under the agreement or negotiate with the other parties to terminate the agreement early. Notice shall be provided promptly by the pilot project city to the department of revenue following termination of a withholding agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pilot project city shall certify to the department of revenue the amount of the targeted jobs withholding credit an employer has remitted to the city and shall provide other information the department may require.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee whose wages are subject to a withholding agreement shall receive full credit for the amount withheld as provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer may participate in a new jobs credit from withholding under }}}{{\f5\fs18\hyphpar0\qj{section 260E.5}}}{{\f5\fs18\hyphpar0\qj{, or a supplemental new jobs credit from withholding under }}}{{\f5\fs18\hyphpar0\qj{section 15E.197, Code 2014,}}}{{\f5\fs18\hyphpar0\qj{ or under }}}{{\f5\fs18\hyphpar0\qj{section 15.331, Code 2005}}}{{\f5\fs18\hyphpar0\qj{, at the same time as the employer is participating in the withholding credit under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding any other provision in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the new jobs credit from withholding under }}}{{\f5\fs18\hyphpar0\qj{section 260E.5}}}{{\f5\fs18\hyphpar0\qj{, and the supplemental new jobs credit from withholding under }}}{{\f5\fs18\hyphpar0\qj{section 15E.197, Code 2014,}}}{{\f5\fs18\hyphpar0\qj{ or under }}}{{\f5\fs18\hyphpar0\qj{section 15.331, Code 2005}}}{{\f5\fs18\hyphpar0\qj{, shall be collected and disbursed prior to the withholding credit under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pilot project city entering into a withholding agreement shall arrange for matching local financial support for the project. The local match required under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be in an amount equal to one dollar for every dollar of withholding credit received by the pilot project city.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flocal financial support\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means cash or in-kind contributions to the project from a private donor, a business, or the pilot project city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the project, when completed, will increase the amount of an employer\u8217\'3fs taxable capital investment by an amount equal to at least ten percent of the amount of withholding credit dollars received by the pilot project city, then the pilot project city shall itself contribute at least ten percent of the local match amount computed under subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the project, when completed, will not increase the amount of an employer\u8217\'3fs taxable capital investment by an amount at least equal to ten percent of the amount of withholding credit dollars received by the pilot project city, then the pilot project city shall not be required to make a contribution to the local match.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pilot project city\u8217\'3fs contribution, if any, to the local match may include the dollar value of any tax abatement provided by the city to the business for new construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of submitting its budget to the department of management, the pilot project city shall submit to the department of management and the economic development authority a description of the activities involving the use of withholding agreements. The description shall include but is not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total number of targeted jobs and a breakdown as to those that are Iowa business expansions or retentions within the city limits of the pilot project city and those that are jobs resulting from established out-of-state businesses moving to or expanding in Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of withholding agreements and the amount of withholding credits involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The types of businesses that entered into agreements, and the types of businesses that declined the city\u8217\'3fs proposal to enter into an agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The economic development authority in consultation with the department of revenue shall coordinate the pilot project program with the pilot project cities under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The economic development authority is authorized to adopt, amend, and repeal rules to implement the pilot project program under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1141, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 2, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 126, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1122, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 103, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a737, 38}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a781, 85, 89}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 131, \'a7126 \u8211\'3f 129}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1018, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 111, \'a71 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1130, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 160, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 152, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a718, 19}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a72.48}}}{{\f5\fs12\hyphpar0\qj{, 15.499}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.20}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adjustment considered in value assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In determining the assessed value of property within an urban renewal area which is subject to a division of tax revenues pursuant to }{{\f5\fs18\hyphpar0\qj{section 403.19}}}{, the difference between the actual value of the property as determined by the assessor each year and the actual value of the property as determined by the assessor following application of the assessment limitations under }{{\f5\fs18\hyphpar0\qj{section 441.21, subsection 9}}}{, shall be subtracted from the actual value of the property as determined pursuant to }{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{. If the assessed value of the property as determined pursuant to }{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{, is reduced to zero, the additional valuation reduction shall be subtracted from the actual value of the property as determined by the assessor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7403.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a733, 38}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7357H.9}}}{{\f5\fs12\hyphpar0\qj{, 441.21A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment applies retroactively to assessment years beginning on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a738}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.21}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Communication and cooperation regarding new jobs training projects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to promote communication and cooperation among cities, counties, and community colleges with respect to the allocation and division of taxes, no jobs training projects as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 260E}}}{{\f5\fs18\hyphpar0\qj{ shall be undertaken within the area of operation of a municipality after July 1, 1995, unless the municipality and the community college have entered into an agreement or have jointly adopted a plan relating to a community college\u8217\'3fs new jobs training program which shall provide for a procedure for advance notification to each affected municipality, for exchange of information, for mutual consultation, and for procedural guidelines for all such new jobs training projects, including related project financing to be undertaken within the area of operation of the municipality. The joint agreement or the plan shall state its precise duration and shall be binding on the community college and the municipality with respect to all new jobs training projects, including related project financing undertaken during its existence. The joint agreement or plan shall be effective upon adoption and shall be placed on file in the office of the secretary of the board of directors of the community college and such other location as may be stated in the joint agreement or plan. The joint agreement or plan shall also be sent to each school district which levied or certified for levy a property tax on any portion of the taxable property located in the area of operation of the municipality in the fiscal year beginning prior to the calendar year in which the plan is adopted or the agreement is reached. If no such agreement is reached or plan adopted, the community college shall not use incremental property tax revenues to fund jobs training projects within the area of operation of the municipality. Agreements entered into between a community college and a city or county pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ shall not apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The community college shall send a copy of the final agreement prepared pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 260E.3}}}{{\f5\fs18\hyphpar0\qj{ to the department of workforce development. For each year in which incremental property taxes are used to pay job training certificates issued for a project creating new jobs, the community college shall provide to the department of workforce development a report of the incremental property taxes and new jobs credits from withholding generated for that year, a specific description of the training conducted, the number of employees provided program services under the project, the median wage of employees in the new jobs in the project, and the administrative costs directly attributable to the project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ For each year in which incremental property taxes are used to retire debt service on a jobs training advance issued for a project creating new jobs, the community college shall provide to the department of workforce development a report of the incremental property taxes and new jobs credits from withholding generated for that year, a specific description of the training conducted, the number of employees provided services under the project, the median wage of employees in the new jobs in the project, and the administrative costs directly attributable to the project.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1182, \'a713, 15}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1132, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72203}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.22}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public improvements related to housing and residential development \u8212\'3f low income assistance requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With respect to any urban renewal area established upon the determination that the area is an economic development area, a division of revenue as provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ shall not be allowed for the purpose of providing or aiding in the provision of public improvements related to housing and residential development, unless the municipality assures that the project will include assistance for low and moderate income family housing. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a municipality with a population over fifteen thousand, the amount to be provided for low and moderate income family housing for such projects shall be either equal to or greater than the percentage of the original project cost that is equal to the percentage of low and moderate income residents for the county in which the urban renewal area is located as determined by the United States department of housing and urban development using section 8 guidelines or by providing such other amount as set out in a plan adopted by the municipality and approved by the economic development authority if the municipality can show that it cannot undertake the project if it has to meet the low and moderate income assistance requirements. However, the amount provided for low and moderate income family housing for such projects shall not be less than an amount equal to ten percent of the original project cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a municipality with a population of fifteen thousand or less, the amount to be provided for low and moderate income family housing shall be the same as for a municipality of over fifteen thousand in population, except that a municipality of fifteen thousand or less in population is not subject to the requirement to provide not less than an amount equal to ten percent of the original project cost for low and moderate income family housing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a municipality with a population of five thousand or less, the municipality need not provide any low and moderate income family housing assistance if the municipality has completed a housing needs assessment meeting the standards set out by the economic development authority, which shows no low and moderate income housing need, and the economic development authority agrees that no low and moderate income family housing assistance is needed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assistance to low and moderate income housing may be in, but is not limited to, any of the following forms:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lots for low and moderate income housing within or outside the urban renewal area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Construction of low and moderate income housing within or outside the urban renewal area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Grants, credits or other direct assistance to low and moderate income families living within or outside the urban renewal area, but within the area of operation of the municipality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Payments to a low and moderate income housing fund established by the municipality to be expended for one or more of the above purposes, including matching funds for any state or federal moneys used for such purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sources for low and moderate income family housing assistance may include the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proceeds from loans, advances, bonds or indebtedness incurred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annual distributions from the division of revenues pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ related to the urban renewal area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lump sum or periodic direct payments from developers or other private parties under an agreement for development or redevelopment between the municipality and a developer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other sources which are legally available for this purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assistance to low and moderate income family housing may be expended outside the boundaries of the urban renewal area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for a municipality with a population under fifteen thousand, the division of the revenue under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ for each project under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be limited to tax collections for ten fiscal years beginning with the second fiscal year after the year in which the municipality first certifies to the county auditor the amount of any loans, advances, indebtedness, or bonds which qualify for payment from the division of the revenue in connection with the project.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality with a population under fifteen thousand may, with the approval of the governing bodies of all other affected taxing districts, extend the division of revenue under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ for up to five years if necessary to adequately fund the project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other time limitations provided by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, for urban renewal areas established before January 1, 2018, a municipality may, with the approval of the governing bodies of all other affected taxing districts, extend the division of revenue under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ for up to three years if necessary to adequately fund the project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The portion of the urban renewal area which is involved in a project under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be subject to any subsequent division of revenue under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality shall not prohibit or restrict the construction of manufactured homes in any project for which public improvements were finalized under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmanufactured home\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as under }}}{{\f5\fs18\hyphpar0\qj{section 435.1, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1204, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 214, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1100, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a742, 47}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.403}}}{{\f5\fs12\hyphpar0\qj{, 384.22}}}{{\f5\fs12\hyphpar0\qj{, 403.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{403.23}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Audit }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ certificate of compliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each municipality that has established an urban renewal area that utilizes, or plans to utilize, revenues from the special fund created in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{, shall make an annual certification of compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. For any year in which the municipality is audited in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 11.6}}}{{\f5\fs18\hyphpar0\qj{, such certification shall be audited as part of the municipality\u8217\'3fs audit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certification required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall include such information or documentation deemed appropriate by the auditor of state including but not limited to the information required to be reported under }}}{{\f5\fs18\hyphpar0\qj{section 331.403, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 384.22, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The auditor of state shall adopt rules necessary to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1124, \'a722}}}\par}}