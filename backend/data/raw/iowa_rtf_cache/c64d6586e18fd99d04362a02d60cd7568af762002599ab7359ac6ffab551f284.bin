\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F812}{\*\bkmkend codeChapter_5F812}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 812}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CONFINEMENT OF PERSONS FOUND}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\f5\fs18\qc\fi0\ri0\li0{ INCOMPETENT TO STAND TRIAL}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a713B.4}}}{{\f5\fs12\qc{, 226.27}}}{{\f5\fs12\qc{, 229.26}}}{{\f5\fs12\qc{, 229A.3}}}{{\f5\fs12\qc{, 229A.7}}}{{\f5\fs12\qc{, 331.190}}}{{\f5\fs12\qc{, 331.653}}}{{\f5\fs12\qc{, 801.1}}}{{\f5\fs12\qc{, 815.9}}}{{\f5\fs12\qc{, 815.10}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{812.1 and 812.2}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2004/CH1084.pdf" }{\fldrslt \f5 \fs18{{2004 Acts, ch 1084, \'a716}}}}}}{{\f5\fs18\qj{2004 Acts, ch 1084, \'a716}}}{.}{{\f5\fs18\qj{\~\~}}}{See }{{\f5\fs18\qj{\'a7811.1A}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{812.3}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mental incompetency of accused.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any stage of a criminal proceeding the defendant or the defendant\u8217\'3fs attorney, upon application to the court, alleges specific facts showing that the defendant is suffering from a mental disorder which prevents the defendant from appreciating the charge, understanding the proceedings, or assisting effectively in the defense, the court shall suspend further proceedings and determine if probable cause exists to sustain the allegations. The applicant has the burden of establishing probable cause. The court may on its own motion schedule a hearing to determine probable cause if the defendant or defendant\u8217\'3fs attorney has failed or refused to make an application under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the court finds that there are specific facts showing that a hearing should be held on that question. The defendant shall not be compelled to testify at the hearing and any testimony of the defendant given during the hearing shall not be admissible on the issue of guilt, except such testimony shall be admissible in proceedings under }}}{{\f5\fs18\hyphpar0\qj{section 811.2, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 811.8}}}{{\f5\fs18\hyphpar0\qj{, and in perjury proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a finding of probable cause sustaining the allegations, the court shall suspend further criminal proceedings and order the defendant to undergo a psychiatric evaluation to determine whether the defendant is suffering a mental disorder which prevents the defendant from appreciating the charge, understanding the proceedings, or assisting effectively in the defense. The order shall also authorize the evaluator to provide treatment necessary and appropriate to facilitate the evaluation. If an evaluation has been conducted within thirty days of the probable cause finding, the court is not required to order a new evaluation and may use the recent evaluation during a hearing under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. Any party is entitled to a separate psychiatric evaluation by a psychiatrist or licensed, doctorate-level psychologist of their own choosing.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73260, 3261; R60, \'a75015, 5016; C73, \'a74620, 4621; C97, \'a75540; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13905;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7783.1; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7812.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1084, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7812.5}}}{{\f5\fs12\hyphpar0\qj{, 812.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{812.4}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hearing shall be held within fourteen days of the arrival of the person at a psychiatric facility for the performance of the evaluation, or within five days of the court\u8217\'3fs motion or the filing of an application, if the defendant has had a psychiatric evaluation within thirty days of the probable cause finding, and upon which the court decides to rely. Pending the hearing, no further proceedings shall be taken under the complaint or indictment and the defendant\u8217\'3fs right to a speedy indictment and speedy trial shall be tolled until the court finds the defendant competent to stand trial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant shall be entitled to representation by counsel, including appointed counsel if indigent, and shall be entitled to the right of cross-examination and to present evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Testimony of the defendant given during the hearing shall not be admissible on the issue of guilt in any other judicial proceeding, except that such testimony shall be admissible in proceedings under }}}{{\f5\fs18\hyphpar0\qj{section 811.2, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 811.8}}}{{\f5\fs18\hyphpar0\qj{, and in perjury proceedings.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73262, 3263; R60, \'a75018, 5019; C73, \'a74623, 4624; C97, \'a75542; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13907;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7783.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7812.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1079, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 64, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1084, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 65, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{812.5}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Competency hearing \u8212\'3f findings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The court shall receive all relevant and material evidence offered at the hearing and shall not be bound by the formal rules of evidence. The evidence shall include the psychiatric evaluation ordered under }{{\f5\fs18\hyphpar0\qj{section 812.3}}}{ or conducted within thirty days of the probable cause finding.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court finds the defendant is competent to stand trial, the court shall reinstate the criminal proceedings suspended under }}}{{\f5\fs18\hyphpar0\qj{section 812.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court, by a preponderance of the evidence, finds the defendant is suffering from a mental disorder which prevents the defendant from appreciating the charge, understanding the proceedings, or assisting effectively in the defense, the court shall suspend the criminal proceedings indefinitely and order the defendant to be placed in a treatment program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 812.6}}}{{\f5\fs18\hyphpar0\qj{ and shall make further findings of record as necessary under }}}{{\f5\fs18\hyphpar0\qj{section 812.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73264 \u8211\'3f 3267; R60, \'a75020 \u8211\'3f 5023; C73, \'a74625 \u8211\'3f 4628; C97, \'a75543; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13908;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7783.4; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7812.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 21, \'a747}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1079, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1084, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{812.6}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Placement and treatment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ payment of costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court finds the defendant does not pose a danger to the public peace and safety, is otherwise qualified for pretrial release, and is willing to cooperate with treatment, the court shall order, as a condition of pretrial release, that the defendant obtain mental health treatment designed to restore the defendant to competency. The costs of treatment pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by an administrative services organization designated pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 225A.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court finds by clear and convincing evidence that the defendant poses a danger to the public peace or safety, or that the defendant is otherwise not qualified for pretrial release, or the defendant refuses to cooperate with treatment, the court shall commit the defendant to an appropriate inpatient treatment facility as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The defendant shall receive mental health treatment designed to restore the defendant to competency.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant who poses a danger to the public peace or safety, or who is otherwise not qualified for pretrial release, shall be committed as a safekeeper to the custody of the director of the department of corrections at the Iowa medical and classification center, or other appropriate treatment facility as designated by the director, for treatment designed to restore the defendant to competency. The costs of the treatment pursuant to this paragraph shall be borne by the department of corrections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant who does not pose a danger to the public peace or safety, but is otherwise being held in custody, or who refuses to cooperate with treatment, shall be committed to the custody of the director of health and human services at a department of health and human services facility for treatment designed to restore the defendant to competency. The costs of the treatment pursuant to this paragraph shall be borne by the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant ordered to obtain treatment or committed to a facility under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may refuse treatment by chemotherapy or other somatic treatment. The defendant\u8217\'3fs right to refuse chemotherapy treatment or other somatic treatment shall not apply if, in the judgment of the director or the director\u8217\'3fs designee of the facility where the defendant has been committed, such treatment is necessary to preserve the life of the defendant or to appropriately control behavior of the defendant which is likely to result in physical injury to the defendant or others. If in the judgment of the director of the facility or the director\u8217\'3fs designee where the defendant has been committed, chemotherapy or other somatic treatments are necessary and appropriate to restore the defendant to competency and the defendant refuses to consent to the use of these treatment modalities, the director of the facility or the director\u8217\'3fs designee shall request from the district court which ordered the commitment of the defendant an order authorizing treatment by chemotherapy or other somatic treatments.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1084, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7392}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a7116, 118}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1066, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71320}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 140, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7132, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7812.5}}}{{\f5\fs12\hyphpar0\qj{, 812.7}}}{{\f5\fs12\hyphpar0\qj{, 812.8}}}{{\f5\fs12\hyphpar0\qj{, 812.9}}}{{\f5\fs12\hyphpar0\qj{, 904.201}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{812.7}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mental status reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The psychiatrist or licensed doctorate-level psychologist evaluating the progress of the outpatient competency restoration treatment of the defendant, or the director of the facility where the defendant is being held and treated pursuant to a court order, shall provide a written status report to the court regarding the defendant\u8217\'3fs mental disorder, methods used to restore competency to the defendant, the defendant\u8217\'3fs current abilities related to competency, and whether it appears the defendant\u8217\'3fs competency can be restored within a reasonable amount of time. The psychiatrist, psychologist, or director shall submit an initial report to the court no later than thirty days after the defendant\u8217\'3fs placement pursuant to }{{\f5\fs18\hyphpar0\qj{section 812.6}}}{, and subsequent reports every sixty days or less after the submission of the initial report until the defendant\u8217\'3fs competency is restored or the placement of the defendant is terminated.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1084, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 140, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{812.8}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restoration of mental competency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time, upon a finding by a psychiatrist or licensed doctorate-level psychologist that there is a substantial probability that the defendant has acquired the ability to appreciate the charge, understand the proceedings, and effectively assist in the defendant\u8217\'3fs defense, the psychiatrist or licensed doctorate-level psychologist evaluating the progress of the defendant\u8217\'3fs outpatient treatment or the director of the inpatient facility shall immediately notify the court. After receiving notice the court shall proceed as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time, a treating psychiatrist or licensed doctorate-level psychologist may notify the court that the defendant receiving outpatient treatment will require inpatient services to continue benefiting from treatment or that it is appropriate for a defendant receiving inpatient treatment services to receive outpatient treatment services. Upon receiving notification, the court shall proceed as provided under }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time upon a finding by an evaluating psychiatrist or licensed doctorate-level psychologist that there is no substantial probability that the defendant will be restored to competency in a reasonable amount of time, the psychiatrist or licensed doctorate-level psychologist evaluating the defendant\u8217\'3fs outpatient treatment or the director of the inpatient facility shall immediately notify the court. Upon receiving notification, the court shall proceed as provided under }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving a notification under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court shall schedule a hearing to be held within fourteen days. The court shall also issue an order to transport the defendant to the hearing if the defendant is in custody or is being held in an inpatient facility. The defendant shall be transported by the sheriff of the county where the court\u8217\'3fs motion or the application pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 812.3}}}{{\f5\fs18\hyphpar0\qj{ was filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court finds by a preponderance of the evidence that the defendant\u8217\'3fs competency has been restored, the court shall terminate the placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 812.6}}}{{\f5\fs18\hyphpar0\qj{, and reinstate the criminal proceedings against the defendant, and may order continued treatment to maintain the competency of the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court finds by a preponderance of the evidence that the defendant remains incompetent to stand trial but is making progress in regaining competency, the court shall continue the placement ordered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 812.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may change the placement of a defendant and the placement may be more restrictive if necessary for the continued progress of the defendant\u8217\'3fs treatment as shown by clear and convincing evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court finds by a preponderance of the evidence that there is no substantial probability the defendant\u8217\'3fs competency will be restored in a reasonable amount of time, the court shall terminate the commitment under }}}{{\f5\fs18\hyphpar0\qj{section 812.6}}}{{\f5\fs18\hyphpar0\qj{ in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 812.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1084, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 140, \'a713}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7812.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{812.9}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Length of placement \u8212\'3f other commitment proceedings \u8212\'3f criminal proceedings after termination of placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 812.8}}}{{\f5\fs18\hyphpar0\qj{, the defendant shall not remain under placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 812.6}}}{{\f5\fs18\hyphpar0\qj{ beyond the expiration of the maximum term of confinement for the criminal offense of which the defendant is accused, or eighteen months from the date of the original adjudication of incompetence to stand trial, including time in jail, or the time when the court finds by a preponderance of the evidence that there is no substantial probability that the defendant will be restored to competency in a reasonable amount of time under }}}{{\f5\fs18\hyphpar0\qj{section 812.8, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, whichever occurs first. When the defendant\u8217\'3fs placement in an inpatient facility equals the length of the maximum term of confinement, the complaint for the criminal offense of which the defendant is accused shall be dismissed with prejudice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the defendant\u8217\'3fs commitment equals eighteen months, the court shall schedule a hearing to determine whether the defendant is competent to stand trial pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 812.8, subsection 5}}}{{\f5\fs18\hyphpar0\qj{. If the defendant is not competent to stand trial after eighteen months, the court shall terminate the placement under }}}{{\f5\fs18\hyphpar0\qj{section 812.6}}}{{\f5\fs18\hyphpar0\qj{ in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the termination of the defendant\u8217\'3fs placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 812.8, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, the state may commence civil commitment proceedings or any other appropriate commitment proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant\u8217\'3fs placement is terminated pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ or pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 812.8, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, and it appears thereafter that the defendant has regained competency, the state may make application to reinstate the prosecution of the defendant and hearing shall be held on the matter in the same manner as if the court has received notice under }}}{{\f5\fs18\hyphpar0\qj{section 812.8, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1084, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 3, \'a7113}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7812.8}}}\par}}