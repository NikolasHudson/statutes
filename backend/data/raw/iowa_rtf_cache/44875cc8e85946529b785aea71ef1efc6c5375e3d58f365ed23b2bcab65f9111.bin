\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F356}{\*\bkmkend codeChapter_5F356}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 356}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{JAILS AND MUNICIPAL HOLDING FACILITIES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7331.381}}}{{\f5\fs12\qc{, 331.653}}}{{\f5\fs12\qc{, 805.16}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{How used.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The jails in the several counties in the state shall be in the charge of the respective sheriffs and used as prisons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the detention of persons charged with an offense and committed for trial or examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the detention of persons who may be committed to secure their attendance as witnesses on the trial of a criminal cause.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the confinement of persons under sentence, upon conviction for any offense, and of all other persons committed for any cause authorized by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the confinement of persons subject to imprisonment under the ordinances of a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ extend to persons detained or committed by authority of the courts of the United States as well as of any state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73103; R60, \'a75122; C73, \'a7485, 4723; C97, \'a7735, 5637; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5497, 5772;}}}{ C46, 50, \'a7356.1, 368.40; C54, 58, 62, 66, 71, 73, \'a7356.1, 368.15; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1117, \'a72, 4}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 3, \'a767}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356A.1}}}{{\f5\fs12\hyphpar0\qj{, 356A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The sheriff shall have charge and custody of the prisoners in the jail or other prisons of the sheriff\u8217\'3fs county, and shall receive those lawfully committed, and keep them until discharged by law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7172; R60, \'a7385; C73, \'a7339; C97, \'a7501; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5498;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Minors separately confined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any sheriff, city marshal, or chief of police, having in the officer\u8217\'3fs care or custody any prisoner under the age of eighteen years, shall keep such prisoner separate and apart, and prevent communication by such prisoner with prisoners above that age, while such prisoners are not under the personal supervision of such officer, if suitable buildings or jails are provided for that purpose, unless such prisoner is likely to or does exercise an immoral influence over other minors with whom the prisoner may be imprisoned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under the age of eighteen years prosecuted under }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ and not waived to criminal court shall be confined in a jail only under the conditions provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any officer having charge of prisoners who without just cause or excuse neglects or refuses to perform the duties imposed on the officer by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be suspended or removed from office therefor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a75638; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5499;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.22}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Separation of men and women.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All jails shall be equipped with separate cells for men and women. Men and women prisoners shall not be allowed in the same cell within a jail at the same time.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a75639; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5500;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 21, \'a743}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Keeper\u8217\'3fs duty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The keeper of each jail shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See that the jail is kept in a clean and healthful condition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Furnish each prisoner with necessary bedding, clothing, towels, fuel, and medical aid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serve each prisoner three times each day with an ample quantity of wholesome food.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Furnish each prisoner sufficient clean, fresh water for drinking purposes and for personal use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep an accurate account of the items furnished each prisoner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep a matron on the jail premises at all times during the incarceration of one or more female prisoners; keep either a jailer or matron on the premises at all times during the incarceration of one or more male prisoners, and make nighttime inspections while any prisoners are confined, or provide for incarceration in a jail which conforms to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73104, 3108; R60, \'a75123, 5127; C73, \'a74724, 4727; C97, \'a75640, 5643; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5501;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.5}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.15}}}{{\f5\fs12\hyphpar0\qj{, 356.15A}}}{{\f5\fs12\hyphpar0\qj{, 356A.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sheriff\u8217\'3fs duty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The sheriff must keep an accurate calendar of each prisoner committed to the sheriff\u8217\'3fs care, which shall contain the prisoner\u8217\'3fs name, place of abode, the day and hour of commitment and discharge, the cause and term of commitment, the authority that committed the prisoner, and a description of the prisoner, a statement of the prisoner\u8217\'3fs occupation, education, and general habits. When any prisoner is discharged, such calendar must show the day and hour when and the authority by which it took place, and if a person escapes, it must state particularly the time and manner thereof.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73105; R60, \'a75124; C73, \'a74725; C97, \'a75641; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5502;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.6}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.6A}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty to inform about veteran services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The personnel of a jail or municipal holding facility shall inquire whether the prisoner is a veteran, and if so, shall inform the prisoner, within twenty-four hours of incarceration, that the prisoner may be entitled to a visit from a veteran service officer to determine if veteran services are required or available. Within seventy-two hours of determining a prisoner is a veteran, the personnel of a jail or municipal holding facility shall provide the prisoner with the contact information for the county commission of veteran affairs of the county where the jail or facility is located, and the prisoner shall be allowed to contact the county commission of veteran affairs to request a visit from a veteran service officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fveteran\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who was a member of the regular component of the armed forces of the United States, national guard, or reserves.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1101, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Charges for administrative costs and room and board \u8212\'3f enforcement procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county sheriff, or a municipality operating a temporary municipal holding facility or jail, may charge a prisoner who is eighteen years of age or older and who has been convicted of a criminal offense or sentenced for contempt of court for violation of a domestic abuse order for the actual administrative costs relating to the arrest and booking of that prisoner, for room and board provided to the prisoner while in the custody of the county sheriff or municipality, and for any medical aid provided to the prisoner under }}}{{\f5\fs18\hyphpar0\qj{section 356.5}}}{{\f5\fs18\hyphpar0\qj{. Moneys collected by the sheriff or municipality under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be credited respectively to the county general fund or the city general fund and distributed as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. If a prisoner who has been convicted of a criminal offense or sentenced for contempt of court for violation of a domestic abuse order fails to pay for the administrative costs, the room and board, or medical aid, the sheriff or municipality may file a reimbursement claim with the district court as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. The county attorney may file the reimbursement claim on behalf of the sheriff and the county or the municipality. The attorney for the municipality may also file a reimbursement claim on behalf of the municipality. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to prisoners who are paying for their room and board by court order pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 356.26 through 356.35}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff, municipality, or the county attorney, on behalf of the sheriff, or the attorney for the municipality, may file a reimbursement claim with the clerk of the district court which shall include all of the following information, if known:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name, date of birth, and social security number of the person who is the subject of the claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The present address of the residence and principal place of business of the person named in the claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The criminal proceeding pursuant to which the claim is filed, including the name of the court, the title of the action, and the court\u8217\'3fs file number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and office address of the person who is filing the claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the notice is being filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of room and board charges the person owes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of administrative costs the person owes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of medical aid the person owes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a claim for reimbursement, the court shall approve the claim in favor of the sheriff or the county, or the municipality, for the amount owed by the prisoner as identified in the claim and any fees or charges associated with the filing or processing of the claim with the court. The sheriff or municipality may choose to enforce the claim in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 626}}}{{\f5\fs18\hyphpar0\qj{. Once approved by the court, the claim for the amount owed by the person shall have the force and effect of a judgment for purposes of enforcement by the sheriff or municipality. However, irrespective of whether the judgment lien for the amount of the claim has been perfected, the claim shall not have priority over competing claims for child support obligations owed by the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A claim for reimbursement shall be filed in a separate civil action rather than as a claim in the underlying criminal case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the moneys collected and credited to the county general fund as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 602.8106, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), sixty percent of the moneys collected shall be used for the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Courthouse security equipment and law enforcement personnel costs.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Infrastructure improvements of a jail, including new or remodeling costs.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Infrastructure improvements of juvenile detention facilities, including new or remodeling costs.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Medical and prescription drug costs of inmates in jail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff may submit a plan or recommendations to the county board of supervisors for the use of the funds as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or the sheriff and board may jointly develop a plan for the use of the funds. Subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, funds may be used in the manner set forth in an agreement entered into under }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county board of supervisors shall review the plan or recommendations submitted by the sheriff during the normal budget process of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the moneys collected and credited to the city general fund as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, sixty percent of the moneys collected shall be used for police or law enforcement budget expenditures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadministrative costs relating to the arrest and booking of a prisoner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those functions or automated functions that are performed to receive a prisoner into jail or a temporary holding facility including the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Patting down and searching, booking, wristbanding, bathing, clothing, fingerprinting, photographing, and medical and dental screening.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Document preparation, retrieval, updating, filing, and court scheduling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Warrant service and processing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inventorying of a prisoner\u8217\'3fs money and subsequent account creation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inventorying and storage of a prisoner\u8217\'3fs property and clothing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Management and supervision.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1081, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1219, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 140, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1116, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 113, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1150, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a73, 60, 61, 64, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.659}}}{{\f5\fs12\hyphpar0\qj{, 356.15A}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(105C)}}}{{\f5\fs12\hyphpar0\qj{, 602.8105}}}{{\f5\fs12\hyphpar0\qj{, 602.8107}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Removal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a jail or any building contiguous or near thereto is on fire, and there is reason to apprehend that the prisoners therein may be injured thereby, the sheriff or keeper must remove such prisoners to some safe and convenient place, and there confine them so long as it may be necessary to avoid such danger.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73109; R60, \'a75128; C73, \'a74728; C97, \'a75644; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5504;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.8}}}{]}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{356.9 through 356.13}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.14}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Refractory prisoners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any person confined in a jail is refractory or disorderly or willfully destroys or injures any part of the jail or of its contents, the sheriff may secure the person or cause the person to be kept in solitary confinement not more than ten days for any one offense, during which time the person may be fed minimum diet requirements as established by the Iowa department of corrections unless other food is necessary for the preservation of the person\u8217\'3fs health.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73115; R60, \'a75134; C73, \'a74734; C97, \'a75650; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5510;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7113, 159}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.15}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All charges and expenses for the safekeeping and maintenance of prisoners shall be allowed by the board of supervisors, with the exception of charges and expenses for the following prisoners:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Those committed or detained by the authority of the courts of the United States, in which cases the United States must pay such expenses to the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Those committed for violation of a city ordinance, in which case the city shall pay expenses to the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Those committed or detained from another state, in which case the governmental entity from the other state sending the prisoners shall pay expenses to the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the charges and expenses allowed pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the costs of required medical aid furnished to prisoners in the custody of the county sheriff pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 356.5}}}{{\f5\fs18\hyphpar0\qj{ shall be paid as specified in }}}{{\f5\fs18\hyphpar0\qj{sections 356.15A}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{804.28}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73116; R60, \'a75135; C73, \'a7485, 4735; C97, \'a7735, 5651; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5511, 5772;}}}{ C46, 50, \'a7356.15, 368.40; C54, 58, 62, 66, 71, 73, \'a7356.15, 368.15; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1117, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1042, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7222}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.401}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.15A}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Responsibility for payment of required medical aid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGovernmental entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state or a state department, division, commission, institution, or authority, an agency, city, county, or special district in this state established pursuant to law, and, except where otherwise indicated, also means the United States or a department, division, or agency of the United States, and an agency, commission, or authority established pursuant to an interstate compact or agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth insurance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a policy, plan, contract, or other agreement providing health insurance, health care benefits, or health care services, provided by an entity including an insurance company offering sickness and accident plans, a health maintenance organization, a nonprofit health service corporation, or any other entity providing a plan of health insurance, health care benefits, or health care services. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth insurance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to private health insurance, Medicaid, and Medicare.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOther benefits\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to veterans administration benefits or other benefits for which the prisoner is eligible or entitled to pay for medical aid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPrisoner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual confined in a jail or municipal holding facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prisoner has the primary responsibility for payment of the costs of required medical aid provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 356.5}}}{{\f5\fs18\hyphpar0\qj{. Payment and reimbursement for medical aid provided to a prisoner shall be sought as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A governmental entity shall request available sources of health insurance or other benefits from a prisoner at the time of intake into a county jail or municipal holding facility. If the governmental entity identifies health insurance or other benefits to which the prisoner is entitled, the governmental entity shall provide the health insurance or benefit information to a hospital or medical provider at the time the prisoner is presented at the hospital or medical provider or at the earliest possible opportunity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hospital or medical provider shall request available sources of health insurance or other benefits from the governmental entity and the prisoner at the time of intake at or admission of the prisoner into the hospital or medical provider. The hospital or medical provider shall utilize the health insurance or other benefits identified and shall seek payment for medical aid through the prisoner\u8217\'3fs health insurance or other benefits prior to a request for reimbursement being presented to a governmental entity. If the prisoner is entitled to health insurance or other benefits to pay for the medical aid, any amounts not met by the prisoner\u8217\'3fs health insurance or other benefits shall be the responsibility of the prisoner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If health insurance is denied or other benefits are not available to pay for medical aid provided to a prisoner, a hospital or medical provider shall submit any bill for reimbursement of medical aid to the governmental entity within sixty days of treatment or shall submit any written denial of coverage to the governmental entity within sixty days of receipt of the denial, whichever is applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governmental entity shall submit the bill for reimbursement within thirty days of receipt of the bill and shall remit payment to the hospital or medical provider in the governmental entity\u8217\'3fs next billing cycle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The hospital or medical provider shall be reimbursed by the governmental entity at the rate negotiated and agreed upon by the hospital or medical provider and the governmental entity. If a rate has not been agreed to, the governmental entity shall reimburse the hospital or medical provider the hospital\u8217\'3fs or medical provider\u8217\'3fs Medicaid rate for such treatment, regardless of the prisoner\u8217\'3fs eligibility for Medicaid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{chapters 669}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{670}}}{{\f5\fs18\hyphpar0\qj{, a governmental entity shall not be responsible for payment of the costs of any medical aid provided to a prisoner if such medical aid is provided after the prisoner is released from the custody of the governmental entity or when the individual is released on parole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not preclude a city or a county from seeking reimbursement from a prisoner for the costs of medical aid incurred by the city or county for the prisoner\u8217\'3fs medical aid including as provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 356.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, payment for medical aid provided to a prisoner at a state-funded hospital shall be provided through state funds received by the hospital.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1042, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.16}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hard labor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Able-bodied persons over the age of sixteen, confined in any jail under the judgment of any tribunal authorized to imprison for the violation of any law, ordinance, bylaw or police regulation, may be required to labor during the whole or part of the time of their sentences, as hereinafter provided, and such tribunal, when passing final judgment of imprisonment, whether for nonpayment of fine or otherwise, shall have the power to and shall determine whether such imprisonment shall be at hard labor or not.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73107; R60, \'a75126; C73, \'a74736; C97, \'a75652; S13, \'a75652; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5512;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.16}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.303}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.17}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Labor on public works.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Such labor may be on the streets or public roads, on or about public buildings or grounds, or at such other places in the county where confined, and during such reasonable time of the day as the person having charge of the prisoners may direct, not exceeding eight hours each day.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74737; C97, \'a75653; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5513;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.17}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.303}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.18}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the sentence be for the violation of any of the statutes of the state, the sheriff of the county shall superintend the performance of the labor, and furnish the tools and materials, if necessary, to work with, at the expense of the county in which the convict is confined, and such county shall be entitled to the convict\u8217\'3fs earnings.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73107; R60, \'a75126; C73, \'a74738; C97, \'a75654; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5514;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.18}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.303}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.19}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules \u8212\'3f labor not to be leased.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Such labor shall be performed in accordance with such rules as may be made by resolution of the board of supervisors, not inconsistent with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and such labor shall not be leased.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a75654; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5515;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.19}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.303}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.20}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violation of city ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When the imprisonment is under the judgment of any court, for the violation of any ordinance, the marshal or chief of police shall superintend the labor and furnish the tools and materials, if necessary, at the expense of the city requiring the labor, and the city shall be entitled to the earnings of its convicts.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74739; C97, \'a75655; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5516;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.21}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Control and punishment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The officer having charge of any prisoner may use such means as are necessary to prevent the prisoner\u8217\'3fs escape, and if the prisoner attempts to escape or if, being convicted, the prisoner refuses to labor, the officer having the prisoner in charge may, to secure the prisoner or cause the prisoner to labor, deal with the prisoner as with other disorderly or refractory prisoners. Such punishment shall be inflicted within the jail or jail enclosure, and the time of such solitary confinement shall not be considered as any part of the time for which the prisoner is sentenced.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74740; C97, \'a75656; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5517;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.21}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.22}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Credit for labor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For every day of labor performed by any convict under the provisions hereof, there shall be credited on any judgment for fine and costs against the convict the sum of one dollar and fifty cents.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74741; C97, \'a75657; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5518;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.22}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.23}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cruel treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any officer or other person treats any prisoner in a cruel or inhuman manner, the officer or other person shall be guilty of a serious misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74742; C97, \'a75658; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5519;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.23}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.24}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Protecting prisoners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The officer having a prisoner in charge shall protect the prisoner from insult and annoyance and communication with others while at labor, and in going to and returning from the same, and may use such means as are necessary and proper therefor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74743; C97, \'a75659; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5520;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.24}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.25}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annoyance of prisoner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person persisting in insulting or annoying or communicating with any prisoner, after being commanded by such officer to desist, shall be guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74743; C97, \'a75659; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5521;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.25}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.26}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Leaving jail for certain purposes \u8212\'3f intermittent sentencing \u8212\'3f in-home detention.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The district court may grant by appropriate order to any person sentenced to a county jail the privilege of a sentence to accommodate the work schedule of the person or the privilege of leaving the jail at necessary and reasonable hours for any of the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seeking employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Working at the person\u8217\'3fs employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conducting the person\u8217\'3fs own business or other self-employed occupation, including housekeeping and attending to family needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Attendance at an educational institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Medical treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All released prisoners shall remain, while absent from the jail, in the legal custody of the sheriff, and shall be subject, at any time, to being taken into custody and returned to the jail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The district court may also grant by order to any person held in a county jail the privilege of in-home detention if the county sheriff has certified to the court that the jail has an in-home detention program.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.26}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1105, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 267, \'a7413}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1071, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.28}}}{{\f5\fs12\hyphpar0\qj{, 356.29}}}{{\f5\fs12\hyphpar0\qj{, 356.30}}}{{\f5\fs12\hyphpar0\qj{, 356.33}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.27}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Privilege expressly granted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless such privilege is expressly granted by the court, the prisoner is sentenced to ordinary confinement. Any prisoner may petition the court for such privilege at the time of sentencing or thereafter, and the court in its discretion may review the petition and make appropriate orders. The court may withdraw the privilege at any time by order entered with or without notice or hearing.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.27}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.28}}}{{\f5\fs12\hyphpar0\qj{, 356.29}}}{{\f5\fs12\hyphpar0\qj{, 356.30}}}{{\f5\fs12\hyphpar0\qj{, 356.33}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.28}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The sheriff or any suitable person or agency designated by the court may endeavor to secure employment for unemployed prisoners granted privileges under }{{\f5\fs18\hyphpar0\qj{sections 356.26 through 356.35}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.28}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7223}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.29}}}{{\f5\fs12\hyphpar0\qj{, 356.30}}}{{\f5\fs12\hyphpar0\qj{, 356.33}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.29}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wages or salary collected by sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a prisoner is employed for wages or salary the sheriff may collect the same or require the prisoner to turn over the wages or salary in full when received, and the sheriff shall deposit the same in a trust checking account and shall keep a ledger showing the status of the account of each prisoner. Such wages or salary are not subject to garnishment during the prisoner\u8217\'3fs term and shall be disbursed only as provided in }{{\f5\fs18\hyphpar0\qj{sections 356.26 through 356.35}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.29}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1144, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.28}}}{{\f5\fs12\hyphpar0\qj{, 356.30}}}{{\f5\fs12\hyphpar0\qj{, 356.33}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.30}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prisoner to pay for board }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every prisoner of a county jail under a sentence to accommodate the person\u8217\'3fs work schedule in accordance with }{{\f5\fs18\hyphpar0\qj{section 356.26}}}{ is liable for the cost of the prisoner\u8217\'3fs board in the jail as fixed by the county board of supervisors. The sheriff shall charge the prisoner\u8217\'3fs account for the board and any meals provided in }{{\f5\fs18\hyphpar0\qj{section 356.31}}}{. If the prisoner is gainfully self-employed the prisoner shall pay the sheriff for the board, in default of which the prisoner\u8217\'3fs privilege under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is automatically forfeited. If necessarily absent from jail at a meal time, the prisoner shall at the prisoner\u8217\'3fs request be furnished with a lunch to carry to work. If the jail food is furnished directly, by the county, the sheriff shall account for and pay over the meal payments to the county treasurer. The county board of supervisors may by resolution provide that the county furnish or pay for the transportation of prisoners employed under }{{\f5\fs18\hyphpar0\qj{sections 356.26 through 356.35}}}{ to and from the place of employment. However, the charges for board and meals under }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall not exceed fifty percent of the wages or salaries of the prisoner, after deductions required by law, including deductions to satisfy any court-ordered child support obligations, earned during the period of time for which the charges are made.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.30}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1144, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1105, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7224}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.303}}}{{\f5\fs12\hyphpar0\qj{, 356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.28}}}{{\f5\fs12\hyphpar0\qj{, 356.29}}}{{\f5\fs12\hyphpar0\qj{, 356.33}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.31}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application of wages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{By order of the court, the wages, salaries, or other income of employed prisoners shall be disbursed by the sheriff for the following purposes and in the order stated.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The meals of the prisoner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Necessary travel expense to and from work including reimbursement for travel furnished by the county, and other incidental expenses of the prisoner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support of the prisoner\u8217\'3fs dependents, if any.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Payment, either in full or ratably, of the prisoner\u8217\'3fs obligations if acknowledged by the prisoner in writing or which have been reduced to judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The balance, if any, to the prisoner upon the prisoner\u8217\'3fs release.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.31}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.28}}}{{\f5\fs12\hyphpar0\qj{, 356.29}}}{{\f5\fs12\hyphpar0\qj{, 356.30}}}{{\f5\fs12\hyphpar0\qj{, 356.33}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.32}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employment in another county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The court may by order authorize the sheriff to whom the prisoner is committed, to contract with a sheriff of another county, for the employment of the prisoner in the other\u8217\'3fs county, and while so employed to be in the other\u8217\'3fs custody, but in other respects to be and continue subject to the commitment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.32}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.28}}}{{\f5\fs12\hyphpar0\qj{, 356.29}}}{{\f5\fs12\hyphpar0\qj{, 356.30}}}{{\f5\fs12\hyphpar0\qj{, 356.33}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.33}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Orders of courts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{District judges, district associate judges, and judicial magistrates, within their respective jurisdictional authority, may make all determinations and orders under }}}{{\f5\fs18\hyphpar0\qj{sections 356.26 through 356.35}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the prisoner was convicted in a court in another county, the district court in the county where the prisoner is jailed, at the request or the concurrence of the committing court, may make all determinations and orders under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ as might otherwise be made by the sentencing court after the prisoner is received at the jail.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.33}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7225}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.28}}}{{\f5\fs12\hyphpar0\qj{, 356.29}}}{{\f5\fs12\hyphpar0\qj{, 356.30}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.34}}}{\*\bkmkstart stylerid1_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Support of dependents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The sheriff or any other suitable person or agency designated by the court shall, at the request of the court, investigate and report to the court the amount necessary for the support of the prisoner\u8217\'3fs dependents.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.34}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.28}}}{{\f5\fs12\hyphpar0\qj{, 356.29}}}{{\f5\fs12\hyphpar0\qj{, 356.30}}}{{\f5\fs12\hyphpar0\qj{, 356.33}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.35}}}{\*\bkmkstart stylerid1_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspension of privileges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The sheriff may in the sheriff\u8217\'3fs discretion suspend the privilege provided the sheriff files with the court the next regular court day a statement of the reasons therefor. Unless the court acts to rescind its order, such suspension of the privileges may not exceed five days.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.35}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.7}}}{{\f5\fs12\hyphpar0\qj{, 356.28}}}{{\f5\fs12\hyphpar0\qj{, 356.29}}}{{\f5\fs12\hyphpar0\qj{, 356.30}}}{{\f5\fs12\hyphpar0\qj{, 356.33}}}{{\f5\fs12\hyphpar0\qj{, 356A.4}}}{{\f5\fs12\hyphpar0\qj{, 903.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.36}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Jail standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa department of corrections, in consultation with the Iowa state sheriff\u8217\'3fs association, the Iowa peace officers association, the Iowa league of cities, and the Iowa board of supervisors association, shall draw up minimum standards for the regulation of jails, alternative jails, facilities established pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 356A}}}{{\f5\fs18\hyphpar0\qj{ and municipal holding facilities. When completed by the department, the standards shall be adopted as rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sole remedy for violation of a rule adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, is by a proceeding for compliance initiated by request to the Iowa department of corrections. A violation of a rule does not permit any civil action to recover damages against the state of Iowa, its departments, agents, or employees or any county, its agents or employees, or any city, its agents or employees.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, \'a7356.37 \u8211\'3f 356.43; }{{\f5\fs18\hyphpar0\qj{C81, \'a7356.36}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1133, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7114, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1127, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 3, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a744}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.37}}}{{\f5\fs12\hyphpar0\qj{, 356.43}}}{{\f5\fs12\hyphpar0\qj{, 356A.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.37}}}{\*\bkmkstart stylerid1_2E39_2E2_2E2}{\*\bkmkend stylerid1_2E39_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confinement and detention report }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ design proposals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The subunit of the department of health and human services responsible for criminal and juvenile justice planning, in consultation with the department of corrections, the Iowa county attorneys association, the Iowa state sheriff\u8217\'3fs association, the Iowa peace officers association, a statewide organization representing rural property taxpayers, the Iowa league of cities, and the Iowa board of supervisors association, shall prepare a report analyzing the confinement and detention needs of jails and facilities established pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and }{{\f5\fs18\hyphpar0\qj{chapter 356A}}}{. The report for each type of jail or facility shall include but is not limited to an inventory of prisoner space, daily prisoner counts, options for detention of prisoners with mental illness or substance use disorder service needs, and the compliance status under }{{\f5\fs18\hyphpar0\qj{section 356.36}}}{ for each jail or facility. The report shall contain an inventory of recent jail or facility construction projects in which voters have approved the issuance of general obligation bonds, essential county purpose bonds, revenue bonds, or bonds issued pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 423B}}}{. The report shall be revised periodically as directed by the director of health and human services. The first submission of the report shall include recommendations on offender data needed to estimate jail space needs in the next two, three, and five years, on a county, geographic region, and statewide basis, which may be based upon information submitted pursuant to }{{\f5\fs18\hyphpar0\qj{section 356.49}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1051, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1175, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 22, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71111}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{356.38 through 356.42}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.43}}}{\*\bkmkstart stylerid1_2E41_2E2_2E2}{\*\bkmkend stylerid1_2E41_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspection \u8212\'3f hearing \u8212\'3f remedial action \u8212\'3f report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa department of corrections and its inspectors and agents shall make periodic inspections of each jail or municipal holding facility and all facilities established pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 356A}}}{{\f5\fs18\hyphpar0\qj{, and officially notify the governing body of the political subdivision in writing to comply fully with }}}{{\f5\fs18\hyphpar0\qj{section 356.36}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa department of corrections may order the governing body of a political subdivision to either correct violations found in the inspection of a jail or municipal holding facility within a designated period, or may prohibit the confinement of prisoners in the jail or municipal holding facility. If the governing body fails to comply with the order within the period designated, the Iowa department of corrections may schedule a hearing on the alleged violation. The department may subpoena witnesses, documents, and other information deemed necessary to determine the validity of the alleged violation. The department shall upon written request from the governing body of the political subdivision grant representatives of the political subdivision the right to appear before the department at the hearing. The representatives have the right to counsel and may produce witnesses and present statements, documents, and other information with respect to the alleged violation for consideration at the hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department after the hearing shall affirm, revoke, or modify the original order. If the order is upheld, the department may include a schedule for correction of the violations and designate the date by which each violation shall be corrected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the political subdivision does not comply with the order within the designated period, the department may petition the attorney general to institute proceedings to enjoin the political subdivision from confining prisoners in the jail or municipal holding facility and require the transfer of prisoners to a jail or municipal holding facility declared by the director to be suitable for confinement. The county or municipality from which prisoners are transferred is liable for the cost of transfer and expenditures incurred in the confinement of prisoners in the jail or municipal holding facility to which transferred. Following inspection of any jail or municipal holding facility, a report of the inspection shall be filed with the director of the Iowa department of corrections. A copy of the report shall also be filed with the sheriff or chief of police, the governing body of the political subdivision, and one copy with the county attorney, which shall be presented at the next session of the grand jury of that county.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.43}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7115, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1127, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.756(53)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.44}}}{\*\bkmkstart stylerid1_2E42_2E2_2E2}{\*\bkmkend stylerid1_2E42_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules of sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county sheriff shall formulate rules for the conduct and behavior of county jail prisoners. These rules may include provisions for county jail prisoners to do all necessary cleaning and upkeep of cells, compartments, dormitories and day rooms. Extra penalties may be provided for intentional damage of county jail property. Such rules and regulations shall be approved by a district judge from the district in which the county jail is located.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.44}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.45}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.46}}}{\*\bkmkstart stylerid1_2E44_2E2_2E2}{\*\bkmkend stylerid1_2E44_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Time off for good behavior.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every prisoner in the county jail may, upon the recommendation of the sheriff or person in charge of the detention of the prisoner, and at the discretion of the sentencing judge, receive a reduction of sentence in an amount to be determined by the judge, if:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No infraction of the rules of discipline of the county jail or of the laws of the state has been recorded against the prisoner since the beginning of the prisoner\u8217\'3fs incarceration; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prisoner has performed in a faithful manner the duties assigned to the prisoner.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.46}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 78, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.47}}}{\*\bkmkstart stylerid1_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sentence suspended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A judge who sentences a person to the county jail or other detention facility pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, may suspend any part of such sentence and place such person on probation, upon such terms and conditions as the sentencing judge may direct, after such person has served that part of the person\u8217\'3fs sentence which was not suspended.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7356.47}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.48}}}{\*\bkmkstart stylerid1_2E46_2E2_2E2}{\*\bkmkend stylerid1_2E46_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Required test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person confined to a jail or in the custody of a peace officer, who bites another person, who causes an exchange of bodily fluids with another person, or who causes any bodily secretion to be cast upon another person, shall submit to the withdrawal of a bodily specimen for testing to determine if the person is infected with a contagious or infectious disease as defined in }}}{{\f5\fs18\hyphpar0\qj{section 141A.2}}}{{\f5\fs18\hyphpar0\qj{. The bodily specimen to be taken shall be determined by the attending physician of the jail or the county medical examiner. The specimen taken shall be sent to the state hygienic laboratory or some other laboratory approved by the department of health and human services. If a person to be tested pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ refuses to submit to the withdrawal of a bodily specimen, the sheriff, person in charge of the jail, or any potentially infected person may file an application with the district court for an order compelling the person that may have caused an infection to submit to the withdrawal and, if infected, to receive available treatment. An order authorizing the withdrawal of a specimen for testing may be issued only by a district judge or district associate judge upon application by the sheriff, person in charge of the jail, or any other potentially infected person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who fails to comply with an order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personnel at the jail shall be notified if a person confined is found to have a contagious or infectious disease.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sheriff, person in charge of the jail, or any other potentially infected person shall take any appropriate measure to prevent the transmittal of a contagious or infectious disease to other persons. The sheriff or person in charge of the jail shall also segregate a confined person who tests positive for acquired immune deficiency syndrome from other confined persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpotentially infected person\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a care provider as defined in }}}{{\f5\fs18\hyphpar0\qj{section 139A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 185, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 87, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71112}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.49}}}{\*\bkmkstart stylerid1_2E47_2E2_2E2}{\*\bkmkend stylerid1_2E47_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Jail report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A county sheriff shall file, on a monthly basis, a written report with the director of the department of corrections. The report shall include, but not be restricted to, the total number of men, women, and juveniles held in the jail for the reporting month. The director shall adopt and provide a uniform reporting form to be utilized by county sheriffs.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 159, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7356.37}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{356.50}}}{\*\bkmkstart stylerid1_2E48_2E2_2E2}{\*\bkmkend stylerid1_2E48_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Private transportation of prisoners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a county sheriff contracts with a private person or entity for the transportation of prisoners to or from a county jail, the contract shall include provisions which require the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The private person or any officers or employees of the private person or private entity shall not have been convicted of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within the three-year period immediately preceding the date of the execution of the contract, a violation of the laws pertaining to operation of motor vehicles punishable as a serious misdemeanor or greater offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Domestic abuse assault in which bodily injury was inflicted or attempted to be inflicted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A crime involving illegal manufacture, use, possession, sale, or an attempt to illegally manufacture, use, possess, or sell alcohol or a controlled substance or other drug.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person or persons actually transporting the prisoners shall be trained and proficient in the safe use of firearms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any employees of a private entity which has entered into the contract for transportation of prisoners shall only possess and use security and restraint equipment, including any firearms, which has been issued by the private entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person or persons actually transporting the prisoners shall be trained and proficient in appropriate transportation procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person or entity complies, within one year of publication, with any applicable standards for the transportation of prisoners promulgated by the American corrections association.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1131, \'a72}}}\par}}