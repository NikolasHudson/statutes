\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F555B}{\*\bkmkend codeChapter_5F555B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 555B}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{DISPOSAL OF ABANDONED MOBILE HOMES AND}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\f5\fs18\qc\fi0\ri0\li0{ PERSONAL PROPERTY}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7321.47}}}{{\f5\fs12\qc{, 562B.27}}}{{\f5\fs12\qc{, 631.4}}}{{\f5\fs12\qc{, 631.5}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{See also }{{\f5\fs12\qc{chapter 555C}}}{ relating to valueless homes}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless the context otherwise requires, in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAbandoned\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means abandoned as provided in }}}{{\f5\fs18\hyphpar0\qj{section 562B.27, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClaimant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to any government subdivision with authority to levy a tax on abandoned personal property. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClaimant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also includes a holder of a lien as defined in }}}{{\f5\fs18\hyphpar0\qj{section 555B.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDemolisher\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means demolisher as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.89}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fJunkyard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means junkyard as defined in }}}{{\f5\fs18\hyphpar0\qj{section 306C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMobile home\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes \u8220\'3fmanufactured homes\u8221\'3f and \u8220\'3fmodular homes\u8221\'3f as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 435.1}}}{{\f5\fs18\hyphpar0\qj{, if the manufactured homes or modular homes are located in a manufactured home community or mobile home park.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes personal property of the mobile home owner in the abandoned mobile home, on the mobile home lot, in the immediate vicinity of the abandoned mobile home and the mobile home lot, and in any storage area provided by the real property owner for the use of the mobile home owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReal property owner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the owner or other lawful possessor of real property upon which a mobile home is located.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 154, \'a76, 7}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a721, 24}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 155, \'a71, 14}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 153, \'a716}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Removal \u8212\'3f notice to sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A real property owner may remove or cause to be removed a mobile home and other personal property which is unlawfully parked, placed, or abandoned on that real property, and may cause the mobile home and personal property to be placed in storage until the owner of the personal property pays a fair and reasonable charge for removal, storage, or other expense incurred, including reasonable attorney fees, or until a judgment of abandonment is entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.8}}}{{\f5\fs18\hyphpar0\qj{ provided that there is no lien on the mobile home or personal property other than a tax lien pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 435}}}{{\f5\fs18\hyphpar0\qj{. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a lien other than a tax lien exists only if the real property owner receives notice of a lien on the standardized registration form completed by a tenant pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 562B.27, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or a lien has been filed in state or county records on a date before the mobile home is considered to be abandoned. The real property owner or the real property owner\u8217\'3fs agent is not liable for damages caused to the mobile home and personal property by the removal or storage unless the damage is caused willfully or by gross negligence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The real property owner shall notify the sheriff of the county where the real property is located of the removal of the mobile home and other personal property.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the mobile home owner can be determined, and if the real property owner so requests, the sheriff shall notify the mobile home owner of the removal by restricted certified mail. If the mobile home owner cannot be determined, and the real property owner so requests, the sheriff shall give notice by one publication in one newspaper of general circulation in the county where the mobile home and personal property were unlawfully parked, placed, or abandoned. If the mobile home and personal property have not been claimed by the owner within six months after notice is given, the mobile home and personal property shall be sold by the sheriff at a public or private sale. After deducting costs of the sale the net proceeds shall be applied to the cost of removal, storage, notice, attorney fees, and any other expenses incurred for preserving the mobile home and personal property, including any rent owed by the mobile home owner to the real property owner in connection with the presence of the mobile home on the real property. The remaining net proceeds, if any, shall be paid to the county treasurer to satisfy any tax lien on the mobile home. The remainder, if any, shall be retained by the county treasurer. A sheriff\u8217\'3fs sale transfers to the purchaser for value, all of the mobile home owner\u8217\'3fs rights in the mobile home and personal property, and discharges the real property owner\u8217\'3fs interest in the mobile home and personal property, and discharges the tax lien on the mobile home. If the purchaser acts in good faith the purchaser takes free of all rights and interests even though the real property owner fails to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or of any judicial proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the real property owner removes the mobile home and personal property but does not request that the sheriff notify the mobile home owner, the real property owner shall proceed with an action for abandonment as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 555B.3 through 555B.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 154, \'a78, 9}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a722, 24}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7555B.1}}}{{\f5\fs12\hyphpar0\qj{, 555B.3}}}{{\f5\fs12\hyphpar0\qj{, 562B.27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Action for abandonment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A real property owner not requesting notification by the sheriff as provided in }{{\f5\fs18\hyphpar0\qj{section 555B.2}}}{ may bring an action alleging abandonment in the court within the county where the real property is located. The action shall be tried as an equitable action. Unless commenced as a small claim, the petition shall be presented to a district judge. Upon receipt of the petition, either the court or the clerk of the district court shall set a date for a hearing not later than fourteen days from the date of the receipt of the petition, except where there is a lien on the mobile home or personal property other than a tax lien, the court or the clerk of the district court shall set a date for a hearing no sooner than twenty-five days from the date of the receipt of the petition so as to allow for service on the lienholder.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 154, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1070, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7555B.2}}}{{\f5\fs12\hyphpar0\qj{, 562B.10}}}{{\f5\fs12\hyphpar0\qj{, 631.1}}}{{\f5\fs12\hyphpar0\qj{, 648.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personal service pursuant to rule of civil procedure 1.305 shall be made upon the mobile home owner not less than ten days before the hearing. If personal service cannot be completed in time to give the mobile home owner the minimum notice required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court may set a new hearing date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If personal service cannot be made on the mobile home owner because the mobile home owner is avoiding service or cannot be found, service may be made by mailing a copy of the petition and notice of hearing to the mobile home owner\u8217\'3fs last known address and publishing the notice in one newspaper of general circulation in the county where the petition is filed. If the mobile home owner\u8217\'3fs address is not known to the real property owner, service may be made pursuant to }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.313}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{ except that service is complete seven days after the initial publication. The court shall set a new hearing date if necessary to allow the ten-day minimum notice required under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a tax lien exists on the mobile home or personal property at the time an action for abandonment is initiated, the real property owner shall notify the county treasurer of each county in which a tax lien appears by restricted certified mail sent not less than ten days before the hearing. The notice shall describe the mobile home and shall state the docket, case number, date, and time at which the hearing is scheduled, and the county treasurer\u8217\'3fs right to assert a claim to the mobile home at the hearing. The notice shall also state that failure to assert a claim to the mobile home is deemed a waiver of all right, title, claim, and interest in the mobile home and is deemed consent to the sale or disposal of the mobile home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a lien other than a tax lien exists on the mobile home or personal property at the time an action for abandonment is initiated, the personal service pursuant to the Iowa rules of civil procedure shall be made upon the lienholder no less than twenty days before the hearing. The notice to the lienholder shall describe the mobile home and shall state the docket, case number, date, and time at which the hearing is scheduled, and the lienholder\u8217\'3fs right to assert a claim to the mobile home at the hearing. The notice shall state that failure to assert a claim to the mobile home within the judicial proceedings is deemed a waiver of all rights, title, claims, and interest in the mobile home and deemed to be consent to the sale or disposal of the mobile home. If personal service cannot be completed in time to give the lienholder the minimum notice required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the court may set a new hearing date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event a tenant who was sole owner of a mobile home dies during the term of the rental agreement resulting in the mobile home being abandoned, service shall be made in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 562B.10, subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 154, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1070, \'a721}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7555B.2}}}{{\f5\fs12\hyphpar0\qj{, 555B.9}}}{{\f5\fs12\hyphpar0\qj{, 562B.10}}}{{\f5\fs12\hyphpar0\qj{, 631.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Change of venue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In an action under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ a change of place of trial may be had as in other cases.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7555B.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Priority of assignment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An action under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be accorded reasonable priority for assignment to assure prompt disposition.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7555B.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Remedy not exclusive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An action under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may be brought in connection with a claim for monetary damages, possession, or recovery as provided in }{{\f5\fs18\hyphpar0\qj{section 562B.25}}}{ or }{{\f5\fs18\hyphpar0\qj{562B.30}}}{ or }{{\f5\fs18\hyphpar0\qj{chapter 648}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.7}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7555B.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines that the mobile home and personal property have been abandoned, judgment shall be entered in favor of the real property owner for the reasonable costs of removal, storage, notice, and attorney fees; any other expenses incurred for preserving the mobile home and personal property or for bringing the action; and, if the action is brought in conjunction with one for monetary damages, the amount of monetary damages assessed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise ordered by the court, if the mobile home owner or other claimant asserts a claim to the property, the judgment shall be satisfied before the mobile home owner or other claimant may take possession of the mobile home or personal property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If no claim is asserted to the mobile home or personal property or if the judgment is not satisfied at the time of entry, an order shall be entered allowing the real property owner to sell or otherwise dispose of the mobile home and personal property pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.9}}}{{\f5\fs18\hyphpar0\qj{. Except as otherwise ordered by the court, if a claimant satisfies the judgment at the time of entry, the court shall enter an order permitting and directing the claimant to remove the mobile home or personal property from its location within a reasonable time to be fixed by the court. The court shall also determine the amount of further rent or storage charges to be paid by the claimant to the real property owner at the time of removal.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1070, \'a722}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.90}}}{{\f5\fs12\hyphpar0\qj{, 435.24}}}{{\f5\fs12\hyphpar0\qj{, 555B.2}}}{{\f5\fs12\hyphpar0\qj{, 555B.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disposal \u8212\'3f proceeds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to an order for disposal under }}}{{\f5\fs18\hyphpar0\qj{section 555B.8, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the real property owner shall dispose of the mobile home and personal property by public or private sale in a commercially reasonable manner. If the personal property owner, lienholder, or other claimant has asserted a claim to the mobile home or personal property within the judicial proceedings, that person shall be notified of the sale by restricted certified mail not less than five days before the sale. The notice is deemed given upon the mailing. The real property owner may buy at any public sale, and if the mobile home or personal property is of a type customarily sold in a recognized market or is the subject of widely distributed standard price quotations, the real property owner may buy at a private sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sale pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ transfers to the purchaser for value, all of the mobile home owner\u8217\'3fs rights in the mobile home and personal property, and discharges the real property owner\u8217\'3fs interest in the mobile home and personal property, any tax lien, and any other lien. The purchaser takes free of all rights and interests even though the real property owner fails to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or of any judicial proceedings, if the purchaser acts in good faith.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of the sale of mobile home and personal property shall be distributed as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{First, to satisfy the real property owner\u8217\'3fs judgment obtained under }}}{{\f5\fs18\hyphpar0\qj{section 555B.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Second, to satisfy any tax lien for which a claim was asserted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.4, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Third, to satisfy any other lien for which a claim was asserted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.4, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any surplus remaining after the proceeds are distributed shall be held by the real property owner for six months. If the mobile home owner fails to claim the surplus in that time, the surplus may be retained by the real property owner. If a deficiency remains after distribution of the proceeds, the mobile home owner is liable for the amount of the deficiency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 3}}}{{\f5\fs18\hyphpar0\qj{, the real property owner may propose to retain the mobile home and personal property in satisfaction of the judgment obtained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.8}}}{{\f5\fs18\hyphpar0\qj{. Written notice of the proposal shall be sent to the mobile home owner, lienholder, or other claimant, if that person has asserted a claim to the mobile home or personal property in the judicial proceedings. If the real property owner receives objection in writing from the mobile home owner, lienholder, or other claimant within twenty-one days after the notice was sent, the real property owner shall dispose of the mobile home and personal property pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. If no written objection is received by the real property owner within twenty-one days after the notice was sent, the mobile home and personal property may be retained. Retention of the mobile home and personal property discharges the judgment of the real property owner, any tax lien, and any other lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the real property owner has made a good faith attempt to sell the mobile home and personal property pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ but is unsuccessful and elects not to retain the mobile home and personal property pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, the real property owner may dispose of the mobile home and personal property to a demolisher or junkyard. Proceeds from the disposition shall be distributed pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. If the personal property is a motor vehicle to which }}}{{\f5\fs18\hyphpar0\qj{section 321.90}}}{{\f5\fs18\hyphpar0\qj{ applies, the real property owner shall present the order for disposal obtained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.8, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, to the police authority to obtain a certificate of authority to dispose of the motor vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.90, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1070, \'a723, 24}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.90}}}{{\f5\fs12\hyphpar0\qj{, 555B.2}}}{{\f5\fs12\hyphpar0\qj{, 555B.8}}}{{\f5\fs12\hyphpar0\qj{, 648.22A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{555B.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitation on liability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A real property owner who disposes of a mobile home or personal property in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is not liable for damages by reason of the removal, sale, or disposal of the mobile home and personal property unless the damage is caused willfully or by gross negligence. Upon a motion to the district court and a showing that the real property owner is not proceeding in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the court may enjoin the real property owner from proceeding further and a determination for the proper disposition of the mobile home and personal property shall be made. If disposition of the mobile home or personal property has not occurred in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the owner thereof has a right to recover from the real property owner, any loss caused by failure to comply with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The burden of proof shall be upon the mobile home or personal property owner to show that the real property owner has not complied with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in disposing of a mobile home or personal property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fact that a better price could have been obtained by a sale at a different time or in a different method from that selected by the real property owner is not of itself sufficient to establish that the sale was not made in a commercially reasonable manner. If the real property owner sells the mobile home and personal property in the usual manner in any recognized market or if the real property owner sells at the price current in the market at the time of the real property owner\u8217\'3fs sale or if the real property owner has otherwise sold in conformity with reasonable commercial practices among dealers in the type of mobile home or personal property sold, the real property owner has sold in a commercially reasonable manner. A disposition approved in any judicial proceeding shall be deemed conclusively to be commercially reasonable.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C89, \'a7562C.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7555B.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 154, \'a712}}}\par}}