}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.1; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbook\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecord\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschedule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ kept by a county auditor, assessor, treasurer, recorder, sheriff, or other county officer means the county system as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the following terms shall be construed, respectively, to mean:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E6_2E4_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInsect pests and diseases.\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Insect pests and diseases injurious to plants and plant products, including any of the stages of development of such insect pests and diseases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E6_2E4_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPlaces.\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vessels, cars, boats, trucks, automobiles, aircraft, wagons and other vehicles or carriers, whether air, land or water, buildings, docks, nurseries, greenhouses, orchards, fields, gardens, and other premises or any container where plants and plant products are grown, kept or handled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E6_2E4_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPlants and plant products.\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Trees, shrubs, vines, berry plants, greenhouse plants and all other nursery plants; forage and cereal plants, and all other parts of plants; cuttings, grafts, scions, buds, and all other parts of plants; and fruit, vegetables, roots, bulbs, seeds, wood, lumber, and all other plant products.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a74062-b2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.2; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1148, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State entomologist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{There is hereby created and established within the department of agriculture and land stewardship the office of state entomologist. The state entomologist shall be appointed by, responsible to and under the authority of the secretary of agriculture in the issuance of all rules, the establishment of quarantines and other official acts. The secretary of agriculture shall provide the state entomologist with suitable office space.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a47; C24, \'a74045; C27, 31, 35, \'a74062-b3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.3; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.3}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 70, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employees \u8212\'3f expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purpose of carrying out the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the state entomologist with the approval of the secretary of agriculture shall employ, prescribe the duties of, and fix the compensation of, such inspectors, and other employees as needed and incur such expenses as may be necessary, within the limits of appropriations made by law. The state entomologist shall cooperate with other departments, boards and officers of the state and of the United States as far as practicable.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a47; C24, \'a74046; C27, 31, 35, \'a74062-b4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.4; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1023, \'a7157}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties \u8212\'3f public nuisances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state entomologist shall keep informed as to known species and varieties of insect pests and diseases, the origin, locality, nature and appearance thereof, the manner in which they are disseminated, and approved methods of treatment and eradication. In the rules made pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ the state entomologist shall list the dangerously injurious insect pests and diseases which the entomologist shall find should be prevented from being introduced into, or disseminated within, this state in order to safeguard the plants and plant products likely to become infested or infected with such insect pests and diseases. Every such insect pest and disease listed, and every plant product infested or infected therewith, is hereby declared to be a public nuisance. Every person who has knowledge of the presence in or upon any place of any insect pest or disease so listed, shall immediately report the fact and location to the state entomologist, or the assistant state entomologist, giving such detailed information relative thereto as the person may have. Every person who deals in or engages in the sale of plants and plant products shall furnish to the state entomologist or the entomologist\u8217\'3fs inspectors, when requested, a statement of the names and addresses of the persons from whom and the localities where the person purchased or obtained such plants and plant products.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a47; C24, \'a74047; C27, 31, 35, \'a74062-b5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.5; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.5}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Nuisances in general, }{{\f5\fs12\hyphpar0\qj{chapter 657}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state entomologist shall, from time to time, adopt rules for carrying out the provisions and requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, including rules under which the inspectors and other employees shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inspect places, plants and plant products, and things and substances used or connected therewith,}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Investigate, control, eradicate and prevent the dissemination of insect pests and diseases, and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Supervise or cause the treatment, cutting and destruction of plants and plant products infested or infected therewith.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state entomologist, the entomologist\u8217\'3fs inspectors, employees, or other authorized agents shall have authority to enforce these rules which shall be published in the same manner as are the other rules of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nursery stock dealer shall not sell, offer for sale, or distribute nursery products by any method, or under any circumstances or condition, which has the capacity and tendency or effect of deceiving purchasers or prospective customers as to quantity, size, grade, kind, species, age, maturity, viability, condition, vigor, hardiness, number of times transplanted, growth ability, growth characteristics, rate of growth or time required before flowering or fruiting, price, origin or place where grown, or in any other material respect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ it becomes necessary for the state entomologist to verify sizes and grades of nursery stock, or either of them, the entomologist shall use as a guide the \u8220\'3fAmerican Standard for Nursery Stock\u8221\'3f as revised and approved by the American standards association, inc.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a48; C24, \'a74050, 4051, 4054; C27, 31, 35, \'a74062-b6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.6; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a773}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Infection \u8212\'3f eradication \u8212\'3f notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever inspection discloses that any places, or plants or plant products, or things and substances used or connected therewith, are infested or infected with any dangerously injurious insect pest or disease listed as a public nuisance, written notice thereof shall be given the owner or person in possession or control of the place where found, who shall proceed to control, eradicate, or prevent the dissemination of such insect pest or disease, and to remove, cut, or destroy infested and infected plants and plant products, or things and substances used or connected therewith, as prescribed in the notice or the rules. Whenever such owner or person in possession cannot be found, or shall fail, neglect or refuse to obey the requirements of the notice and the rules, such requirements shall be carried out by the state entomologist, as required by }{{\f5\fs18\hyphpar0\qj{section 177A.17}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a48; C24, \'a74050, 4052, 4053, 4055; C27, 31, 35, \'a74062-b7; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.7; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.7}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Importation \u8212\'3f regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be unlawful for any person to bring or cause to be brought into this state any plant or plant product listed in the rules, unless there be plainly and legibly marked thereon or affixed thereto, or on or to the carrier, or the bundle, package, or container, in a conspicuous place, a statement or tag or device showing the names and addresses of the consignors or shippers and the consignees or persons to whom shipped, the general nature and quantity of the contents, and the name of the locality where grown, together with a certificate of inspection of the proper official of the state, territory, district, or country from which it was brought or shipped, showing that such plant or plant product was found or believed to be free from dangerously injurious insect pests and diseases, and giving any other information required by the state entomologist.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a50; C24, \'a74058; C27, 31, 35, \'a74062-b8; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.8; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.8}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.9}}}{{\f5\fs12\hyphpar0\qj{, 177A.10}}}{{\f5\fs12\hyphpar0\qj{, 177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspection \u8212\'3f certificate \u8212\'3f fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any person to sell, give away, carry, ship, or deliver for carriage or shipment, within this state, any plants or plant products listed in the rules unless such plants or plant products have been officially inspected and a certificate issued by an inspector of the state entomologist\u8217\'3fs office stating that such plants or plant products have been inspected and found to be apparently free from dangerously injurious insect pests and diseases, and giving any other facts provided for in the rules. For the issuance of such certificate, the state entomologist may require the payment of a reasonable fee to cover the expense of such inspection and certification. Provided, that if such plants or plant products were brought into this state in compliance with }}}{{\f5\fs18\hyphpar0\qj{section 177A.8}}}{{\f5\fs18\hyphpar0\qj{, the certificate required by that section may be accepted in lieu of the inspection and certificate required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, in such cases as shall be provided for in the rules. If it shall be found at any time that a certificate of inspection, issued or accepted under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, is being used in connection with plants and plant products which are infested or infected with dangerously injurious insect pests or diseases or in connection with uninspected plants, its further use may be prohibited, subject to such inspection and disposition of the plants and plant products involved as may be provided for by the state entomologist. All moneys collected under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be turned over to the secretary who shall deposit them in the state treasury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fees for inspections and certifications shall not be less than twenty-five dollars nor more than five hundred dollars. Certificates shall be issued to nursery stock growers and dealers on an annual basis. Inspection and certification fees for nursery stock growers shall be twenty-five dollars plus five dollars per acre or part thereof, according to the amount of stock inspected. The inspection and certification fee for nursery stock dealers shall be twenty-five dollars. All fees shall be paid at the time of inspection or before a certificate is issued. Inspection and certification shall take place when necessary to enforce }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the rules pursuant to it. Certificates issued in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may be revoked when inspection results determine that conditions violate the standards for which certification was issued.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a47, -a49; C24, \'a74047, 4048, 4057; C27, 31, 35, \'a74062-b9; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.9; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.9}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 70, \'a72}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1272, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.10}}}{{\f5\fs12\hyphpar0\qj{, 177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Report of violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who receives from without the state any plant or plant product without }{{\f5\fs18\hyphpar0\qj{section 177A.8}}}{ having been complied with, or who receives any plant or plant product sold, given away, carried, shipped or delivered for carriage or shipment within this state without }{{\f5\fs18\hyphpar0\qj{section 177A.9}}}{ having been complied with, shall immediately inform the state entomologist or one of the entomologist\u8217\'3fs inspectors of such facts and isolate and hold the plant or plant product unopened or unused, subject to such inspection and disposition as may be provided for by the state entomologist.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a49; C24, \'a74057; C27, 31, 35, \'a74062-b10; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.10; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.10}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Quarantine \u8212\'3f general powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever the state entomologist shall find that there exists outside of this state any insect pest or disease, and that its introduction into this state should be prevented in order to safeguard plants and plant products in this state, the state entomologist is authorized to quarantine and promulgate quarantine restrictions covering areas within the states affected by the pest and may adopt, issue, and enforce rules supplemental to such quarantines for the control of the pest. Under such quarantines, the state entomologist or the state entomologist\u8217\'3fs authorized agents may prohibit and prevent the movement within the state without inspection, or the shipment or transportation within the state, of any agricultural or horticultural product, or any other material of any character whatsoever, capable of carrying any dangerously injurious insect pest or disease in any living state of its development; and, in the enforcement of such quarantine, may intercept, stop, and detain for official inspection any person, car, vessel, boat, truck, automobile, aircraft, wagon, vehicles or carriers or any container, material, or substance believed or known to be carrying the insect pest or plant disease in any living state of its development in violation of said quarantines or of the rules issued supplemental thereto, and may seize, possess, and destroy any agricultural or horticultural product or other material of any character whatsoever, moved, shipped, or transported in violation of such quarantines or the rules.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a48; C24, \'a74049; C27, 31, 35, \'a74062-b11; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.11; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.11}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.12}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Federal quarantine \u8212\'3f seizures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Until the secretary of agriculture of the United States shall have made a determination that a federal quarantine is necessary, and has duly established the same with reference to any dangerous plant disease or insect infestation, the state entomologist of this state is authorized to promulgate and enforce quarantine regulations prohibiting or restricting the transportation of any class of plant material or product or article into this state from any state, territory or district of the United States, when the entomologist shall have information that a dangerous plant disease or insect infestation exists in such state, territory, district, or portion thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state entomologist, the entomologist\u8217\'3fs inspectors or duly authorized agents are authorized to seize, destroy, or return to the point of origin any material received in this state in violation of any state quarantine established under the authority of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or in violation of any federal quarantine established under the authority of the federal }}}{{\f5\fs18\hyphpar0\qj{Plant Protection Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{7 U.S.C. \'a77701 et seq.}}}{{\f5\fs18\hyphpar0\qj{, or any amendment to that Act.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a74062-b12; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.12; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1010, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a748}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.13}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Quarantines \u8212\'3f seizure and destruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever the state entomologist shall find that there exists in this state, or any part thereof, any dangerously injurious insect pest or plant disease, and that its dissemination should be controlled or prevented, the entomologist may institute quarantines and promulgate quarantine restrictions covering areas within the state affected by such pest or disease, and may adopt, issue and enforce rules supplemental to such quarantines for the control of this pest. Under such quarantines, the state entomologist, the entomologist\u8217\'3fs inspectors or authorized agents may prohibit and prevent the movement within the state without inspection or the shipment or transportation within this state, of any agricultural or horticultural product, or any other material of any character whatsoever, capable of carrying any dangerously injurious insect pest or disease in any living state of its development; and, in the enforcement of such quarantine, may intercept, stop, and detain for official inspection any person, car, vessel, boat, truck, automobile, aircraft, wagon, or other vehicles or carriers of any kind or character, whether air, land, or water, or any container or material believed or known to be carrying such insect pest or plant disease in any living state of its development or any such material, in violation of said quarantine or of the rules issued supplemental thereto, and may seize, possess, and destroy any agricultural or horticultural product or other material of any character whatsoever, moved, shipped, or transported in violation of such quarantines or the said rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state entomologist shall give public notice of such quarantines, specifying the plants and plant products infested or infected, or likely to become infested or infected; and the movement, planting or other use of any such plant or plant product, or other thing or substance specified in such notice as likely to carry and disseminate such insect pest or disease, except under such conditions as shall be prescribed as to inspection, treatment and disposition, shall be prohibited within such area as the entomologist may designate. When the state entomologist shall find that the danger of the dissemination of such insect pest or disease has ceased to exist, the entomologist shall give public notice that the quarantine is raised.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a48; C24, \'a74049; C27, 31, 35, \'a74062-b13; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.13; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.13}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.14}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Right of access.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state entomologist and the entomologist\u8217\'3fs authorized inspectors, employees, and agents shall have free access within reasonable hours to any farm, field, orchard, nursery, greenhouse, garden, elevator, seedhouse, warehouse, building, cellar, freight or express office or car, freight yard, truck, automobile, aircraft, wagon, vehicle, carrier, vessel, boat, container or any place which it may be necessary or desirable for such authorized agents to enter in carrying out the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. It shall be unlawful to deny such access to such authorized agents or to hinder, thwart, or defeat such inspection or entrance by misrepresentation or concealment of facts or conditions, or otherwise.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a48; C24, \'a74049; C27, 31, 35, \'a74062-b14; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.14; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.14}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.15}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Right to hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person affected by any rule made or notice given may have a review thereof by the secretary of agriculture for the purpose of having such rule or notice modified, suspended or withdrawn.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a74062-b15; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.15;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.15; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.15}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.16}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person, partnership, association or corporation, or any combination of individuals, violating any provision of a quarantine promulgated under the authority of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or of any rules issued supplemental thereto, shall be guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a50; C24, \'a74059; C27, 31, 35, \'a74062-b16; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.16;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.16; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.16}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7106}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.17}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty of owner \u8212\'3f assessment of costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When treatment or destruction of an agricultural or horticultural plant or product, in field, feedlot, place of assemblage or storage, or elsewhere, or when a special type of plowing or any other agricultural or horticultural operation is required under the rules, the owner or person having charge of the plants, plant products or places, upon due notice from the state entomologist or the entomologist\u8217\'3fs authorized agents, shall take the action required within the time and in the manner designated by the notice. If the owner or person in charge refuses or neglects to obey the notice, the secretary of agriculture, or the secretary\u8217\'3fs authorized agents, may do what is required, and the secretary shall assess the expense to the owner after giving the owner legal notice and a hearing. No expense other than that incidental to normal and usual farm operations shall be so assessed. If the assessment is not paid, the secretary shall certify it to the treasurer of the proper county who shall enter it on the tax books and collect it as ordinary taxes are collected and remit it to the secretary.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a48; C24, \'a74055, 4056; C27, 31, 35, \'a74062-b17; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.17;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.17; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.17}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 70, \'a73}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.7}}}{{\f5\fs12\hyphpar0\qj{, 177A.19}}}{{\f5\fs12\hyphpar0\qj{, 331.559}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.18}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who shall violate any provision or requirement of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or of the rules made or of any notice given pursuant thereto, or who shall forge, counterfeit, deface, destroy, or wrongfully use, any certificate provided for in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or in the rules and regulations made pursuant thereto, shall be deemed guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a50; C24, \'a74059; C27, 31, 35, \'a74062-b18; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.18;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.18; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.18}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7177A.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.19}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Harmful barberry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person, firm, or corporation shall receive, ship, accept for shipment, transport, sell, offer for sale, give away, deliver, plant, or permit to exist on the person\u8217\'3fs, firm\u8217\'3fs, or corporation\u8217\'3fs premises any plant of the harmful barberry, or any plant of a species that shall be designated by the state entomologist in published regulations to be a host or carrier of a dangerous plant disease or insect pest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state entomologist and the entomologist\u8217\'3fs inspectors, and authorized agents, are hereby empowered to eradicate any such plant found growing in the state. If the owner shall refuse or neglect to eradicate such plants within ten days after receiving a written notice, the expense of such eradication shall be assessed, collected, and enforced against the premises upon which such expense was incurred as taxes are assessed, collected and enforced.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fharmful barberry\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be interpreted to consist of any species of Berberis or Mahonia susceptible to infection by Puccinia graminis, commonly called black stem rust of grain, but not including Japanese barberry (B. thunbergii), which does not propagate the rust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The procedures provided in }}}{{\f5\fs18\hyphpar0\qj{section 177A.17}}}{{\f5\fs18\hyphpar0\qj{ and all other applicable provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 177A.5 through 177A.18}}}{{\f5\fs18\hyphpar0\qj{ shall govern and apply to the enforcement of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, \'a74053; C27, 31, 35, \'a74062-b19; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.19;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.19; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a790}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.20}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Liability of principal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In construing and enforcing the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the act, omission, or failure of any official, agent, or other person acting for or employed by an association, partnership or corporation within the scope of the person\u8217\'3fs authority shall, in every case, also be deemed the act, omission, or failure of such association, partnership, or corporation as well as that of the person.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a74062-b20; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.20;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.20; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.21}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Party plaintiff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The secretary of agriculture, the state entomologist, or any of their inspectors or authorized agents shall be a proper party plaintiff in any action in any court of equity brought for the purpose of carrying out any of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a74062-b21; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.21;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.21; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.21}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{177A.22}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall not be so construed or enforced as to conflict in any way with any Act of Congress regulating the movement of plants and plant products in interstate or foreign commerce.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a74062-b22; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4062.22;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7267.22; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7177A.22}}}{]}\par}}