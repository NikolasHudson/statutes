\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F455D}{\*\bkmkend codeChapter_5F455D}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 455D}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{WASTE VOLUME REDUCTION AND RECYCLING}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7364.22}}}{{\f5\fs12\qc{, 455H.303}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the environmental protection commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of natural resources created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPollution prevention techniques\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following practices employed by the user of a toxic substance:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Input substitution, which is the replacement of a toxic substance or raw material used in a production process with a nontoxic or less toxic substance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Product reformulation, which is the substitution of an end product which is nontoxic or less toxic upon use or release for an existing end product.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Production process redesign or modification, which is the development and use of production processes of a different design other than those currently in use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Production process modernization, which is the upgrading or replacing of existing production process equipment or methods with other equipment or methods based on the same production process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Improved operation and maintenance of existing production process equipment and methods, which is the modification or addition to existing equipment or methods, including but not limited to such techniques as improved housekeeping practices, system adjustments, product and process inspections, and production process control equipment or methods.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recycling, reuse, or extended use of toxic substances by using equipment or methods that become an integral part of the production process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecycling\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any process by which waste, or materials that would otherwise become waste, are collected, separated, or processed and revised or returned to use in the form of raw materials or products pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455D.4A}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecycling\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to the composting of yard waste which has been previously separated from other waste, but does not include any form of energy recovery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fScrap metal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any ferrous or nonferrous metal suitable for reprocessing into a viable market commodity grade specification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWaste reduction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means practices which reduce, avoid, or eliminate both the generation of solid waste and the use of toxic materials so as to reduce risks to health and the environment and to avoid, reduce, or eliminate the generation of wastes or environmental pollution at the source and not merely achieved by shifting a waste output or waste stream from one environmental medium to another environmental medium.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 12, \'a712, 13}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1023, \'a75, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Findings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The general assembly finds that:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Iowa\u8217\'3fs environment is precious and no person has the right to pollute Iowa\u8217\'3fs air, water, or soil. The environment is vulnerable and irreplaceable, and all Iowans have an ongoing responsibility to conserve, preserve, and enhance the state\u8217\'3fs natural resources to guarantee their continued existence and use by the present and future generations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The land itself is the source of Iowa\u8217\'3fs livelihood not only for the purposes of an agricultural economy, but for the establishment of manufacturing plants, business offices, and residences. While zoning establishes restrictions on the use of land for social order, a similar system has not been established to maintain environmental order below the ground. Protection of the environment includes not only visible but invisible threats as well.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rapidly rising volume of waste deposited by society threatens the capacity of existing and future landfills. The nature of waste disposal today means that unknown quantities of potentially toxic and hazardous materials are being buried and pose a constant threat to the groundwater supply. In addition, the nature of the waste and disposal methods utilized allow the waste to remain basically inert for decades, if not centuries, without decomposition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wastes filling Iowa\u8217\'3fs landfills may, at best, represent a potential resource. However, without proper management, wastes are hazards to the environment and life itself.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reduction of solid waste at the source and the recycling of reusable waste materials will reduce the flow of waste to sanitary landfills and increase the supply of reusable materials for the use of the public.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Goals for waste stream reduction \u8212\'3f procedures \u8212\'3f reductions and increases in fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E7_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{ Waste reduction goals.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The goal of the state is to reduce the amount of materials in the waste stream, existing as of July 1, 1988, by an intermediate goal of twenty-five percent, and by a final goal of at least fifty percent, through the practice of waste volume reduction at the source and through recycling. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwaste stream\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the disposal of solid waste as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsolid waste\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is defined in }}}{{\f5\fs18\hyphpar0\qj{section 455B.301}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 455D.1, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, facilities which employ combustion of solid waste with energy recovery and refuse-derived fuel, which are included in an approved comprehensive plan, may include these processes in the definition of recycling for the purpose of meeting the state goal if at least thirty-five percent of the fifty percent waste reduction goal is met through volume reduction at the source and recycling and reuse, as established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455B.301A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E7_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Departmental monitoring.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time the department determines that a planning area has met or exceeded the twenty-five percent goal, but has not met or exceeded the fifty percent goal, a planning area shall subtract sixty cents from the total amount of the tonnage fee imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455B.310}}}{{\f5\fs18\hyphpar0\qj{. If at any time the department determines that a planning area has met or exceeded the fifty percent goal, a planning area shall subtract fifty cents from the total amount of the tonnage fee imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455B.310}}}{{\f5\fs18\hyphpar0\qj{. The reduction in tonnage fees pursuant to this paragraph shall be taken from that portion of the tonnage fees which would have been allocated for funding alternatives to landfills pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455E.11, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines that a planning area has failed to meet the twenty-five percent goal, the planning area shall remit fifty cents per ton to the department. The moneys shall be deposited in the groundwater protection fund created in }}}{{\f5\fs18\hyphpar0\qj{section 455E.11, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and credited to the solid waste account of the fund to be used for funding alternatives to landfills pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455E.11, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1). Moneys shall continue to be remitted pursuant to this paragraph until such time as evidence of attainment of the twenty-five percent goal is documented in subsequent plans submitted to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time the department determines that a planning area has met or exceeded the fifty percent goal, the planning area shall subtract fifty cents from the total amount of the tonnage fee imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455B.310}}}{{\f5\fs18\hyphpar0\qj{. This amount shall be in addition to any amount subtracted pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The reduction in tonnage fees pursuant to this paragraph shall be taken from that portion of the tonnage fees which would have been allocated to funding alternatives to landfills pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455E.11, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1). A planning area failing to meet the fifty percent goal is not required to remit any additional tonnage fees to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E7_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Environmental management systems.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A planning area designated as an environmental management system pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455J.7}}}{{\f5\fs18\hyphpar0\qj{ is exempt from the waste stream reduction goals of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1213, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1177, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 80, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 209, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1193, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 124, \'a72, 6}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1063, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1109, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7108}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 12, \'a714, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455B.306}}}{{\f5\fs12\hyphpar0\qj{, 455B.310}}}{{\f5\fs12\hyphpar0\qj{, 455J.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Waste volume reduction policies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the policy of this state to encourage the development of waste volume reduction programs and education at the local government level through incentives, technical assistance, grants, and other practical measures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the policy of this state to support and encourage the development of new uses and markets for recycled goods, placing emphasis on the development, in Iowa, of businesses relating to waste reduction and recycling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provision of education concerning waste volume reduction at the elementary through high school levels and through community organizations will enhance the success of local programs requiring public involvement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This state supports and encourages manufacturing methods which are environmentally sustainable, technologically safe, and ecologically sound. The state shall encourage manufacturing methods which enhance waste reduction by creating products with longer usage life, and by creating products which are adaptable to secondary uses, require less input material, and decrease resource consumption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The people of this state recognize that a variety of benefits result from a comprehensive waste reduction policy including the following environmental, economic, governmental, and public benefits:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not producing waste in the first instance is the most certain means for avoiding the widely recognized health and environmental damage associated with waste. Although waste reduction will never eliminate all wastes, to the extent that waste reduction is achieved it results in the most certain form of direct risk reduction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Waste reduction may result in reduced pollution control costs for industry by stimulating and promoting beneficial technological and management reorganization within industry in place of pollution control strategies which channel capital into nonproductive pollution control expenditures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The government is better able to administer programs which offer a variety of benefits to industry and which reduce the overall cost of government involvement than it is to administer programs which offer few benefits to industry and require increasingly extensive, complex, and costly governmental actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Public confidence in environmental policies of the government is important for the effectiveness of these policies. Waste reduction poses no adverse environmental and public health effects and does not, therefore, lead to increased public concern. Waste reduction also increases the public confidence that the government and industry are doing all that is possible to protect human health and the environment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.4A}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Recycling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecycling facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any facility, business, or operation that has the stated primary purpose of facilitating the recycling of materials that would otherwise be solid waste.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recycling of materials for the purpose of being excluded from the solid waste provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 455B, subchapter IV, part 1}}}{{\f5\fs18\hyphpar0\qj{, must be legitimate. A material that is not legitimately recycled is discarded material and is a solid waste. In determining if recycling is legitimate, a recycling facility must establish all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The material is potentially recyclable and has a feasible means of being recycled into a valuable product.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The material is being managed as a valuable commodity while under the facility\u8217\'3fs control.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The material is not being accumulated speculatively pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines that a facility is not legitimately recycling material, the department may allow the facility owner or operator an opportunity to comply with the criteria in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, or may immediately deem the facility subject to the solid waste provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 455B, subchapter IV, part 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The criteria in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ are intended to mitigate the risk posed by facilities that accumulate materials speculatively prior to recycling by preventing materials that are not otherwise regulated under }}}{{\f5\fs18\hyphpar0\qj{chapter 455B, subchapter IV, part 1}}}{{\f5\fs18\hyphpar0\qj{, from being stored indefinitely and potentially causing a public health nuisance or adverse environmental impact. In response to enforcement initiated by the department for alleged violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the burden of proof falls on the recycling facility owner or operator to establish that materials are being legitimately recycled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish that a material is potentially recyclable and has a feasible means of being recycled into a valuable product, a recycling facility owner or operator shall maintain with an end user at least one purchase contract, a letter of understanding, or other formal agreement. Such documentation must be provided to the department upon request. In addition, if the material is going to be recycled in an unusual manner, the owner or operator may use technical specifications from the end user or other documentation to prove recycling the material in such manner will result in a valuable product.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish that a material is being managed as a valuable commodity while under the facility\u8217\'3fs control, a recycling facility owner or operator shall ensure that stockpiled material is not speculatively accumulated by maintaining current inventory records and is managed in a manner consistent with comparable recyclable materials or products in an equally protective manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish that a material is not being accumulated speculatively, the recycling facility owner or operator must document that, during a given calendar year, the amount of material that is recycled, or transferred to a different site for recycling, equals at least seventy-five percent by weight or volume of the amount of material accumulated at the beginning of the period. Materials must be placed in a storage unit with a label indicating the first date that the material began to be accumulated. If placing a label on the storage unit is not practicable, the accumulation period must be documented through an inventory log or other appropriate method.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure to provide documentation upon request to the department relative to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is grounds for the department to immediately deem the facility not in compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Scrap metal is not subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1023, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a7139 \u8211\'3f 141}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a7150}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455B.301}}}{{\f5\fs12\hyphpar0\qj{, 455D.1}}}{{\f5\fs12\hyphpar0\qj{, 455D.22}}}{{\f5\fs12\hyphpar0\qj{, 455D.23}}}{{\f5\fs12\hyphpar0\qj{, 455D.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statewide waste reduction and recycling network \u8212\'3f established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall establish a statewide waste reduction and recycling network to promote the waste management policy contained in }}}{{\f5\fs18\hyphpar0\qj{section 455B.481}}}{{\f5\fs18\hyphpar0\qj{ and the waste management hierarchy contained in }}}{{\f5\fs18\hyphpar0\qj{section 455B.301A}}}{{\f5\fs18\hyphpar0\qj{. Programs established shall encourage waste generators to reduce the volume of waste generated and to recycle or properly dispose of the waste that is generated. The network shall utilize existing recycling companies when possible. The programs may utilize financial and legal incentives, education, technical assistance, regulation, and other methods as appropriate to implement the programs. The programs may involve the development of public and private sector initiatives, the development of markets and other opportunities for waste reduction and recycling, and other related efforts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The elements of the network shall include but are not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotion of efforts to increase the amount of recyclable materials used by the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotion of efforts to recover recyclable materials from the waste stream.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotion of local efforts to implement recycling collection centers located at disposal sites or other convenient local sites.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotion of local efforts of curbside collection of separated recyclable waste materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provision of public education programs which promote public awareness of waste volume reduction and the use of recyclable materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotion of the creation of markets for recyclable materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotion of research, manufacturing processes, and product development, which provide for waste reduction through decreased material input, and resource consumption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotion of the concentration of the efforts of the business and industry resource search service by the small business assistance center for the safe and economic management of solid waste and hazardous substances at the university of northern Iowa, to locate existing waste streams and materials from businesses and industries which generate small amounts of waste and to catalyze the reuse of these materials in the production of goods and services.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 44, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise specified in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, recommend rules to the commission which are necessary to implement }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer and coordinate the waste volume reduction and recycling fund created under }}}{{\f5\fs18\hyphpar0\qj{section 455D.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter into contracts and agreements, with the approval of the commission, for contracts in excess of twenty-five thousand dollars, with local units of government, other state agencies, governments of other states, governmental agencies of the United States, other public and private contractors, and other persons as may be necessary or beneficial in carrying out the department\u8217\'3fs duties under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop a strategy and recommend to the commission the adoption of rules necessary to implement a strategy for white goods and waste oil.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop a strategy and recommend to the commission the adoption of rules necessary to implement a strategy for the recycling of electronic goods and the disassembling and removing of toxic parts from electronic goods.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1162, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 12, \'a716, 17}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.22}}}{{\f5\fs12\hyphpar0\qj{, 455D.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commission shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise specified in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, adopt rules necessary to implement }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prohibit land disposal of specific components of the waste stream for which the department has developed and implemented a strategy for alternative disposal according to the waste management hierarchy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish by rule standards for the acceptance of recyclable or rebatable products at redemption centers. The standards may address matters of public health and handling by the redemption center.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 12, \'a718, 19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deposits, rebates, and waste abatement fees.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 9, \'a711}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Land disposal of yard waste \u8212\'3f prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Land disposal of yard waste as defined by the department is prohibited. A sanitary landfill may accept yard waste under any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the yard waste is separated at its source from other solid waste and is accepted by the sanitary landfill for the purposes of soil conditioning and composting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the yard waste is collected for disposal as a result of a severe storm and the yard waste originates in an area declared to be a disaster area in a declaration issued by the president of the United States or the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the yard waste is collected for disposal to control, eradicate, or prevent the spread of insect pests, tree and plant diseases, or invasive plant species problems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the yard waste is collected for disposal by a sanitary landfill that operates a methane collection system that produces energy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall assist local communities in the development of collection systems for yard waste generated from residences and shall assist in the establishment of local composting facilities. Each city and county shall, by ordinance, require persons within the city or county to separate yard waste from other solid waste generated. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules which define yard waste and provide for the safe and proper method of composting yard waste and other organic materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State and local agencies responsible for the maintenance of public lands in the state shall give preference to the use of composted materials in all land maintenance activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit the use of yard waste as land cover or as soil conditioning material.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ prohibits the open burning of yard waste within the permitted boundary at a sanitary disposal project.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1191, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1182, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 12, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1060, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 19, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.9A}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disposal of baled solid waste at a sanitary landfill \u8212\'3f prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Beginning January 1, 1992, a person shall not dispose of baled solid waste at a sanitary landfill and a sanitary landfill shall not accept baled solid waste for final disposal. Solid waste which is baled on-site may be disposed of at the sanitary landfill.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 113, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 14, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.10}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Land disposal of lead acid batteries \u8212\'3f prohibited \u8212\'3f collection for recycling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning July 1, 1990, land disposal of lead acid batteries is prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person offering for sale or selling lead acid batteries at retail in the state shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Accept used lead acid batteries from customers who purchase new lead acid batteries, at the point of sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Post written notice that land disposal of lead acid batteries is prohibited and that state law requires the retailer to accept lead acid batteries for recycling when new lead acid batteries are purchased.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person offering for sale or selling lead acid batteries at wholesale shall accept used lead acid batteries from retailers who purchase new lead acid batteries for resale to consumers, or from wholesale customers.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.10A}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Household batteries \u8212\'3f heavy metal content and recycling requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E17_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and in }}}{{\f5\fs18\hyphpar0\qj{section 455D.10B}}}{{\f5\fs18\hyphpar0\qj{ unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fButton cell battery\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a household battery which resembles a button or coin in size and shape.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConsumer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who purchases household batteries for personal or business use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEasily removed\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a battery or battery pack which can be removed from a battery-powered product by the consumer, using common household tools.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHousehold battery\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any type of dry cell battery used by consumers, including but not limited to mercuric oxide, carbon-zinc, zinc air, silver oxide, nickel-cadmium, nickel-hydride, alkaline, lithium, or sealed lead acid batteries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInstitutional generator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a governmental, commercial, industrial, communications, or medical facility which generates waste mercuric oxide, nickel-cadmium, or sealed lead acid rechargeable batteries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRechargeable consumer product\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a product that is primarily powered by a rechargeable battery and is primarily used or purchased to be used for household purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRechargeable household battery\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a small sealed nickel-cadmium or sealed lead acid battery used for nonvehicular purposes and weighing less than twenty-five pounds, which can be recharged by the consumer and reused.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E17_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Mercury content limited.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell, distribute, or offer for retail sale in this state an alkaline manganese battery that contains more than twenty-five one-thousandths of a percent mercury by weight. A person shall not sell, distribute, or offer for sale at retail in this state an alkaline manganese household battery manufactured on or after January 1, 1996, to which mercury has been added. This paragraph does not apply to alkaline manganese button cell batteries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell, distribute, or offer for retail sale in this state an alkaline manganese button cell battery which contains more than twenty-five milligrams of mercury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E17_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Recycling/disposal requirements for household batteries.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning July 1, 1996, a system or systems shall be in place to protect the health and safety of Iowans, and the state\u8217\'3fs environment, from the toxic components of used household batteries. The system or systems shall include at least one of the following elements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Elimination or reduction to the extent established by rule of the department, of heavy metals and other toxic components in nickel-cadmium, mercuric oxide, or sealed lead acid household batteries, to ensure protection of public health, safety, and the environment when placed in or disposed of as part of mixed municipal solid waste.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishment of a comprehensive recycling program for each type of battery listed in subparagraph (1) that is sold, distributed, or offered for sale in this state. An institutional generator shall provide for the on-site source separation and collection of used mercuric oxide batteries, nickel-cadmium rechargeable batteries, and sealed lead acid rechargeable batteries. All participants in the stream of commerce relating to the batteries, which are listed in subparagraph (1) and which are not designated as exempt pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455D.10B, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3) or (4), shall, individually or collectively, be responsible for developing and operating a system for collecting and transporting used batteries to the appropriate dry cell battery manufacturer or to a site or facility designated by a manufacturer. Additionally, dry cell battery manufacturers shall be responsible for the recycling of used batteries in an environmentally sound manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provision for collection, transporting, and proper disposal of used household batteries of the types listed in subparagraph (1) which are distributed, sold, or offered for retail sale in the state. For the purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fproper disposal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means disposal which complies with all applicable state and federal laws. All participants in the stream of commerce relating to the batteries, which are listed in subparagraph (1) and which are not designated as exempt pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455D.10B, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3) or (4), shall, individually or collectively, be responsible for developing and operating a system for collecting and transporting used batteries to the appropriate dry cell battery manufacturer or to a site or facility designated by a manufacturer. Additionally, dry cell battery manufacturers shall be responsible for proper disposal of the used batteries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To meet the recycling and disposal requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, participants in the systems established under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, either individually or collectively, shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identify a collection entity, other than a local government collection system, unless the local government agrees otherwise, through which the discarded batteries listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1) shall be returned for collection and recycling or disposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inform each customer of the prohibition of disposal of batteries listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), and a safe and convenient return process available to the customer for recycling or proper disposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After July 1, 1996, nickel-cadmium, sealed lead acid, or mercuric oxide household batteries shall not be sold, distributed, or offered for sale in the state, unless a system required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is in operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may make recommendations to the commission to include other types of household or rechargeable batteries, not enumerated in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), in the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to batteries subject to regulation under the federal Resource Conservation and Recovery Act, 42 U.S.C. \'a76901 et seq.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E17_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E17_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rules adopted.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall adopt, upon recommendation of the director, the rules necessary to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1215, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 99, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 151, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7140}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.10B}}}{{\f5\fs12\hyphpar0\qj{, 455D.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.10B}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Batteries used in rechargeable consumer products.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not distribute, sell, or offer for retail sale in the state a rechargeable consumer product manufactured on or after January 1, 1994, unless all of the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The battery can be easily removed by the consumer, or is contained in a battery pack that is separate from the product and can be easily removed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The battery, the instruction manual, and the product package are clearly labeled to indicate that the battery must be recycled or disposed of properly and includes the designation \u8220\'3fCd\u8221\'3f or \u8220\'3fNi-Cd\u8221\'3f for nickel-cadmium batteries and \u8220\'3fPb\u8221\'3f or \u8220\'3fLead\u8221\'3f for small lead batteries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A rechargeable consumer product manufacturer may apply to the department for exemption from the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The product cannot be redesigned or manufactured to comply with the requirements prior to January 1, 1994.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The redesign of the product to comply with the requirements would result in significant danger to public health and safety.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The battery poses no unreasonable hazard to public health, safety, or the environment when placed in and processed or disposed of as part of mixed municipal solid waste, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455D.10A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consumer product manufacturer has in operation a program to recycle used batteries in an environmentally sound manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer of a product that is powered by a battery that cannot be easily removed who has been granted an exemption under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall label the product as required in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An exemption granted by the department under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), is limited to a maximum of two years, but may be renewed.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1215, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1037, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7109}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.10A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.11}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Waste tires \u8212\'3f land disposal prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPermit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a permit issued by the department to establish, construct, modify, own, or operate a tire stockpiling facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProcessing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means producing or manufacturing usable materials from waste tires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProcessing site\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a site which is used for the processing of waste tires and which is owned or operated by a tire processor who has a permit for the site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTire collector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means either a person who owns or operates a site used for the storage, collection, or deposit of more than five hundred waste tires or an authorized vehicle recycler who is licensed by the state department of transportation pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321H.4}}}{{\f5\fs18\hyphpar0\qj{ and who owns or operates a site used for the storage, collection, or deposit of more than three thousand five hundred waste tires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTire processor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person engaged in the processing of waste tires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWaste tire\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a tire that is no longer suitable for its originally intended purpose due to wear, damage, or defect. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWaste tire\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a nonpneumatic tire.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWaste tire collection site\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a site which is used for the storage, collection, or deposit of waste tires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Land disposal of waste tires is prohibited beginning July 1, 1991, unless the tire has been processed in a manner established by the department. A sanitary landfill shall not refuse to accept a waste tire which has been properly processed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall conduct a study and make recommendations to the general assembly by January 1, 1991, concerning a waste tire abatement program which includes but is not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number and geographic distribution of waste tires generated and existing in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The development of markets for the recycling and processing of waste tires, in the midwestern states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The methods to establish reliable sources of waste tires for users of waste tires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The permitting of waste tire collection sites, waste tire processing facilities, and waste tire haulers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The methods for the cleanup of existing stockpiles of waste tires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon completion of the study pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the department shall determine the number of stockpiling facilities which are necessary and shall develop rules for stockpiling facilities which include but are not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prohibition of burning within one hundred yards of a tire stockpile.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum height, width, and length of a tire stockpile.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plans to control mosquitoes and rodents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A facility closure plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Specifications for fire lanes between stockpiles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Limitations of the total number of tires allowed at a single stockpile site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall develop criteria for the issuance of permits and shall issue permits to qualified stockpiling facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall provide financial assistance to persons who establish recycling and processing sites for waste tires, subject to the rules established by the department for the establishment of such sites and subject to the conditions prescribed by the department for application for and awarding of such financial assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall adopt rules which provide the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That a person who contracts with another person to transport more than forty waste tires is required to contract only with a person registered as a waste tire hauler pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455D.11I}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That a person who transports waste tires for final disposal is required to only dispose of the tires at a permitted sanitary disposal facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules relating to the storage and disposal of nonpneumatic tires and processed tires.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 257, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1218, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1117, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 24, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1121, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1030, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 151, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7110}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.22}}}{{\f5\fs12\hyphpar0\qj{, 455D.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.11A}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Financial assurance \u8212\'3f waste tire collection or processing sites.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person owning or operating a waste tire collection or processing site shall provide a financial assurance instrument to the department prior to the initial approval of a permit or prior to the renewal of a permit for an existing or expanding facility. The financial assurance instrument shall be used to provide for closure of the waste tire collection or processing facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financial assurance instrument shall meet all requirements adopted by rule by the commission, and shall not be canceled, revoked, disbursed, released, or allowed to terminate without the approval of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Financial assurance instruments may include instruments such as cash or surety bond, a letter of credit in a form prescribed by the department, a secured trust fund, a corporate guarantee, or a combination of such instruments and guarantees sufficient to satisfy the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{. The department may request an annual audit, which shall remain confidential, to be performed by a third party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the owner or operator of a waste tire collection or processing site chooses to provide financial assurance in the form of a surety bond, the bond shall be executed by a surety company authorized to do business in this state. The bond shall be continuous in nature until canceled by the surety. A surety shall provide at least ninety days\u8217\'3f notice in writing to the owner or operator and to the department indicating the surety\u8217\'3fs intent to cancel the bond and the effective date of the cancellation. The surety bond shall be for the benefit of the citizens of this state and shall be conditioned upon compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The surety\u8217\'3fs liability under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is limited to the amount of the bond or the amount of the damages or moneys due, whichever is less. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not limit the amount of damages recoverable from an owner or operator to the amount of the surety bond. The bond shall be made in a form prescribed by the commissioner of insurance and written by a company authorized by the commissioner of insurance to do business in this state. If a surety bond that has been provided as financial assurance under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is canceled, the owner or operator of the waste tire collection or processing site shall demonstrate a means of continued compliance with the financial assurance requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the department within thirty days of the cancellation. If a means of continued compliance is not demonstrated within the thirty-day period, the department shall suspend the permit for the site, and the owner or operator shall perform proper closure of the site within thirty days of the suspension. If the owner or operator does not properly close the site within the time period allowed, the department shall file a claim with the surety company, prior to the effective date of cancellation of the bond, to collect the amount of the bond for use in performing proper closure. A person who fails to provide for proper closure, notwithstanding collection by the department of the amount of the bond, is guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financial assurance instrument for a waste tire collection site shall provide coverage in an amount that is equivalent to two dollars and fifty cents per passenger tire equivalent collected by the site. The financial assurance instrument for a waste tire processing site shall provide coverage in an amount that is equivalent to two dollars and fifty cents per passenger tire equivalent collected for processing by the site that is above the three-day processing supply of tires for the site as determined by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financial assurance instrument shall not be assigned for the benefit of creditors with the exception of the state, and shall not be used to pay any final judgment against a permit holder arising out of the ownership or operation of the site. The commission shall adopt rules to establish conditions under which the department may gain access to the financial assurance instrument.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement for financial assurance shall not apply to waste tire collection or processing sites operated by a city or county, or operated in conjunction with a sanitary landfill.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1218, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 53, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1180, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7134, 135}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 29, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a7108}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.11C}}}{{\f5\fs12\hyphpar0\qj{, 455D.22}}}{{\f5\fs12\hyphpar0\qj{, 455D.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.11B}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Permitting of waste tire collection or processing sites \u8212\'3f fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An owner or operator of a waste tire collection or processing site, including an enclosed site, shall obtain a permit from the department prior to operation of the site. The owner or operator shall pay an annual fee of eight hundred fifty dollars to the department. The moneys collected by the department shall be deposited in the hazardous substance remedial fund established pursuant to }{{\f5\fs18\hyphpar0\qj{section 455B.423}}}{ and shall be used for the purposes of administering the waste tire collection or processing site permit program.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1218, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.22}}}{{\f5\fs12\hyphpar0\qj{, 455D.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.11C}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Waste tire management fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A waste tire management fund is created within the state treasury. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, any unexpended balance in the fund at the end of each fiscal year shall be retained in the fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7}}}{{\f5\fs18\hyphpar0\qj{, any interest or earnings on investments from moneys in the fund shall be credited to the fund. Moneys from the fund that are expended by the department in closing or bringing into compliance a waste tire collection site pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455D.11A}}}{{\f5\fs18\hyphpar0\qj{ and later recouped by the department shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the waste tire management fund are appropriated and shall be used for the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Thirty percent of the moneys shall be used for all of the following positions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One full-time equivalent position for the administration of permits and registrations for tire processing, storage, and hauling activities, and tire program initiatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One and one-half full-time equivalent positions for waste tire-related compliance checks and inspections. The full-time equivalent positions shall be divided equally between the field offices in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ten percent of the moneys shall be used for a public education and awareness initiative related to the proper tire disposal options and environmental and health hazards posed by improper tire storage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Thirty percent of the moneys shall be used for market development initiatives for waste tires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Thirty percent of the moneys shall be used for waste tire stockpile abatement initiatives which would require a cost-share agreement with the landowner.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1117, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1173, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a7116}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a7103}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{455D.11D through 455D.11F}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2004/CH1173.pdf" }{\fldrslt \f5 \fs18{{2004 Acts, ch 1173, \'a72}}}}}}{{\f5\fs18\qj{2004 Acts, ch 1173, \'a72}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.11G}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Waste tire disposal fees and abatement costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retail tire dealer who currently charges a fee relating to disposal of used tires is encouraged to include the fee within the sales price of new tires. The practice by retail tire dealers of adding the fee as a separate charge on sales invoices is discouraged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, any generator of waste tires who is identified as being a contributor to the materials which are the object of an abatement and who can document full compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and administrative rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in disposing of such waste tires shall not be liable for any of the cost of recovery actions of the abatement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1117, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1180, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.11H}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Future repeal.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2004/CH1173.pdf" }{\fldrslt \cf5 \f5 \fs18{{2004 Acts, ch 1173, \'a72}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.11I}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Registration of waste tire haulers \u8212\'3f bond.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwaste tire hauler\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who transports for hire more than forty waste tires in a single load for commercial purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A waste tire hauler shall register with, and obtain a certificate of registration from, the department before hauling waste tires in this state. Requirements for registration of a waste tire hauler shall include a provision that waste tire haulers shall pay all amounts due to any individual or group of individuals when due for damages caused by improper disposal of waste tires by the waste tire hauler or the waste tire hauler\u8217\'3fs employee while acting within the scope of employment. The waste tire hauler may apply for a certificate of registration by submitting the forms provided for that purpose and shall provide the name of the applicant and the address of the applicant\u8217\'3fs principal place of business and any additional information as deemed appropriate by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate of registration issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is valid for one year from the date of issuance. A registered waste tire hauler may renew the certificate by filing a renewal application in the form prescribed by the department, accompanied by any applicable renewal fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate of registration shall at all times be carried and displayed in the vehicle used for transportation of waste tires and shall be shown to a representative of the department of natural resources or the state department of transportation, upon request. The state department of transportation may inspect vehicles used for the transportation of waste tires and request that the certificate of registration of the waste tire hauler be shown.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall establish a reasonable registration fee sufficient to offset expenses incurred in the administration of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall require that a waste tire hauler have on file with the department, before the issuance or renewal of a registration certificate, a surety bond executed by a surety company authorized to do business in this state in the sum of a minimum of one hundred fifty thousand dollars, which bond shall be continuous in nature until canceled by the surety. A surety shall provide at least thirty days\u8217\'3f notice in writing to the waste tire hauler and to the department indicating the surety\u8217\'3fs intent to cancel the bond and the effective date of the cancellation. The surety bond shall be for the benefit of the citizens of this state and shall be conditioned upon the waste tire hauler\u8217\'3fs willingness to comply with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The surety\u8217\'3fs liability under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is limited to the amount of the bond or the amount of the damages or moneys due, whichever is less. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not limit the amount of damages recoverable from a waste tire hauler to the amount of the surety bond. The bond shall be made in a form prescribed by the commissioner of insurance and written by a company authorized by the commissioner of insurance to do business in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules necessary for the implementation and administration of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1121, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 151, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 29, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.11}}}{{\f5\fs12\hyphpar0\qj{, 455D.22}}}{{\f5\fs12\hyphpar0\qj{, 455D.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.12}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Plastic container labeling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLabel\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a molded imprint or raised symbol on or near the bottom of a plastic product.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPlastic\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any material made of polymeric organic compounds and additives that can be shaped by flow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPlastic bottle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a plastic container that has a neck that is smaller than the body of the container, accepts a screw-type, snap cap, or other closure, and has a capacity of sixteen fluid ounces or more, but less than five gallons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRigid plastic container\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any formed or molded container, other than a bottle, intended for single use, composed predominantly of plastic resin, and having a relatively inflexible infinite shape or form with a capacity of eight ounces or more, but less than five gallons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ A person shall not distribute, sell, or offer for sale in this state a plastic bottle or rigid plastic container unless the product is labeled with a code indicating the plastic resin used to produce the bottle or container. Rigid plastic bottles or rigid plastic containers with labels and basecups of a different material shall be coded by their basic material. The code shall consist of a number placed within a triangle of arrows and letters placed below the triangle of arrows. The triangle shall be equilateral, formed by three arrows with the apex of each point of the triangle at the midpoint of each arrow, rounded with a short radius. The arrowhead of each arrow shall be at the midpoint of each side of the triangle with a short gap separating the pointer from the base of the adjacent arrow. The triangle, formed by the three arrows curved at their midpoints, shall depict a clockwise path around the code number. The numbers and letters used shall be as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1 and PETE (polyethylene terephthalate)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2 and HDPE (high density polyethylene)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3 and V (vinyl)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4 and LDPE (low density polyethylene)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5 and PP (polypropylene)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6 and PS (polystyrene)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7 and OTHER (includes multilayer)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A container manufacturer or distributor who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is subject to a civil penalty of not more than five hundred dollars for each violation.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 12, \'a721, 22}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.13}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Land disposal of used oil and used oil filters prohibited \u8212\'3f collection and recycling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sanitary landfill shall not accept used oil for final disposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person offering for sale or selling oil or oil filters at retail in the state shall do the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Accept at the point of sale, used oil and used oil filters from customers, or post notice of locations where a customer may dispose of used oil and used oil filters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Post written notice that it is unlawful to dispose of used oil in a sanitary landfill.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A business that generates used oil filters or collects used oil filters from a person shall not dispose of the oil filters in a sanitary landfill and shall source-separate and recycle the oil filters.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a713}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1167, \'a71, 2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.14}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Products manufactured with chlorofluorocarbons prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Beginning January 1, 1990, a person shall not sell, offer for sale, purchase, or use plastic foam packaging products or food service items manufactured with chlorofluorocarbons. Beginning January 1, 1998, a person shall not sell, offer for sale, purchase, or use plastic foam products, not previously prohibited, which are manufactured with fully halogenated chlorofluorocarbons. A person violating }{{\f5\fs18\hyphpar0\qj{this section}}}{ is guilty of a serious misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a714}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.15}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Waste volume reduction and recycling fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A waste volume reduction and recycling fund is created within the state treasury. Moneys received by the department from fees, including general revenue, federal funds, awards, wills, bequests, gifts, or other moneys designated shall be deposited in the state treasury to the credit of the fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, any unexpended balance in the fund at the end of each fiscal year shall be retained in the fund. Any interest and earnings on investments from money in the fund shall be credited to the fund, }}}{{\f5\fs18\hyphpar0\qj{section 12C.7}}}{{\f5\fs18\hyphpar0\qj{ notwithstanding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund shall be utilized by the department for providing technical assistance to Iowa businesses in developing and implementing pollution prevention techniques.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 272, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 9, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 12, \'a723, 24}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a729C.8A}}}{{\f5\fs12\hyphpar0\qj{, 455D.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.15A}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Permitting of waste conversion technologies operations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 14, \'a74}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.16}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mercury }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ thermostats.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmercury-added thermostat\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a product or device that uses a mercury switch to sense and control room temperature through communication with heating, ventilating, or air-conditioning equipment. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMercury-added thermostat\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes thermostats used to sense and control room temperature in residential, commercial, industrial, and other buildings but does not include thermostats used to sense and control temperature as part of a manufacturing process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell, offer for sale, or install a mercury-added thermostat in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided, a person who generates a discarded mercury-added thermostat shall manage the mercury-added thermostat as a hazardous waste or universal hazardous waste, according to all applicable state and federal regulations. A contractor who replaces or removes mercury-added thermostats shall assure that any discarded mercury-added thermostat is subject to proper separation and management as hazardous waste or universal hazardous waste. A contractor who replaces a mercury-added thermostat in a residence shall deliver the mercury-added thermostat to an appropriate collection location for recycling.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1168, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1023, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a7142}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 131, \'a737}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{455D.17 and 455D.18}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.19}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Packaging \u8212\'3f heavy metal content.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly finds and declares all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The management of solid waste can pose a wide range of hazards to public health and safety and to the environment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Packaging comprises a significant percentage of the overall solid waste stream.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The presence of heavy metals in packaging is a concern in light of the likely presence of heavy metals in emissions or ash when packaging is incinerated or in leachate when packaging is landfilled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lead, mercury, cadmium, and hexavalent chromium, on the basis of available scientific and medical evidence, are of particular concern.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is desirable as a first step in reducing the toxicity of packaging waste to eliminate the addition of heavy metals to packaging.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The intent of the general assembly is to achieve reduction in toxicity without impeding or discouraging the expanded use of postconsumer materials in the production of packaging and its components.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDistributor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who takes title to one or more packages or packaging components purchased for promotional purposes or resale. A person involved solely in delivering or storing packages or packaging components on behalf of third parties is not a distributor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIncidental presence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the presence of a regulated metal as an unintended or undesired ingredient of a package or packaging component.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIntentional introduction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an act of deliberately utilizing a regulated metal in the formulation of a package or packaging component where its continued presence is desired in the final package or packaging component to provide a specific characteristic, appearance, or quality. Intentional introduction does not include the use of a regulated metal as a processing agent or intermediate to impart certain chemical or physical changes during manufacturing, if the incidental presence of a residue of the metal in the final package or packaging component is neither desired nor deliberate, and if the final package or packaging component is in compliance with }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3). Intentional introduction also does not include the use of recycled materials as feedstock for the manufacture of new packaging materials, if the recycled materials contain amounts of a regulated metal and if the new package or packaging component is in compliance with }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufacturer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who produces one or more packages or packaging components.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufacturing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means physical or chemical modification of one or more materials to produce packaging or packaging components.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPackage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a container which provides a means of marketing, protecting, or handling a product including a unit package, intermediate package, or a shipping container. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPackage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also includes but is not limited to unsealed receptacles such as carrying cases, crates, cups, pails, rigid foil and other trays, wrappers and wrapping films, bags, and tubs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPackaging component\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any individual assembled part of a package including but not limited to interior and exterior blocking, bracing, cushioning, weatherproofing, exterior strapping, coatings, closures, inks, labels, tin-plated steel that meets ASTM (American society for testing and materials) international specification A-623, electro-galvanized coated steel, or hot-dipped-coated galvanized steel that meets ASTM (American society for testing and materials) international specification A-525 or A-879.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRegulated metal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any metal regulated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReusable entities\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means packaging or packaging components having a controlled distribution and reuse subject to the exemption provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer or distributor shall not offer for sale or sell or offer for promotional purposes a package or packaging component, in this state, which includes, in the package itself or in any packaging component, inks, dyes, pigments, adhesives, stabilizers, or any other additives, any lead, cadmium, mercury, or hexavalent chromium which has been intentionally introduced as an element during manufacturing or distribution as opposed to the incidental presence of any of these elements and which exceed the concentration level established by the department. A distributor shall only be subject to the assessment of a civil penalty pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455D.25, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for the knowing violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Knowledge by the distributor of the violation shall be presumed beginning sixty days from the receipt of notification from the department by certified mail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The concentration levels of lead, cadmium, mercury, and hexavalent chromium present in a package or packaging component shall not exceed the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six hundred parts per million by weight by July 1, 1992.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two hundred fifty parts per million by weight by July 1, 1993.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One hundred parts per million by weight by July 1, 1994.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Concentration levels of lead, cadmium, mercury, and hexavalent chromium shall be determined using ASTM (American society for testing and materials) international test methods, as revised, or United States environmental protection agency test methods for evaluating solid waste, S-W 846, as revised.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following packaging and packaging components are exempt from the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Packaging or packaging components with a code indicating a date of manufacture prior to July 1, 1990, and packaging or packaging components used by the alcoholic beverage industry or the wine industry prior to July 1, 1992.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Packages or packaging components to which lead, cadmium, mercury, or hexavalent chromium have been added in the manufacturing, forming, printing, or distribution process in order to comply with health or safety requirements of federal law or for which there is no feasible alternative if the manufacturer of a package or packaging component petitions the department for an exemption from the provisions of this paragraph for a particular package or packaging component. The department may grant a two-year exemption, if warranted by the circumstances, and an exemption may, upon meeting either criterion of this paragraph, be renewed for two years. For purposes of this paragraph, a use for which there is no feasible alternative is one in which the regulated substance is essential to the protection, safe handling, or function of the package\u8217\'3fs contents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Packages and packaging components that would not exceed the maximum contaminant levels established but for the addition of recycled materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Packages or packaging components that are reused, but exceed contaminant levels set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), if all of the following criteria are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The product being conveyed by the package, including any packaging component, is regulated under federal or state health or safety requirements.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transportation of the packaged product is regulated under federal or state transportation requirements.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The disposal of the packages or packaging components is performed according to federal or state radioactive or hazardous waste disposal requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may grant a two-year exemption if warranted by the circumstances and an exemption may, upon meeting the criteria of this paragraph, be renewed for additional two-year periods.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Packages or packaging components which qualify as reusable entities that exceed the contaminant levels set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), if the manufacturers or distributors of such packages or packaging components petition the department for an exemption and receive approval from the department according to the following standards based upon a satisfactory demonstration that the environmental benefit of the controlled distribution and reuse is significantly greater than if the same package is manufactured in compliance with the contaminant levels set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3). The department may grant a two-year exemption, if warranted by the circumstances, and an exemption may, upon meeting the four criteria listed in subparagraph (2), subparagraph divisions (a) through (d), be renewed for additional two-year periods.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to receive an exemption, the application must ensure that reusable entities are used, transported, and disposed of in a manner consistent with the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A means of identifying in a permanent and visible manner those reusable entities containing regulated metals for which an exemption is sought.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A method of regulatory and financial accountability so that a specified percentage of the reusable entities manufactured and distributed to another person are not discarded by that person after use, but are returned to the manufacturer or the manufacturer\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A system of inventory and record maintenance to account for the reusable entities placed in, and removed from, service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A means of transforming returned entities, that are no longer reusable, into recycled materials for manufacturing or into manufacturing wastes which are subject to existing federal or state laws or regulations governing manufacturing wastes to ensure that these wastes do not enter the commercial or municipal waste stream.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application for an exemption must document the measures to be taken by the applicant as set out in subparagraph (2), subparagraph divisions (a) through (d).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ A manufacturer or distributor of packaging or packaging components shall make available to purchasers, to the department, and to the general public upon request, certificates of compliance which state that the manufacturer\u8217\'3fs or distributor\u8217\'3fs packaging or packaging components comply with, or are exempt from, the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the manufacturer or distributor of the package or packaging component reformulates or creates a new package or packaging component, the manufacturer or distributor shall provide an amended or new certificate of compliance for the reformulated or new package or packaging component.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall adopt rules to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and recommend any other toxic substances contained in packaging to be added to the list in order to further reduce the toxicity of packaging waste.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1255, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 203, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 255, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1085, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1095, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1086, \'a775, 106}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 151, \'a75 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7134, 135}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7136}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.22}}}{{\f5\fs12\hyphpar0\qj{, 455D.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.20}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Refuse-derived fuel \u8212\'3f calculation as portion of waste reduction goal.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2004/CH1078.pdf" }{\fldrslt \cf5 \f5 \fs18{{2004 Acts, ch 1078, \'a73}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.21}}}{\*\bkmkstart stylerid1_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local ordinance \u8212\'3f curbside collection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city council or county board of supervisors which provides for the collection of solid waste by its residents shall consider as a proposed ordinance, the mandatory curbside collection of recyclable materials which have been separated from other solid waste. The proposed ordinance shall be considered in accordance with }{{\f5\fs18\hyphpar0\qj{chapter 331}}}{ or }{{\f5\fs18\hyphpar0\qj{380}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1215, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.22}}}{\*\bkmkstart stylerid1_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person who violates }{{\f5\fs18\hyphpar0\qj{section 455D.4A,}}}{ }{{\f5\fs18\hyphpar0\qj{455D.6, subsection 4}}}{, }{{\f5\fs18\hyphpar0\qj{section 455D.11}}}{, }{{\f5\fs18\hyphpar0\qj{455D.11A}}}{, }{{\f5\fs18\hyphpar0\qj{455D.11B}}}{, }{{\f5\fs18\hyphpar0\qj{455D.11I}}}{, or }{{\f5\fs18\hyphpar0\qj{455D.19}}}{, or any rule, permit, or order issued pursuant thereto shall be subject to a civil penalty which shall be established, assessed, and collected in the same manner as provided in }{{\f5\fs18\hyphpar0\qj{section 455B.109}}}{. Any civil penalty collected shall be deposited in the general fund of the state.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 151, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1023, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.23}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administrative enforcement }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ compliance orders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director may issue any order necessary to secure compliance with or prevent a violation of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or any rule adopted or permit or order issued pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Any order issued to enforce }{{\f5\fs18\hyphpar0\qj{section 455D.4A}}}{ may include a requirement to remove and properly dispose of materials being accumulated speculatively from a property and impose costs and penalties as determined by the department by rule. The person to whom a compliance order is issued under }{{\f5\fs18\hyphpar0\qj{this section}}}{ may cause to be commenced a contested case within the meaning of }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ by filing a notice of appeal to the commission. On appeal, the commission may affirm, modify, or vacate the order of the director. The applicable time frames for the issuance and appeal of the order are defined in }{{\f5\fs18\hyphpar0\qj{section 455B.110}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 151, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1023, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 97, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7243}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.24}}}{\*\bkmkstart stylerid1_2E39_2E2_2E2}{\*\bkmkend stylerid1_2E39_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judicial review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Judicial review of any order or other action of the commission or director may be sought in accordance with the terms of }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{. Notwithstanding the terms of }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{, petitions for judicial review may be filed in the district court of the county in which the alleged offense was committed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 151, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{455D.25}}}{\*\bkmkstart stylerid1_2E4_30_2E2_2E2}{\*\bkmkend stylerid1_2E4_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil actions for compliance \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general, on request of the department, shall institute any legal proceedings necessary to obtain compliance with an order of the commission or the director, including proceedings for a temporary injunction, or prosecuting any person for a violation of an order of the commission or the director or the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or any rules adopted or permit or order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who violates }}}{{\f5\fs18\hyphpar0\qj{section 455D.4A,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\f5\fs18\hyphpar0\qj{455D.10A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455D.11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455D.11A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455D.11B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455D.11I}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{455D.19}}}{{\f5\fs18\hyphpar0\qj{, or any order or permit issued or rule adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455D.6, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 455D.10A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455D.11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455D.11A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455D.11B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455D.11I}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{455D.19}}}{{\f5\fs18\hyphpar0\qj{, shall be subject to a civil penalty, not to exceed ten thousand dollars for each day of such violation.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 151, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1023, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7455D.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\