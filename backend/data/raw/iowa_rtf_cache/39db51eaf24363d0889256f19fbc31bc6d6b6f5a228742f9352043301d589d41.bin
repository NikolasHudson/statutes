j\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.128}}}{\*\bkmkstart stylerid1_2E11_2E4_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Community colleges and post-secondary readiness bureau }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director of the department shall appoint the bureau chief of the community colleges and post-secondary readiness bureau, and the bureau chief shall direct the work of personnel as necessary to carry out }{{\f5\fs18\hyphpar0\qj{this part}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3839;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7258.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71425}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72526, 2535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.128}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.129}}}{\*\bkmkstart stylerid1_2E11_2E4_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of state board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state board shall do all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approve the multiyear state plan developed in accordance with applicable federal laws and regulations governing career and technical education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules prescribing standards for teachers in the six career and technical education service areas specified in }}}{{\f5\fs18\hyphpar0\qj{section 256.11, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in approved programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules prescribing standards for approval of school district career and technical education programs; and community colleges with career and technical education programs; and practitioner preparation schools, departments, and classes, applying for federal and state moneys under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules prescribing standards for the career and technical education service areas specified in }}}{{\f5\fs18\hyphpar0\qj{section 256.11, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules prescribing standards for approval of career and technical education planning partnerships, collaborations, and regional centers in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 256.136}}}{{\f5\fs18\hyphpar0\qj{. The rules shall establish a process for the establishment of no fewer than twelve and no greater than fifteen regions in which regional career and technical education planning partnerships may operate. The rules shall establish standards to ensure regional centers have appropriate educational programs, adequate participation, and are located within an appropriate distance of participating high schools and in a manner compatible with development of a statewide network of regional centers.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71426}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a7258.3A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1108, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72527, 2535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.129}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.125}}}{{\f5\fs12\hyphpar0\qj{, 256.130}}}{{\f5\fs12\hyphpar0\qj{, 256.131}}}{{\f5\fs12\hyphpar0\qj{, 256.136}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.130}}}{\*\bkmkstart stylerid1_2E11_2E4_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director of the department of education shall do all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop and submit to the state board for approval the multiyear state plan developed in accordance with federal laws and regulations governing career and technical education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for making studies and investigations relating to career and technical education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promote and aid in the establishment of career and technical education programs in local communities, school districts, and community colleges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cooperate with local communities, school districts, and community colleges in the maintenance of career and technical education programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make recommendations to the board of educational examiners relating to the enforcement of rules prescribing standards for teachers of career and technical education service areas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cooperate in the maintenance of practitioner preparation schools, departments, and classes, supported and controlled by the public, for the training of career and technical education teachers and supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review and approve career and technical education programs to ensure that the programs meet standards adopted by the state board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.129}}}{{\f5\fs18\hyphpar0\qj{. The director shall annually review at least twenty percent of the approved career and technical programs as a basis for continuing approval to ensure that the programs meet board standards and are compatible with educational reform efforts, are capable of responding to technological change and innovation, and meet the educational needs of students and the employment community. The review shall include an assessment of the extent to which the competencies in the program are being mastered by the students enrolled, the costs are proportionate to educational benefits received, the career and technical education curriculum is articulated and integrated with other curricular offerings required of all students, the programs would permit students with career and technical education backgrounds to pursue other educational interests in a postsecondary institutional setting, and the programs remove barriers for both traditional and nontraditional students to access educational and employment opportunities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facilitate the process established by the state board for the implementation of a statewide system of regional career and technical education planning partnerships that utilize the services of local school districts, community colleges, sector partnerships, and other resources to assist local school districts in meeting career and technical education standards while avoiding unnecessary duplication of services. The director shall also review and approve regional planning partnerships and regional centers to ensure that the partnerships and centers meet the standards adopted by the state board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.129, subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enforce rules adopted by the state board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.129}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the accreditation process contained in }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{, permit school districts that provide a program which does not meet the standards for accreditation for career and technical education to cooperate with the regional career and technical education planning partnership and contract for an approved program under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ without losing accreditation. A school district that fails to cooperate with the regional career and technical education planning partnership and contract for an approved program shall, however, be subject to }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribe standards and procedures for the approval of career academies as defined in }}}{{\f5\fs18\hyphpar0\qj{section 256.125}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3840;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7258.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71427}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 278, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1198, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1108, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72528, 2535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.130}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.132}}}{{\f5\fs12\hyphpar0\qj{, 256.137}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.131}}}{\*\bkmkstart stylerid1_2E11_2E4_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reimbursement from federal and state moneys.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An approved regional career and technical education planning partnership is eligible to receive state funds for purposes allowed under }}}{{\f5\fs18\hyphpar0\qj{section 256.136, subsection 6}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Federal funds received as a reimbursement for allowable expenditures shall be received pursuant to the multiyear state plan adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.129, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may use federal funds to reimburse approved practitioner preparation schools, departments, or classes for the training of teachers of agriculture, food, and natural resources; arts, communications, and information systems; applied sciences, technology, engineering, and manufacturing; health sciences; human services; and business, finance, marketing, and management. The director may also use such funds to reimburse approved practitioner preparation schools, departments, or classes for the training of guidance counselors.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3841, 3844;}}}{ C46, 50, \'a7258.5, 258.8; C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7258.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71428}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1108, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1130, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.131}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.132}}}{\*\bkmkstart stylerid1_2E11_2E4_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local advisory council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a school district or community college that maintains a career and technical education program receiving federal or state funds under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ shall, as a condition of approval by the state board, appoint a local advisory council for each career and technical education program offered by the school district or community college. However, a school district and a community college that maintain a career and technical education program receiving federal or state funds may create a joint local advisory council. The membership of each local advisory council shall consist of public members with expertise in the occupation or occupational field related to the career and technical education program. The local advisory council shall give advice and assistance to the board of directors, administrators, and instructors in the establishment and maintenance of the career and technical education program. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a regional advisory council established by a regional career and technical education planning partnership approved by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.130}}}{{\f5\fs18\hyphpar0\qj{ may serve in place of a local advisory council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local advisory councils are not subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 4A.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of an advisory council shall serve without compensation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3845;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7258.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71431}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1108, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72530, 2535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.132}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.133}}}{\*\bkmkstart stylerid1_2E11_2E4_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers of district boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board of directors of a school district shall offer career and technical instruction in service areas as provided in }{{\f5\fs18\hyphpar0\qj{section 256.11, subsection 5}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{, and pay the expense of such instruction in the same way as the expenses for other subjects in the school district are paid.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3846;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7258.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 37, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1108, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.133}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1162, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.134}}}{\*\bkmkstart stylerid1_2E11_2E4_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Salary and expenses for administration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director may make expenditures for salaries and other expenses as necessary to the proper administration of }{{\f5\fs18\hyphpar0\qj{this part}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3847;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7258.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71432}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1134, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1108, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72531, 2535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.134}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.135}}}{\*\bkmkstart stylerid1_2E11_2E4_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Custodian of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer of state shall be custodian of the funds paid to the state from the appropriations made under the federal }{{\f5\fs18\hyphpar0\qj{Carl D. Perkins Career and Technical Education Improvement Act of 2006}}}{, }{{\f5\fs18\hyphpar0\qj{20 U.S.C. \'a72301 et seq.}}}{, as amended, and shall disburse the same on vouchers audited as provided by law. }\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3848;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7258.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 88, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1108, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.135}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.136}}}{\*\bkmkstart stylerid1_2E11_2E4_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Regional career and technical education planning partnerships.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regional career and technical education planning partnerships are established to assist school districts in providing an effective, efficient, and economical means of delivering high-quality secondary career and technical education programs. Regional career and technical education planning partnerships shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the active participation of local school districts and community colleges in the delivery of career and technical education in the region.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for the participation of representatives of business and industry and representatives of sector partnerships and community stakeholders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promote career and college readiness through thoughtful career guidance and purposeful academic and technical planning practices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promote high-quality, integrated career and technical education programming, including career academies, comprised of secondary exploratory and transitory coursework to prepare students for higher-level, specialized academic and technical training aligned with labor market needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide for increased and equitable access to high-quality career and technical education programs through the planning and development of a system of regional centers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regional career and technical education planning partnerships shall be established in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 256.129, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, to serve each community college and all of the school districts in the state no later than June 30, 2017.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A regional career and technical education planning partnership shall be responsible for the following activities:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ensuring compliance with standards adopted by the state board under }}}{{\f5\fs18\hyphpar0\qj{section 256.129, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, for regional career and technical education planning partnerships.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Developing a multiyear plan addressing the delivery of quality career and technical education programs by school districts in fulfillment of the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 256.11, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 256.11, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The plan shall be updated annually.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Securing collaboration with secondary schools, postsecondary educational institutions, and employers to ensure the creation of high-quality career and technical education programming, including career academies, for students that aligns career guidance, twenty-first century career and technical education and academic curricula, and work-based learning opportunities that empower students to be successful learners and practitioners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reviewing career and technical education programs of school districts within the region based on standards adopted by the state board, and recommending to the department career and technical education programs for approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Coordinating and facilitating local advisory councils for career and technical education programs. As necessary, establishing regional advisory councils to serve in the same capacity as local advisory councils.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Planning for regional centers with the purpose of achieving equitable access to high-quality career and technical education programming and concurrent enrollment opportunities for all students. As a condition for approval, a regional center shall comply with standards adopted by the state board and shall consist of a minimum of four career academies. A regional center shall be compatible with development of a statewide system of regional centers serving all students. A regional center shall serve either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A combined minimum of one hundred twenty students from no fewer than two school districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A minimum of four school districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Meeting regularly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The membership of each regional career and technical education planning partnership shall consist of stakeholders in a position to contribute to the development and successful implementation of high-quality career and technical education programs and shall include but not be limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent of a school district within the regional planning partnership, or the superintendent\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The president of a community college within the regional planning partnership, or the president\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief administrator of an area education agency within the regional planning partnership, or the chief administrator\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representatives of regional economic and workforce entities including local workforce development boards established under }}}{{\f5\fs18\hyphpar0\qj{section 84A.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representatives of business and industry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Career and technical education teachers and faculty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Convening the regional career and technical education planning partnership shall be the joint responsibility of the area education agency and community college located within the region. In convening the regional career and technical education planning partnership, the area education agency and the community college shall include stakeholders from each member district of the partnership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A regional career and technical education partnership may use funds received from state and federal sources on behalf of school districts and community colleges participating in the regional career and technical education planning partnership to convene, lead, and staff the regional career and technical education planning partnership; to offer regional career and technical education professional development opportunities; to coordinate and maintain a career guidance system pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 279.61}}}{{\f5\fs18\hyphpar0\qj{; to purchase career and technical education equipment; and to purchase standard classroom consumable supplies other than consumable supplies that will be made into products to be sold or used personally by students, teachers, and other persons.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1108, \'a746}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2017, \'a7258.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 29, \'a773 \u8211\'3f 75}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1130, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.136}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1162, \'a76 \u8211\'3f 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.125}}}{{\f5\fs12\hyphpar0\qj{, 256.129}}}{{\f5\fs12\hyphpar0\qj{, 256.131}}}{{\f5\fs12\hyphpar0\qj{, 256.137}}}{{\f5\fs12\hyphpar0\qj{, 282.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.137}}}{\*\bkmkstart stylerid1_2E11_2E4_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Career academy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A career academy may be established under an agreement between a single school district and a community college, or by multiple school districts and a community college organized into a regional career and technical education planning partnership pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.136}}}{{\f5\fs18\hyphpar0\qj{. A career academy established under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be a career-oriented or occupation-oriented program of study that includes a minimum of two years of secondary education, which may fulfill the sequential unit requirement in one of the four service areas required under }}}{{\f5\fs18\hyphpar0\qj{section 256.11, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, is articulated with a postsecondary education program, and is approved by the director under }}}{{\f5\fs18\hyphpar0\qj{section 256.130}}}{{\f5\fs18\hyphpar0\qj{. A career academy shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Utilize regional career and technical education planning partnerships outlined in }}}{{\f5\fs18\hyphpar0\qj{section 256.136}}}{{\f5\fs18\hyphpar0\qj{ in an advisory capacity to inform the selection and design of the career academy and establishment of industry standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish a program of study that meets all of the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is designed to meet industry standards and prepare students for success in postsecondary education and the workforce.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Integrates academic coursework, includes work-based learning, and utilizes the individual career and academic planning process established under }}}{{\f5\fs18\hyphpar0\qj{section 279.61}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allows students enrolled in the academy an opportunity to continue on to an associate degree and, if applicable, a postsecondary baccalaureate degree program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board, in consultation with the community colleges and post-secondary readiness bureau, shall adopt rules setting minimum standards for the development and implementation of career academies under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and ensuring compliance with the federal }}}{{\f5\fs18\hyphpar0\qj{Carl D. Perkins Career and Technical Education Improvement Act of 2006}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{20 U.S.C. \'a72301 et seq.}}}{{\f5\fs18\hyphpar0\qj{, as amended.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1108, \'a747}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2017, \'a7258.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 29, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72535}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.137}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1043, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.125}}}{{\f5\fs12\hyphpar0\qj{, 257.51}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{256.138 through 256.144}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 3}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_2E5_2E2_2E2}{BOARD OF EDUCATIONAL EXAMINERS}{\*\bkmkend stylerid1_2E11_2E5_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a720.17}}}{{\f5\fs12\qc{, 20.19}}}{{\f5\fs12\qc{, 20.20}}}{{\f5\fs12\qc{, 256.7}}}{{\f5\fs12\qc{, 256.9}}}{{\f5\fs12\qc{, 256.11}}}{{\f5\fs12\qc{, 256.16}}}{{\f5\fs12\qc{, 256.41}}}{{\f5\fs12\qc{, 256.43}}}{{\f5\fs12\qc{, 256.103}}}{{\f5\fs12\qc{, 256.121}}}{{\f5\fs12\qc{, 256.220}}}{{\f5\fs12\qc{, 256C.3}}}{{\f5\fs12\qc{, 256E.7}}}{{\f5\fs12\qc{, 257.11}}}{{\f5\fs12\qc{, 260C.48}}}{{\f5\fs12\qc{, 261E.4}}}{{\f5\fs12\qc{, 261H.2}}}{{\f5\fs12\qc{, 272C.15}}}{{\f5\fs12\qc{, 273.3}}}{{\f5\fs12\qc{, 279.13}}}{{\f5\fs12\qc{, 279.19B}}}{{\f5\fs12\qc{, 279.72}}}{{\f5\fs12\qc{, 279.73}}}{{\f5\fs12\qc{, 284.2}}}{{\f5\fs12\qc{, 284.10}}}{{\f5\fs12\qc{, 284.15}}}{{\f5\fs12\qc{, 284.16}}}{{\f5\fs12\qc{, 284A.2}}}{{\f5\fs12\qc{, 284A.6}}}{{\f5\fs12\qc{, 284A.7}}}{{\f5\fs12\qc{, 299A.2}}}{{\f5\fs12\qc{, 622.10}}}{{\f5\fs12\qc{, 709.15}}}{{\f5\fs12\qc{, 714.19}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Continuity of licenses, certificates, or authorization issued by board of educational examiners under former }{{\f5\fs12\qc{chapter 272}}}{ prior to July 1, 2023; use of federal funds to employ personnel necessary for program administration; }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\cf5{{\f5\fs12\qc\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH19.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 19, \'a72604}}}}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri1445\li1445\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.145}}}{\*\bkmkstart stylerid1_2E11_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this part}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdministrator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is licensed to coordinate, supervise, or direct an educational program or the activities of other practitioners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the board of educational examiners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCertificate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means limited recognition to perform instruction and instruction-related duties in school, other than those duties for which practitioners are licensed. A certificate is nonexclusive recognition and does not confer the exclusive authority of a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the authority that is given to allow a person to legally serve as a practitioner, a school, an institution, or a course of study to legally offer professional development programs, other than those programs offered by practitioner preparation schools, institutions, courses of study, or area education agencies. A license is the exclusive authority to perform these functions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOffense directly relates\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ refers to either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The actions taken in furtherance of an offense are actions customarily performed within the scope of practice of a licensed profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The circumstances under which an offense was committed are circumstances customary to a licensed profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPara-educator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is certified to assist a teacher in the performance of instructional tasks to support and assist classroom instruction and related school activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPractitioner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an administrator, teacher, or other licensed professional, including an individual who holds a statement of professional recognition, who provides educational assistance to students.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPractitioner preparation program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a program approved by the state board of education which prepares a person to obtain a license as a practitioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPrincipal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a licensed member of a school\u8217\'3fs instructional staff who serves as an instructional leader, coordinates the process and substance of educational and instructional programs, coordinates the budget of the school, provides formative evaluation for all practitioners and other persons in the school, recommends or has effective authority to appoint, assign, promote, or transfer personnel in a school building, implements the local school board\u8217\'3fs policy in a manner consistent with professional practice and ethics, and assists in the development and supervision of a school\u8217\'3fs student activities program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProfessional development program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a course or program which is offered by a person or agency for the purpose of providing continuing education for the renewal or upgrading of a practitioner\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchool\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a school under }}}{{\f5\fs18\hyphpar0\qj{section 280.2}}}{{\f5\fs18\hyphpar0\qj{, an area education agency, and a school operated by a state agency for special purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchool administration manager\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is authorized to assist a school principal in performing noninstructional administrative duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchool service personnel\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those persons holding a practitioner\u8217\'3fs license who provide support services for a student enrolled in school or to practitioners employed in a school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fStudent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is enrolled in a course of study at a school or practitioner preparation program, or who is receiving direct or indirect assistance from a practitioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSuperintendent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an administrator who promotes, demotes, transfers, assigns, or evaluates practitioners or other personnel, and carries out the policies of a governing board in a manner consistent with professional practice and ethics.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTeacher\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a licensed member of a school\u8217\'3fs instructional staff who diagnoses, prescribes, evaluates, and directs student learning in a manner which is consistent with professional practice and school objectives, shares responsibility for the development of an instructional program and any coordinating activities, evaluates or assesses student progress before and after instruction, and who uses the student evaluation or assessment information to promote additional student learning.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWork-based learning program supervisor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is certified pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.161}}}{{\f5\fs18\hyphpar0\qj{ to supervise students\u8217\'3f opportunities and experiences related to workplace tours, job shadowing, rotations, mentoring, entrepreneurship, service learning, internships, and apprenticeships. }}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72628; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3858;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7260.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1249, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1216, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1098, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1047, \'a710, 20}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1008, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1119, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1103, \'a721, 31}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1134, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72560, 2603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.145}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.44}}}{{\f5\fs12\hyphpar0\qj{, 256.219}}}{{\f5\fs12\hyphpar0\qj{, 256E.7}}}{{\f5\fs12\hyphpar0\qj{, 256F.7}}}{{\f5\fs12\hyphpar0\qj{, 261B.3A}}}{{\f5\fs12\hyphpar0\qj{, 263.1}}}{{\f5\fs12\hyphpar0\qj{, 266.2}}}{{\f5\fs12\hyphpar0\qj{, 279.78}}}{{\f5\fs12\hyphpar0\qj{, 284.15}}}{{\f5\fs12\hyphpar0\qj{, 284.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.146}}}{\*\bkmkstart stylerid1_2E11_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Board of examiners created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board is created within the higher education division of the department of education to exercise the exclusive authority to:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{License practitioners, which includes the authority to do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish criteria for the licenses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish issuance and renewal requirements, provided that a continuing education requirement may be completed by electronic means, and there shall be no renewal requirement for a practitioner who has been employed as a practitioner for at least ten years and who possesses a master\u8217\'3fs or doctoral degree, unless the practitioner holds an evaluator approval endorsement, which must be renewed at least once every ten years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Create application and renewal forms.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Create licenses that authorize different instructional functions or specialties.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop a code of professional rights and responsibilities, practices, and ethics, which shall, among other things, address all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The failure of a practitioner to fulfill contractual obligations under }}}{{\f5\fs18\hyphpar0\qj{section 279.13}}}{{\f5\fs18\hyphpar0\qj{. In addressing the failure of a practitioner to fulfill contractual obligations, the board shall consider factors beyond the practitioner\u8217\'3fs control.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The failure of an administrator to protect the safety of staff and students.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The failure of an administrator to meet mandatory reporter obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The refusal of a practitioner to implement provisions of an individualized education program or behavioral intervention plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Habitual nonparticipation in professional development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The development of any other classifications, distinctions, and procedures which may be necessary to exercise licensing duties. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide annually to any person who holds a license, certificate, authorization, or statement of recognition issued by the board, training relating to the knowledge and understanding of the board\u8217\'3fs code of professional conduct and ethics. The board shall develop a curriculum that addresses the code of professional conduct and ethics and shall annually provide regional training opportunities throughout the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ establishing licensure renewal requirements shall provide that up to half of the units needed for licensure renewal may be earned upon the successful completion of an individualized professional development plan as verified by the supervising licensed evaluator, or by successful completion of professional development courses or programs offered by a professional development program licensed by the board, or by a practitioner preparation institution or area education agency approved by the state board of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish, collect, and refund fees for a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter into reciprocity agreements with other equivalent state boards or a national certification board to provide for licensing of applicants from other states or nations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enforce rules adopted by the board through revocation or suspension of a license, or by other disciplinary action against a practitioner or professional development program licensed by the board. The board shall designate who may or shall initiate a licensee disciplinary investigation and a licensee disciplinary proceeding, and who shall prosecute a disciplinary proceeding and under what conditions, and shall state the procedures for review by the board of findings of fact if a majority of the board does not hear the disciplinary proceeding. However, in a case alleging failure of a practitioner to fulfill contractual obligations, the person who files a complaint with the board, or the complainant\u8217\'3fs designee, shall represent the complainant in a disciplinary hearing conducted in accordance with }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Apply for and receive federal or other funds on behalf of the state for purposes related to its duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Evaluate and conduct studies of board standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hear appeals regarding application, renewal, suspension, or revocation of a license. Board action is final agency action for purposes of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish standards for the determination of whether an applicant is qualified to perform the duties required for a given license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue statements of professional recognition to school service personnel who have attained a minimum of a baccalaureate degree and who are licensed by another professional licensing board, including but not limited to athletic trainers licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make recommendations to the state board of education concerning standards for the approval of professional development programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt, under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, rules necessary to carry out board duties, and establish a budget request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules to provide for nontraditional preparation options for licensing persons who hold a bachelor\u8217\'3fs degree or higher from an accredited or state-approved college or university, who do not meet other requirements for licensure. The rules shall, at a minimum, require the board to do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a teacher intern license to an applicant who has enrolled in a program established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.16, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allow a licensee who has attained a teacher intern license pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ to apply for an initial teaching license if the school that employed the licensee during the licensee\u8217\'3fs completion of the program established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.16, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and the higher education institution that operated the program recommend that the licensee be allowed to apply for an initial teaching license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules to determine whether an applicant is qualified to perform the duties for which a license is sought. The rules shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may deny a license to or revoke the license of a person upon the board\u8217\'3fs finding by a preponderance of evidence that either the person has been convicted of an offense and the offense directly relates to the duties and responsibilities of the profession or that there has been a founded report of child abuse against the person. Rules adopted in accordance with this paragraph shall provide that in determining whether a person should be denied a license or that a practitioner\u8217\'3fs license should be revoked, the board shall consider the nature and seriousness of the founded abuse or offense in relation to the position sought, the time elapsed since the offense was committed, the degree of rehabilitation which has taken place since the incidence of founded abuse or the commission of the offense, the likelihood that the person will commit the same abuse or offense again, and the number of founded abuses committed by or criminal convictions of the person involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the rules shall require the board to disqualify an applicant for a license or to revoke the license of a person for any of the following reasons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person entered a plea of guilty to, or has been found guilty of, any of the following offenses, whether or not a sentence is imposed:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following forcible felonies included in }}}{{\f5\fs18\hyphpar0\qj{section 702.11}}}{{\f5\fs18\hyphpar0\qj{:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{child endangerment, assault, murder, sexual abuse, or kidnapping.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following sexual abuse offenses, as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 709}}}{{\f5\fs18\hyphpar0\qj{, involving a child:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{First, second, or third degree sexual abuse committed on or with a person who is under the age of eighteen years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lascivious acts with a child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assault with intent to commit sexual abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Indecent contact with a child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(v)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual exploitation by a counselor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(vi)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lascivious conduct with a minor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(vii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual exploitation by a school employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enticing a minor under }}}{{\f5\fs18\hyphpar0\qj{section 710.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Human trafficking under }}}{{\f5\fs18\hyphpar0\qj{section 710A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Incest involving a child under }}}{{\f5\fs18\hyphpar0\qj{section 726.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Dissemination and exhibition of obscene material to minors under }}}{{\f5\fs18\hyphpar0\qj{section 728.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(g)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Telephone dissemination of obscene material to minors under }}}{{\f5\fs18\hyphpar0\qj{section 728.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(h)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any offense specified in the laws of another jurisdiction, or any offense that may be prosecuted in federal, military, or foreign court, that is comparable to an offense listed in this subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any offense under prior laws of this state or another jurisdiction, or any offense under prior law that was prosecuted in a federal, military, or foreign court, that is comparable to an offense listed in this subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant\u8217\'3fs application is fraudulent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant\u8217\'3fs license or certification from another state is suspended or revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant fails to meet board standards for application for an initial or renewed license. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Qualifications or criteria for the granting or revocation of a license or the determination of an individual\u8217\'3fs professional standing shall not include membership or nonmembership in any teachers\u8217\'3f organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a license or certificate under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ shall demonstrate that the requirements of the license or certificate have been met and the burden of proof shall be on the applicant. However, if the executive director of the board receives notice from the director of the department under }}}{{\f5\fs18\hyphpar0\qj{section 256.9, subsection 17}}}{{\f5\fs18\hyphpar0\qj{, that an error in the basic education data survey submission resulted in an incorrect determination relating to licensure of a practitioner, the executive director shall initiate corrective action with the board and the findings of the director of the department shall be sufficient evidence to correct such error.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may deny a license to or revoke the license of a person upon the board\u8217\'3fs finding by a preponderance of evidence that the person knowingly and intentionally discriminated against a student in violation of }}}{{\f5\fs18\hyphpar0\qj{section 261H.2, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 279.73}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules that require specificity in written complaints that are filed by individuals who have personal knowledge of an alleged violation and which are accepted by the board, provide that the jurisdictional requirements as set by the board in administrative rule are met on the face of the complaint before initiating an investigation of allegations, provide that any investigation be limited to the allegations contained on the face of the complaint, provide for an adequate interval between the receipt of a complaint and public notice of the complaint, permit parties to a complaint to mutually agree to a resolution of the complaint filed with the board, allow the respondent the right to review any investigative report upon a finding of probable cause for further action by the board, require that the conduct providing the basis for the complaint occurred within three years of discovery of the event by the complainant unless good cause can be shown for an extension of this limitation or unless the conduct constitutes conduct described in }}}{{\f5\fs18\hyphpar0\qj{section 256.160, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (a), require complaints to be resolved within one hundred eighty days unless good cause can be shown for an extension of this limitation, and require the board to finalize the investigation of the written complaint even if the licensed practitioner resigns or surrenders the licensed practitioner\u8217\'3fs license, certificate, authorization, or statement of recognition during the investigation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules that require the collection and retention of written complaints that are filed. If the board determines a written complaint is not founded, the complaint and all records related to the complaint shall be kept confidential and are not subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules that require the board to notify the public when a licensed practitioner who is the subject of an ongoing investigation initiated under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ has a case pending with a finding of probable cause. This paragraph shall not be construed to require the board to disclose unfounded, closed investigations initiated under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules that require the evaluation of complaints that did not result in any discipline or sanction if similar complaints are filed against the same licensed practitioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules that require the board to investigate an administrator who is employed by the school that employs a licensed practitioner who is the subject of an investigation initiated under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The rules shall require the board to investigate whether the administrator filed a written complaint pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and whether the administrator was required to report to the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.160}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt criteria for administrative endorsements that allow a person to achieve the endorsement authorizing the person to serve as an elementary or secondary principal without regard to the grade level at which the person accrued teaching experience.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules to require that a background investigation be conducted by the division of criminal investigation of the department of public safety on all initial applicants for licensure. The board shall also require all initial applicants to submit a completed fingerprint packet and shall use the packet to facilitate a national criminal history background check. The board shall have access to, and shall review the sex offender registry information under }}}{{\f5\fs18\hyphpar0\qj{section 692A.121}}}{{\f5\fs18\hyphpar0\qj{ available to the general public, information in the Iowa court information system available to the general public, the central registry for child abuse information established under }}}{{\f5\fs18\hyphpar0\qj{chapter 235A}}}{{\f5\fs18\hyphpar0\qj{, and the dependent adult abuse records maintained under }}}{{\f5\fs18\hyphpar0\qj{chapter 235B}}}{{\f5\fs18\hyphpar0\qj{ for information regarding applicants for license renewal and, every five years, for practitioners who are not subject to renewal requirements pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2). The board may charge such a practitioner who is not subject to renewal requirements a reasonable fee for the review of the sex offender registry information, information in the Iowa court information system, the central registry for child abuse information, and the dependent adult abuse records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{May adopt rules for practitioners who are not eligible for a statement of professional recognition under }}}{{\f5\fs18\hyphpar0\qj{subsection 9}}}{{\f5\fs18\hyphpar0\qj{, but have received a baccalaureate degree and provide a service to students at any or all levels from prekindergarten through grade twelve for a school district, accredited nonpublic school, area education agency, or preschool program established pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 256C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules to provide in the board\u8217\'3fs code of professional conduct and ethics that any licensee of the board, who commits or solicits any sexual conduct as defined in }}}{{\f5\fs18\hyphpar0\qj{section 709.15, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), or solicits, encourages, or consummates a romantic relationship with any individual who was a student within ninety days prior to any such conduct alleged in a complaint initiated with the board, if the licensee taught the individual or supervised the individual in any school activity when the individual was a student, engages in unprofessional and unethical conduct that may result in disciplinary action by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing endorsements and authorizations for computer science instruction, including traditional and nontraditional pathways for obtaining such endorsements or authorizations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to prohibit the suspension or revocation of a license issued by the board to a person who is in default or is delinquent on repayment or a service obligation under federal or state postsecondary educational loans or public or private services-conditional postsecondary tuition assistance solely on the basis of such default or delinquency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By July 1, 2021, adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, developed in collaboration with the Iowa reading research center, establishing an advanced dyslexia specialist endorsement. The endorsement shall require a strong understanding of structured literacy instruction; the neurobiological nature, cognitive-linguistic correlates, developmental indicators, compensatory behaviors, potential psychological factors, and co-occurring disorders of dyslexia; demonstrated skill in administering informal and formal assessments related to dyslexia; demonstrated skill in delivery of explicit, systematic literacy intervention; demonstrated skill in developing and supporting services for students with characteristics of dyslexia including those who are eligible for services under }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 504 of the federal Rehabilitation Act of 1973}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7794}}}{{\f5\fs18\hyphpar0\qj{, as amended; demonstrated skill in the design and implementation of accommodations and modifications; demonstrated competence in creating a dyslexia-friendly learning environment; and demonstrated skill in the use and integration of assistive technology. This endorsement shall, at a minimum, require three years of prior teaching experience and completion of a supervised practical experience.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish, collect, and refund fees from an administrator for the administrative costs of processing complaints and conducting hearings if the administrator is the respondent in a complaint for violation of the code of professional conduct and ethics, developed pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, for which final board action results in a sanction against the administrator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By August 1, 2021, adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing a statement of professional recognition for behavior analysts licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By January 1, 2022, adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing a statement of professional recognition for mental health professionals as defined in }}}{{\f5\fs18\hyphpar0\qj{section 228.1}}}{{\f5\fs18\hyphpar0\qj{. The rules shall require that any mental health professional who provides mental health services to students for a school obtain such a statement unless a professional service license or endorsement relating to mental health services has been issued to the mental health professional by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop and implement a process for the reporting and investigation of any incident that arises that may reasonably lead to the conclusion that any individual who is employed by the board of directors of a school district, the authorities in charge of an accredited nonpublic school, or the governing board of a charter school, including an individual with a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners, has committed a felony or, in the case of an individual with a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners, has engaged in conduct described in }}}{{\f5\fs18\hyphpar0\qj{section 256.160, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1).}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The process must require the board of educational examiners to assign a unique identifier to each incident that is reported. The board of educational examiners shall provide the unique identifier to the person who reported the incident and to the employee who is the subject of the incident, and the unique identifier must be able to be used to search the board of educational examiners\u8217\'3f internet site to determine the current status of the investigation of the incident, including the date of the most recently taken action. The board of educational examiners shall ensure that the portion of the internet site displaying such information is only accessible by the person who reported the incident, the employee who is the subject of the incident, and the board of educational examiners and its employees and agents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The process shall prohibit the board of directors of a school district, the authorities in charge of an accredited nonpublic school, and the governing board of a charter school from entering into any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written or oral agreement that prohibits the board of directors of the school district, the authorities in charge of an accredited nonpublic school, the governing board of a charter school, an employee of the school district, the accredited nonpublic school, or the charter school, or a contractor of the school district, the accredited nonpublic school, or the charter school from discussing an incident, past performance or actions, past allegations leading to discipline or adverse employment action, or employee resignation with any governmental agent, governmental officer, or any potential employer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written or oral agreement that waives the liability of an individual with a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners related to or arising from an incident, past performance or action, or past allegations of wrongdoing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The process shall require the board of directors of a school district, the authorities in charge of an accredited nonpublic school, and the governing board of a charter school to provide all documentation and information related to the incident to the board of educational examiners for investigation if the employee who is the subject of the incident and who has a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners resigns or the employee\u8217\'3fs contract is terminated during the school district\u8217\'3fs, accredited nonpublic school\u8217\'3fs, or charter school\u8217\'3fs investigation of the incident.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The process shall require the board of directors of a school district, the authorities in charge of an accredited nonpublic school, and the governing board of a charter school to finalize the investigation of the incident even if the employee who is the subject of the incident and who does not have a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners resigns or the employee\u8217\'3fs contract is terminated during the school district\u8217\'3fs, accredited nonpublic school\u8217\'3fs, or charter school\u8217\'3fs investigation of the incident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The process shall require that, prior to hiring an applicant for any position, the board of directors of a school district, the authorities in charge of an accredited nonpublic school, and the governing board of a charter school must conduct a review of the applicant\u8217\'3fs employment history, including by contacting the applicant\u8217\'3fs previous employers listed on the application for employment and by viewing the board of educational examiners\u8217\'3f public license information to determine if the applicant has a case pending with a finding of probable cause or any licensure sanction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The process shall require the board of directors of a school district, the authorities in charge of an accredited nonpublic school, and the governing board of a charter school to maintain on forms prescribed by the board of educational examiners reference information related to all employees of the school district, accredited nonpublic school, or charter school, and respond to any request for such information from a potential employer. This paragraph shall not be construed to require the board of directors of a school district, the authorities in charge of an accredited nonpublic school, or the governing board of a charter school to disclose unfounded, closed investigations. The board of directors of a school district, the authorities in charge of an accredited nonpublic school, or the governing board of a charter school shall be immune from any criminal or civil liability arising from the disclosure of reference information under this paragraph if the school district, accredited nonpublic school, or charter school does not knowingly disclose false information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a school district, the authorities in charge of an accredited nonpublic school, or the governing board of a charter school, and contractors of the school district, the accredited nonpublic school, or the charter school shall be immune from any civil liability arising from discussing an incident, past performance or actions, past allegations leading to discipline or adverse employment action, or employee resignation with any governmental agent, governmental officer, or any potential employer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after investigation, the board of educational examiners determines that the board of directors of a school district, the authorities in charge of an accredited nonpublic school, or the governing board of a charter school has intentionally failed to follow the process established by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ regarding an incident, or the reporting requirements established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.160}}}{{\f5\fs18\hyphpar0\qj{, related to an employee who holds a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners, any administrator of the school district, the accredited nonpublic school, or the charter school who intentionally failed to ensure compliance with the process shall be subject to a hearing conducted by the board of educational examiners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after investigation, the board of educational examiners determines that the board of directors of a school district, the authorities in charge of an accredited nonpublic school, or the governing board of a charter school has intentionally failed to follow the process established by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ regarding an incident related to an employee who does not hold a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners, any administrator of the school district, the accredited nonpublic school, or the charter school who intentionally failed to ensure compliance with the process shall be subject to a hearing conducted by the board of educational examiners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after investigation, the board of educational examiners determines that the board of directors of a school district, the authorities in charge of an accredited nonpublic school, or the governing board of a charter school has intentionally concealed, or attempted to conceal from any governmental agent, governmental officer, or potential employer a founded incident, or any conduct required to be reported pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.160}}}{{\f5\fs18\hyphpar0\qj{, related to an employee who holds a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners, any administrator of the school district, the accredited nonpublic school, or the charter school who intentionally assisted in the concealment, or attempted concealment, of an incident, or any conduct required to be reported pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.160}}}{{\f5\fs18\hyphpar0\qj{, shall be subject to a hearing conducted by the board of educational examiners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after investigation, the board of educational examiners finds that the board of directors of a school district, the authorities in charge of an accredited nonpublic school, or the governing board of a charter school has intentionally concealed, or attempted to conceal from any governmental agent, governmental officer, or potential employer a founded incident related to an employee who does not hold a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners, any administrator of the school district, the accredited nonpublic school, or the charter school who intentionally assisted in the concealment, or attempted concealment, of an incident shall be subject to a hearing conducted by the board of educational examiners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annually, on or before June 30 of each year, the board of educational examiners shall submit to the general assembly a report that contains information related to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number and types of disciplinary hearings before the board of educational examiners.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any trends in the number or types of disciplinary hearings before the board of educational examiners.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of board of educational examiners investigations of the employees of school districts, accredited nonpublic schools, or charter schools who do not hold a license, endorsement, certification, authorization, or statement of recognition issued by the board of educational examiners, that the board of educational examiners referred to a law enforcement agency.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information deemed relevant by the board of educational examiners in order to inform the general assembly of the status of the enforcement of the board of educational examiners\u8217\'3f rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The report shall not include any personally identifiable information related to investigations referred to a law enforcement agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ that allow an individual seeking a career and technical secondary authorization to apply, and, if eligible, be issued the secondary authorization prior to accepting an offer of employment with a school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By September 1, 2024, adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing endorsements for instruction related to career and technical fields in schools providing instruction to students enrolled in prekindergarten through grade twelve, including but not limited to business, agriculture, industrial technology, consumer science, and information technology.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72629; S13, \'a72629; C24, 27, 31, \'a73863; C35, \'a73858-e1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3858.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7260.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71442}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1249, \'a75, 6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1189, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1215, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 103, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 161, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 177, \'a713, 15}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1084, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1128, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 180, \'a714, 15}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 108, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1008, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 119, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 177, \'a732, 33}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1043, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 35, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 132, \'a793, 106}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1045, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 4, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 10, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1066, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 106, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 13, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 30, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1048, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1093, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1103, \'a722, 31, 39, 51}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1108, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7144}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 87, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 111, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 130, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 170, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1103, \'a76, 7, 9, 10}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72561 \u8211\'3f 2565, 2603, 2605}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 62, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 95, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 100, \'a72, 3}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.146}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1079, \'a77, 11}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1162, \'a712, 14}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1171, \'a72, 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.69}}}{{\f5\fs12\hyphpar0\qj{, 232E.1}}}{{\f5\fs12\hyphpar0\qj{, 235B.16}}}{{\f5\fs12\hyphpar0\qj{, 256.7}}}{{\f5\fs12\hyphpar0\qj{, 256.11}}}{{\f5\fs12\hyphpar0\qj{, 256.151}}}{{\f5\fs12\hyphpar0\qj{, 256.155}}}{{\f5\fs12\hyphpar0\qj{, 256.157}}}{{\f5\fs12\hyphpar0\qj{, 256.160}}}{{\f5\fs12\hyphpar0\qj{, 256.161}}}{{\f5\fs12\hyphpar0\qj{, 256.165}}}{{\f5\fs12\hyphpar0\qj{, 261E.3}}}{{\f5\fs12\hyphpar0\qj{, 279.43}}}{{\f5\fs12\hyphpar0\qj{, 279.69}}}{{\f5\fs12\hyphpar0\qj{, 279.73}}}{{\f5\fs12\hyphpar0\qj{, 279.78}}}{{\f5\fs12\hyphpar0\qj{, 280.34}}}{{\f5\fs12\hyphpar0\qj{, 284.6A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendments apply to students who attended or are attending practitioner preparation programs before, on, or after June 13, 2022; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1103.pdf" }{\fldrslt \cf5 \f5 \fs12{{2022 Acts, ch 1103, \'a710}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendments by }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 192023 Acts, ch 19}}}{, apply to individuals appointed as the executive director of the board of educational examiners before, on, or after July 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 19, \'a72605}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.147}}}{\*\bkmkstart stylerid1_2E11_2E5_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Membership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of educational examiners shall consist of thirteen members, subject to the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Four members shall be members of the general public who have demonstrated an interest in education but have never held a practitioner\u8217\'3fs license. Two of the members appointed pursuant to this paragraph shall be the parent or guardian of a student who is currently enrolled in a school district, accredited nonpublic school, or charter school, shall not currently hold any elective office, and shall not be an employee or contractor of a school district, accredited nonpublic school, or charter school. One of the members appointed pursuant to this paragraph shall have been or currently be a member of the board of directors of a school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eight members shall be licensed practitioners. Three of the members appointed pursuant to this paragraph shall be administrators and one shall be an employee of an accredited nonpublic school. The remaining four members appointed pursuant to this paragraph shall be selected from the following areas and specialties of the teaching profession:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Elementary teachers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Secondary teachers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Special education or similar teachers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Counselors or other special purpose practitioners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{School service personnel. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall be the director of the department or the director\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The membership of the board shall comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 4A.12}}}{{\f5\fs18\hyphpar0\qj{. A quorum of the board shall consist of seven members. Members shall elect a chairperson of the board. Members, except for the director of the department or the director\u8217\'3fs designee, shall be appointed by the governor subject to confirmation by the senate.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72634; S13, \'a72634-a; SS15, \'a72634-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3859;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7260.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71443}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a73}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1047, \'a711, 20}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 104, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1008, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72566, 2567, 2603}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 95, \'a78, 12}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.147}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1004, \'a735}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.148}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment applies to the governor\u8217\'3fs appointments to the board of educational examiners on or after July 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 95, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.148}}}{\*\bkmkstart stylerid1_2E11_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Terms of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members, except for the director or the director\u8217\'3fs designee, shall be appointed to serve staggered terms of four years. A member shall not serve more than two consecutive terms, except for the director or the director\u8217\'3fs designee, who shall serve until the director\u8217\'3fs term of office expires. A member of the board who is a licensed practitioner appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.147, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall hold a valid practitioner\u8217\'3fs license during the member\u8217\'3fs term of office. A vacancy exists when any of the following occur:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The license of a licensed practitioner appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.147, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, expires, is suspended, or is revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensed practitioner appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.147, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, retires or terminates employment as a practitioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member dies, resigns, is removed from office, or is otherwise physically unable to perform the duties of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member\u8217\'3fs term of office expires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Terms of office for regular appointments shall begin and end as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{. Terms of office for members appointed to fill vacancies shall begin on the date of appointment and end as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{. Members may be removed for cause by a state court with competent jurisdiction after notice and opportunity for hearing. The board may remove a member for three consecutive absences or for cause.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a74}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS89, \'a7260.4}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1212, \'a725}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 22, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1008, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72568, 2603}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 95, \'a79, 12}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.148}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 1 applies to the governor\u8217\'3fs appointments to the board of educational examiners on or after July 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 95, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.149}}}{\*\bkmkstart stylerid1_2E11_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Compensation of board }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ executive director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members shall be reimbursed for actual and necessary expenses incurred while engaged in their official duties and may be entitled to per diem compensation as authorized under }}}{{\f5\fs18\hyphpar0\qj{section 7E.6}}}{{\f5\fs18\hyphpar0\qj{. For duties performed during an ordinary school day by a member who is employed by a school corporation or state university, the member shall also receive regular compensation from the school or university. However, the member shall reimburse the school or university in the amount of the per diem compensation received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall appoint an executive director of the board. The executive director shall possess a background in education licensure and administrative experience. The director shall set the salary of the executive director.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a73872-e1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3872.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7260.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1249, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1119, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72569, 2603, 2605}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.149}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 2 applies to individuals appointed as the executive director of the board of educational examiners before, on, or after July 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 19, \'a72605}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.150}}}{\*\bkmkstart stylerid1_2E11_2E5_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Immunities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be civilly liable as a result of the person\u8217\'3fs acts, omissions, or decisions that are reasonable and in good faith as a member of the board or as an employee or agent in connection with the person\u8217\'3fs duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be civilly liable as a result of filing a report or complaint with the board or for the disclosure to the board or its agents or employees, whether or not pursuant to a subpoena of records, documents, testimony, or other forms of information in connection with proceedings of the board. However, such immunity from civil liability shall not apply if such an act is done with malice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be dismissed from employment or discriminated against by an employer for doing any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Filing a complaint with the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Participating as a member, agent, or employee of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Presenting testimony or other evidence to the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be liable to a person aggrieved by such violation for actual and punitive damages plus reasonable attorney fees.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 37, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS2011, \'a7272.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.150}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.151}}}{\*\bkmkstart stylerid1_2E11_2E5_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Validity of license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license issued under board authority is valid for the period of time for which it is issued, unless the license is suspended or revoked. Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 256.146, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), permanent licenses shall not be issued. A person employed as a practitioner shall hold a valid license with an endorsement for the type of service for which the person is employed. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not limit the duties or powers of a school board to select or discharge practitioners or to terminate practitioners\u8217\'3f contracts. A professional development program, except for a program offered by a practitioner preparation institution or area education agency and approved by the state board of education, must possess a valid license for the types of programs offered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The executive director of the board may grant or deny license applications, applications for renewal of a license, and suspension or revocation of a license. A denial of an application for a license, the denial of an application for renewal, or a suspension or revocation of a license may be appealed by the practitioner to the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may issue emergency renewal or temporary, limited-purpose licenses upon petition by a current or former practitioner. An emergency renewal or a temporary, limited-purpose license may be issued for a period not to exceed two years, if a petitioner demonstrates, to the satisfaction of the board, good cause for failure to comply with board requirements for a regular license and provides evidence that the petitioner will comply with board requirements within the period of the emergency or temporary license. Under exceptional circumstances, an emergency license may be renewed by the board for one additional year. A previously unlicensed person is not eligible for an emergency or temporary license, except that a student who is enrolled in a licensed practitioner preparation program may be issued a temporary, limited-purpose license, without payment of a fee, as part of a practicum or internship program.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72630-b, 2734-e; C24, 27, 31, \'a73878; C35, \'a73872-e3, -e4, -e5, 3878; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3872.03, 3872.04, 3872.05, 3878;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7260.7, 260.8, 260.9, 260.17, 260.18; C75, 77, 79, \'a7260.7, 260.8, 260.9, 260.17; }{{\f5\fs18\hyphpar0\qj{C81, \'a7260.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1126, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1070, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1021, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72603}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 100, \'a74}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.151}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.152}}}{\*\bkmkstart stylerid1_2E11_2E5_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License to applicants from other states or countries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may issue a license to an applicant from another state or country if the applicant files evidence of the possession of the required or equivalent requirements with the board, including any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A full license from another state or country, which shall not include a temporary license or an emergency license. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Verification from an institution located in another state that the applicant has completed all program and licensure requirements with the exception of any assessments required by the state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transcripts indicating the applicant completed an educator preparation program located in another country.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant is the spouse of a military person who is on duty or in active state duty as defined in }}}{{\f5\fs18\hyphpar0\qj{section 29A.1, subsections 10 and 12}}}{{\f5\fs18\hyphpar0\qj{, the board shall assign a consultant to be the single point of contact for the applicant regarding nontraditional licensure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The executive director of the board may, subject to board approval, enter into reciprocity agreements with another state or country for the licensing of practitioners on an equitable basis of mutual exchange, when the action is in conformity with law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Practitioner preparation and professional development programs offered in this state by out-of-state institutions must be approved by the board in order to fulfill requirements for licensure or renewal of a license by an applicant.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 217, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7260.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1169, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 14, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72603}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 97, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.152}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.153}}}{\*\bkmkstart stylerid1_2E11_2E5_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Continuity of certificates and licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate which was issued by the board to a practitioner before July 1, 1989, continues to be in force as long as the certificate complies with the rules and statutes in effect on July 1, 1989. Requirements for the renewal of licenses, under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{, do not apply retroactively to renewal of certificates. However, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not limit the duties or powers of a school board to select or discharge practitioners or to terminate practitioners\u8217\'3f contracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A practitioner who holds a certificate issued before July 1, 1989, shall, upon application and payment of a fee, be granted a license which will permit the practitioner to perform the same duties and functions as the practitioner was entitled to perform with the certificate held at the time of application. A practitioner shall be permitted to convert a permanent certificate to a term certificate, after July 1, 1989, without payment of a fee.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7260.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 59, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71445}}}{; }{{\f5\fs18\hyphpar0\qj{87 Acts, ch 17, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a79}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1008, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72570, 2603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.153}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7294.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.154}}}{\*\bkmkstart stylerid1_2E11_2E5_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administrator licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning July 1, 2007, requirements for administrator licensure beyond an initial license shall include completion of a beginning administrator mentoring and induction program and demonstration of competence on the administrator standards adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 284A.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules for administrator licensure renewal that include credit for individual administrator professional development plans developed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 284A.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An administrator formerly employed by an accredited nonpublic school or formerly employed as an administrator in another state or country is exempt from the mentoring and induction requirement under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ if the administrator can document two years of successful administrator experience and meet or exceed the requirements contained in rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ for endorsement and licensure. However, if an administrator cannot document two years of successful administrator experience when hired by a school district, the administrator shall meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1249, \'a78}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C91, \'a7260.9A}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.9A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 108, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1031, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72571, 2603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.154}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.155}}}{\*\bkmkstart stylerid1_2E11_2E5_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the intent of the general assembly that licensing fees established by the board be sufficient to finance the activities of the board under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensing fees are payable to the treasurer of state and shall be deposited with the executive director of the board. The executive director shall deposit twenty-five percent of the fees collected annually with the treasurer of state and the fees shall be credited to the general fund of the state. The remaining licensing fees collected during the fiscal year shall be retained by and are appropriated to the board for the purposes related to the board\u8217\'3fs duties. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, licensing fees retained by and appropriated to the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ that remain unencumbered or unobligated at the close of the fiscal year shall not revert but shall remain available for expenditure for the activities of the board as provided in }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ until the close of the succeeding fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The executive director shall keep an accurate and detailed account of fees received, including fees paid to the treasurer of state and fees retained by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall submit a detailed annual financial report by January 1 to the general assembly and the legislative services agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fees established by the board for the administrative costs of processing complaints and conducting hearings pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.146, subsection 22}}}{{\f5\fs18\hyphpar0\qj{, may include a fee for personal service by a sheriff, a fee for legal notice when placed in a newspaper, transcription service or court reporter fee, and other fees assessed as costs by the board. The fees collected annually in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be retained by and are appropriated to the board for the purposes related to the board\u8217\'3fs duties. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, fees retained by and appropriated to the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ that remain unencumbered or unobligated at the close of the fiscal year shall not revert but shall remain available for expenditure for the activities of the board as provided in }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ until the close of the succeeding fiscal year.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72634-f1; C24, 27, 31, \'a73867; C35, \'a73872-e6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3872.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7260.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71446}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1180, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1135, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 170, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72572, 2603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.155}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.156}}}{\*\bkmkstart stylerid1_2E11_2E5_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expenditures and refunds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Expenditures and refunds made by the board under }{{\f5\fs18\hyphpar0\qj{this part}}}{ shall be certified by the executive director of the board to the director of the department of administrative services, and if found correct, the director of the department of administrative services shall approve the expenditures and refunds and draw warrants upon the treasurer of state from the funds appropriated for that purpose.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72631; S13, \'a72634-g; C24, 27, 31, \'a73868; C35, \'a73872-e7, -e8; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3872.07, 3872.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, \'a7260.11, 260.12; }{{\f5\fs18\hyphpar0\qj{C81, \'a7260.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71447}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a712}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72573, 2603, 2605}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.156}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment applies to individuals appointed as the executive director of the board of educational examiners before, on, or after July 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 19, \'a72605}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.157}}}{\*\bkmkstart stylerid1_2E11_2E5_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Para-educator certificates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board shall adopt rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ relating to a voluntary certification system for para-educators. The rules shall specify rights, responsibilities, levels, and qualifications for the certificate. Applicants shall be disqualified for any reason specified in }{{\f5\fs18\hyphpar0\qj{section 256.146, subsection 13}}}{, or in administrative rule. The board may issue a para-educator certificate to a person who is at least eighteen years of age. A person holding a para-educator certificate shall not perform the duties of a licensed practitioner. A certificate issued pursuant to }{{\f5\fs18\hyphpar0\qj{this part}}}{ shall not be considered a teacher or administrator license for any purpose specified by law, including the purposes specified under }{{\f5\fs18\hyphpar0\qj{this part}}}{ or }{{\f5\fs18\hyphpar0\qj{chapter 279}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1216, \'a723}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C99, \'a7272.12}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1098, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1223, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1128, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72574, 2603}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 62, \'a72}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.157}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.158}}}{\*\bkmkstart stylerid1_2E11_2E5_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hearing procedures \u8212\'3f confidentiality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hearings before the board shall be conducted in the same manner as contested cases under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. The board may subpoena books, papers, records, and any other real evidence necessary for the board to decide whether it should institute a contested case hearing. At the hearing the board may administer oaths and issue subpoenas to compel the attendance of witnesses and the production of other evidence. Subpoenas may be issued by the board to a party to a hearing, if the party demonstrates that the evidence or witnesses\u8217\'3f testimony is relevant and material to the hearing. Service of process and subpoenas for board hearings shall be conducted in accordance with the law applicable to the service of process and subpoenas in civil actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Witnesses subpoenaed to appear before the board shall be reimbursed for mileage and necessary expenses and shall receive per diem compensation by the board, unless the witness is an employee of the state or a political subdivision, in which case the witness shall receive reimbursement only for mileage and necessary expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, all complaint files, investigation files, other investigation reports, and other investigative information in the possession of the board or its employees or agents, which relate to licensee discipline or the investigation of nonlicensed school employees, are privileged and confidential, and are not subject to discovery, subpoena, or other means of legal compulsion for their release to a person other than the respondent and the board and its employees and agents involved in licensee discipline or the investigation of nonlicensed school employees, and are not admissible in evidence in a judicial or administrative proceeding other than the proceeding involving licensee discipline. A complaint, any amendment to a complaint, and any supporting documents shall be provided to the respondent immediately upon the board\u8217\'3fs determination that jurisdictional requirements have been met and prior to the commencement of the board\u8217\'3fs investigation of a licensee. Investigative information in the possession of the board or its employees or agents which relates to licensee discipline may be disclosed to appropriate licensing authorities within this state, the appropriate licensing authority in another state, the District of Columbia, or a territory or country in which the licensee is licensed or has applied for a license. A final written decision and finding of fact of the board in a disciplinary proceeding is a public record.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if the investigative information in the possession of the board or its employees or agents indicates that a crime has been committed by either a licensee or a nonlicensed school employee, the board shall report the investigative information to the proper law enforcement agency.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 265, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS89, \'a7260.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1199, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1183, \'a728, 43}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.158}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1079, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.160}}}{{\f5\fs12\hyphpar0\qj{, 261H.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.158A}}}{\*\bkmkstart stylerid1_2E11_2E5_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Required annual report to general assembly.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1079, \'a79}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.159}}}{\*\bkmkstart stylerid1_2E11_2E5_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of administrative law judges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board shall maintain a list of qualified persons employed by the division of administrative hearings created by }{{\f5\fs18\hyphpar0\qj{section 10A.801}}}{ and who are experienced in the educational system of this state to serve as administrative law judges when a hearing is requested under }{{\f5\fs18\hyphpar0\qj{section 279.24}}}{. When requested under }{{\f5\fs18\hyphpar0\qj{section 279.24}}}{, the board shall submit a list of five qualified administrative law judges from the list maintained by the board to the parties. The parties shall select one of the five qualified persons to conduct the hearing as provided in }{{\f5\fs18\hyphpar0\qj{section 279.24}}}{. The hearing shall be held pursuant to the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ relating to contested cases. The full costs of the hearing shall be shared equally by the parties.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1249, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C91, \'a7260.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a71718, 2603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.159}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.160}}}{\*\bkmkstart stylerid1_2E11_2E5_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reporting requirements \u8212\'3f complaints.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a school district or area education agency, the superintendent of a school district, the chief administrator of an area education agency, and the authorities in charge of an accredited nonpublic school shall report to the board any instance of disciplinary action taken against a licensed school employee by the board of directors of the school district or area education agency, the superintendent of the school district, the chief administrator of the area education agency, or the authorities in charge of the accredited nonpublic school for conduct constituting any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Soliciting, encouraging, or consummating any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sexual or physical relationship with a student.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Grooming behavior toward a student.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An otherwise inappropriate relationship with a student.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Falsifying student grades, test scores, or other official information or material.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Converting public property or funds to the personal use of the school employee.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Being on school premises or at a school-sponsored activity involving students while under the influence of, possessing, using, or consuming illegal drugs, unauthorized drugs, or alcohol.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Abusing a student.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a school district or area education agency, the superintendent of a school district, the chief administrator of an area education agency, and the authorities in charge of an accredited nonpublic school shall report to the board the nonrenewal or termination, for reasons of alleged or actual misconduct, of a person\u8217\'3fs contract executed under }}}{{\f5\fs18\hyphpar0\qj{sections 279.12}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.13}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.15}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.16}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.18 through 279.21}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{279.23}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{279.24}}}{{\f5\fs18\hyphpar0\qj{, and the resignation of a person who holds a license, certificate, or authorization issued by the board as a result of or following an incident or allegation of misconduct that, if proven, would constitute a violation of the rules adopted by the board to implement }}}{{\f5\fs18\hyphpar0\qj{section 256.146, subsection 13}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1); soliciting, encouraging, or consummating a sexual or physical relationship with a student, grooming behavior toward a student, or an otherwise inappropriate relationship with a student; falsifying student grades, test scores, or other official information or material; converting public property or funds to the personal use of the school employee; being on school premises or at a school-sponsored activity involving students while under the influence of, possessing, using, or consuming illegal drugs, unauthorized drugs, or alcohol; or abusing a student, when the board or reporting official has a good faith belief that the incident occurred or the allegation is true. The board may deny a license or revoke the license of an administrator if the board finds by a preponderance of the evidence that the administrator failed to report the termination or resignation of a school employee holding a license, certificate, statement of professional recognition, or coaching authorization, for reasons of alleged or actual misconduct, as defined by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information reported to the board in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is privileged and confidential, and except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 256.158}}}{{\f5\fs18\hyphpar0\qj{, is not subject to discovery, subpoena, or other means of legal compulsion for its release to a person other than the respondent and the board and its employees and agents involved in licensee discipline, and is not admissible in evidence in a judicial or administrative proceeding other than the proceeding involving licensee discipline. The board shall review the information reported to determine whether a complaint should be initiated. In making that determination, the board shall consider the factors enumerated in }}}{{\f5\fs18\hyphpar0\qj{section 256.146, subsection 13}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, in the course of performing official duties, an employee of the department becomes aware of any alleged misconduct by an individual licensed under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{, the employee shall report the alleged misconduct to the board under rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information required to be reported to the board under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be reported within thirty days of either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date action was taken which necessitated the report, including the date of disciplinary action taken, nonrenewal or termination of a contract for reasons of alleged or actual misconduct, or resignation of a person following an incident or allegation of misconduct as required under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date the employee becomes aware of alleged misconduct as required under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the executive director of the board verifies through a review of official records that a teacher who holds a practitioner\u8217\'3fs license under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ is assigned instructional duties for which the teacher does not hold the appropriate license or endorsement, either by grade level or subject area, by a school district or accredited nonpublic school, the executive director may initiate a complaint against the teacher and the administrator responsible for the inappropriate assignment of instructional duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGrooming behavior\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any behavior, which in light of all relevant circumstances, constitutes actions to entice or entrap a student or students with the intent to make such student or students engage in a sex act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInappropriate relationship\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An unprofessional relationship for an educator to have with a student.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sexual relationship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A relationship in which sexual harassment or any form of physical or sexual abuse occurs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A relationship that is not in compliance with generally accepted educational practices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMisconduct\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an action disqualifying an applicant for a license or causing the license of a person to be revoked or suspended in accordance with the rules adopted by the board to implement }}}{{\f5\fs18\hyphpar0\qj{section 256.146, subsection 13}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1).}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 180, \'a716}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS2003, \'a7272.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 214, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 132, \'a794, 106}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1055, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 6, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 87, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7123}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72575, 2603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.160}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1079, \'a71 \u8211\'3f 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.9}}}{{\f5\fs12\hyphpar0\qj{, 256.146}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.161}}}{\*\bkmkstart stylerid1_2E11_2E5_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Work-based learning program supervisor certificates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ relating to a certification system for work-based learning program supervisors. The rules shall specify rights, responsibilities, levels, and qualifications for the certificate. The certificate shall not require more than fifteen contact hours, which shall be available over the internet and which shall provide instruction related to fundamentals in career education, curriculum, assessment, and the evaluation of student participation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Applicants shall be disqualified for any reason specified in }}}{{\f5\fs18\hyphpar0\qj{section 256.146, subsection 13}}}{{\f5\fs18\hyphpar0\qj{, or in rules adopted by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered a teacher or administrator license for any purpose specified by law, including the purposes specified under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 279}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The work-based learning program supervisor certificate established pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be considered a professional development program.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1134, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2023, \'a7272.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72576, 2603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.161}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.145}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.162}}}{\*\bkmkstart stylerid1_2E11_2E5_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{National certification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board shall review the standards for teacher\u8217\'3fs certificates adopted by the national board for professional teaching standards, a nonprofit corporation created as a result of recommendations of the task force on teaching as a profession of the Carnegie forum on education and the economy. In those cases in which the standards required by the national board for an Iowa endorsement or license meet or exceed the requirements contained in rules adopted under }{{\f5\fs18\hyphpar0\qj{this part}}}{ for that endorsement or license, the board shall issue endorsements or licenses to holders of certificates issued by the national board who request the endorsement or license.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 51, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS91, \'a7260.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72577, 2603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.162}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.163}}}{\*\bkmkstart stylerid1_2E11_2E5_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licensure beyond temporary initial license or initial license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requirements for teacher licensure beyond a temporary initial license or an initial license shall include successful completion of a beginning teacher mentoring and induction program approved by the state board of education pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 284.5}}}{{\f5\fs18\hyphpar0\qj{; or two years of successful teaching experience in a school district with an approved career paths, leadership roles, and compensation framework or approved comparable system as provided in }}}{{\f5\fs18\hyphpar0\qj{section 284.15}}}{{\f5\fs18\hyphpar0\qj{; or evidence of not less than three years of successful teaching experience at any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accredited nonpublic school in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A preschool program approved by the United States department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Preschool programs at school districts approved to participate in the preschool program under }}}{{\f5\fs18\hyphpar0\qj{chapter 256C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Shared visions programs receiving grants from the child development coordinating council under }}}{{\f5\fs18\hyphpar0\qj{section 256A.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Preschool programs receiving moneys from the school ready children grants account of the early childhood Iowa fund created in }}}{{\f5\fs18\hyphpar0\qj{section 256I.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A teacher from an accredited nonpublic school or another state or country is exempt from the requirement of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ if the teacher can document three years of successful teaching experience and meet or exceed the requirements contained in rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ for endorsement and licensure.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 161, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS2001, \'a7272.28}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 180, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1132, \'a711, 19}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 172, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72578, 2603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.163}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1171, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.164}}}{\*\bkmkstart stylerid1_2E11_2E5_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual administrative rules review }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ triennial report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The executive director of the board shall annually review the administrative rules adopted pursuant to }{{\f5\fs18\hyphpar0\qj{this part}}}{ and related state laws. The executive director shall submit the executive director\u8217\'3fs findings and recommendations in a report every three years to the board and the general assembly by January 15.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 169, \'a728}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS2005, \'a7272.29}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1152, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1135, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72579, 2603, 2605}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.164}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment applies to individuals appointed as the executive director of the board of educational examiners before, on, or after July 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 19, \'a72605}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.165}}}{\*\bkmkstart stylerid1_2E11_2E5_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authorizations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ coaching, school business officials, school administration managers, substitute teachers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the minimum requirements for the board to issue a coaching authorization to an applicant are:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Successful completion of one semester credit hour or ten contact hours in a course relating to knowledge and understanding of the structure and function of the human body in relation to physical activity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Successful completion of one semester credit hour or ten contact hours in a course relating to knowledge and understanding of human growth and development of children and youth in relation to physical activity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Successful completion of two semester credit hours or twenty contact hours in a course relating to knowledge and understanding of the prevention and care of athletic injuries and medical and safety problems relating to physical activity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Successful completion of one semester credit hour or ten contact hours relating to knowledge and understanding of the techniques and theory of coaching interscholastic athletics.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Attainment of at least eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall issue a transitional coaching authorization to an individual who is at least twenty-one years of age and who provides verification of an offer of a coaching position by a school or a consortium of schools, but who has not completed the coursework required for a coaching authorization as specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. A transitional coaching authorization is valid for not more than one year, shall not be renewed, and is valid only in the school or consortium of schools making the offer of the coaching position. A consortium of schools may include a school district, a school district school attendance center, or an accredited nonpublic school, or any combination thereof. However, prior to issuing a transitional coaching authorization to an individual under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the board shall ensure that the individual meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Completes a shortened course of training relating to the code of professional rights and responsibilities, practices, and ethics developed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 256.146, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, by the board specifically for transitional coaches.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Completes the child and dependent adult abuse mandatory reporter training required by }}}{{\f5\fs18\hyphpar0\qj{sections 232.69}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{235B.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Completes a nationally recognized concussion in youth sports training course.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Complies with the background investigation requirements established by the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.146, subsection 16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall issue a school business official authorization to an individual who successfully completes a training program that meets the standards set by the state board of education pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.7, subsection 30}}}{{\f5\fs18\hyphpar0\qj{, and who complies with rules adopted by the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person hired on or after July 1, 2012, as a school business official responsible for the financial operations of a school district who is without prior experience as a school business official in Iowa shall either hold the school business official authorization issued pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or obtain the authorization within two years of the start date of employment as a school business official.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual employed as a school business official prior to July 1, 2012, who meets the requirements of the board, other than the training program requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be issued, with no fee for issuance, an initial authorization by the board, but shall meet renewal requirements for an authorization within the time period specified by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall issue a school administration manager authorization to an individual who successfully completes a training program that meets the standards set by the state board pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.7, subsection 30}}}{{\f5\fs18\hyphpar0\qj{, and who complies with rules adopted by the state board pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall issue a substitute authorization that allows an individual to substitute in grades prekindergarten through twelve for no more than ten consecutive days in a thirty-day period in one job assignment for a regularly assigned teacher who is absent, except in the driver education classroom. A school district administrator may file a written request with the board for an extension of the ten-day limit in one job assignment in a thirty-day period on the basis of documented need and benefit to the instructional program. The executive director of the board or the executive director\u8217\'3fs designee shall review the request and provide a written decision either approving or denying the request. A substitute teacher authorization shall require not less than the successful completion of an associate degree or not less than sixty undergraduate semester hours, or the equivalent, from a college or university accredited by an institutional accrediting agency recognized by the United States department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ for authorizations, including but not limited to approval of courses, validity and expiration, fees, and suspension and revocation of authorizations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board of education shall work with institutions of higher education, private colleges and universities, community colleges, area education agencies, and professional organizations to ensure that the courses and programs required for authorizations under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are offered throughout the state at convenient times and at a reasonable cost.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1296, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C85, \'a7260.31}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71452}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1249, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7272.31}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 32, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1099, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1183, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1119, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1066, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 109, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72603}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.165}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.69}}}{{\f5\fs12\hyphpar0\qj{, 279.19B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.166}}}{\*\bkmkstart stylerid1_2E11_2E5_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Temporary initial license for applicants who complete an alternative teacher certification program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall grant a temporary initial teaching license to an applicant who meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant shall hold a bachelor\u8217\'3fs degree from an accredited college or university.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant shall have at least sixty contact hours in the classroom, of which at least thirty hours shall be teaching in a classroom under a licensed teacher. The applicant may complete any remaining contact hours by working as a para-educator or in another relevant role. The principal of the school where the applicant completed the contact hours shall certify to the board the applicant\u8217\'3fs completion of the requirements in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant shall successfully complete an alternative teacher certification program that has been approved by the state board of education pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ and that includes the required content training in the area in which the applicant seeks to be licensed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall recommend to the state board of education that an alternative teacher certification program be approved or denied within sixty days after the alternative teacher certification program applies to the department for approval and provides to the department sufficient evidence that the alternative teacher certification program meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alternative teacher certification program must operate in at least five states.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alternative teacher certification program must have been in operation for at least ten years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alternative teacher certification program must incorporate pedagogy training, including an examination, that teaches effective instructional delivery, classroom management and organization, assessment, instructional design, and professional learning and leadership.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alternative teacher certification program must include the administration of an assessment that is identical to the foundations of reading assessment administered in 2012 as part of the Massachusetts tests, or the most current version of such assessment, and must adhere to the same reporting requirements related to the assessment that }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ imposes upon higher education institutions, if any.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the state board of education approves an alternative teacher certification program, the approval shall be for seven years, or less if the state board of education determines that a shorter term is warranted.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the state board of education approves an alternative teacher certification program, the approved alternative teacher certification program shall submit an annual report to the department, on or before March 15 each year, that contains all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of students participating in the approved alternative teacher certification program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of students who completed the approved alternative teacher certification program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information related to student retention.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Data that allows the department to match records associated with licensing and employment within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information requested by the department that will allow the department to monitor and assess the quality of the approved alternative teacher certification program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the state board of education denies an alternative teacher certification program, the state board of education shall provide the alternative teacher certification program with advice concerning the areas in which the alternative teacher certification program needs to improve, or changes the alternative teacher certification program otherwise needs to make, in order for the state board of education to approve the alternative teacher certification program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board of education shall allow an alternative teacher certification program that has been denied approval to present factual information concerning the alternative teacher certification program at a regularly scheduled meeting of the state board of education within three months after such denial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An alternative teacher certification program that has been denied approval shall not apply to the department for approval pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ within six months after such denial.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an alternative teacher certification program does apply to the department for approval after a denial, the alternative teacher certification program shall provide to the department, in addition to the information described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) through (4), sufficient evidence that the alternative teacher certification program has taken actions to address any areas that needed to be improved or changes the alternative teacher certification program otherwise needed to make.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who successfully completes an approved alternative teacher certification program and who is granted a temporary initial teaching license by the board under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is authorized to teach the subjects and grade levels that the individual successfully completed during the alternative teacher certification program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who successfully completes an approved alternative teacher certification program and who is granted a temporary initial teaching license by the board under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not provide instruction to students who are eligible for services under }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ until the individual successfully completes a practicum relating to providing instruction to such students that includes short-term field experiences in educational settings that are connected to specific coursework.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall treat an individual who successfully completes an approved alternative teacher certification program and who is granted a temporary initial teaching license by the board under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in the same manner as an individual who completes a traditional teacher preparation program and who receives an initial teaching license, including during the process of converting the temporary initial teaching license to a standard teaching license.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1171, \'a74}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{256.167 through 256.175}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{PART 4}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_2E6_2E2_2E2}{COLLEGE STUDENT AID COMMISSION}{\*\bkmkend stylerid1_2E11_2E6_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7256.121}}}{{\f5\fs12\qc{, 261B.11A}}}{{\f5\fs12\qc{, 261F.1}}}{{\f5\fs12\qc{, 261G.4}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Iowa higher education loan authority is attached to the commission; }{{\f5\fs12\qc{\'a7261A.5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Continuity of scholarships, loans, or grants awarded by college student aid commission under former }{{\f5\fs12\qc{chapter 261}}}{ prior to July 1, 2023; use of federal funds to employ personnel necessary for program administration; }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\cf5{{\f5\fs12\qc\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH19.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 19, \'a72642}}}}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri1445\li1445\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBPART A}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E2_2E2}{COLLEGE STUDENT AID COMMISSION \u8212\'3f GENERAL PROVISIONS}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.176}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commission created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is hereby created within the higher education division of the department a commission to be known as the }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCollege Student Aid Commission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of the state of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Membership of the commission shall be as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the state board of regents to be named by the state board of regents, or the executive director of the state board of regents if so appointed by the state board of regents, who shall serve for a four-year term or until the expiration of the member\u8217\'3fs term of office, and who shall serve as an ex officio, nonvoting member. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department or the director\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two members of the senate, one to be appointed by the president of the senate and one to be appointed by the minority leader of the senate, to serve as ex officio, nonvoting members.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two members of the house of representatives, one to be appointed by the speaker of the house of representatives and one to be appointed by the minority leader of the house of representatives, to serve as ex officio, nonvoting members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the senate and house of representatives shall serve at the pleasure of the appointing legislator for a term beginning upon the convening of the general assembly and expiring upon the convening of the following general assembly, or when the appointee\u8217\'3fs successor is appointed, whichever occurs later.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seven additional members to be appointed by the governor as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At least one member shall be enrolled as a student at an institution of higher learning governed by the board of regents, a community college, or an accredited private institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At least one member shall be a parent of a student enrolled at an institution of higher learning governed by the board of regents, a community college, or an accredited private institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At least one member shall have knowledge and experience in financial or fiduciary matters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member to represent private colleges and universities located in the state of Iowa, who shall be selected by an organization or association of some or all private colleges and universities located in the state of Iowa, and who shall serve as an ex officio, nonvoting member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member to represent Iowa\u8217\'3fs community colleges, who shall be selected by an organization or association of Iowa community colleges, and who shall serve as an ex officio, nonvoting member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the commission appointed by the governor shall serve for a term of four years. The voting members of the commission shall elect a chairperson and vice chairperson. Meetings may be called by the chairperson or a majority of the voting members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vacancies on the commission shall be filled for the unexpired term of such vacancies, if applicable, in the same manner as the original appointment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy shall exist on the commission when a legislative member of the commission ceases to be a member of the general assembly, when a parent member no longer has a child enrolled in postsecondary education, or when a student member ceases to be enrolled as a student. Such vacancy shall be filled within thirty days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall appoint an executive director of the commission. The director shall set the salary of the executive director.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 67, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 212, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a72032}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 83, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 300, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1223, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a7121, 122}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 61, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1095, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1051, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1107, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a7134}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a791}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 172, \'a711 \u8211\'3f 13}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72557, 2608 \u8211\'3f 2611, 2641, 2643}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.176}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1170, \'a7290, 291}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.182}}}{{\f5\fs12\hyphpar0\qj{, 261B.2}}}{{\f5\fs12\hyphpar0\qj{, 261G.2}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendments to subsections 1, 2, and 4 apply to individuals appointed as the executive director of the college student aid commission before, on, or after July 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 19, \'a72643}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5 applies to individuals appointed as the executive director of the college student aid commission before, on, or after July 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 19, \'a72643}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.177}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commission shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare and administer a state plan for a state supported and administered scholarship program. The state plan shall provide for scholarships to deserving students of Iowa, matriculating in Iowa universities, colleges, community colleges, or schools of professional nursing. Eligibility of a student for receipt of a scholarship shall be based upon academic achievement and completion of advanced level courses prescribed by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer the tuition grant program under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop and implement, in cooperation with the state board of regents, an educational program and marketing strategies designed to inform parents about the options available for financing a college education and the need to accumulate the financial resources necessary to pay for a college education. The educational program shall include but not be limited to distribution of informational material to public and nonpublic elementary schools for distribution to parents and guardians of five-year and six-year old children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop and implement, in cooperation with the judicial district departments of correctional services and the department of corrections, a program to assist criminal offenders in applying for federal and state aid available for higher education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop and implement, in cooperation with the department of health and human services and the judicial branch, a program to assist juveniles who are sixteen years of age or older and who have a case permanency plan under }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{237}}}{{\f5\fs18\hyphpar0\qj{ or are otherwise under the jurisdiction of }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ in applying for federal and state aid available for higher education. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules to establish reasonable registration standards for the approval, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 261B.3A}}}{{\f5\fs18\hyphpar0\qj{, of postsecondary schools that are required to register with the commission in order to operate in this state. The registration standards established by the commission shall ensure that all of the following conditions are satisfied:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The courses, curriculum, and instruction offered by the postsecondary school are of such quality and content as may reasonably and adequately ensure achievement of the stated objective for which the courses, curriculum, or instruction are offered.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The postsecondary school has adequate space, equipment, instructional material, and personnel to provide education and training of good quality.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The educational and experience qualifications of the postsecondary school\u8217\'3fs directors, administrators, and instructors are such as may reasonably ensure that students will receive instruction consistent with the objectives of the postsecondary school\u8217\'3fs programs of study.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon completion of training or instruction, students are given certificates, diplomas, or degrees as appropriate by the postsecondary school indicating satisfactory completion of the program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The postsecondary school is financially responsible and capable of fulfilling commitments for instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall post an application on the commission\u8217\'3fs internet site and shall render a decision on an application for registration within one hundred eighty days of the filing of the application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit by January 15 annually a report to the general assembly which provides, by program, the number of individuals who received state financial aid funding in the previous fiscal year, the amounts paid to or on behalf of the individuals, other key program indicators, findings, and recommendations. The report shall also include a description of the methodology and manner in which the commission makes the determination of awards for programs for which moneys are appropriated under }}}{{\f5\fs18\hyphpar0\qj{section 256.194}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require any postsecondary institution whose students are eligible for or who receive assistance under programs administered by the commission and who were enrolled in a school district in Iowa to include in its student management information system the unique student identifiers assigned to the institution\u8217\'3fs students while the students were in the state\u8217\'3fs kindergarten through grade twelve system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ensure that students receiving state-funded scholarships and grants are attending institutions of higher education that meet all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The institutions are not required to register under }}}{{\f5\fs18\hyphpar0\qj{chapter 261B}}}{{\f5\fs18\hyphpar0\qj{ or the institutions are participating resident institutions as defined in }}}{{\f5\fs18\hyphpar0\qj{section 261G.2}}}{{\f5\fs18\hyphpar0\qj{ that volunteer to register under }}}{{\f5\fs18\hyphpar0\qj{section 261B.11B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The institutions are eligible to participate in a federal student aid program authorized under }}}{{\f5\fs18\hyphpar0\qj{Tit. IV of the federal Higher Education Act of 1965}}}{{\f5\fs18\hyphpar0\qj{,}}}{{\f5\fs18\hyphpar0\qj{ Pub. L. No. 89-329, as amended}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require any postsecondary institution whose students are eligible for or who receive financial assistance under programs administered by the commission to transmit annually to the commission information about the numbers of minority students enrolled in and minority faculty members employed at the institution. The commission shall compile and report the information collected to the general assembly, the governor, and the legislative services agency by March 1 annually.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter into and administer, or recognize, an interstate reciprocity agreement for the provision of postsecondary distance education by a postsecondary institution pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 261G}}}{{\f5\fs18\hyphpar0\qj{. The commission shall adopt rules establishing application procedures and criteria for the authorization of postsecondary institutions providing postsecondary distance education under interstate reciprocity agreements pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 261G}}}{{\f5\fs18\hyphpar0\qj{ and for the review and approval of interstate reciprocity agreements the commission may enter into or recognize pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 261G}}}{{\f5\fs18\hyphpar0\qj{. The commission may accept an authorization granted by another state to a postsecondary institution under an interstate reciprocity agreement to deliver postsecondary distance education.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 184, \'a75, 11, 15}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1003, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1261, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1284, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 300, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1272, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1231, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1240, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 179, \'a720}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{95 Acts, ch 70, \'a71}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1047, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1095, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1145, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 59, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 214, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1181, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 12, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 118, \'a748, 54}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 177, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7314}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1147, \'a78, 13}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 36, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1063, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 172, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71014, 2612, 2641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.177}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1057, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 157, \'a718}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.2}}}{{\f5\fs12\hyphpar0\qj{, 261G.2}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4 stricken and former subsections 5 \u8211\'3f 12 renumbered as 4 \u8211\'3f 11}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.178}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Organization }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission, under the authority of the higher education division of the department, shall draw up its own bylaws, adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, and do such other things as may be necessary and incidental in the administration of }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{, including the housing and fixing the bond of persons required to carry out its functions and responsibilities. A decision of the commission is final agency action under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall function at the seat of government or such other place as the commission might designate.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71454}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72613, 2641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.178}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.179}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funds \u8212\'3f compensation and expenses of commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director of the department of administrative services shall keep an accounting of all funds received and expended by the commission. The members of the commission, except those members who are employees of the state, shall be paid a per diem as specified in }{{\f5\fs18\hyphpar0\qj{section 7E.6}}}{ and shall be reimbursed for actual and necessary expenses. All per diem and expense moneys paid to nonlegislative members shall be paid from funds appropriated to the commission. Legislative members of the commission shall receive payment pursuant to }{{\f5\fs18\hyphpar0\qj{section 2.10}}}{ and }{{\f5\fs18\hyphpar0\qj{section 2.12}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1256, \'a744}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.179}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.180}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Response to national emergency \u8212\'3f waiver authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fActive duty\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3factive duty\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as defined in 10 U.S.C. \'a7101(d)(1), except that the term does not include active duty for training or attendance at a service school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAffected individual\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who is serving on active duty during the national emergency; or who resides or is employed in an area that is declared a disaster area by any federal, state, or local official in connection with the national emergency; or who suffered direct economic hardship as a result of the national emergency, as determined under a waiver or modification issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fServing on active duty during the national emergency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following individuals:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A reserve of an armed force ordered to active duty under 10 U.S.C. \'a712301(a), 12301(g), 12302, 12304, or 12306, or any retired member of an armed force ordered to active duty under 10 U.S.C. \'a7688, as amended, for service in connection with the emergency or subsequent actions or conditions, regardless of the location at which the active duty service is performed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other member of an armed force on active duty in connection with the emergency or subsequent actions or conditions who has been assigned to a duty station at a location other than the location at which the member is normally assigned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{, in the event of a national emergency declared by the president of the United States by reason of terrorist attack, the commission may waive or modify any statutory or regulatory provision applicable to state financial aid programs established pursuant to }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{ to ensure, with regard to affected individuals, that the following occurs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financial positions of affected individuals who are state student loan borrowers are not worsened in relation to those loans because of their status as affected individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administrative requirements placed on state student loan borrowers are minimized, to the extent possible, without impairing the integrity of the student loan programs, to ease the burden on these borrowers and to avoid inadvertent technical violations or defaults.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The calculation of \u8220\'3fannual adjusted family income\u8221\'3f and \u8220\'3favailable income\u8221\'3f, as used in the determination of need for student financial assistance under 20 U.S.C. \'a71070 et seq., for affected individuals, or if applicable, for the spouses or dependents of affected individuals, may be modified to mean the sums received in the first calendar year of the award year for which the determination is made, in order to reflect more accurately the financial condition of the affected individuals or their families.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{, in the event of a national emergency declared by the president of the United States by reason of terrorist attack, the commission may grant temporary relief from requirements rendered infeasible or unreasonable, including due diligence requirements and reporting deadlines, by the national emergency, to an institution of higher education under the state board of regents, a community college, an accredited private institution as defined in }}}{{\f5\fs18\hyphpar0\qj{section 256.183}}}{{\f5\fs18\hyphpar0\qj{, eligible lenders, and other entities participating in the state student assistance programs in accordance with }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{, that are located in, or whose operations are directly affected by, areas that are declared disaster areas by any federal, state, or local official in connection with the national emergency. If the commission issues a waiver in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the report prepared by the commission pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.9A, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, shall include examples of measures that a postsecondary institution may take in the appropriate exercise of discretion, as provided in }}}{{\f5\fs18\hyphpar0\qj{20 U.S.C. \'a71087tt}}}{{\f5\fs18\hyphpar0\qj{, to adjust financial need and aid eligibility determinations for affected individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed as a requirement that the commission exercise the waiver or modification authority provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on a case-by-case basis.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1036, \'a71, 2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2003, \'a7261.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72614, 2615, 2641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.180}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.181}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Textbook notice \u8212\'3f legislative intent and recommendation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to promote consumer choice and lower the costs of textbooks in higher education, the general assembly intends that students enrolled in institutions of higher learning have access to appropriate textbook information prior to the start of classes, with adequate time to pursue alternative purchase avenues.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly recommends that every public and private institution of higher education in this state, including those institutions referenced in }}}{{\f5\fs18\hyphpar0\qj{chapters 260C}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{262}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 256.183}}}{{\f5\fs18\hyphpar0\qj{, post the list of required and suggested textbooks for all courses and the corresponding international standard book numbers for such textbooks at least fourteen days before the start of each semester or term, to the extent possible, at the locations where textbooks are sold on campus and on the internet site for the respective institution of higher education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The college student aid commission is directed to convey the legislative intent and recommendation contained in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to every institution of higher education in the state registered pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 261B}}}{{\f5\fs18\hyphpar0\qj{ at least once a year.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1146, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2009, \'a7261.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1191, \'a7125}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7257}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.181}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.182}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Corporation for educational financial assistance, services, and research.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E9_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E9_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Nonprofit corporation for receiving and disbursing funds.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may organize a nonprofit corporation under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 504}}}{{\f5\fs18\hyphpar0\qj{ that qualifies under }}}{{\f5\fs18\hyphpar0\qj{section 501(c)(3) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ as an organization exempt from taxation for the purpose of receiving and disbursing moneys from public or private sources to be used to provide Iowans with educational financial assistance, services to increase access to and success in postsecondary education, and research. Unless otherwise provided in this section, the corporation is subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 504}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Incorporators.}}}{{\f5\fs18\hyphpar0\qj{ The incorporators of the corporation organized pursuant to this section shall be the chairperson of the commission, the executive director of the commission, and a member of the commission selected by a majority vote of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E9_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E9_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Board of directors.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of the corporation organized pursuant to this section shall be the members of the commission appointed under }}}{{\f5\fs18\hyphpar0\qj{section 256.176, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or their successors in office, and may include up to two additional members who shall be appointed by the commission and who shall have experience or legal and technical expertise relating to nonprofit organizations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E9_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E9_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Accepting grants in aid.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation organized pursuant to this section may accept grants of money or property from the federal government or private sources and may upon its own order use its money, property, or other resources for the purposes set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E9_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E9_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Open meetings and open records.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation is subject to }}}{{\f5\fs18\hyphpar0\qj{chapters 21}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{22}}}{{\f5\fs18\hyphpar0\qj{ as if the corporation were a governmental body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Status.}}}{{\f5\fs18\hyphpar0\qj{ The corporation shall collaborate with the commission for the purposes specified in this section, but the corporation shall not be considered, in whole or in part, an agency, department, or administrative unit of the state. The corporation shall not receive appropriations from the general assembly. Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, the corporation shall not be required to comply with any requirements that apply to a state agency, department, or administrative unit and shall not exercise any sovereign power of the state. The commission shall enter into an agreement under }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ with the corporation to stipulate the powers and responsibilities of the corporation and the commission for purposes of this section. The corporation may enter into agreements with other entities as necessary to fulfill the provisions of this section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E9_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E9_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{No state liability.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation does not have authority to pledge the credit of the state, and the state shall not be liable for the debts or obligations of the corporation. All debts and obligations of the corporation shall be payable solely from the corporation\u8217\'3fs funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Tax deductible.}}}{{\f5\fs18\hyphpar0\qj{ The corporation shall be established so that donations and bequests to the corporation qualify as tax deductible under state income tax laws and under }}}{{\f5\fs18\hyphpar0\qj{section 501(c)(3) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E9_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E9_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Staffing and administrative support.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall provide staff assistance and administrative support to the corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E9_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E9_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Report.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation shall submit by January 15 annually a written report of its activities and operations to the governor, the general assembly, and the commission.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 24, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2022, \'a7261.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.182}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBPART B}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E2_2E2}{TUITION GRANTS TO STUDENTS}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.183}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When used in }{{\f5\fs18\hyphpar0\qj{this subpart}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAccredited private institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an institution of higher learning located in Iowa which is operated privately and not controlled or administered by any state agency or any subdivision of the state and which meets the criteria in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and all of the criteria in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, except that institutions defined in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are exempt from the requirements of paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is accredited by any federally recognized accreditor of postsecondary educational institutions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is accredited by any federally recognized accreditor of postsecondary educational institutions, is exempt from taxation under }}}{{\f5\fs18\hyphpar0\qj{section 501(c)(3) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, and annually provides a matching aggregate amount of institutional financial aid equal to at least seventy-five percent of the amount received in a fiscal year by the institution\u8217\'3fs students for Iowa tuition grant assistance under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{. Commencing with the fiscal year beginning July 1, 2006, the matching aggregate amount of institutional financial aid shall increase by the percentage of increase each fiscal year of funds appropriated for Iowa tuition grants under }}}{{\f5\fs18\hyphpar0\qj{section 256.194, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, to a maximum match of one hundred percent. The institution shall file annual reports with the commission prior to receipt of tuition grant moneys under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{. An institution whose income is not exempt from taxation under }}}{{\f5\fs18\hyphpar0\qj{section 501(c) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and whose students were eligible to receive Iowa tuition grant money in the fiscal year beginning July 1, 2003, shall meet the match requirements of this paragraph no later than June 30, 2005.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a specialized college that is accredited by any federally recognized accreditor of postsecondary educational institutions, and which offers health professional programs that are affiliated with health care systems located in Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promotes equal opportunity and affirmative action efforts in the recruitment, appointment, assignment, and advancement of personnel at the institution and provides information regarding such efforts to the commission upon request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopts a policy that prohibits unlawful possession, use, or distribution of controlled substances by students and employees on property owned or leased by the institution or in conjunction with activities sponsored by the institution. Each institution shall provide information about the policy to all students and employees. The policy shall include a clear statement of sanctions for violation of the policy and information about available drug or alcohol counseling and rehabilitation programs. In carrying out this policy, an institution shall provide substance use disorder prevention programs for students and employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develops and implements a written policy, which is disseminated during student registration or orientation, addressing the following four areas relating to sexual abuse:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Counseling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Campus security.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Education, including prevention, protection, and the rights and duties of students and employees of the institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facilitating the accurate and prompt reporting of sexual abuse to the duly constituted law enforcement authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopts a policy to offer not less than the following options to a student who is a member, or the spouse of a member if the member has a dependent child, of the Iowa national guard or reserve forces of the United States and who is ordered to national guard duty or federal active duty:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Withdraw from the student\u8217\'3fs entire registration and receive a full refund of tuition and mandatory fees.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make arrangements with the student\u8217\'3fs instructors for course grades, or for incompletes that shall be completed by the student at a later date. If such arrangements are made, the student\u8217\'3fs registration shall remain intact and tuition and mandatory fees shall be assessed for the courses in full.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make arrangements with only some of the student\u8217\'3fs instructors for grades, or for incompletes that shall be completed by the student at a later date. If such arrangements are made, the registration for those courses shall remain intact and tuition and mandatory fees shall be assessed for those courses. Any course for which arrangements cannot be made for grades or incompletes shall be considered dropped and the tuition and mandatory fees for the course refunded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this lettered paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdependent child\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 260C.14, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), subparagraph division (a).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develops and implements a consistent written policy for an employee who in the scope of the person\u8217\'3fs employment responsibilities examines, attends, counsels, or treats a child to report suspected physical or sexual abuse. The policy shall include an employee\u8217\'3fs reporting responsibilities. The reporting responsibilities shall designate the time, circumstances, and method for reporting suspected child abuse to the accredited private institution\u8217\'3fs administration and reporting to law enforcement. Nothing in the policy shall prohibit an employee from reporting suspected child abuse in good faith to law enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopts a policy to require that the institution shall annually, beginning December 15, 2015, file a report with the governor and the general assembly providing information and statistics for the previous five academic years on the number of students per year who are veterans who received education credit for military education, training, and service, that number as a percentage of veterans known to be enrolled at the institution, the average number of credits received by students, and the average number of credits applied towards the award or completion of a course of instruction, postsecondary diploma, degree, or other evidences of distinction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fveteran\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a veteran as defined in }}}{{\f5\fs18\hyphpar0\qj{section 35.1}}}{{\f5\fs18\hyphpar0\qj{ or a member of the reserve forces of the United States or the national guard as defined in }}}{{\f5\fs18\hyphpar0\qj{section 29A.1}}}{{\f5\fs18\hyphpar0\qj{ who has served at least one year of the member\u8217\'3fs commitment and is eligible for or has exhausted federal veterans education benefits under }}}{{\f5\fs18\hyphpar0\qj{38 U.S.C. ch. 30, 32, 33, or 36}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{10 U.S.C. ch. 1606 or 1607}}}{{\f5\fs18\hyphpar0\qj{, respectively.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annually, beginning December 15, 2025, files a report with the commission, the department of workforce development, and the general assembly that provides all of the following information and statistics for the previous academic year:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of students who are enrolled in the institution and who receive a tuition grant under }}}{{\f5\fs18\hyphpar0\qj{this subpart}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The academic majors or courses of study in which the students described in subparagraph division (a) are participating.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An estimate of the amount of students who were enrolled in the institution in the previous academic year, received a tuition grant under }}}{{\f5\fs18\hyphpar0\qj{this subpart}}}{{\f5\fs18\hyphpar0\qj{, and who entered a high-demand job, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 84A.1B, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, after graduating from the institution.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An estimate of the amount of students who were enrolled in the institution in the previous academic year, received a tuition grant under }}}{{\f5\fs18\hyphpar0\qj{this subpart}}}{{\f5\fs18\hyphpar0\qj{, and who remained a resident of this state after graduating from the institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an institution fails to timely file the report described in subparagraph (1), students enrolled in the institution shall not be eligible to receive tuition grants under }}}{{\f5\fs18\hyphpar0\qj{this subpart}}}{{\f5\fs18\hyphpar0\qj{ for the subsequent academic year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall review the report filed pursuant to subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopts a policy that requires the institution to include in any communication to students that is related to immunization requirements information regarding exemptions to such requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the college student aid commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an institution of higher learning located in Iowa which is operated privately and not controlled or administered by any state agency or any subdivision of the state, which is not exempt from taxation under }}}{{\f5\fs18\hyphpar0\qj{section 501(c)(3) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, and which meets all of the criteria in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and is a school of barbering and cosmetology arts and sciences licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 157}}}{{\f5\fs18\hyphpar0\qj{ and is accredited by a national accrediting agency recognized by the United States department of education. For the fiscal year beginning July 1, 2017, such a school of barbering and cosmetology arts and sciences shall provide a matching aggregate amount of institutional financial aid equal to at least seventy-five percent of the amount received by the institution\u8217\'3fs students for Iowa tuition grant assistance under }}}{{\f5\fs18\hyphpar0\qj{section 256.191}}}{{\f5\fs18\hyphpar0\qj{. For the fiscal year beginning July 1, 2018, the school of barbering and cosmetology arts and sciences shall provide a matching aggregate amount of institutional financial aid equal to at least eighty-five percent of the amount received in that fiscal year. Commencing with the fiscal year beginning July 1, 2019, and each succeeding fiscal year, the matching aggregate amount of institutional financial aid shall be at least equal to the match provided by eligible institutions under }}}{{\f5\fs18\hyphpar0\qj{section 261.9, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, Code 2023.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinancial need\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the difference between the student\u8217\'3fs financial resources available, including those available from the student\u8217\'3fs parents as determined by a completed parents\u8217\'3f confidential statement, and the student\u8217\'3fs anticipated expenses while attending the accredited private institution. Financial need shall be redetermined at least annually.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFull-time resident student\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual resident of Iowa who is enrolled at an accredited private institution in a course of study including at least twelve semester hours or the trimester equivalent of twelve semester hours. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCourse of study\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include correspondence courses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPart-time resident student\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual resident of Iowa who is enrolled at an accredited private institution in a course of study including at least three semester hours or the trimester or quarter equivalent of three semester hours. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCourse of study\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include correspondence courses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fQualified student\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a resident student who has established financial need and who is making satisfactory progress toward graduation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTuition grant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an award by the state of Iowa to a qualified student under }}}{{\f5\fs18\hyphpar0\qj{this subpart}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 233, \'a7455}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1284, \'a722 \u8211\'3f 24}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 319, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1272, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 180, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1106, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1095, \'a74 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 39, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7113, 114}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1086, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7237, 238}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 169, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1169, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 36, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1040, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1072, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1013, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1061, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1116, \'a731, 32}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 8, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 170, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 172, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71015, 2616 \u8211\'3f 2618, 2641}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 79, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 99, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 119, \'a746}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.183}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1152, \'a739 \u8211\'3f 41}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 62, \'a74, 9}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 106, \'a74 \u8211\'3f 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.1B}}}{{\f5\fs12\hyphpar0\qj{, 139A.8B}}}{{\f5\fs12\hyphpar0\qj{, 256.7}}}{{\f5\fs12\hyphpar0\qj{, 256.28}}}{{\f5\fs12\hyphpar0\qj{, 256.180}}}{{\f5\fs12\hyphpar0\qj{, 256.181}}}{{\f5\fs12\hyphpar0\qj{, 256.191}}}{{\f5\fs12\hyphpar0\qj{, 256.203}}}{{\f5\fs12\hyphpar0\qj{, 256.207}}}{{\f5\fs12\hyphpar0\qj{, 256.210}}}{{\f5\fs12\hyphpar0\qj{, 256.210A}}}{{\f5\fs12\hyphpar0\qj{, 256.214}}}{{\f5\fs12\hyphpar0\qj{, 256.219}}}{{\f5\fs12\hyphpar0\qj{, 256.228}}}{{\f5\fs12\hyphpar0\qj{, 256.229}}}{{\f5\fs12\hyphpar0\qj{, 261B.11}}}{{\f5\fs12\hyphpar0\qj{, 261E.2}}}{{\f5\fs12\hyphpar0\qj{, 261G.2}}}{{\f5\fs12\hyphpar0\qj{, 297.24}}}{{\f5\fs12\hyphpar0\qj{, 714.19}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, unnumbered paragraph 1 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraphs a, b, and c amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, NEW paragraph k}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.184}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Who qualified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A tuition grant may be awarded to a resident of Iowa who is admitted and in attendance as a full-time or part-time resident student at an accredited private institution and who establishes financial need.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1284, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.184}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.185}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Extent of grant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A qualified full-time resident student may receive tuition grants for not more than eight semesters of undergraduate study or the trimester or quarter equivalent. A qualified part-time resident student may receive tuition grants for not more than sixteen semesters of undergraduate study or the trimester or quarter equivalent.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1284, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.185}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.186}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Amount of grant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a tuition grant to a qualified full-time student for the fall and spring semesters, or the trimester equivalent, shall be the amount of the student\u8217\'3fs financial need for that period. However, a tuition grant shall not exceed the lesser of:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total tuition and mandatory fees for that student for two semesters or the trimester or quarter equivalent, less the base amount determined annually by the college student aid commission, which base amount shall be within ten dollars of the average tuition for two semesters or the trimester equivalent of undergraduate study at the state universities under the board of regents, but in any event the base amount shall not be less than four hundred dollars; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2017, and for each succeeding fiscal year, an amount equivalent to the average resident tuition and mandatory fees for two semesters or the equivalent of undergraduate study at the institutions of higher learning governed by the state board of regents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a tuition grant to a qualified full-time student for the summer semester or trimester equivalent shall be one-half the amount of the tuition grant the student receives under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a tuition grant to a qualified part-time student enrolled in a course of study including at least three semester hours but fewer than twelve semester hours for the fall, spring, and summer semesters, or the trimester or quarter equivalent, shall be equal to the amount of a tuition grant that would be paid to a full-time student times a number which represents the number of hours in which the part-time student is actually enrolled divided by twelve semester hours, or the trimester or quarter equivalent.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 197, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1302, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 263, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1284, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 300, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 319, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1272, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 10, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 258, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 218, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1215, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1219, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 212, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1215, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 205, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1223, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7151}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 140, \'a746, 58, 59}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 172, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.186}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.187}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual grant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A tuition grant may be made annually for the fall, spring, and summer semesters or the trimester equivalent. Payments under the grant shall be allocated equally among the semesters or trimesters and shall be paid at the beginning of each semester or trimester upon certification by the accredited private institution that the student is admitted and in attendance. If the student discontinues attendance before the end of any semester or trimester after receiving payment under the grant, the entire amount of any refund due that student, up to the amount of any payments made under the annual grant, shall be paid by the accredited private institution to the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1219, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.187}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.188}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Other aid considered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a student receives financial aid under any other program the full amount of such financial aid shall be considered part of the student\u8217\'3fs financial resources available in determining the amount of the student\u8217\'3fs financial need for that period. In no case may the state\u8217\'3fs total financial contribution to the student\u8217\'3fs education, including financial aid under any other state program, exceed the tuition and mandatory fees at the institution which the student attends.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.188}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.189}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administration by commission }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ rules }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ Iowa tuition grants fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall administer this program and shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide application forms and parents\u8217\'3f confidential statement forms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules and regulations for determining financial need, defining tuition and mandatory fees, defining residence for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subpart}}}{{\f5\fs18\hyphpar0\qj{, processing and approving applications for tuition grants, and determining priority of grants. The commission may provide for proration of funds if the available funds are insufficient to pay all approved grants. Such proration shall take primary account of the financial need of the applicant. In determining who is a resident of Iowa, the commission\u8217\'3fs rules shall be at least as restrictive as those of the board of regents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approve and award tuition grants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may require an accredited private institution to promptly furnish any information which the commission may request in connection with the tuition grant program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa tuition grants fund is established in the state treasury. The fund shall be administered by the commission and shall consist of moneys appropriated by the general assembly and other moneys received by the commission for deposit in the fund. The moneys in the fund are appropriated to the commission for purposes of providing tuition grants to qualified students who are enrolled in accredited private institutions. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys in the fund at the close of the fiscal year shall not revert to the general fund of the state but shall remain available for expenditure for purposes of providing tuition grants to qualified students who are enrolled in accredited private institutions for subsequent fiscal years. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund and are appropriated to the commission for purposes of administering any scholarship or grant program described in }}}{{\f5\fs18\hyphpar0\qj{this subchapter VII, part 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72619, 2641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.189}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1057, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 157, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.191}}}{{\f5\fs12\hyphpar0\qj{, 256.194}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.190}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application for grants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each applicant, in accordance with the rules and regulations of the commission, shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Complete and file an application for a tuition grant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be responsible for the submission of the parents\u8217\'3f confidential statement for processing, the processed information to be returned both to the commission and to the college in which the applicant is enrolling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Report promptly to the commission any information requested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{File a new application and parents\u8217\'3f confidential statement annually on the basis of which the applicant\u8217\'3fs eligibility for a renewed tuition grant will be evaluated and determined.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.16}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.190}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.191}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.191}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa tuition grants }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ for-profit institutions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E11_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E11_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Students qualified.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tuition grant from moneys appropriated under }}}{{\f5\fs18\hyphpar0\qj{section 256.194, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, may be awarded to a resident of Iowa who is admitted and in attendance as a full-time or part-time resident student at an eligible institution and who establishes financial need.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E11_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E11_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Extent of grant.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualified full-time resident student enrolled in an eligible institution that meets the criteria of }}}{{\f5\fs18\hyphpar0\qj{section 256.183, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, may receive tuition grants for not more than four semesters or the equivalent of two full years of study. However, if a student resumes study after at least a two-year absence, the student may again be eligible for the specified amount of time, except that the student shall not receive assistance for courses for which credit was previously received. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E11_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E11_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Amount of grant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a tuition grant to a qualified full-time student for the fall and spring semesters, or the equivalent, shall be the amount of the student\u8217\'3fs financial need for that period. However, a tuition grant shall not exceed six thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a tuition grant to a qualified full-time student for the summer semester or equivalent shall be one-half the amount of the tuition grant the student receives under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a tuition grant to a qualified part-time student enrolled in a course of study including at least three semester hours but fewer than twelve semester hours for the fall, spring, and summer semesters, or the equivalent, shall be equal to the amount of a tuition grant that would be paid to a full-time student times a number which represents the number of hours in which the part-time student is actually enrolled divided by twelve semester hours, or the equivalent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a qualified student receives financial aid under any other program, the full amount of such financial aid shall be considered part of the student\u8217\'3fs financial resources available in determining the amount of the student\u8217\'3fs financial need for that period. In no case may the state\u8217\'3fs total financial contribution to the student\u8217\'3fs education, including financial aid under any other state or federal program, exceed the tuition and mandatory fees at the eligible institution the student attends.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E11_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E11_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Grant payments }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ attendance discontinued.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Payments under the tuition grant shall be allocated equally among the semesters or the equivalent and shall be paid at the beginning of each semester or equivalent upon certification by the eligible institution that the student is admitted and in full-time or part-time attendance in a course of study. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the student discontinues attendance before the end of any semester, or the equivalent, after receiving payment under the grant, the entire amount of any refund due that student, up to the amount of any payments made under the annual grant, shall be paid by the eligible institution to the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E11_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E11_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Commission responsibilities.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission\u8217\'3fs responsibilities for administering tuition grants under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be the same as provided under }}}{{\f5\fs18\hyphpar0\qj{section 256.189}}}{{\f5\fs18\hyphpar0\qj{. The commission may require an eligible institution to promptly furnish any information which the commission may request in connection with the tuition grant program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E11_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E11_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Grant applications.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each applicant for a tuition grant under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 256.190}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E11_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E11_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Reports to commission.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An eligible institution shall file annual reports with the commission, as required by the commission and under }}}{{\f5\fs18\hyphpar0\qj{section 256.183}}}{{\f5\fs18\hyphpar0\qj{, prior to receipt of tuition grant moneys under }}}{{\f5\fs18\hyphpar0\qj{this part}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E11_2E6_2_2955157345}{\*\bkmkend stylerid1_2E11_2E6_2_2955157345}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Fund established.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa tuition grants for-profit institutions fund is established in the state treasury. The fund shall be administered by the commission and shall consist of moneys appropriated by the general assembly and other moneys received by the commission for deposit in the fund. The moneys in the fund are appropriated to the commission for purposes of providing tuition grants to qualified students who are enrolled in eligible institutions. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys in the fund at the close of the fiscal year shall not revert to the general fund of the state but shall remain available for expenditure for purposes of providing tuition grants to qualified students who are enrolled in eligible institutions for subsequent fiscal years. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund and are appropriated to the commission for purposes of administering any scholarship or grant program described in }}}{{\f5\fs18\hyphpar0\qj{this subchapter VII, part 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 172, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2018, \'a7261.16A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72620, 2641}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 79, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.191}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 157, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.183}}}{{\f5\fs12\hyphpar0\qj{, 256.194}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 8}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256.192}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vocational-technical tuition grants }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vocational-technical tuition grant may be awarded to any resident of Iowa who is admitted and in attendance as a full-time or part-time student in a vocational-technical or career option program at a community college in the state, and who establishes financial need.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All classes, including liberal arts classes, identified by the community college as required for completion of the student\u8217\'3fs vocational-technical or career option program shall be considered a part of the student\u8217\'3fs vocational-technical or career option program for the purpose of determining the student\u8217\'3fs eligibility for a grant. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, if a student is making satisfactory academic progress but the student cannot complete a vocational-technical or career option program in the time frame allowed for a student to receive a vocational-technical tuition grant as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ because additional classes are required to complete the program, the student may continue to receive a vocational-technical tuition grant for not more than one additional enrollment period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A qualified full-time student may receive vocational-technical tuition grants for not more than four semesters or the trimester or quarter equivalent of two full years of study. A qualified part-time student enrolled in a course of study including at least three semester hours but fewer than twelve semester hours or the trimester or quarter equivalent may receive vocational-technical tuition grants for not more than eight semesters or the trimester or quarter equivalent of two full years of full-time study.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, if a student resumes study after at least a two-year absence, the student may again be eligible for the specified amount of time, except that the student shall not receive assistance for courses for which credit was previously received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a vocational-technical tuition grant to a qualified full-time student shall not exceed the lesser of one thousand two hundred dollars per year or the amount of the student\u8217\'3fs established financial need.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a vocational-technical tuition grant to a qualified part-time student enrolled in a course of study including at least three semester hours but fewer than twelve semester hours or the trimester or quarter equivalent shall be equal to the amount of a vocational-technical tuition grant that would be paid to a full-time student, except that the commission shall prorate the amount in a manner consistent with the federal Pell grant program proration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vocational-technical tuition grant shall be awarded on an annual basis, requiring reapplication by the student for each year. Payments under the grant shall be allocated equally among the semesters or quarters of the year upon certification by the institution that the student is in full-time or part-time attendance in a vocational-technical or career option program, as defined under rules of the department. If the student discontinues attendance before the end of any term after receiving payment of the grant, the entire amount of any refund due that student, up to the amount of any payments made under the annual grant, shall be paid by the institution to the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a student receives financial aid under any other program, the full amount of that financial aid shall be considered part of the student\u8217\'3fs financial resources available in determining the amount of the student\u8217\'3fs financial need for that period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall administer this program and shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide application forms for distribution to students by Iowa high schools and community colleges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules for determining financial need, defining residence for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, processing and approving applications for grants and determining priority for grants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approve and award grants on an annual basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vocational-technical tuition grants fund is established in the state treasury. The fund shall be administered by the commission and shall consist of moneys appropriated by the general assembly and other moneys received by the commission for deposit in the fund. The moneys in the fund are appropriated to the commission for purposes of providing vocational-technical tuition grants pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys in the fund at the close of the fiscal year shall not revert to the general fund of the state but shall remain available for expenditure for purposes of providing vocational-technical tuition grants pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for subsequent fiscal years. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund and are appropriated to the commission for purposes of administering any scholarship or grant program described in }}}{{\f5\fs18\hyphpar0\qj{this subchapter VII, part 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each applicant, in accordance with the rules established by the commission, shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Complete and file an application for a vocational-technical tuition grant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be responsible for the submission of the financial information required for evaluation of the applicant\u8217\'3fs need for a grant, on forms determined by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Report promptly to the commission any information requested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit a new application and financial statement for reevaluation of the applicant\u8217\'3fs eligibility to receive a second-year renewal of the grant.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7261.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 197, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 233, \'a7456}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 319, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1272, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 212, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1215, \'a734, 35}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 205, \'a729, 30}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2001 Acts, 2nd Ex, ch 6, \'a720, 37}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1014, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72621, 2641}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a7256.192}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\