{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBusiness district\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that territory defined by city ordinance as required under }}}{{\f5\fs18\hyphpar0\qj{section 321L.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state department of transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLifelong disability\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a disability described under }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{ which has been determined to be permanent by a person authorized to provide the statement of disability required by }}}{{\f5\fs18\hyphpar0\qj{section 321L.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersons with disabilities parking permit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a permit bearing the international symbol of accessibility issued by the department which allows the holder to park in a persons with disabilities parking space, and includes the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A persons with disabilities registration plate issued to or for a person with a disability under }}}{{\f5\fs18\hyphpar0\qj{section 321.34, subsection 14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A persons with disabilities parking sticker affixed to a registration plate issued to a disabled veteran under }}}{{\f5\fs18\hyphpar0\qj{section 321.166, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, or to an operator under }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A persons with disabilities removable windshield placard which is a two-sided placard for hanging from the rearview mirror when the motor vehicle is parked in a persons with disabilities parking space.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersons with disabilities parking sign\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a sign which bears the international symbol of accessibility that meets the requirements under }}}{{\f5\fs18\hyphpar0\qj{section 321L.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersons with disabilities parking space\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a parking space, including the access aisle, designated for use by only motor vehicles displaying a persons with disabilities parking permit that meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 321L.5}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321L.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson with a disability\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person with a disability that limits or impairs the person\u8217\'3fs ability to walk. A person shall be considered a person with a disability for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ under the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person cannot walk two hundred feet without stopping to rest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person cannot walk without the use of, or assistance from, a brace, cane, crutch, another person, prosthetic device, wheelchair, or other assistive device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is restricted by lung disease to such an extent that the person\u8217\'3fs forced expiratory volume for one second, when measured by spirometry, is less than one liter, or the arterial oxygen tension is less than sixty mm/hg on room air at rest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person uses portable oxygen.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has a cardiac condition to the extent that the person\u8217\'3fs functional limitations are classified in severity as class III or class IV according to standards set by the American heart association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is severely limited in the person\u8217\'3fs ability to walk due to an arthritic, neurological, or orthopedic condition.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1151, \'a73, 4}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1171, \'a74, 5}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 23, \'a735}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 70, \'a76 \u8211\'3f 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.34}}}{{\f5\fs12\hyphpar0\qj{, 321L.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321L.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons with disabilities parking permits \u8212\'3f application and issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident of the state with a disability desiring a persons with disabilities parking permit shall apply to the department upon an application form furnished by the department providing the applicant\u8217\'3fs full legal name, address, date of birth, and social security number or Iowa driver\u8217\'3fs license number or Iowa nonoperator\u8217\'3fs identification card number, and shall also provide a statement from a physician licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{149}}}{{\f5\fs18\hyphpar0\qj{, a physician assistant licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{, an advanced registered nurse practitioner licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{, a chiropractor licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 151}}}{{\f5\fs18\hyphpar0\qj{, an occupational therapist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148B}}}{{\f5\fs18\hyphpar0\qj{, or a physical therapist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148A}}}{{\f5\fs18\hyphpar0\qj{, or a physician, physician assistant, nurse practitioner, chiropractor, occupational therapist, or physical therapist licensed to practice in another state, written on the physician\u8217\'3fs, physician assistant\u8217\'3fs, nurse practitioner\u8217\'3fs, chiropractor\u8217\'3fs, occupational therapist\u8217\'3fs, or physical therapist\u8217\'3fs stationery, stating the nature of the applicant\u8217\'3fs disability and such additional information as required by rules adopted by the department under }}}{{\f5\fs18\hyphpar0\qj{section 321L.8}}}{{\f5\fs18\hyphpar0\qj{. If the person is applying for a temporary persons with disabilities parking permit, the physician\u8217\'3fs, physician assistant\u8217\'3fs, nurse practitioner\u8217\'3fs, chiropractor\u8217\'3fs, occupational therapist\u8217\'3fs, or physical therapist\u8217\'3fs statement shall state the period of time during which the person is expected to be disabled and the period of time for which the permit should be issued, not to exceed six months. The department may waive the requirement that the applicant furnish the applicant\u8217\'3fs social security number, Iowa driver\u8217\'3fs license number, or nonoperator\u8217\'3fs identification card number when the application for a temporary persons with disabilities parking permit is made on behalf of a person who is less than one year old. The department may accept a certification of disability from the United States department of veterans affairs in lieu of a statement from a physician, physician assistant, advanced registered nurse practitioner, chiropractor, occupational therapist, or physical therapist. The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ detailing the requirements for an acceptable certification of disability.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person with a disability may apply for one of the following persons with disabilities parking permits:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons with disabilities registration plates. An applicant may order persons with disabilities registration plates pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{. An applicant may order a persons with disabilities registration plate for a trailer used to transport a wheelchair pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{ in addition to persons with disabilities registration plates ordered by the applicant for a motor vehicle used to tow such a trailer pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons with disabilities parking sticker. An applicant who owns a motor vehicle for which the applicant has been issued registration plates under }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{ or registration plates as a seriously disabled veteran under }}}{{\f5\fs18\hyphpar0\qj{section 321.105}}}{{\f5\fs18\hyphpar0\qj{ may apply to the department for a persons with disabilities parking sticker to be affixed to the plates. The persons with disabilities parking stickers shall bear the international symbol of accessibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Removable windshield placard.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person with a disability may apply for a temporary removable windshield placard valid for a period of up to six months or a standard removable windshield placard valid for a period of five years, as determined by the physician\u8217\'3fs, physician assistant\u8217\'3fs, nurse practitioner\u8217\'3fs, chiropractor\u8217\'3fs, occupational therapist\u8217\'3fs, or physical therapist\u8217\'3fs statement under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A temporary removable windshield placard shall be renewed within thirty days of the date of expiration. Persons seeking temporary removable windshield placards shall be required to furnish evidence upon initial application that they have a temporary disability and, in addition, furnish evidence at subsequent intervals that they remain temporarily disabled. Temporary removable windshield placards shall be of a distinctively different color from standard removable windshield placards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A standard removable windshield placard shall expire on the last day of the month five years from the date of issuance. A person with a disability may renew a standard removable windshield placard within thirty days before or after the date of expiration by submitting a statement from a physician, physician assistant, nurse practitioner, chiropractor, occupational therapist, or physical therapist, as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, to the department that the person has a continuing need for the placard. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall issue one additional removable windshield placard upon the request of a person with a disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue expiring removable windshield placards to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An organization which has a program for transporting persons with disabilities or elderly persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person in the business of transporting persons with disabilities or elderly persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One expiring removable windshield placard may be issued for each vehicle used by the organization or person for transporting persons with disabilities or elderly persons. A placard issued under this paragraph shall be renewed every four years from the date of issuance and shall be surrendered to the department if the organization or person is no longer providing the service for which the placard was issued. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 321L.4}}}{{\f5\fs18\hyphpar0\qj{, a person transporting persons with disabilities or elderly persons in a motor vehicle for which a placard has been issued under this paragraph may display the placard in the motor vehicle and may use a persons with disabilities parking space while the motor vehicle is displaying the placard. A placard issued under this paragraph shall be of a distinctively different color from a placard issued under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A new removable windshield placard can be issued if the previously issued placard is reported lost, stolen, or damaged. The placard reported as being lost or stolen shall be invalidated by the department. A placard which is damaged shall be returned to the department and exchanged for a new placard in accordance with rules adopted by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person providing false information with the intent to defraud on the application for a persons with disabilities parking permit used in establishing proof under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ is subject to a civil penalty of three hundred dollars which may be imposed by the department. A physician, physician assistant, nurse practitioner, chiropractor, occupational therapist, or physical therapist who provides false information with the intent to defraud on the physician\u8217\'3fs, physician assistant\u8217\'3fs, nurse practitioner\u8217\'3fs, chiropractor\u8217\'3fs, occupational therapist\u8217\'3fs, or physical therapist\u8217\'3fs statement used in establishing proof under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ is subject to a civil penalty of three hundred dollars which may be imposed by the department. In addition to the civil penalty, the department shall revoke the permit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The removable windshield placard shall contain the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each side of the placard shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The international symbol of access, which is at least three inches in height, centered on the placard, and is white on a blue shield.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An identification number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A date of expiration, which shall be of sufficient size to be readable from outside the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The seal or other identification of the issuing authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One side of the placard shall contain all of the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Subject to subparagraph division (b), a statement printed on it as follows: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{Unauthorized use of this placard as indicated in Iowa Code }{{\f5\fs18\hyphpar0\qj{chapter 321L}}}{ may result in a fine, invalidation of the placard, or revocation of the right to use the placard. This placard shall be displayed only when the vehicle is parked in a persons with disabilities parking space or in a parking space not designated as a persons with disabilities parking space if a wheelchair parking cone is used pursuant to Iowa Code }{{\f5\fs18\hyphpar0\qj{section 321L.2A}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the department has issued the existing supply of placards bearing the statement set forth in subparagraph division (a), the statement printed on each newly issued placard shall be as follows: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{Remove from mirror before operating vehicle.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The return address and telephone number of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The signature of the person who has been issued the placard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A removable windshield placard shall only be displayed when the vehicle is parked in a persons with disabilities parking space. The removable windshield placard shall be displayed in a manner that allows the entire placard to be visible through the vehicle\u8217\'3fs windshield.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A seriously disabled veteran who has been provided with an automobile or other vehicle by the United States government under the provisions of }}}{{\f5\fs18\hyphpar0\qj{38 U.S.C. \'a73901 }}}{{\f5\fs18\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj{ 3904}}}{{\f5\fs18\hyphpar0\qj{ is not required to apply for a persons with disabilities parking permit under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the veteran has been issued special registration plates or personalized plates for the vehicle. The regular registration plates issued for the disabled veteran\u8217\'3fs vehicle without fee pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.105}}}{{\f5\fs18\hyphpar0\qj{ entitle the disabled veteran to all of the rights and privileges associated with persons with disabilities parking permits under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1151, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1267, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1088, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1171, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 70, \'a79 \u8211\'3f 13, 15}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 123, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1206, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7124}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1124, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7118}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1035, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1067, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1111, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7118}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1080, \'a72 \u8211\'3f 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.23}}}{{\f5\fs12\hyphpar0\qj{, 321.166}}}{{\f5\fs12\hyphpar0\qj{, 321L.1}}}{{\f5\fs12\hyphpar0\qj{, 321L.2A}}}{{\f5\fs12\hyphpar0\qj{, 321L.4}}}{{\f5\fs12\hyphpar0\qj{, 321L.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321L.2A}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wheelchair parking cone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person issued a persons with disabilities parking permit under }}}{{\f5\fs18\hyphpar0\qj{section 321L.2}}}{{\f5\fs18\hyphpar0\qj{ who uses a wheelchair due to a disability that renders the person permanently unable to walk may park in a persons with disabilities parking space, or a parking space not designated as a persons with disabilities parking space, and reserve up to an eight foot space adjacent to the motor vehicle for the purpose of exiting and entering the motor vehicle if all of the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person places a wheelchair parking cone within eight feet of the motor vehicle\u8217\'3fs entry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person displays the persons with disabilities parking permit in the motor vehicle as described in }}}{{\f5\fs18\hyphpar0\qj{section 321L.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motor vehicle and the wheelchair parking cone do not obstruct an aisle, street, or roadway so that other vehicles are unable to pass through the aisle, street, or roadway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parking space is provided by the state, a political subdivision of the state, or an entity providing nonresidential parking.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person carries in the motor vehicle a copy of the statement from a physician, physician assistant, advanced registered nurse practitioner, chiropractor, occupational therapist, or physical therapist which accompanied the person\u8217\'3fs application for persons with disabilities registration plates under }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{ or other persons with disabilities parking permit under }}}{{\f5\fs18\hyphpar0\qj{section 321L.2}}}{{\f5\fs18\hyphpar0\qj{ and which indicates the person is permanently unable to walk. The person shall show the copy of the statement to any peace officer upon request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person issued a persons with disabilities parking permit who does not comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ when using a wheelchair parking cone commits a misdemeanor punishable by a scheduled fine under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not interfere with a wheelchair parking cone properly placed under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. A violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is a misdemeanor punishable by a scheduled fine under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules as necessary to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 70, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 147, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1080, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1206, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1080, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321L.2}}}{{\f5\fs12\hyphpar0\qj{, 321L.4}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(1)(b)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(1)(c)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321L.3}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Return of persons with disabilities parking permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons with disabilities parking permits shall be returned to the department upon the occurrence of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person to whom the persons with disabilities parking permit has been issued is deceased.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person to whom the persons with disabilities parking permit has been issued has moved out of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person has found or has in the person\u8217\'3fs possession a persons with disabilities parking permit that was not issued to that person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The persons with disabilities parking permit has expired.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The persons with disabilities parking permit has been revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The persons with disabilities parking permit reported lost or stolen is later found or retrieved after a subsequent persons with disabilities parking permit has been issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who fails to return the persons with disabilities parking permit and subsequently misuses the permit by illegally parking in a persons with disabilities parking space is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons with disabilities parking permits may be returned to the department as required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ directly to the department, to a driver\u8217\'3fs license station, or to any law enforcement office.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1171, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 70, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a755, 59}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(1)(c)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321L.4}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons with disabilities parking \u8212\'3f display and use of parking permit and persons with disabilities identification designation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A persons with disabilities parking permit shall be displayed in a motor vehicle as a removable windshield placard or on a vehicle as a plate or sticker as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321L.2}}}{{\f5\fs18\hyphpar0\qj{ when being used by a person with a disability, either as an operator or passenger. Each removable windshield placard shall be of uniform design and fabricated of durable material, suitable for display from within the passenger compartment of a motor vehicle, and readily transferable from one vehicle to another. The placard shall only be displayed when the motor vehicle is parked in a persons with disabilities parking space, except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321L.2A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The use of a persons with disabilities parking space, located on either public or private property as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321L.5}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321L.6}}}{{\f5\fs18\hyphpar0\qj{, by an operator of a vehicle not displaying a persons with disabilities parking permit; by an operator of a vehicle displaying a persons with disabilities parking permit but not being used by a person issued a permit or being transported in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321L.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{; or by a vehicle in violation of the rules adopted by the department under }}}{{\f5\fs18\hyphpar0\qj{section 321L.8}}}{{\f5\fs18\hyphpar0\qj{, constitutes improper use of a persons with disabilities parking permit, which is a misdemeanor for which a scheduled fine shall be imposed upon the owner, operator, or lessee of the vehicle or the person to whom the persons with disabilities parking permit is issued. The scheduled fine for each violation shall be as established in }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. Proof of conviction of two or more violations involving improper use of a persons with disabilities parking permit is grounds for revocation by the court or the department of the holder\u8217\'3fs privilege to possess or use the persons with disabilities parking permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer as designated in }}}{{\f5\fs18\hyphpar0\qj{section 801.4, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, shall have the authority to and shall enforce the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on public and private property.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1122, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1171, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 70, \'a714, 15}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 147, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1206, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 137, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}{{\f5\fs12\hyphpar0\qj{, 321.236}}}{{\f5\fs12\hyphpar0\qj{, 321L.2}}}{{\f5\fs12\hyphpar0\qj{, 321L.2A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(1)(c)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321L.5}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons with disabilities parking spaces \u8212\'3f location and requirements \u8212\'3f review committees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons with disabilities parking spaces and access loading zones for persons with disabilities that serve a particular building shall be located on the shortest accessible route to the nearest accessible entrance to the building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A persons with disabilities parking space designated after July 1, 1990, shall comply with the dimension requirements specified in rules adopted by the department of inspections, appeals, and licensing and in effect when the spaces are designated. The department shall adopt accepted national standards for dimensions of persons with disabilities spaces, consistent with the requirements of federal law. However, these dimension requirements do not apply to parallel on-street parking spaces.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state or a political subdivision of the state which provides off-street public parking facilities or an entity providing nonresidential parking in off-street public parking facilities shall provide not less than two percent of the total parking spaces in each parking facility as persons with disabilities parking spaces, rounded to the nearest whole number of persons with disabilities parking spaces. However, such parking facilities having ten or more parking spaces shall set aside at least one persons with disabilities parking space.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity providing off-street nonresidential public parking facilities shall review the utilization of existing persons with disabilities parking spaces for a one-month period not less than once every twelve months. If upon review, the average occupancy rate for persons with disabilities parking spaces in a facility exceeds sixty percent during normal business hours, the entity shall provide additional persons with disabilities parking spaces as needed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity providing off-street nonresidential parking as a lessor shall provide a persons with disabilities parking space to an individual requesting to lease a parking space, if that individual possesses a persons with disabilities parking permit issued in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321L.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A new nonresidential facility in which construction has been completed on or after July 1, 1991, providing parking to the general public shall provide persons with disabilities parking spaces as stipulated below:}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~}}}{Required Minimum}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~}}}{Number of Persons}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Total Parking}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~}}}{with Disabilities}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Spaces in Lot}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~}}}{Parking Spaces}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{___________________________________________}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{10}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{25}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{1}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{26}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{50}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{2}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{51}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{75}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{3}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{76}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{100}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{4}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{101}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{150}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{5}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{151}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{200}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{6}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{201}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{300}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{7}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{301}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{400}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{8}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{401}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{500}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{9}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{501}{{\f5\fs18\hyphpar0\qj{\~\~}}}{to}{{\f5\fs18\hyphpar0\qj{\~\~}}}{1000}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~}}}{2 Percent of Total}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{1001}{{\f5\fs18\hyphpar0\qj{\~\~}}}{and over}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~}}}{20 Spaces Plus 1 for}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Each 100 Over 1000}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other person may also set aside persons with disabilities parking spaces on the person\u8217\'3fs property provided each persons with disabilities parking space is clearly and prominently designated as a persons with disabilities parking space.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cities which provide on-street parking areas within a business district shall by ordinance define and establish a business district or districts and shall designate not less than two percent of the total parking spaces within each business district as persons with disabilities parking spaces.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon petition by an individual possessing a persons with disabilities parking permit issued in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321L.2}}}{{\f5\fs18\hyphpar0\qj{, the city shall review utilization and location of existing persons with disabilities parking spaces for a one-month period but not more than once every twelve months. If, upon review, the average occupancy rate for persons with disabilities parking spaces exceeds sixty percent during normal business hours, the city shall provide additional persons with disabilities parking spaces as needed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A persons with disabilities parking space located on a paved surface may be painted with a blue background upon which the international symbol of accessibility is painted in white or yellow paint. However, the blue background paint may be omitted. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpaved surface\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes surfaces which are asphalt surfaced.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A persons with disabilities parking review committee may be established by the state and each political subdivision of the state which is required to provide persons with disabilities parking spaces in off-street public parking facilities according to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ and in political subdivisions required to provide persons with disabilities parking spaces for on-street parking within a business district according to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{. The persons with disabilities parking review committee shall consist of five members who are persons with disabilities as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321L.1}}}{{\f5\fs18\hyphpar0\qj{ and five members who are officials of the state or political subdivision. The persons with disabilities parking review committee shall have the discretion to increase or decrease the numbers of persons with disabilities parking spaces required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A decision to change the numbers or location of persons with disabilities parking spaces shall be based upon the needs of the community, the percentage of use of the present persons with disabilities parking spaces, and the past experience of the state or political subdivision regarding persons with disabilities parking.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual may request the persons with disabilities parking review committee to review the amounts and locations of persons with disabilities parking spaces. The persons with disabilities parking review committee shall investigate each individual\u8217\'3fs request and shall act upon such request if the investigation substantiates the individual\u8217\'3fs complaint.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1151, \'a76 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1015, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1107, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1171, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 70, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1080, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7119}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 98, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321L.1}}}{{\f5\fs12\hyphpar0\qj{, 321L.4}}}{{\f5\fs12\hyphpar0\qj{, 321L.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321L.6}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons with disabilities parking sign.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A persons with disabilities parking sign shall be displayed designating the persons with disabilities parking space.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The persons with disabilities parking sign shall have a blue background and bear the international symbol of accessibility in white. If an entity who owns or leases real property in a city is required to provide persons with disabilities parking spaces, the city shall provide, upon request, the signs for the entity at cost. If an entity who owns or leases real property outside the corporate limits of a city is required to provide persons with disabilities parking spaces, the county in which the property is located shall provide the signs for the entity at cost upon request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The persons with disabilities parking sign shall be affixed vertically on another object so that it is readily visible to a driver of a motor vehicle approaching the persons with disabilities parking space. A persons with disabilities parking space designated only by the international symbol of accessibility being painted or otherwise placed horizontally on the parking space does not meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 169, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 70, \'a715, 16}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 147, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321L.1}}}{{\f5\fs12\hyphpar0\qj{, 321L.4}}}{{\f5\fs12\hyphpar0\qj{, 321L.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321L.7}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty for failing to provide persons with disabilities parking spaces and signs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Failure to provide proper persons with disabilities parking spaces as provided in }{{\f5\fs18\hyphpar0\qj{section 321L.5}}}{ or to properly display persons with disabilities parking signs as provided in }{{\f5\fs18\hyphpar0\qj{section 321L.6}}}{ is a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 1}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 70, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 176, \'a756, 59}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(1)(c)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321L.8}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons with disabilities parking permits and parking \u8212\'3f rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, shall adopt rules:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing procedures for applying to the department for issuance of persons with disabilities parking permits under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Governing the manner in which persons with disabilities parking permits are to be displayed in or on motor vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regarding enforcement of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of inspections, appeals, and licensing shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ governing the manner in which persons with disabilities parking spaces are provided.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1171, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 70, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 98, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321L.2}}}{{\f5\fs12\hyphpar0\qj{, 321L.4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5