\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F9_301}{\*\bkmkend codeChapter_5F9_301}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 901}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{JUDGMENT AND SENTENCING PROCEDURES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7232.55}}}{{\f5\fs12\qc{, 715E.1}}}{{\f5\fs12\qc{, 716.13}}}{{\f5\fs12\qc{, 716.14}}}{{\f5\fs12\qc{, 717B.1}}}{{\f5\fs12\qc{, 901A.2}}}{{\f5\fs12\qc{, 904.602}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Chapters 901 through 909}}}{ shall be known and may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa Corrections Code\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7901.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1023, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7375}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presentence investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a plea of guilty, a verdict of guilty, or a special verdict upon which a judgment of conviction of a public offense may be rendered, the court shall receive from the state, from the judicial district department of correctional services, and from the defendant any information which may be offered which is relevant to the question of sentencing. The court may consider information from other sources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall not order a presentence investigation when the offense is a class \u8220\'3fA\u8221\'3f felony. If, however, the board of parole determines that the Iowa medical and classification center reception report for a class \u8220\'3fA\u8221\'3f felon is inadequate, the board may request and shall be provided with additional information from the appropriate judicial district department of correctional services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall order a presentence investigation when the offense is a class \u8220\'3fB\u8221\'3f, class \u8220\'3fC\u8221\'3f, or class \u8220\'3fD\u8221\'3f felony. A presentence investigation for a class \u8220\'3fB\u8221\'3f, class \u8220\'3fC\u8221\'3f, or class \u8220\'3fD\u8221\'3f felony shall not be waived. The court may order, with the consent of the defendant, that the presentence investigation begin prior to the acceptance of a plea of guilty, or prior to a verdict of guilty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may order a presentence investigation when the offense is an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may order a presentence investigation when the offense is a serious misdemeanor only upon a finding of exceptional circumstances warranting an investigation. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 901.3}}}{{\f5\fs18\hyphpar0\qj{, a presentence investigation ordered by the court for a serious misdemeanor shall include information concerning only the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A brief personal and social history of the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs criminal record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The harm to the victim, the victim\u8217\'3fs immediate family, and the community, including any completed victim impact statement or statements and restitution plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may withhold execution of any judgment or sentence for such time as shall be reasonably necessary for an investigation with respect to deferment of judgment, deferment of sentence, or suspension of sentence and probation. The investigation shall be made by the judicial district department of correctional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of the report by the judicial district department of correctional services is to provide the court pertinent information for purposes of sentencing and to include suggestions for correctional planning for use by correctional authorities subsequent to sentencing.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a75447-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3800;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7247.20; C75, 77, \'a7789A.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7901.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 38, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1126, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 156, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1099, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 12, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1122, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7257}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7240}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 86, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7903B.10}}}{{\f5\fs12\hyphpar0\qj{, 907.3A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presentence investigation report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a presentence investigation is ordered by the court, the investigator shall promptly inquire into all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs characteristics, family and financial circumstances, needs, and potentialities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs criminal record and social history.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The circumstances of the offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The time the defendant has been in detention.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The harm to the victim, the victim\u8217\'3fs immediate family, and the community. Additionally, the presentence investigator shall provide a victim impact statement form to each victim, if one has not already been provided, and shall file the completed statement or statements with the presentence investigation report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs potential as a candidate for the community service sentence program established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 907.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any mitigating circumstances relating to the offense and the defendant\u8217\'3fs potential as a candidate for deferred judgment, deferred sentencing, a suspended sentence, or probation, if the defendant is charged with or convicted of assisting suicide pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 707A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the defendant has a history of mental health issues or a substance use disorder. If so, the investigator shall inquire into the treatment options available in both the community of the defendant and the correctional system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All local and state mental and correctional institutions, courts, and police agencies shall furnish to the investigator on request the defendant\u8217\'3fs criminal record and other relevant information. The originating source of specific mental health or substance use disorder information including the histories, treatment, and use of medications shall not be released to the presentence investigator unless the defendant authorizes the release of such information. If the defendant refuses to release the information, the presentence investigator may note the defendant\u8217\'3fs refusal to release mental health or substance use disorder information in the presentence investigation report and rely upon other mental health or substance use disorder information available to the presentence investigator. With the approval of the court, a physical examination or psychiatric evaluation of the defendant may be ordered, or the defendant may be committed to an inpatient or outpatient psychiatric facility for an evaluation of the defendant\u8217\'3fs personality and mental health. The results of any such examination or evaluation shall be included in the report of the investigator.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7789A.4; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7901.3}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1069, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1178, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 219, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1002, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 7, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7222}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71321, 1322}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7901.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presentence investigation report confidential }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ access.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The presentence investigation report is confidential and the court shall provide safeguards to ensure its confidentiality, including but not limited to sealing the report, which may be opened only by further court order. The defendant\u8217\'3fs attorney and the attorney for the state shall have access to the presentence investigation report at least three days prior to the date set for sentencing. The defendant\u8217\'3fs appellate attorney and the appellate attorney for the state shall have access to the presentence investigation report upon request and without the necessity of a court order. The report shall remain confidential except upon court order. However, the court may conceal the identity of the person who provided confidential information. The report of a medical examination or psychological or psychiatric evaluation shall be made available to the attorney for the state and to the defendant upon request. The reports are part of the record but shall be sealed and opened only on order of the court. If the defendant is committed to the custody of the Iowa department of corrections and is not a class \u8220\'3fA\u8221\'3f felon, an employee of the department, if authorized by the director of the department, an employee of a judicial district department of correctional services, if authorized by the director of the judicial district department of correctional services, and an employee of the board of parole, if authorized by the chairperson or a member of the board of parole, shall have access to the presentence investigation report. Pursuant to }{{\f5\fs18\hyphpar0\qj{section 904.602}}}{, the presentence investigation report may also be released by ordinary or electronic mail by the department of corrections or a judicial district department of correctional services to another jurisdiction for the purpose of providing interstate probation and parole compact or interstate compact for adult offender supervision services or evaluations, or to a substance use disorder or mental health services provider when referring a defendant for services. The defendant or the defendant\u8217\'3fs attorney may file with the presentence investigation report, a denial or refutation of the allegations, or both, contained in the report. The denial or refutation shall be included in the report.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7789A.5; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7901.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 38, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 96, \'a7124, 159, 160}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 279, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1095, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1169, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 112, \'a720}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2003 Acts, 1st Ex, ch 2, \'a750, 209}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1106, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7465, 468}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 171, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1007, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1159, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 11, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71323}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7216A.136}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.4A}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Substance use disorder evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon a plea of guilty, a verdict of guilty, or a special verdict upon which a judgment of conviction may be rendered, the court may order the defendant to submit to and complete a substance use disorder evaluation, if the court determines that there is reason to believe that the defendant regularly uses alcohol or other controlled substances and may be in need of treatment. An order made pursuant to }{{\f5\fs18\hyphpar0\qj{this section}}}{ may be made in addition to any other sentence or order of the court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1251, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71324}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7901.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.4B}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presentence determinations and statements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before imposing sentence, the court shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Verify that the defendant and the defendant\u8217\'3fs attorney have read and discussed the presentence investigation report and any addendum to the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide the defendant\u8217\'3fs attorney an opportunity to speak on the defendant\u8217\'3fs behalf.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Address the defendant personally in order to permit the defendant to make a statement or present any information to mitigate the defendant\u8217\'3fs sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide the prosecuting attorney an opportunity to speak.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After hearing any statements presented pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and before imposing sentence, the court shall address any victim of the crime who is present at the sentencing and shall allow any victim to be reasonably heard, including but not limited to by presenting a victim impact statement in the manner described in }}}{{\f5\fs18\hyphpar0\qj{section 915.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fvictim\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 915.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 140, \'a737}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.5}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pronouncing judgment and sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{After receiving and examining all pertinent information, including the presentence investigation report and victim impact statements, if any, the court shall consider the following sentencing options. The court shall determine which of them is authorized by law for the offense, and of the authorized sentences, which of them or which combination of them, in the discretion of the court, will provide maximum opportunity for the rehabilitation of the defendant, and for the protection of the community from further offenses by the defendant and others. At the time fixed by the court for pronouncement of judgment and sentence, the court shall act accordingly:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If authorized by }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{, the court may defer judgment and sentence for an indefinite period in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 907}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant is not an habitual offender as defined by }}}{{\f5\fs18\hyphpar0\qj{section 902.8}}}{{\f5\fs18\hyphpar0\qj{, the court may pronounce judgment and impose a fine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may pronounce judgment and impose a fine or sentence the defendant to confinement, or both, and suspend the execution of the sentence or any part of it as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 907}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may pronounce judgment and impose a fine or sentence the defendant to confinement, or both.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If authorized by }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{, the court may defer the sentence and assign the defendant to the judicial district department of correctional services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may pronounce judgment and sentence the defendant to confinement and then reconsider the sentence as provided by }}}{{\f5\fs18\hyphpar0\qj{section 902.4}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{903.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall inform the defendant of the mandatory minimum sentence, if one is applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may order the defendant to complete any treatment indicated by a substance use disorder evaluation ordered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 901.4A}}}{{\f5\fs18\hyphpar0\qj{ or any other section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall order DNA profiling of a defendant convicted of an offense that requires profiling under }}}{{\f5\fs18\hyphpar0\qj{section 81.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 81.2}}}{{\f5\fs18\hyphpar0\qj{, the court may order the defendant to provide a DNA sample to be submitted for DNA profiling if appropriate. In determining the appropriateness of ordering DNA profiling, the court shall consider the deterrent effect of DNA profiling, the likelihood of repeated offenses by the defendant, and the seriousness of the offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant is being sentenced for an aggravated misdemeanor or a felony, the court shall publicly announce the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the defendant\u8217\'3fs term of incarceration may be reduced from the maximum sentence because of statutory earned time, work credits, and program credits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the defendant may be eligible for parole before the sentence is discharged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of multiple sentences, whether the sentences shall be served consecutively or concurrently.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any sentence or other penalty imposed against the defendant for an offense under }}}{{\f5\fs18\hyphpar0\qj{chapter 124}}}{{\f5\fs18\hyphpar0\qj{, the court shall consider the provisions of }}}{{\f5\fs18\hyphpar0\qj{21 U.S.C. \'a7862}}}{{\f5\fs18\hyphpar0\qj{, regarding the denial of federal benefits to drug traffickers and possessors convicted under state or federal law, and may enter an order specifying the range and scope of benefits to be denied to the defendant, according to the provisions of }}}{{\f5\fs18\hyphpar0\qj{21 U.S.C. \'a7862}}}{{\f5\fs18\hyphpar0\qj{. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffederal benefit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the issuance of any grant, contract, loan, professional license, or commercial license provided by an agency of the United States or through the appropriation of funds of the United States, but does not include any retirement, welfare, social security, health, disability, veterans, public housing, or similar benefit for which payments or services are required for eligibility. The supreme court may adopt rules establishing sentencing guidelines consistent with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{21 U.S.C. \'a7862}}}{{\f5\fs18\hyphpar0\qj{. The clerk of the district court shall send a copy of any order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to the denial of federal benefits program of the United States department of justice, along with any other forms and information required by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any sentence or other penalty imposed against the defendant for an offense under }}}{{\f5\fs18\hyphpar0\qj{chapter 124}}}{{\f5\fs18\hyphpar0\qj{, the court shall consider the denial of state benefits to the defendant, and may enter an order specifying the range and scope of benefits to be denied to the defendant, comparable to the federal benefits denied under }}}{{\f5\fs18\hyphpar0\qj{subsection 11}}}{{\f5\fs18\hyphpar0\qj{. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstate benefit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the issuance of any grant, contract, loan, professional license, or commercial license provided by a state agency, department, program, or otherwise through the appropriation of funds of the state, but does not include any retirement, welfare, health, disability, veterans, public housing, or similar benefit. The supreme court may adopt rules establishing sentencing guidelines consistent with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and comparable to the guidelines for denial of federal benefits in 21 U.S.C. \'a7862. The clerk of the district court shall send a copy of any order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to each state agency, department, or program required to deny benefits pursuant to such an order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other sentence or other penalty imposed against the defendant, the court shall impose a special sentence if required under }}}{{\f5\fs18\hyphpar0\qj{section 903B.1}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{903B.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision in }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{ or any other provision of law prescribing a mandatory minimum sentence for the offense, if the defendant, other than a child being prosecuted as a youthful offender, is guilty of a public offense other than a class \u8220\'3fA\u8221\'3f felony, and was under the age of eighteen at the time the offense was committed, the court may suspend the sentence in whole or in part, including any mandatory minimum sentence, or with the consent of the defendant, defer judgment or sentence, and place the defendant on probation upon such conditions as the court may require.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7901.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1063, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1178, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1023, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1218, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1122, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1173, \'a72, 10}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 165, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 109, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 156, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a777}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 58, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 158, \'a714, 19, 37}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1101, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7223}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 42, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a7102, 104}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71325}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.8}}}{{\f5\fs12\hyphpar0\qj{, 462A.14}}}{{\f5\fs12\hyphpar0\qj{, 602.8103}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 708.2D}}}{{\f5\fs12\hyphpar0\qj{, 901.5B}}}{{\f5\fs12\hyphpar0\qj{, 902.13}}}{{\f5\fs12\hyphpar0\qj{, 907.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Modification of no-contact orders, }{{\f5\fs12\hyphpar0\qj{\'a7664A.5}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fines, see }{{\f5\fs12\hyphpar0\qj{chapter 909}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Surcharge on penalty, }{{\f5\fs12\hyphpar0\qj{chapter 911}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.5A}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reopening of a sentence.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 86, \'a714}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.5B}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pronouncement of judgment and sentence \u8212\'3f social security number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to pronouncement of judgment and sentence pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 901.5}}}{{\f5\fs18\hyphpar0\qj{, or prior to pleading guilty for an offense that does not require a court appearance, the defendant shall provide the defendant\u8217\'3fs social security number to the clerk of the district court or the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court shall duly note the social security number in the case file.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant\u8217\'3fs social security number shall be considered a confidential record exempted from public access under }}}{{\f5\fs18\hyphpar0\qj{section 22.7}}}{{\f5\fs18\hyphpar0\qj{, but shall be disclosed by the clerk of the district court for the limited purpose of collecting court debt pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure or refusal to provide a social security number pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not delay the pronouncement of judgment and sentence pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 901.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1172, \'a726}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.6}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judgment entered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If judgment is not deferred, and no sufficient cause is shown why judgment should not be pronounced and none appears to the court upon the record, judgment shall be pronounced and entered. In every case in which judgment is entered, the court shall include in the judgment entry the number of the particular section of the Code and the name of the offense under which the defendant is sentenced and a statement of the days credited pursuant to }{{\f5\fs18\hyphpar0\qj{section 903A.5}}}{ shall be incorporated into the sentence.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73066; R60, \'a74873, 4874; C73, \'a74506, 4507; C97, \'a75438; C24, \'a713958; C27, 31, 35, \'a713958-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13958.2;}}}{ C46, 50, 54, 58, 62, 66, \'a7789.11; C71, 73, 75, 77, \'a7789.11, 791.8; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7901.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 38, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{83 Acts, ch 147, \'a711, 14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.7}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commitment to custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In imposing a sentence of confinement for more than one year, the court shall commit the defendant to the custody of the director of the Iowa department of corrections. Upon entry of judgment and sentence, the clerk of the district court immediately shall notify the director of the commitment. The court shall make an order as appropriate for the temporary custody of the defendant pending the defendant\u8217\'3fs transfer to the custody of the director. The court shall order the county where a person was convicted to pay the cost of temporarily confining the person and of transporting the person to the state institution where the person is to be confined in execution of the judgment. The order shall require that a person transported to a state institution pursuant to }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be accompanied by a person of the same sex.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7901.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7125, 159}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 21, \'a749}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.8102(134)}}}{{\f5\fs12\hyphpar0\qj{, 904.503}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.8}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consecutive sentences.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a person is sentenced for two or more separate offenses, the sentencing judge may order the second or further sentence to begin at the expiration of the first or succeeding sentence. If a person is sentenced for escape under }{{\f5\fs18\hyphpar0\qj{section 719.4}}}{ or for a crime committed while confined in a detention facility or penal institution, the sentencing judge shall order the sentence to begin at the expiration of any existing sentence. If the person is presently in the custody of the director of the Iowa department of corrections, the sentence shall be served at the facility or institution in which the person is already confined unless the person is transferred by the director. Except as otherwise provided in }{{\f5\fs18\hyphpar0\qj{section 903A.7}}}{, if consecutive sentences are specified in the order of commitment, the several terms shall be construed as one continuous term of imprisonment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a75718-a13; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13961;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7789.14; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7901.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7126, 159}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 131, \'a71, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7903.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.9}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Information for parole board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{At the time of committing a defendant to the custody of the director of the Iowa department of corrections for incarceration, the trial judge and prosecuting attorney shall, and the defense attorney may, furnish the board of parole with a full statement of their recommendations relating to release or parole.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 38, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7160}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.10}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reduction of sentences.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court sentencing a person for the person\u8217\'3fs first conviction under }}}{{\f5\fs18\hyphpar0\qj{section 124.406}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{124.413}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{902.7}}}{{\f5\fs18\hyphpar0\qj{ may, at its discretion, sentence the person to a term less than provided by the statute if mitigating circumstances exist and those circumstances are stated specifically in the record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court sentencing a person for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not grant any reduction of sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, if the sentence under }}}{{\f5\fs18\hyphpar0\qj{section 124.413}}}{{\f5\fs18\hyphpar0\qj{ involves an amphetamine or methamphetamine offense under }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court shall not grant any reduction of sentence unless the defendant pleads guilty. If the defendant pleads guilty, the court may, at its discretion, reduce the mandatory minimum sentence by up to one-third. If the defendant additionally cooperates in the prosecution of other persons involved in the sale or use of controlled substances, and if the prosecutor requests an additional reduction in the defendant\u8217\'3fs sentence because of such cooperation, the court may grant a further reduction in the defendant\u8217\'3fs mandatory minimum sentence, up to one-half of the remaining mandatory minimum sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court sentencing a person for the person\u8217\'3fs first conviction under }}}{{\f5\fs18\hyphpar0\qj{section 124.401D}}}{{\f5\fs18\hyphpar0\qj{ may, at its discretion, sentence the person to a term less than the maximum term provided under }}}{{\f5\fs18\hyphpar0\qj{section 902.9, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{,* if mitigating circumstances exist and those circumstances are stated specifically in the record. However, the court shall not grant any reduction of sentence unless the defendant pleads guilty. If the defendant pleads guilty, the court may, at its discretion, reduce the maximum sentence by up to one-third. If the defendant cooperates in the prosecution of other persons involved in the sale or use of controlled substances, and if the prosecutor requests an additional reduction in the defendant\u8217\'3fs sentence because of such cooperation, the court may grant a further reduction in the defendant\u8217\'3fs maximum sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state may appeal the discretionary decision on the grounds that the stated mitigating circumstances do not warrant a reduction of the sentence.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 41, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 12, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1144, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7259}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 86, \'a711}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{*Paragraph \u8220\'3fa\u8221\'3f of section 902.9, subsection 1 was stricken by }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH86.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 86, \'a712}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; corrective legislation is pending}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.11}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Parole or work release eligibility determination }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ certain offenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of sentencing, the court shall determine when a person convicted under }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall first become eligible for parole or work release within the parameters described in }}}{{\f5\fs18\hyphpar0\qj{section 124.413, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, based upon all the pertinent information including the person\u8217\'3fs criminal record, a validated risk assessment, and the negative impact the offense has had on the victim or other persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of sentencing, the court shall determine when a person convicted of child endangerment as described in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall first become eligible for parole or work release within the parameters specified in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, based upon all pertinent information including the person\u8217\'3fs criminal record, a validated risk assessment, and whether the offense involved multiple intentional acts or a series of intentional acts, or whether the offense involved torture or cruelty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of sentencing, the court shall determine when a person convicted of robbery in the first degree as described in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, shall first become eligible for parole or work release within the parameters specified in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, based upon all pertinent information including the person\u8217\'3fs criminal record, a validated risk assessment, and the negative impact the offense has had on the victim or other persons. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of sentencing, the court shall determine when a person convicted of robbery in the second degree as described in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, shall first become eligible for parole or work release within the parameters specified in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, based upon all pertinent information including the person\u8217\'3fs criminal record, a validated risk assessment, and the negative impact the offense has had on the victim or other persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of sentencing, the court shall determine when a person convicted of arson in the first degree as described in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, shall first become eligible for parole or work release within the parameters specified in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, based upon all pertinent information including the person\u8217\'3fs criminal record, a validated risk assessment, and the negative impact the offense has had on the victim or other persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of sentencing, the court shall determine when a person convicted of sexual exploitation of a minor as described in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, shall first become eligible for parole or work release within the parameters specified in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, based upon all pertinent information including the person\u8217\'3fs criminal record, a validated risk assessment, and the negative impact the offense has had on the victim or other persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of sentencing, the court shall determine when a person convicted of human trafficking as described in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, shall first become eligible for parole or work release within the parameters specified in }}}{{\f5\fs18\hyphpar0\qj{section 902.12, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, based upon all pertinent information including the person\u8217\'3fs criminal record, a validated risk assessment, and the negative impact the offense has had on the victim or other persons.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1104, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 122, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 140, \'a76, 38}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7381}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 74, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1175, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7124.413}}}{{\f5\fs12\hyphpar0\qj{, 902.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901.12}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Minimum sentence }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ parole or work release eligibility }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ certain drug offenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Effective July 1, 2016, and notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 124.413}}}{{\f5\fs18\hyphpar0\qj{, a person whose sentence commenced prior to July 1, 2016, for a conviction under }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, who has not previously been convicted of a forcible felony, and who does not have a prior conviction under }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall first be eligible for parole or work release after the person has served one-half of the minimum term of confinement prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 124.413}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Effective July 1, 2017, a person whose sentence commenced prior to July 1, 2017, for a conviction under }}}{{\f5\fs18\hyphpar0\qj{section 124.401, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not be required to serve a minimum term of confinement as prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 124.413}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the board of parole considers a person for parole or work release pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the board shall consider all pertinent information including the person\u8217\'3fs criminal record, a validated risk assessment, and the negative impact the offense has had on the victim or other persons.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1104, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 122, \'a714, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7124.413}}}\par}}