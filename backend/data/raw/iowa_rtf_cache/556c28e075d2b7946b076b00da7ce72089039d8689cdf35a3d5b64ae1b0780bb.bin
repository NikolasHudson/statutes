\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F12}{\*\bkmkend codeChapter_5F12}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 12}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{TREASURER OF STATE}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7159.35}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E2_2E2}{GENERAL PROVISIONS}{\*\bkmkend stylerid1_2E5_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.1}}}{\*\bkmkstart stylerid1_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Office }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ accounts }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer shall keep the treasurer\u8217\'3fs office at the seat of government, and shall keep an accurate account of the receipts and disbursements at the treasury in books kept for that purpose, in which the treasurer shall specify the names of the persons from whom money is received, and on what account, and the time of receipt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer is responsible for reporting on the bonding activities of all political subdivisions, instrumentalities, and agencies of the state and shall make recommendations to the general assembly and the governor on modification in the bonding authority. The treasurer shall notify each political subdivision, instrumentality, and agency of the state to report to the treasurer the amount of bonds outstanding and each new bond issue. The treasurer shall adopt rules and establish forms for carrying out }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Each political subdivision, instrumentality, and agency of the state shall provide all the information required by the treasurer under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a762; R60, \'a783; C73, \'a775; C97, \'a7101; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{131;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7823}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.2}}}{\*\bkmkstart stylerid1_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Daily balance sheet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer of state shall so keep the books of the treasurer\u8217\'3fs office that at the close of each day\u8217\'3fs business the account of each fund will show the balance or deficit therein, and show also the total amount of the money in the state treasury, and should the books not be in balance, the daily statement shall show the amount of the surplus or deficit by which the books fail to balance.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{132;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.3}}}{\*\bkmkstart stylerid1_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record and payment of warrants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer of state shall keep a record of warrants issued as certified by the director of the department of administrative services, and receive in payment of public dues the warrants so issued in conformity with law, and redeem the same, if there be money in the treasury not otherwise appropriated, and on receiving any such warrant shall cause the person presenting it to endorse it, and shall indicate on its face in a suitable manner that it has been redeemed, and keep a record of warrants redeemed showing the name of the person to whom paid, date of payment, and amount of interest paid.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a763; R60, \'a784; C73, \'a776; C97, \'a7102; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{133;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.4}}}{\*\bkmkstart stylerid1_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Receipts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When money is paid to the treasurer, the treasurer shall execute receipts in duplicate therefor, stating the fund to which it belongs, one of which must be delivered to the director of the department of administrative services in order to obtain the proper credit, and the treasurer must be charged therewith.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a764; R60, \'a785; C73, \'a777; C97, \'a7103; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{134;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.5}}}{\*\bkmkstart stylerid1_2E5_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer shall pay no money from the treasury but upon the warrants of the director of the department of administrative services, and only in the order of their presentation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a765; R60, \'a786; C73, \'a778; C97, \'a7104; S13, \'a7104; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{135;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Warrants not paid for want of funds, }{{\f5\fs12\hyphpar0\qj{chapter 74}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.6}}}{\*\bkmkstart stylerid1_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Report to and account with director of the department of administrative services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Once in each week the treasurer shall certify to the director of the department of administrative services the number, date, amount, and payee of each warrant taken up by the treasurer, with the date when taken up, and the amount of interest allowed; and on the first Monday of January, and the first day of April, July, and October, annually, the treasurer is directed to account with the director of the department of administrative services and deposit with the department of administrative services all such warrants received at the treasury, and take the director\u8217\'3fs receipt therefor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a767; R60, \'a788; C73, \'a780; C97, \'a7106; S13, \'a7106; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{137;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.7}}}{\*\bkmkstart stylerid1_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interest on bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When interest on any bonds of the state becomes due, the treasurer shall provide funds for the payment thereof on the day and at the place where payable; and persons holding such bonds are required to present the same at such place within ten days from such day, at the expiration of which time the funds remaining unexpended and vouchers for interest paid shall be returned to the treasury.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a782; C97, \'a7108; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{138;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.7}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Deposits in general, }{{\f5\fs12\hyphpar0\qj{\'a712C.1}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.8}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Investment or deposit of surplus \u8212\'3f appropriation \u8212\'3f investment income \u8212\'3f lending securities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall invest or deposit, subject to}}}{{\f5\fs18\hyphpar0\qj{ chapters 12F}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{12H}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{12J}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{12K}}}{{\f5\fs18\hyphpar0\qj{ and as provided by law, any of the public funds not currently needed for operating expenses and shall do so upon receipt of monthly notice from the director of the department of administrative services of the amount not so needed. In the event of loss on redemption or sale of securities invested as prescribed by law, and if the transaction is reported to the executive council, neither the treasurer nor director of the department of administrative services is personally liable but the loss shall be charged against the funds which would have received the profits or interest of the investment and there is appropriated from the funds the amount so required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Investment income may be used to maintain compensating balances, pay transaction costs for investments made by the treasurer of state, and pay administrative and related overhead costs incurred by the treasurer of state in the management of money. The treasurer of state shall coordinate with the affected departments to determine how compensating balances, transaction costs, or money management and related costs will be established. All charges against a retirement system must be documented and notification of the charges shall be made to the appropriate administration of the retirement system affected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state, with the approval of the investment board of the Iowa public employees\u8217\'3f retirement system, may conduct a program of lending securities in the Iowa public employees\u8217\'3f retirement system portfolio. When securities are loaned as provided by this paragraph, the treasurer shall act in the manner provided for investment of moneys in the Iowa public employees\u8217\'3f retirement fund under }}}{{\f5\fs18\hyphpar0\qj{section 97B.7A}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state shall report at least annually to the investment board of the Iowa public employees\u8217\'3f retirement system on the program and shall provide additional information on the program upon the request of the investment board or the employees of the Iowa public employees\u8217\'3f retirement system.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{141;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1180, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 227, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1242, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 268, \'a7123}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1001, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 68, \'a71, 24}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a798, 102}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 39, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 82, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 58, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712C.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Investment or deposit, }{{\f5\fs12\hyphpar0\qj{\'a712B.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.9}}}{\*\bkmkstart stylerid1_2E5_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employee classifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to public employees listed in }{{\f5\fs18\hyphpar0\qj{section 20.4}}}{, public employees of the treasurer of state who hold positions that are classified in the administrative assistant series and executive officer series are excluded from }{{\f5\fs18\hyphpar0\qj{chapter 20}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 181, \'a739}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.10}}}{\*\bkmkstart stylerid1_2E5_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deposits by state officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except as otherwise provided, all elective and appointive state officers, boards, commissions, and departments shall, within ten days succeeding the collection, deposit with the treasurer of state, or to the credit of the treasurer of state in any depository designated by the treasurer of state, ninety percent of all fees, commissions, and moneys collected or received. The balance actually collected in cash, remaining in the hands of any officer, board, or department shall not exceed the sum of five thousand dollars and money collected shall not be held more than thirty days. }{{\f5\fs18\hyphpar0\qj{This section}}}{ does not apply to the state fair board, the state board of regents, the utilities commission, the director of health and human services, the Iowa finance authority, or to the funds received by the state racing and gaming commission under }{{\f5\fs18\hyphpar0\qj{sections 99D.7}}}{ and }{{\f5\fs18\hyphpar0\qj{99D.14}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a73778; C97, \'a7191; S13, \'a7170-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{143;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{; }{{\f5\fs18\hyphpar0\qj{83 Acts, ch 187, \'a729}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1266, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a716, 2658}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7524.207}}}{{\f5\fs12\hyphpar0\qj{, 533.111}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.11 through 12.13}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.14}}}{\*\bkmkstart stylerid1_2E5_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statement itemized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each deposit shall be accompanied by an itemized statement of the sources from which the money has been collected, and the funds to be credited, a duplicate of which shall, at the time, be filed with the department of administrative services.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7170-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{144;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.15}}}{\*\bkmkstart stylerid1_2E5_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Director and treasurer to keep account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer and director of the department of administrative services shall each keep an accurate account of the moneys so deposited.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7170-f; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{145;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.15}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.16}}}{\*\bkmkstart stylerid1_2E5_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Swampland indemnity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All swampland indemnity money paid by the federal government to this state under any Act of Congress relating thereto shall be paid by the treasurer of state to the county treasurer of the county where the land, on account of which such payment is made, is located. The county treasurer shall be liable on a bond for the safe custody of said funds and shall promptly notify the board of supervisors of the receipt thereof. Said funds shall be applied by the said supervisors as required by law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7116-d, -e, -f; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{146;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.16}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.552}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.17}}}{\*\bkmkstart stylerid1_2E5_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Biennial report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer of state shall, biennially, at the time provided by law, report to the governor the state of the treasury and exhibit therein the amount received and paid out by the treasurer since the last report, and the balance remaining in the treasury.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a768; R60, \'a789; C73, \'a781; C97, \'a7107; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{147;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.17}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Biennial reports, see }{{\f5\fs12\hyphpar0\qj{\'a77A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.18}}}{\*\bkmkstart stylerid1_2E5_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Salary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The salary of the treasurer of state shall be as fixed by the general assembly.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a7147-c1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{147.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.18}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.19}}}{\*\bkmkstart stylerid1_2E5_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Six-months limit on checks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{On the first day of each quarter of each fiscal year of the state, the state treasurer shall stop payment on and make void all treasury checks dated six months or more prior to that date, and the state treasurer shall not redeem any such check thereafter.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.19}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.20}}}{\*\bkmkstart stylerid1_2E5_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of new check.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon presentation of any check voided as provided in }{{\f5\fs18\hyphpar0\qj{section 12.19}}}{ by the holder of the check after the six-month period, the state treasurer is authorized to issue a new check for the amount of the original check to the holder.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a712.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.21}}}{\*\bkmkstart stylerid1_2E5_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Accepting credit card payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer of state may enter into an agreement with a financial institution to provide credit card receipt processing for state departments which are authorized by the treasurer of state to accept payment by credit card. A department which accepts credit card payments may adjust its fees to reflect the cost of processing as determined by the treasurer of state. A fee may be charged by a department for using the credit card payment method notwithstanding any other provision of the Code setting specific fees. The treasurer of state shall adopt rules to implement }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 120, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1126, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 219, \'a736}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.22 through 12.24}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.25}}}{\*\bkmkstart stylerid1_2E5_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legislative findings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The general assembly finds and declares that because of differences in the timing of the receipt of tax and other revenues and the expenditure of funds by the state, the state has been unable to remain timely on its obligations, including its payments of school aid; the untimely payment of state aid has created a hardship for schools by increasing their costs and hindering their ability to remain timely on their obligations; it would be advantageous to the state to be able to issue notes in anticipation of its tax and other revenues in order to coordinate its cash flow; and pending their use, the proceeds of notes issued in anticipation of tax and other revenues should be invested in order to pay the cost of issuing the notes and as a benefit to the state. It is the purpose of }{{\f5\fs18\hyphpar0\qj{this section}}}{ and }{{\f5\fs18\hyphpar0\qj{section 12.26}}}{ to enable the state to make timely payments of its obligations, including its school aid payments, by securing funds through the issuance of notes in anticipation of the state\u8217\'3fs tax and other revenues.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 34, \'a718}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.26}}}{\*\bkmkstart stylerid1_2E5_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of revenue anticipation notes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In anticipation of the collection of revenues in and for a fiscal year, the treasurer of state may borrow money, and issue notes for the money, in an amount not exceeding the estimated state revenues for that year. The sums so anticipated are appropriated for the payment of the notes with interest at maturity. The notes may be issued prior to the beginning of a fiscal year, but the notes shall be payable not later than the end of the fiscal year for which they are issued. More than one series of notes may be issued in a fiscal year and the proceeds of notes may be used to retire a prior issue of notes provided that the total outstanding at any one time shall not exceed the limit prescribed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The proceeds from the issuance of notes shall be invested in the same manner as other public funds and shall be used only for the purposes for which the anticipated tax revenues were levied, collected, and appropriated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The principal of and the interest on notes are payable solely out of the taxes and revenues of the state for the fiscal year for which the notes are issued. The notes of each issue shall be dated, shall bear interest at a rate or rates which may be variable according to a method approved by the treasurer of state, without regard to any limit contained in }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{ or any other law of this state, and shall mature at a time or times not later than the end of the fiscal year, all as determined by the treasurer of state. The notes may be made redeemable before maturity, at the option of the treasurer of state, at the price and under the terms and conditions provided by the treasurer of state. The treasurer of state shall determine the form of the notes and shall fix the denomination of the notes and the place of payment of principal and interest which may be at any bank within or without the state. The notes shall be executed by the manual or facsimile signatures of the treasurer of state, the director of the department of management, and the director of the department of administrative services. If an official whose signature or a facsimile of whose signature appears on any notes ceases to hold office before the delivery of the notes, the signature or the facsimile is valid and sufficient for all purposes the same as if the official had remained in office until the delivery. All notes issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ have the qualities and incidents of negotiable instruments under the laws of this state and without regard to any other law. The notes shall be issued in registered form. The notes may be sold in a manner, at public or private sale, as the treasurer of state may determine without regard to }}}{{\f5\fs18\hyphpar0\qj{chapter 75}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notes may be issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ without obtaining the consent of any officer or agency of this state, and without any other proceedings or conditions other than those proceedings and conditions which are specifically required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state, the director of the department of management, and the director of the department of administrative services are not liable personally on the notes or subject to any personal liability or accountability by reason of the issuance of the notes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fnotes\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means notes and other obligations, including short term obligations backed by a commercial letter of credit, issued by the treasurer of state pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 34, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1134, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a7114}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.27}}}{\*\bkmkstart stylerid1_2E5_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Credit rules.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1999/CH0073.pdf" }{\fldrslt \cf5 \f5 \fs18{{99 Acts, ch 73, \'a71}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.28}}}{\*\bkmkstart stylerid1_2E5_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Centralized financing for state agency purchase of real and personal property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinancing agreement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any lease, lease-purchase agreement, or installment acquisition contract in which the lessee may purchase the leased property at a price which is less than the fair market value of the property at the end of the lease term, or any lease, agreement, or transaction which would be considered under criteria established by the internal revenue service to be a conditional sale agreement for tax purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a board, commission, bureau, division, office, department, or branch of state government. However, state agency does not mean the state board of regents, institutions governed by the board of regents, or authorities created under }}}{{\f5\fs18\hyphpar0\qj{chapter 16}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{261A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall have sole authority to enter into financing agreements on behalf of state agencies. The treasurer of state may enter into financing agreements, including master lease-purchase agreements, for the purpose of funding state agency requests for the financing of real or personal property, wherever located within the state, including equipment, buildings, facilities, and structures, or additions or improvements to existing buildings, facilities, and structures. Subject to the selection procedures of }}}{{\f5\fs18\hyphpar0\qj{section 12.30}}}{{\f5\fs18\hyphpar0\qj{, the treasurer may employ financial consultants, banks, trustees, insurers, underwriters, accountants, attorneys, and other advisors or consultants as necessary to implement the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The costs of professional services and any other costs of entering into the financing agreements may be included in the financing agreement as a cost of the property being financed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financing agreement may provide for ultimate ownership of the property by the state. Title to all property acquired in this manner shall be taken and held in the name of the state. The state shall be the lessee or contracting party under all financing agreements entered into pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The financing agreements may contain provisions pertaining, but not limited to, interest, term, prepayment, and the state\u8217\'3fs obligation to make payments on the financing agreement beyond the current budget year subject to availability of appropriations. All projects financed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be deemed to be for an essential governmental purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may contract for additional security or liquidity for a financing agreement and may enter into agreements for letters of credit, lines of credit, insurance, or other forms of security with respect to rental and other payments due under a financing agreement. Fees for the costs of additional security or liquidity are a cost of entering into the financing agreement and may be paid from funds annually appropriated by the general assembly to the state agency for which the property is being obtained, from other funds legally available, or from proceeds of the financing agreement. The provision of a financing agreement which provides that a portion of the periodic rental or lease payment be applied as interest is subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{. Other laws relating to interest rates do not apply. }}}{{\f5\fs18\hyphpar0\qj{Chapter 75}}}{{\f5\fs18\hyphpar0\qj{ does not apply to financing agreements entered into pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Payments and other costs due under financing agreements entered into pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be payable from funds annually appropriated by the general assembly to the state agency for which the property is being obtained or from other funds legally available. The treasurer of state, in cooperation with the department of administrative services, shall implement procedures to ensure that state agencies are timely in making payments due under the financing agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum principal amount of financing agreements which the treasurer of state can enter into shall be one million dollars per state agency in a fiscal year, subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 8.46}}}{{\f5\fs18\hyphpar0\qj{. For the fiscal year, the treasurer of state shall not enter into more than one million dollars of financing agreements per state agency, not considering interest expense. However, the treasurer of state may enter into financing agreements in excess of the one million dollar per agency per fiscal year limit if a constitutional majority of each house of the general assembly, or the legislative council if the general assembly is not in session, and the governor, authorize the treasurer of state to enter into additional financing agreements above the one million dollar authorization contained in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state shall not enter into a financing agreement for real or personal property which is to be constructed for use as a prison or prison-related facility without prior authorization by a constitutional majority of each house of the general assembly and approval by the governor of the use, location, and maximum cost, not including interest expense, of the real or personal property to be financed. However, financing agreements for an energy conservation measure, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 7D.34}}}{{\f5\fs18\hyphpar0\qj{, are exempt from the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, but are subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 7D.34}}}{{\f5\fs18\hyphpar0\qj{. In addition, financing agreements funded through the materials and equipment revolving fund established in }}}{{\f5\fs18\hyphpar0\qj{section 307.47}}}{{\f5\fs18\hyphpar0\qj{ are exempt from the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall decide upon the most economical method of financing a state agency\u8217\'3fs request for funds. The treasurer of state may utilize master lease-purchase agreements, issue certificates of participation in lease-purchase agreements, or use any other financing method or method of sale which the treasurer believes will provide savings to the state in issuance or interest costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financing agreement to which the state is a party is an obligation of the state for purposes of }}}{{\f5\fs18\hyphpar0\qj{chapters 502}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{636}}}{{\f5\fs18\hyphpar0\qj{, and is a lawful investment for banks, trust companies, building and loan associations, savings and loan associations, investment companies, insurance companies, insurance associations, executors, guardians, trustees, and other fiduciaries responsible for the investment of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Publication of any notice, whether under }}}{{\f5\fs18\hyphpar0\qj{section 73A.12}}}{{\f5\fs18\hyphpar0\qj{ or otherwise, and other or further proceedings with respect to the financing agreements referred to in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are not required except as set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, notwithstanding any provisions of other statutes of the state to the contrary.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1177, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1126, \'a72, 33}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1156, \'a713, 58}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 97, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 100, \'a719, 27}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 70, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1167, \'a715}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.321}}}{{\f5\fs12\hyphpar0\qj{, 8D.11}}}{{\f5\fs12\hyphpar0\qj{, 29C.23}}}{{\f5\fs12\hyphpar0\qj{, 476.10B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.29}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.30}}}{\*\bkmkstart stylerid1_2E5_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Coordination of bonding activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthority\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a department, or public or quasi-public instrumentality of the state including but not limited to the authority created under }}}{{\f5\fs18\hyphpar0\qj{chapter 12E}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{16}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{261A}}}{{\f5\fs18\hyphpar0\qj{, which has the power to issue obligations, except that }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fauthority\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include the state board of regents or the Iowa finance authority to the extent the Iowa finance authority acts pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 260C}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthority\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also includes a port authority created under }}}{{\f5\fs18\hyphpar0\qj{chapter 28J}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fObligations\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means notes, bonds, including refunding bonds, and other evidences of indebtedness of an authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of the Code the treasurer shall coordinate the issuance of obligations by authorities. The treasurer, or the treasurer\u8217\'3fs designee, shall serve as ex officio nonvoting member of each authority. Prior to the issuance of obligations, an authority shall notify the treasurer of its intention to do so. The treasurer shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Select and fix the compensation for, in consultation with the respective authority, through a competitive selection procedure, attorneys, accountants, financial advisors, banks, underwriters, insurers, and other employees and agents which in the treasurer\u8217\'3fs judgment are necessary to carry out the authority\u8217\'3fs intention. Prior to the initial selection, the treasurer shall, after consultation with the authorities, establish a procedure which provides for a fair and open selection process including, but not limited to, the opportunity to present written proposals and personal interviews. The treasurer shall maintain a list of firms which have requested to be notified of requests for proposal. The selection criteria shall take into consideration, but are not limited to, compensation, expenses, experience with similar issues, scheduling, ability to provide the services of individuals with specific knowledge in the relevant subject matter and length of the engagement. The treasurer may waive the requirements for a competitive selection procedure for any specific employment upon written notice to the executive council stating why the waiver is in the public interest. Upon selection by the treasurer, the authority shall promptly employ the individual or firm and be responsible for payment of costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit an account to the respective authority for all costs incurred in each transaction. The treasurer will charge an authority for costs of administration. The authority shall disburse to the treasurer the amounts set forth in the account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Direct the investment or deposit of the proceeds of the sale of the obligations, in accordance with the language of the documents drafted to effectuate issuance of the obligations, except for the proceeds necessary to fund the ongoing operations of the authority. This paragraph does not apply to proceeds of obligations issued before July 1, 1986.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collect from an authority and other sources, any statistical and financial information necessary to draft an offering document or prepare a presentation necessary for the issuance or marketing of the obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each respective authority shall consult with the treasurer on the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amount, terms, and conditions of the obligations to be issued by the authority including other provisions deemed necessary by the treasurer or the authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The documents or instruments necessary to effectuate issuance of the obligation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Presentations to rating agencies and marketing activities. The treasurer may choose to participate in these presentations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Professional services, including but not limited to attorneys, accountants, financial advisors, banks, underwriters, insurers, and other employees employed by a project sponsor may be selected by the project sponsor, if the obligation is issued in behalf of the project sponsor and the purchaser of the obligation does not have recourse to the authority or state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7824}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1254, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1208, \'a719, 25}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 150, \'a788}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 178, \'a742, 64}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1156, \'a714, 58}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 97, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 100, \'a720, 27}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 46, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 70, \'a717}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.321}}}{{\f5\fs12\hyphpar0\qj{, 8D.11}}}{{\f5\fs12\hyphpar0\qj{, 12.28}}}{{\f5\fs12\hyphpar0\qj{, 12A.13}}}{{\f5\fs12\hyphpar0\qj{, 12E.5}}}{{\f5\fs12\hyphpar0\qj{, 12E.14}}}{{\f5\fs12\hyphpar0\qj{, 76.15}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E2_2E2}{LINKED INVESTMENTS}{\*\bkmkend stylerid1_2E6_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.31}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subchapter}}}{ shall be known as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLinked Investments for Tomorrow Act\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1096, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 234, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1058, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1165, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.32}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible borrower\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person who is qualified to participate in one of the programs in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible borrower\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a person who has been determined to be delinquent in making child support payments or any other payments due the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible lending institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a financial institution that is empowered to make commercial loans and is eligible pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 12C}}}{{\f5\fs18\hyphpar0\qj{ to be a depository of state funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLinked investment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a certificate of deposit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ to the treasurer of state by an eligible lending institution, at an interest rate not more than three percent below current market rate on the condition that the institution agrees to lend the value of the deposit, according to the investment agreement provided in }}}{{\f5\fs18\hyphpar0\qj{section 12.35}}}{{\f5\fs18\hyphpar0\qj{, to an eligible borrower at a rate not to exceed four percent above the rate paid on the certificate of deposit. The treasurer of state shall determine and make available the current market rate which shall be used each month.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1096, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 234, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1058, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 195, \'a71, 2, 10}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 177, \'a71, 9}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1058, \'a74, 5}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 24, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1165, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.36}}}{{\f5\fs12\hyphpar0\qj{, 466.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.33}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public policy.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2006/CH1165.pdf" }{\fldrslt \cf5 \f5 \fs18{{2006 Acts, ch 1165, \'a78}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.34}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Linked investments \u8212\'3f limitations \u8212\'3f rules \u8212\'3f maturity and renewal of certificates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may invest up to the lesser of one hundred eight million dollars or twenty-five percent of the balance of the state pooled money fund in certificates of deposit in eligible lending institutions as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. One-half of the moneys invested pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be made available under the program implemented pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.43}}}{{\f5\fs18\hyphpar0\qj{ to increase the availability of lower cost moneys for purposes of injecting needed capital into small businesses which are fifty-one percent or more owned, operated, and actively managed by one or more women, veterans, minority persons, or persons with disabilities. The treasurer shall invest the remaining one-half of the moneys invested pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to support any other eligible applicant as provided in }}}{{\f5\fs18\hyphpar0\qj{section 12.43}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDisability\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 15.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMinority person\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 15.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fVeteran\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who served on federal active duty, other than training, in the armed forces of the United States and who was released or discharged under any circumstances other than dishonorable conditions, or who meets the definition of }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fveteran\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ in }}}{{\f5\fs18\hyphpar0\qj{section 35.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate of deposit that is issued to the treasurer of state by an eligible lending institution on or after July 1, 2006, may be renewed at the option of the treasurer on an annual basis for a total term not to exceed five years. All participants with certificates of deposit issued prior to July 1, 2006, are subject, for renewal certificates of deposit, to the requirements and terms applicable to the certificates of deposit issued prior to July 1, 2006.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1096, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 234, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1058, \'a72, 3, 9, 10, 12}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 195, \'a74, 10}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 177, \'a72, 7, 9}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1165, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 139, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1140, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.35}}}{\*\bkmkstart stylerid1_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Agreement \u8212\'3f loan applications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An eligible lending institution that desires to receive a linked investment shall enter into an agreement with the treasurer of state, which shall include requirements necessary for the eligible lending institution to comply with }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An eligible lending institution that desires to receive a linked investment shall accept and review applications for loans from eligible borrowers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The eligible lending institution shall forward to the treasurer of state a linked investment loan package in the form and manner as prescribed by the treasurer of state. The package shall include information required by the treasurer of state, including but not limited to the amount of the loan requested and the purpose of the loan. The institution shall certify that the applicant is an eligible borrower.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1096, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 234, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1058, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 24, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1165, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.32}}}{{\f5\fs12\hyphpar0\qj{, 12.43}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.36}}}{\*\bkmkstart stylerid1_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Actions by treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall accept or reject a linked investment loan package or any portion of the package based on the type or terms of the loan involved, the availability of state funds, or the compliance of the eligible borrower or eligible lending institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon acceptance of the linked investment loan package or any portion of the package, the treasurer of state shall deposit funds with the eligible lending institution and the eligible lending institution shall issue to the treasurer of state one or more certificates of deposit with interest at a rate determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.32, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state shall not deposit funds with an eligible lending institution pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, unless the certificate of deposit earns a rate of interest of at least one percent. Interest earned on the certificate of deposit and principal not renewed shall be remitted to the treasurer of state at the time the certificate of deposit matures. Interest from the linked investments for tomorrow program shall be considered earnings of the general fund of the state. Certificates of deposit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ are not subject to a penalty for early withdrawal.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1096, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 234, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1105, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1058, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 24, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1165, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.37}}}{\*\bkmkstart stylerid1_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Loans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the placement of a linked investment with an eligible lending institution, the institution is required to lend the funds to the eligible borrower listed in the linked investment loan package and in accordance with the investment agreement. The loan shall be at a rate not more than four percent above the rate paid the treasurer by the financial institution. The eligible lending institution shall be required to submit a certification of compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in the form and manner as prescribed by the treasurer of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall take all steps necessary to implement the linked investments for tomorrow program and monitor compliance of eligible lending institutions and eligible borrowers.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1096, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 234, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.38}}}{\*\bkmkstart stylerid1_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{By February 1 of each year, the treasurer of state shall report on the linked investments for tomorrow programs for the preceding calendar year to the governor, the economic development authority, the speaker of the house of representatives, and the president of the senate. The speaker of the house shall transmit copies of this report to the house co-chairperson of the joint economic development appropriations subcommittee and the chairpersons of the standing committees in the house which customarily consider legislation regarding agriculture, commerce, and economic growth, and the president of the senate shall transmit copies of this report to the senate co-chairperson of the joint economic development appropriations subcommittee and the chairpersons of the standing committees in the senate which customarily consider legislation regarding agriculture, commerce, and economic growth. The report shall set forth the linked investments made by the treasurer of state under the program during the year, the total amount deposited, the number of deposits, and an estimate of foregone interest, and shall include information regarding the nature, terms, and amounts of the loans upon which the linked investments were based and a listing of eligible borrowers to which the loans were made.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1096, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 234, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1188, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1058, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1165, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.39}}}{\*\bkmkstart stylerid1_2E6_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Liability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state and the treasurer of state are not liable to an eligible lending institution in any manner for payment of the principal or interest on the loan to an eligible borrower. Any delay in payments or default on the part of an eligible borrower does not in any manner affect the investment agreement between the eligible lending institution and the treasurer of state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1096, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1168, \'a76}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.40 and 12.41}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2006/CH1165.pdf" }{\fldrslt \f5 \fs18{{2006 Acts, ch 1165, \'a78}}}}}}{{\f5\fs18\qj{2006 Acts, ch 1165, \'a78}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.42}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.43}}}{\*\bkmkstart stylerid1_2E6_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Small business linked investments program created \u8212\'3f definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer of state shall adopt rules to implement a small business linked investments program to increase the availability of lower cost funds to inject needed capital into small businesses owned and operated in this state by residents of this state, which is the public policy of the state. The rules shall be in accordance with the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsmall business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A new or existing small business that meets all the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For applications to transfer an existing small business to a new owner, the small business must also meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ when local competition does not exist in the principal area of business activity of the existing small business, and the loss of the existing small business would result in a hardship on the community.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Loan applications for a new or existing small business shall be for the purchase of land, improvements, fixtures, machinery, inventory, supplies, equipment, information technology, or licenses, or patent, trademark, or copyright fees and expenses. Loan applications for the transfer of an existing small business shall be to assist in the transfer of ownership of a retail, wholesale, manufacturing, service, or agricultural business that may close in the absence of sufficient financial assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During the lifetime of this loan program, the maximum amount of assistance that an eligible borrower or business may borrow or receive through this loan program shall be two hundred thousand dollars. An eligible borrower or business under this program shall be limited to one loan from one financial institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A preference shall be given to those persons who are less able than other persons to secure funds for a small business without participation in the small business linked investment program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to qualify under this program, all owners of the business or borrowers must not have a combined net worth exceeding nine hundred seventy-five thousand dollars as defined in rules adopted by the treasurer of state pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ and the small business must meet all of the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be a for-profit business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an application involves an existing business or the transfer of an existing business to a new owner, the business must have annual gross sales of two million dollars or less at the time the application is submitted under }}}{{\f5\fs18\hyphpar0\qj{section 12.35}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not be operated out of the home of any person, unless the person is eligible for a deduction on federal income taxes pursuant to 26 U.S.C. \'a7280A.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not involve real estate investments, rental of real estate, leasing of real estate, or real estate speculation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Liquor, beer, and wine sales must not exceed twenty percent of annual sales for establishments holding a class \u8220\'3fC\u8221\'3f retail alcohol license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.30}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an application involves the transfer of an existing small business, the transfer must be by purchase, lease-purchase, or contract of sale. The purchase must be for all or a portion of the business which is essential to its continued viability, including land where the business is located, fixtures attached to the land, machinery, inventory, supplies, equipment, information technology, or licenses, patents, trademarks, copyrights, or other intellectual property relied upon by the business, and inventory for sale by the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Loan proceeds shall not be used to refinance existing debt, including credit card debt. However, proceeds may be used to refinance a short-term bridge loan made in anticipation of the treasurer of state\u8217\'3fs approval of the linked investment loan package.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eligible lending institutions shall verify the borrower is eligible to participate under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ pursuant to rules adopted by the treasurer of state pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 233, \'a7128}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1273, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 234, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1201, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 195, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1165, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1184, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a790, 102}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.34}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.43A and 12.43B}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2006/CH1165.pdf" }{\fldrslt \f5 \fs18{{2006 Acts, ch 1165, \'a78}}}}}}{{\f5\fs18\qj{2006 Acts, ch 1165, \'a78}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER III}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E2_2E2}{TARGETED SMALL BUSINESSES \u8212\'3f WAIVER OF BOND REQUIREMENT}{\*\bkmkend stylerid1_2E7_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.44}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa satisfaction and performance bond program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agencies of state government shall be required to waive the requirement of satisfaction, performance, surety, or bid bonds for targeted small businesses which are able to demonstrate the inability of securing such a bond because of a lack of experience, lack of net worth, or lack of capital. This waiver shall not apply to businesses with a record of repeated failure of substantial performance or material breach of contract in prior circumstances. The waiver shall be applied only to a project or individual transaction amounting to fifty thousand dollars or less, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 573.2}}}{{\f5\fs18\hyphpar0\qj{. In order to qualify, the targeted small business shall provide written evidence to the economic development authority that the bond would otherwise be denied the business. The granting of the waiver shall in no way relieve the business from its contractual obligations and shall not preclude the state agency from pursuing any remedies under law upon default or breach of contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The economic development authority shall certify targeted small businesses for eligibility and participation in this program and shall make this information available to other state agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subdivisions of state government may also grant such a waiver under similar circumstances.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 233, \'a7129}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1273, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1156, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1244, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 160, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7573.2}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.45 through 12.50}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E2_2E2}{OPIOID SETTLEMENT FUND}{\*\bkmkend stylerid1_2E8_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.51}}}{\*\bkmkstart stylerid1_2E8_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Opioid settlement fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdministrative services organization\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 225A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBehavioral health district\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 225A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDistrict behavioral health advisory council\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 225A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An opioid settlement fund is created in the office of the treasurer of state. The fund shall be separate from the general fund of the state and the balance in the fund shall not be considered part of the balance of the general fund of the state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state portion of any moneys paid to the state as a result of a national settlement of litigation with entities that manufactured, marketed, sold, distributed, dispensed, or promoted opioids, made in connection with claims arising from the manufacturing, marketing, selling, distributing, dispensing, or promoting of opioids, shall be deposited in the fund.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each fiscal year for the period beginning July 1, 2025, and ending June 30, 2030, of the total amount of the state portion of the moneys paid to the state as described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and deposited in the fund, plus any interest and earnings on moneys in the fund, seventy-five percent is appropriated to the department and twenty-five percent is appropriated to the office of the attorney general for purposes of abating the opioid crisis in this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys appropriated under subparagraph division (a) that remain unencumbered and unobligated at the close of each fiscal year shall not revert but shall remain available for expenditure for the purposes designated until June 30, 2030.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the interest or earnings on moneys appropriated under subparagraph division (a) are appropriated to the entity receiving the appropriation to be used for the purposes designated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department and the office of the attorney general shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review each administrative services organization\u8217\'3fs proposed uses of the appropriated moneys for crisis response, early intervention, and treatment for opioid addiction, and recovery from opioid addiction, for the behavioral health district for which the administrative services organization has been designated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disburse the moneys appropriated under subparagraph (2), subparagraph division (a), in accordance with the national opioid settlement agreements and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identify indicators and outcomes applicable to each disbursement to be used to determine if the services and activities that are funded achieve the intended outcomes, which may include prevention of opioid-related deaths, reduction of opioid misuse, and increased access to opioid use disorder medications and services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit an annual report on or before November 1 to the general assembly and the governor that contains all of the following for the immediately preceding fiscal year:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information related to each disbursement from the fund, and if the intended outcomes of each disbursement were achieved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Input from each district behavioral health advisory council regarding disbursements from the fund, intended outcomes, and recommendations for future disbursements from the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list of the current opioid-related initiatives within the behavioral health district that are funded by moneys from the national settlements that are earmarked for or otherwise required to be transferred or distributed to counties, cities, or other local governmental entities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A recipient shall receive no more than one disbursement under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), subparagraph division (b).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department and the office of the attorney general may, but are not required to, ensure that moneys appropriated under subparagraph (2) are distributed equally to the administrative services organizations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department and the office of the attorney general shall use no more than two and one-half percent of the moneys appropriated under subparagraph (2) for administrative costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to such moneys paid to the state that are earmarked for or otherwise required to be transferred or distributed to counties, cities, or other local governmental entities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund shall not be transferred, used, obligated, appropriated, or otherwise encumbered except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund shall only be used for purposes of abating the opioid crisis in this state, which may include but are not limited to the purposes specified in }}}{{\f5\fs18\hyphpar0\qj{section 135.190A}}}{{\f5\fs18\hyphpar0\qj{ for moneys in the opioid antagonist medication fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys in the fund that remain unencumbered or unobligated at the close of a fiscal year shall not revert. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1121, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 150, \'a71}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.52 through 12.60}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER V}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E2_2E2}{STATE-SPONSORED CREDIT CARD}{\*\bkmkend stylerid1_2E9_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.61}}}{\*\bkmkstart stylerid1_2E9_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State-sponsored credit card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinancial institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a state bank as defined in }}}{{\f5\fs18\hyphpar0\qj{section 524.103}}}{{\f5\fs18\hyphpar0\qj{, a federally chartered state bank having its principal office within this state, a federally chartered credit union having its principal office within this state, a federally chartered savings and loan association having its principal office within the state, a credit union organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 533}}}{{\f5\fs18\hyphpar0\qj{, or a trust company organized or incorporated under the laws of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinancial institution credit card\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a credit card that entitles the holder to make open-account purchases up to an approved amount and is issued through the agency of a financial institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSponsoring entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an entity that allows its name or logo to be used on a particular financial institution credit card in exchange for a fee from the credit card issuer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer is authorized to participate in a financial institution credit card program for the benefit of the state. Within six months of May 27, 1989, the treasurer shall contact each financial institution to determine if:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financial institution or its Iowa holding company or Iowa affiliate currently administers a credit card program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The credit card program provides a fee or commission on retail sales to the sponsoring entity for the issuance and use of the credit card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The credit card program would accept the state as a sponsoring entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the treasurer determines that the state may be a sponsoring entity for a financial institution credit card, the treasurer shall negotiate the most favorable rate for the state\u8217\'3fs fee by a credit card issuer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state shall not offer a more favorable rate to any other credit card issuer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rate must be expressed as a percentage of the gross sales from the use of the credit card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of the fee shall be deposited in the Iowa resources enhancement and protection fund created under }}}{{\f5\fs18\hyphpar0\qj{section 455A.18}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer shall recommend a logo or design for the state-sponsored credit card indicating the use for which the revenues will be used.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In selecting a credit card issuer, the treasurer shall consider the issuer\u8217\'3fs record of investments in the state, shall take into consideration credit card features which will enhance the promotion of the state-sponsored credit card including, but not limited to, favorable interest rates, annual fees, and other fees for using the card, and shall require that the card be available to any person who qualifies for a credit card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon entering into an agreement with the financial institution, the treasurer shall notify all state agencies then possessing a credit card to obtain the new state-sponsored credit card.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 236, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1255, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1062, \'a71}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VI}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{TECHNICAL INFORMATION AND ASSISTANCE}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.62}}}{\*\bkmkstart stylerid1_2E1_30_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Investments by agencies and political subdivisions \u8212\'3f technical information and assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer of state shall adopt rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ for providing technical information and assistance to political subdivisions, the state board of regents, instrumentalities, and agencies of the state authorized to invest funds which are seeking to invest public funds. The treasurer or the treasurer\u8217\'3fs designee shall provide technical information and assistance to a political subdivision, the state board of regents, or an instrumentality, or agency of the state authorized to invest funds at the request of the political subdivision, the state board of regents, or an instrumentality, or agency of the state authorized to invest funds, including but not limited to technical information regarding the statutory requirements for investments by the political subdivision, the state board of regents, or an instrumentality, or agency and technical assistance to enable the political subdivision, the state board of regents, or an instrumentality, or agency to invest funds in accordance with state law. However, the fact that information and assistance are provided under }{{\f5\fs18\hyphpar0\qj{this section}}}{ to a political subdivision, the state board of regents, or an instrumentality, or agency authorized to invest funds shall not make the state, the treasurer of state, or the treasurer\u8217\'3fs designee liable to a political subdivision, the state board of regents, or an instrumentality, or agency of the state in any manner for any loss, damage, or expense incurred by the political subdivision, the state board of regents, or an instrumentality, or agency as a result of an investment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1156, \'a75}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.63 and 12.64}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_2E2_2E2}{HEALTHY IOWANS TOBACCO TRUST}{\*\bkmkend stylerid1_2E11_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.65}}}{\*\bkmkstart stylerid1_2E11_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Healthy Iowans tobacco trust.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1186.pdf" }{\fldrslt \cf5 \f5 \fs18{{2008 Acts, ch 1186, \'a718, 19}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{\'a712E.3A}}}{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.66 through 12.70}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VIII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E12_2E2_2E2}{VISION IOWA PROGRAM}{\*\bkmkend stylerid1_2E12_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.71}}}{\*\bkmkstart stylerid1_2E12_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General and specific bonding powers \u8212\'3f vision Iowa program \u8212\'3f future repeal.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by its own terms; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2016/CH1115.pdf" }{\fldrslt \cf5 \f5 \fs18{{2016 Acts, ch 1115, \'a71}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section repealed August 15, 2020, pursuant to terms of former subsection 12.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.72}}}{\*\bkmkstart stylerid1_2E12_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vision Iowa fund and reserve funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vision Iowa fund is created and established as a separate and distinct fund in the state treasury. The moneys in the fund are appropriated to the economic development authority board for purposes of the vision Iowa program established in }}}{{\f5\fs18\hyphpar0\qj{section 15F.302}}}{{\f5\fs18\hyphpar0\qj{. Moneys in the fund shall not be subject to appropriation for any other purpose by the general assembly, but shall be used only for the purposes of the vision Iowa fund. The treasurer of state shall act as custodian of the fund and disburse moneys contained in the fund as directed by the economic development authority board, including automatic disbursements of funds received pursuant to the terms of bond indentures and documents and security provisions to trustees. The fund shall be administered by the economic development authority board which shall make expenditures from the fund consistent with the purposes of the vision Iowa program without further appropriation. An applicant under the vision Iowa program shall not receive more than seventy-five million dollars in financial assistance from the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue for the vision Iowa fund shall include, but is not limited to, the following, which shall be deposited with the treasurer of state or the treasurer\u8217\'3fs designee as provided by any bond or security documents and credited to the fund:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of bonds issued to capitalize and pay the costs of the fund and investment earnings on the proceeds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest attributable to investment of money in the fund or an account of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the form of a devise, gift, bequest, donation, federal or other grant, reimbursement, repayment, judgment, transfer, payment, or appropriation from any source intended to be used for the purposes of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys in the vision Iowa fund that remain unencumbered or unobligated at the close of a fiscal year shall be deposited in the rebuild Iowa infrastructure fund created in }}}{{\f5\fs18\hyphpar0\qj{section 8.57}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may create and establish one or more special funds, to be known as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbond reserve funds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to secure one or more issues of bonds or notes issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.71, Code 2020}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state shall pay into each bond reserve fund any moneys appropriated and made available by the state or the treasurer for the purpose of the fund, any proceeds of sale of notes or bonds to the extent provided in the resolutions authorizing their issuance, and any other moneys which may be available to the treasurer for the purpose of the fund from any other sources. All moneys held in a bond reserve fund, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall be used as required solely for the payment of the principal of bonds secured in whole or in part by the fund or of the sinking fund payments with respect to the bonds, the purchase or redemption of the bonds, the payment of interest on the bonds, or the payments of any redemption premium required to be paid when the bonds are redeemed prior to maturity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in a bond reserve fund shall not be withdrawn from it at any time in an amount that will reduce the amount of the fund to less than the bond reserve fund requirement established for the fund, as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, except for the purpose of making, with respect to bonds secured in whole or in part by the fund, payment when due of principal, interest, redemption premiums, and the sinking fund payments with respect to the bonds for the payment of which other moneys of the treasurer are not available. Any income or interest earned by, or incremental to, a bond reserve fund due to the investment of it may be transferred by the treasurer to other funds or accounts to the extent the transfer does not reduce the amount of that bond reserve fund below the bond reserve fund requirement for it.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall not at any time issue bonds, secured in whole or in part by a bond reserve fund if, upon the issuance of the bonds, the amount in the bond reserve fund will be less than the bond reserve fund requirement for the fund, unless the treasurer at the time of issuance of the bonds deposits in the fund from the proceeds of the bonds issued or from other sources an amount which, together with the amount then in the fund, will not be less than the bond reserve fund requirement for the fund. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbond reserve fund requirement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, as of any particular date of computation, an amount of money, as provided in the resolutions authorizing the bonds with respect to which the fund is established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To assure the continued solvency of any bonds secured by the bond reserve fund, provision is made in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for the accumulation in each bond reserve fund of an amount equal to the bond reserve fund requirement for the fund. In order further to assure maintenance of the bond reserve funds, the treasurer shall, on or before January 1 of each calendar year, make and deliver to the governor the treasurer\u8217\'3fs certificate stating the sum, if any, required to restore each bond reserve fund to the bond reserve fund requirement for that fund. Within thirty days after the beginning of the session of the general assembly next following the delivery of the certificate, the governor shall submit to both houses printed copies of a budget including the sum, if any, required to restore each bond reserve fund to the bond reserve fund requirement for that fund. Any sums appropriated by the general assembly and paid to the treasurer pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited by the treasurer in the applicable bond reserve fund.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a77, 8}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2001/CH0005.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2001 Acts, 1st Ex, ch 5, \'a73, 7}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1030, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1115, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7137}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 167, \'a75, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.75}}}{{\f5\fs12\hyphpar0\qj{, 12.76}}}{{\f5\fs12\hyphpar0\qj{, 12.77}}}{{\f5\fs12\hyphpar0\qj{, 15F.301}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.73}}}{\*\bkmkstart stylerid1_2E12_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vision Iowa fund moneys \u8212\'3f administrative costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{During the term of the vision Iowa program established in }{{\f5\fs18\hyphpar0\qj{section 15F.302}}}{, two hundred thousand dollars of the moneys deposited each fiscal year in the vision Iowa fund and appropriated for the vision Iowa program shall be allocated each fiscal year to the economic development authority for administrative costs incurred by the authority for purposes of administering the vision Iowa program.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1225, \'a731, 38, 39}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 185, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.74}}}{\*\bkmkstart stylerid1_2E12_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pledges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is the intention of the general assembly that a pledge made in respect of bonds or notes shall be valid and binding from the time the pledge is made, that the money or property so pledged and received after the pledge by the treasurer of state shall immediately be subject to the lien of the pledge without physical delivery or further act, and that the lien of the pledge shall be valid and binding as against all parties having claims of any kind in tort, contract, or otherwise against the treasurer of state whether or not the parties have notice of the lien.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1232, \'a742}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 24, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 185, \'a735, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.75}}}{{\f5\fs12\hyphpar0\qj{, 12.77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.75}}}{\*\bkmkstart stylerid1_2E12_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Projects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The economic development authority board may undertake a project for two or more applicants jointly or for any combination of applicants, and may combine for financing purposes, with the consent of all of the applicants which are involved, the project and some or all future projects of any applicant, and }}}{{\f5\fs18\hyphpar0\qj{section 12.71, Code 2020}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 12.72}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{12.74}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{sections 12.76}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{12.77}}}{{\f5\fs18\hyphpar0\qj{ apply to and for the benefit of the economic development authority board and the joint applicants. However, the money set aside in a fund or funds pledged for any series or issue of bonds or notes shall be held for the sole benefit of the series or issue separate and apart from money pledged for another series or issue of bonds or notes of the treasurer of state. To facilitate the combining of projects, bonds or notes may be issued in series under one or more resolutions or trust agreements and may be fully open-ended, thus providing for the unlimited issuance of additional series, or partially open-ended, limited as to additional series.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fapplicant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a city or county or public organization applying for financial assistance under the vision Iowa program established in }}}{{\f5\fs18\hyphpar0\qj{section 15F.302}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1115, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7138}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.76}}}{\*\bkmkstart stylerid1_2E12_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Bonds or notes issued pursuant to }{{\f5\fs18\hyphpar0\qj{section 12.71, Code 2020}}}{, are not debts of the state, nor of any political subdivision of the state, and do not constitute a pledge of the faith and credit of the state or a charge against the general credit or general fund of the state. The issuance of any bonds or notes pursuant to }{{\f5\fs18\hyphpar0\qj{section 12.71, Code 2020}}}{, by the treasurer of state does not directly, indirectly, or contingently obligate the state or a political subdivision of the state to apply moneys from, or to levy or pledge any form of taxation whatever to, the payment of the bonds or notes. Bonds and notes issued under }{{\f5\fs18\hyphpar0\qj{section 12.71, Code 2020}}}{, are payable solely and only from the sources and special fund provided in }{{\f5\fs18\hyphpar0\qj{section 12.72}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a719}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 22, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.75}}}{{\f5\fs12\hyphpar0\qj{, 12.77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.77}}}{\*\bkmkstart stylerid1_2E12_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 12.71}}}{, Code 2020, and sections }{{\f5\fs18\hyphpar0\qj{12.72 through 12.76}}}{, being necessary for the welfare of this state and its inhabitants, shall be liberally construed to effect the purposes of the sections.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.78}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IX}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E13_2E2_2E2}{PRISON INFRASTRUCTURE}{\*\bkmkend stylerid1_2E13_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.79}}}{\*\bkmkstart stylerid1_2E13_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{FY 2009 prison bonding fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An FY 2009 prison bonding fund is created as a separate fund in the state treasury. Moneys in the fund shall not be subject to appropriation for any other purpose by the general assembly, but shall be used only for the purposes of the FY 2009 prison bonding fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue for the fund shall consist of the net proceeds from the bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.80}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund in a fiscal year shall be used as appropriated by the general assembly for prison improvement and prison construction projects. However, for the fiscal year beginning July 1, 2016, any unobligated and unencumbered moneys in the fund from the previous fiscal year are appropriated to the department of corrections for major maintenance projects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund are not subject to }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annually, on or before January 15 of each year, the department of corrections shall report to the legislative services agency and the department of management the status of all projects completed or in progress. The report shall include a description of the project, the work completed, the total estimated cost of the project, a list of all revenue sources being used to fund the project, the amount of funds expended, the amount of funds obligated, and the date the project was completed or an estimated completion date of the project, where applicable.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1179, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1133, \'a721}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.80}}}{\*\bkmkstart stylerid1_2E13_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General and specific bonding powers \u8212\'3f prison infrastructure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state is authorized to issue bonds to provide prison infrastructure financing as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Bonds shall be issued in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 12A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are payable solely and only out of the moneys, assets, or revenues of the prison infrastructure fund established in }}}{{\f5\fs18\hyphpar0\qj{section 602.8108A}}}{{\f5\fs18\hyphpar0\qj{, and other moneys available as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, all of which may be deposited with trustees or depositories in accordance with bond or security documents, and are not an indebtedness of this state, or a charge against the general credit or general fund of the state, and the state shall not be liable for the bonds except from amounts on deposit in the prison infrastructure fund and other moneys available as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall contain a statement that the bonds do not constitute an indebtedness of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are declared to be issued for an essential public and governmental purpose and all bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be exempt from taxation by the state of Iowa and the interest on the bonds shall be exempt from the state income tax and the state inheritance tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The net proceeds from the bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited into the FY 2009 prison bonding fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall cooperate with the department of corrections in the implementation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to assure maintenance of bond reserve funds, an issuer shall, on or before January 1 of each calendar year, make and deliver to the governor the issuer\u8217\'3fs certificate stating the sum, if any, required to restore each bond reserve fund to the bond reserve fund requirement for that fund. Within thirty days after the beginning of the session of the general assembly next following the delivery of the certificate, the governor shall submit to both houses printed copies of a budget including the sum, if any, required to restore each bond reserve fund to the bond reserve fund requirement for that fund. Any sums appropriated by the general assembly and paid to the issuer pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited by the issuer in the applicable bond reserve fund.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1179, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1138, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1076, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.79}}}{{\f5\fs12\hyphpar0\qj{, 422.7(2)(g)}}}{{\f5\fs12\hyphpar0\qj{, 602.8108A}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER X}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E14_2E2_2E2}{SCHOOL INFRASTRUCTURE PROGRAM }{\*\bkmkend stylerid1_2E14_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.81}}}{\*\bkmkstart stylerid1_2E14_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General and specific bonding powers \u8212\'3f school infrastructure program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may issue bonds for purposes of the school infrastructure program established in }}}{{\f5\fs18\hyphpar0\qj{section 292.2}}}{{\f5\fs18\hyphpar0\qj{. Excluding the issuance of refunding bonds, the treasurer of state shall not issue bonds which result in the deposit of bond proceeds of more than fifty million dollars into the school infrastructure fund. The treasurer of state shall have all of the powers which are necessary to issue and secure bonds and carry out the purposes of the fund. The treasurer of state may issue bonds in principal amounts which are necessary to provide funds for the fund as provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the payment of interest on the bonds, the establishment of reserves to secure the bonds, the costs of issuance of the bonds, other expenditures of the treasurer of state incident to and necessary or convenient to carry out the bond issue for the fund, and all other expenditures of the treasurer of state necessary or convenient to administer the fund. The bonds are investment securities and negotiable instruments within the meaning of and for purposes of the uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are payable solely and only out of the moneys, assets, or revenues of the school infrastructure fund and any bond reserve funds, all of which may be deposited with trustees or depositories in accordance with bond or security documents and pledged by the treasurer of state to the payment thereof. Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall contain on their face a statement that the bonds do not constitute an indebtedness of the state. The treasurer of state shall not pledge the credit or taxing power of this state or any political subdivision of this state or make bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ payable out of any moneys except those in the school infrastructure fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of bonds issued by the treasurer of state and not required for immediate disbursement may be deposited with a trustee or depository as provided in the bond documents and invested or reinvested in any investment approved by the treasurer of state and specified in the trust indenture, resolution, or other instrument pursuant to which the bonds are issued without regard to any limitation otherwise provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bonds shall be:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a form, issued in denominations, executed in a manner, and payable over terms and with rights of redemption, and be subject to such other terms and conditions as prescribed in the trust indenture, resolution, or other instrument authorizing their issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Negotiable instruments under the laws of the state and may be sold at prices, at public or private sale, and in a manner, as prescribed by the treasurer of state. }}}{{\f5\fs18\hyphpar0\qj{Chapters 73A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{74}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{74A}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{75}}}{{\f5\fs18\hyphpar0\qj{ do not apply to the sale or issuance of the bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the terms, conditions, and covenants providing for the payment of the principal, redemption premiums, if any, interest, and other terms, conditions, covenants, and protective provisions safeguarding payment, not inconsistent with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and as determined by the trust indenture, resolution, or other instrument authorizing their issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bonds are securities in which public officers and bodies of this state; political subdivisions of this state; insurance companies and associations and other persons carrying on an insurance business; banks, trust companies, savings associations, and investment companies; administrators, guardians, executors, trustees, and other fiduciaries; and other persons authorized to invest in bonds or other obligations of the state, may properly and legally invest funds, including capital, in their control or belonging to them.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds must be authorized by a trust indenture, resolution, or other instrument of the treasurer of state. However, a trust indenture, resolution, or other instrument authorizing the issuance of bonds may delegate to an officer of the issuer the power to negotiate and fix the details of an issue of bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Neither the resolution, trust agreement, nor any other instrument by which a pledge is created needs to be recorded or filed under the Iowa uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554}}}{{\f5\fs18\hyphpar0\qj{, to be valid, binding, or effective.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are declared to be issued for a general public and governmental purpose and all bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be exempt from taxation by the state of Iowa and the interest on the bonds shall be exempt from the state income tax and the state inheritance tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the terms of any bond documents, moneys in the school infrastructure fund may be expended for administration expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may issue bonds for the purpose of refunding any bonds or notes issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ then outstanding, including the payment of any redemption premiums thereon and any interest accrued or to accrue to the date of redemption of the outstanding bonds or notes. Until the proceeds of bonds issued for the purpose of refunding outstanding bonds or notes are applied to the purchase or retirement of outstanding bonds or notes or the redemption of outstanding bonds or notes, the proceeds may be placed in escrow and be invested and reinvested in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The interest, income, and profits earned or realized on an investment may also be applied to the payment of the outstanding bonds or notes to be refunded by purchase, retirement, or redemption. After the terms of the escrow have been fully satisfied and carried out, any balance of proceeds and interest earned or realized on the investments may be returned and deposited in the school infrastructure fund. All refunding bonds shall be issued and secured and subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in the same manner and to the same extent as other bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1119, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1138, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1076, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57F}}}{{\f5\fs12\hyphpar0\qj{, 12.82}}}{{\f5\fs12\hyphpar0\qj{, 12.85}}}{{\f5\fs12\hyphpar0\qj{, 12.86}}}{{\f5\fs12\hyphpar0\qj{, 422.7(2)(b)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.82}}}{\*\bkmkstart stylerid1_2E14_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{School infrastructure fund and reserve funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school infrastructure fund is created and established as a separate and distinct fund in the state treasury under the control of the department of education. Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the fund shall be used for purposes of the school infrastructure program established in }}}{{\f5\fs18\hyphpar0\qj{section 292.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue for the school infrastructure fund shall include, but is not limited to, the following, which shall be deposited with the treasurer of state or its designee as provided by any bond or security documents and credited to the fund:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of bonds issued to capitalize and pay the costs of the fund and investment earnings on the proceeds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest attributable to investment of money in the fund or an account of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the form of a devise, gift, bequest, donation, federal or other grant, reimbursement, repayment, judgment, transfer, payment, or appropriation from any source intended to be used for the purposes of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the school infrastructure fund are not subject to }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any amounts remaining in the school infrastructure fund at the end of the fiscal year beginning July 1, 2010, and for each fiscal year thereafter, which are determined by the treasurer of state to be unencumbered and unobligated and otherwise unnecessary to make the payments for such fiscal year, shall be transferred to the rebuild Iowa infrastructure fund created in }}}{{\f5\fs18\hyphpar0\qj{section 8.57}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may create and establish one or more special funds, to be known as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbond reserve funds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to secure one or more issues of bonds or notes issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.81}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state shall pay into each bond reserve fund any moneys appropriated and made available by the state or the treasurer for the purpose of the fund, any proceeds of sale of notes or bonds to the extent provided in the resolutions authorizing their issuance, and any other moneys which may be available to the treasurer for the purpose of the fund from any other sources. All moneys held in a bond reserve fund, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall be used as required solely for the payment of the principal of bonds secured in whole or in part by the fund or of the sinking fund payments with respect to the bonds, the purchase or redemption of the bonds, the payment of interest on the bonds, or the payments of any redemption premium required to be paid when the bonds are redeemed prior to maturity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in a bond reserve fund shall not be withdrawn from it at any time in an amount that will reduce the amount of the fund to less than the bond reserve fund requirement established for the fund, as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, except for the purpose of making, with respect to bonds secured in whole or in part by the fund, payment when due of principal, interest, redemption premiums, and the sinking fund payments with respect to the bonds for the payment of which other moneys of the treasurer are not available. Any income or interest earned by, or incremental to, a bond reserve fund due to the investment of it may be transferred by the treasurer to other funds or accounts to the extent the transfer does not reduce the amount of that bond reserve fund below the bond reserve fund requirement for it.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall not at any time issue bonds, secured in whole or in part by a bond reserve fund if, upon the issuance of the bonds, the amount in the bond reserve fund will be less than the bond reserve fund requirement for the fund, unless the treasurer at the time of issuance of the bonds deposits in the fund from the proceeds of the bonds issued or from other sources an amount which, together with the amount then in the fund, will not be less than the bond reserve fund requirement for the fund. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbond reserve fund requirement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, as of any particular date of computation, an amount of money, as provided in the resolutions authorizing the bonds with respect to which the fund is established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To assure the continued solvency of any bonds secured by the bond reserve fund, provision is made in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for the accumulation in each bond reserve fund of an amount equal to the bond reserve fund requirement for the fund. In order further to assure maintenance of the bond reserve funds, the treasurer shall, on or before January 1 of each calendar year, make and deliver to the governor the treasurer\u8217\'3fs certificate stating the sum, if any, required to restore each bond reserve fund to the bond reserve fund requirement for that fund. Within thirty days after the beginning of the session of the general assembly next following the delivery of the certificate, the governor shall submit to both houses printed copies of a budget including the sum, if any, required to restore each bond reserve fund to the bond reserve fund requirement for that fund. Any sums appropriated by the general assembly and paid to the treasurer pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited by the treasurer in the applicable bond reserve fund.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a722}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2001 Acts, 1st Ex, ch 5, \'a74, 7}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a712}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2011/CH0133.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2011 Acts, ch 133, \'a724, 25, 29}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57F}}}{{\f5\fs12\hyphpar0\qj{, 12.85}}}{{\f5\fs12\hyphpar0\qj{, 12.86}}}{{\f5\fs12\hyphpar0\qj{, 292.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.83}}}{\*\bkmkstart stylerid1_2E14_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{School infrastructure fund moneys }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ allocation to department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{During the term of the school infrastructure program established in }{{\f5\fs18\hyphpar0\qj{section 292.2}}}{, up to fifty thousand dollars of the moneys deposited each fiscal year in the school infrastructure fund shall be allocated each fiscal year to the department of inspections, appeals, and licensing for the use of the department. The funds shall be used by the department solely for the purpose of retaining an architect or architectural firm to evaluate structures for which school infrastructure program grant applications are made, to consult with school district representatives, to review construction drawings and blueprints, and to perform related duties at the direction of the department to ensure the best possible use of moneys received by a school district under the school infrastructure program. The department shall provide for the review of plans, drawings, and blueprints in a timely manner.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1225, \'a732, 38, 39}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71483}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57F}}}{{\f5\fs12\hyphpar0\qj{, 12.85}}}{{\f5\fs12\hyphpar0\qj{, 12.86}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.84}}}{\*\bkmkstart stylerid1_2E14_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pledges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is the intention of the general assembly that a pledge made in respect of bonds or notes shall be valid and binding from the time the pledge is made, that the money or property so pledged and received after the pledge by the treasurer of state shall immediately be subject to the lien of the pledge without physical delivery or further act, and that the lien of the pledge shall be valid and binding as against all parties having claims of any kind in tort, contract, or otherwise against the treasurer of state whether or not the parties have notice of the lien.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a723}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1232, \'a743}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 185, \'a736, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57F}}}{{\f5\fs12\hyphpar0\qj{, 12.85}}}{{\f5\fs12\hyphpar0\qj{, 12.86}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.85}}}{\*\bkmkstart stylerid1_2E14_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Bonds or notes issued pursuant to }{{\f5\fs18\hyphpar0\qj{section 12.81}}}{ are not debts of the state, or of any political subdivision of the state, and do not constitute a pledge of the faith and credit of the state or a charge against the general credit or general fund of the state. The issuance of any bonds or notes pursuant to }{{\f5\fs18\hyphpar0\qj{section 12.81}}}{ by the treasurer of state does not directly, indirectly, or contingently obligate the state or a political subdivision of the state to apply moneys from, or to levy or pledge any form of taxation whatever to, the payment of the bonds or notes. Bonds and notes issued under }{{\f5\fs18\hyphpar0\qj{section 12.81}}}{ are payable solely and only from the sources and special fund provided in }{{\f5\fs18\hyphpar0\qj{section 12.82}}}{. Expenses incurred in carrying out }{{\f5\fs18\hyphpar0\qj{sections 12.81 through 12.84}}}{, }{{\f5\fs18\hyphpar0\qj{this section}}}{, and }{{\f5\fs18\hyphpar0\qj{section 12.86}}}{ are payable solely from funds available under those sections.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a724}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57F}}}{{\f5\fs12\hyphpar0\qj{, 12.86}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.86}}}{\*\bkmkstart stylerid1_2E14_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sections 12.81 through 12.85}}}{, being necessary for the welfare of this state and its inhabitants, shall be liberally construed to effect the purposes of the sections.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1174, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57F}}}{{\f5\fs12\hyphpar0\qj{, 12.85}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER XI}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E15_2E2_2E2}{INFRASTRUCTURE PROJECTS AND IOWA JOBS PROGRAM \u8212\'3f REVENUE BONDS}{\*\bkmkend stylerid1_2E15_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.87}}}{\*\bkmkstart stylerid1_2E15_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General and specific bonding powers \u8212\'3f revenue bonds \u8212\'3f Iowa jobs program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state is authorized to issue and sell bonds on behalf of the state to provide funds for certain infrastructure projects and for purposes of the Iowa jobs program established in }}}{{\f5\fs18\hyphpar0\qj{section 16.194}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state shall have all of the powers which are necessary or convenient to issue, sell, and secure bonds and carry out the treasurer of state\u8217\'3fs duties, and exercise the treasurer of state\u8217\'3fs authority under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 12.88 through 12.90}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state may issue and sell bonds in such amounts as the treasurer of state determines to be necessary to provide sufficient funds for certain infrastructure projects and the revenue bonds capitals fund, the revenue bonds capitals II fund, the payment of interest on the bonds, the establishment of reserves to secure the bonds, the payment of costs of issuance of the bonds, the payment of other expenditures of the treasurer of state incident to and necessary or convenient to carry out the issuance and sale of the bonds, and the payment of all other expenditures of the treasurer of state necessary or convenient to administer the funds and to carry out the purposes for which the bonds are issued and sold. The treasurer of state may issue and sell bonds as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ in one or more series on the terms and conditions the treasurer of state determines to be in the best interest of the state, in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in such amounts as the treasurer of state determines to be necessary to fund the purposes for which such bonds are issued and sold.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may issue and sell bonds in amounts which provide aggregate net proceeds of not more than six hundred ninety-five million dollars, excluding any bonds issued and sold to refund outstanding bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or after July 1, 2009, the treasurer of state may issue and sell bonds in amounts which provide aggregate net proceeds of not more than one hundred eighty-five million dollars for capital projects which qualify as vertical infrastructure projects as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.57, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to the extent practicable in any fiscal year and without limiting other qualifying capital expenditures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or after July 1, 2009, the treasurer of state may issue and sell bonds in amounts which provide aggregate net proceeds of not more than three hundred sixty million dollars for purposes of the Iowa jobs program established in }}}{{\f5\fs18\hyphpar0\qj{section 16.194}}}{{\f5\fs18\hyphpar0\qj{ and for watershed flood rebuilding and prevention projects, soil conservation projects, sewer infrastructure projects, for certain housing and public service shelter projects and public broadband and alternative energy projects, and for projects relating to bridge safety and the rehabilitation of deficient bridges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or after April 1, 2010, the treasurer of state may issue and sell bonds in amounts which provide aggregate net proceeds of not more than one hundred fifty million dollars for purposes of the Iowa jobs II program established in }}}{{\f5\fs18\hyphpar0\qj{section 16.194A}}}{{\f5\fs18\hyphpar0\qj{ and for qualified projects in the departments of agriculture and land stewardship, education, natural resources, and transportation, and the economic development authority, Iowa finance authority, state board of regents, and treasurer of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued and sold under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are payable solely and only out of the moneys in the revenue bonds debt service fund, the revenue bonds federal subsidy holdback fund, and any bond reserve funds established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.89}}}{{\f5\fs18\hyphpar0\qj{, and only to the extent provided in the trust indenture, resolution, or other instrument authorizing their issuance. All moneys in the revenue bonds debt service fund, the revenue bonds federal subsidy holdback fund, and any bond reserve funds established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.89}}}{{\f5\fs18\hyphpar0\qj{ may be deposited with trustees or depositories in accordance with the terms of the trust indentures, resolutions, or other instruments authorizing the issuance of bonds and pledged by the treasurer of state to the payment thereof. Bonds issued and sold under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall contain a statement that the bonds are limited special obligations of the state and do not constitute a debt or indebtedness of the state or a pledge of the faith or credit of the state or a charge against the general credit or general fund of the state. The treasurer of state shall not pledge the credit or taxing power of this state or any political subdivision of this state or make bonds issued and sold pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ payable out of any moneys except those in the revenue bonds debt service fund, the revenue bonds federal subsidy holdback fund, and any bond reserve funds established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.89}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of bonds issued and sold by the treasurer of state and not required for immediate disbursement may be deposited with a trustee or depository as provided in the bond documents and invested or reinvested in any investment as directed by the treasurer of state and specified in the trust indenture, resolution, or other instrument pursuant to which the bonds are issued and sold without regard to any limitation otherwise provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bonds, if issued and sold, shall be:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a form, issued in denominations, executed in a manner, and payable over terms and with rights of redemption, and be subject to such other terms and conditions as prescribed in the trust indenture, resolution, or other instrument authorizing their issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Negotiable instruments and investment securities under the laws of the state and sold at prices, at public or private sale, and in a manner, as prescribed by the treasurer of state. }}}{{\f5\fs18\hyphpar0\qj{Chapters 73A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{74}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{74A}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{75}}}{{\f5\fs18\hyphpar0\qj{ do not apply to the sale or issuance of the bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the terms, conditions, and covenants providing for the payment of the principal, redemption premiums, if any, interest, and other terms, conditions, covenants, and protective provisions safeguarding payment, not inconsistent with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and as determined by the trust indenture, resolution, or other instrument authorizing their issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bonds are securities in which public officers and bodies of this state; political subdivisions of this state; insurance companies and associations and other persons carrying on an insurance business; banks, trust companies, savings associations, and investment companies; administrators, guardians, executors, trustees, and other fiduciaries; and other persons authorized to invest in bonds or other obligations of the state, may properly and legally invest funds, including capital, in their control or belonging to them.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds must be authorized by a trust indenture, resolution, or other instrument of the treasurer of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The resolution, trust indenture, or any other instrument by which a pledge is created shall not be required to be recorded or filed under the Iowa uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554}}}{{\f5\fs18\hyphpar0\qj{, to be valid, binding, or effective.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any bonds issued and sold under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are declared to be issued and sold for an essential public and governmental purpose, and all bonds issued and sold under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ except as otherwise provided in any trust indentures, resolutions, or other instruments authorizing their issuance shall be exempt from taxation by the state of Iowa and the interest on the bonds shall be exempt from the state income tax and the state inheritance tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may issue and sell bonds for the purpose of refunding any bonds issued and sold pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ then outstanding, including the payment of any redemption premiums thereon and any interest accrued or to accrue to the date of redemption of the outstanding bonds. Until the proceeds of bonds issued for the purpose of refunding outstanding bonds are applied to the purchase or retirement of outstanding bonds or the redemption of outstanding bonds, the proceeds may be placed in escrow and be invested and reinvested in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The interest, income, and profits earned or realized on an investment may also be applied to the payment of the outstanding bonds to be refunded by purchase, retirement, or redemption. After the terms of the escrow have been fully satisfied and carried out, any balance of proceeds and interest earned or realized on the investments shall be returned to the treasurer of state for deposit in the revenue bonds debt service fund established in }}}{{\f5\fs18\hyphpar0\qj{section 12.89}}}{{\f5\fs18\hyphpar0\qj{. All refunding bonds shall be issued, sold and secured and subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in the same manner and to the same extent as other bonds issued and sold pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued and sold pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are limited special obligations of the state and are not a debt or indebtedness of the state, nor of any political subdivision of the state, and do not constitute a pledge of the faith and credit of the state or a charge against the general credit or general fund of the state. The issuance and sale of any bonds pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by the treasurer of state do not directly, indirectly, or contingently obligate the state or a political subdivision of the state to apply moneys from or to levy or pledge any form of taxation whatever to, or to continue the appropriation of the funds for, the payment of the bonds. Bonds issued and sold under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are payable solely and only from moneys in the revenue bonds debt service fund and any reserve fund created in }}}{{\f5\fs18\hyphpar0\qj{section 12.89}}}{{\f5\fs18\hyphpar0\qj{ and only to the extent provided in the trust indenture, resolution, or other instrument authorizing their issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may enter into or obtain authorizing documents and other agreements and ancillary arrangements with respect to the bonds as the treasurer of state determines to be in the best interests of the state, including but not limited to trust indentures, resolutions, other instruments authorizing the issuance of the bonds, liquidity facilities, remarketing or dealer agreements, letter of credit agreements, insurance policies, guaranty agreements, reimbursement agreements, indexing agreements, or interest rate exchange agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Neither the treasurer of state, the Iowa finance authority, nor any person acting on behalf of the treasurer of state or the Iowa finance authority while acting within the scope of their employment or agency, is subject to personal liability resulting from carrying out the powers and duties conferred by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 12.88 through 12.90}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 12.88 through 12.90}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbonds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means bonds, notes, or other evidence of obligations.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 173, \'a71, 36}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1138, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1184, \'a779, 96}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a787, 89}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a7129}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 142, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1076, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57}}}{{\f5\fs12\hyphpar0\qj{, 8.57F}}}{{\f5\fs12\hyphpar0\qj{, 12.88}}}{{\f5\fs12\hyphpar0\qj{, 12.88A}}}{{\f5\fs12\hyphpar0\qj{, 12.89}}}{{\f5\fs12\hyphpar0\qj{, 12.89A}}}{{\f5\fs12\hyphpar0\qj{, 12.90}}}{{\f5\fs12\hyphpar0\qj{, 16.50}}}{{\f5\fs12\hyphpar0\qj{, 422.7(2)(c)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.88}}}{\*\bkmkstart stylerid1_2E15_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revenue bonds capitals fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A revenue bonds capitals fund is created and established as a separate and distinct fund in the state treasury. The treasurer of state shall act as custodian of the fund and disburse moneys contained in the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue for the revenue bonds capitals fund shall include but is not limited to the following, which shall be deposited with the treasurer of state or the treasurer of state\u8217\'3fs designee as provided by any bond or security documents and credited to the fund:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The net proceeds of bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.87}}}{{\f5\fs18\hyphpar0\qj{ other than bonds issued for the purpose of refunding such bonds, and investment earnings on the net proceeds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest attributable to investment of moneys in the fund or an account of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the form of a devise, gift, bequest, donation, federal or other grant, reimbursement, repayment, judgment, transfer, payment, or appropriation from any source intended to be used for the purposes of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the revenue bonds capitals fund are not subject to }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annually, on or before January 15 of each year, a state agency that received an appropriation from the revenue bonds capitals fund shall report to the legislative services agency and the department of management the status of all projects completed or in progress. The report shall include a description of the project, the work completed, the total estimated cost of the project, a list of all revenue sources being used to fund the project, the amount of funds expended, the amount of funds obligated, and the date the project was completed or an estimated completion date of the project, where applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2017, any unobligated and unencumbered moneys in the fund from the previous fiscal year are appropriated to the department of administrative services for major maintenance projects.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 173, \'a72, 36}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 173, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.87}}}{{\f5\fs12\hyphpar0\qj{, 12.90}}}{{\f5\fs12\hyphpar0\qj{, 16.196}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.88A}}}{\*\bkmkstart stylerid1_2E15_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revenue bonds capitals II fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A revenue bonds capitals II fund is created and established as a separate and distinct fund in the state treasury. The treasurer of state shall act as custodian of the fund and disburse moneys contained in the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue for the revenue bonds capitals II fund shall include but is not limited to the following, which shall be deposited with the treasurer of state or the treasurer of state\u8217\'3fs designee as provided by any bond or security documents and credited to the fund:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The net proceeds of bonds issued after April 1, 2010, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.87}}}{{\f5\fs18\hyphpar0\qj{ other than bonds issued for the purpose of refunding such bonds, and investment earnings on the net proceeds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest attributable to investment of moneys in the fund or an account of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the form of a devise, gift, bequest, donation, federal or other grant, reimbursement, repayment, judgment, transfer, payment, or appropriation from any source intended to be used for the purposes of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the revenue bonds capitals II fund are not subject to }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annually, on or before January 15 of each year, a state agency that received an appropriation from the revenue bonds capitals II fund shall report to the legislative services agency and the department of management the status of all projects completed or in progress. The report shall include a description of the project, the work completed, the total estimated cost of the project, a list of all revenue sources being used to fund the project, the amount of funds expended, the amount of funds obligated, and the date the project was completed or an estimated completion date of the project, where applicable.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1184, \'a79, 13}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.87}}}{{\f5\fs12\hyphpar0\qj{, 12.90}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.89}}}{\*\bkmkstart stylerid1_2E15_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revenue bonds debt service fund and bond reserve funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A revenue bonds debt service fund is created and established as a separate and distinct fund in the state treasury. The treasurer of state shall act as custodian of the fund and disburse moneys contained in the fund. The moneys in such fund are appropriated and shall be used for the purpose of making all payments with respect to bonds issued and sold pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.87}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Principal payments, interest payments, sinking fund payments, purchase price, redemption price, redemption premiums, and interest rate exchange payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fees and expenses of trustees, paying agents, remarketing agents, financial advisors, underwriters, depositories, guarantors, bond insurers, liquidity or credit facility providers, interest rate indexing agents, and other professional services providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Costs and expenses of the treasurer of state incident to and necessary and convenient to carry out the issuance and sale of the bonds and the administration of the revenue bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the revenue bonds debt service fund shall include but are not limited to the following, which shall be deposited with the treasurer of state or the treasurer of state\u8217\'3fs designee as provided in any bond or security documents and credited to the fund:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of bonds to the extent provided in the trust indenture, resolution, or other instrument authorizing their issuance and investment earnings on the proceeds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The revenues required to be deposited into the fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 8.57, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transfers from any bond reserve fund created pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Federal subsidies and any transfers from the revenue bonds federal subsidy holdback fund created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.89A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest attributable to investment of moneys in the fund or an account of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other moneys from any other sources which may be legally available to the treasurer of state for the purpose of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may create and establish one or more special funds, to be known as bond reserve funds, to secure one or more issues of bonds issued and sold pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.87}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state shall pay into each bond reserve fund any moneys appropriated and made available for the purpose of the fund, any proceeds of sale of bonds to the extent provided in the trust indenture, resolution, or other instrument authorizing their issuance, and any other moneys which may be legally available to the treasurer of state for the purpose of the fund from any other sources. All moneys held in a bond reserve fund shall be used or transferred to the revenue bonds debt service fund to be used as required solely to make the payments authorized to be made from such fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in a bond reserve fund shall not be transferred or withdrawn from the fund at any time in an amount that will reduce the amount of the fund to less than the bond reserve fund requirement established for the fund, as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, except for the purpose of making, with respect to bonds secured in whole or in part by the fund, the payments authorized to be made from such fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for the payment of which sufficient moneys in the revenue bonds debt service fund are not available. Any income or interest earned by, or incremental to, a bond reserve fund due to the investment of moneys in the bond reserve fund may be transferred by the treasurer of state to other funds or accounts to the extent the transfer does not reduce the amount of that bond reserve fund below the established bond reserve fund requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall not at any time issue and sell bonds, secured in whole or in part by a bond reserve fund if, upon the issuance of the bonds, the amount in the bond reserve fund will be less than the bond reserve fund requirement for the fund, unless the treasurer of state at the time of issuance of the bonds deposits in the fund from the proceeds of the bonds issued or from other legally available sources an amount which, together with the amount then in the fund, will not be less than the bond reserve fund requirement for the fund. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbond reserve fund requirement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, as of any particular date of computation, an amount of moneys, as provided in the trust indenture, resolution, or other instrument authorizing the bonds with respect to which the fund is established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To assure the continued solvency of any bonds secured by a bond reserve fund, provision is made in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for the accumulation in each bond reserve fund of an amount equal to the bond reserve fund requirement for the fund. In order further to assure maintenance of the bond reserve funds, the treasurer of state shall, on or before January 1 of each calendar year, make and deliver to the governor and to both houses of the general assembly the treasurer of state\u8217\'3fs certificate stating the sum, if any, required to restore each bond reserve fund to the bond reserve fund requirement for that fund and requesting that the budget and appropriation bills approved for such fiscal year include amounts sufficient to restore each bond reserve fund to the bond reserve fund requirement for such fund. Within thirty days after the beginning of the session of the general assembly next following the delivery of the certificate, the governor may submit to both houses printed copies of a budget including the sum, if any, required to restore each bond reserve fund to the bond reserve fund requirement for that fund. Any sums appropriated by the general assembly and paid to the treasurer of state pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited by the treasurer of state in the applicable bond reserve fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the moneys on deposit in the revenue bonds debt service fund or any bond reserve fund relating to bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.87}}}{{\f5\fs18\hyphpar0\qj{ shall be held for the sole benefit of the bonds and shall not be pledged or used for the benefit of any bonds issued by the treasurer of state pursuant to any other section of the Code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the revenue bonds debt service fund and any bond reserve fund created pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are not subject to }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{; provided however, that on August 31 following the close of each fiscal year, any moneys on deposit in the revenue bonds debt service fund at the end of such fiscal year, which is determined by the treasurer of state to not be encumbered or obligated or otherwise necessary to make the payments for such fiscal year authorized to be made from such fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall be credited to the rebuild Iowa infrastructure fund created in }}}{{\f5\fs18\hyphpar0\qj{section 8.57}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the revenue bonds debt service fund and any bond reserve fund shall be credited to such funds.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 173, \'a73, 36}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1184, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a7130}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7101}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57}}}{{\f5\fs12\hyphpar0\qj{, 12.87}}}{{\f5\fs12\hyphpar0\qj{, 12.89A}}}{{\f5\fs12\hyphpar0\qj{, 12.90}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.89A}}}{\*\bkmkstart stylerid1_2E15_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revenue bonds federal subsidy holdback fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A revenue bonds federal subsidy holdback fund is created and established as a separate and distinct fund in the state treasury. The treasurer of state shall act as custodian of the fund and disburse moneys contained in the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The moneys in such fund shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The revenues required to be deposited in the fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 8.57, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Interest attributable to investment moneys in the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other moneys from any other sources which may be legally available to the treasurer of state for the purpose of the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The moneys in the revenue bonds federal subsidy holdback fund are appropriated and shall be used or transferred to the revenue bonds debt service fund created in }}}{{\f5\fs18\hyphpar0\qj{section 12.89, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, solely for the purpose of making payments of principal and interest on federal subsidy bonds when due, if the treasurer of state or the treasurer\u8217\'3fs designee has not received a federal subsidy scheduled to be received for such payment by the due date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The moneys on deposit in the revenue bonds federal subsidy holdback fund shall be used or transferred to the revenue bonds debt service fund created in }}}{{\f5\fs18\hyphpar0\qj{section 12.89, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, solely for the purpose of making payments of principal and interest on federal subsidy bonds prior to any use or transfer of moneys on deposit in any bond reserve fund created for such federal subsidy bonds by the treasurer of state pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.89, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any time during each fiscal year that there are moneys on deposit in the revenue bonds federal subsidy holdback fund that are not needed to pay principal and interest on federal subsidy bonds during such fiscal year as determined by the treasurer of state or the treasurer\u8217\'3fs designee, such moneys on deposit in the revenue bonds federal subsidy holdback fund shall be credited to the rebuild Iowa infrastructure fund created in }}}{{\f5\fs18\hyphpar0\qj{section 8.57}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this section:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal subsidy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any payment from the federal government with respect to federal subsidy bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal subsidy bonds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any bonds issued and sold pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12.87}}}{{\f5\fs18\hyphpar0\qj{ for which a federal subsidy is expected to be paid on or before any date on which interest on such bonds is due and payable.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1184, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a7131}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7102}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57}}}{{\f5\fs12\hyphpar0\qj{, 12.87}}}{{\f5\fs12\hyphpar0\qj{, 12.89}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.90}}}{\*\bkmkstart stylerid1_2E15_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pledges \u8212\'3f construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the intention of the general assembly that a pledge made in respect of bonds shall be valid and binding from the time the pledge is made, that the money or property so pledged and received after the pledge by the treasurer of state shall immediately be subject to the lien of the pledge without physical delivery or further act, and that the lien of the pledge shall be valid and binding as against all parties having claims of any kind in tort, contract, or otherwise against the treasurer of state whether or not the parties have notice of the lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sections 12.87 through 12.89}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, being necessary for the welfare of this state and its inhabitants, shall be liberally construed to effect the purposes of the sections.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 173, \'a74, 36}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.87}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER XII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E16_2E2_2E2}{ANNUAL APPROPRIATION BONDS}{\*\bkmkend stylerid1_2E16_2E2_2E2}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.90A through 12.90C}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2010/CH1184.pdf" }{\fldrslt \f5 \fs18{{2010 Acts, ch 1184, \'a795}}}}}}{{\f5\fs18\qj{2010 Acts, ch 1184, \'a795}}}{.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER XIII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E17_2E2_2E2}{ENERGY-EFFICIENT BUILDING PROJECT}{\*\bkmkend stylerid1_2E17_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{12.91}}}{\*\bkmkstart stylerid1_2E17_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Utilities commission and consumer advocate building project \u8212\'3f bond issue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBonds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means bonds, notes, or other evidences of indebtedness issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChargeable expenses\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means expenses charged by the utilities commission and the consumer advocate division of the department of justice under }}}{{\f5\fs18\hyphpar0\qj{section 476.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChargeable expenses fund\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the fund created in the state treasury under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProject\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a building and related improvements and furnishings authorized under }}}{{\f5\fs18\hyphpar0\qj{section 476.10B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may issue bonds and do all things necessary in order to finance the costs of the project. The treasurer of state shall have all of the powers which are necessary to issue and secure bonds to provide the financing for the project. The treasurer of state may issue bonds in principal amounts which, in the opinion of the treasurer, are necessary to provide sufficient funds for the costs of the project, the payment of interest on the bonds, the establishment of reserves to secure the bonds, the costs of issuance of the bonds, other expenditures of the treasurer of state incident to and necessary or convenient to carry out the bond issue, and all other expenditures of the utilities commission and the department of administrative services in connection with the construction of the project. The bonds are investment securities and negotiable instruments within the meaning of and for purposes of the Iowa uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are payable solely and only out of the moneys, assets, or revenues of the chargeable expenses fund and any bond reserve funds established pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, all of which may be held by the treasurer of state or deposited with trustees or depositories in accordance with bond or security documents and pledged by the treasurer of state to the payment thereof. Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall contain a statement that the bonds do not constitute an indebtedness of the state. The treasurer of state shall not pledge the credit or taxing power of this state or any political subdivision of this state or make bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ payable out of any moneys except those in the chargeable expenses fund and any bond reserve funds established pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of bonds issued by the treasurer of state and not required for immediate disbursement may be deposited with a trustee or depository as provided in the bond documents and invested or reinvested in any investment as directed by the treasurer of state and specified in the trust indenture, resolution, or other instrument pursuant to which the bonds are issued without regard to any limitation otherwise provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bonds shall be:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a form, issued in denominations, executed in a manner, and payable over terms and with rights of redemption, and be subject to such other terms and conditions as prescribed in the trust indenture, resolution, or other instrument authorizing their issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Negotiable instruments under the laws of the state and may be sold at prices, at public or private sale, and in a manner, as prescribed by the treasurer of state. }}}{{\f5\fs18\hyphpar0\qj{Chapters 73A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{74}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{74A}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{75}}}{{\f5\fs18\hyphpar0\qj{ do not apply to the sale or issuance of the bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the terms, conditions, and covenants providing for the payment of the principal, redemption premiums, if any, interest, and other terms, conditions, covenants, and protective provisions safeguarding payment, not inconsistent with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and as determined by the trust indenture, resolution, or other instrument authorizing their issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bonds are securities in which public officers and bodies of this state; political subdivisions of this state; insurance companies and associations and other persons carrying on an insurance business; banks, trust companies, savings associations, and investment companies; administrators, guardians, executors, trustees, and other fiduciaries; and other persons authorized to invest in bonds or other obligations of the state may properly and legally invest funds, including capital, in their control or belonging to them.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds must be authorized by a trust indenture, resolution, or other instrument of the treasurer of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Neither the resolution, trust agreement, nor any other instrument by which a pledge is created needs to be recorded or filed under the Iowa uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554}}}{{\f5\fs18\hyphpar0\qj{, to be valid, binding, or effective.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are declared to be issued for a general public and governmental purpose and all bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be exempt from taxation by the state of Iowa and the interest on the bonds shall be exempt from the state income tax and the state inheritance tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the terms of any bond documents, moneys in the chargeable expenses fund may be expended for administration expenses of the treasurer of state in connection with the bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may issue bonds for the purpose of refunding any bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ then outstanding, including the payment of any redemption premiums thereon and any interest accrued or to accrue to the date of redemption of the outstanding bonds. Until the proceeds of bonds issued for the purpose of refunding outstanding bonds are applied to the purchase or retirement of outstanding bonds or the redemption of outstanding bonds, the proceeds may be placed in escrow and be invested and reinvested in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The interest, income, and profits earned or realized on an investment may also be applied to the payment of the outstanding bonds to be refunded by purchase, retirement, or redemption. After the terms of the escrow have been fully satisfied and carried out, any balance of proceeds and interest earned or realized on the investments may be returned to the treasurer of state for deposit in the chargeable expenses fund unless all bonds issued under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ have been retired, in which case the proceeds shall be deposited in the general fund of the state. All refunding bonds shall be issued and secured and subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in the same manner and to the same extent as other bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A chargeable expenses fund is created and established as a separate and distinct fund in the state treasury. The moneys in the fund are appropriated for payment of the principal of, premium, and interest on any bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Moneys in the fund shall not be subject to appropriation for any other purpose by the general assembly, but shall be used only for the purposes of the chargeable expenses fund. The treasurer of state shall act as custodian of the fund and disburse moneys contained in the fund for payment of the principal of, premium, and interest on any bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 476.10}}}{{\f5\fs18\hyphpar0\qj{, there shall in each fiscal year be deposited in the chargeable expenses fund from amounts collected by the utilities commission as chargeable expenses an amount equal to the principal of, premium, if any, and interest on any bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to become due, whether at maturity, by call for optional redemption or by sinking fund redemption, in such fiscal year. The treasurer of state is authorized to pledge any amounts in the chargeable expenses fund as security for the payment of the principal of, premium, and interest on any bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state may provide in the trust indenture, resolution, or other instrument authorizing the issuance of bonds for the transfer to the general fund of the state of any amounts on deposit in the chargeable expenses fund that are not necessary for the payment of the principal of, premium, and interest on any bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the chargeable expenses fund are not subject to }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state may create and establish one or more special funds, to be known as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbond reserve funds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to secure one or more issues of bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The treasurer of state shall pay into each bond reserve fund any moneys appropriated and made available by the state or the treasurer of state for the purpose of the fund, any proceeds of sale of bonds to the extent provided in the resolutions authorizing their issuance, and any other moneys which may be available to the treasurer of state for the purpose of the fund from any other sources. All moneys held in a bond reserve fund, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall be used as required solely for the payment of the principal of bonds secured in whole or in part by the fund or of the sinking fund payments with respect to the bonds, the purchase or redemption of the bonds, the payment of interest on the bonds, or the payments of any redemption premium required to be paid when the bonds are redeemed prior to maturity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in a bond reserve fund shall not be withdrawn from it at any time in an amount that will reduce the amount of the fund to less than the bond reserve fund requirement established for the fund, as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, except for the purpose of making, with respect to bonds secured in whole or in part by the fund, payment when due of principal, interest, redemption premiums, and the sinking fund payments with respect to the bonds for the payment of which other moneys of the treasurer of state are not available. Any income or interest earned by, or incremental to, a bond reserve fund due to the investment of it may be transferred by the treasurer of state to other funds or accounts to the extent the transfer does not reduce the amount of that bond reserve fund below the bond reserve fund requirement for that bond reserve fund. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbond reserve fund requirement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, as of any particular date of computation, an amount of money, as provided in the resolutions authorizing the bonds with respect to which the fund is established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall comply with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 476.10B}}}{{\f5\fs18\hyphpar0\qj{ in order to assure the maintenance of any bond reserve funds established under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the intent of the general assembly that a pledge made in respect of bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be valid and binding from the time the pledge is made, that the money or property so pledged and received after the pledge by the treasurer of state shall immediately be subject to the lien of the pledge without physical delivery or further act, and that the lien of the pledge shall be valid and binding as against all parties having claims of any kind in tort, contract, or otherwise against the treasurer of state whether or not the parties have notice of the lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are not debts of the state, nor of any political subdivision of the state, and do not constitute a pledge of the faith and credit of the state or a charge against the general credit or general fund of the state. The issuance of any bonds pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by the treasurer of state does not directly, indirectly, or contingently obligate the state or a political subdivision of the state to apply moneys from, or to levy or pledge any form of taxation whatever to, the payment of the bonds. Bonds issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are payable solely and only from the sources and special fund provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{, being necessary for the welfare of this state and its inhabitants, shall be liberally construed to effect its purposes.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1179, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 22, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1119, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1138, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1076, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.7(2)(d)}}}{{\f5\fs12\hyphpar0\qj{, 476.10B}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.92 through 12.100}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER XIV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E18_2E2_2E2}{FAIRGROUNDS INFRASTRUCTURE}{\*\bkmkend stylerid1_2E18_2E2_2E2}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{12.101 and 12.102}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0184.pdf" }{\fldrslt \f5 \fs18{{2009 Acts, ch 184, \'a740}}}}}}{{\f5\fs18\qj{2009 Acts, ch 184, \'a740}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}}