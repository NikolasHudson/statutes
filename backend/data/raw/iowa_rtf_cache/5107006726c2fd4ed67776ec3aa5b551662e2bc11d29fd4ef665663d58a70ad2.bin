\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F447}{\*\bkmkend codeChapter_5F447}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 447}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{TAX REDEMPTION}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7306.22}}}{{\f5\fs12\qc{, 331.559}}}{{\f5\fs12\qc{, 419.11}}}{{\f5\fs12\qc{, 435.25}}}{{\f5\fs12\qc{, 437A.11}}}{{\f5\fs12\qc{, 437B.7}}}{{\f5\fs12\qc{, 445.1}}}{{\f5\fs12\qc{, 446.9}}}{{\f5\fs12\qc{, 446.14}}}{{\f5\fs12\qc{, 448.13}}}{{\f5\fs12\qc{, 458A.20}}}{{\f5\fs12\qc{, 461A.25}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb0\ri1445\li1445\sa146{ }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{For definitions applicable to chapter,}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\sa0\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{see }{{\f5\fs12\qc{\'a7445.1}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Redemption \u8212\'3f terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A parcel sold under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 446}}}{{\f5\fs18\hyphpar0\qj{ may be redeemed at any time before the right of redemption expires, by payment to the county treasurer, to be held by the treasurer subject to the order of the purchaser, of the amount for which the parcel was sold, including the fee for the certificate of purchase, and interest of two percent per month, counting each fraction of a month as an entire month, from the month of sale, and the total amount paid by the purchaser or the purchaser\u8217\'3fs assignee for any subsequent year, with interest at the same rate added on the amount of the payment for each subsequent year from the month of payment, counting each fraction of a month as an entire month. The amount of interest must be at least one dollar and shall be rounded to the nearest whole dollar. Interest shall accrue on subsequent amounts as provided in }}}{{\f5\fs18\hyphpar0\qj{section 446.32}}}{{\f5\fs18\hyphpar0\qj{. The redemption must be received by the treasurer or entered through the county treasurer\u8217\'3fs authorized internet site on or before the last day of the month to avoid additional interest being added to the amount necessary to redeem. However, if the last day of a month falls on a Saturday, Sunday, or a holiday, the payment must be received by the treasurer or entered through the county treasurer\u8217\'3fs authorized internet site by the close of business on the first business day of the following month.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the county or city is the certificate holder of the parcel redeemed from a sale held under }}}{{\f5\fs18\hyphpar0\qj{section 446.19}}}{{\f5\fs18\hyphpar0\qj{, the redemption amount shall be apportioned among the several funds for which the taxes were levied. All interest, costs, and fees shall be apportioned to the general fund of the county regardless of who is the certificate holder. If a city is the certificate holder of the parcel redeemed from a sale held under }}}{{\f5\fs18\hyphpar0\qj{section 446.7}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{446.28}}}{{\f5\fs18\hyphpar0\qj{, the city shall be entitled to the total amount redeemed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7505; R60, \'a7779; C73, \'a7890; C97, \'a71436; S13, \'a71436; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7272;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7447.1}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71232}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a789}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 73, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a727, 31}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 92, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7445.3}}}{{\f5\fs12\hyphpar0\qj{, 446.19A}}}{{\f5\fs12\hyphpar0\qj{, 446.32}}}{{\f5\fs12\hyphpar0\qj{, 447.4}}}{{\f5\fs12\hyphpar0\qj{, 447.7}}}{{\f5\fs12\hyphpar0\qj{, 447.8}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Tax sale certificate fee, }{{\f5\fs12\hyphpar0\qj{\'a7331.552(23)}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonallowable penalties.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1991/CH0191.pdf" }{\fldrslt \cf5 \f5 \fs18{{91 Acts, ch 191, \'a7123, 124}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Agricultural college lands.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In redeeming from a sale of a leasehold interest in agricultural college land, the amount to be paid shall include any amount paid by the holder of the certificate as interest or principal due by the terms of the lease or otherwise to prevent a forfeiture, and for which proper voucher has been filed with the county treasurer, with interest at eight percent per annum from date of payment, which amount shall be paid by the treasurer to the holder of the certificate, and the certificate of redemption shall show the amount paid by the party redeeming.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7505; R60, \'a7779; C73, \'a7890; C97, \'a71436; S13, \'a71436; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7274;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7447.3}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71233}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a790}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7447.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Redemption from sale for part of tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In case a redemption is made of a parcel compromised and assigned for a sum less than the total amount due, the purchaser is entitled to receive only the amount paid and a ratable part of the interest and costs. In determining the interest to be paid upon redemption from sale, the sum due on a parcel sold shall be taken to be the total amount due on the parcel at the time of sale, and the amount paid for a parcel at sale shall be apportioned ratably in accordance with }{{\f5\fs18\hyphpar0\qj{section 447.1}}}{. Parcels so sold are redeemable in the same manner and with the same interest as those sold for the taxes of the preceding year.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a71437; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7275;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7447.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1168, \'a749}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a791}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate of redemption \u8212\'3f issued by treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county treasurer, upon application of a party to redeem a parcel sold at a tax sale, and being satisfied that the party has a right to redeem the parcel upon the payment of the proper amount, shall issue to the party a certificate of redemption, setting forth the facts of the sale substantially as contained in the certificate, the date of the redemption, the amount paid, and by whom redeemed, and shall make the proper entries in the county system in the treasurer\u8217\'3fs office.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7780; C73, \'a7891; C97, \'a71438; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7276;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7447.5}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71234}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a792}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1070, \'a728, 31}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Documentation of corrections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The entries by the county treasurer on the county system shall be of a permanent nature and if errors are subsequently discovered the correcting entries shall be adequately documented to support the correction.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a77276-c1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7276.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7447.6}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71235}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a793}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Redemption by persons with a legal disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a parcel of a person with a legal disability is sold at tax sale and the county treasurer has not delivered the treasurer\u8217\'3fs deed, a legal representative of the person with the legal disability may redeem the parcel under sections }}}{{\f5\fs18\hyphpar0\qj{447.1}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{447.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a parcel of a person with a legal disability is sold at tax sale and the county treasurer has delivered the treasurer\u8217\'3fs deed, the person with the legal disability or the person\u8217\'3fs legal representative may redeem the parcel at any time prior to one year after the legal disability is removed by bringing an equitable action for redemption in the district court of the county where the parcel is located, unless the action is required to be brought sooner in time by operation of }}}{{\f5\fs18\hyphpar0\qj{subsection 3 or 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish the right to redeem, the person maintaining the action shall prove to the court that the owner of the parcel is a person with a legal disability entitled to redeem prior to the delivery of the treasurer\u8217\'3fs deed. If the legal disability has been removed, the person maintaining the action shall establish the date the disability was removed and explain the manner by which the legal disability was removed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person maintaining the action shall name as defendants all persons claiming an interest in the parcel derived from the tax sale, as shown by the record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines that the person maintaining the action or the person\u8217\'3fs legal representative is entitled to redeem by virtue of legal disability or prior legal disability, the court shall so order. The order shall determine the rights, claims, and interests of all parties, including liens for taxes and claims for improvements made on or to the parcel by the person claiming under the tax title. The order shall establish the amount necessary to effect redemption. The redemption amount shall include the amount for redemption computed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 447.1}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{447.3}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable, including interest computed up to and including the date of payment of the total redemption amount to the clerk of court and the amount of all costs added to the redemption amount in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 447.13}}}{{\f5\fs18\hyphpar0\qj{. In addition, if the person claiming under the tax title is determined by the court to have made improvements on or to the parcel after the treasurer\u8217\'3fs deed was issued, the court shall enter judgment in favor of the person claiming under the tax title for an amount equal to the value of all such improvements, and such judgment shall be a lien on the parcel until paid. The order shall direct that the person maintaining the action shall pay to the clerk of court, within thirty days after the date of the order, the total redemption amount the order sets forth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon timely receipt of the payment, the court shall enter judgment declaring the treasurer\u8217\'3fs deed to be void and determining the resulting rights, claims, and interests of all parties to the action. In its judgment, the court shall direct the clerk of court to deliver the entire amount of the redemption payment to the person claiming title under the treasurer\u8217\'3fs deed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person maintaining the action fails to timely deliver payment of the total redemption amount to the clerk of court, the court shall enter judgment holding that all rights of redemption of the person with a legal disability who brought the action, or on whose behalf the action was brought, are terminated and that the validity of the tax title or purported tax title is conclusively established as a matter of law against the claims of such person with a legal disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person with a legal disability remains in possession of the parcel after the recording of the treasurer\u8217\'3fs deed, and if the person claiming under the tax title properly commences an action to remove the person from possession, the person with a legal disability shall forfeit any rights of redemption that the person may have under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless either of the following actions is timely filed by or on behalf of the person:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A counterclaim in the removal action asserting the redemption rights under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ of the person with a legal disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A separate action under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. Such action shall be filed within thirty days after the person with a legal disability and the person\u8217\'3fs legal representative were served with original notice in the removal action. If an action under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ is filed by or on behalf of the person with a legal disability within the thirty-day period, the court may order the action consolidated with the removal action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person with a legal disability is not in possession of the parcel at the time of the recording of the treasurer\u8217\'3fs deed, the person or the person\u8217\'3fs legal representative is forever barred and estopped from commencing an action under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if either of the following occurs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An affidavit is filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 448.15}}}{{\f5\fs18\hyphpar0\qj{ and claims adverse to the tax title are barred by }}}{{\f5\fs18\hyphpar0\qj{section 448.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ is not brought within three years after the recording of the treasurer\u8217\'3fs deed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7779; C73, \'a7892; C97, \'a71439; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7277;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7447.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1039, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.27}}}{{\f5\fs12\hyphpar0\qj{, 420.240}}}{{\f5\fs12\hyphpar0\qj{, 447.8}}}{{\f5\fs12\hyphpar0\qj{, 448.6}}}{{\f5\fs12\hyphpar0\qj{, 448.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{\u8220\'3fPerson with a legal disability\u8221\'3f defined, see }{{\f5\fs12\hyphpar0\qj{\'a7445.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Redemption after delivery of deed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the delivery of the treasurer\u8217\'3fs deed, a person entitled to redeem a parcel sold at tax sale shall do so only by an equitable action in the district court of the county where the parcel is located. The action to redeem may be maintained only by a person who was entitled to redeem the parcel during the ninety-day redemption period in }}}{{\f5\fs18\hyphpar0\qj{section 447.12}}}{{\f5\fs18\hyphpar0\qj{, except that such a person may assign the person\u8217\'3fs right of redemption or right to maintain the action to another person, or by a person entitled to redeem under }}}{{\f5\fs18\hyphpar0\qj{section 447.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to establish the right to redeem, the person maintaining the action shall be required to prove to the court either that the person maintaining the action or a predecessor in interest was not properly served with notice in accordance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 447.9 through 447.12}}}{{\f5\fs18\hyphpar0\qj{, or that the person maintaining the action or a predecessor in interest acquired an interest in or possession of the parcel during the ninety-day redemption period in }}}{{\f5\fs18\hyphpar0\qj{section 447.12}}}{{\f5\fs18\hyphpar0\qj{. A person shall not be entitled to maintain such action by claiming that a different person was not properly served with notice of expiration of right of redemption, if the person seeking to maintain the action, or the person\u8217\'3fs predecessor in interest, if applicable, was properly served with the notice. After the execution and delivery of the treasurer\u8217\'3fs deed, a person may only redeem a parcel sold for delinquent taxes under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 447.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person maintaining the action shall name as defendants all persons claiming an interest in the parcel derived from the tax sale, as shown by the record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines that notice was properly served, the court shall enter judgment holding that all rights of redemption are terminated and that the validity of the tax title or purported tax title is conclusively established as a matter of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines that notice was not properly served and that the person maintaining the action is entitled to redeem, the court shall so order. The order shall determine the rights, claims, and interests of all parties, including liens for taxes and claims for improvements made on or to the parcel by the person claiming under the tax title. The order shall establish the amount necessary to effect redemption. The redemption amount shall include the amount for redemption computed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 447.1}}}{{\f5\fs18\hyphpar0\qj{, including interest computed up to and including the date of payment of the total redemption amount to the clerk of court; the amount of all costs added to the redemption amount in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 447.13}}}{{\f5\fs18\hyphpar0\qj{; and, in the event that the person claiming under the tax title has made improvements on or to the parcel after the treasurer\u8217\'3fs deed was issued, an amount equal to the value of all such improvements. The order shall direct that the person maintaining the action shall pay to the clerk of court, within thirty days after the date of the order, the total redemption amount established in the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon timely receipt of the payment, the court shall enter judgment declaring the treasurer\u8217\'3fs deed to be invalid and determining the resulting rights, claims, and interests of all parties to the action. In its judgment, the court shall direct the clerk of court to deliver the entire amount of the redemption payment to the person who previously claimed title under the treasurer\u8217\'3fs deed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person maintaining the action fails to timely deliver payment of the total redemption amount to the clerk of court, the court shall enter judgment holding that all rights of redemption are terminated and that the validity of the tax title or purported tax title is conclusively established as a matter of law. No subsequent action shall be brought to challenge the treasurer\u8217\'3fs deed or to recover the parcel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an affidavit is filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 448.15}}}{{\f5\fs18\hyphpar0\qj{ and if the time period for filing a claim under }}}{{\f5\fs18\hyphpar0\qj{section 448.16}}}{{\f5\fs18\hyphpar0\qj{ expires with no claims having been filed, all persons are thereafter barred and estopped from commencing an action under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7893; C97, \'a71440; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7278;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7447.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a795}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 34, \'a719, 26}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1039, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.240}}}{{\f5\fs12\hyphpar0\qj{, 448.6}}}{{\f5\fs12\hyphpar0\qj{, 448.12}}}{{\f5\fs12\hyphpar0\qj{, 448.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice of expiration of right of redemption \u8212\'3f county right of redemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After one year and nine months from the date of sale, or after nine months from the date of a sale made under }}}{{\f5\fs18\hyphpar0\qj{section 446.18}}}{{\f5\fs18\hyphpar0\qj{, or after three months from the date of a sale made under }}}{{\f5\fs18\hyphpar0\qj{section 446.19A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{446.19B}}}{{\f5\fs18\hyphpar0\qj{, the holder of the certificate of purchase may cause to be served upon the person in possession of the parcel, and also upon the person in whose name the parcel is taxed, a notice signed by the certificate holder or the certificate holder\u8217\'3fs agent or attorney, stating the date of sale, the description of the parcel sold, the name of the purchaser, and that the right of redemption will expire and a deed for the parcel be made unless redemption is made within ninety days from the completed service of the notice. The notice shall be served by both regular mail and certified mail to the person\u8217\'3fs last known address and such service is deemed completed when the notice is deposited in the mail and postmarked for delivery. The ninety-day redemption period begins as provided in }}}{{\f5\fs18\hyphpar0\qj{section 447.12}}}{{\f5\fs18\hyphpar0\qj{. When the notice is given by a county as a holder of a certificate of purchase the notice shall be signed by the county treasurer or the county attorney, and when given by a city, it shall be signed by the city officer designated by resolution of the council. When the notice is given by the Iowa finance authority or a city or county agency holding the parcel as part of an Iowa homesteading project, it shall be signed on behalf of the agency or authority by one of its officers, as authorized in rules of the agency or authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Service of the notice shall be made by both regular mail and certified mail on any mortgagee having a lien upon the parcel, a vendor of the parcel under a recorded contract of sale, a lessor who has a recorded lease or recorded memorandum of a lease, and any other person who has an interest of record, at the person\u8217\'3fs last known address. The notice shall be served on any city where the parcel is situated. Notice shall not be served after the filing of the affidavit required by }}}{{\f5\fs18\hyphpar0\qj{section 447.12}}}{{\f5\fs18\hyphpar0\qj{. Only those persons who are required to be served the notice of expiration as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or who have acquired an interest in or possession of the parcel subsequent to the filing of the notice of expiration of the right of redemption are eligible to redeem a parcel from tax sale. Service of the notice is deemed completed when the notice is deposited in the mail and postmarked for delivery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county in which the parcel is located has the right of redemption for owner-occupied residential parcels as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. If a person is unable to contribute to the public revenue, the person may file a petition, duly sworn to, with the board of supervisors, stating that fact and giving a statement of parcels, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{, owned or possessed by the petitioner, and other information as the board may require. The board of supervisors may order the county auditor to redeem a parcel owned or possessed by the petitioner from the holder of a certificate of purchase upon payment by the county to the certificate holder of the amount necessary to redeem under }}}{{\f5\fs18\hyphpar0\qj{section 447.1}}}{{\f5\fs18\hyphpar0\qj{. Each of the tax-levying and tax-certifying bodies having any interest in the taxes shall be charged with the total amount due the tax-levying or tax-certifying body as its just share of the purchase price, and that amount shall be deducted from the next month\u8217\'3fs disbursement made by the county to the tax-levying or tax-certifying body. Interest paid by the county to the certificate holder pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 447.1}}}{{\f5\fs18\hyphpar0\qj{ shall be paid solely by the county and shall not be charged against the other tax-levying and tax-certifying bodies. Taxes charged and paid by the tax-levying or tax-certifying body in this manner shall be treated as suspended taxes pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 427.8 through 427.12}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 447.14}}}{{\f5\fs18\hyphpar0\qj{, a county may redeem pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for tax sales held before, on, or after July 1, 1998. A county may limit the number of times a taxpayer may file a petition for assistance under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7781; C73, \'a7894; C97, \'a71441; S13, \'a71441; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7279;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7447.9}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71236}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1139, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1241, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 66, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1203, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 57, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1107, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1153, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 29, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 83, \'a78, 10, 12}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1165, \'a78, 11, 12}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 54, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1006, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.207}}}{{\f5\fs12\hyphpar0\qj{, 420.240}}}{{\f5\fs12\hyphpar0\qj{, 420.241}}}{{\f5\fs12\hyphpar0\qj{, 447.8}}}{{\f5\fs12\hyphpar0\qj{, 447.10}}}{{\f5\fs12\hyphpar0\qj{, 448.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Acquisition of title by municipal corporations, }{{\f5\fs12\hyphpar0\qj{chapter 569}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Service of original notice, }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0{{\f5\fs12\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs12{{\f5\b\fs12\hyphpar0\qj\cf5{R.C.P. 1.302 \u8211\'3f 1.315}}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Service by publication \u8212\'3f fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If notice in accordance with }{{\f5\fs18\hyphpar0\qj{section 447.9}}}{ cannot be served upon a person entitled to notice in the manner prescribed in that section, then the holder of the certificate of purchase shall cause the required notice to be published once in an official newspaper in the county. If service is made by publication, the affidavit required by }{{\f5\fs18\hyphpar0\qj{section 447.12}}}{ shall state the reason why service in accordance with }{{\f5\fs18\hyphpar0\qj{section 447.9}}}{ could not be made. Service of notice by publication shall be deemed complete on the day of the publication. Fees for publication, if required under }{{\f5\fs18\hyphpar0\qj{section 447.13}}}{, shall not exceed the customary publication fees for official county publications.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7894; C97, \'a71441; S13, \'a71441; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7280;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7447.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1139, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 121, \'a723}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.207}}}{{\f5\fs12\hyphpar0\qj{, 420.240}}}{{\f5\fs12\hyphpar0\qj{, 420.241}}}{{\f5\fs12\hyphpar0\qj{, 447.8}}}{{\f5\fs12\hyphpar0\qj{, 447.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Agent of nonresident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A nonresident may in writing appoint a resident of the county in which the parcel is situated as agent, and file the appointment with the county treasurer of the county, who shall make note of the appointment in the county system, after which service of notice by certified and regular mail shall be made upon the agent.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7894; C97, \'a71441; S13, \'a71441; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7281;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7447.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a797}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 45, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.207}}}{{\f5\fs12\hyphpar0\qj{, 420.240}}}{{\f5\fs12\hyphpar0\qj{, 420.241}}}{{\f5\fs12\hyphpar0\qj{, 447.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When service deemed complete }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ presumption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Service is complete only after an affidavit has been filed with the county treasurer, showing the making of the service, the manner of service, the time when and place where made, under whose direction the service was made, and costs incurred as provided in }{{\f5\fs18\hyphpar0\qj{section 447.13}}}{. Costs not filed with the treasurer before a redemption is complete shall not be collected by the treasurer. Costs shall not be filed with the treasurer prior to the filing of the affidavit. The affidavit shall be made by the holder of the certificate or by the holder\u8217\'3fs agent or attorney, and in either of the latter cases stating that the affiant is the agent or attorney of the holder of the certificate. The affidavit shall be filed by the treasurer and entered in the county system and is presumptive evidence of the completed service of the notice. The right of redemption shall not expire until ninety days after service is complete. A redemption shall not be considered valid unless received by the treasurer or entered through the county treasurer\u8217\'3fs authorized internet site prior to the close of business on the ninetieth day from the date of completed service except in the case of a public bidder certificate held by the county in which case the county may accept a redemption at any time prior to the issuance of the tax deed. However, if the ninetieth day falls on a Saturday, Sunday, or a holiday, payment of the total redemption amount must be received by the treasurer or entered through the county treasurer\u8217\'3fs authorized internet site before the close of business on the first business day following the ninetieth day. The date of postmark of a redemption shall not be considered as the day the redemption was received by the treasurer for purposes of the ninety-day time period.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7894; C97, \'a71441; S13, \'a71441; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7282;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7447.12}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71237}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 66, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a798}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 73, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a730, 31}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 54, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 92, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.207}}}{{\f5\fs12\hyphpar0\qj{, 420.240}}}{{\f5\fs12\hyphpar0\qj{, 420.241}}}{{\f5\fs12\hyphpar0\qj{, 446.37}}}{{\f5\fs12\hyphpar0\qj{, 447.8}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}{{\f5\fs12\hyphpar0\qj{, 447.10}}}{{\f5\fs12\hyphpar0\qj{, 448.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.13}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cost \u8212\'3f fee \u8212\'3f report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cost of serving the notice, including the cost of sending certified mail notices, and the cost of publication under }}}{{\f5\fs18\hyphpar0\qj{section 447.10}}}{{\f5\fs18\hyphpar0\qj{, if publication is required, shall be added to the amount necessary to redeem. The cost of a record search shall also be added to the amount necessary to redeem. However, if the certificate holder is other than a county, the search must be performed by an abstractor who is an active participant in the Iowa title guaranty program under }}}{{\f5\fs18\hyphpar0\qj{section 16.91}}}{{\f5\fs18\hyphpar0\qj{ or by an attorney licensed to practice law in the state of Iowa, and the amount of the cost of the record search that may be added to the amount necessary to redeem shall not exceed three hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer shall file the proof of service and statement of costs and record these costs against the parcel. The certificate holder or the holder\u8217\'3fs agent shall report in writing to the treasurer the amount of authorized costs incurred, and the treasurer shall file the statement. Costs not filed with the treasurer before a redemption is complete shall not be collected by the treasurer and may be recovered through a court action against the parcel owner by the certificate holder.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7894; C97, \'a71441; S13, \'a71441; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7283;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7447.13}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71238}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1139, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1016, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 83, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 45, \'a79, 11}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 34, \'a720, 26}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 54, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1012, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.207}}}{{\f5\fs12\hyphpar0\qj{, 420.240}}}{{\f5\fs12\hyphpar0\qj{, 420.241}}}{{\f5\fs12\hyphpar0\qj{, 447.7}}}{{\f5\fs12\hyphpar0\qj{, 447.8}}}{{\f5\fs12\hyphpar0\qj{, 447.10}}}{{\f5\fs12\hyphpar0\qj{, 447.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{447.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Law in effect at time of sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The law in effect at the time of tax sale governs redemption.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a733}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.241}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}}