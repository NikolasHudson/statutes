}{2024 amendment to subsection 12 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 12 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.9}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fraudulent practice in the first degree.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the first degree is a fraudulent practice where the amount of money or value of property or services involved exceeds ten thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the first degree is a class \u8220\'3fC\u8221\'3f felony.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1060, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1055, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715A.3}}}{{\f5\fs12\hyphpar0\qj{, 96.16}}}{{\f5\fs12\hyphpar0\qj{, 714.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.10}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fraudulent practice in the second degree.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the second degree is the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fraudulent practice where the amount of money or value of property or services involved exceeds one thousand five hundred dollars but does not exceed ten thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fraudulent practice where the amount of money or value of property or services involved does not exceed one thousand five hundred dollars by one who has been convicted of a fraudulent practice twice before.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the second degree is a class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1060, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7207}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 140, \'a713}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a796.16}}}{{\f5\fs12\hyphpar0\qj{, 237A.29}}}{{\f5\fs12\hyphpar0\qj{, 714.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.11}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fraudulent practice in the third degree.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the third degree is the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fraudulent practice where the amount of money or value of property or services involved exceeds seven hundred fifty dollars but does not exceed one thousand five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fraudulent practice as set forth in }}}{{\f5\fs18\hyphpar0\qj{section 714.8, subsections 2, 8, 9, and 21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fraudulent practice where it is not possible to determine an amount of money or value of property and services involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the third degree is an aggravated misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1060, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7208}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1055, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7192}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 113, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 140, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a796.16}}}{{\f5\fs12\hyphpar0\qj{, 714.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.12}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fraudulent practice in the fourth degree.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the fourth degree is a fraudulent practice where the amount of money or value of property or services involved exceeds three hundred dollars but does not exceed seven hundred fifty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the fourth degree is a serious misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1060, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 153, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 140, \'a715}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a796.16}}}{{\f5\fs12\hyphpar0\qj{, 135L.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.13}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fraudulent practice in the fifth degree.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the fifth degree is a fraudulent practice where the amount of money or value of property or services involved does not exceed three hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraudulent practice in the fifth degree is a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1060, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 153, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 140, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a796.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.14}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Value for purposes of fraudulent practices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The value of property or service is its highest value by any reasonable standard at the time the fraudulent practice is committed. Reasonable standard includes but is not limited to market value within the community, actual value, or replacement value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If money, property, or a service involved in two or more acts of fraudulent practice is from the same person or location, or from different persons by two or more acts which occur in approximately the same location or time period so that the fraudulent practices are attributable to a single scheme, plan, or conspiracy, these acts may be considered as a single fraudulent practice and the value may be the total value of all money, property, and services involved.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1162, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1055, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7193}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a796.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.15}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reproduction of sound recordings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOwner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person who owns the original fixation of sounds embodied in the master phonograph record, master disc, master tape, master film or other device used for reproducing sounds on phonograph records, discs, tapes, films, or other articles upon which sound is recorded, and from which the transferred recorded sounds are derived.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean person as defined in }}}{{\f5\fs18\hyphpar0\qj{section 4.1, subsection 20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, it is unlawful for a person knowingly to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transfer or cause to be transferred any sounds recorded on a phonograph record, disc, wire, tape, film or other article without the consent of the owner; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sell; distribute; circulate; offer for sale, distribution or circulation; possess for the purpose of sale, distribution or circulation; or cause to be sold, distributed, circulated; offered for sale, distribution or circulation; or possessed for sale, distribution or circulation, any article or device on which sounds have been transferred without the consent of the person who owns the master phonograph record, master disc, master tape or other device or article from which the sounds are derived.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for a person to sell, distribute, circulate, offer for sale, distribution or circulation or possess for the purposes of sale, distribution or circulation, any phonograph record, disc, wire, tape, film or other article on which sounds have been transferred unless the phonograph record, disc, wire, tape, film or other article bears the actual name and address of the transferor of the sounds in a prominent place on its outside face or package.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a person who transfers or causes to be transferred sounds intended for or in connection with radio or television broadcast transmission or related uses, synchronized sound tracks of motion pictures or sound tracks recorded for synchronizing with motion pictures, for archival purposes or for the personal use of the person transferring or causing the transfer and without any compensation being derived by the person from the transfer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of theft.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, \'a7713.44, 713.45; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 90, \'a7232}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7549.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.16}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consumer frauds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Definitions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadvertisement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the attempt by publication, dissemination, solicitation, or circulation to induce directly or indirectly any person to enter into any obligation or acquire any title or interest in any merchandise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fContaminant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any physical, chemical, biological, or radiological substance in water.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDeception\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an act or practice which has the tendency or capacity to mislead a substantial number of consumers as to a material fact or facts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth-related contaminant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a contaminant which has a potentially adverse health effect and for which a maximum contaminant level or treatment technique requirement or an action level established in lieu of a maximum contaminant level has been specified in the national primary drinking water regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmerchandise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any objects, wares, goods, commodities, intangibles, securities, bonds, debentures, stocks, real estate or services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fperson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any natural person or the person\u8217\'3fs legal representative, partnership, corporation (domestic and foreign), company, trust, business entity or association, and any agent, employee, salesperson, partner, officer, director, member, stockholder, associate, trustee or cestui que trust thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsale\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any sale, offer for sale, or attempt to sell any merchandise for cash or on credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsubdivided lands\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ refers to improved or unimproved land or lands divided or proposed to be divided for the purpose of sale or lease, whether immediate or future, into five or more lots or parcels; provided, however, it does not apply to the leasing of apartments, offices, stores or similar space within an apartment building, industrial building or commercial building unless an undivided interest in the land is granted as a condition precedent to occupying space in said structure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnfair practice\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an act or practice which causes substantial, unavoidable injury to consumers that is not outweighed by any consumer or competitive benefits which the practice produces.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWater treatment system\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a device or assembly for which a claim is made that it will improve the quality of drinking water by reducing one or more contaminants through mechanical, physical, chemical, or biological processes or combinations of the processes. As used in this paragraph and in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, each model of a water treatment system shall be deemed a distinct water treatment system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The act, use or employment by a person of an unfair practice, deception, fraud, false pretense, false promise, or misrepresentation, or the concealment, suppression, or omission of a material fact with intent that others rely upon the concealment, suppression, or omission, in connection with the lease, sale, or advertisement of any merchandise or the solicitation of contributions for charitable purposes, whether or not a person has in fact been misled, deceived, or damaged, is an unlawful practice.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is deceptive advertising within the meaning of }{{\f5\fs18\hyphpar0\qj{this section}}}{ for a person to represent in connection with the lease, sale, or advertisement of any merchandise that the advertised merchandise has certain performance characteristics, accessories, uses, or benefits or that certain services are performed on behalf of clients or customers of that person if, at the time of the representation, no reasonable basis for the claim existed. The burden is on the person making the representation to demonstrate that a reasonable basis for the claim existed.}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A retailer who uses advertising for a product, other than a drug or other product claiming to have a health related benefit or use, prepared by a supplier shall not be liable under }{{\f5\fs18\hyphpar0\qj{this section}}}{ unless the retailer participated in the preparation of the advertisement; knew or should have known that the advertisement was deceptive, false, or misleading; refused to withdraw the product from sales upon the request of the attorney general pending a determination of whether the advertisement was deceptive, false, or misleading; refused upon the request of the attorney general to provide the name and address of the supplier; or refused to cooperate with the attorney general in an action brought against the supplier under }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMaterial fact\u8221\'3f}}}{ as used in }{{\f5\fs18\hyphpar0\qj{this subsection}}}{ does not include repairs of damage to or adjustments on or replacements of parts with new parts of otherwise new merchandise if the repairs, adjustments or replacements are made to achieve compliance with factory specifications and are made before sale of the merchandise at retail and the actual cost of any labor and parts charged to or performed by a retailer for any such repairs, adjustments and parts does not exceed three hundred dollars or ten percent of the actual cost to a retailer including freight of the merchandise, whichever is less, providing that the seller posts in a conspicuous place notice that repairs, adjustments or replacements will be disclosed upon request. The exemption provided in this paragraph does not apply to the concealment, suppression or omission of a material fact if the purchaser requests disclosure of any repair, adjustment or replacement.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The advertisement for sale, lease or rent, or the actual sale, lease, or rental of any merchandise at a price or with a rebate or payment or other consideration to the purchaser which is contingent upon the procurement of prospective customers provided by the purchaser, or the procurement of sales, leases, or rentals to persons suggested by the purchaser, is declared to be an unlawful practice rendering any obligation incurred by the buyer in connection therewith, completely void and a nullity. The rights and obligations of any contract relating to such contingent price, rebate, or payment shall be interdependent and inseverable from the rights and obligations relating to the sale, lease, or rental.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for any person to advertise the sale of merchandise at reduced rates due to the cessation of business operations and after the date of the first such advertisement remain in business under the same or substantially the same ownership, or under the same or substantially the same trade name, or to continue to offer for sale the same type of merchandise at the same location for more than one hundred twenty days. As used in this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fperson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a person who acquires an ownership interest in the business either within sixty days before the initial advertisement of the sale or at any time after the initial advertisement of the sale. In addition, a person acquiring an ownership interest shall comply with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ if the person adds additional merchandise to the sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall offer or advertise within this state for sale or lease, any subdivided lands without first filing with the real estate commission true and accurate copies of all road plans, plats, field notes, and diagrams of water, sewage, and electric power lines as they exist at the time of the filing, however, this filing is not required for a subdivision subject to }}}{{\f5\fs18\hyphpar0\qj{section 306.21}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 354}}}{{\f5\fs18\hyphpar0\qj{. A filing shall be accompanied by a fee of fifty dollars for each subdivision included, payable to the real estate commission.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{False or misleading statements filed pursuant to subparagraph (1) or }}}{{\f5\fs18\hyphpar0\qj{section 306.21}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 354}}}{{\f5\fs18\hyphpar0\qj{, and advertising, offers to sell, or contracts not in substantial conformity with the filings made pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 306.21}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 354}}}{{\f5\fs18\hyphpar0\qj{ are unlawful.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violations of }}}{{\f5\fs18\hyphpar0\qj{chapter 123}}}{{\f5\fs18\hyphpar0\qj{ or any other provisions of law by a manufacturer, distiller, vintner, importer, or any other person participating in the distribution of alcoholic liquor or beer as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 123}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of a provision of }}}{{\f5\fs18\hyphpar0\qj{sections 535C.1 through 535C.10}}}{{\f5\fs18\hyphpar0\qj{ is an unlawful practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to acquire directly or indirectly an interest in a business which has either gone out of business or is going out of business and conduct or continue a going-out-of-business sale where additional merchandise has been added to the merchandise of the liquidating business for the purposes of the sale, unless the person provides a clear and conspicuous notice in all advertisements that merchandise has been added. The advertisement shall also state the customary retail price of the merchandise that has been added or brought in for the sale. The person acquiring the interest shall obtain a permit to hold the sale before commencing the sale. If the sale is to be held in a city which has an ordinance regulating going-out-of-business sales, then the permit shall be obtained from the city. If the sale is to be located outside of a city or in a city which does not have an ordinance regulating going-out-of-business sales, then the permit shall be obtained from the county in which the proposed sale is to be held. The county board of supervisors shall prescribe the procedures necessary to obtain the permit. The permit shall state the percentage of merchandise for sale that was obtained from the liquidating business and the percentage of merchandise for sale that was added from other sources. The permit or an accurate reproduction of the permit shall be clearly and conspicuously posted at all entrances to the site of the sale and at all locations where sales are consummated. A person who violates this paragraph, including any misrepresentation of the presence and the percentage of additional merchandise that had been added to that of the liquidating company, is liable for a civil penalty of not to exceed one thousand dollars for each day of each violation. The civil penalties collected shall be deposited in the general fund of the political entity which prosecutes the violation. The civil penalty is in addition to and not in lieu of any criminal penalty. A political entity enforcing this paragraph may obtain a preliminary injunction without posting a bond to enjoin a violation of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and this paragraph pending a hearing.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{This paragraph does not prohibit a city or county from adopting an ordinance prohibiting the conducting of a going-out-of-business sale in which additional merchandise is added to the merchandise of the liquidating business for the purposes of the sale.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to sell, lease, rent, or advertise the sale, lease, or rental of a water treatment system in this state, for which claims or representations related to the removal of health-related contaminants are made, unless a certification body accredited by the American national standards institute certifies all of the claims or representations related to the removal of health-related contaminants. This paragraph shall not be construed as limiting a manufacturer\u8217\'3fs ability to make claims or representations of removing contaminants that are not health-related contaminants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to sell, lease, rent, or advertise the sale, lease, or rental of a water treatment system in this state for which false or deceptive claims or representations of removing health-related contaminants are made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to make any representation or claim that the seller\u8217\'3fs water treatment system has been approved or endorsed by any agency of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a supplier to commit a deceptive act or practice under }}}{{\f5\fs18\hyphpar0\qj{chapter 537B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a repair facility or manufacturer or distributor of aftermarket crash parts, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537B.4}}}{{\f5\fs18\hyphpar0\qj{, to commit a deceptive act or practice under }}}{{\f5\fs18\hyphpar0\qj{chapter 537B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to advertise the sale of wood products without disclosing information which may affect the price of the product.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An advertisement for all plywood and dimension lumber products shall include the grade and species, in accordance with federal products standards 1 and 20, and the measure. The products advertised shall also be labeled according to the federal products standards.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An advertisement for any other wood product shall include the grade and species, according to the applicable federal product standards, and the measure. These products need not be labeled.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An advertisement for any wood products must also include the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The condition of the wood product, including but not limited to the following designations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Green.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Kiln-dried.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Air-dried or partially air-dried.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the wood product consists of seconds, culls, shop grade, or ungraded material.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Use of any contrived or unrecognized grading standard is prohibited, and any factors affecting the final delivered price of the products shall be disclosed and displayed in a conspicuous place.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{This paragraph applies only to persons who offer wood products for sale in the ordinary course of business, except that this paragraph does not apply to any person who produces rough-sawed lumber, commonly referred to as native lumber, in this state. For purposes of this paragraph:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDimension lumber\u8221\'3f}}}{ means softwood lumber nominally referred to as \u8220\'3ftwo inch by four inch\u8221\'3f or greater.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLabeling\u8221\'3f}}}{ means all labels and other written, printed, branded, or graphic matter upon any building material.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPlywood\u8221\'3f}}}{ means a structural material consisting of sheets or chips of wood glued or cemented together.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWood products\u8221\'3f}}}{ means any wood products derived from trees as a result of any work or manufacturing process upon the wood, and intended primarily for use as a building material.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to misrepresent the geographic location of a supplier of a service or product by listing a fictitious business name or an assumed business name in a local telephone directory or directory assistance database if all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name purportedly represents the geographic location of the supplier.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The listing does not identify the address, including the city and state, of the supplier.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Calls made to a local telephone number are routinely forwarded to or otherwise transferred to a business location that is outside the local calling area covered by the local telephone directory or directory assistance database.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A telephone company, provider of directory assistance, publisher of a local telephone directory, or officer, employee, or agent of such company, provider, or publisher shall not be liable in a civil action under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for publishing in any directory or directory assistance database the listing of a fictitious or assumed business name of a person in violation of subparagraph (1) unless the telephone company, directory assistance provider, directory publisher, or officer, employee, or agent of the company, provider, or publisher is the person committing such violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal telephone directory\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a telephone classified advertising directory or the business section of a telephone directory that is distributed free of charge to some or all telephone subscribers in a local area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal telephone number\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a telephone number that has a three-number prefix used by the provider of telephone service for telephone customers physically located within the area covered by the local telephone directory in which the number is listed. The term does not include long distance numbers or 800, 888, or 900 exchange numbers listed in the telephone directory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to make a free offer to a consumer, or impose a financial obligation on the consumer as a result of the consumer\u8217\'3fs acceptance of a free offer, unless the person provides the consumer with clear and conspicuous information regarding the terms of the free offer before the consumer agrees to accept the free offer, including at a minimum all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identification of all goods or services, or enrollments in a membership, subscription, or service contract, that the consumer will receive or incur a financial obligation for as a result of accepting the free offer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cost to the consumer of any financial obligation the consumer will incur if the consumer accepts the free offer, including any fees or charges.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any requirement, if applicable, that the consumer take affirmative action to reject the free offer and instructions about how the consumer is to indicate the consumer\u8217\'3fs rejection of the free offer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement, if applicable, that by accepting the free offer, the consumer will become obligated for additional goods or services, or enrollment in a membership, subscription, or service contract, unless the consumer takes affirmative action to cancel the free offer or otherwise reject receipt of the additional goods or services or the enrollment in a membership, subscription, or service contract.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consumer\u8217\'3fs right to cancel the free offer using procedures specifically intended for that purpose that, at a minimum, enable the consumer to cancel by calling a toll-free telephone number or to cancel in a manner substantially similar to that by which the consumer accepted the free offer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The time period during which the consumer must cancel in order to avoid incurring a financial obligation as a result of accepting the free offer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(g)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If applicable, the consumer\u8217\'3fs right to receive a credit on goods or services received as a result of accepting the free offer when the goods or services are returned or rejected, and the time period during which the goods or services must be returned or rejected for the purpose of receiving a credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to cause a consumer to incur a financial obligation as a result of accepting a free offer unless one of the following occurs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person obtains the consumer\u8217\'3fs billing information directly from the consumer. For purposes of this subparagraph division, a person obtains a consumer\u8217\'3fs billing information directly from the consumer if the billing information is obtained by the person or by the person\u8217\'3fs agent or employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consumer gives affirmative consent at the time the consumer accepts a free offer for the person to provide billing information to a person other than the person making the free offer. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to impose a financial obligation on a consumer as a result of the consumer\u8217\'3fs acceptance of a free offer unless the consumer\u8217\'3fs affirmative consent to the terms of the free offer as disclosed in subparagraph (1) is obtained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person that makes a free offer to a consumer to fail or refuse to cancel the free offer if the consumer has used, or made reasonable efforts to attempt to use, one of the procedures required to be available to the consumer as described in subparagraph (1), subparagraph division (e).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fo\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply to free offers made in connection with services that are subject to the federal }}}{{\f5\fs18\hyphpar0\qj{Communications Act of 1934}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{47 U.S.C. \'a7151 et seq.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fo\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAffirmative consent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a consumer\u8217\'3fs agreement to incur a financial obligation as a result of accepting a free offer, or to provide the consumer\u8217\'3fs billing information, given or made in the manner specifically identified for the consumer to indicate the consumer\u8217\'3fs agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBilling information\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any record or information compiled or maintained with respect to a consumer that identifies the consumer and provides a means by which the consumer\u8217\'3fs financial obligation incurred by accepting a free offer may be paid or otherwise satisfied, including but not limited to information pertaining to a consumer\u8217\'3fs credit card, payment card, charge card, debit card, checking, savings, or other banking account, and electronic funds transfer information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClear and conspicuous information\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means language that is readily understandable and presented in such size, color, contrast, and location, or audibility and cadence, compared to other language, as to be readily noticed and understood, and that is in close proximity to the request for consent to a free offer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConsumer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who seeks to accept or accepts a free offer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFree offer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an offer of goods or services without cost, or for a one-time payment to cover only incidental charges such as shipping or handling, to a consumer that, if accepted, causes the consumer to incur a financial obligation for any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(A)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The goods or services received.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(B)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additional goods or services other than those initially received.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(C)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enrollment in a membership, subscription, or service contract as a result of accepting the offer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFree offer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a free good or service that is received by a consumer as a result of the consumer\u8217\'3fs entering into an agreement for enrollment in a membership, subscription, or service contract that is not otherwise a free offer or a consequence of the consumer\u8217\'3fs agreement to accept a free offer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFree offer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include enrollment in a subscription to a publication, including but not limited to a magazine, newspaper, or other periodical, if the consumer may cancel the subscription at any time and receive a refund for issues not yet distributed, or in the case of a newspaper, a refund for newspapers that would otherwise be distributed after the expiration of the current month.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for an athlete agent to violate any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 9A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be an unlawful practice for a person to violate }}}{{\f5\fs18\hyphpar0\qj{section 558B.2, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be an unlawful practice for a financial institution to violate }}}{{\f5\fs18\hyphpar0\qj{section 525.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is an unlawful practice for a person to violate }}}{{\f5\fs18\hyphpar0\qj{section 554I.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When it appears to the attorney general that a person has engaged in, is engaging in, or is about to engage in any practice declared to be unlawful by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or when the attorney general believes it to be in the public interest that an investigation should be made to ascertain whether a person in fact has engaged in, is engaging in or is about to engage in, any such practice, the attorney general may:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require such person to file on such forms as the attorney general may prescribe a statement or report in writing under oath or otherwise, as to all the facts and circumstances concerning the sale or advertisement of merchandise by such person, and such other data and information as the attorney general may deem necessary;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Examine under oath any person in connection with the sale or advertisement of any merchandise;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Examine any merchandise or sample thereof, record, book, document, account or paper as the attorney general may deem necessary; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to an order of a district court impound any record, book, document, account, paper, or sample of merchandise that is produced in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and retain the same in the attorney general\u8217\'3fs possession until the completion of all proceedings in connection with which the same are produced.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To accomplish the objectives and to carry out the duties prescribed by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the attorney general, in addition to other powers conferred upon the attorney general by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, may issue subpoenas to any person, administer an oath or affirmation to any person, conduct hearings in aid of any investigation or inquiry, prescribe such forms and promulgate such rules as may be necessary, which rules shall have the force of law.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, information, documents, testimony, or other evidence provided to the attorney general by a person pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or provided by a person as evidence in any civil action brought pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall not be admitted in evidence, or used in any manner whatsoever, in any criminal prosecution or forfeiture proceeding against that person. If a criminal prosecution or forfeiture proceeding is initiated in a state court against a person who has provided information pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the state shall have the burden of proof that the information provided was not used in any manner to further the criminal investigation, prosecution, or forfeiture proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply unless the person has first asserted a right against self-incrimination and the attorney general has elected to provide the person with a written statement that the information, documents, testimony, or other evidence at issue are subject to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. After a person has been provided with such a written statement by the attorney general, a claim of privilege against self-incrimination is not a defense to any action or proceeding to obtain the information, documents, testimony, or other evidence. The limitation on the use of evidence in a criminal proceeding contained in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to any prosecution or proceeding for perjury or contempt of court committed in the course of the giving or production of the information, documents, testimony, or other evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Service by the attorney general of any notice requiring a person to file a statement or report, or of a subpoena upon any person, shall be made personally within this state, but if such cannot be obtained, substituted service therefor may be made in the following manner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personal service thereof without this state; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The mailing thereof by registered mail to the last known place of business, residence or abode within or without this state of such person for whom the same is intended; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As to any person other than a natural person, in the manner provided in the rules of civil procedure as if a petition had been filed; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such service as a district court may direct in lieu of personal service within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person fails or refuses to file a statement or report, or obey any subpoena issued by the attorney general, the attorney general may, after notice, apply to the Polk county district court or the district court for the county in which the person resides or is located and, after hearing, request an order:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Granting injunctive relief, restraining the sale or advertisement of any merchandise by such persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Dissolving a corporation created by or under the laws of this state or revoking or suspending the certificate of authority to do business in this state of a foreign corporation or revoking or suspending any other licenses, permits, or certificates issued pursuant to law to such person which are used to further the allegedly unlawful practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Granting such other relief as may be required until the person files the statement or report, or obeys the subpoena.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A civil action pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be by equitable proceedings. If it appears to the attorney general that a person has engaged in, is engaging in, or is about to engage in a practice declared to be unlawful by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the attorney general may seek and obtain in an action in a district court a temporary restraining order, preliminary injunction, or permanent injunction prohibiting the person from continuing the practice or engaging in the practice or doing an act in furtherance of the practice. The court may make orders or judgments as necessary to prevent the use or employment by a person of any prohibited practices, or which are necessary to restore to any person in interest any moneys or property, real or personal, which have been acquired by means of a practice declared to be unlawful by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including the appointment of a receiver in cases of substantial and willful violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. If a person has acquired moneys or property by any means declared to be unlawful by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and if the cost of administering reimbursement outweighs the benefit to consumers or consumers entitled to the reimbursement cannot be located through reasonable efforts, the court may order disgorgement of moneys or property acquired by the person by awarding the moneys or property to the state to be used by the attorney general for the administration and implementation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Except in an action for the concealment, suppression, or omission of a material fact with intent that others rely upon it, it is not necessary in an action for reimbursement or an injunction, to allege or to prove reliance, damages, intent to deceive, or that the person who engaged in an unlawful act had knowledge of the falsity of the claim or ignorance of the truth. A claim for reimbursement may be proved by any competent evidence, including evidence that would be appropriate in a class action.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to the remedies otherwise provided for in }{{\f5\fs18\hyphpar0\qj{this subsection}}}{, the attorney general may request and the court may impose a civil penalty not to exceed forty thousand dollars per violation against a person found by the court to have engaged in a method, act, or practice declared unlawful under }{{\f5\fs18\hyphpar0\qj{this section}}}{; provided, however, a course of conduct shall not be considered to be separate and different violations merely because the conduct is repeated to more than one person. In addition, on the motion of the attorney general or its own motion, the court may impose a civil penalty of not more than five thousand dollars for each day of intentional violation of a temporary restraining order, preliminary injunction, or permanent injunction issued under authority of }{{\f5\fs18\hyphpar0\qj{this section}}}{. A penalty imposed pursuant to }{{\f5\fs18\hyphpar0\qj{this subsection}}}{ is in addition to any penalty imposed pursuant to }{{\f5\fs18\hyphpar0\qj{section 537.6113}}}{. Civil penalties ordered pursuant to }{{\f5\fs18\hyphpar0\qj{this subsection}}}{ shall be paid to the treasurer of state to be deposited in the general fund of the state.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a receiver is appointed by the court pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the receiver shall have the power to sue for, collect, receive and take into possession all the goods and chattels, rights and credits, moneys and effects, lands and tenements, books, records, documents, papers, choses in action, bills, notes and property of every description, derived by means of any practice declared to be illegal and prohibited by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including property with which such property has been mingled if it cannot be identified in kind because of such commingling, and to sell, convey, and assign the same and hold and dispose of the proceeds thereof under the direction of the court. Any person who has suffered damages as a result of the use or employment of any unlawful practices and submits proof to the satisfaction of the court that the person has in fact been damaged, may participate with general creditors in the distribution of the assets to the extent the person has sustained out-of-pocket losses. In the case of a partnership or business entity, the receiver shall settle the estate and distribute the assets under the direction of the court. The court shall have jurisdiction of all questions arising in such proceedings and may make such orders and judgments therein as may be required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to an order of the court terminating the business affairs of any person after receivership proceedings held pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not bar any claim against any person who has acquired any moneys or property, real or personal, by means of any practice herein declared to be unlawful.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A civil action pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be commenced in the county in which the person against whom it is brought resides, has a principal place of business, or is doing business, or in the county where the transaction or any substantial portion of the transaction occurred, or where one or more of the victims reside.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In an action brought under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the attorney general is entitled to recover costs of the court action and any investigation which may have been conducted, including reasonable attorneys\u8217\'3f fees, for the use of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or the application thereof to any person or circumstances is held invalid, the invalidity shall not affect other provisions of applications of the section which can be given effect without the invalid provision or application and to this end the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are severable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general or the designee of the attorney general is deemed to be a regulatory agency under }}}{{\f5\fs18\hyphpar0\qj{chapter 692}}}{{\f5\fs18\hyphpar0\qj{ for the purpose of receiving criminal intelligence data relating to violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the newspaper, magazine, publication, or other print media in which the advertisement appears, or to the radio station, television station, or other electronic media which disseminates the advertisement if the newspaper, magazine, publication, radio station, television station, or other print or electronic media has no knowledge of the fraudulent intent, design, or purpose of the advertiser at the time the advertisement is accepted; and provided, further, that nothing herein contained shall apply to any advertisement which complies with the rules and regulations of, and the statutes administered by the federal trade commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general may bring an action on behalf of the residents of this state, or as parens patriae, under the federal Telemarketing and Consumer Fraud and Abuse Prevention Act, Pub. L. No. 103-297, and pursue any and all enforcement options available under that Act. Subsequent amendments to that Act which do not substantially alter its structure and purpose shall not be construed to affect the authority of the attorney general to pursue an action pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, except to the extent the amendments specifically restrict the authority of the attorney general.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a75051-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13069, 13070;}}}{ C46, 50, 54, 58, 62, \'a7713.24, 713.25; C66, 71, 73, 75, 77, \'a7713.24; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.16}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 146, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 16, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 164, \'a71 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1016, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 93, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 129, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1010, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1236, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 212, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1062, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1142, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1200, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1079, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1232, \'a785}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 58, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7194, 203}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 101, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1139, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1015, \'a71 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 47, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 25, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 126, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a79A.116}}}{{\f5\fs12\hyphpar0\qj{, 13C.2}}}{{\f5\fs12\hyphpar0\qj{, 13C.8}}}{{\f5\fs12\hyphpar0\qj{, 22A.1}}}{{\f5\fs12\hyphpar0\qj{, 103A.71}}}{{\f5\fs12\hyphpar0\qj{, 123.23}}}{{\f5\fs12\hyphpar0\qj{, 126.5}}}{{\f5\fs12\hyphpar0\qj{, 154A.24}}}{{\f5\fs12\hyphpar0\qj{, 154A.26}}}{{\f5\fs12\hyphpar0\qj{, 162.10D}}}{{\f5\fs12\hyphpar0\qj{, 261B.12}}}{{\f5\fs12\hyphpar0\qj{, 261F.9}}}{{\f5\fs12\hyphpar0\qj{, 261G.6}}}{{\f5\fs12\hyphpar0\qj{, 321.69}}}{{\f5\fs12\hyphpar0\qj{, 321.69A}}}{{\f5\fs12\hyphpar0\qj{, 321.71A}}}{{\f5\fs12\hyphpar0\qj{, 321H.6}}}{{\f5\fs12\hyphpar0\qj{, 322.6}}}{{\f5\fs12\hyphpar0\qj{, 322.19A}}}{{\f5\fs12\hyphpar0\qj{, 322C.6}}}{{\f5\fs12\hyphpar0\qj{, 322G.2}}}{{\f5\fs12\hyphpar0\qj{, 322G.10}}}{{\f5\fs12\hyphpar0\qj{, 453A.52B}}}{{\f5\fs12\hyphpar0\qj{, 476.95}}}{{\f5\fs12\hyphpar0\qj{, 516D.7}}}{{\f5\fs12\hyphpar0\qj{, 516D.9}}}{{\f5\fs12\hyphpar0\qj{, 523A.807}}}{{\f5\fs12\hyphpar0\qj{, 523C.13}}}{{\f5\fs12\hyphpar0\qj{, 523G.9}}}{{\f5\fs12\hyphpar0\qj{, 523I.205}}}{{\f5\fs12\hyphpar0\qj{, 525.1}}}{{\f5\fs12\hyphpar0\qj{, 533A.8A}}}{{\f5\fs12\hyphpar0\qj{, 533A.10}}}{{\f5\fs12\hyphpar0\qj{, 533D.11}}}{{\f5\fs12\hyphpar0\qj{, 535B.10}}}{{\f5\fs12\hyphpar0\qj{, 535B.13}}}{{\f5\fs12\hyphpar0\qj{, 535C.10}}}{{\f5\fs12\hyphpar0\qj{, 536.10}}}{{\f5\fs12\hyphpar0\qj{, 536A.15}}}{{\f5\fs12\hyphpar0\qj{, 537.2403}}}{{\f5\fs12\hyphpar0\qj{, 537.3309}}}{{\f5\fs12\hyphpar0\qj{, 543D.18A}}}{{\f5\fs12\hyphpar0\qj{, 546B.5}}}{{\f5\fs12\hyphpar0\qj{, 551A.10}}}{{\f5\fs12\hyphpar0\qj{, 552.13}}}{{\f5\fs12\hyphpar0\qj{, 552A.5}}}{{\f5\fs12\hyphpar0\qj{, 554.3513}}}{{\f5\fs12\hyphpar0\qj{, 554I.4}}}{{\f5\fs12\hyphpar0\qj{, 555A.6}}}{{\f5\fs12\hyphpar0\qj{, 557A.16}}}{{\f5\fs12\hyphpar0\qj{, 557B.14}}}{{\f5\fs12\hyphpar0\qj{, 558A.4A}}}{{\f5\fs12\hyphpar0\qj{, 558B.2}}}{{\f5\fs12\hyphpar0\qj{, 577.3}}}{{\f5\fs12\hyphpar0\qj{, 714.16A}}}{{\f5\fs12\hyphpar0\qj{, 714.16B}}}{{\f5\fs12\hyphpar0\qj{, 714.16C}}}{{\f5\fs12\hyphpar0\qj{, 714.21A}}}{{\f5\fs12\hyphpar0\qj{, 714A.1}}}{{\f5\fs12\hyphpar0\qj{, 714A.5}}}{{\f5\fs12\hyphpar0\qj{, 714B.1}}}{{\f5\fs12\hyphpar0\qj{, 714B.7}}}{{\f5\fs12\hyphpar0\qj{, 714B.9}}}{{\f5\fs12\hyphpar0\qj{, 714D.2}}}{{\f5\fs12\hyphpar0\qj{, 714D.7}}}{{\f5\fs12\hyphpar0\qj{, 714E.6}}}{{\f5\fs12\hyphpar0\qj{, 714F.9}}}{{\f5\fs12\hyphpar0\qj{, 714G.11}}}{{\f5\fs12\hyphpar0\qj{, 714H.2}}}{{\f5\fs12\hyphpar0\qj{, 714H.3}}}{{\f5\fs12\hyphpar0\qj{, 715A.8}}}{{\f5\fs12\hyphpar0\qj{, 715C.2}}}{{\f5\fs12\hyphpar0\qj{, 716A.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendments to subsection 1 and subsection 2, paragraph h effective January 1, 2023, and apply to the sale, lease, and rental of water treatment systems, and the advertisement of the sale, lease, or rental of water treatment systems occurring on or after January 1, 2023; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1015.pdf" }{\fldrslt \cf5 \f5 \fs12{{2022 Acts, ch 1015, \'a75, 6}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See Code editor\u8217\'3fs note on simple harmonization at the beginning of this Code volume}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, NEW paragraph r}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, NEW paragraph s}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.16A}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional civil penalty for consumer frauds committed against older individuals }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fund established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person violates }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{, and the violation is committed against an older individual, in an action brought by the attorney general, in addition to any other civil penalty, the court may impose an additional civil penalty not to exceed five thousand dollars for each such violation. Additionally, the attorney general may accept a civil penalty as determined by the attorney general in settlement of an investigation of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{, regardless of whether an action has been filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A civil penalty imposed by a court or determined and accepted by the attorney general pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be paid to the treasurer of state, who shall deposit the money in the elderly victim fund, a separate fund created in the state treasury and administered by the attorney general for the investigation and prosecution of frauds against the elderly. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, any balance in the fund on June 30 of any fiscal year shall not revert to the general fund of the state. An award of reimbursement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{ has priority over a civil penalty imposed by the court pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining whether to impose a civil penalty under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and the amount of any such penalty, the court shall consider the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the defendant\u8217\'3fs conduct was in willful disregard of the rights of the older individual.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the defendant knew or should have known that the defendant\u8217\'3fs conduct was directed to an older individual.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the older individual was substantially more vulnerable to the defendant\u8217\'3fs conduct because of age, poor health, infirmity, impaired understanding, restricted mobility, or disability, than other persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other factors the court deems appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3folder individual\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who is sixty years of age or older.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 102, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1142, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1200, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7261}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1132, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713.2}}}{{\f5\fs12\hyphpar0\qj{, 633.669}}}{{\f5\fs12\hyphpar0\qj{, 633.670}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.16B}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Identity theft }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ civil cause of action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other remedies provided by law, a person as defined under }}}{{\f5\fs18\hyphpar0\qj{section 714.16, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, suffering a pecuniary loss as a result of an identity theft by another person under }}}{{\f5\fs18\hyphpar0\qj{section 715A.8}}}{{\f5\fs18\hyphpar0\qj{, or a financial institution on behalf of an account holder suffering a pecuniary loss as a result of an identity theft by another person under }}}{{\f5\fs18\hyphpar0\qj{section 715A.8}}}{{\f5\fs18\hyphpar0\qj{, may bring an action against such other person to recover all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five thousand dollars or three times the actual damages, whichever is greater.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reasonable costs incurred due to the violation of }}}{{\f5\fs18\hyphpar0\qj{section 715A.8}}}{{\f5\fs18\hyphpar0\qj{, including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Costs for repairing the victim\u8217\'3fs credit history or credit rating.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Costs incurred for bringing a civil or administrative proceeding to satisfy a debt, lien, judgment, or other obligation of the victim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Punitive damages, attorney fees, and court costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffinancial institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 527.2}}}{{\f5\fs18\hyphpar0\qj{, and includes an insurer organized under }}}{{\f5\fs18\hyphpar0\qj{Title XIII, subtitle 1}}}{{\f5\fs18\hyphpar0\qj{, of this Code, or under the laws of any other state or the United States.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 47, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 18, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7209}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7614.4A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.16C}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consumer education and litigation fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A consumer education and litigation fund is created as a separate fund in the state treasury to be administered by the attorney general. Moneys credited to the fund shall include amounts received as a result of a state or federal civil consumer fraud judgment or settlement, civil penalties, costs, or attorney fees, and amounts which are specifically directed to the credit of the fund by the judgment or settlement, and amounts which are designated by the judgment or settlement for use by the attorney general for consumer litigation or education purposes. Moneys designated for consumer reimbursement shall not be credited to the fund, except to the extent that such moneys are permitted to be used for enforcement of }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each fiscal year, not more than one million eight hundred seventy-five thousand dollars is appropriated from the fund to the department of justice to be used for public education relating to consumer fraud and for enforcement of }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{ and federal consumer laws, and not more than one hundred twenty-five thousand dollars is appropriated from the fund to the department of justice to be used for investigation, prosecution, and consumer education relating to consumer and criminal fraud committed against older Iowans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys credited to the fund shall not revert to any other fund. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on the moneys in the fund shall be credited to the fund.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 213, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 154, \'a721}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7715D.1}}}{{\f5\fs12\hyphpar0\qj{, 715D.8}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See annual Iowa Acts for appropriations from fund for farm mediation services and for criminal prosecutions, criminal appeals, and state tort claim representation}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.17}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unlawful advertising and selling of educational courses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be unlawful for any person, firm, association, or corporation maintaining, advertising, or conducting in Iowa any educational course for profit, or for tuition charge, whether by classroom instructions, by correspondence, or by other delivery method to:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Falsely advertise or represent to any person any matter material to an educational course. All advertising of such courses shall adhere to and comply with the applicable rules and regulations of the federal trade commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collect tuition or other charges in excess of one hundred fifty dollars in the case of educational courses offered by correspondence, in advance of the receipt and approval by the pupil of the first assignment or lesson of such course. Any contract providing for advance payment of more than one hundred fifty dollars shall be voidable on the part of the pupil or any person liable for the tuition provided for in the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promise or guarantee employment utilizing information, training, or skill purported to be provided or otherwise enhanced by an educational course, unless the promisor or guarantor offers the student or prospective student a bona fide contract of employment agreeing to employ said student or prospective student for a period of not less than one hundred twenty days in a business or other enterprise regularly conducted by the promisor or guarantor and in which such information, training, or skill is a normal condition of employment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7713A.1; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1077, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7261G.4}}}{{\f5\fs12\hyphpar0\qj{, 714.19}}}{{\f5\fs12\hyphpar0\qj{, 714.21}}}{{\f5\fs12\hyphpar0\qj{, 714.21A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.18}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Evidence of financial responsibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every person, firm, association, or corporation maintaining or conducting in Iowa any educational course by classroom instruction or by correspondence or by other delivery method, or soliciting in Iowa the sale of such course, shall file with the college student aid commission, in a format prescribed by the commission, all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A continuous corporate surety bond to the state of Iowa in the sum of fifty thousand dollars or ten percent of the total annual tuition determined in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, whichever is less, conditioned on the faithful performance of all contracts and agreements with students made by such person, firm, association, or corporation, or their salespersons. The aggregate liability of the surety for all breaches of the conditions of the bond shall not exceed the sum of the bond. The surety on the bond may cancel the bond upon giving thirty days\u8217\'3f written notice to the college student aid commission and thereafter shall be relieved of liability for any breach of condition occurring after the effective date of the cancellation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement designating a resident agent for the purpose of receiving service in civil actions. In the absence of such designation, service may be had upon the secretary of state if service cannot otherwise be made in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of any catalog, prospectus, brochure, or other advertising material intended for distribution in Iowa. Such material shall state the cost of the educational course offered, the schedule of tuition refunds for portions of the educational course not completed, and if no refunds are to be paid, the material shall so state. Any contract induced by advertising materials not previously filed as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be voidable on the part of the pupil or any person liable for the tuition provided for in the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school that files with the college student aid commission a continuous corporate surety bond in a sum less than fifty thousand dollars shall provide to the college student aid commission, in the format prescribed by the commission, a notarized statement attesting to the total amount of tuition the school charged to students in the immediately preceding fiscal year. The commission shall determine the sufficiency of the statement and the amount of the bond or, as permitted under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, letter of credit. Tuition information submitted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be kept confidential.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The aggregate liability of the surety for all breaches of the conditions of the bond shall not exceed the sum of the bond. The surety on the bond may cancel the bond upon giving thirty days\u8217\'3f written notice to the college student aid commission and thereafter shall be relieved of liability for any breach of condition occurring after the effective date of the cancellation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The college student aid commission may accept a letter of credit issued by a state or federally chartered bank or credit union in lieu of and for the amount of the corporate surety bond required under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 261B}}}{{\f5\fs18\hyphpar0\qj{, a letter of credit must meet all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be payable to the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be valid for a period of at least one year from the date of issuance and subject to renewal as required by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allow the commission to draw one or multiple installments of the total letter of credit amount upon making the required presentations to the issuer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fletter of credit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a financial instrument subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 554, article 5}}}{{\f5\fs18\hyphpar0\qj{, with irrevocable terms and conditions that cannot be modified or canceled after issuance without the consent of all of the parties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a letter of credit accepted by the college student aid commission under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ is canceled, revoked, not renewed, or otherwise fails to be of full force and effect, the school shall comply with the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to the provision of an educational course of flight instruction under regulations promulgated by the federal aviation administration for which students do not pay tuition in advance of instruction and which students may cancel at any time with no further monetary obligation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7713A.2; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.18}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 240, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1222, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1140, \'a740-42}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 12, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1077, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 140, \'a750, 51, 53, 54}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 158, \'a73 \u8211\'3f 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7261B.4}}}{{\f5\fs12\hyphpar0\qj{, 261B.11}}}{{\f5\fs12\hyphpar0\qj{, 261G.4}}}{{\f5\fs12\hyphpar0\qj{, 714.19}}}{{\f5\fs12\hyphpar0\qj{, 714.21}}}{{\f5\fs12\hyphpar0\qj{, 714.21A}}}{{\f5\fs12\hyphpar0\qj{, 714.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.19}}}{\*\bkmkstart stylerid1_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonapplicability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{sections 714.17}}}{, }{{\f5\fs18\hyphpar0\qj{714.18}}}{, }{{\f5\fs18\hyphpar0\qj{714.20}}}{, and }{{\f5\fs18\hyphpar0\qj{714.21}}}{ shall not apply to the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A community college established under }}}{{\f5\fs18\hyphpar0\qj{chapter 260C}}}{{\f5\fs18\hyphpar0\qj{ or an institution of higher learning under the control of the state board of regents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public college or university created or authorized by the laws of any other state to grant degrees, in which state the college or university maintains its principal domicile and from which the college or university receives public funds to support the operating costs of the college or university.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district described in }}}{{\f5\fs18\hyphpar0\qj{chapter 274}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Private and nonprofit elementary or secondary schools recognized by the department of education or the board of directors of a school district for the purpose of complying with }}}{{\f5\fs18\hyphpar0\qj{chapter 299}}}{{\f5\fs18\hyphpar0\qj{ and employing teachers licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 256, subchapter VII, part 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonprofit schools exclusively engaged in training persons with disabilities in the state of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Schools and educational programs conducted by firms, corporations, or persons for which no fee is charged to any student or any other party who assumes the cost of education on the student\u8217\'3fs behalf.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seminars, refresher courses, and schools of instruction conducted by professional, business, or farming organizations or associations for the members and employees of members of such organizations or associations. A person who provides instruction under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ who is not a member or an employee of a member of the organization or association shall not be eligible for this exemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Private college preparatory schools accredited or probationally accredited under }}}{{\f5\fs18\hyphpar0\qj{section 256.11, subsection 13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Private, nonprofit schools that meet the criteria established under }}}{{\f5\fs18\hyphpar0\qj{section 256.183, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7713A.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71498}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 240, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a7108}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1079, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1077, \'a713 \u8211\'3f 15}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7173}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 158, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72602}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a7100}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7261B.4}}}{{\f5\fs12\hyphpar0\qj{, 261B.11}}}{{\f5\fs12\hyphpar0\qj{, 714.24}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Unnumbered paragraph 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.20}}}{\*\bkmkstart stylerid1_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{One contract per person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be unlawful to sell more than one lifetime contract to any one person.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7713A.4; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.20}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7261G.4}}}{{\f5\fs12\hyphpar0\qj{, 714.19}}}{{\f5\fs12\hyphpar0\qj{, 714.21}}}{{\f5\fs12\hyphpar0\qj{, 714.21A}}}{{\f5\fs12\hyphpar0\qj{, 714.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.21}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Violation of any of the provisions of }{{\f5\fs18\hyphpar0\qj{section 714.17}}}{, }{{\f5\fs18\hyphpar0\qj{714.18}}}{ or }{{\f5\fs18\hyphpar0\qj{714.20}}}{ shall be a serious misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, \'a7713A.5; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7714.21}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7261G.4}}}{{\f5\fs12\hyphpar0\qj{, 714.19}}}{{\f5\fs12\hyphpar0\qj{, 714.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.21A}}}{\*\bkmkstart stylerid1_2E39_2E2_2E2}{\*\bkmkend stylerid1_2E39_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A violation of }{{\f5\fs18\hyphpar0\qj{chapter 261B}}}{, or }{{\f5\fs18\hyphpar0\qj{section 714.17}}}{, }{{\f5\fs18\hyphpar0\qj{714.18}}}{, }{{\f5\fs18\hyphpar0\qj{714.20}}}{, }{{\f5\fs18\hyphpar0\qj{714.23}}}{, or }{{\f5\fs18\hyphpar0\qj{714.25}}}{ constitutes an unlawful practice pursuant to }{{\f5\fs18\hyphpar0\qj{section 714.16}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 12, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7714.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.22}}}{\*\bkmkstart stylerid1_2E4_30_2E2_2E2}{\*\bkmkend stylerid1_2E4_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trade and vocational schools \u8212\'3f exemption \u8212\'3f conditions.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1077, \'a720}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.23}}}{\*\bkmkstart stylerid1_2E41_2E2_2E2}{\*\bkmkend stylerid1_2E41_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Refund policies }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPayment period\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as set forth in }}}{{\f5\fs18\hyphpar0\qj\cf1{34 C.F.R. \'a7668.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPostsecondary educational program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a series of postsecondary educational courses that lead to a recognized educational credential including but not limited to an academic or professional degree, diploma, license, or other certification or designation, regardless of whether the school awards the credential.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProprietary school\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person offering a postsecondary educational program, for profit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchool period\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the course, term, payment period, postsecondary educational program, or other period for which the school assessed tuition charges to the student. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proprietary school shall refund all tuition charges to a student who withdraws within the first two calendar weeks of instruction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proprietary school shall make a pro rata refund of tuition charges to a student who terminates from any of the school\u8217\'3fs postsecondary educational programs or courses after the first two calendar weeks in an amount that is not less than ninety-five percent of the amount of tuition charged to the student multiplied by the ratio of the number of calendar days remaining in the school period to the total number of calendar days in the school period. If a terminating student has completed sixty percent or more of a school period, the school offering the postsecondary educational program is not required to refund tuition charges to the student.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proprietary school as provided in subparagraph (2) shall provide to a student who terminates after the first two calendar weeks a refund of tuition charges in an amount that is not less than ninety-five percent of the amount of tuition charged to the student multiplied by the ratio of the remaining number of calendar days in the school period to the total number of calendar days in the school period.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies to a proprietary school whose cohort default rate for students under the Stafford loan program as reported by the United States department of education for the most recent federal fiscal year is more than one hundred ten percent of the national average cohort default rate of all schools for the same federal fiscal year or six percent, whichever is higher.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proprietary school that assesses tuition charges to the student at the beginning of each course, term, payment period, or other period that is shorter than the postsecondary educational program\u8217\'3fs length shall base its tuition refund on the amount of tuition costs the school charged for the course, term, or other period in which the student terminated. A school shall not base its tuition refund calculation on any portion of a postsecondary educational program that remains after a student terminates unless the student was charged for that remaining portion of the postsecondary educational program before the student\u8217\'3fs termination and the student began attendance in the school term or course.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if, at any time, a student terminates a postsecondary educational program after the first two calendar weeks due to the student\u8217\'3fs physical incapacity or, for a program that requires classroom instruction, due to the transfer of the student\u8217\'3fs spouse\u8217\'3fs employment to another city, the terminating student shall receive a refund of the tuition charges in an amount that equals the amount of tuition charged to the student multiplied by the ratio of the remaining number of calendar days in the school period to the total number of calendar days in the school period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a program in which student progress is measured only in clock hours, all occurrences of \u8220\'3fcalendar days\u8221\'3f in }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 4}}}{{\f5\fs18\hyphpar0\qj{ shall be replaced with \u8220\'3fscheduled clock hours\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A student who does not receive a tuition refund up to the full refund of tuition charges due to the effect of an interstate reciprocity agreement under }}}{{\f5\fs18\hyphpar0\qj{section 261G.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, may apply to the attorney general for a refund in a sum that represents the difference between any tuition refund received from the school and the full refund of tuition charges. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffull refund of tuition charges\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the monetary sum of the refund for which the student would be eligible pursuant to the application of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tuition refund fund is created as a separate fund in the office of the treasurer of state under the control of the attorney general. Moneys credited to the fund shall include amounts appropriated by the general assembly and moneys received as a result of a court order, judgment, or settlement which specifically directs that moneys be used for the purpose of providing student tuition refunds, or which authorizes the attorney general to use moneys for any other purpose at the discretion of the attorney general. All moneys credited to the fund are appropriated and made available to the attorney general for such purposes. For each fiscal year, the attorney general may expend all moneys in the fund to provide tuition refunds to eligible students. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, any balance in the fund on June 30 of each fiscal year shall not revert to the general fund of the state, but shall be available for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ in subsequent fiscal years. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on the moneys in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A refund of tuition charges shall be provided to the student within forty-five days following the date of the school\u8217\'3fs determination that a student has terminated from a postsecondary educational program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A student who terminates a postsecondary educational program shall not be charged any fee or other monetary penalty for terminating the postsecondary educational program, other than a reduction in tuition refund as specified in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proprietary school shall apply the refund policy it adopts in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to all students who attend on-campus classes or at instructional sites in Iowa and to all Iowa resident students who attend the school\u8217\'3fs distance education programs. A proprietary school offering instructional programs or courses under an interstate reciprocity agreement entered into or recognized by the commission under }}}{{\f5\fs18\hyphpar0\qj{chapter 261G}}}{{\f5\fs18\hyphpar0\qj{ shall apply the policy it adopts under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to Iowa resident and nonresident students who attend distance education programs the school offers under the interstate reciprocity agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personal vehicle driving education schools.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Postsecondary vocational schools that offer solely discrete continuing education courses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A for-profit school that offers solely programs for which the sum of tuition, fees, instructional materials, technology, and other items required for program completion is less than three thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is a simple misdemeanor.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 220, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1222, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1077, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 107, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 138, \'a749, 161, 162}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 158, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7261B.4}}}{{\f5\fs12\hyphpar0\qj{, 261B.11}}}{{\f5\fs12\hyphpar0\qj{, 261G.4}}}{{\f5\fs12\hyphpar0\qj{, 714.21A}}}{{\f5\fs12\hyphpar0\qj{, 714.24}}}{{\f5\fs12\hyphpar0\qj{, 714.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.24}}}{\*\bkmkstart stylerid1_2E42_2E2_2E2}{\*\bkmkend stylerid1_2E42_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A required filing of evidence of financial responsibility pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 714.18}}}{{\f5\fs18\hyphpar0\qj{ must be completed at least once every two years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity that claims an exemption under }}}{{\f5\fs18\hyphpar0\qj{section 714.19}}}{{\f5\fs18\hyphpar0\qj{ must file an exemption claim with the commission. The commission may approve or deny the exemption claim. Except for a school that claims an exemption under }}}{{\f5\fs18\hyphpar0\qj{section 714.19, subsection 1, 2, 3, or 9}}}{{\f5\fs18\hyphpar0\qj{, a filing of a claim for an exemption pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 714.19}}}{{\f5\fs18\hyphpar0\qj{ must be completed at least once every two years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity that claims an exemption under }}}{{\f5\fs18\hyphpar0\qj{section 714.19}}}{{\f5\fs18\hyphpar0\qj{ must file evidence of financial responsibility pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 714.18}}}{{\f5\fs18\hyphpar0\qj{ within sixty calendar days following the date upon which conditions that qualify the entity for an exemption under }}}{{\f5\fs18\hyphpar0\qj{section 714.19}}}{{\f5\fs18\hyphpar0\qj{ no longer exist. The commission may grant an entity a longer period to file evidence of financial responsibility based on documentation the entity provides to the commission of its substantial progress to comply with }}}{{\f5\fs18\hyphpar0\qj{section 714.18, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity that is required to file evidence of financial responsibility under }}}{{\f5\fs18\hyphpar0\qj{section 714.18}}}{{\f5\fs18\hyphpar0\qj{, or an entity that files a claim of exemption under }}}{{\f5\fs18\hyphpar0\qj{section 714.19}}}{{\f5\fs18\hyphpar0\qj{, shall utilize required forms approved and supplied by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proprietary school that must comply with }}}{{\f5\fs18\hyphpar0\qj{sections 714.23}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{714.25}}}{{\f5\fs18\hyphpar0\qj{ shall submit documentation of compliance with }}}{{\f5\fs18\hyphpar0\qj{sections 714.23}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{714.25}}}{{\f5\fs18\hyphpar0\qj{ to the commission for review and approval as part of the evidence of financial responsibility filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 714.18}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission and the attorney general may, individually or jointly, adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ for the implementation of }}}{{\f5\fs18\hyphpar0\qj{sections 714.18 through 714.25}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 714.18, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the information submitted under }}}{{\f5\fs18\hyphpar0\qj{sections 714.18}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{714.19}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{714.23}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{714.25}}}{{\f5\fs18\hyphpar0\qj{ are public records under }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1077, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7189}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 158, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7261G.4}}}{{\f5\fs12\hyphpar0\qj{, 714.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.25}}}{\*\bkmkstart stylerid1_2E43_2E2_2E2}{\*\bkmkend stylerid1_2E43_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disclosure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fproprietary school\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 714.23, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proprietary school shall, prior to the time a student is obligated for payment of any moneys, inform the student and the college student aid commission of all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The current total cost of the postsecondary educational program as charged by the proprietary school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An estimate of fees that may be charged to the student by others in order to obtain a recognized educational credential, including but not limited to fees for examination or licensure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The percentage of students who successfully complete the postsecondary educational program and the percentage who terminate prior to completing the postsecondary educational program in accordance with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If claims are made by the proprietary school as to successful placement of students in jobs upon completion of the proprietary school\u8217\'3fs postsecondary educational programs, the proprietary school shall, in accordance with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, provide the student with all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The percentage of graduating students who were placed in jobs in fields related to the postsecondary educational programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The percentage of graduating students who went on to further education immediately upon graduation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The percentage of students who, ninety days after graduation, were without a job and had not gone on to further education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The method by which the proprietary school collected and verified the validity of data provided in accordance with this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information provided by the proprietary school in accordance with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and, if applicable, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall include all of the following additional data:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicable program name and the normal length of time required to complete the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total number of students in the cohort for which data is reported and the year in which the students began the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The percentages of students that met the conditions described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and, if applicable, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, by the most recent ending date for program completion in each of the school\u8217\'3fs programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If claims are made by the proprietary school as to income levels of students who have graduated and are working in fields related to the proprietary school\u8217\'3fs postsecondary educational programs, the proprietary school shall inform the student of the method used to derive such information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proprietary school that is initiating operation for the first time is exempt from data reporting under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, until the school\u8217\'3fs first biennial renewal application under }}}{{\f5\fs18\hyphpar0\qj{section 714.24, subsection 5}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to any of the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A proprietary school that is eligible for federal student financial aid under }}}{{\f5\fs18\hyphpar0\qj{Tit. IV of the federal Higher Education Act of 1965, as amended}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person described in }}}{{\f5\fs18\hyphpar0\qj{section 714.23, subsection 11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1274, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 296, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1222, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a7182}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1077, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 158, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7261G.4}}}{{\f5\fs12\hyphpar0\qj{, 714.21A}}}{{\f5\fs12\hyphpar0\qj{, 714.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.26}}}{\*\bkmkstart stylerid1_2E44_2E2_2E2}{\*\bkmkend stylerid1_2E44_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Intellectual property counterfeiting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E44_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E44_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounterfeit mark\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any unauthorized reproduction or copy of intellectual property, or intellectual property affixed to any item knowingly sold, offered for sale, manufactured, or distributed, or identifying services offered or rendered, without authority of the owner of the intellectual property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIntellectual property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any trademark, service mark, trade name, label, term, device, design, or word adopted or used by a person to identify the items or services of the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRetail value\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the highest value of an item determined by any reasonable standard at the time the item bearing or identified by a counterfeit mark is seized. If a seized item bearing or identified by a counterfeit mark is a component of a finished product, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fretail value\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also means the highest value, determined by any reasonable standard, of the finished product on which the component would have been utilized. The retail value shall be the retail value of the aggregate quantity of all items seized which bear or are identified by a counterfeit mark. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freasonable standard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to the market value within the community, actual value, replacement value, or the counterfeiter\u8217\'3fs regular selling price for the item bearing or identified by a counterfeit mark, or the intellectual property owner\u8217\'3fs regular selling price for an item similar to the item bearing or identified by a counterfeit mark.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E44_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E44_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Criminal offense.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who knowingly manufactures, produces, displays, advertises, distributes, offers for sale, sells, possesses with intent to sell or distributes any item or knowingly provides service bearing or identified by a counterfeit mark commits intellectual property counterfeiting.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits intellectual property counterfeiting in the first degree if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is manufacturing or producing an item bearing or identified by a counterfeit mark.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense involves more than one thousand items bearing or identified by a counterfeit mark or the total retail value of such items is equal to or greater than ten thousand dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a third or subsequent violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Intellectual property counterfeiting in the first degree is a class \u8220\'3fC\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits intellectual property counterfeiting in the second degree if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense involves more than one hundred items but does not involve more than one thousand items bearing or identified by a counterfeit mark or the total retail value of such items is equal to or greater than one thousand dollars but less than ten thousand dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offense is a second violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Intellectual property counterfeiting in the second degree is a class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All intellectual property counterfeiting which is not intellectual property counterfeiting in the first degree or second degree is intellectual property counterfeiting in the third degree. Intellectual property counterfeiting in the third degree is an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E44_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E44_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Evidence.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any state or federal certificate of registration of any intellectual property shall be prima facie evidence of ownership of the intellectual property in dispute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E44_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E44_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Seizure and disposition.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any items bearing or identified by a counterfeit mark, and all personal property, including but not limited to any items, objects, tools, machines, equipment, instrumentalities, or vehicles used in connection with a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall be seized by any law enforcement agency.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All seized personal property shall be disposed of in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 809.5}}}{{\f5\fs18\hyphpar0\qj{ or as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request of the intellectual property owner, all seized items bearing or identified by a counterfeit mark shall be released by the seizing agency to the intellectual property owner for destruction or disposition. If the intellectual property owner does not request release of the seized items, the items shall be destroyed unless the intellectual property owner consents to another disposition.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1112, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7390}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7210}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.27}}}{\*\bkmkstart stylerid1_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scrap metal transactions and reporting }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and unless the context otherwise requires, the following definitions shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fScrap metal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any metal suitable for reprocessing. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fScrap metal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a motor vehicle or a catalytic converter detached from a motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fScrap metal dealer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person operating a business at a fixed or mobile location that is engaged in one of the following activities:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Buying, selling, procuring, collecting, gathering, soliciting, or dealing in scrap metal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating, managing, or maintaining a scrap metal yard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fScrap metal yard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any yard, plot, space, enclosure, building, mobile facility, or other place where scrap metal is collected, gathered together, stored, or kept for shipment, sale, or transfer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell scrap metal to a scrap metal dealer in this state unless the person provides to the scrap metal dealer, at or before the time of sale, the person\u8217\'3fs name, address, and place of business, if any, and presents to the scrap metal dealer a valid driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card, military identification card, passport, or other government-issued photo identification.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A scrap metal dealer shall not make an initial purchase of scrap metal from a person without demanding and receiving the information required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. However, after an initial transaction, a scrap metal dealer may only require the person\u8217\'3fs name and place of business for subsequent purchases, provided the scrap metal dealer retains all information received during the initial transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A scrap metal dealer shall keep a confidential register or log of each transaction, including a record of the information required by }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. All records and information kept pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be retained for at least two years, and shall be provided to a law enforcement agency or other officer or employee designated by a county or city to enforce }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ upon request during normal business hours when the law enforcement agency or designated officer or employee of a county or city has reasonable grounds to request such information as part of an investigation. A law enforcement agency or designated officer or employee of a county or city shall preserve the confidentiality of the information provided under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and shall not disclose it to a third party, except as may be necessary in enforcement of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or the prosecution of a criminal violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All scrap metal transactions, other than those transactions exempt pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, in which the total sale price exceeds fifty dollars shall require payment by check or electronic funds transfer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following scrap metal transactions are exempt from the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transactions in which the total sale price is fifty dollars or less.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transactions in which a scrap metal dealer is selling scrap metal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transactions in which the person selling the scrap metal is known to the scrap metal dealer purchasing the scrap metal to be the officer, employee, or agent of an established commercial or industrial business, operating from a fixed location, that may reasonably be expected to produce scrap metal during the operation of the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall take precedence over and supersede any local ordinance adopted by a political subdivision that regulates scrap metal transactions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a city ordinance regarding scrap metal or other scrap material in effect prior to January 1, 2012, in a city with a population exceeding one hundred fifty thousand as shown by the 2010 federal decennial census may continue to be enforced by the city which adopted it.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or a person who conducts a scrap metal transaction by or on behalf of a scrap metal dealer who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to a civil penalty as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An initial violation shall subject the person to a civil penalty in the amount of one hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A second violation within two years shall subject the person to a civil penalty in the amount of five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A third or subsequent violation within two years shall subject the person to a civil penalty in the amount of one thousand dollars.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 51, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a7112}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1099, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1092, \'a72 \u8211\'3f 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7714.27A}}}{{\f5\fs12\hyphpar0\qj{, 805.8C(10)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8C, subsection 10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.27A}}}{\*\bkmkstart stylerid1_2E46_2E2_2E2}{\*\bkmkend stylerid1_2E46_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Used catalytic converter transactions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ reporting }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBusiness transaction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an exchange of consideration for a catalytic converter between a scrap metal dealer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 714.27}}}{{\f5\fs18\hyphpar0\qj{, and another scrap metal dealer, an authorized vehicle recycler licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 321H}}}{{\f5\fs18\hyphpar0\qj{ operating a business at a fixed location, a motor vehicle dealer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ operating a business at a fixed location, a towable recreational vehicle dealer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322C}}}{{\f5\fs18\hyphpar0\qj{ operating a business at a fixed location, a mechanic or an automotive repair facility operating a business at a fixed location, or a person operating a similar business at a fixed location in another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCatalytic converter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a catalytic converter that was previously installed in a motor vehicle and subsequently removed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell a catalytic converter in this state unless the person provides to the purchaser, at or before the time of sale, the person\u8217\'3fs name, address, and place of business, if any, and presents to the purchaser a valid driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card, military identification card, passport, or other government-issued photo identification.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a business transaction in which the person selling the catalytic converter operates a business at a fixed location in this state, the person shall provide to the purchaser a copy of the person\u8217\'3fs valid sales tax permit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 423}}}{{\f5\fs18\hyphpar0\qj{ or a copy of the person\u8217\'3fs valid business license or permit. For a business transaction in which the person selling the catalytic converter operates a business at a fixed location in another state and is authorized to conduct a business transaction in this state, the person shall provide to the purchaser a copy of the person\u8217\'3fs valid sales tax permit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 423}}}{{\f5\fs18\hyphpar0\qj{, if the person has such a permit, or a copy of the person\u8217\'3fs valid business license or permit from the other state. If a person is unable to provide the documentation required in this paragraph, the person shall instead comply with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For transactions other than business transactions, the person selling the catalytic converter shall provide to the purchaser an original receipt or invoice for a replacement catalytic converter purchased fewer than thirty days before the person sells the replaced catalytic converter, a signed affidavit attesting to the seller\u8217\'3fs valid ownership of the catalytic converter, or a junking certificate for a vehicle that was issued fewer than thirty days before the person sells the catalytic converter.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The receipt, invoice, affidavit, or junking certificate presented by the person to the purchaser must be unmarked by a purchaser pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph does not apply to a transaction if the person presents proof, unmarked pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, to the purchaser that the sale is approved by the sheriff of the county in which the vehicle from which the catalytic converter was removed is registered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not purchase a catalytic converter from a seller without demanding and receiving the information required by }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who purchases a catalytic converter shall mark the receipt, invoice, affidavit, junking certificate, or proof of sheriff approval presented under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ to indicate the catalytic converter has been sold. The person shall take a photograph of the catalytic converter that clearly identifies the item as a catalytic converter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who purchases a catalytic converter shall have a residence or fixed business address within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who purchases a catalytic converter shall keep a confidential register or log of each transaction, including a copy of the information required by }}}{{\f5\fs18\hyphpar0\qj{subsections 2, 3, and 5}}}{{\f5\fs18\hyphpar0\qj{. All records and information kept pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be retained for at least two years, and shall be provided to a law enforcement agency or other officer or employee designated by a county or city to enforce }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ upon request during normal business hours when the law enforcement agency or designated officer or employee of a county or city has reasonable grounds to request such information as part of an investigation. A law enforcement agency or designated officer or employee of a county or city shall preserve the confidentiality of the information provided under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and shall not disclose it to a third party, except as may be necessary in enforcement of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or the prosecution of a criminal violation. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A transaction under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall make use of a traceable payment method including but not limited to payment made by check, voucher, issuance of a prepaid bank, credit, or debit card, or electronic funds transfer. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, including a person who conducts a business transaction on behalf of another person, who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to a civil penalty as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an initial violation, one thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a second violation within two years, five thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a third or subsequent violation within two years, ten thousand dollars. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proof that a person, including a person who conducted a business transaction on behalf of another person, violated }}}{{\f5\fs18\hyphpar0\qj{subsection 2 or 3}}}{{\f5\fs18\hyphpar0\qj{ shall be evidence from which the court or jury may infer any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person aided and abetted the underlying theft of the catalytic converter involved in the transaction from a vehicle, under }}}{{\f5\fs18\hyphpar0\qj{section 703.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person had knowledge that a public offense has been committed and that a certain person committed it, for purposes of proving the person acted as an accessory after the fact under }}}{{\f5\fs18\hyphpar0\qj{section 703.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1092, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1184, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7714.1}}}{{\f5\fs12\hyphpar0\qj{, 805.8C(11)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8C, subsection 11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.28}}}{\*\bkmkstart stylerid1_2E47_2E2_2E2}{\*\bkmkend stylerid1_2E47_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Claims against purchased or pledged goods held by pawnbrokers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClaimant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who claims that the person\u8217\'3fs property was misappropriated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConveying customer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who delivers property into the custody of a pawnbroker, either by pawn, sale, consignment, or trade.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMisappropriated\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means stolen, embezzled, converted, or otherwise wrongfully appropriated against the will of the rightful owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To obtain possession of purchased or pledged goods held by a pawnbroker which a claimant claims to have been misappropriated, the claimant must notify the pawnbroker by certified mail, return receipt requested, or in person evidenced by signed receipt, of the claimant\u8217\'3fs claim to the purchased or pledged goods. The notice must contain a complete and accurate description of the purchased or pledged goods and must be accompanied by a legible copy of the applicable law enforcement agency\u8217\'3fs report documenting the misappropriation of the property. If the claimant and the pawnbroker do not resolve the right to possession within ten days after the pawnbroker\u8217\'3fs receipt of the notice, the claimant may petition the district court sitting in small claims to order the return of the property, naming the pawnbroker as a defendant, and shall serve the pawnbroker with a copy of the petition. The pawnbroker shall hold the property described in the petition until the right to possession is resolved by the parties or by the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after notice and a hearing, the court finds that the property was misappropriated and orders the return of the property to the claimant, both of the following shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The claimant may recover from the pawnbroker the costs of the action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the conveying customer was convicted in a separate criminal proceeding of theft or dealing in stolen property involving the misappropriated property, the court shall order the conveying customer to repay the pawnbroker the full amount that the conveying customer received from the pawnbroker for the property, plus all applicable pawn service charges. As used in this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fconvicted\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a plea of no contest to the charges or any agreement in which adjudication is withheld.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court finds that the claimant failed to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or otherwise finds against the claimant, the claimant shall be liable for the defendant\u8217\'3fs costs.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1070, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7631.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714.29}}}{\*\bkmkstart stylerid1_2E48_2E2_2E2}{\*\bkmkend stylerid1_2E48_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records filed with intent to harass or defraud.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not cause to be communicated to the filing office as defined in }}}{{\f5\fs18\hyphpar0\qj{section 554.9102}}}{{\f5\fs18\hyphpar0\qj{ for filing a record if all of the following are true:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is not authorized to file the record under }}}{{\f5\fs18\hyphpar0\qj{section 554.9509}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The record is not related to an existing or anticipated transaction that is or will be governed by }}}{{\f5\fs18\hyphpar0\qj{chapter 554, article 9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The record is filed with the intent to harass or defraud the person identified as debtor in the record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person that violates }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor for a first offense and a serious misdemeanor for a second or subsequent offense.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 183, \'a711}}}\par}}