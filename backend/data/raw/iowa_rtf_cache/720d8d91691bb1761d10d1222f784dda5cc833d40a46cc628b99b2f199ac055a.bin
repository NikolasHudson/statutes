\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F235B}{\*\bkmkend codeChapter_5F235B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 235B}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{DEPENDENT ADULT ABUSE SERVICES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\f5\fs18\qc\fi0\ri0\li0{ \u8212\'3f INFORMATION REGISTRY}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7216A.136}}}{{\f5\fs12\qc{, 235E.2}}}{{\f5\fs12\qc{, 256.146}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Dependent adult abuse in facilities and programs, see }{{\f5\fs12\qc{chapter 235E}}}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\sa0\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri1445\li1445\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Legislative services agency to monitor reporting of dependent adult abuse, investigations, and workload and performance of personnel, and report annually by February 1; department of health and human services and department of inspections, appeals, and licensing to cooperate; }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\cf5{{\f5\fs12\qc\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/87/CH0182.pdf" }{\fldrslt \cf5 \f5 \fs12{{87 Acts, ch 182, \'a711}}}}}}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{; }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\cf5{{\f5\fs12\qc\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH35.pdf" }{\fldrslt \cf5 \f5 \fs12{{2003 Acts, ch 35, \'a746, 49}}}}}}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{; }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\sa0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\cf5{{\f5\fs12\qc\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0182.pdf" }{\fldrslt \cf5 \f5 \fs12{{2009 Acts, ch 182, \'a7137}}}}}}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{; }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\cf5{{\f5\fs12\qc\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH19.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 19, \'a71358}}}}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri1445\li1445\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E2_2E2}{GENERAL PROVISIONS}{\*\bkmkend stylerid1_2E6_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235B.1}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dependent adult abuse services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall establish and operate a dependent adult abuse services program. The program shall emphasize the reporting and evaluation of cases of abuse of a dependent adult who is unable to protect the adult\u8217\'3fs own interests or unable to perform activities necessary to meet essential human needs. The program shall include but is not limited to:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The establishment of local or regional multidisciplinary teams to assist in assessing the needs of, formulating and monitoring a treatment plan for, and coordinating services to victims of dependent adult abuse. The membership of a team shall include individuals who possess knowledge and skills related to the diagnosis, assessment, and disposition of dependent adult abuse cases and who are professionals practicing in the disciplines of medicine, public health, mental health, social work, law, law enforcement, or other disciplines relative to dependent adults. Members of a team shall include but are not limited to persons representing the area agencies on aging, county attorneys, health care providers, and other persons involved in advocating or providing services to dependent adults.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions for information sharing and case consultation among service providers, care providers, and victims of dependent adult abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Procedures for referral of cases among service providers, including the referral of victims of dependent adult abuse residing in licensed health care facilities.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7159, 160}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 153, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1178, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 180, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 182, \'a72 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1238, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 24, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1204, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1271, \'a71509}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 231, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1130, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1116, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1093, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 23, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7715, 1937, 1938}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1004, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7276}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7235A.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235B.2}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCaretaker\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a related or nonrelated person who has the responsibility for the protection, care, or custody of a dependent adult as a result of assuming the responsibility voluntarily, by contract, through employment, or by order of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCourt\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDependent adult\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person eighteen years of age or older who is unable to protect the person\u8217\'3fs own interests or unable to adequately perform or obtain services necessary to meet essential human needs, as a result of a physical or mental condition which requires assistance from another, or as defined by departmental rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDependent adult abuse\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following as a result of the willful or negligent acts or omissions of a caretaker:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Physical injury to, or injury which is at a variance with the history given of the injury, or unreasonable confinement, unreasonable punishment, or assault of a dependent adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission of a sexual offense under }}}{{\f5\fs18\hyphpar0\qj{chapter 709}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 726.2}}}{{\f5\fs18\hyphpar0\qj{ with or against a dependent adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exploitation of a dependent adult which means a fraudulent or otherwise illegal, unauthorized, or improper attempt, act, or process by a caretaker or fiduciary to use the physical or financial resources of a dependent adult for any of the following purposes: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Monetary or personal benefit, profit, or gain.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To deprive the dependent adult of the use of the dependent adult\u8217\'3fs physical or financial resources, including any benefits, belongings, or assets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The deprivation of the minimum food, shelter, clothing, supervision, physical or mental health care, or other care necessary to maintain a dependent adult\u8217\'3fs life or health.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The deprivation of the minimum food, shelter, clothing, supervision, physical or mental health care, and other care necessary to maintain a dependent adult\u8217\'3fs life or health as a result of the acts or omissions of the dependent adult.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual exploitation of a dependent adult by a caretaker.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSexual exploitation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any consensual or nonconsensual sexual conduct with a dependent adult which includes but is not limited to kissing; touching of the clothed or unclothed inner thigh, breast, groin, buttock, anus, pubes, or genitals; or a sex act, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.17}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSexual exploitation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the transmission, display, taking of electronic images of the unclothed breast, groin, buttock, anus, pubes, or genitals of a dependent adult by a caretaker for a purpose not related to treatment or diagnosis or as part of an ongoing assessment, evaluation, or investigation. Sexual exploitation does not include touching which is part of a necessary examination, treatment, or care by a caretaker acting within the scope of the practice or employment of the caretaker; the exchange of a brief touch or hug between the dependent adult and a caretaker for the purpose of reassurance, comfort, or casual friendship; or touching between spouses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personal degradation of a dependent adult by a caretaker.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal degradation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a willful act or statement by a caretaker intended to shame, degrade, humiliate, or otherwise harm the personal dignity of a dependent adult, or where the caretaker knew or reasonably should have known the act or statement would cause shame, degradation, humiliation, or harm to the personal dignity of a reasonable person. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal degradation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the taking, transmission, or display of an electronic image of a dependent adult by a caretaker, where the caretaker\u8217\'3fs actions constitute a willful act or statement intended to shame, degrade, humiliate, or otherwise harm the personal dignity of the dependent adult, or where the caretaker knew or reasonably should have known the act would cause shame, degradation, humiliation, or harm to the personal dignity of a reasonable person. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal degradation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(A)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taking, transmission, or display of an electronic image of a dependent adult for the purpose of reporting dependent adult abuse to law enforcement, the department, or any other regulatory agency that oversees caretakers or enforces abuse or neglect provisions, or for the purpose of treatment or diagnosis or as part of an ongoing investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(B)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taking, transmission, or display of an electronic image by a caretaker who takes, transmits, or displays the electronic image in accordance with the confidentiality policy and release of information or consent policies of a contractor, employer, or facility or program not covered under }}}{{\f5\fs18\hyphpar0\qj{section 235E.1, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(C)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement by a caretaker who is the spouse of a dependent adult that is not intended to shame, degrade, humiliate, or otherwise harm the personal dignity of the dependent adult spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDependent adult abuse\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Circumstances in which the dependent adult declines medical treatment if the dependent adult holds a belief or is an adherent of a religion whose tenets and practices call for reliance on spiritual means in place of reliance on medical treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Circumstances in which the dependent adult\u8217\'3fs caretaker, acting in accordance with the dependent adult\u8217\'3fs stated or implied consent, declines medical treatment if the dependent adult holds a belief or is an adherent of a religion whose tenets and practices call for reliance on spiritual means in place of reliance on medical treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The withholding or withdrawing of health care from a dependent adult who is terminally ill in the opinion of a licensed physician, when the withholding or withdrawing of health care is done at the request of the dependent adult or at the request of the dependent adult\u8217\'3fs next of kin, attorney in fact, or guardian pursuant to the applicable procedures under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{144A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{144B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{222}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{229}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{633}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmergency shelter services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes, but is not limited to, secure crisis shelters or housing for victims of dependent adult abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFamily or household member\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a spouse, a person cohabiting with the dependent adult, a parent, or a person related to the dependent adult by consanguinity or affinity, but does not include children of the dependent adult who are less than eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fImmediate danger to health or safety\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a situation in which death or severe bodily injury could reasonably be expected to occur without intervention.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndividual employed as an outreach person\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a natural person who, in the course of employment, makes regular contacts with dependent adults regarding available community resources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLegal holiday\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a legal public holiday as defined in }}}{{\f5\fs18\hyphpar0\qj{section 1C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means person as defined in }}}{{\f5\fs18\hyphpar0\qj{section 4.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecklessly\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that a person acts or fails to act with respect to a material element of a public offense, when the person is aware of and consciously disregards a substantial and unjustifiable risk that the material element exists or will result from the act or omission. The risk must be of such a nature and degree that disregard of the risk constitutes a gross deviation from the standard conduct that a reasonable person would observe in the situation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSerious injury\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.18}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSupport services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to community-based services including area agency on aging assistance, mental health services, fiscal management, home health services, housing-related services, counseling services, transportation services, adult day services, respite services, legal services, and advocacy services.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 182, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1238, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 231, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1143, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 76, \'a77}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{95 Acts, ch 51, \'a73}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1130, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 64, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1030, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1093, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 107, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1073, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 39, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 122, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7716}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a741}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7235B.3}}}{{\f5\fs12\hyphpar0\qj{, 235B.16A}}}{{\f5\fs12\hyphpar0\qj{, 249A.4}}}{{\f5\fs12\hyphpar0\qj{, 502.801}}}{{\f5\fs12\hyphpar0\qj{, 633B.116}}}{{\f5\fs12\hyphpar0\qj{, 633B.118}}}{{\f5\fs12\hyphpar0\qj{, 692A.102}}}{{\f5\fs12\hyphpar0\qj{, 726.26}}}{{\f5\fs12\hyphpar0\qj{, 726.28}}}{{\f5\fs12\hyphpar0\qj{, 915.84}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5, paragraph a, subparagraph (1), subparagraph division (c) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235B.3}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dependent adult abuse reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall receive dependent adult abuse reports and shall collect, maintain, and disseminate the reports by establishing a central registry for dependent adult abuse information. The department shall evaluate the reports expeditiously.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, the department of inspections, appeals, and licensing is solely responsible for the evaluation and disposition of dependent adult abuse cases within facilities and programs pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 235E}}}{{\f5\fs18\hyphpar0\qj{ and shall inform the department of such evaluations and dispositions pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 235E.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, in the course of an assessment or evaluation of a report of dependent adult abuse, the department determines the case involves wages, workplace safety, or other labor and employment matters under the jurisdiction of the department of inspections, appeals, and licensing or the division of labor services of the department of inspections, appeals, and licensing, the relevant portions of the case shall be referred to the department of inspections, appeals, and licensing or the division, as applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, in the course of an assessment or evaluation of a report of dependent adult abuse, the department or the department of inspections, appeals, and licensing determines that the case involves discrimination under the jurisdiction of the Iowa office of civil rights, the relevant portions of the case shall be referred to the office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reports of dependent adult abuse which is the result of the acts or omissions of the dependent adult shall be collected and maintained in the files of the dependent adult as assessments only and shall not be included in the central registry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A report of dependent adult abuse that meets the definition of dependent adult abuse under }}}{{\f5\fs18\hyphpar0\qj{section 235B.2, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (a) or (d), or }}}{{\f5\fs18\hyphpar0\qj{section 235B.2, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (4), which the department determines is minor, isolated, and unlikely to reoccur shall be collected and maintained by the department as an assessment only for a five-year period and shall not be included in the central registry and shall not be considered to be founded dependent adult abuse. However, a subsequent report of dependent adult abuse that meets the definition of dependent adult abuse under }}}{{\f5\fs18\hyphpar0\qj{section 235B.2, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (a) or (d), or }}}{{\f5\fs18\hyphpar0\qj{section 235B.2, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (4), that occurs within the five-year period and that is committed by the caretaker responsible for the act or omission which was the subject of the previous report of dependent adult abuse which the department determined was minor, isolated, and unlikely to reoccur shall not be considered minor, isolated, and unlikely to reoccur.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who, in the course of employment, examines, attends, counsels, or treats a dependent adult and reasonably believes the dependent adult has suffered abuse, shall report the suspected dependent adult abuse to the department. Persons required to report include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the staff of a community mental health center.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An in-home homemaker-home health aide.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual employed as an outreach person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health practitioner, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.68}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the staff or an employee of a supported community living service, sheltered workshop, or work activity center.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A social worker.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified psychologist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A massage therapist licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 152C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a staff member or employee is required to report pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the person shall immediately notify the department and shall also immediately notify the person in charge or the person\u8217\'3fs designated agent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer or supervisor of a person who is required to or may make a report pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply a policy, work rule, or other requirement that interferes with the person making a report of dependent adult abuse or that results in the failure of another person to make the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee of a financial institution may report suspected financial exploitation of a dependent adult to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other person who believes that a dependent adult has suffered abuse may report the suspected abuse to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following the reporting of suspected dependent adult abuse, the department or an agency approved by the department shall complete an assessment of necessary services and shall make appropriate referrals for receipt of these services. The assessment shall include interviews with the dependent adult, and, if appropriate, with the alleged perpetrator of the dependent adult abuse and with any person believed to have knowledge of the circumstances of the case. The department may provide necessary protective services and may establish a sliding fee schedule for those persons able to pay a portion of the protective services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a showing of probable cause that a dependent adult has been abused, a court may authorize a person, also authorized by the department, to make an evaluation, to enter the residence of, and to examine the dependent adult.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a showing of probable cause that there has been exploitation of a dependent adult, a court may authorize a person, also authorized by the department, to make an evaluation, and to gain access to the financial records that the department reasonably believes are related to the resources of the dependent adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines that disclosure is necessary for the protection of a dependent adult, the department may disclose to a subject of a dependent adult abuse report referred to in }}}{{\f5\fs18\hyphpar0\qj{section 235B.6, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, that an individual is listed in the child or dependent adult abuse registry or is required to register with the sex offender registry in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 692A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, in the course of assessment, evaluation, or investigation of a report of dependent adult abuse, the department determines that disclosure is necessary for the protection of a dependent adult\u8217\'3fs resources, the department may disclose the initiation and status of the dependent adult abuse evaluation to the dependent adult\u8217\'3fs bank, savings association, credit union, broker-dealer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 502.102, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, investment advisor as defined in }}}{{\f5\fs18\hyphpar0\qj{section 502.102, subsection 15}}}{{\f5\fs18\hyphpar0\qj{, financial advisor, or other financial institution, or the administrator as defined in }}}{{\f5\fs18\hyphpar0\qj{section 502.102, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall inform the appropriate county attorneys of any reports of dependent adult abuse. The department may request information from any person believed to have knowledge of a case of dependent adult abuse. The person, including but not limited to a county attorney, a law enforcement agency, a multidisciplinary team, a social services agency in the state, or any person who is required pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ to report dependent adult abuse, whether or not the person made the specific dependent adult abuse report, shall cooperate and assist in the evaluation upon the request of the department. If the department\u8217\'3fs assessment reveals that dependent adult abuse exists which might constitute a criminal offense, a report shall be made to the appropriate law enforcement agency. County attorneys and appropriate law enforcement agencies shall also take any other lawful action necessary or advisable for the protection of the dependent adult.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, upon completion of the evaluation or upon referral from the department of inspections, appeals, and licensing, the department determines that the best interests of the dependent adult require court action, the department shall initiate action for the appointment of a guardian or conservator or for admission or commitment to an appropriate institution or facility pursuant to the applicable procedures under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{222}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{229}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{633}}}{{\f5\fs18\hyphpar0\qj{, or shall pursue other remedies provided by law. The appropriate county attorney shall assist the department in the preparation of the necessary papers to initiate the action and shall appear and represent the department at all district court proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall assist the court during all stages of court proceedings involving a suspected case of dependent adult abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In every case involving abuse which is substantiated by the department and which results in a judicial proceeding on behalf of the dependent adult, legal counsel shall be appointed by the court to represent the dependent adult in the proceedings. The court may also appoint a guardian ad litem to represent the dependent adult if necessary to protect the dependent adult\u8217\'3fs best interests. The same attorney may be appointed to serve both as legal counsel and as guardian ad litem. Before legal counsel or a guardian ad litem is appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court shall require the dependent adult and any person legally responsible for the support of the dependent adult to complete under oath a detailed financial statement. If, on the basis of that financial statement, the court deems that the dependent adult or the legally responsible person is able to bear all or a portion of the cost of the legal counsel or guardian ad litem, the court shall so order. In cases where the dependent adult or the legally responsible person is unable to bear the cost of the legal counsel or guardian ad litem, the expense shall be paid by the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person participating in good faith in reporting or cooperating with or assisting the department in evaluating a case of dependent adult abuse has immunity from liability, civil or criminal, which might otherwise be incurred or imposed based upon the act of making the report or giving the assistance. The person has the same immunity with respect to participating in good faith in a judicial proceeding resulting from the report or cooperation or assistance or relating to the subject matter of the report, cooperation, or assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any person or employer to discharge, suspend, or otherwise discipline a person required to report or voluntarily reporting an instance of suspected dependent adult abuse pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2 or 5}}}{{\f5\fs18\hyphpar0\qj{, or cooperating with, or assisting the department in evaluating a case of dependent adult abuse, or participating in judicial proceedings relating to the reporting or cooperation or assistance based solely upon the person\u8217\'3fs reporting or assistance relative to the instance of dependent adult abuse. A person or employer found in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to report a suspected case of dependent adult abuse who knowingly and willfully fails to do so commits a simple misdemeanor. A person required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to report a suspected case of dependent adult abuse who knowingly fails to do so or who knowingly, in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, interferes with the making of such a report or applies a requirement that results in such a failure is civilly liable for the damages proximately caused by the failure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of inspections, appeals, and licensing shall adopt rules which require facilities or programs to separate an alleged dependent adult abuser from a victim following an allegation of perpetration of abuse and prior to the completion of an investigation of the allegation.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 231, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1143, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 72, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 51, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1130, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1181, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 129, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 122, \'a77 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 98, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 123, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 166, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1116, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1030, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 159, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1093, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 136, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 122, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1078, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1096, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7717, 1939 \u8211\'3f 1941}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7277}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a742}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7235B.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 7 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235B.3A}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prevention of additional abuse \u8212\'3f notification of rights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a peace officer has reason to believe that dependent adult abuse, which is criminal in nature, has occurred, the officer shall use all reasonable means to prevent further abuse, including but not limited to any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If requested, remaining on the scene as long as there is a danger to the dependent adult\u8217\'3fs physical safety without the presence of a peace officer, including but not limited to staying in the dwelling unit, or if unable to remain at the scene, assisting the dependent adult in leaving the residence and securing support services or emergency shelter services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assisting the dependent adult in obtaining medical treatment necessitated by the dependent adult abuse, including providing assistance to the dependent adult in obtaining transportation to the emergency room of the nearest hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing a dependent adult with immediate and adequate notice of the dependent adult\u8217\'3fs rights. The notice shall consist of handing the dependent adult a document that includes the telephone numbers of shelters, support groups, and crisis lines operating in the area and contains the following written statement of rights; requesting the dependent adult to read the document; and asking the dependent adult whether the dependent adult understands the rights:}}}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[1]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{You have the right to ask the court for the following help on a temporary basis:}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[a]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Keeping the alleged perpetrator away from you, your home, and your place of work.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[b]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{The right to stay at your home without interference from the alleged perpetrator.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[c]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{Professional counseling for you, your family, or household members, and the alleged perpetrator of the dependent adult abuse.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[2]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If you are in need of medical treatment, you have the right to request that the peace officer present assist you in obtaining transportation to the nearest hospital or otherwise assist you.}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\b0\fs18\hyphpar0\qj\ul0\strike0{\~\~\~}}}{\f5\fs18\hyphpar0\qj}{[3]}{{\f5\fs18\hyphpar0\qj{\~\~}}}{If you believe that police protection is needed for your physical safety, you have the right to request that the peace officer present remain at the scene until you and other affected parties can leave or safety is otherwise ensured.}{\f5\fs18\hyphpar0\qj}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri1084\li1084\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1130, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a787, 88}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a771}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Similar provisions, }{{\f5\fs12\hyphpar0\qj{\'a7235E.3}}}{, }{{\f5\fs12\hyphpar0\qj{236.12}}}{, }{{\f5\fs12\hyphpar0\qj{236A.13}}}{, }{{\f5\fs12\hyphpar0\qj{709.22}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E2_2E2}{DEPENDENT ADULT ABUSE INFORMATION REGISTRY}{\*\bkmkend stylerid1_2E7_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235B.4}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legislative findings and purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly finds and declares that a central registry is required to provide a single source for the statewide collection, maintenance, and dissemination of dependent adult abuse information. Such a registry is imperative for increased effectiveness in dealing with the problem of dependent adult abuse. The general assembly also finds that vigorous protection of rights of individual privacy is an indispensable element of a fair and effective system of collecting, maintaining, and disseminating dependent adult abuse information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 235B.5 through 235B.13}}}{{\f5\fs18\hyphpar0\qj{ are to facilitate the identification of victims or potential victims of dependent adult abuse by making available a single, statewide source of dependent adult abuse data; to facilitate research on dependent adult abuse by making available a single, statewide source of dependent adult abuse data; and to provide maximum safeguards against the unwarranted invasions of privacy which such a registry might otherwise entail.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 231, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a780}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7235E.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235B.5}}}{\*\bkmkstart stylerid1_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Creation and maintenance of a central registry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is created within the department a central registry for dependent adult abuse information. The department shall organize and staff the registry and adopt rules for its operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The registry shall collect, maintain, and disseminate dependent adult abuse information as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall maintain a toll-free telephone line, which shall be available on a twenty-four-hour-a-day, seven-day-a-week basis and which the department and all other persons may use to report cases of suspected dependent adult abuse and that all persons authorized by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may use for obtaining dependent adult abuse information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An oral report of suspected dependent adult abuse initially made to the central registry shall be immediately transmitted by the department to the appropriate county department of human services or law enforcement agency, or both.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An oral report of suspected dependent adult abuse initially made to the central registry regarding a facility or program as defined in }}}{{\f5\fs18\hyphpar0\qj{section 235E.1}}}{{\f5\fs18\hyphpar0\qj{ shall be transmitted by the department to the department of inspections, appeals, and licensing on the first working day following the submitting of the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The registry, upon receipt of a report of suspected dependent adult abuse, shall search the records of the registry, and if the records of the registry reveal any previous report of dependent adult abuse involving the same adult or if the records reveal any other pertinent information with respect to the same adult, the department or the appropriate law enforcement agency shall be immediately notified of that fact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The central registry shall include but not be limited to report data, investigation data, and disposition data.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 231, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1093, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7718, 1942}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7235B.4}}}{{\f5\fs12\hyphpar0\qj{, 235E.4}}}{{\f5\fs12\hyphpar0\qj{, 279.13}}}{{\f5\fs12\hyphpar0\qj{, 279.69}}}{{\f5\fs12\hyphpar0\qj{, 321.375}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{235B.6}}}{\*\bkmkstart stylerid1_2E7_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authorized access.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Dependent adult abuse information shall be confidential and shall not be a public record under }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{. The confidentiality of all dependent adult abuse information shall be maintained, except as specifically provided by }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Access to dependent adult abuse information other than unfounded dependent adult abuse information is authorized only to the following persons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A subject of a report including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To an adult named in a report as a victim of abuse or to the adult\u8217\'3fs attorney or guardian ad litem.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a guardian or legal custodian, or that person\u8217\'3fs attorney, of an adult named in a report as a victim of abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the person or the attorney for the person named in a report as having abused an adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person involved in an investigation of dependent adult abuse including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health practitioner or mental health professional who is examining, attending, or treating an adult whom such practitioner or professional believes or has reason to believe has been the victim of abuse or to a health practitioner or mental health professional whose consultation with respect to an adult believed to have been the victim of abuse is requested by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or agent of the department responsible for the investigation of a dependent adult abuse report or for the purpose of performing record checks as required under }}}{{\f5\fs18\hyphpar0\qj{section 135C.33}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A representative of the department involved in the certification or accreditation of an agency or program providing care or services to a dependent adult believed to have been a victim of abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A law enforcement officer responsible for assisting in an investigation of a dependent adult abuse allegation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A multidisciplinary team, if the department approves the composition of the multidisciplinary team and determines that access to the team is necessary to assist the department in the investigation, diagnosis, assessment, and disposition of a case of dependent adult abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The mandatory reporter who reported the dependent adult abuse in an individual case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each board specified under }}}{{\f5\fs18\hyphpar0\qj{chapter 147}}}{{\f5\fs18\hyphpar0\qj{ and the department of inspections, appeals, and licensing for the purpose of licensure, certification or registration, disciplinary investigation, or the renewal of licensure, certification or registration, or disciplinary proceedings of health care professionals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person providing care to an adult including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensing authority for a facility, including a facility or program defined in }}}{{\f5\fs18\hyphpar0\qj{section 235E.1}}}{{\f5\fs18\hyphpar0\qj{, providing care to an adult named in a report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person authorized as responsible for the care or supervision of an adult named in a report as a victim of abuse or a person named in a report as having abused an adult if the court or registry deems access to dependent adult abuse information by such person to be necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or agent of the department responsible for registering or licensing or approving the registration or licensing of a person, or to an individual providing care to an adult and regulated by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legally authorized protection and advocacy agency recognized pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 135C.2}}}{{\f5\fs18\hyphpar0\qj{ if a person identified in the information as a victim or a perpetrator of abuse resided in or receives services from a facility, including a facility or program defined in }}}{{\f5\fs18\hyphpar0\qj{section 235E.1}}}{{\f5\fs18\hyphpar0\qj{, or agency because the person is diagnosed as having a developmental disability or a mental illness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To an administrator of an agency certified by the department to provide services under a medical assistance home and community-based services waiver, if the information concerns a person employed by or being considered by the agency for employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the administrator of an agency providing mental health, intellectual disability, or developmental disability services under a regional service system management plan implemented in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 225C.60}}}{{\f5\fs18\hyphpar0\qj{,* if the information concerns a person employed by or being considered by the agency for employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To an administrator of a hospital licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{{\f5\fs18\hyphpar0\qj{ if the data concerns a person employed or being considered for employment by the hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee of an agency requested by the department to provide case management or other services to the dependent adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Relating to judicial and administrative proceedings, persons including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court upon a finding that information is necessary for the resolution of an issue arising in any phase of a case involving dependent adult abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court or agency hearing an appeal for correction of dependent adult abuse information as provided in }}}{{\f5\fs18\hyphpar0\qj{section 235B.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An expert witness or a witness who testifies at any stage of an appeal necessary for correction of dependent adult abuse information as provided in }}}{{\f5\fs18\hyphpar0\qj{section 235B.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court or administrative agency making a determination regarding an unemployment compensation claim pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 96.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a juvenile court involved in an adjudication or disposition of a child that is the subject of a guardianship proceeding under }}}{{\f5\fs18\hyphpar0\qj{chapter 232D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a district court upon a finding that data is necessary for the resolution of an issue arising in any phase of a case involving proceedings for a child guardianship under }}}{{\f5\fs18\hyphpar0\qj{chapter 232D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a district court conducting checks of the dependent adult abuse registry for all proposed guardians and conservators pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 633.564}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a tribal court as defined in }}}{{\f5\fs18\hyphpar0\qj{section 626D.2}}}{{\f5\fs18\hyphpar0\qj{, a tribal prosecutor, or tribal services provided that the dependent adult is an Indian as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232B.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other persons including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person conducting bona fide research on dependent adult abuse, but without information identifying individuals named in a dependent adult abuse report, unless having that information open to review is essential to the research or evaluation and the authorized registry officials give prior written approval and the adult, the adult\u8217\'3fs guardian or guardian ad litem, and the person named in a report as having abused an adult give permission to release the information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registry or department personnel when necessary to the performance of their official duties, or a person, an instrumentality of the state, or an agency under contract with the department to carry out official duties and functions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of justice for the sole purpose of the filing of a claim for reparation pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 915.21}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{915.84}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A legally constituted adult protection agency of another state which is investigating or treating an adult named in a report as having been abused.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The office of the attorney general.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care facility administrator or the administrator\u8217\'3fs designee, following the appeals process, for the purpose of hiring staff or continued employment of staff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the administrator of an agency providing care to a dependent adult in another state, for the purpose of performing an employment background check.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the superintendent, or the superintendent\u8217\'3fs designee, of a school district or to the authorities in charge of an accredited nonpublic school for purposes of a volunteer or employment record check.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of inspections, appeals, and licensing for purposes of record checks of applicants for employment with the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state or a local long-term care ombudsman if the victim resides in or the alleged perpetrator is an employee of a long-term care facility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 231.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state office or local office of public guardian as defined in }}}{{\f5\fs18\hyphpar0\qj{section 231E.3}}}{{\f5\fs18\hyphpar0\qj{, if the information relates to the provision of legal services for a client served by the state or local office of public guardian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nursing program that is approved by the state board of nursing under }}}{{\f5\fs18\hyphpar0\qj{section 152.5}}}{{\f5\fs18\hyphpar0\qj{, if the information relates to a record check performed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 152.5A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the board of educational examiners created under }}}{{\f5\fs18\hyphpar0\qj{chapter 256}}}{{\f5\fs18\hyphpar0\qj{ for purposes of determining whether a license, certificate, or authorization should be issued, denied, or revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(14)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department for the purposes of conducting background checks of applicants for employment with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(15)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the Iowa veterans home for purposes of record checks of potential volunteers and volunteers in the Iowa veterans home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(16)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the administrator of a certified nurse aide program, if the data relates to a record check of a student of the program performed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 135C.33}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(17)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the administrator of a juvenile detention or shelter care home, if the data relates to a record check of an existing or prospective employee, resident, or volunteer for or in the home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(18)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the employer or prospective employer of a school bus driver for purposes of an employment record check.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(19)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a free clinic as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135.24A}}}{{\f5\fs18\hyphpar0\qj{ for purposes of record checks of potential volunteers and existing volunteers at the free clinic.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(20)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a bank, savings association, credit union, broker-dealer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 502.102, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, investment advisor as defined in }}}{{\f5\fs18\hyphpar0\qj{section 502.102, subsection 15}}}{{\f5\fs18\hyphpar0\qj{, financial advisor, or other financial institution as deemed necessary by the department to protect the dependent adult\u8217\'3fs resources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(21)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the social security administration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(22)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the administrator as defined in }}}{{\f5\fs18\hyphpar0\qj{section 502.102, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a person who submits written authorization from an individual allowing the person access to information on the determination only on whether or not the individual who authorized the access is named in a founded dependent adult abuse report as having abused a dependent adult.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Access to unfounded dependent adult abuse information is authorized only to those persons identified in any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (2), (5), and (6).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (8).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (2), (5), (10), (20), (21), and (22).}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 231, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 50, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 93, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1183, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 42, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1090, \'a765, 84}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 141, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1067, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1153, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 8, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts