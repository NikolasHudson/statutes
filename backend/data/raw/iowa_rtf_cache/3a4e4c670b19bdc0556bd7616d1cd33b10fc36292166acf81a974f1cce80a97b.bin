r0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1138, \'a725, 26}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.52}}}{\*\bkmkstart stylerid1_2E1_30_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Innovation fund investment tax credits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this section, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 15.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInnovation fund\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one or more early-stage capital funds certified by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInnovative business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business applying novel or original methods to the manufacture of a product or the delivery of a service. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInnovative business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to a business engaged in the industries of advanced manufacturing, biosciences, and information technology.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax credit shall be allowed against the taxes imposed in }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapters II}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{III}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{V}}}{{\f5\fs18\hyphpar0\qj{, and in }}}{{\f5\fs18\hyphpar0\qj{chapter 432}}}{{\f5\fs18\hyphpar0\qj{, and against the moneys and credits tax imposed in }}}{{\f5\fs18\hyphpar0\qj{section 533.329}}}{{\f5\fs18\hyphpar0\qj{, for a portion of a taxpayer\u8217\'3fs equity investment in the form of cash in an innovation fund.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual may claim a tax credit under this section of a partnership, limited liability company, S corporation, estate, or trust electing to have income taxed directly to the individual. The amount claimed by the individual shall be based upon the pro rata share of the individual\u8217\'3fs earnings from the partnership, limited liability company, S corporation, estate, or trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a tax credit allowed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall equal twenty-five percent of the taxpayer\u8217\'3fs equity investment in an innovation fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A taxpayer shall not claim a tax credit under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the taxpayer is a venture capital investment fund allocation manager for the Iowa fund of funds created in }}}{{\f5\fs18\hyphpar0\qj{section 15E.65}}}{{\f5\fs18\hyphpar0\qj{ or an investor that receives a tax credit for the same investment in a qualifying business as described in section }}}{{\f5\fs18\hyphpar0\qj{15E.28}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To receive a tax credit, a taxpayer must submit an application to the board. The board shall issue certificates under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on a first-come, first-served basis, which certificates may be redeemed for tax credits. The board shall issue such certificates so that not more than the amount allocated for such tax credits under }}}{{\f5\fs18\hyphpar0\qj{section 15.119, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, may be claimed. The board shall not issue a certificate before September 1, 2014.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall not issue a certificate to a taxpayer for an equity investment in an innovation fund until such fund has been certified as an innovation fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall, in cooperation with the department of revenue, establish criteria and procedures for the allocation and issuance of tax credits by means of certificates issued by the board. The criteria shall include the contingencies that must be met for a certificate to be redeemable in order to receive a tax credit. The procedures established by the board, in cooperation with the department of revenue, shall relate to the procedures for the issuance and transfer of the certificates and for the redemption of a certificate and related tax credit. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate and related tax credit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be deemed a vested right of the original holder or any transferee thereof, and the state shall not cause either to be redeemed in such a way that amends or rescinds the certificate or that curtails, limits, or withdraws the related tax credit, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or upon consent of the proper holder. A certificate issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ cannot pledge the credit of the state and any such certificate so pledged to secure the debt of the original holder or a transferee shall not constitute a contract binding the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any tax credit in excess of the taxpayer\u8217\'3fs liability for the tax year may be credited to the tax liability for the following five years or until depleted, whichever is earlier. A tax credit shall not be carried back to a tax year prior to the tax year in which the taxpayer claims the tax credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An innovation fund shall submit an application for certification to the board. The board shall approve the application and certify the innovation fund if all of the following criteria are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund is organized for the purposes of making investments in promising early-stage companies which have a principal place of business in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund proposes to make investments in innovative businesses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund seeks to secure private funding sources for investment in such businesses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund proposes to provide multiple rounds of funding and early-stage private sector funding to innovative businesses with a high growth potential, and proposes to focus such funding on innovative businesses that show a potential to produce commercially viable products or services within a reasonable period of time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund proposes to evaluate all prospective innovative businesses using a rigorous approach and proposes to collaborate and coordinate with the authority and other state and local entities in an effort to achieve policy consistency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund proposes to collaborate with the regents institutions of this state and to leverage relationships with such institutions in order to potentially commercialize research developed at those institutions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fund proposes to obtain at least three million dollars in binding investment commitments and to invest a minimum of three million dollars in companies that have a principal place of business in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall not certify an innovation fund after June 30, 2028.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An innovation fund shall collect and provide to the board the information required in }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in the manner and form prescribed by the board. An innovation fund failing to comply with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may have its certification revoked by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before January 31 of each year, the board, in cooperation with the department of revenue, shall submit to the general assembly and the governor, or provide to the authority for inclusion in the annual report under }}}{{\f5\fs18\hyphpar0\qj{section 15.107B}}}{{\f5\fs18\hyphpar0\qj{, a report describing the activities of the innovation funds during the preceding fiscal year. The report shall at a minimum include the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of tax credit certificates issued to equity investors in each innovation fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of tax credits claimed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of tax credits transferred to other persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of investments in each innovation fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each investment by an innovation fund in a business:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of the investment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and industry of the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location or locations from which the business operates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of employees of the business located in Iowa and the number of employees of the business located outside Iowa on the date of the initial investment by the innovation fund in the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of employees of the business located in Iowa and the number of employees of the business located outside Iowa at the close of the fiscal year which is the subject of the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tax credit certificates issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be transferred, in whole or in part, to any person. A tax credit certificate shall only be transferred once. Within ninety days of transfer, the transferee shall submit the transferred tax credit certificate to the department of revenue along with a statement containing the transferee\u8217\'3fs name, tax identification number, and address, the denomination that each replacement tax credit certificate is to carry, and any other information required by the department of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within thirty days of receiving the transferred tax credit certificate and the transferee\u8217\'3fs statement, the department of revenue shall issue one or more replacement tax credit certificates to the transferee. Each replacement tax credit certificate must contain the information required for the original tax credit certificate. A replacement tax credit certificate may designate a different tax than the tax designated on the original tax credit certificate. A tax credit shall not be claimed by a transferee under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ until a replacement tax credit certificate identifying the transferee as the proper holder has been issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transferee may use the amount of the tax credit transferred against the taxes imposed in }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapters II}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{III}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{V}}}{{\f5\fs18\hyphpar0\qj{, and in }}}{{\f5\fs18\hyphpar0\qj{chapter 432}}}{{\f5\fs18\hyphpar0\qj{, and against the moneys and credits tax imposed in }}}{{\f5\fs18\hyphpar0\qj{section 533.329}}}{{\f5\fs18\hyphpar0\qj{, for any tax year the original transferor could have claimed the tax credit. Any consideration received for the transfer of the tax credit shall not be included as income under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapters II}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{III}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{V}}}{{\f5\fs18\hyphpar0\qj{. Any consideration paid for the transfer of the tax credit shall not be deducted from income under }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapters II}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{III}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{V}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 118, \'a723, 36, 89}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 130, \'a740, 47, 71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1126, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 117, \'a72 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 138, \'a7119, 126, 127}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a730, 43}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 116, \'a712 \u8211\'3f 14, 17}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 136, \'a765, 66, 71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a72.48}}}{{\f5\fs12\hyphpar0\qj{, 15.410}}}{{\f5\fs12\hyphpar0\qj{, 84A.21}}}{{\f5\fs12\hyphpar0\qj{, 422.11Z}}}{{\f5\fs12\hyphpar0\qj{, 422.33}}}{{\f5\fs12\hyphpar0\qj{, 422.60}}}{{\f5\fs12\hyphpar0\qj{, 432.12M}}}{{\f5\fs12\hyphpar0\qj{, 515.35}}}{{\f5\fs12\hyphpar0\qj{, 533.329}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 strike of former subsection 5, paragraph b applies to all applications submitted for innovation fund tax credits administered under this section and placed on a wait list under former subsection 5, paragraph b; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 116, \'a717}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5, paragraph a amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 7, paragraph g amended}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{15E.53 through 15E.60}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_2E2_2E2}{CAPITAL INVESTMENT}{\*\bkmkend stylerid1_2E11_2E2_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{\u8212\'3f IOWA FUND OF FUNDS}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7502.102}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{For future repeal of this subchapter, see }{{\f5\fs12\qc{\'a715E.72, subsection 11}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.61}}}{\*\bkmkstart stylerid1_2E11_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Findings \u8212\'3f purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly finds the following:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fundamental changes have occurred in national and international financial markets and in the financial markets of this state. A critical shortage of seed and venture capital resources exists in the state, and such shortage is impairing the growth of commerce in the state. A need exists to increase the availability of venture equity capital for emerging, expanding, and restructuring enterprises in Iowa, including, without limitation, enterprises in the life sciences, advanced manufacturing, information technology, alternative and renewable energy including the alternative and renewable energy sectors listed in }}}{{\f5\fs18\hyphpar0\qj{section 476.42, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), and value-added agriculture areas. Such investments will create jobs for Iowans and will help to diversify the state\u8217\'3fs economic base.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subchapter}}}{{\f5\fs18\hyphpar0\qj{ is enacted to fulfill the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To mobilize private investment in a broad variety of venture capital partnerships in diversified industries and locales.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To retain the private-sector culture of focusing on rate of return in the investing process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To secure the services of the best managers in the venture capital industry, regardless of location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To facilitate the organization of the Iowa fund of funds in which to seek such private investment and to create interest in such investments by offering state incentives for private persons to make investments in the Iowa fund of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To enhance the venture capital culture and infrastructure in the state of Iowa so as to increase venture capital investment within the state and to promote venture capital investing within Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To accomplish these purposes in such a manner as to minimize any appropriations by the state of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To effectuate specific, measurable results, including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The creation of three new venture capital fund offices in Iowa within three years of February 28, 2002.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The investment of resources from the Iowa fund of funds in Iowa businesses within three years of February 28, 2002.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cumulative rate of return on venture investments of the Iowa fund of funds equal to a minimum of one and one-half percentage points above the ten-year treasury bill rate in effect at the end of five years following February 28, 2002.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1005, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1006, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1142, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7127}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715E.63}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.62}}}{\*\bkmkstart stylerid1_2E11_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the Iowa capital investment board created in }}}{{\f5\fs18\hyphpar0\qj{section 15E.63}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCertificate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a contract between the board and a designated investor pursuant to which a tax credit is available and issued to the designated investor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCreditor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person, including an assignee of or successor to such person, who extends credit or makes a loan to the Iowa fund of funds or to a designated investor, and includes any person who refinances such credit or loan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDesignated investor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person, other than the Iowa capital investment corporation, who purchases an equity interest in the Iowa fund of funds or a transferee of a certificate or tax credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFund documents\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all agreements relating to matters under the purview of }}}{{\f5\fs18\hyphpar0\qj{this subchapter VII}}}{{\f5\fs18\hyphpar0\qj{ entered into prior to June 20, 2013, between or among the state, the Iowa fund of funds, a fund allocation manager or similar manager, the Iowa capital investment corporation, the board, a creditor, a designated investor, and a private seed or venture capital partnership, and includes other documents having the same force and effect between or among such parties, as any of the foregoing may be amended, modified, restated, or replaced from time to time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa capital investment corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a private, nonprofit corporation created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 15E.64}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa fund of funds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a private, for-profit limited partnership or limited liability company established by the Iowa capital investment corporation pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 15E.65}}}{{\f5\fs18\hyphpar0\qj{ in which a designated investor purchases an equity interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTax credit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a contingent tax credit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 15E.66}}}{{\f5\fs18\hyphpar0\qj{ that is available against tax liabilities imposed by }}}{{\f5\fs18\hyphpar0\qj{chapter 422, subchapters II}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{III}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{V}}}{{\f5\fs18\hyphpar0\qj{, and by }}}{{\f5\fs18\hyphpar0\qj{chapter 432}}}{{\f5\fs18\hyphpar0\qj{ and against the moneys and credits tax imposed by }}}{{\f5\fs18\hyphpar0\qj{section 533.329}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1005, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1006, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 174, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7129, 132}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7515.35}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.63}}}{\*\bkmkstart stylerid1_2E11_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa capital investment board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa capital investment board is created as a state governmental board and the exercise by the board of powers conferred by }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be deemed and held to be the performance of essential public purposes. The purpose of the board shall be to mobilize venture equity capital for investment in such a manner that will result in a significant potential to create jobs and to diversify and stabilize the economy of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall consist of five voting members and four nonvoting advisory members who are members of the general assembly. Members shall be selected based upon demonstrated expertise and competence in the supervision of investment managers, in the fiduciary management of investment funds, or in the management and administration of tax credit allocation programs. Members shall not have an interest in any person to whom a tax credit is allocated and issued by the board.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The five voting members shall be appointed by the governor and confirmed by the senate pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 2.32}}}{{\f5\fs18\hyphpar0\qj{. One nonvoting member shall be appointed by the majority leader of the senate after consultation with the president of the senate and one nonvoting member shall be appointed by the minority leader of the senate. One nonvoting member shall be appointed by the speaker of the house of representatives after consultation with the majority leader of the house of representatives and one nonvoting member shall be appointed by the minority leader of the house of representatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The five voting members shall be appointed to five-year staggered terms that shall be structured to allow the term of one member to expire each year. The nonvoting members shall serve terms as provided in }}}{{\f5\fs18\hyphpar0\qj{section 4A.13}}}{{\f5\fs18\hyphpar0\qj{. Vacancies shall be filled in the same manner as the appointment of the original members.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members shall be compensated by the board for direct expenses and mileage but members shall not receive a director\u8217\'3fs fee, per diem, or salary for service on the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall have the power to engage consultants, expend funds, invest funds, contract, bond or insure against loss, or perform any other act necessary to carry out its purpose, provided, however, that the board shall not hire employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the board shall be indemnified against loss to the broadest extent permissible under }}}{{\f5\fs18\hyphpar0\qj{chapter 669}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Meetings of the board shall, except to the extent necessary to protect confidential information with respect to investments in the Iowa fund of funds, be subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall, in cooperation with the department of revenue, establish criteria and procedures for the allocation and issuance of tax credits to designated investors by means of certificates issued by the board. The criteria shall include the contingencies that must be met for a certificate to be redeemable by a designated investor or transferee in order to receive a tax credit. The contingencies to redemption shall be tied to the scheduled rates of return of equity interests purchased by designated investors in the Iowa fund of funds. The procedures established by the board, in cooperation with the department of revenue, shall relate to the procedures for the issuance of the certificates and the related tax credits, for the transfer of a certificate and related tax credit by a designated investor, and for the redemption of a certificate and related tax credit by a designated investor or transferee. The board shall also establish criteria and procedures for assessing the likelihood of future certificate redemptions by designated investors and transferees, including, without limitation, criteria and procedures for evaluating the value of investments made by the Iowa fund of funds and the returns from the Iowa fund of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 15E.66}}}{{\f5\fs18\hyphpar0\qj{, the board shall issue certificates which may be redeemable for tax credits to provide incentives to designated investors to make equity investments in the Iowa fund of funds. The board shall issue the certificates so that not more than twenty million dollars of tax credits may be initially redeemable in any fiscal year. The board shall indicate on the tax certificate the principal amount of the tax credit and the date or dates on which the credit may be first claimed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may charge a placement fee to the Iowa fund of funds with respect to the issuance of a certificate and related tax credit to a designated investor, but the fee shall be charged only to pay for reasonable and necessary costs of the board and shall not exceed one-half of one percent of the equity investment of the designated investor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall, in consultation with the Iowa capital investment corporation, publish an annual report of the activities conducted by the Iowa fund of funds, and present the report to the governor and the general assembly or provide the report to the authority to include such report as part of the annual report under }}}{{\f5\fs18\hyphpar0\qj{section 15.107B}}}{{\f5\fs18\hyphpar0\qj{. The annual report shall include a copy of the audit of the Iowa fund of funds and a valuation of the assets of the Iowa fund of funds, review the progress of the investment fund allocation manager in implementing its investment plan, and describe any redemption or transfer of a certificate issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, provided, however, that the annual report shall not identify any specific designated investor who has redeemed or transferred a certificate. Every five years, the board shall publish a progress report which shall evaluate the progress of the state of Iowa in accomplishing the purposes stated in }}}{{\f5\fs18\hyphpar0\qj{section 15E.61}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall redeem a certificate submitted to the board by a designated investor and shall calculate the amount of the allowable tax credit based upon the investment returns received by the designated investor and its predecessors in interest and the provisions of the certificate. Upon submission of a certificate for redemption, the board shall issue a verification to the department of revenue setting forth the maximum tax credit which may be claimed by the designated investor with respect to the redemption of the certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ necessary to administer the duties of the board. The department of revenue may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ related to the duties of the board or }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1005, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1006, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 7, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1156, \'a718, 58}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 70, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7128}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715E.62}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.64}}}{\*\bkmkstart stylerid1_2E11_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa capital investment corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa capital investment corporation may be organized as a private, not-for-profit corporation under }}}{{\f5\fs18\hyphpar0\qj{chapter 504}}}{{\f5\fs18\hyphpar0\qj{. The Iowa capital investment corporation is not a public corporation or instrumentality of the state and shall not enjoy any of the privileges and shall not be required to comply with the requirements of a state agency. Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ does not exempt the corporation from the requirements under state law which apply to other corporations organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 504}}}{{\f5\fs18\hyphpar0\qj{. The purposes of an Iowa capital investment corporation shall be to organize the Iowa fund of funds, to select a venture capital investment fund allocation manager to select venture capital fund investments by the Iowa fund of funds, to negotiate the terms of a contract with the venture capital investment fund allocation manager, to execute the contract with the selected venture capital investment fund allocation manager on behalf of the Iowa fund of funds, to receive investment returns from the Iowa fund of funds, and to reinvest the investment returns in additional venture capital investments designed to result in a significant potential to create jobs and to diversify and stabilize the economy of the state. The corporation shall not exercise governmental functions and shall not have members. The obligations of the corporation are not obligations of this state or any political subdivision of this state within the meaning of any constitutional or statutory debt limitations, but are obligations of the corporation payable solely and only from the corporation\u8217\'3fs funds. The corporation shall not and cannot pledge the credit or taxing power of this state or any political subdivision of this state or make its debts payable out of any moneys except those of the corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To facilitate the organization of an Iowa capital investment corporation, both of the following persons shall serve as incorporators as provided in }}}{{\f5\fs18\hyphpar0\qj{section 504.201}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chairperson of the economic development authority board or a designee of the chairperson.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the economic development authority or a designee of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After incorporation, the initial board of directors shall be elected by the members of an appointment committee. The members of the appointment committee shall be appointed by the economic development authority. The initial board of directors shall consist of five members. The persons elected to the initial board of directors by the appointment committee shall include persons who have an expertise in the areas of the selection and supervision of investment managers or in the fiduciary management of investment funds, and other areas of expertise as deemed appropriate by the appointment committee. After the election of the initial board of directors, vacancies in the board of directors of the corporation shall be elected by the remaining directors of the corporation. Members of the board of directors shall be subject to any restrictions on conflicts of interest specified in the organizational documents and shall have no interest in any venture capital investment fund allocation manager selected by the corporation pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ or in any investments made by the Iowa fund of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the appointment committee shall exercise due care to assure that persons elected to the initial board of directors have the requisite financial experience necessary in order to carry out the duties of the corporation as established in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, including in areas related to venture capital investment, investment management, and supervision of investment managers and investment funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the election of the initial board of directors, the terms of the members of the appointment committee shall expire.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The economic development authority shall assist the incorporators and the appointment committee in any manner determined necessary and appropriate by the incorporators and appointment committee in order to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After incorporation, the Iowa capital investment corporation shall conduct a national solicitation for investment plan proposals from qualified venture capital investment fund allocation managers for the raising and investing of capital by the Iowa fund of funds in accordance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. Any proposed investment plan shall address the applicant\u8217\'3fs level of experience, quality of management, investment philosophy and process, probability of success in fundraising, prior investment fund results, and plan for achieving the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. The selected venture capital investment fund allocation manager shall be a person with substantial, successful experience in the design, implementation, and management of seed and venture capital investment programs and in capital formation. The corporation shall only select a venture capital investment fund allocation manager with demonstrated expertise in the management and fund allocation of investments in venture capital funds. The corporation shall select the venture capital investment fund allocation manager deemed best qualified to generate the amount of capital required by }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and to invest the capital of the Iowa fund of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa capital investment corporation may charge a management fee on assets under management in the Iowa fund of funds. The fee shall be in addition to any fee charged to the Iowa fund of funds by the venture capital investment fund allocation manager selected by the corporation, but the fee shall be charged only to pay for reasonable and necessary costs of the Iowa capital investment corporation and shall not exceed one-half of one percent per year of the value of assets under management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Directors of the Iowa capital investment corporation shall be compensated for direct expenses and mileage but shall not receive a director\u8217\'3fs fee or salary for service as directors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa capital investment corporation shall have the power to engage consultants, expend funds, invest funds, contract, bond or insure against loss, or perform any other act necessary to carry out its purpose. However, the corporation shall not hire staff as employees except to administer the rural and small business loan guarantee program of the Iowa fund of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the dissolution of the Iowa fund of funds, the Iowa capital investment corporation shall be liquidated and dissolved, and any assets owned by the corporation shall be distributed to the state of Iowa and deposited in the general fund.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1005, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1006, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1175, \'a777}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1049, \'a7181, 191, 192}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7393}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a758, 59, 84, 85, 89}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715E.62}}}{{\f5\fs12\hyphpar0\qj{, 15E.65}}}{{\f5\fs12\hyphpar0\qj{, 15E.72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.65}}}{\*\bkmkstart stylerid1_2E11_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa fund of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa capital investment corporation shall organize the Iowa fund of funds. The Iowa fund of funds shall be authorized to make investments in private seed and venture capital partnerships or entities in a manner which will encourage the availability of a wide variety of venture capital in the state, strengthen the economy of the state, help business in Iowa gain access to sources of capital, help build a significant, permanent source of capital available to serve the needs of Iowa businesses, and accomplish all these benefits in a way that minimizes the use of tax credits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa capital investment corporation shall organize the Iowa fund of funds in the following manner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa fund of funds shall be organized as a private, for-profit, limited partnership or limited liability company under Iowa law pursuant to which the Iowa capital investment corporation shall be the general partner or manager. The entity shall be organized so as to provide for equity interests for designated investors which provide for a designated scheduled rate of return. The interest of the Iowa capital investment corporation in the Iowa fund of funds shall be to serve as general partner or manager and to be paid a management fee for the service as provided in }}}{{\f5\fs18\hyphpar0\qj{section 15E.64, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, and to receive investment returns of the Iowa fund of funds in excess of those payable to designated investors. Any returns in excess of those payable to designated investors shall be reinvested by the Iowa capital investment corporation by being held in the Iowa fund of funds as a revolving fund for reinvestment in venture capital funds or investments until the termination of the Iowa fund of funds. Any returns received from these reinvestments shall be deposited in the revolving fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa fund of funds shall principally make investments in high-quality venture capital funds managed by investment managers who have made a commitment to consider equity investments in businesses located within the state of Iowa and which have committed to maintain a physical presence within the state of Iowa. The investments by the Iowa fund of funds shall be focused principally on partnership interests in private venture capital funds and not in direct investments in individual businesses. The Iowa fund of funds shall invest in venture capital funds with experienced managers or management teams with demonstrated expertise and a successful history in the investment of venture capital funds. The Iowa fund of funds may invest in newly created venture capital funds as long as the managers or management teams of the funds have the experience, expertise, and a successful history in the investment of venture capital funds described in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa fund of funds shall establish and administer a program to provide loan guarantees and other related credit enhancements on loans to rural and small business borrowers within the state of Iowa. The Iowa fund of funds shall invest five percent of its assets in investments for this program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa fund of funds shall have the power to engage consultants, expend funds, invest funds, contract, bond or insure against loss, or perform any other act necessary to carry out its purpose, including, without limitation, engaging and agreeing to compensate a venture capital investment fund allocation manager. Such compensation shall be in addition to the management fee paid to the Iowa capital investment corporation. However, the Iowa fund of funds shall not hire employees except to administer its rural and small business loan guarantee and credit enhancement program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa fund of funds may issue debt and borrow such funds as may be needed to accomplish its goals. However, such debt shall not be secured by tax credits issued by the board. The Iowa fund of funds may open and manage bank and short-term investment accounts as deemed necessary by the venture capital investment fund allocation manager.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa fund of funds may expend moneys to secure investment ratings for investments by designated investors in the Iowa fund of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each calendar year, the auditor of state shall conduct an annual audit of the activities of the Iowa fund of funds or shall engage an independent auditor to conduct the audit, provided that the independent auditor has no business, contractual, or other connection to the Iowa capital investment corporation or the Iowa fund of funds. The corporation shall reimburse the auditor of state for costs associated with the annual audit. The audit shall be delivered to the Iowa capital investment corporation and the board each year and shall include a valuation of the assets owned by the Iowa fund of funds as of the end of each year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As soon as practicable after June 20, 2013, the Iowa capital investment corporation, in conjunction with the department of revenue, the board, and the attorney general, shall wind up the Iowa fund of funds pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 15E.72}}}{{\f5\fs18\hyphpar0\qj{ and shall cause the Iowa fund of funds to be liquidated with all of its assets distributed to its owners in accordance with the provisions of its organizational documents and in accordance with the fund documents. In liquidating such assets, the capital investment corporation, the department of revenue, the board, and the attorney general shall act with prudence and caution in order to minimize costs and fees and to preserve investment assets to the extent reasonably possible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the liquidation of the Iowa fund of funds, the Iowa capital investment corporation shall file a report with the general assembly stating how many jobs in this state were created through investments made by the Iowa fund of funds.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1005, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1006, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 7, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7130, 132}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715E.52}}}{{\f5\fs12\hyphpar0\qj{, 15E.62}}}{{\f5\fs12\hyphpar0\qj{, 15E.72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.66}}}{\*\bkmkstart stylerid1_2E11_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificates and tax credits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may issue certificates and related tax credits to designated investors which, if redeemed for the maximum possible amount, shall not exceed a total aggregate of sixty million dollars of tax credits. The certificates shall be issued contemporaneously with a commitment to invest in the Iowa fund of funds by a designated investor. A certificate issued by the board shall have a specific maturity date or dates designated by the board and shall be redeemable only in accordance with the contingencies reflected on the certificate or incorporated therein by reference. A certificate and the related tax credit shall be transferable by the designated investor. A tax credit shall not be claimed or redeemed except by a designated investor or transferee in accordance with the terms of a certificate from the board. A tax credit shall not be claimed for a tax year that begins earlier than the maturity date or dates stated on the certificate. An individual may claim the credit of a partnership, limited liability company, S corporation, estate, or trust electing to have the income taxed directly to the individual. The amount claimed by the individual shall be based upon the pro rata share of the individual\u8217\'3fs earnings from the partnership, limited liability company, S corporation, estate, or trust. Any tax credit in excess of the taxpayer\u8217\'3fs tax liability for the tax year may be credited to the tax liability for the following seven years, or until depleted, whichever is earlier.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall certify the maximum amount of a tax credit which could be issued to a designated investor and identify the specific earliest date or dates the certificate may be redeemed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. The amount of the tax credit shall be limited to an amount equivalent to any difference between the scheduled aggregate return to the designated investor at rates of return authorized by the board and aggregate actual return received by the designated investor and any predecessor in interest of capital and interest on the capital. The rates, whether fixed rates or variable rates, shall be determined pursuant to a formula stipulated in the certificate or incorporated therein by reference. The board shall clearly indicate on the certificate, or incorporate therein by reference, the schedule, the amount of equity investment, the calculation formula for determining the scheduled aggregate return on invested capital, and the calculation formula for determining the amount of the tax credit that may be claimed. Once issued to a designated investor, a certificate shall be binding on the board and the department of revenue and shall not be modified, terminated, or rescinded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a designated investor or transferee elects to redeem a certificate, the certificate shall not be redeemed prior to the maturity date or dates stated on the certificate. At the time of redemption, the board shall determine the amount of the tax credit that may be claimed by the designated investor based upon the returns received by the designated investor and its predecessors in interest and the provisions of the certificate. The board shall issue a verification to the department of revenue setting forth the maximum tax credit which can be claimed by the designated investor with respect to the redemption of the certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall, in conjunction with the department of revenue, develop a system for registration of any certificate and related tax credit issued or transferred pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and a system that permits verification that any tax credit claimed upon a tax return is valid and that any transfers of the certificate and related tax credit are made in accordance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall issue the tax credits in such a manner that not more than twenty million dollars of tax credits may be initially redeemable in any fiscal year. The board shall indicate on the tax certificate the principal amount of the tax credit and the maturity date or dates on which the credit may be first claimed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate or tax credit issued or transferred pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered a security pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 502}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining the maximum aggregate limit in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and the fiscal year limitation in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, the board shall use the cumulative amount of scheduled aggregate returns on certificates issued by the board to designated investors. However, certificates and related tax credits which have expired shall not be included and certificates and related tax credits which have been redeemed shall be included only to the extent of tax credits actually allowed.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1005, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1006, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 7, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1138, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715E.62}}}{{\f5\fs12\hyphpar0\qj{, 15E.63}}}{{\f5\fs12\hyphpar0\qj{, 422.11Q}}}{{\f5\fs12\hyphpar0\qj{, 422.33}}}{{\f5\fs12\hyphpar0\qj{, 422.60}}}{{\f5\fs12\hyphpar0\qj{, 432.12I}}}{{\f5\fs12\hyphpar0\qj{, 533.329}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.67}}}{\*\bkmkstart stylerid1_2E11_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and effectiveness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subchapter}}}{ shall not be construed as a restriction or limitation upon any power which the board might otherwise have under any other law of this state and the provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ are cumulative to such powers. }{{\f5\fs18\hyphpar0\qj{This subchapter}}}{ shall be construed to provide a complete, additional, and alternative method for performing the duties authorized and shall be regarded as supplemental and additional to the powers conferred by any other law. The level, timing, or degree of success of the Iowa fund of funds or the investment funds in which the Iowa fund of funds invests in, or the extent to which the investment funds are invested in Iowa venture capital projects, or are successful in accomplishing any economic development objectives, shall not compromise, diminish, invalidate, or affect the provisions of any contract entered into by the board or the Iowa fund of funds.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1005, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1006, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.68}}}{\*\bkmkstart stylerid1_2E11_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Permissible investments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Investments by designated investors in the Iowa fund of funds shall be deemed permissible investments for state-chartered banks, for credit unions, and for domestic insurance companies under applicable state laws.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1005, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1006, \'a713, 14}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Insurance companies; }{{\f5\fs12\hyphpar0\qj{\'a7511.8}}}{, }{{\f5\fs12\hyphpar0\qj{515.35}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Banks; }{{\f5\fs12\hyphpar0\qj{\'a7524.901}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Credit unions; }{{\f5\fs12\hyphpar0\qj{\'a7533.304}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.69}}}{\*\bkmkstart stylerid1_2E11_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The attorney general may enforce the provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ and conduct any investigations necessary for such enforcement.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1005, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1006, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.70}}}{\*\bkmkstart stylerid1_2E11_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Financial statements \u8212\'3f auditor of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{By July 1 of each year, the Iowa fund of funds, the Iowa capital investment corporation, and designated investors shall submit a financial statement for the previous calendar year to the auditor of state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 179, \'a7193}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.71}}}{\*\bkmkstart stylerid1_2E11_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Executive council action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding }{{\f5\fs18\hyphpar0\qj{section 7D.29, subsection 1}}}{, the executive council in full consultation with the attorney general, and with the agreement of the attorney general, shall take any action deemed necessary to protect the interests of the state with respect to any certificates, tax credits, entities created, or action taken in relation to }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{. Such actions may include but are not limited to initiation of legal action, commencement of special investigations, institution of special audits of any involved entity, or establishment of receiverships. If such action is taken, the council may incur the necessary expense to perform such a duty or cause such a duty to be performed, and pay the expense out of any moneys in the state treasury not otherwise appropriated.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1138, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.72}}}{\*\bkmkstart stylerid1_2E11_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Program wind-up and future repeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Organization of additional funds prohibited.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 15E.65}}}{{\f5\fs18\hyphpar0\qj{, an Iowa fund of funds shall not be organized on or after June 20, 2013.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{New investments by the fund of funds prohibited.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 15E.65}}}{{\f5\fs18\hyphpar0\qj{, the Iowa fund of funds shall not make new investments in private seed and venture capital partnerships or entities on or after June 20, 2013, except as required by the fund documents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{New investments by designated investors prohibited.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and notwithstanding any other provision in }}}{{\f5\fs18\hyphpar0\qj{this subchapter VII}}}{{\f5\fs18\hyphpar0\qj{, a designated investor shall not invest in the Iowa fund of funds on or after June 20, 2013.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the prohibition in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a designated investor may invest in the Iowa fund of funds on or after June 20, 2013, to the extent such investment is required by the fund documents. In addition, the director of revenue, with the approval of the attorney general, may authorize additional investment in the Iowa fund of funds but only if such an investment is necessary to preserve fund assets, repay creditors, pay taxes, or otherwise effectuate an orderly wind-up of the program pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Issuance, verification, and redemption of new certificates prohibited.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and notwithstanding any other provision in }}}{{\f5\fs18\hyphpar0\qj{this subchapter VII}}}{{\f5\fs18\hyphpar0\qj{, the board shall not issue, verify, or redeem a certificate or a related tax credit on or after June 20, 2013.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the prohibition in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the board may issue, redeem, or verify a certificate or a related tax credit under any of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board is required to do so under the terms of the fund documents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance, redemption, or verification is deemed necessary by the director of revenue and the attorney general in order to arrange new financing terms with a creditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance, redemption, or verification is deemed necessary by the director of revenue and the attorney general to preserve fund assets, repay creditors, or otherwise effectuate an orderly wind-up of the program pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{New fund allocation managers prohibited.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision in }}}{{\f5\fs18\hyphpar0\qj{this subchapter VII}}}{{\f5\fs18\hyphpar0\qj{, the Iowa capital investment corporation shall not have authority to solicit, select, terminate, or change a fund allocation manager or similar manager on or after June 20, 2013.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or after June 20, 2013, all decisions pertaining to relationships with a fund allocation manager or similar manager selected prior to June 20, 2013, shall be made by the director of revenue with the approval of the attorney general. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to impair the terms of the fund documents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Pledging of certificates prohibited.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and notwithstanding any other provision of law to the contrary, a certificate and a related tax credit or verified tax credit issued by the board shall not be pledged by a designated investor as security for a loan or an extension of credit on or after June 20, 2013.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the prohibition in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a certificate and related tax credit or verified tax credit issued by the board may be pledged by a designated investor as security for a loan or an extension of credit to the extent such pledge is required by the fund documents. In addition, the board, with the approval of the director of revenue and the attorney general, may authorize a certificate and related tax credit to be pledged as security for a loan or an extension of credit, but only if such a pledge is necessary to arrange new financing terms with a creditor or to repay creditors for moneys loaned or credit extended to a designated investor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rural and small business loan guarantees prohibited.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision in }}}{{\f5\fs18\hyphpar0\qj{this subchapter VII}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the Iowa capital investment corporation shall not make rural and small business loan guarantees or otherwise administer a program to provide loan guarantees and other related credit enhancements on loans to rural and small business borrowers within the state of Iowa on or after June 20, 2013.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Iowa capital investment corporation purposes amended.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 15E.64}}}{{\f5\fs18\hyphpar0\qj{, on or after June 20, 2013, the purposes of the Iowa capital investment corporation shall be to comply with its obligations under the fund documents and to assist the board, the director of revenue, and the attorney general in effectuating the orderly wind-up of the Iowa fund of funds. In effectuating such a wind-up, the Iowa capital investment corporation shall comply with all reasonable requests by the board, the director of revenue, the attorney general, or the auditor of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Use of revolving fund prohibited.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 15E.65, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, on or after June 20, 2013, all investment returns received by the Iowa capital investment corporation that are in excess of those payable to designated investors shall be deposited in the general fund of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to impair the terms of the fund documents. It is the intent of the general assembly that }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ only applies in the event that there are investment returns in excess of those necessary to repay creditors and designated investors under the terms of the fund documents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Preservation of existing rights.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ is not intended to and shall not limit, modify, or otherwise adversely affect the fund documents, including any certificate, verified tax credit, or related tax credit issued before June 20, 2013, or limit, modify, or otherwise adversely affect the redemption of any tax credit, verified tax credit, or certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E11_2E16_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E16_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Future repeal.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subchapter VII}}}{{\f5\fs18\hyphpar0\qj{ is repealed upon the occurrence of one of the following, whichever is earlier:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The expiration or termination of all fund documents. The director of revenue shall notify the Iowa Code editor upon the occurrence of this condition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{December 31, 2027.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 140, \'a7131, 132}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715E.65}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{15E.73 through 15E.80}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VIII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E12_2E2_2E2}{IOWA SEED CAPITAL CORPORATION}{\*\bkmkend stylerid1_2E12_2E2_2E2}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{15E.81 through 15E.85}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2001/CH0061.pdf" }{\fldrslt \f5 \fs18{{2001 Acts, ch 61, \'a719}}}}}}{{\f5\fs18\qj{2001 Acts, ch 61, \'a719}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{15E.86}}}{\*\bkmkstart stylerid1_2E12_2E4_2E2_2E2}{\*\bkmken