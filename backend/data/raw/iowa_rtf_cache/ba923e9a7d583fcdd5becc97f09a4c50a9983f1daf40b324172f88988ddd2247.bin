ar0\qj{section 321.46}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.47}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a combined gross weight exceeding forty tons, the annual registration fee shall be one thousand six hundred ninety-five dollars plus eighty dollars for each ton over forty tons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For truck tractors or road tractors equipped with two or more solid rubber tires, the annual registration fee shall be the fee for truck tractors or road tractors with pneumatic tires and of the same combined gross weight, plus twenty-five percent thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a rubber-tired farm tractor not operated for hire upon the public highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74919-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.18;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.122}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a719, 38}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1182, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1210, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1019, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a77, 11, 23, 25}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.26}}}{{\f5\fs12\hyphpar0\qj{, 321.106}}}{{\f5\fs12\hyphpar0\qj{, 321.109}}}{{\f5\fs12\hyphpar0\qj{, 321.115}}}{{\f5\fs12\hyphpar0\qj{, 321.115A}}}{{\f5\fs12\hyphpar0\qj{, 321.120}}}{{\f5\fs12\hyphpar0\qj{, 321.134}}}{{\f5\fs12\hyphpar0\qj{, 321E.12}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.123}}}{\*\bkmkstart stylerid1_2E148_2E2_2E2}{\*\bkmkend stylerid1_2E148_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trailers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All trailers except farm trailers, mobile homes, and manufactured homes, unless otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, are subject to an annual registration fee as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For trailers with an empty weight of two thousand pounds or less, the annual registration fee is twenty dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For trailers with an empty weight in excess of two thousand pounds, the annual registration fee is thirty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Trailers for which the empty weight is two thousand pounds or less are exempt from the certificate of title and lien provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For trailers and semitrailers licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{, the annual registration fee for the permanent registration plate shall be the applicable fee under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The registration fees for a permanent registration plate, at the option of the registrant, shall be remitted to the department at five-year intervals or on an annual basis. Fees collected under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be reduced or prorated under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Travel trailers and fifth-wheel travel trailers, except those in manufacturer\u8217\'3fs or dealer\u8217\'3fs stock, shall be subject to an annual registration fee of thirty cents per square foot of floor space computed on the exterior overall measurements, but excluding three feet occupied by any trailer hitch as provided by and certified to by the owner, to the nearest whole dollar. When a travel trailer or fifth-wheel travel trailer is registered in Iowa for the first time or when title is transferred, the annual registration fee shall be prorated on a monthly basis. The annual registration fee shall be reduced to seventy-five percent of the full fee after the vehicle is more than six model years old.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A travel trailer may be stored under }}}{{\f5\fs18\hyphpar0\qj{section 321.134}}}{{\f5\fs18\hyphpar0\qj{, provided the travel trailer is not used for human habitation for any period during storage and is not moved upon the highways of the state. A travel trailer stored under }}}{{\f5\fs18\hyphpar0\qj{section 321.134}}}{{\f5\fs18\hyphpar0\qj{ is not subject to a manufactured or mobile home tax assessed under }}}{{\f5\fs18\hyphpar0\qj{chapter 435}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Motor trucks or truck tractors pulling trailers or semitrailers shall be registered for the combined gross weight of the motor truck or truck tractor and trailer or semitrailer, except that:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Motor trucks registered for six tons or less not used for hire, pulling trailers or semitrailers used by a person engaged in farming to transport commodities produced by the owner, or to transport commodities or livestock purchased by the owner for use in the owner\u8217\'3fs own farming operation or used by any person to transport horses shall not be subject to registration for the gross weight of such trailer or semitrailer provided the combined gross weight does not exceed twelve tons, plus the tolerance provided for in }}}{{\f5\fs18\hyphpar0\qj{section 321.466}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Motor trucks registered for six tons or less not used for hire, pulling trailers or semitrailers used by a person in the person\u8217\'3fs own operations shall not be subject to registration for the gross weight of such trailer or semitrailer provided the combined gross weight does not exceed eight tons, plus the tolerance provided for in }}}{{\f5\fs18\hyphpar0\qj{section 321.466}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74920; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.19;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.123}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a716 \u8211\'3f 18}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a720, 38}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a763}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a729}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 118, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1152, \'a75, 6}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 188, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1016, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 153, \'a715, 17}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 176, \'a780}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1070, \'a79, 31}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a724, 25, 94, 95}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.310}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.124}}}{\*\bkmkstart stylerid1_2E149_2E2_2E2}{\*\bkmkend stylerid1_2E149_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motor homes, multipurpose vehicles, and motorsports recreational vehicles \u8212\'3f fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Motor homes are classified as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class A motor home means a truck chassis or special chassis upon which is built a driver\u8217\'3fs compartment and an entire body which provides temporary living quarters. A class A motor home shall also mean a passenger carrying bus which has been registered at least five times as a motor truck and which has been converted, modified, or altered to provide temporary living quarters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class B motor home means a completed van-type vehicle which has been converted, modified, constructed, or altered to provide temporary living quarters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class C motor home means an incomplete vehicle upon which is permanently attached a body designed to provide temporary living quarters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class A motor homes and class C motor homes are exempt from the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 322.5, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, except that a motor vehicle dealer showing class A motor homes and class C motor homes shall apply for a temporary permit upon forms and for such time as provided in }}}{{\f5\fs18\hyphpar0\qj{section 322.5, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and the department may issue the temporary permit upon payment of the fee provided therein.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual registration fee for motor homes and 1992 and older model years for multipurpose vehicles is as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For class A motor homes with a list price of eighty thousand dollars or more as certified to the department by the manufacturer, four hundred dollars for registration each year through five model years and three hundred dollars for each succeeding registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For class A motor homes with a list price of forty thousand dollars or more but less than eighty thousand dollars as certified to the department by the manufacturer, two hundred dollars for registration each year through five model years and one hundred fifty dollars for each succeeding registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For class A motor homes with a list price of twenty thousand dollars or more but less than forty thousand dollars as certified to the department by the manufacturer, one hundred forty dollars for the first five registrations and one hundred five dollars for each succeeding registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For class A motor homes with a list price of less than twenty thousand dollars as certified to the department by the manufacturer, one hundred twenty dollars for registration each year through five model years and eighty-five dollars for each succeeding registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a class A motor home which is a passenger-carrying bus which has been registered at least five times as a motor truck and which has been converted, modified, or altered to provide temporary living quarters, ninety dollars for registration each year through ten model years and sixty-five dollars for each succeeding registration. In computing the number of registrations, the registrations shall be cumulative beginning with the registration of the class A motor home as a motor truck prior to its conversion, modification, or alteration to provide temporary living quarters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For class B motor homes, ninety dollars for registration each year through five model years and sixty-five dollars for each succeeding registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For class C motor homes, one hundred ten dollars for registration each year through five model years and eighty dollars for each succeeding registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For multipurpose vehicles in accordance with the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two hundred dollars for registration for the first and second model years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One hundred seventy-five dollars for registration for the third and fourth model years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One hundred fifty dollars for registration for the fifth model year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seventy-five dollars for registration for the sixth model year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fifty-five dollars for registration for each succeeding model year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual registration fee for a multipurpose vehicle with permanently installed equipment manufactured for and necessary to assist a person with a disability who is either the owner or a member of the owner\u8217\'3fs household in entry and exit of the vehicle or for a multipurpose vehicle if the vehicle\u8217\'3fs owner or a member of the vehicle owner\u8217\'3fs household uses a wheelchair as the only means of mobility shall be sixty dollars. For purposes of this subparagraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fuses a wheelchair\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include use of a wheelchair due to a temporary injury or medical condition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The registration fees required by this lettered paragraph are applicable to all 1992 and older model years for multipurpose vehicles beginning January 1, 1993. The registration fees for multipurpose vehicles that are 1993 and subsequent model years shall be in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.109}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of determining that portion of the annual registration fee which is based upon the value of the multipurpose vehicle, sixty percent of the annual fee is attributable to the value of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual registration fee for a motorsports recreational vehicle is four hundred dollars. For purposes of determining that portion of the annual registration fee which is based upon the value of the motorsports recreational vehicle, sixty percent of the annual fee is attributable to the value of the vehicle. The owner of a motor vehicle registered under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall certify at the time of registration or renewal of registration that the motor vehicle is used for the purpose of participating in motorsports competition.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines by audit or other means that a person registered a vehicle as a motorsports recreational vehicle that is not qualified for such registration, the person shall be required to pay the difference between the regular annual registration fees owed for the vehicle for each year the vehicle was registered in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the fees actually paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines by audit or other means that the person knowingly registered a vehicle as a motorsports recreational vehicle that is not qualified for such registration, the person shall be required to pay a penalty for improper registration in the amount of seven hundred fifty dollars for each registration year in which the vehicle was registered in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, not to exceed two thousand two hundred fifty dollars.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7321.124}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a721, 38}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 75, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1019, \'a72, 8}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1222, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1232, \'a7402, 412}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 165, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1127, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.109}}}{{\f5\fs12\hyphpar0\qj{, 321.115}}}{{\f5\fs12\hyphpar0\qj{, 321.115A}}}{{\f5\fs12\hyphpar0\qj{, 321.152}}}{{\f5\fs12\hyphpar0\qj{, 322.2}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.125}}}{\*\bkmkstart stylerid1_2E15_30_2E2_2E2}{\*\bkmkend stylerid1_2E15_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Effect of exemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The exemption of a motor vehicle from an annual registration fee or a fee for new registration shall not exempt the operator of such vehicle from the performance of any other duty imposed on the operator by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74923; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.21;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.125}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a796}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.126}}}{\*\bkmkstart stylerid1_2E151_2E2_2E2}{\*\bkmkend stylerid1_2E151_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Refunds of annual registration fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refunds of unexpired annual vehicle registration fees shall be allowed in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, except that no refund shall be allowed and paid if the unused portion of the fee is less than ten dollars. Paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ do not apply to vehicles registered by the county treasurer. The refunds shall be made as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle is destroyed by fire or accident, or junked and its identity as a vehicle entirely eliminated, the owner in whose name the vehicle was registered at the time of destruction or dismantling shall return the plates to the department and within thirty days thereafter make a statement of such destruction or dismantling and make claim for refund. With reference to the destruction or dismantling of a vehicle, no refund shall be allowed unless a junking certificate has been issued, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.52}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle is stolen, the owner shall give notice of the theft to the department within five days. If the vehicle is not recovered by the owner thirty days prior to the end of the current registration year, the owner shall make a statement of the theft and make claim for refund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle is placed in storage by the owner upon the owner\u8217\'3fs entry into the military service of the United States, the owner shall return the plates to the county treasurer or the department and make a statement regarding the storage and military service and make claim for refund. Whenever the owner of a vehicle so placed in storage desires to again register the vehicle, the county treasurer or department shall compute and collect the fees for registration for the registration year commencing in the month the vehicle is removed from storage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle is registered by the county treasurer during the current registration year and the owner or lessee registers the vehicle for apportioned registration under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{, the owner of the registered vehicle shall surrender the registration plates to the county treasurer and may file a claim for refund. In lieu of a refund, a credit for the annual registration fees paid to the county treasurer may be applied by the department to the owner or lessee\u8217\'3fs apportioned registration fees upon the surrender of the county plates and registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A refund for trailers and semitrailers issued a permanent registration plate pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by the department upon application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a vehicle is sold or junked, the owner in whose name the vehicle was registered may make claim to the county treasurer or department for a refund of the sold or junked vehicle\u8217\'3fs annual registration fee. Also if the owner of a vehicle receives a vehicle registration fee credit under }}}{{\f5\fs18\hyphpar0\qj{section 321.46, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and the credit allowed exceeds the amount of the annual registration fee for the vehicle acquired, the owner may claim a refund for the balance of the credit. The refund is subject to the following limitations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a vehicle registration fee credit has not been received by the owner of the vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 321.46, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the refund shall be computed on the basis of the number of unexpired months remaining in the registration year at the time the vehicle was sold or junked. The refund shall be rounded to the nearest whole dollar. }}}{{\f5\fs18\hyphpar0\qj{Section 321.127, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, does not apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The refund shall only be allowed if the owner makes claim for the refund within six months after the date of the vehicle\u8217\'3fs sale, trade, or junking.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply to vehicles registered under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle was leased and an affidavit was filed by the lessor or the lessee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.46}}}{{\f5\fs18\hyphpar0\qj{, the lessor or the lessee, as applicable, may make a claim for a refund with the county treasurer of the county where the vehicle was registered within six months of the vehicle\u8217\'3fs surrender to the lessor. The refund shall be paid to either the lessor or the lessee, as specified on the application for title and initial registration pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the owner of the vehicle moves out of state, the owner may make a claim for a refund by returning the Iowa registration plates, along with evidence of the vehicle\u8217\'3fs registration in another jurisdiction, to the county treasurer of the county in which the vehicle was registered within six months of the out-of-state registration. For purposes of }}}{{\f5\fs18\hyphpar0\qj{section 321.127}}}{{\f5\fs18\hyphpar0\qj{, the unexpired months remaining in the registration year shall be calculated on the basis of the effective date of the out-of-state registration. However, for the purpose of timely issuance of the refund, the claim for a refund under this paragraph is considered to be filed on the date the registration documents are received by the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, there shall be no refund of apportioned registration fees unless the state which issued the base plate for the vehicle allows such refund. If an owner subject to apportioned registration leases the vehicle for which the refund is sought, the claim shall be filed in the names of both the lessee and the lessor and the refund payment made payable to both the lessor and the lessee. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fowner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall include a person in whom is vested right of possession or control of a vehicle which is subject to a lease, contract, or other legal arrangement vesting right of possession or control in addition to the term as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 49}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74924; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.22;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.126}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a722, 23, 38}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 87, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 108, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1154, \'a76 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1073, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a719, 40}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a721, 35}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 133, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a710, 11, 31}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a797}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a791}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a724, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.46}}}{{\f5\fs12\hyphpar0\qj{, 321.128}}}{{\f5\fs12\hyphpar0\qj{, 326.15}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.127}}}{\*\bkmkstart stylerid1_2E152_2E2_2E2}{\*\bkmkend stylerid1_2E152_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Payment of refund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The refund of the annual registration fee for vehicles shall be computed on the basis of the number of unexpired months remaining in the registration year from date of filing of the claim for refund with the county treasurer, computed to the nearest dollar.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, unless reasonable grounds exist for delay, shall make refund on or before the last day of the month following the month in which the claim is filed with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For trailers or semitrailers issued a permanent registration plate, a refund shall be paid equal to the annual fee for twelve months times the remaining number of complete registration years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refunds for vehicles registered for apportioned registration under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ shall be paid on the basis of unexpired complete calendar months remaining in the registration year from the date the claim for refund and the license plate are received by the department.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74924; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.23;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.127}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 104, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a724, 38}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 87, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 108, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a712, 31}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a798}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.126}}}{{\f5\fs12\hyphpar0\qj{, 321.128}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.128}}}{\*\bkmkstart stylerid1_2E153_2E2_2E2}{\*\bkmkend stylerid1_2E153_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Payment authorized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may make the payments under }{{\f5\fs18\hyphpar0\qj{sections 321.126}}}{ and }{{\f5\fs18\hyphpar0\qj{321.127}}}{, when sufficient proof of such destruction by accident, or the junking and entire elimination of identity as a motor vehicle, theft, or storage by an owner entering the military service of the United States in time of war, is properly certified, approved by the county treasurer, and filed with the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74925; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.24;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.128}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 24, \'a710, 12}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.129}}}{\*\bkmkstart stylerid1_2E154_2E2_2E2}{\*\bkmkend stylerid1_2E154_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When fees returnable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever any application to the department is accompanied by a vehicle registration fee as required by law and the application is refused or rejected, the fee shall be returned to the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever the department through error collects any vehicle registration fee not required to be paid under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the fee shall be refunded from the refund account to the person paying the fee upon application made within one year after the date of such payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the fee for new registration administered by the department of revenue pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.105A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5012.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.173}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1018, \'a721, 30}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a7121}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2009, \'a7321.129}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.130}}}{\*\bkmkstart stylerid1_2E155_2E2_2E2}{\*\bkmkend stylerid1_2E155_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees in lieu of taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The registration fees imposed by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ upon private passenger motor vehicles or semitrailers are in lieu of all state and local taxes, except local vehicle taxes, to which motor vehicles or semitrailers are subject.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m8; C24, 27, 31, 35, \'a74927; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.26;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.130}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a779}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a730}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.131}}}{\*\bkmkstart stylerid1_2E156_2E2_2E2}{\*\bkmkend stylerid1_2E156_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lien of fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All registration or other fees provided for in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall constitute a lien against the vehicle for which the fees are payable unless otherwise provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{ until such time as they are paid as provided by law, with any accrued penalties. The county treasurer may perfect a security interest in a vehicle for the amount of such fees as provided in }{{\f5\fs18\hyphpar0\qj{section 321.50}}}{. If the lien is not perfected as provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{, the lien shall not be valid against a bona fide purchaser of the vehicle without actual notice to the purchaser.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m21; SS15, \'a71571-m7; C24, 27, 31, 35, \'a74928; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.27;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.131}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1013, \'a722, 35}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.132}}}{\*\bkmkstart stylerid1_2E157_2E2_2E2}{\*\bkmkend stylerid1_2E157_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When lien attaches.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The lien of the original annual registration fee attaches, at the time the fee is first payable, as provided by law, and the lien of all renewals of registration attach on the first day of each succeeding registration year.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74929; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.28;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.132}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a725, 38}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a799}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E158_2E1_2E1}{PENALTIES, COSTS, AND COLLECTIONS}{\*\bkmkend stylerid1_2E158_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.133}}}{\*\bkmkstart stylerid1_2E159_2E2_2E2}{\*\bkmkend stylerid1_2E159_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Methods of collection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The collection of all fees and penalties may be enforced against any vehicle or they may be collected by suit against the owner who shall remain personally liable therefor until such time as the transfer thereof shall be reported to the county treasurer and the department or until such time as said vehicle ceases to be in use and all fees and penalties to such date shall be paid.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m21; C24, 27, 31, 35, \'a74930; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5009.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.133}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.134}}}{\*\bkmkstart stylerid1_2E16_30_2E2_2E2}{\*\bkmkend stylerid1_2E16_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Monthly penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the first day of the second month following the beginning of each registration year a penalty of five percent of the annual registration fee shall be added to the annual registration fees not paid by that date and an additional penalty of five percent shall be added the first day of each succeeding month, until the fee is paid. A penalty shall not be less than five dollars. If the owner of a vehicle surrenders the registration plates for a vehicle prior to the plates becoming delinquent, to the county treasurer of the county where the vehicle is registered, or to the department if the vehicle is registered under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{, the owner may register the vehicle any time thereafter upon payment of the annual registration fee for the registration year without penalty. To avoid a penalty or an additional penalty in the case of a delinquent registration through a county treasurer, if the last calendar day of a month falls on Saturday, Sunday, or a holiday, the payment deadline is extended to include the first business day of the following month. For payments made through a county treasurer\u8217\'3fs authorized internet site only, if the last day of the month falls on a Saturday, Sunday, or a holiday, the electronic payment must be entered by midnight on the first business day of the next month. All other electronic payments must be entered by midnight on the last day of the month preceding the delinquent date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual registration fee for trucks, truck tractors, and road tractors registered by the county treasurer, as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.120,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\f5\fs18\hyphpar0\qj{321.121}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{321.122}}}{{\f5\fs18\hyphpar0\qj{, may be payable in two equal semiannual installments if the annual registration fee exceeds the annual registration fee for a vehicle with a gross weight exceeding five tons. The penalties provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be computed on the amount of the first installment only and on the first day of the seventh month of the registration period the same rate of penalty shall apply to the second installment, until the fee is paid. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a penalty applies to an annual vehicle registration fee provided for in }}}{{\f5\fs18\hyphpar0\qj{sections 321.120,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\f5\fs18\hyphpar0\qj{321.121}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{321.122}}}{{\f5\fs18\hyphpar0\qj{, the same penalty shall be assessed on the fees collected to increase the registered gross weight of the vehicle, if the increased gross weight is requested within forty-five days from the date the delinquent vehicle is registered for the current registration period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 3}}}{{\f5\fs18\hyphpar0\qj{, if a vehicle registration is delinquent for twenty-four months or more, a flat penalty and fee shall be assessed for the delinquent period in addition to the current annual registration fee. The flat penalty and fee shall be one hundred fifty percent of the current annual registration fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall waive the penalties imposed by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for an owner who is in the military service of the United States and who has been relocated as a result of being placed on active duty on or after September 11, 2001. The department shall adopt rules to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, including, if necessary, procedures for refunding penalties collected prior to March 29, 2004.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m7; C24, 27, 31, 35, \'a74931; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5009.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.134}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a726, 38}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 24, \'a76, 12}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 185, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1043, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a723, 35}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1092, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 143, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a7100}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a713, 40}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7257}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 103, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 92, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.39}}}{{\f5\fs12\hyphpar0\qj{, 321.123}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.135}}}{\*\bkmkstart stylerid1_2E161_2E2_2E2}{\*\bkmkend stylerid1_2E161_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When fees delinquent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except as otherwise provided, annual registration fees become delinquent and penalties accrue the first of the month following the purchase of a new vehicle, and thirty days following the date a vehicle is brought into the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74932; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5009.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.135}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 209, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a7101}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.136 through 321.144}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E163_2E1_2E1}{FUNDS}{\*\bkmkend stylerid1_2E163_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.145}}}{\*\bkmkstart stylerid1_2E164_2E2_2E2}{\*\bkmkend stylerid1_2E164_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disposition of moneys and fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for fines, forfeitures, court costs, and the collection fees retained by the county treasurer pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.152}}}{{\f5\fs18\hyphpar0\qj{, and except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, moneys and motor vehicle registration fees collected under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be credited by the treasurer of state to the road use tax fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenues derived from trailer registration fees collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 321.105}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.105A}}}{{\f5\fs18\hyphpar0\qj{, fees charged for driver\u8217\'3fs licenses and nonoperator\u8217\'3fs identification cards, fees charged for commercial driver\u8217\'3fs license driving skills tests pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.187A}}}{{\f5\fs18\hyphpar0\qj{, fees charged for the issuance of a certificate of title, the certificate of title surcharge collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.52A}}}{{\f5\fs18\hyphpar0\qj{, and revenues credited pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 423.43, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 423C.5}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited in a fund to be known as the statutory allocations fund under the control of the department and credited as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys shall be credited in order of priority as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An amount equal to four percent of the revenue from the operation of }}}{{\f5\fs18\hyphpar0\qj{section 321.105A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be credited to the department, to be used for purposes of public transit assistance under }}}{{\f5\fs18\hyphpar0\qj{chapter 324A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An amount equal to two dollars per year of license validity for each issued or renewed driver\u8217\'3fs license which is valid for the operation of a motorcycle shall be credited to the motorcycle rider education fund established under }}}{{\f5\fs18\hyphpar0\qj{section 321.179}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amounts required to be transferred pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{ from revenues available under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be transferred and credited as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{ for the various purposes specified in that section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An amount necessary for the payment of costs associated with producing and distributing driver\u8217\'3fs licenses and nonoperator\u8217\'3fs identification cards, not to exceed revenues derived from fees charged for driver\u8217\'3fs licenses and nonoperator\u8217\'3fs identification cards, is appropriated to the department for that purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any such revenues remaining shall be credited to the road use tax fund.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m32; C24, 27, 31, 35, \'a74999; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.145}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a730, 36}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 97, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7144}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 113, \'a747, 55, 56}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 114, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1105, \'a71, 2, 15, 16, 18}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7110}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 135, \'a71, 8}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 153, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.1}}}{{\f5\fs12\hyphpar0\qj{, 321.34}}}{{\f5\fs12\hyphpar0\qj{, 321.52A}}}{{\f5\fs12\hyphpar0\qj{, 321.211}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 423.43}}}{{\f5\fs12\hyphpar0\qj{, 423C.5}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Road use tax fund, }{{\f5\fs12\hyphpar0\qj{\'a7312.1}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph a, NEW subparagraph (4)}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.146 and 321.147}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.148}}}{\*\bkmkstart stylerid1_2E166_2E2_2E2}{\*\bkmkend stylerid1_2E166_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Monthly estimate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall, on the first day of each month, furnish an estimate in writing to the treasurer of state of the amount of expenditures to be made by the department during that month.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75003-c1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.148}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.149}}}{\*\bkmkstart stylerid1_2E167_2E2_2E2}{\*\bkmkend stylerid1_2E167_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supplies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall prepare and furnish to the treasurer of each county all supplies required for the administration of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ in such form as the department may prescribe. Contracts for the supplies shall be awarded by the director of the department of administrative services to persons, firms, partnerships, or corporations engaged in the business of printing in Iowa unless, or through them, the persons, firms, partnerships, or corporations cannot provide the required printing set forth in }{{\f5\fs18\hyphpar0\qj{this section}}}{. In lieu of purchasing under competitive bids, the director of the department of administrative services shall have authority to arrange with the director of the department of corrections to furnish the supplies as can be made in the state institutions.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m2; C24, 27, 31, 35, \'a75006; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.149}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a727, 38}}}{; }{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1119, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1164, \'a740}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7249}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1013, \'a724, 35}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.150}}}{\*\bkmkstart stylerid1_2E168_2E2_2E2}{\*\bkmkend stylerid1_2E168_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Time limit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Blanks or forms for listing used motor vehicles shall be placed in the hands of county treasurers not later than December 15 of any year.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75007; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.150}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.151}}}{\*\bkmkstart stylerid1_2E169_2E2_2E2}{\*\bkmkend stylerid1_2E169_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty and liability of treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county treasurer shall collect the registration fee, the fee for new registration, and penalties on each vehicle registered by the county treasurer and shall be responsible on the county treasurer\u8217\'3fs bond for such amount. The county treasurer shall remit such amount to the treasurer of state as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Fees collected pursuant to participation in county issuance of driver\u8217\'3fs licenses under }{{\f5\fs18\hyphpar0\qj{chapter 321M}}}{ shall be governed by the provisions of that chapter.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75011; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.151}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1143, \'a718, 26}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a7102}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.152}}}{\*\bkmkstart stylerid1_2E17_30_2E2_2E2}{\*\bkmkend stylerid1_2E17_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Collection fees retained by county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county treasurer may retain for deposit in the county general fund the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Four percent of the total collection, excluding the amount of any fee for new registration, for each annual or semiannual vehicle registration and each duplicate registration card or plate issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Twelve dollars and fifty cents from each fee collected for certificates of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Forty percent of all fees collected for certified copies of certificates of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sixteen dollars of each fee collected for perfection of security interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Twenty-five percent of each penalty collected for improper business-trade truck registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.120, subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eleven dollars from each fee for new registration collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.105A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Twenty-five percent of each penalty collected for improper motorsports recreational vehicle registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.124, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The moneys retained under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be deducted, and reported to the department when the county treasurer transfers the money collected under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, a deduction is not lawful unless the county treasurer has complied with }}}{{\f5\fs18\hyphpar0\qj{sections 321.24}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.153}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The five dollar processing fee charged by a county treasurer for collection of tax debt owed to the department of revenue pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.40, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, shall be retained for deposit in the county general fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to fees collected or retained by a county treasurer pursuant to participation in county issuance of driver\u8217\'3fs licenses under }}}{{\f5\fs18\hyphpar0\qj{chapter 321M}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75012; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.152}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7126, 209}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 267, \'a7608}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1238, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1143, \'a719, 26}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a725, 35}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a78, 11, 103, 104}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1146, \'a74, 26}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1127, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a725, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.145}}}{{\f5\fs12\hyphpar0\qj{, 321.153}}}{{\f5\fs12\hyphpar0\qj{, 331.427}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.153}}}{\*\bkmkstart stylerid1_2E171_2E2_2E2}{\*\bkmkend stylerid1_2E171_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Treasurer\u8217\'3fs report to department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer on the tenth day of each month shall certify to the department a full and complete statement of all fees and penalties received by the county treasurer during the preceding calendar month and shall remit all moneys not retained for deposit under }}}{{\f5\fs18\hyphpar0\qj{section 321.152}}}{{\f5\fs18\hyphpar0\qj{ to the treasurer of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The distributed teleprocessing network shall be used in the collection, receipting, accounting, and reporting of any fee collected through the registration renewal or title process, with sufficient time and financial resources provided for implementation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to fees collected or retained by a county treasurer pursuant to participation in county issuance of driver\u8217\'3fs licenses under }}}{{\f5\fs18\hyphpar0\qj{chapter 321M}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to processing fees charged by a county treasurer for the collection of tax debt owed to the department of revenue pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.40}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75013; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.153}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 185, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1073, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1238, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1143, \'a720, 26}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a726, 35}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1146, \'a75, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.152}}}{{\f5\fs12\hyphpar0\qj{, 321.154}}}{{\f5\fs12\hyphpar0\qj{, 331.555}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 331.558}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.154}}}{\*\bkmkstart stylerid1_2E172_2E2_2E2}{\*\bkmkend stylerid1_2E172_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports by department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department, immediately upon receiving the county treasurer\u8217\'3fs report under }{{\f5\fs18\hyphpar0\qj{section 321.153}}}{, shall also report to the treasurer of state the amount so collected by such county treasurer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75014; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.154}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a7101}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.155}}}{\*\bkmkstart stylerid1_2E173_2E2_2E2}{\*\bkmkend stylerid1_2E173_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty of treasurer of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The treasurer of state shall keep proper books of account for the purposes specified herein and shall report to the department each remittance from the county treasurer, when said remittance is received.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75015; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.155}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.156}}}{\*\bkmkstart stylerid1_2E174_2E2_2E2}{\*\bkmkend stylerid1_2E174_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Audit by department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall check and audit all fees and penalties collected, and shall effect a settlement with the county treasurer annually.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75016; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5010.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.156}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E175_2E1_2E1}{VALUE AND WEIGHT OF VEHICLES}{\*\bkmkend stylerid1_2E175_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.157}}}{\*\bkmkstart stylerid1_2E176_2E2_2E2}{\*\bkmkend stylerid1_2E176_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Schedule of prices and weights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer or importer of a motor vehicle sold or offered for sale in this state, either by the manufacturer, importer, distributor, dealer, or any other person, shall file in the office of the department a sworn statement showing the various models manufactured by the manufacturer, importer, distributor, dealer, or other person, and the retail list price and weight of each model concurrently with a public announcement of such prices or concurrently with notification of such prices to dealers licensed to sell such motor vehicles under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{, whichever comes first. The manufacturer, importer, distributor, dealer, or other person shall also make the same report on subsequent new models manufactured.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of filing the sworn statement required under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a manufacturer or importer of a motor vehicle sold or offered for sale in this state may electronically provide the information required in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ to the department, or, if the manufacturer or importer provides the required information to a third-party vendor, the manufacturer or importer shall make the required information available to the department through the third-party vendor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74968; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5011.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.157}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1016, \'a745, 47}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.158}}}{{\f5\fs12\hyphpar0\qj{, 321.160}}}{{\f5\fs12\hyphpar0\qj{, 321.161}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.158}}}{\*\bkmkstart stylerid1_2E177_2E2_2E2}{\*\bkmkend stylerid1_2E177_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Registration dependent on schedule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except as provided in }{{\f5\fs18\hyphpar0\qj{section 321.159}}}{, a motor vehicle shall not be registered in this state unless the manufacturer of the vehicle has furnished, in compliance with }{{\f5\fs18\hyphpar0\qj{section 321.157}}}{, the list price and weight of the model of the motor vehicle that is offered for registration.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74970; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5011.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.158}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1021, \'a769}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.159}}}{\*\bkmkstart stylerid1_2E178_2E2_2E2}{\*\bkmkend stylerid1_2E178_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exceptional cases \u8212\'3f annual registration fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall have the power to fix the annual registration fee on all makes and models of motor vehicles which are not now being furnished or upon which the statement from the factory cannot be obtained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a current year model of a motor vehicle for which the manufacturer or importer of the motor vehicle has not provided the weight and list price, the department shall set the annual registration fee at ten dollars greater than the annual registration fee for the previous year model. Once the manufacturer or importer provides the required information, the information shall be used to set the annual registration fee or the registration renewal fee for the succeeding registration or registration renewal time for the motor vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74971; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5011.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.159}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1222, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1016, \'a746, 47}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a7105}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.158}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.160}}}{\*\bkmkstart stylerid1_2E179_2E2_2E2}{\*\bkmkend stylerid1_2E179_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department to maintain statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall maintain a statement showing all the different makes and models of motor vehicles previously registered in the department, and all the different makes and models of motor vehicles, statements of which have been filed in the office by the manufacturers as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.157}}}{{\f5\fs18\hyphpar0\qj{, together with the retail list price and weight of the vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Copies of the statement shall be furnished to each county treasurer and additional copies may be sold by the department to other persons, at a price to be set by the department, covering the approximate cost of the copies and service involved. Copies of the statement required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be provided electronically. All funds received shall be forwarded by the department to the treasurer of state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74972; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5011.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.160}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1013, \'a727, 35}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.161}}}{\*\bkmkstart stylerid1_2E18_30_2E2_2E2}{\*\bkmkend stylerid1_2E18_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department to fix values and weight.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall annually, and at such other times as new makes or models of motor vehicles are offered for sale or sold in this state, fix the value and weight of each of the different makes and models of motor vehicles which are sold or offered for sale within the state. The value and weight as fixed by the department shall, on 1975 and subsequent year model motor vehicles, be based on the original certification as provided in }{{\f5\fs18\hyphpar0\qj{section 321.157}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74973; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5011.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.161}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.162}}}{\*\bkmkstart stylerid1_2E181_2E2_2E2}{\*\bkmkend stylerid1_2E181_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Method of fixing value and weight.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The value shall be fixed at the next even one hundred dollars above the retail list price F.O.B. the factory, and the weight shall be fixed at the next even one hundred pounds above the manufacturer\u8217\'3fs shipping weight or the actual weight of the vehicle fully equipped.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74974; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5011.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.162}}}{]}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.163 and 321.164}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E183_2E1_2E1}{PLATES AND SUPPLIES}{\*\bkmkend stylerid1_2E183_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.165}}}{\*\bkmkstart stylerid1_2E184_2E2_2E2}{\*\bkmkend stylerid1_2E184_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Manufacture by state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall have authority to arrange with the director of the department of corrections to furnish such supplies as may be made at the state institutions.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74977; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5012.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.165}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.166}}}{\*\bkmkstart stylerid1_2E185_2E2_2E2}{\*\bkmkend stylerid1_2E185_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vehicle plate specifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Vehicle registration plates shall conform to the following specifications:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration plates shall be of metal and of a size not to exceed six inches by twelve inches, except that the size of plates issued for use on autocycles, motorized bicycles, motorcycles, motorcycle trailers, and trailers with an empty weight of two thousand pounds or less shall be established by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Trailers with empty weights of two thousand pounds or less may, upon request, be licensed with regular-sized license plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every registration plate or pair of plates shall display a registration plate number which shall consist of alphabetical or numerical characters or a combination thereof and the name of this state, which may be abbreviated. Every registration plate issued by the county treasurer shall display the name of the county, including any plate issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{, except Pearl Harbor and purple heart registration plates issued prior to January 1, 1997; and collegiate, fire fighter, and medal of honor registration plates. Special truck registration plates shall display the word \u8220\'3fspecial\u8221\'3f. The department may adopt rules to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The registration plate number shall be displayed in characters which shall not exceed a height of four inches nor a stroke width exceeding five-eighths of an inch. Special plates issued to dealers shall display the alphabetical character \u8220\'3fD\u8221\'3f, which shall be of the same size as the characters in the registration plate. The registration plate number issued for autocycles, motorized bicycles, motorcycles, trailers with an empty weight of two thousand pounds or less, and motorcycle trailers shall be a size prescribed by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The registration plate number, except on autocycles, motorized bicycles, motorcycles, motorcycle trailers, and trailers with an empty weight of two thousand pounds or less, shall be of sufficient size to be readable from a distance of one hundred feet during daylight.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There shall be a marked contrast between the color of the registration plates and the data which is required to be displayed on the registration plates. When a new series of registration plates is issued to replace a current series, the new registration plates shall be of a distinctively different color from the series which is replaced, except for collegiate registration plates issued under }}}{{\f5\fs18\hyphpar0\qj{section 321.34, subsection 7 or 7A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration plates issued to a disabled veteran under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.105}}}{{\f5\fs18\hyphpar0\qj{ shall display the alphabetical characters \u8220\'3fDV\u8221\'3f which shall precede the registration plate number. The plates may also display a persons with disabilities parking sticker if issued to the disabled veteran by the department under }}}{{\f5\fs18\hyphpar0\qj{section 321L.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The year and month of expiration of registration, which may be abbreviated, shall be displayed on vehicle registration plates issued by the county treasurer. A distinctive emblem or validation sticker may be prescribed by the department to designate the year and month of expiration. The year and month of expiration shall not be required to be displayed on plates issued under }}}{{\f5\fs18\hyphpar0\qj{section 321.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a trailer with an empty weight of two thousand pounds or less shall receive registration plates for the trailer smaller than plates regularly issued for automobiles pursuant to rules adopted by the department in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the owner requests regular-sized plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Special registration plates issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{, other than gold star, medal of honor, collegiate, fire fighter, natural resources, blackout, and flying our colors registration plates, shall be consistent with the design and color of regular registration plates but shall provide a space on a portion of the plate for the purpose of allowing the placement of a distinguishing processed emblem or an organization decal. Special registration plates shall also comply with the requirements for regular registration plates as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the extent the requirements are consistent with the section authorizing a particular special vehicle registration plate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department reissues a new registration plate design for a special registration plate under }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{, all persons who have purchased or obtained the special registration plates shall not be required to pay the issuance fee.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m12, -m13; C24, 27, 31, 35, \'a74978; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.19, 5001.20, 5012.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7321.35, 321.36, 321.166; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.166}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1032, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 82 Acts, ch 1062, \'a728, 29, 36, 38}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 24, \'a77, 12}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1225, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1215, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 247, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1026, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1028, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a720, 40}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1088, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1171, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1219, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 70, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a714, 15}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a710, 29}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 184, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1124, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a725, 26}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a752, 180}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1068, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 89, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a7156}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a774}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321L.1}}}{{\f5\fs12\hyphpar0\qj{, 364.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.167}}}{\*\bkmkstart stylerid1_2E186_2E2_2E2}{\*\bkmkend stylerid1_2E186_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Delivery of plates, stickers, and emblems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department, upon requisition by the county treasurer, shall provide vehicle registration plates, validation stickers, and emblems as required for the administration of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Vehicle registration plates and validation stickers shall be provided to the county treasurer in numerical sequence.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74979; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5012.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.167}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a730, 38}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.168}}}{\*\bkmkstart stylerid1_2E187_2E2_2E2}{\*\bkmkend stylerid1_2E187_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional deliveries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Thereafter, during the year, the department, upon requisition of the county treasurer, shall deliver additional number plates.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74980; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5012.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.168}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.169}}}{\*\bkmkstart stylerid1_2E188_2E2_2E2}{\*\bkmkend stylerid1_2E188_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Account of plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall keep an accurate record of all number plates issued to each county, and shall also keep a record showing the assignment thereof by the county treasurer to motor vehicles.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74981; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5012.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.169}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.170}}}{\*\bkmkstart stylerid1_2E189_2E2_2E2}{\*\bkmkend stylerid1_2E189_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Plates for exempt vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall furnish, on application, free of charge, distinguishing plates for motor vehicles exempted from annual registration fees and shall keep a separate record thereof.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74982; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5012.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.170}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a7106}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Exempt vehicles, see }{{\f5\fs12\hyphpar0\qj{\'a7321.18}}}{, }{{\f5\fs12\hyphpar0\qj{321.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.171}}}{\*\bkmkstart stylerid1_2E19_30_2E2_2E2}{\*\bkmkend stylerid1_2E19_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Title of plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All number plates issued shall be and remain the property of the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74983; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5012.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.171}}}{]}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.172 and 321.173}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E192_2E1_2E1}{DRIVER\u8217\'3fS LICENSES}{\*\bkmkend stylerid1_2E192_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.174}}}{\*\bkmkstart stylerid1_2E193_2E2_2E2}{\*\bkmkend stylerid1_2E193_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operators licensed \u8212\'3f operation of commercial motor vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, except those expressly exempted, shall not operate any motor vehicle upon a highway in this state unless the person has a driver\u8217\'3fs license issued by the department valid for the vehicle\u8217\'3fs operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a commercial motor vehicle shall not have more than one driver\u8217\'3fs license. A nonresident may operate a commercial motor vehicle in Iowa if the nonresident has been issued a license by another state, a nonresident commercial driver\u8217\'3fs license or nonresident commercial learner\u8217\'3fs permit, or a driver\u8217\'3fs license issued by a foreign jurisdiction which the federal highway administration has determined to be issued in conformity with the federal commercial driver testing and licensing standards, if the license, commercial driver\u8217\'3fs license, commercial learner\u8217\'3fs permit, or driver\u8217\'3fs license is valid for the vehicle operated.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who operates a commercial motor vehicle upon the highways of this state without having been issued a driver\u8217\'3fs license valid for the vehicle operated commits a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who operates a commercial motor vehicle upon the highways of this state after the person\u8217\'3fs commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit has been downgraded to a noncommercial status pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.207}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall have the licensee\u8217\'3fs driver\u8217\'3fs license in immediate possession at all times when operating a motor vehicle and shall display the same upon demand of a judicial magistrate, district associate judge, district judge, peace officer, or examiner of the department. If the licensee has been issued a commercial learner\u8217\'3fs permit, the licensee\u8217\'3fs driver\u8217\'3fs license includes both the licensee\u8217\'3fs commercial learner\u8217\'3fs permit and the licensee\u8217\'3fs underlying commercial or noncommercial driver\u8217\'3fs license. However, a person charged with violating }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be convicted and the citation shall be dismissed by the court if the person produces to the clerk of the district court, prior to the licensee\u8217\'3fs court date indicated on the citation, a driver\u8217\'3fs license issued to that person and valid for the vehicle operated at the time of the person\u8217\'3fs arrest or at the time the person was charged with a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Upon dismissal, the court or clerk of court shall assess the costs of the action against the defendant named on the citation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d2, -d29; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.01, 5013.15;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7321.174, 321.190; C77, 79, \'a7321.174, 321.189; }{{\f5\fs18\hyphpar0\qj{C81, \'a7321.174}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1120, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1144, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a748}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.176}}}{{\f5\fs12\hyphpar0\qj{, 321.515}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(4)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 4}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.174A}}}{\*\bkmkstart stylerid1_2E194_2E2_2E2}{\*\bkmkend stylerid1_2E194_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operation of motor vehicle with expired license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not operate a motor vehicle upon a highway in this state with an expired driver\u8217\'3fs license.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(4)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 4}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.175}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.176}}}{\*\bkmkstart stylerid1_2E196_2E2_2E2}{\*\bkmkend stylerid1_2E196_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons exempt from driver\u8217\'3fs licensing requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The following persons are exempt from driver\u8217\'3fs licensing requirements:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person while operating a military motor vehicle in the service of the armed forces of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person while operating a farm tractor or implement of husbandry to or from the home farm buildings to any adjacent or nearby farmland for the exclusive purpose of conducting farm operations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident operating a motor vehicle within the legal scope of the nonresident\u8217\'3fs home state or country license except a nonresident may operate a commercial motor vehicle only in compliance with }}}{{\f5\fs18\hyphpar0\qj{section 321.174}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d3, -d4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.176}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 105, \'a71, 2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.176A}}}{\*\bkmkstart stylerid1_2E197_2E2_2E2}{\*\bkmkend stylerid1_2E197_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons exempt from commercial driver\u8217\'3fs license requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The following operators are exempt from the commercial driver\u8217\'3fs license requirements:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A farmer or a person working for a farmer while operating a covered farm vehicle as defined in the }}}{{\f5\fs18\hyphpar0\qj{federal Moving Ahead for Progress in the 21st Century Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 112-141, \'a732934}}}{{\f5\fs18\hyphpar0\qj{. The exemption provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall apply to farmers who assist each other through an exchange of services and shall include operation of a commercial motor vehicle between the farms of the farmers who are exchanging services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fire fighter while operating a fire vehicle for a volunteer or paid fire organization or a peace officer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{, while operating a commercial motor vehicle for a law enforcement agency, under conditions necessary to preserve life or property or to execute related governmental functions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following persons when operating commercial motor vehicles for military purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Active duty military personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the military reserves.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the national guard on active duty, including personnel on full-time national guard duty, personnel on part-time national guard training, and national guard military technicians.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Active duty United States coast guard personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person while operating a motor home solely for personal or family use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a motor vehicle with a gross vehicle weight rating of less than twenty-six thousand one pounds towing a travel trailer or fifth-wheel travel trailer solely for personal or family use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A home care aide operating a motor vehicle in the course of the home care aide\u8217\'3fs duties.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 139, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 40, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.188}}}{{\f5\fs12\hyphpar0\qj{, 321.189}}}{{\f5\fs12\hyphpar0\qj{, 321.463}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.176B}}}{\*\bkmkstart stylerid1_2E198_2E2_2E2}{\*\bkmkend stylerid1_2E198_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restricted commercial driver\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall, upon application and payment of the required fee, issue a restricted commercial driver\u8217\'3fs license to a person who is employed in a designated farm-related service industry if the person qualifies for a restricted commercial driver\u8217\'3fs license under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.3(f)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person issued a restricted commercial driver\u8217\'3fs license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may operate a commercial motor vehicle to the fullest extent authorized under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.3(f)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 40, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.177}}}{\*\bkmkstart stylerid1_2E199_2E2_2E2}{\*\bkmkend stylerid1_2E199_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons not to be licensed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall not issue a driver\u8217\'3fs license:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any person who is under the age of eighteen years except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.180B}}}{{\f5\fs18\hyphpar0\qj{. However, the department may issue a driver\u8217\'3fs license to certain minors as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.178}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.194}}}{{\f5\fs18\hyphpar0\qj{, or a driver\u8217\'3fs license restricted to motorized bicycles as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.189}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any person holding any other driver\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any person whose driver\u8217\'3fs license or driving privilege is suspended or revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any person who is a chronic alcoholic, or is addicted to the use of an illegal narcotic drug.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any person who has previously been adjudged to be incompetent by reason of mental illness and who has not at the time of application been restored to competency by the methods provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any person who fails to pass an examination required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any person when the director has good cause to believe the person by reason of physical or mental disability would not be able to operate a motor vehicle safely.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any person to operate a commercial motor vehicle unless the person is eighteen years of age or older and the person qualifies under federal and state law to be issued a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any person, as a chauffeur, who is under the age of eighteen.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d5 \u8211\'3f 4960-d9; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.177}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 195, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 194, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1112, \'a71, 14, 16}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1030, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a749}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.180A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.178}}}{\*\bkmkstart stylerid1_2E2_30_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driver education \u8212\'3f restricted work license \u8212\'3f reciprocity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E2_30_30_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E2_30_30_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Approved course.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An approved driver education course as programmed by the department shall consist of at least thirty clock hours of classroom instruction, of which no more than one hundred eighty minutes shall be provided to a student in a single day, and six or more clock hours of laboratory instruction of which at least three clock hours shall consist of street or highway driving. Classroom instruction shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A minimum of four hours of instruction concerning substance use disorder and distracted driving.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A minimum of twenty minutes of instruction concerning railroad crossing safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instruction relating to becoming an organ donor under the revised uniform anatomical gift Act as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 142C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instruction providing an awareness about sharing the road with pedestrians, bicycles, and motorcycles. The instruction course shall be first approved by the state department of transportation. Instructional materials creating an awareness about sharing the road with pedestrians, bicycles, and motorcycles shall also be distributed during the course of instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be qualified as a classroom driver education instructor, a person shall have satisfied the educational requirements for a teaching license at the elementary or secondary level and hold a valid license to teach driver education in the public schools of this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be qualified to provide street or highway driving instruction, a person shall be certified by the department and authorized by the board of educational examiners. However, if the person is a peace officer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, with five or more years of experience as a peace officer, or a retired peace officer who holds a driver\u8217\'3fs license that is valid for more than two years from the date of issuance, the person shall not be required to be authorized by the board of educational examiners. A person shall not be required to hold a current Iowa teacher or administrator license at the elementary or secondary level or to have satisfied the educational requirements for an Iowa teacher license at the elementary or secondary level in order to be certified by the department or authorized by the board of educational examiners to provide street or highway driving instruction. For purposes of this subparagraph division, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fretired peace officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person retired under }}}{{\f5\fs18\hyphpar0\qj{chapter 97A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{411}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 97B.49B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{97B.49C}}}{{\f5\fs18\hyphpar0\qj{, after service as a peace officer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to provide for certification of persons qualified to provide street or highway driving instruction. The board of educational examiners shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to provide for authorization of persons certified by the department to provide street or highway driving instruction. The department may disqualify a person from providing street or highway driving instruction without concurrent or further action by the board of educational examiners, and the board of educational examiners may withhold or withdraw authorization to provide street or highway driving instruction without concurrent or further action by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not disqualify a person from providing street or highway driving instruction and the board of educational examiners shall not withhold or withdraw authorization to provide street or highway instruction for the sole reason that the person was involved in a motor vehicle accident, unless either of the following circumstances exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person contributed to the motor vehicle accident and the accident caused the death or serious injury of another person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person contributed to the motor vehicle accident and it was the person\u8217\'3fs second or subsequent contributive motor vehicle accident in a two-year period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who provides street or highway driving instruction shall hold a driver\u8217\'3fs license valid for the vehicle operated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every public school district in Iowa shall offer or make available to all students residing in the school district, or Iowa students attending a nonpublic school or receiving competent private instruction or independent private instruction as defined in }}}{{\f5\fs18\hyphpar0\qj{section 299A.1}}}{{\f5\fs18\hyphpar0\qj{, in the district, an approved course in driver education. The receiving district shall be the school district responsible for making driver education available to a student participating in open enrollment under }}}{{\f5\fs18\hyphpar0\qj{section 282.18}}}{{\f5\fs18\hyphpar0\qj{. The courses may be offered at sites other than at the public school, including nonpublic school facilities within the public school districts. An approved course offered during the summer months, on Saturdays, after regular school hours during the regular terms or partly in one term or summer vacation period and partly in the succeeding term or summer vacation period, as the case may be, shall satisfy the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the same extent as an approved course offered during the regular school hours of the school term. A student who successfully completes and obtains certification in an approved course in driver education or an approved course in motorcycle education may, upon proof of such fact, be excused from any field test which the student would otherwise be required to take in demonstrating the student\u8217\'3fs ability to operate a motor vehicle. A student shall not be excused from any field test if a parent, guardian, or instructor requests that a test be administered. A final field test prior to a student\u8217\'3fs completion of an approved course shall be administered by a person qualified to provide street or highway driving instruction under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2). }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fStudent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, means a person between the ages of fourteen years and twenty-one years who satisfies the preliminary licensing requirements of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who successfully completes an approved driver education course at a private or commercial driver education school licensed by the department shall likewise be eligible for a driver\u8217\'3fs license as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.180B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.194}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E2_30_30_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E2_30_30_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Restricted work license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person between sixteen and eighteen years of age who has completed an approved driver education course and is not in attendance at school and has not met the requirements described in }}}{{\f5\fs18\hyphpar0\qj{section 299.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, may be issued a restricted work license only for travel to and from work or to transport dependents to and from temporary care facilities, if necessary for the person to maintain the person\u8217\'3fs present employment. The restricted work license shall be issued by the department only upon confirmation of the person\u8217\'3fs employment and need for a restricted work license to travel to and from work or to transport dependents to and from temporary care facilities if necessary to maintain the person\u8217\'3fs employment. The employer shall notify the department if the employment of the person is terminated before the person attains the age of eighteen.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ The department may suspend a restricted work license issued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ upon receiving a record of the person\u8217\'3fs conviction for one violation and shall revoke the license upon receiving a record of conviction for two or more violations of a law of this state or a city ordinance regulating the operation of motor vehicles on highways, other than parking violations as described in }}}{{\f5\fs18\hyphpar0\qj{section 321.210}}}{{\f5\fs18\hyphpar0\qj{. After revoking a restricted work license under this paragraph, the department shall not grant an application for a new driver\u8217\'3fs license or instruction permit until the expiration of one year or until the person attains the age of eighteen, whichever is the longer period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E2_30_30_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E2_30_30_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Driver\u8217\'3fs license reciprocity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue a class C or M driver\u8217\'3fs license to a person who is sixteen or seventeen years of age and who is a current resident of the state, but who has been driving as a resident of another state for at least one year prior to residency within the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following criteria must be met prior to issuance of a driver\u8217\'3fs license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The minor must reside with a parent or guardian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The minor must have driven under a valid driver\u8217\'3fs license for at least one year in the prior state of residence. Six months of the one year computation may include driving with an instruction permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The minor must have had no moving traffic violations on the minor\u8217\'3fs driving record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The minor must pass the written and driving skills tests as required by the department, but is not required to have taken a driver education class.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, \'a7321.177; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.178}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1215, \'a71, 2}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1248, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1022, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1220, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 266, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 128, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a775}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1231, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1102, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1112, \'a72, 14, 16}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 33, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1140, \'a732, 33}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1021, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 44, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 214, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1075, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1105, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a728, 29}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a774}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 77, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 88, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 121, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 7, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71059}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1166, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 14, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.177}}}{{\f5\fs12\hyphpar0\qj{, 321.178A}}}{{\f5\fs12\hyphpar0\qj{, 321.180B}}}{{\f5\fs12\hyphpar0\qj{, 321.191}}}{{\f5\fs12\hyphpar0\qj{, 321.213B}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Driver education courses to include instruction relating to energy efficiency and safety; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/90/CH1252.pdf" }{\fldrslt \cf5 \f5 \fs12{{90 Acts, ch 1252, \'a754}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Department of health and human services to cooperate to provide materials and information relating to becoming an organ donor; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/94/CH1102.pdf" }{\fldrslt \cf5 \f5 \fs12{{94 Acts, ch 1102, \'a73}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 19, \'a71358}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.178A}}}{\*\bkmkstart stylerid1_2E2_301_2E2_2E2}{\*\bkmkend stylerid1_2E2_301_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driver education }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ teaching parent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E2_301_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E2_301_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Teaching parent.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As an alternative to the driver education requirements under }}}{{\f5\fs18\hyphpar0\qj{section 321.178}}}{{\f5\fs18\hyphpar0\qj{, a teaching parent may instruct a student in a driver education course that meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and provide evidence that the requirements under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ have been met.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E2_301_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E2_301_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fApproved course\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means driver education curriculum approved by the department pursuant to rules adopted under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. An approved course shall, at a minimum, meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ and be appropriate for teaching-parent-directed driver education and related street or highway instruction. Driver education materials that meet or exceed standards established by the department for an approved course in driver education for a public or private school shall be approved unless otherwise determined by the department. The list of approved courses shall be posted on the department\u8217\'3fs internet site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fStudent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person between the ages of fourteen and twenty-one years who is within the custody and control of the teaching parent and who satisfies preliminary licensing requirements of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTeaching parent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a parent, guardian, or legal custodian of a student who is meeting the attendance requirement of }}}{{\f5\fs18\hyphpar0\qj{section 299.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{; who has a valid driver\u8217\'3fs license, other than a motorized bicycle license or a temporary restricted license, that permits unaccompanied driving; and who has maintained a clear driving record for the previous two years. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fclear driving record\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the individual has not been identified as a candidate for suspension or revocation of a driver\u8217\'3fs license under the habitual violator or habitual offender provisions of the department\u8217\'3fs regulations; is not subject to a driver\u8217\'3fs license suspension, revocation, denial, cancellation, disqualification, or bar; and has no record of a conviction for a moving traffic violation determined to be the cause of a motor vehicle accident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E2_301_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E2_301_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Course of instruction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An approved course administered by a teaching parent shall consist of but not be limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Thirty hours of street or highway driving including three hours of driving after sunset and before sunrise while accompanied by a teaching parent or a person who is qualified to provide street or highway driving instruction pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.178}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instruction concerning substance use disorder and distracted driving.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instruction concerning railroad crossing safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instruction relating to becoming an organ donor under the revised uniform anatomical gift Act as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 142C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instruction providing an awareness about sharing the road with pedestrians, bicycles, and motorcycles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The content of the course of instruction required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be equivalent to that required under }}}{{\f5\fs18\hyphpar0\qj{section 321.178}}}{{\f5\fs18\hyphpar0\qj{. However, reference and study materials, physical classroom requirements, actual classroom hours and minutes, and extra vehicle safety equipment required for instruction under }}}{{\f5\fs18\hyphpar0\qj{section 321.178}}}{{\f5\fs18\hyphpar0\qj{ shall not be required for the course of instruction provided under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E2_301_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E2_301_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Course completion and certification.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application by a student for an intermediate license, the teaching parent shall provide evidence showing the student\u8217\'3fs completion of an approved course and substantial compliance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ by affidavit signed by the teaching parent on a form to be provided by the department. The evidence shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Documentation that the instructor is a teaching parent as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Documentation that the teaching parent is meeting the attendance requirement of }}}{{\f5\fs18\hyphpar0\qj{section 299.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the approved course completed by the student.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An affidavit attesting to satisfactory completion of course work and street or highway driving instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Copies of written tests completed by the student or lesser documentation as may be required by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement of the number of classroom hours of instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A log of completed street or highway driving instruction including the dates when the lessons were conducted, notes on driving activities including a list of driving deficiencies and improvements, and the duration of the driving time for each session.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E2_301_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E2_301_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Intermediate license.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any student who successfully completes an approved course as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, passes a driving test to be administered by the department, and is otherwise qualified under }}}{{\f5\fs18\hyphpar0\qj{section 321.180B, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be eligible for an intermediate license pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.180B}}}{{\f5\fs18\hyphpar0\qj{. Twenty of the thirty hours of street or highway driving instruction required under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), may be used to satisfy the requirement of }}}{{\f5\fs18\hyphpar0\qj{section 321.180B, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E2_301_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E2_301_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Full license.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A student must comply with }}}{{\f5\fs18\hyphpar0\qj{section 321.180B, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, to be eligible for a full driver\u8217\'3fs license pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.180B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E2_301_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E2_301_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Applicability.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to require a teaching parent to apply for or seek approval of the department separate from the course completion and certification requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 121, \'a7100}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 88, \'a710 \u8211\'3f 15}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 121, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71060}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.180B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.179}}}{\*\bkmkstart stylerid1_2E2_302_2E2_2E2}{\*\bkmkend stylerid1_2E2_302_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motorcycle rider education fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The motorcycle rider education fund is established in the office of the treasurer of state. The moneys credited to the fund are appropriated to the state department of transportation to be used to establish new motorcycle rider education courses and reimburse sponsors of motorcycle rider education courses for the costs of providing motorcycle rider education courses approved and established by the department. The department shall adopt rules under }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ providing for the distribution of moneys to sponsors of motorcycle rider education courses based upon the cost of providing the education courses.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1069, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.34}}}{{\f5\fs12\hyphpar0\qj{, 321.145}}}{{\f5\fs12\hyphpar0\qj{, 321.180B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.180}}}{\*\bkmkstart stylerid1_2E2_303_2E2_2E2}{\*\bkmkend stylerid1_2E2_303_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Instruction permits, commercial learner\u8217\'3fs permits, and chauffeur\u8217\'3fs instruction permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is at least eighteen years of age and who, except for the person\u8217\'3fs lack of instruction in operating a motor vehicle, would be qualified to obtain a driver\u8217\'3fs license, shall, upon meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.186}}}{{\f5\fs18\hyphpar0\qj{ other than a driving demonstration, and upon paying the required fee, be issued an instruction permit by the department. Subject to the limitations in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, an instruction permit entitles the permittee, while having the permit in the permittee\u8217\'3fs immediate possession, to operate a motor vehicle, other than a commercial motor vehicle or as a chauffeur or a motor vehicle with a gross vehicle weight rating of sixteen thousand one or more pounds, upon the highways for a period not to exceed four years from the licensee\u8217\'3fs birthday anniversary in the year of issuance. If the applicant for an instruction permit holds a driver\u8217\'3fs license issued in this state valid for the operation of a motorized bicycle or a motorcycle, the instruction permit shall be valid for such operation without the need of an accompanying person.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A permittee shall not be penalized for failing to have the instruction permit in immediate possession if the permittee produces in court, within a reasonable time, an instruction permit issued to the permittee and valid at the time of the permittee\u8217\'3fs arrest or at the time the permittee was charged with failure to have the permit in the permittee\u8217\'3fs immediate possession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided, a permittee who is eighteen years of age or older must be accompanied by a person issued a driver\u8217\'3fs license valid for the vehicle operated who is a member of the permittee\u8217\'3fs immediate family if the family member is at least twenty-one years of age, an approved driver education instructor, a prospective driver education instructor who is enrolled in a practitioner preparation program with a safety education program approved by the state board of education, or a person at least twenty-five years of age, and who is actually occupying a seat beside the driver.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, if the permittee is operating a motorcycle in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 321.180B}}}{{\f5\fs18\hyphpar0\qj{, the accompanying person must be within audible and visual communications distance from the permittee and be accompanying the permittee on or in a different motor vehicle. Only one permittee shall be under the immediate supervision of an accompanying qualified person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to administer commercial learner\u8217\'3fs permits in compliance with the procedures set forth in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.73}}}{{\f5\fs18\hyphpar0\qj{. An applicant for a commercial learner\u8217\'3fs permit must hold a valid class A, B, C, or D driver\u8217\'3fs license issued in this state, must be at least eighteen years of age, and must meet the qualifications to obtain a valid commercial driver\u8217\'3fs license, including the requirements set forth in }}}{{\f5\fs18\hyphpar0\qj{section 321.188}}}{{\f5\fs18\hyphpar0\qj{, except for the required driving skills test.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commercial learner\u8217\'3fs permit shall be a separate document from a commercial or noncommercial driver\u8217\'3fs license. A person operating a vehicle pursuant to a commercial learner\u8217\'3fs permit shall have both the commercial learner\u8217\'3fs permit and the commercial or noncommercial driver\u8217\'3fs license issued to the person within the person\u8217\'3fs possession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commercial learner\u8217\'3fs permit shall be valid for a period not to exceed the period provided in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.25(c)}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.73(a)(3)}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commercial learner\u8217\'3fs permit shall be valid for the operation of a commercial motor vehicle only when the permit holder is accompanied by a holder of a valid commercial driver\u8217\'3fs license with the proper commercial driver\u8217\'3fs license group designation and endorsements necessary to operate the commercial motor vehicle, and who is at all times physically present in the front passenger seat of the vehicle, or in the case of a passenger vehicle, directly behind or in the first row behind the permit holder in a position to directly observe and supervise the permit holder.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a commercial learner\u8217\'3fs permit is issued to the holder of a commercial driver\u8217\'3fs license, this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ only applies to the operation of a commercial motor vehicle for which the permit holder\u8217\'3fs commercial driver\u8217\'3fs license is not valid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a commercial learner\u8217\'3fs permit is issued to the holder of a noncommercial driver\u8217\'3fs license, this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ only applies to the operation of a commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance of a commercial learner\u8217\'3fs permit is a precondition to the initial issuance of a commercial driver\u8217\'3fs license. The issuance of a commercial learner\u8217\'3fs permit is also a precondition to the upgrade of a commercial driver\u8217\'3fs license if the upgrade requires a driving skills test. The holder of a commercial learner\u8217\'3fs permit is not eligible to take a driving skills test required by }}}{{\f5\fs18\hyphpar0\qj{section 321.188}}}{{\f5\fs18\hyphpar0\qj{ for the first fourteen days after the permit holder is issued the permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commercial learner\u8217\'3fs permit is not valid for the operation of a vehicle transporting hazardous materials as defined in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, upon meeting each of the following requirements, shall be eligible to apply for a chauffeur\u8217\'3fs instruction permit valid for the operation of a motor vehicle, other than a commercial motor vehicle, as a chauffeur when the permittee is accompanied by a person, possessing a valid class D driver\u8217\'3fs license or commercial driver\u8217\'3fs license valid for the operation of the motor vehicle and the accompanying person is actually occupying a seat beside the permittee. An applicant must be at least eighteen years of age, otherwise qualified to obtain a class D driver\u8217\'3fs license, and must meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.186}}}{{\f5\fs18\hyphpar0\qj{ other than a driving demonstration. The chauffeur\u8217\'3fs instruction permit shall be valid for a period not to exceed two years from the licensee\u8217\'3fs birthday anniversary in the year of issuance and shall be returned to the department upon issuance of a class D driver\u8217\'3fs license or commercial driver\u8217\'3fs license. If the applicant for a chauffeur\u8217\'3fs instruction permit holds a driver\u8217\'3fs license issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the chauffeur\u8217\'3fs instruction permit shall be valid in the same manner as the driver\u8217\'3fs license would be for the operation of motor vehicles without the need of an accompanying person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The instruction permit, chauffeur\u8217\'3fs instruction permit, and commercial learner\u8217\'3fs permit are subject to suspension or revocation for the same reasons and in the same manner as suspension or revocation of a driver\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motorcycle instruction permit issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not renewable.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d23; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.180}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1134, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1112, \'a73, 4, 14, 16}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a750, 51}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 149, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 126, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.196}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(4)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fee, }{{\f5\fs12\hyphpar0\qj{\'a7321.191}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 4}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.180A}}}{\*\bkmkstart stylerid1_2E2_304_2E2_2E2}{\*\bkmkend stylerid1_2E2_304_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special instruction permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a person with a physical disability, who is not suffering from a convulsive disorder and who can provide a favorable medical report, whose license renewal has been denied under }}}{{\f5\fs18\hyphpar0\qj{section 321.177, subsection 6 or 7}}}{{\f5\fs18\hyphpar0\qj{, or whose driver\u8217\'3fs license has been suspended under }}}{{\f5\fs18\hyphpar0\qj{section 321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), upon meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.186}}}{{\f5\fs18\hyphpar0\qj{, other than a driving demonstration or elimination of the person\u8217\'3fs limitations which caused the denial under }}}{{\f5\fs18\hyphpar0\qj{section 321.177, subsection 6 or 7}}}{{\f5\fs18\hyphpar0\qj{, or suspension under }}}{{\f5\fs18\hyphpar0\qj{section 321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), and upon paying the fee required in }}}{{\f5\fs18\hyphpar0\qj{section 321.191}}}{{\f5\fs18\hyphpar0\qj{, shall be issued a special instruction permit by the department. Upon issuance of the permit the denial or suspension shall be stayed and the stay shall remain in effect as long as the permit is valid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special instruction permit entitles the permittee, while having the permit in the permittee\u8217\'3fs immediate possession, to operate a noncommercial motor vehicle upon the highways for a period of six months from the date of issuance. However, the permittee must be accompanied by a person who is at least twenty-one years of age, who has been issued a driver\u8217\'3fs license valid for the vehicle being operated, and who is actually occupying a seat beside the permittee.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A permittee shall not be penalized for failing to have the permit in immediate possession if the permittee produces in court, within a reasonable time, the special instruction permit issued to the permittee which was valid at the time of the permittee\u8217\'3fs arrest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The permittee may apply for a driver\u8217\'3fs license if thirty days have elapsed since issuance of the special instruction permit. The department shall issue a driver\u8217\'3fs license if the permittee is qualified, passes all required tests, including a driving test, and pays the required fees. If the person has not obtained a driver\u8217\'3fs license before expiration of the person\u8217\'3fs special instruction permit, the person\u8217\'3fs former denial or suspension under }}}{{\f5\fs18\hyphpar0\qj{section 321.177, subsection 6 or 7}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), upon service of notice by the department, shall be reinstated. A permit shall be reissued for one additional six-month period if a permittee continues to meet the qualifications of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and has incurred no motor vehicle violations.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a778}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7170}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a775}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.180B}}}{\*\bkmkstart stylerid1_2E2_305_2E2_2E2}{\*\bkmkend stylerid1_2E2_305_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Graduated driver\u8217\'3fs licenses for persons aged fourteen through seventeen.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Persons under age eighteen shall not be issued a license or permit to operate a motor vehicle except under the provisions of }{{\f5\fs18\hyphpar0\qj{this section}}}{. However, the department may issue restricted work and special minor\u8217\'3fs restricted licenses to certain minors as provided in }{{\f5\fs18\hyphpar0\qj{sections 321.178}}}{ and }{{\f5\fs18\hyphpar0\qj{321.194}}}{, and driver\u8217\'3fs licenses restricted to motorized bicycles as provided in }{{\f5\fs18\hyphpar0\qj{section 321.189}}}{. A person shall not be issued a license or permit to operate a motor vehicle if prohibited under }{{\f5\fs18\hyphpar0\qj{section 321.194, subsection 7}}}{. A license or permit shall not be issued under }{{\f5\fs18\hyphpar0\qj{this section}}}{ or }{{\f5\fs18\hyphpar0\qj{section 321.178}}}{ or }{{\f5\fs18\hyphpar0\qj{321.194}}}{ without the consent of a parent or guardian or a person having custody of the applicant under }{{\f5\fs18\hyphpar0\qj{chapter 232}}}{ or }{{\f5\fs18\hyphpar0\qj{600A}}}{. An additional consent is required each time a license or permit is issued under }{{\f5\fs18\hyphpar0\qj{this section}}}{ or }{{\f5\fs18\hyphpar0\qj{section 321.178}}}{ or }{{\f5\fs18\hyphpar0\qj{321.194}}}{. The consent must be signed by at least one parent, guardian, or custodian on an affidavit form provided by the department.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E2_305_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E2_305_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Instruction permit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue an instruction permit to an applicant between the ages of fourteen and eighteen years if the applicant meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 321.184}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.186}}}{{\f5\fs18\hyphpar0\qj{, other than a driving demonstration, and pays the required fee. An instruction permit issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be valid for a period not to exceed four years from the licensee\u8217\'3fs birthday anniversary in the year of issuance. A motorcycle instruction permit issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not renewable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the limitations in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, an instruction permit entitles the permittee, while having the permit in the permittee\u8217\'3fs immediate possession, to operate a motor vehicle other than a commercial motor vehicle or as a chauffeur or a motor vehicle with a gross vehicle weight rating of sixteen thousand one or more pounds upon the highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided, a permittee who is less than eighteen years of age and who is operating a motor vehicle must be accompanied by a person issued a driver\u8217\'3fs license valid for the vehicle operated who is the parent, guardian, or custodian of the permittee, a member of the permittee\u8217\'3fs immediate family if the family member is at least twenty-one years of age, an approved driver education instructor, a prospective driver education instructor who is enrolled in a practitioner preparation program with a safety education program approved by the state board of education, or a person at least twenty-five years of age if written permission is granted by the parent, guardian, or custodian, and who is actually occupying a seat beside the driver. A permittee shall not operate a motor vehicle if the number of passengers in the motor vehicle exceeds the number of passenger safety belts in the motor vehicle. If the applicant for an instruction permit holds a driver\u8217\'3fs license issued in this state valid for the operation of a motorized bicycle or a motorcycle, the instruction permit shall be valid for such operation without the requirement of an accompanying person.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ If the permittee is operating a motorcycle in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the accompanying person must be within audible and visual communications distance from the permittee and be accompanying the permittee on or in a different motor vehicle. Only one permittee shall be under the immediate supervision of an accompanying qualified person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A permittee shall not be penalized for failing to have the instruction permit in the permittee\u8217\'3fs immediate possession if the permittee produces in court, within a reasonable time, an instruction permit issued to the permittee and valid at the time of the permittee\u8217\'3fs arrest or at the time the permittee was charged with failure to have the permit in the permittee\u8217\'3fs immediate possession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E2_305_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E2_305_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Intermediate license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue an intermediate driver\u8217\'3fs license to a person sixteen or seventeen years of age who possesses an instruction permit issued under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ or a comparable instruction permit issued by another state for a minimum of twelve months immediately preceding application, and who presents an affidavit signed by a parent, guardian, or custodian on a form to be provided by the department that the permittee has accumulated a total of twenty hours of street or highway driving of which two hours were conducted after sunset and before sunrise and the street or highway driving was with the permittee\u8217\'3fs parent, guardian, custodian, instructor, a person certified by the department, or a person at least twenty-five years of age who had written permission from a parent, guardian, or custodian to accompany the permittee, and whose driving privileges have not been suspended, revoked, or barred under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ during, and who has been accident and violation free continuously for, the six-month period immediately preceding the application for an intermediate license. An applicant for an intermediate license must meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.186}}}{{\f5\fs18\hyphpar0\qj{, including satisfactory completion of driver education as required in }}}{{\f5\fs18\hyphpar0\qj{section 321.178}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.178A}}}{{\f5\fs18\hyphpar0\qj{, and payment of the required license fee before an intermediate license will be issued. A person issued an intermediate license must limit the number of passengers in the motor vehicle when the intermediate licensee is operating the motor vehicle to the number of passenger safety belts. In addition, unless waived by the person\u8217\'3fs parent or guardian at the time the intermediate license is issued, for the first six months following issuance of the license, a person issued an intermediate license must limit the number of unrelated minor passengers in the motor vehicle when the intermediate licensee is operating the motor vehicle to one, except when the intermediate licensee is accompanied in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3funrelated minor passenger\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a passenger who is under eighteen years of age and who is not a sibling of the driver, a stepsibling of the driver, or a child who resides in the same household as the driver. The department shall prescribe the form for waiver of the six-month restriction on unrelated minor passengers, which may be in an electronic format, and shall designate characteristics for the intermediate license that shall distinguish between an intermediate license that includes the six-month restriction on unrelated minor passengers and an intermediate license that does not include the six-month restriction on unrelated minor passengers. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided, a person issued an intermediate license under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ who is operating a motor vehicle between the hours of 12:30 a.m. and 5:00 a.m. must be accompanied by a person issued a driver\u8217\'3fs license valid for the vehicle operated who is the parent, guardian, or custodian of the intermediate licensee, a member of the intermediate licensee\u8217\'3fs immediate family if the family member is at least twenty-one years of age, an approved driver education instructor, a prospective driver education instructor who is enrolled in a practitioner preparation program with a safety education program approved by the state board of education, or a person at least twenty-five years of age if written permission is granted by the parent, guardian, or custodian, and who is actually occupying a seat beside the driver. However, a licensee may operate a vehicle to and from school-related extracurricular activities and work without an accompanying driver between the hours of 12:30 a.m. and 5:00 a.m. if the licensee possesses a waiver on a form to be provided by the department. An accompanying driver is not required between the hours of 5:00 a.m. and 12:30 a.m.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E2_305_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E2_305_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Remedial driver improvement action }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ suspension of permit, intermediate license, or full license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has been issued an instruction permit, an intermediate license, or a full driver\u8217\'3fs license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, upon conviction of a moving traffic violation or involvement in a motor vehicle accident which occurred during the term of the instruction permit or intermediate license, shall be subject to remedial driver improvement action or suspension of the permit or current license. A person possessing an instruction permit who has been convicted of a moving traffic violation or has been involved in an accident shall not be issued an intermediate license until the person has completed the remedial driver improvement action and has been accident and violation free continuously for the six-month period immediately preceding the application for the intermediate license. A person possessing an intermediate license who has been convicted of a moving traffic violation or has been involved in an accident shall not be issued a full driver\u8217\'3fs license until the person has completed the remedial driver improvement action and has been accident and violation free continuously for the twelve-month period immediately preceding the application for a full driver\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may suspend an instruction permit, intermediate license, or full license issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ upon receiving satisfactory evidence that the person issued the instruction permit, intermediate license, or full license violated the restrictions imposed under }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{ during the term of the instruction permit or intermediate license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E2_305_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E2_305_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Full driver\u8217\'3fs license.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A full driver\u8217\'3fs license may be issued to a person seventeen years of age who possesses an intermediate license issued under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ or a comparable intermediate license issued by another state for a minimum of twelve months immediately preceding application, and who presents an affidavit signed by a parent, guardian, or custodian on a form to be provided by the department that the intermediate licensee has accumulated a total of ten hours of street or highway driving of which two hours were conducted after sunset and before sunrise and the street or highway driving was with the licensee\u8217\'3fs parent, guardian, custodian, instructor, a person certified by the department, or a person at least twenty-five years of age who had written permission from a parent, guardian, or custodian to accompany the licensee, whose driving privileges have not been suspended, revoked, or barred under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ during, and who has been accident and violation free continuously for, the twelve-month period immediately preceding the application for a full driver\u8217\'3fs license, and who has paid the required fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E2_305_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E2_305_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Class M license education requirements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under the age of eighteen applying for an intermediate or full driver\u8217\'3fs license valid for the operation of a motorcycle shall be required to successfully complete a motorcycle education course either approved and established by the department of transportation or from a private or commercial driver education school licensed by the department of transportation before the class M license will be issued. A public school district shall charge a student a fee which shall not exceed the actual cost of instruction minus moneys received by the school district under }}}{{\f5\fs18\hyphpar0\qj{ section 321.179}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E2_305_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E2_305_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Citations for violation of restrictions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates the restrictions imposed under }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{ may be issued a citation under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and shall not be issued a citation under }}}{{\f5\fs18\hyphpar0\qj{section 321.193}}}{{\f5\fs18\hyphpar0\qj{. A violation of the restrictions imposed under }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered a moving violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E2_305_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E2_305_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rules.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1112, \'a75, 14, 16}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a712, 13}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 128, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a722 \u8211\'3f 24}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a72 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1105, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a79 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 80, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a778}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a7101}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1166, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 14, \'a73 \u8211\'3f 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.177}}}{{\f5\fs12\hyphpar0\qj{, 321.178}}}{{\f5\fs12\hyphpar0\qj{, 321.178A}}}{{\f5\fs12\hyphpar0\qj{, 321.180}}}{{\f5\fs12\hyphpar0\qj{, 321.189}}}{{\f5\fs12\hyphpar0\qj{, 321.194}}}{{\f5\fs12\hyphpar0\qj{, 321.196}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(4)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 4}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph b amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 6 stricken}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Former subsection 7 amended and renumbered as 6}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Former subsection 8 renumbered as 7}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.181}}}{\*\bkmkstart stylerid1_2E2_306_2E2_2E2}{\*\bkmkend stylerid1_2E2_306_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Temporary permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may issue a temporary permit to an applicant for a driver\u8217\'3fs license permitting the applicant to operate a motor vehicle while the department is completing its investigation and determination of all facts relative to the applicant\u8217\'3fs privilege to receive the driver\u8217\'3fs license. The permit must be in the applicant\u8217\'3fs immediate possession while operating a motor vehicle. The temporary permit shall be invalid and returned to the department when the applicant\u8217\'3fs license is issued or when the license is denied.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.181}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a728}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1152, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.190}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.182}}}{\*\bkmkstart stylerid1_2E2_307_2E2_2E2}{\*\bkmkend stylerid1_2E2_307_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every applicant for a driver\u8217\'3fs license shall do all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make application on a form provided by the department which shall include the applicant\u8217\'3fs full name, signature, current mailing address, current residential address, date of birth, social security number, and physical description including sex, height, and eye color. The application may contain other information the department may require by rule. Pursuant to procedures established by the department and for an applicant who is a foreign national temporarily present in this state, the department may waive the requirement that the application include the applicant\u8217\'3fs social security number.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee shall notify the department when the licensee\u8217\'3fs mailing address changes and provide the new address within thirty days of obtaining the new address. The application provided by the department shall include a statement for the applicant to sign that acknowledges the applicant\u8217\'3fs knowledge of the requirement to notify the department of a mailing address change. The penalty under }}}{{\f5\fs18\hyphpar0\qj{section 321.482}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a licensee\u8217\'3fs failure to notify the department of such an address change.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Surrender all other driver\u8217\'3fs licenses and nonoperator\u8217\'3fs identification cards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certify that the applicant has no other driver\u8217\'3fs license and certify that the applicant is a resident of this state as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.1A}}}{{\f5\fs18\hyphpar0\qj{. However, certification of residency is not required for an applicant for a nonresident commercial driver\u8217\'3fs license or nonresident commercial learner\u8217\'3fs permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certify that the applicant is not currently subject to suspension, revocation, or cancellation of any driver\u8217\'3fs license and has committed no offense and has not acted in a manner which either alone or with previous actions or offenses could result in suspension, revocation, or cancellation of any driver\u8217\'3fs license.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d12; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.182}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a723, 55}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a752}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.188}}}{{\f5\fs12\hyphpar0\qj{, 321.190}}}{{\f5\fs12\hyphpar0\qj{, 321.196}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Voter registration, see }{{\f5\fs12\hyphpar0\qj{\'a748A.18}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.183}}}{\*\bkmkstart stylerid1_2E2_308_2E2_2E2}{\*\bkmkend stylerid1_2E2_308_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application for driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card \u8212\'3f selective service registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who applies for a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card or for renewal of a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card, and who is required by 50 U.S.C. app. \'a7451 et seq. to register with the United States selective service system, shall be registered by the department with the selective service system. The department shall forward to the selective service system in an electronic format the necessary personal information of such applicant, notwithstanding provisions to the contrary in }}}{{\f5\fs18\hyphpar0\qj{section 321.11, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant\u8217\'3fs submission of an application for a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card or for renewal of a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card shall indicate that the applicant has already registered with the selective service system or that the applicant authorizes the department to forward the applicant\u8217\'3fs personal information to the selective service system for registration. The department shall notify the applicant on the application that submission of the application shall serve as consent to registration with the selective service system, if the applicant is required by 50 U.S.C. app. \'a7451 et seq. to register.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, an applicant for a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card or for renewal of a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card who is required to register with the United States selective service system shall not be registered by the department if, after being given information on the penalties for failure to register, the applicant declines to be registered. The department shall forward to the selective service system in an electronic format the applicable personal information of such applicant indicating the applicant refused to be registered.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 41, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.190}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.184}}}{\*\bkmkstart stylerid1_2E2_309_2E2_2E2}{\*\bkmkend stylerid1_2E2_309_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applications of unmarried minors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E2_309_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E2_309_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Consent required.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application of an unmarried person under the age of eighteen years for a driver\u8217\'3fs license shall contain the verified consent and confirmation of the applicant\u8217\'3fs birthday by either parent of the applicant, the guardian of the applicant, or a person having custody of the applicant under }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{600A}}}{{\f5\fs18\hyphpar0\qj{. Officers and employees of the department may administer the oaths without charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E2_309_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E2_309_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Withdrawal of consent.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person who provided the signed consent under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ may withdraw that consent at any time. The withdrawal of consent shall be in writing, signed and verified. The department, upon receipt of the withdrawal of consent, shall cancel the applicant\u8217\'3fs driver\u8217\'3fs license and shall not issue a new license until such time as a new application, duly signed and verified, is made as required in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply if the licensee or permittee has attained the age of eighteen years or is married.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d13; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.184}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1248, \'a72}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a723}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1048, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 130, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.180B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.185}}}{\*\bkmkstart stylerid1_2E21_30_2E2_2E2}{\*\bkmkend stylerid1_2E21_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Death of person signing application \u8212\'3f effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department upon receipt of satisfactory evidence of the death of the persons who signed the application of a minor for a license shall cancel such license and shall not issue a new license until such time as a new application, duly signed and verified, is made as required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. This provision shall not apply in the event the minor has attained the age of eighteen years.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.185}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.186}}}{\*\bkmkstart stylerid1_2E211_2E2_2E2}{\*\bkmkend stylerid1_2E211_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Examination of new or incompetent operators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may examine every new applicant for a driver\u8217\'3fs license or any person holding a valid driver\u8217\'3fs license when the department has reason to believe that the person may be physically or mentally incompetent to operate a motor vehicle, or whose driving record appears to the department to justify the examination. The department shall make every effort to accommodate a functionally illiterate applicant when the applicant is taking a knowledge test. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The examination shall include a screening of the applicant\u8217\'3fs eyesight, a test of the applicant\u8217\'3fs ability to read and understand highway signs regulating, warning, and directing traffic, a test of the applicant\u8217\'3fs knowledge of the traffic laws of this state, an actual demonstration of ability to exercise ordinary and reasonable control in the operation of a motor vehicle, and other physical and mental examinations as the department finds necessary to determine the applicant\u8217\'3fs fitness to operate a motor vehicle safely upon the highways. However, an applicant for a new driver\u8217\'3fs license need not pass a vision test administered by the department if the applicant files with the department a vision report in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.186A}}}{{\f5\fs18\hyphpar0\qj{ which shows that the applicant\u8217\'3fs visual acuity level meets or exceeds those required by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physician licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{, an advanced registered nurse practitioner licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{, a physician assistant licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{, or an optometrist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154}}}{{\f5\fs18\hyphpar0\qj{ may report to the department the identity of a person who has been diagnosed as having a physical or mental condition which would render the person physically or mentally incompetent to operate a motor vehicle in a safe manner. The physician, advanced registered nurse practitioner, physician assistant, or optometrist shall make reasonable efforts to notify the person who is the subject of the report, in writing. The written notification shall state the nature of the disclosure and the reason for the disclosure. A physician, advanced registered nurse practitioner, physician assistant, or optometrist making a report under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be immune from any liability, civil or criminal, which might otherwise be incurred or imposed as a result of the report. A physician, advanced registered nurse practitioner, physician assistant, or optometrist has no duty to make a report or to warn third parties with regard to any knowledge concerning a person\u8217\'3fs mental or physical competency to operate a motor vehicle in a safe manner. Any report received by the department from a physician, advanced registered nurse practitioner, physician assistant, or optometrist under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be kept confidential. Information regulated by }}}{{\f5\fs18\hyphpar0\qj{chapter 141A}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to the confidentiality provisions and remedies of that chapter.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d14; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.186}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1029, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 181, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1032, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7119}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 5, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 56, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 135, \'a72, 3, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.180}}}{{\f5\fs12\hyphpar0\qj{, 321.180A}}}{{\f5\fs12\hyphpar0\qj{, 321.180B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.186A}}}{\*\bkmkstart stylerid1_2E212_2E2_2E2}{\*\bkmkend stylerid1_2E212_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vision report in lieu of vision test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a new or renewed driver\u8217\'3fs license need not take a vision test administered by the department if the applicant files with the department a vision report signed by a licensed vision specialist in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for such a new or renewed driver\u8217\'3fs license who fails a vision test administered by the department may subsequently be issued the driver\u8217\'3fs license without need of passing a department administered vision test, if the applicant files with the department a vision report from a licensed vision specialist in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vision report shall state the visual acuity level of the applicant as measured by the vision specialist and shall be in the form and include other information as required by rule of the department. A vision report is valid only if the visual acuity level of the applicant has been measured by the licensed vision specialist within thirty days before the application for the new or renewed driver\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flicensed vision specialist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a physician licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or an optometrist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.186}}}{{\f5\fs12\hyphpar0\qj{, 321.189}}}{{\f5\fs12\hyphpar0\qj{, 321.196}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.187}}}{\*\bkmkstart stylerid1_2E213_2E2_2E2}{\*\bkmkend stylerid1_2E213_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Examiners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall examine applicants for driver\u8217\'3fs licenses. Examiners of the department shall wear an identifying badge and uniform provided by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may by rule designate community colleges established under }}}{{\f5\fs18\hyphpar0\qj{chapter 260C}}}{{\f5\fs18\hyphpar0\qj{ and other third-party testers to administer the knowledge and driving skills tests required for a commercial learner\u8217\'3fs permit or commercial driver\u8217\'3fs license, provided all of the following occur:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The test is the same as that which would otherwise be administered by the state. The fees for administering a commercial driver\u8217\'3fs license driving skills test as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.187A}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321M.6A}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a driving skills test administered by a third-party tester under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The third-party tester contractually agrees to comply with the requirements of 49 C.F.R. }}}{{\f5\fs18\hyphpar0\qj\cf1{pts. 383}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj\cf1{384}}}{{\f5\fs18\hyphpar0\qj{ applicable to third-party knowledge and driving skills testing, as adopted by rule by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any third-party test examiner used by the third-party tester shall comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pts. 383}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj\cf1{384}}}{{\f5\fs18\hyphpar0\qj{ applicable to third-party knowledge and driving skills testing, as adopted by rule by the department. The department shall adopt rules regarding who may qualify as a third-party tester. The department may adopt rules doing any of the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requiring a third-party tester to conduct a number of skills test examinations above the number required under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.75}}}{{\f5\fs18\hyphpar0\qj{ in order to remain qualified as a third-party tester under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Restricting the testing scope of a third-party tester.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fThird-party test examiner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person employed by a third-party tester who is authorized by the department to administer the knowledge and driving skills tests under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fThird-party tester\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person designated by the department to employ knowledge and driving skills test examiners to administer knowledge and driving skills tests under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d17; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.187}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 96, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a713, 25}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 41, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7146}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 135, \'a74, 8}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1124, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 14, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.187A}}}{\*\bkmkstart stylerid1_2E214_2E2_2E2}{\*\bkmkend stylerid1_2E214_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commercial driver\u8217\'3fs license driving skills tests }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall make every effort to accommodate a commercial driver\u8217\'3fs license applicant\u8217\'3fs need to arrange an appointment for a driving skills test at an established test site other than where the applicant passed the required knowledge test. The department shall report to the governor and the general assembly on any problems, extraordinary costs, and recommendations regarding the appointment scheduling process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall make every effort to have an examiner conduct the commercial driver\u8217\'3fs license driving skills tests at other locations in this state where skills may be adequately tested when requested by a person representing ten or more drivers requiring driving skills testing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driving skills test for a commercial driver\u8217\'3fs license shall consist of three parts that must be completed in the following order:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pre-trip vehicle inspection test.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The basic vehicle control skills test.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The on-road driving skills test. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant fails one part of the test, the applicant shall not continue to the next part of the test, in accordance with }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 383, subpts. E, G, and H}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may charge a scheduling fee not to exceed twenty-five dollars to a commercial driver\u8217\'3fs license applicant for the pre-trip vehicle inspection test. The department shall not charge a fee to schedule or administer the basic vehicle control or on-road driving skills tests. The department shall not charge a fee under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to an applicant who is an employee or volunteer of a government agency, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 553.3}}}{{\f5\fs18\hyphpar0\qj{, and who provides reasonable proof that a commercial driver\u8217\'3fs license is necessary for the applicant\u8217\'3fs employment or volunteer duties for the government agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fees authorized under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are nonrefundable. If the applicant fails to appear for the pre-trip vehicle inspection test, the appointment shall be canceled. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit an applicant from scheduling a new test appointment upon payment of a new fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All fees authorized in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are in addition to any other fees imposed by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall remit all fees collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ monthly to the treasurer of state for deposit in the statutory allocations fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 135, \'a75, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.145}}}{{\f5\fs12\hyphpar0\qj{, 321.187}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.188}}}{\*\bkmkstart stylerid1_2E215_2E2_2E2}{\*\bkmkend stylerid1_2E215_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commercial driver\u8217\'3fs license requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to administer commercial driver\u8217\'3fs licenses in compliance with the procedures set forth in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.73}}}{{\f5\fs18\hyphpar0\qj{. Before the department issues, renews, or upgrades a commercial driver\u8217\'3fs license and in addition to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.182}}}{{\f5\fs18\hyphpar0\qj{, the license applicant shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certify whether the applicant is subject to and meets applicable driver qualifications of }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 391}}}{{\f5\fs18\hyphpar0\qj{ as adopted by rule by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certify the applicant is not subject to any commercial driver\u8217\'3fs license disqualification and has committed no offense and has not acted in a manner which either alone or with previous actions or offenses could result in commercial driver\u8217\'3fs license disqualification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Successfully complete any entry-level driver training if required under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 380, subpt. F}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 383, subpt. E}}}{{\f5\fs18\hyphpar0\qj{, prior to taking a knowledge test or driving skills test, the passage of which is required under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Successfully pass knowledge tests and driving skills tests, provide self-certification of type of driving, provide a medical examiner\u8217\'3fs certificate prepared by a medical examiner, as defined in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7390.5}}}{{\f5\fs18\hyphpar0\qj{, and provide all other required information, proofs, and certificates, as required by rule by the department. The rules adopted shall substantially comply with the federal minimum testing and licensing requirements in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 383, subpts. E, G, and H,}}}{{\f5\fs18\hyphpar0\qj{ as adopted by rule by the department. Except as required under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 383, subpt. E, G, or H}}}{{\f5\fs18\hyphpar0\qj{, a commercial driver\u8217\'3fs license is renewable without a knowledge test or driving skills test within one year after its expiration date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certify the vehicle to be operated in the driving skills tests is representative of the class of motor vehicle the applicant will operate on the highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certify that the applicant is a resident of Iowa or a resident of a foreign jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identify all states where the applicant has been licensed to drive any type of motor vehicle during the previous ten years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a commercial driver\u8217\'3fs license may substitute for a driving skills test the applicant\u8217\'3fs operating record and previous passage of a driving skills test or the applicant\u8217\'3fs operating record and previous driving experience if all of the following conditions exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is currently licensed to operate a commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant certifies that during the two years immediately preceding application all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not held driver\u8217\'3fs licenses valid for the operation of commercial motor vehicles from more than one state simultaneously.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not had any convictions which are federal commercial driver\u8217\'3fs license disqualifying offenses under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.51}}}{{\f5\fs18\hyphpar0\qj{ as adopted by rule by the department while operating any type of vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not committed a traffic violation, other than a parking violation, arising in connection with a traffic accident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No record of an accident exists for which the applicant was convicted of a moving traffic violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not had any driver\u8217\'3fs license suspended, revoked, or canceled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant provides evidence of and certifies that the applicant is employed in a job requiring operation of a commercial motor vehicle and the applicant has done one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has previously passed a driving skills test given by this state or its designee in a motor vehicle representative of the class of motor vehicle the applicant will operate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has operated during the two-year period immediately preceding the application a motor vehicle representative of the class of motor vehicle the applicant will operate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a hazardous material endorsement must pass a knowledge test as required under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.121}}}{{\f5\fs18\hyphpar0\qj{ as adopted by rule by the department to obtain or retain the endorsement. However, an applicant for license issuance who was previously issued a commercial driver\u8217\'3fs license from another state may retain the hazardous material endorsement from the previously issued license if the applicant successfully passed the endorsement test within the preceding twenty-four months. Pursuant to procedures established by the department, an applicant for a hazardous material endorsement must also comply with the application and security threat assessment requirements established under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 383}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj\cf1{384}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj\cf1{1572}}}{{\f5\fs18\hyphpar0\qj{. A hazardous material endorsement shall be revoked or denied if the department determines that the applicant has not complied with or met the security threat assessment standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall check the applicant\u8217\'3fs driving record as maintained by the applicant\u8217\'3fs current licensing state, the national commercial driver\u8217\'3fs license information system, and the national driver register to determine whether the applicant qualifies for the issuance, renewal, or upgrade of a commercial driver\u8217\'3fs license, as applicable. The department shall notify the national commercial driver\u8217\'3fs license information system of the issuance, renewal, or upgrade of a commercial driver\u8217\'3fs license and shall post the driver\u8217\'3fs self-certification of type of driving as required by rule. The department shall also post information from the medical examiner\u8217\'3fs certificate required under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to the national commercial driver\u8217\'3fs license information system, if required by rule.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall request information from the national drug and alcohol clearinghouse if required under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.73}}}{{\f5\fs18\hyphpar0\qj{ and shall not issue, renew, or upgrade the commercial driver\u8217\'3fs license if the response indicates the applicant is prohibited from operating a commercial motor vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7382.501(a)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident of this state holding a commercial driver\u8217\'3fs license issued by a former state of residence in conformity with the federal commercial driver testing and licensing standards shall not be required to take a knowledge or driving skills test prior to issuance of a commercial driver\u8217\'3fs license in this state, except a basic Iowa rules of the road knowledge test and, when applicable, motorcycle operator knowledge and driving skills tests. The commercial driver\u8217\'3fs license issued by this state shall be valid for operation of the same class of vehicles with the same endorsements and restrictions as in the former state of licensure. However, a person with a hazardous materials endorsement must comply with }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may waive the requirement that an applicant pass a driving skills test specified in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for an applicant who is on active duty in the military service, or who has separated from such service in the past year, who certifies that during the two-year period immediately preceding application for a commercial driver\u8217\'3fs license, all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not had more than one driver\u8217\'3fs license, other than a military license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not had any driver\u8217\'3fs license suspended, revoked, or canceled.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not been convicted of an offense committed while operating any type of motor vehicle that is listed as a disqualifying offense in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.51(b)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not had more than one conviction for an offense committed while operating any type of motor vehicle that is listed as a serious traffic violation in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.51(c)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has not had a conviction for a violation of a military, state, or local law relating to motor vehicle traffic control, other than a parking violation, arising in connection with any traffic accident and has no record of a traffic accident in which the applicant was at fault.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a waiver of the driving skills test under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall certify and provide evidence as required by the department that the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is regularly employed or was regularly employed within the past year in a military position requiring operation of a commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant was exempt from commercial driver licensing requirements pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.176A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or a comparable law of another state implementing }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.3(c)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant was operating a motor vehicle representative of the class of motor vehicle the applicant operates or expects to operate for at least two years immediately preceding honorable separation from military service as evidenced by the person\u8217\'3fs certificate of release or discharge from active duty, commonly referred to as a DD214.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant who obtains a driving skills test waiver under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall take and successfully pass the knowledge test required pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 96, \'a730 \u8211\'3f 32}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a728, 35}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1058, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 41, \'a72, 3, 6, 7}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 31, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 126, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.180}}}{{\f5\fs12\hyphpar0\qj{, 321.196}}}{{\f5\fs12\hyphpar0\qj{, 321.207}}}{{\f5\fs12\hyphpar0\qj{, 321.376}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.189}}}{\*\bkmkstart stylerid1_2E216_2E2_2E2}{\*\bkmkend stylerid1_2E216_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driver\u8217\'3fs license \u8212\'3f content.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E216_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Classification and issuance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon payment of the required fee, the department shall issue to every qualified applicant a driver\u8217\'3fs license. Driver\u8217\'3fs licenses shall be classified as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class A \u8212\'3f Valid for the operation of vehicles with a gross combination weight rating of twenty-six thousand one or more pounds if the towed vehicle or vehicles have a gross vehicle weight rating or gross combination weight rating of ten thousand one or more pounds, and also valid for the operation of vehicles with lower gross combination weight ratings and other vehicles except motorcycles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class B \u8212\'3f Valid for the operation of a vehicle with a gross vehicle weight rating of twenty-six thousand one or more pounds or a combination of vehicles with a gross combination weight rating of twenty-six thousand one or more pounds if the towing vehicle has a gross vehicle weight rating of twenty-six thousand one or more pounds and the towed vehicle or vehicles have a gross vehicle weight rating or gross combination weight rating of less than ten thousand one pounds, and also valid for the operation of vehicles with lower gross vehicle weight ratings or gross combination weight ratings except motorcycles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class C \u8212\'3f Valid for the operation of a vehicle, other than a motorcycle, or a combination of vehicles with a gross combination weight rating of twenty-six thousand one or more pounds provided the towing vehicle has a gross vehicle weight rating of less than twenty-six thousand one pounds and each towed vehicle has a gross vehicle weight rating of less than ten thousand one pounds, or a combination of vehicles with a gross vehicle weight rating or gross combination weight rating of less than twenty-six thousand one pounds and also valid for the operation of any vehicle, other than a motorcycle, for which the operator is exempt from commercial driver\u8217\'3fs license requirements under }}}{{\f5\fs18\hyphpar0\qj{section 321.176A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class D \u8212\'3f Valid for the operation of a motor vehicle as a chauffeur.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class M \u8212\'3f Valid for the operation of a motorcycle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A driver\u8217\'3fs license may be issued for more than one class. Class A and B driver\u8217\'3fs licenses shall only be issued as commercial driver\u8217\'3fs licenses. Class C and M driver\u8217\'3fs licenses may be issued as commercial driver\u8217\'3fs licenses. A driver\u8217\'3fs license is not valid for the operation of a vehicle requiring an endorsement unless the driver\u8217\'3fs license is endorsed for the vehicle. A class D driver\u8217\'3fs license is also valid as a noncommercial class C driver\u8217\'3fs license. The holder of a commercial driver\u8217\'3fs license is not required to obtain a class D driver\u8217\'3fs license to operate a motor vehicle as a chauffeur. When necessary, the department shall by rule create additional classes or modify existing classes of driver\u8217\'3fs licenses, however, the rule shall be temporary and if within sixty days after the next regular session of the general assembly convenes the general assembly has not made corresponding changes in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the temporary classification or modification shall be nullified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E216_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Content of license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appearing on the driver\u8217\'3fs license shall be a distinguishing number assigned to the licensee; the licensee\u8217\'3fs full name, date of birth, sex, and residence address; a color photograph; a physical description of the licensee; the name of the state; the dates of issuance and expiration; and the usual signature of the licensee. The license shall identify the class of vehicle the licensee may operate and the applicable endorsements and restrictions which the department shall require by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A commercial driver\u8217\'3fs license shall include the licensee\u8217\'3fs address as required under federal regulations, and the words \u8220\'3fcommercial driver\u8217\'3fs license\u8221\'3f or \u8220\'3fCDL\u8221\'3f shall appear prominently on the face of the license. A commercial learner\u8217\'3fs permit shall include the permit holder\u8217\'3fs address as required under federal regulations, and the words \u8220\'3fcommercial learner\u8217\'3fs permit\u8221\'3f or \u8220\'3fCLP\u8221\'3f with a statement that the permit is invalid unless accompanied by the permit holder\u8217\'3fs underlying driver\u8217\'3fs license shall appear prominently on the face of the permit. If the applicant is a nonresident, the license must conspicuously display the word \u8220\'3fnondomiciled\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall assign an applicant for a driver\u8217\'3fs license a distinguishing driver\u8217\'3fs license number other than the applicant\u8217\'3fs social security number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The license may contain other information as required under the department\u8217\'3fs rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E216_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Replacement.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If prior to the renewal date, a person desires to obtain a driver\u8217\'3fs license in the form authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a license may be issued as a voluntary replacement upon payment of the required fee as set by the department by rule. A person shall return a driver\u8217\'3fs license and be issued a new license when the first license contains inaccurate information upon payment of the required fee as set by the department by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E216_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Symbols.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the request of a licensee, the department shall indicate on the license the presence of a medical condition, that the licensee is a donor under the revised uniform anatomical gift Act as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 142C}}}{{\f5\fs18\hyphpar0\qj{, or that the licensee has in effect a medical advance directive. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a medical advance directive includes but is not limited to a valid durable power of attorney for health care as defined in }}}{{\f5\fs18\hyphpar0\qj{section 144B.1}}}{{\f5\fs18\hyphpar0\qj{. The license may contain such other information as the department may require by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E216_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Tamperproofing.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall issue a driver\u8217\'3fs license by a method or process which prevents as nearly as possible the alteration, reproduction, or superimposition of a photograph on the license without ready detection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E216_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Licenses or nonoperator\u8217\'3fs identification cards issued to persons under age twenty-one.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A driver\u8217\'3fs license issued to a person under eighteen years of age shall contain the same information as any other driver\u8217\'3fs license except that the words \u8220\'3funder eighteen\u8221\'3f shall appear prominently on the face of the license. A driver\u8217\'3fs license issued to a person eighteen years of age or older but less than twenty-one years of age shall contain the same information as any other driver\u8217\'3fs license except that the words \u8220\'3funder twenty-one\u8221\'3f shall appear prominently on the face of the license. Upon attaining the age of eighteen or upon attaining the age of twenty-one, and upon payment of a ten dollar fee, the person shall be entitled to a new driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card for the unexpired months of the driver\u8217\'3fs license or card. Upon attaining the age of twenty-one, a person who is otherwise eligible to be issued a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card shall be eligible to apply electronically for issuance of a replacement license or card for the unexpired months of the license or card, regardless of whether the most recent previous issuance of the license or card occurred electronically. The department shall, within a reasonable time period prior to a person\u8217\'3fs twenty-first birthday anniversary, notify the person of the person\u8217\'3fs eligibility to apply for a replacement driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card electronically upon attaining the age of twenty-one. The department shall develop educational media to raise awareness of a person\u8217\'3fs eligibility to apply for a replacement driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card electronically upon attaining the age of twenty-one. An instruction permit or intermediate license issued under }}}{{\f5\fs18\hyphpar0\qj{section 321.180B, subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{, shall include a distinctive color bar. An intermediate license issued under }}}{{\f5\fs18\hyphpar0\qj{section 321.180B, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall include the words \u8220\'3fintermediate license\u8221\'3f printed prominently on the face of the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E216_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Motorized bicycle.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue a driver\u8217\'3fs license valid only for operation of a motorized bicycle to a person fourteen years of age or older who has passed a vision test or who files a vision report as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.186A}}}{{\f5\fs18\hyphpar0\qj{ which shows that the applicant\u8217\'3fs visual acuity level meets or exceeds those required by the department and who passes a written examination on the rules of the road. A person under the age of sixteen applying for a driver\u8217\'3fs license valid only for operation of a motorized bicycle shall also be required to successfully complete a motorized bicycle education course approved and established by the department or successfully complete an approved motorized bicycle education course at a private or commercial driver education school licensed by the department. A public school district shall charge a student a fee which shall not exceed the actual cost of instruction. A driver\u8217\'3fs license valid only for operation of a motorized bicycle entitles the licensee to operate a motorized bicycle upon the highway while having the license in the licensee\u8217\'3fs immediate possession. The license is valid for a period not to exceed two years from the licensee\u8217\'3fs birthday anniversary in the year of issuance, subject to termination or cancellation as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A driver\u8217\'3fs license valid only for operation of a motorized bicycle shall be canceled upon a conviction for a moving traffic violation and reapplication may be made thirty days after the date of cancellation. The cancellation of the license upon conviction for a moving traffic violation shall not result in requiring the applicant to maintain proof of financial responsibility under }}}{{\f5\fs18\hyphpar0\qj{section 321A.17}}}{{\f5\fs18\hyphpar0\qj{, unless the conviction would otherwise result in a suspension or revocation of a person\u8217\'3fs driver\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmoving traffic violation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a parking violation as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.210}}}{{\f5\fs18\hyphpar0\qj{ or a violation of a section of the Code or municipal ordinance pertaining to standards to be maintained for motor vehicle equipment except }}}{{\f5\fs18\hyphpar0\qj{sections 321.430}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.431}}}{{\f5\fs18\hyphpar0\qj{, or except a municipal ordinance pertaining to motor vehicle brake requirements as applicable to motorized bicycles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of any class of driver\u8217\'3fs license may operate a motorized bicycle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates this subsection commits a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E216_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Veterans status.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee who is an honorably discharged veteran of the armed forces of the United States may request that the license be marked to reflect the licensee\u8217\'3fs veteran status. Upon such a request, the word \u8220\'3fVETERAN\u8221\'3f shall be marked prominently on the face of the license. Such a license shall be issued upon receipt of satisfactory proof of veteran status pursuant to procedures established by the department in consultation with the department of veterans affairs, or upon presentation of the licensee\u8217\'3fs certification of release or discharge from active duty, DD form 214, to the department at the time of the licensee\u8217\'3fs request, if the form indicates the licensee was honorably discharged. If the license is issued upon presentation of the licensee\u8217\'3fs certification of release or discharge from active duty, DD form 214, the department shall notify the commission of veteran affairs of the county of the licensee\u8217\'3fs residence that the licensee was issued a license marked to reflect the licensee\u8217\'3fs veteran status. After receiving notification from the department, the commission of veteran affairs shall initiate contact with the licensee. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E216_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Deaf or hard-of-hearing status.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee who is a deaf person or a hard-of-hearing person, as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 622B.1}}}{{\f5\fs18\hyphpar0\qj{, may request that the license be marked to reflect the licensee\u8217\'3fs deaf or hard-of-hearing status on the face of the license when the licensee applies for the issuance or renewal of a license. The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing criteria under which a license may be marked, including requiring the licensee to submit medical proof of the licensee\u8217\'3fs deaf or hard-of-hearing status. When a driver\u8217\'3fs license is so marked, the licensee\u8217\'3fs deaf or hard-of-hearing status shall be noted in the electronic database used by the department and law enforcement to access registration, titling, and driver\u8217\'3fs license information. The department, in consultation with the commission of deaf services, shall develop educational media to raise awareness of a licensee\u8217\'3fs ability to request the license be marked to reflect the licensee\u8217\'3fs deaf or hard-of-hearing status.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E216_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E216_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Autism spectrum disorder status.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee who has autism spectrum disorder, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 514C.28}}}{{\f5\fs18\hyphpar0\qj{, may request that the license be marked to reflect the licensee\u8217\'3fs autism spectrum disorder status on the face of the license when the licensee applies for the issuance or renewal of a license. The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing criteria under which a license may be marked, including requiring the licensee to submit medical proof of the licensee\u8217\'3fs autism spectrum disorder status. When a driver\u8217\'3fs license is so marked, the licensee\u8217\'3fs autism spectrum disorder status shall be noted in the electronic database used by the department and law enforcement to access registration, titling, and driver\u8217\'3fs license information. The department, in consultation with the department of health and human services, shall develop educational media to raise awareness of a licensee\u8217\'3fs ability to request the license be marked to reflect the licensee\u8217\'3fs autism spectrum disorder status.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d19, -d20, -d22, -d28; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7321.189; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.189}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 107, \'a71, 2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1022, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1292, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 167, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 206, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a722, 23}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 164, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1102, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 95, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1017, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 74, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1112, \'a76, 7, 14, 16}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 90, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 180, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 44, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1091, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 82, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a733, 54}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1111, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 76, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 84, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1089, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1026, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7107, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a749.78}}}{{\f5\fs12\hyphpar0\qj{, 321.177}}}{{\f5\fs12\hyphpar0\qj{, 321.180B}}}{{\f5\fs12\hyphpar0\qj{, 321.189A}}}{{\f5\fs12\hyphpar0\qj{, 321.190}}}{{\f5\fs12\hyphpar0\qj{, 321.191}}}{{\f5\fs12\hyphpar0\qj{, 321.213}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Driver\u8217\'3fs license fees, see }{{\f5\fs12\hyphpar0\qj{\'a7321.191}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Intermediate driver\u8217\'3fs license to indicate applicability of six-month restriction on unrelated minor passengers; see }{{\f5\fs12\hyphpar0\qj{\'a7321.180B, subsection 2}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 10 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 10 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.189A}}}{\*\bkmkstart stylerid1_2E217_2E2_2E2}{\*\bkmkend stylerid1_2E217_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driver\u8217\'3fs license for undercover law enforcement officers \u8212\'3f fee \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue undercover driver\u8217\'3fs licenses to certified peace officers employed by a local authority or by the state or federal law enforcement officers for use in the line of duty when a fictitious identity is necessary. The department, in cooperation with the commissioner of public safety, shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ regarding the issuance, use, and cancellation of licenses issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall only be issued to a certified peace officer or federal law enforcement officer, who is qualified to obtain the class of license sought, at the request of the law enforcement agency employing the officer for official use when the officer is involved in duty in which a fictitious identity is necessary. An officer issued a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall surrender the license when the license is no longer needed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall only be used in the line of duty when it is necessary for the officer holding the license to assume a fictitious identity. An officer issued a license pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall report as soon as practical to the law enforcement agency employing the officer any traffic citation issued to the officer while using the officer\u8217\'3fs fictitious identity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer using a license issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be prosecuted for a public offense under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ if the offense was committed in the line of duty and was necessary to protect the identity of the officer. However, this paragraph shall not apply to a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer who provides the department false information for the purposes of obtaining a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a class \u8220\'3fD\u8221\'3f felony.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer who displays or uses a license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ during the commission or attempted commission of a public offense other than a public offense referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ or who knowingly permits another person to use the license issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer who displays or uses a license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in any manner which is not a public offense but which is not authorized under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or who knowingly fails or refuses to surrender the license upon demand by the department commits an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for issuing a license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be the same as for licenses issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.189}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall keep as confidential public records under }}}{{\f5\fs18\hyphpar0\qj{section 22.7}}}{{\f5\fs18\hyphpar0\qj{, all records regarding licenses issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 92, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a722.7(36)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.190}}}{\*\bkmkstart stylerid1_2E218_2E2_2E2}{\*\bkmkend stylerid1_2E218_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of nonoperator\u8217\'3fs identification cards \u8212\'3f fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E218_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E218_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Application for and contents of card.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall, upon application and payment of the required fee, issue to an applicant a nonoperator\u8217\'3fs identification card. To be valid the card shall bear a distinguishing number other than a social security number assigned to the cardholder, the full name, date of birth, sex, residence address, a physical description and a color photograph of the cardholder, the usual signature of the cardholder, and such other information as the department may require by rule. An applicant for a nonoperator\u8217\'3fs identification card shall apply for the card in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.182, subsections 1 through 3}}}{{\f5\fs18\hyphpar0\qj{. The card shall be issued to the applicant at the time of application pursuant to procedures established by rule. An applicant for a nonoperator\u8217\'3fs identification card who is required by }}}{{\f5\fs18\hyphpar0\qj{50 U.S.C. app. \'a7451 et seq.}}}{{\f5\fs18\hyphpar0\qj{ to register with the United States selective service system shall be registered by the department with the selective service system as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.183}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not issue a card to a person holding a driver\u8217\'3fs license. However, a card may be issued to a person holding a temporary permit under }}}{{\f5\fs18\hyphpar0\qj{section 321.181}}}{{\f5\fs18\hyphpar0\qj{. The card shall be identical in form to a driver\u8217\'3fs license issued under }}}{{\f5\fs18\hyphpar0\qj{section 321.189}}}{{\f5\fs18\hyphpar0\qj{ except the word \u8220\'3fnonoperator\u8221\'3f shall appear prominently on the face of the card.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonoperator\u8217\'3fs identification card issued to a person under eighteen years of age shall contain the same information as any other nonoperator\u8217\'3fs identification card except that the words \u8220\'3funder eighteen\u8221\'3f shall appear prominently on the face of the card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonoperator\u8217\'3fs identification card issued to a person eighteen years of age or older but under twenty-one years of age shall contain the same information as any other nonoperator\u8217\'3fs identification card except that the words \u8220\'3funder twenty-one\u8221\'3f shall appear prominently on the face of the card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonoperator\u8217\'3fs identification card issued to an honorably discharged veteran of the armed forces of the United States who satisfies the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.189, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, shall contain the same information as any other nonoperator\u8217\'3fs identification card except the word \u8220\'3fVETERAN\u8221\'3f shall appear prominently on the face of the card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a nonoperator\u8217\'3fs identification card who is a deaf person or a hard-of-hearing person, as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 622B.1}}}{{\f5\fs18\hyphpar0\qj{, may request that the card be marked to reflect the applicant\u8217\'3fs deaf or hard-of-hearing status on the face of the card when the applicant applies for the issuance or renewal of a card. The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing criteria under which a card may be marked, including requiring the applicant to submit medical proof of the applicant\u8217\'3fs deaf or hard-of-hearing status. The department, in consultation with the commission of deaf services, shall develop educational media to raise awareness of an applicant\u8217\'3fs ability to request the card be marked to reflect the applicant\u8217\'3fs deaf or hard-of-hearing status.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a nonoperator\u8217\'3fs identification card who has autism spectrum disorder, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 514C.28}}}{{\f5\fs18\hyphpar0\qj{, may request that the card be marked to reflect the applicant\u8217\'3fs autism spectrum disorder status on the face of the card when the applicant applies for the issuance or renewal of a card. The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing criteria under which a card may be marked, including requiring the applicant to submit medical proof of the applicant\u8217\'3fs autism spectrum disorder status. The department, in consultation with the department of health and human services, shall develop educational media to raise awareness of an applicant\u8217\'3fs ability to request the card be marked to reflect the applicant\u8217\'3fs autism spectrum disorder status.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall use a process or processes for issuance of a nonoperator\u8217\'3fs identification card that prevent, as nearly as possible, the opportunity for alteration or reproduction of, and the superimposition of a photograph on the nonoperator\u8217\'3fs identification card without ready detection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for a nonoperator\u8217\'3fs identification card shall be eight dollars and the card shall be valid for a period of eight years from the date of issuance. If an applicant for a nonoperator\u8217\'3fs identification card is a foreign national who is temporarily present in this state, the nonoperator\u8217\'3fs identification card shall be issued only for the length of time the foreign national is authorized to be present as determined by the department, not to exceed two years. An issuance fee shall not be charged for a person whose driver\u8217\'3fs license or driving privilege has been suspended under }}}{{\f5\fs18\hyphpar0\qj{section 321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), or voluntarily surrendered by the person in lieu of suspension under }}}{{\f5\fs18\hyphpar0\qj{section 321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E218_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E218_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Cancellation.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall cancel a person\u8217\'3fs nonoperator\u8217\'3fs identification card upon determining the person was not entitled to be issued the card, did not provide correct information, committed fraud in applying for the card, or unlawfully used a nonoperator\u8217\'3fs identification card.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.190}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 317, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a736, 37}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1090, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 74, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 41, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7112}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1091, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 82, \'a72, 5}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 84, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1089, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1026, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7108, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a749.78}}}{{\f5\fs12\hyphpar0\qj{, 123.48}}}{{\f5\fs12\hyphpar0\qj{, 142C.2}}}{{\f5\fs12\hyphpar0\qj{, 321M.1}}}{{\f5\fs12\hyphpar0\qj{, 453A.4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Voter registration, see }{{\f5\fs12\hyphpar0\qj{\'a748A.18}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Replacement of identification cards upon person attaining age twenty-one, see }{{\f5\fs12\hyphpar0\qj{\'a7321.189}}}{, subsection 6}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1, paragraph b, subparagraph (6) effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph b, subparagraph (6) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.191}}}{\*\bkmkstart stylerid1_2E219_2E2_2E2}{\*\bkmkend stylerid1_2E219_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees for driver\u8217\'3fs licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E219_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Instruction permits.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for an instruction permit, other than a special instruction permit, chauffeur\u8217\'3fs instruction permit, or commercial learner\u8217\'3fs permit, is six dollars. The fee for a special instruction permit is ten dollars. The fee for a chauffeur\u8217\'3fs instruction permit or commercial learner\u8217\'3fs permit is twelve dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E219_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Noncommercial driver\u8217\'3fs licenses.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for a noncommercial driver\u8217\'3fs license, other than a class D driver\u8217\'3fs license or any type of instruction permit, is four dollars per year of license validity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E219_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Licenses for chauffeurs.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for a noncommercial class D driver\u8217\'3fs license is eight dollars per year of license validity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E219_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Commercial driver\u8217\'3fs licenses.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for a commercial driver\u8217\'3fs license, other than a commercial learner\u8217\'3fs permit, for the operation of a commercial motor vehicle is eight dollars per year of license validity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E219_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Licenses valid for motorcycles.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An additional fee of two dollars per year of license validity is required to issue a license valid to operate a motorcycle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E219_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Minors\u8217\'3f restricted licenses.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the fee for a special minor\u8217\'3fs restricted license issued to a minor under }}}{{\f5\fs18\hyphpar0\qj{section 321.194}}}{{\f5\fs18\hyphpar0\qj{ or a restricted work license issued to a minor under }}}{{\f5\fs18\hyphpar0\qj{section 321.178, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, is eight dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E219_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Endorsements and removal of restrictions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for a double or triple trailer endorsement, tank vehicle endorsement, or hazardous materials endorsement is five dollars for each endorsement. The fee for a passenger endorsement or a school bus endorsement is ten dollars. The fee for removal of an air brake, full air brake, manual transmission, tractor-trailer, or passenger vehicle restriction on a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit is ten dollars. Fees imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for endorsements or removal of restrictions are valid for the period of the license. Upon renewal of a commercial driver\u8217\'3fs license, no fee is payable for retaining endorsements or the removal of a restriction for those endorsements or restrictions which do not require the taking of either a knowledge or a driving skills test for renewal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E219_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Driver\u8217\'3fs license reinstatements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for reinstatement of a driver\u8217\'3fs license shall be twenty dollars for a license which is, after notice and opportunity for hearing, canceled, suspended, revoked, or barred. However, reinstatement of the privilege suspended under }}}{{\f5\fs18\hyphpar0\qj{section 321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), shall be without fee. The fee for reinstatement of the privilege to operate a commercial motor vehicle after a period of disqualification shall be twenty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E219_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Upgrading a license class privilege }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ fee adjustment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an applicant wishes to upgrade a license class privilege, the fee charged shall be prorated on full-year fee increments of the new license in accordance with rules adopted by the department. The expiration date of the new license shall be the expiration date of the currently held driver\u8217\'3fs license. The fee for a commercial driver\u8217\'3fs license endorsement, the removal of a restriction, or a commercial learner\u8217\'3fs permit shall not be prorated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fto upgrade a license class privilege\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means to add any privilege to a valid driver\u8217\'3fs license. The addition of a privilege includes converting from a noncommercial to a commercial license, converting from a noncommercial class C to a class D license, converting an instruction or learner\u8217\'3fs permit to a class license, adding any privilege to a }}}{{\f5\fs18\hyphpar0\qj{section 321.189, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, license, adding an instruction or learner\u8217\'3fs permit privilege, adding a }}}{{\f5\fs18\hyphpar0\qj{section 321.189, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, license to an instruction or learner\u8217\'3fs permit, and adding any privilege relating to a driver\u8217\'3fs license issued to a minor under }}}{{\f5\fs18\hyphpar0\qj{section 321.194}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.178}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E219_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E219_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Fees waived }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ veterans.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the department shall not charge the following fees for a driver\u8217\'3fs license to the following applicants:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fees set forth under }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 5}}}{{\f5\fs18\hyphpar0\qj{ to an applicant who is a veteran with a permanent service-connected disability rating of one hundred percent, as certified by the United States department of veterans affairs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fees set forth under }}}{{\f5\fs18\hyphpar0\qj{subsections 3 and 4}}}{{\f5\fs18\hyphpar0\qj{ to an applicant who is on federal active duty or state active duty, as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 29A.1}}}{{\f5\fs18\hyphpar0\qj{, or who was issued an honorable discharge or general discharge under honorable conditions from such service.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d26; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.16;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.191}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1160, \'a71}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1167, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1220, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 167, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 206, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a725 \u8211\'3f 27}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 8, \'a714, 26}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7171}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7102}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1134, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1166, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.12}}}{{\f5\fs12\hyphpar0\qj{, 321.180A}}}{{\f5\fs12\hyphpar0\qj{, 321.210B}}}{{\f5\fs12\hyphpar0\qj{, 321.211}}}{{\f5\fs12\hyphpar0\qj{, 321.212}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.192}}}{\*\bkmkstart stylerid1_2E22_30_2E2_2E2}{\*\bkmkend stylerid1_2E22_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Waivers or refunds of fees.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0130.pdf" }{\fldrslt \cf5 \f5 \fs18{{2009 Acts, ch 130, \'a717}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.193}}}{\*\bkmkstart stylerid1_2E221_2E2_2E2}{\*\bkmkend stylerid1_2E221_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restrictions on licenses \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As provided by rule, the department may impose restrictions suitable to the licensee\u8217\'3fs driving ability with respect to the type of motor vehicle or special mechanical control devices required on a motor vehicle which the licensee may operate or other restrictions applicable to the licensee as the department may determine to be appropriate.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may set forth restrictions upon the driver\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may suspend or revoke the driver\u8217\'3fs license upon receiving satisfactory evidence of any violation of the license\u8217\'3fs restrictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, for a person to operate a motor vehicle in any manner in violation of the restrictions imposed on a restricted license issued to that person under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.18;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.193}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79, 12}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a751, 59}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a739}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.180B}}}{{\f5\fs12\hyphpar0\qj{, 321.194}}}{{\f5\fs12\hyphpar0\qj{, 321.213}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(4)(e)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.194}}}{\*\bkmkstart stylerid1_2E222_2E2_2E2}{\*\bkmkend stylerid1_2E222_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special minor\u8217\'3fs restricted license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E222_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Application }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ persons eligible.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue a special minor\u8217\'3fs restricted license to an applicant between the ages of fourteen and eighteen years if the applicant meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant holds an instruction permit issued by the department in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.180B}}}{{\f5\fs18\hyphpar0\qj{, or a comparable permit issued by another state, and has held such permit for a minimum of six months prior to applying for the special minor\u8217\'3fs restricted license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has successfully completed an approved driver education course. However, the completion of a course is not required if the applicant demonstrates to the satisfaction of the department that completion of the course would impose a hardship upon the applicant. The department shall adopt rules defining the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhardship\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and establishing procedures for the demonstration and determination of when completion of the course would impose a hardship upon an applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant submits a certification from the applicant\u8217\'3fs school certifying the applicant is enrolled at the school for courses of instruction or extracurricular activities, or from the applicant\u8217\'3fs primary instructor if the applicant receives competent private instruction or independent private instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E222_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Consent }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ employment.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to being authorized to operate a motor vehicle unsupervised to a place of employment or a location for farm-related work while employed to work on a farm, the applicant\u8217\'3fs parent or guardian must complete a written consent form prescribed by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The written consent form must include, at minimum, the name and address of the applicant\u8217\'3fs current place of employment or primary farm location, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the place of employment or primary farm location changes, the parent or guardian must complete a new written consent form prior to the licensee being authorized to operate a motor vehicle unsupervised to the new location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While a licensee is operating a motor vehicle as described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the licensee shall carry a copy of the written consent form in the vehicle and present the form for inspection upon request by a certified peace officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E222_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Persons ineligible.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not issue a special minor\u8217\'3fs restricted license to an applicant if any of the following occurred during the six-month period immediately preceding the application:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant\u8217\'3fs driving privileges have been suspended, revoked, or barred under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant was at fault for causing an accident or collision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant has been convicted of a violation of a law of this state or a city ordinance regulating the operation of motor vehicles on highways other than parking violations as described in }}}{{\f5\fs18\hyphpar0\qj{section 321.210}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E222_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{License privileges.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall classify the special minor\u8217\'3fs restricted license as a class C or class M license, as applicable. A licensee is entitled to operate a motor vehicle as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, other than a commercial motor vehicle, a motor vehicle with more than two axles, a motor vehicle towing another vehicle, or as a chauffeur.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee may operate a motor vehicle unsupervised over the most direct and accessible route between the licensee\u8217\'3fs residence, school of enrollment, location where the licensee receives competent private instruction or independent private instruction, place of employment, location for farm work or farm-related work if the licensee resides on a farm or is employed for compensation on a farm in this state, and the closest service station, for any of the following purposes, as applicable, provided the driving distance between the point of origin and the destination is no more than twenty-five miles, and the licensee is in immediate possession of the license card:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To return to the licensee\u8217\'3fs residence following the end of the licensee\u8217\'3fs duly scheduled courses of instruction, extracurricular activities, work shift, farm work, or farm-related work, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To attend duly scheduled courses of instruction. However, a licensee who attends a public school and resides within that public school district may operate a motor vehicle between the licensee\u8217\'3fs residence and school regardless of the distance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To participate in extracurricular activities. If the licensee receives independent private instruction and participates in an extracurricular activity at another school, the licensee may drive to the location of the extracurricular activity regardless of whether the licensee is enrolled at the school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To complete a scheduled work shift, if approved by the licensee\u8217\'3fs parent or guardian pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of assisting the licensee\u8217\'3fs parents, guardians, or employer with farm work or in connection with any farm job, employment, or other farm-related work, including traveling to or from the location of the farm work, if the licensee resides on a farm or is employed for compensation on a farm in this state. If employed, the licensee\u8217\'3fs parent or guardian must provide consent pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of refueling the motor vehicle being operated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E222_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Restrictions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless accompanied and supervised in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.180B, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a licensee shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operate the motor vehicle except during the hour before and after the beginning and end of the licensee\u8217\'3fs duly scheduled courses of instruction, extracurricular activities, work shift, farm work, or farm-related work, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transport more than one unrelated minor passenger in the motor vehicle when the licensee is operating the motor vehicle. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3funrelated minor passenger\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a passenger who is under eighteen years of age and who is not a sibling of the driver, a stepsibling of the driver, or a child who resides in the same household as the driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operate the motor vehicle on a highway except as authorized under }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operate a motor vehicle to the licensee\u8217\'3fs place of employment or location for farm work or farm-related work unless the licensee\u8217\'3fs parent or guardian completed a written consent form and the form is carried in the motor vehicle and available for inspection in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E222_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Certification.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall prescribe a certification form for purposes of meeting the requirement under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. If the applicant is enrolled at a school for courses of instruction or extracurricular activities, the applicant\u8217\'3fs school shall certify that fact on the certification form, which must also include a statement that the person signing the certificate is not responsible for actions of the applicant which pertain to the use of the special minor\u8217\'3fs restricted license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant attends a public school, the certification must be made by the school board, superintendent of the applicant\u8217\'3fs school, or principal, if authorized by the superintendent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant attends an accredited nonpublic school, the certification must be made by the authorities in charge of the accredited nonpublic school or a duly authorized representative of the authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant receives competent private instruction, the certification must be made by the applicant\u8217\'3fs primary instructor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E222_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{License sanctions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special minor\u8217\'3fs restricted license issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is subject to suspension, revocation, or other sanction for the same reasons and in the same manner as suspension or revocation of any other driver\u8217\'3fs license, and as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The department shall suspend a special minor\u8217\'3fs restricted license for three months, as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving satisfactory evidence that the licensee violated the restrictions of the license or was at fault in an accident or collision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving a record of the licensee\u8217\'3fs conviction for one violation of a law of this state or a city ordinance regulating the operation of motor vehicles on highways other than parking violations as described in }}}{{\f5\fs18\hyphpar0\qj{section 321.210}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As a result of the suspension, the department shall not issue an intermediate license under }}}{{\f5\fs18\hyphpar0\qj{section 321.180B}}}{{\f5\fs18\hyphpar0\qj{ for an additional three months to a person whose special minor\u8217\'3fs restricted license was suspended under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, per violation, following the person\u8217\'3fs sixteenth birthday.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E222_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Citations for violation of restrictions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates the restrictions imposed under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ may be issued a citation under this section and shall not be issued a citation under }}}{{\f5\fs18\hyphpar0\qj{section 321.193}}}{{\f5\fs18\hyphpar0\qj{. A violation of the restrictions imposed under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ is a moving violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E222_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompetent private instruction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 299A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndependent private instruction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 299A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPlace of employment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the fixed location of an employer who employs a person between the ages of fourteen and eighteen in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 92}}}{{\f5\fs18\hyphpar0\qj{, as applicable, and is the only location at which the person is authorized to work for the employer unless the person is employed for purposes of farm work or farm-related work.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResidence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the place where a person resides, permanently or temporarily. A person may have up to three different residences for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, if the person\u8217\'3fs parent or guardian provides written consent of the additional residences on a form prescribed by the department. If a licensee has two or three different residences, the licensee shall carry a copy of the written consent form required under this paragraph in the vehicle operated by a licensee pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and the licensee shall present the form for inspection upon request by a certified peace officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchool\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a public school or an accredited nonpublic school, and includes facilities operated by a public or accredited nonpublic school for the purposes of educational or extracurricular activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E222_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E222_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rules.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.19;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.194}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1248, \'a73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 49, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 101, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1022, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1219, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 266, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1112, \'a78, 14, 16}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 159, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1105, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 80, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1025, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a777}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1170, \'a75 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 22, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 6, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1166, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 14, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.177}}}{{\f5\fs12\hyphpar0\qj{, 321.178}}}{{\f5\fs12\hyphpar0\qj{, 321.180B}}}{{\f5\fs12\hyphpar0\qj{, 321.191}}}{{\f5\fs12\hyphpar0\qj{, 321.213}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(4)(f)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 4}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5, paragraph d stricken and former paragraph e redesignated as d}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.195}}}{\*\bkmkstart stylerid1_2E223_2E2_2E2}{\*\bkmkend stylerid1_2E223_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{ Replacement of driver\u8217\'3fs licenses and nonoperator\u8217\'3fs identification cards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A fee of ten dollars shall be charged for the replacement of a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card. If a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card issued under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is lost or destroyed, the person to whom the license or card was issued must furnish proof satisfactory to the department that the driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card has been lost or destroyed in order to obtain a replacement. }\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d27; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.20;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.195}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 317, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 27, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 82, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.208}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.196}}}{\*\bkmkstart stylerid1_2E224_2E2_2E2}{\*\bkmkend stylerid1_2E224_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expiration of license \u8212\'3f renewal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided, if the licensee is between the ages of seventeen years eleven months and seventy-eight years on the date of issuance of the license, a driver\u8217\'3fs license, other than an instruction permit, chauffeur\u8217\'3fs instruction permit, or commercial learner\u8217\'3fs permit issued under }}}{{\f5\fs18\hyphpar0\qj{section 321.180}}}{{\f5\fs18\hyphpar0\qj{, expires eight years from the licensee\u8217\'3fs birthday anniversary occurring in the year of issuance, but not to exceed the licensee\u8217\'3fs eightieth birthday. If the licensee is under the age of seventeen years eleven months or age seventy-eight or over, the license is effective for a period of two years from the licensee\u8217\'3fs birthday anniversary occurring in the year of issuance. A licensee whose license is restricted due to vision or other physical deficiencies may be required to renew the license every two years. If a licensee is a foreign national who is temporarily present in this state, the license shall be issued only for the length of time the foreign national is authorized to be present as verified by the department, not to exceed two years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as required in }}}{{\f5\fs18\hyphpar0\qj{section 321.188}}}{{\f5\fs18\hyphpar0\qj{, and except for a motorcycle instruction permit issued in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.180}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.180B}}}{{\f5\fs18\hyphpar0\qj{, a driver\u8217\'3fs license is renewable without a driving test or written examination within a period of one year after its expiration date. A person shall not be considered to be driving with an invalid license during a period of sixty days following the license expiration date. However, for a license renewed within the sixty-day period, the date of issuance shall be considered to be the previous birthday anniversary on which it expired.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the birthday anniversary of a person born on February 29 shall be deemed to occur on March 1.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as required in }}}{{\f5\fs18\hyphpar0\qj{section 321.180}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.188}}}{{\f5\fs18\hyphpar0\qj{, the department in its discretion may authorize the renewal of a valid driver\u8217\'3fs license upon application without an examination provided that the applicant meets one of the following conditions: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant satisfactorily passes a vision test as prescribed by the department. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant files a vision report in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.186A}}}{{\f5\fs18\hyphpar0\qj{ which shows that the applicant\u8217\'3fs visual acuity level meets or exceeds those required by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is eligible for license renewal electronically, pursuant to rules adopted by the department. An applicant shall not be eligible for electronic renewal of a driver\u8217\'3fs license if the most recent previous renewal of the applicant\u8217\'3fs driver\u8217\'3fs license occurred electronically.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for renewal of a driver\u8217\'3fs license shall include a statement for the applicant to sign that acknowledges the applicant\u8217\'3fs knowledge of the requirement to notify the department of a mailing address change under }}}{{\f5\fs18\hyphpar0\qj{section 321.182, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident of Iowa holding a valid driver\u8217\'3fs license who is temporarily absent from the state or incapacitated, may, at the time for renewal of such license, apply to the department for a temporary extension of the license. The department upon receipt of the application shall, upon a showing of good cause, issue a temporary extension of the driver\u8217\'3fs license for a period not to exceed six months.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d15, -d30; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.21;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.196}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 195, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1220, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 167, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 296, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 51, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1112, \'a79, 14, 16}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 180, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1018, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 124, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 82, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 104, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1072, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 31, \'a72, 3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.197}}}{\*\bkmkstart stylerid1_2E225_2E2_2E2}{\*\bkmkend stylerid1_2E225_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Emergency contact information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall include in the electronic database used by the department and law enforcement to access registration, titling, and driver\u8217\'3fs license information a collection of emergency contact information for persons who are issued a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card. Emergency contact information in the database shall be confidential and accessible only by employees of the department or a law enforcement agency in the performance of the employee\u8217\'3fs official duties, and shall not be considered a public record under }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time a person applies for issuance, replacement, or renewal of a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card, the department shall request that the applicant voluntarily submit emergency contact information for inclusion in the database. A person may provide the emergency contact information along with or separate from an application for issuance, replacement, or renewal of a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card. The department shall not require a person to submit emergency contact information as part of the driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card issuance, replacement, or renewal process. The department shall accept submitted information without payment of a fee.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall allow a person to provide the name, address, telephone number, and relationship to the person of no more than two emergency contacts whom the person wishes to be contacted if the person is involved in a motor vehicle accident or emergency situation and the person dies or is seriously injured or rendered unconscious and is unable to communicate with the emergency contact. The department shall accept the emergency contact information provided by a person, but has no duty to verify any of the information provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The emergency contact need not be the next of kin of the person, except that if the person is under eighteen years of age and is not emancipated, the person shall include a parent, guardian, or custodian of the person as an emergency contact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event of a motor vehicle accident or emergency situation in which a person dies or is seriously injured or rendered unconscious and is unable to communicate with the emergency contact specified in the database, an employee of a law enforcement agency shall make a good-faith effort to notify the emergency contact of the situation based on information in the database, but the department, the law enforcement agency, and the employee shall not be liable if the employee is not able to notify the emergency contact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ necessary to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to rules relating to all of the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The methods whereby a person who has submitted the information of an emergency contact for inclusion in the database may make changes to that entry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The methods whereby a person may opt out of being listed as an emergency contact in the database.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 122, \'a71, 2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.198}}}{\*\bkmkstart stylerid1_2E226_2E2_2E2}{\*\bkmkend stylerid1_2E226_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Military service exception.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The effective date of a valid driver\u8217\'3fs license issued under the laws of this state, held by any person at the time of entering the military service of the United States or of the state of Iowa, notwithstanding the expiration of the license according to its terms, is extended without fee until six months following the initial separation from active duty of the person from the military service, provided the person is not suffering from physical disabilities which impair the person\u8217\'3fs competency as an operator, and provided further that the licensee shall furnish, upon demand of any peace officer, satisfactory evidence of the person\u8217\'3fs military service. However, a person entitled to the benefits of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ who is charged with operating a motor vehicle without a valid driver\u8217\'3fs license shall not be convicted if the person produces in court, within a reasonable time, a valid driver\u8217\'3fs license previously issued to that person along with satisfactory evidence of the person\u8217\'3fs military service as provided in this paragraph.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department is authorized to renew any driver\u8217\'3fs license falling within the provisions and limitations of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, without examination, upon application and payment of fee made within six months following separation from the military service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a United States department of defense common access card issued to a person is satisfactory evidence of the person\u8217\'3fs current military service, and a certificate of release or discharge from active duty, commonly referred to as a DD214, is satisfactory evidence of a person\u8217\'3fs previous military service and separation from active duty. A person who produces a valid driver\u8217\'3fs license previously issued to the person along with the person\u8217\'3fs common access card or DD214 shall not be required to produce any additional documentation to satisfy the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall also apply to the spouse and children, or protected person, of military personnel when such spouse, children, or protected person are living with the military personnel described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ outside of the state of Iowa and provided that such extension of license does not exceed five years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person whose period of validity of the person\u8217\'3fs driver\u8217\'3fs license is extended under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may file an application in accordance with rules adopted by the department to have the person\u8217\'3fs record of issuance of a driver\u8217\'3fs license retained in the department\u8217\'3fs record system during the period for which the driver\u8217\'3fs license remains valid. If a person has had the record of issuance of the person\u8217\'3fs driver\u8217\'3fs license removed from the department\u8217\'3fs records, the person shall have the person\u8217\'3fs record of driver\u8217\'3fs license issuance reentered by the department upon request if the request is accompanied by a letter from the applicable person\u8217\'3fs commanding officer verifying the military service.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.198}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 167, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 170, \'a75}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{90 Acts, ch 1230, \'a743, 44}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1070, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7103}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1009, \'a748}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.199}}}{\*\bkmkstart stylerid1_2E227_2E2_2E2}{\*\bkmkend stylerid1_2E227_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driver\u8217\'3fs license records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall file every application for a license received by it and shall maintain suitable indexes containing, in alphabetical order, all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All applications denied and the reasons for the denial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All applications granted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of every licensee who has been disqualified from operating a commercial motor vehicle or whose license has been suspended, revoked, or canceled by the department and after each name a note on the reasons for the action.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d18; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.23;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.199}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a745}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.200}}}{\*\bkmkstart stylerid1_2E228_2E2_2E2}{\*\bkmkend stylerid1_2E228_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conviction and accident file.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall also file all accident reports and abstracts of court records of convictions received by it under the laws of this state or any other state or foreign jurisdiction and in connection therewith maintain convenient records or make suitable notations in order that an individual record of each licensee showing the convictions of such licensee and the traffic accidents in which the licensee has been involved shall be readily ascertainable and available for the consideration of the department upon any application for renewal of license and at other suitable times.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5013.24;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.200}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 8, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.213}}}{{\f5\fs12\hyphpar0\qj{, 321.267A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.200A}}}{\*\bkmkstart stylerid1_2E229_2E2_2E2}{\*\bkmkend stylerid1_2E229_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Convictions based upon fraud.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person discovers a record of conviction for a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ was entered by fraudulent use of the person\u8217\'3fs name or by use of other fraudulent identification, the person may, within one year of the date of the discovery of the conviction, submit a written application to the department to investigate the allegation. The department may summarily reject the application as submitted or proceed to investigate the application. If the department investigates the application, the department may either deny the application or, if the department determines the allegation is warranted, approve the application. If the department investigates the application, the department shall also issue a report and findings with the decision of the department. The rejection, approval, or denial of an application is not subject to contested case proceedings or further review as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. If the application is investigated, the department shall provide the applicant with a certified copy of the decision of the department. If the department approves the application, the department shall also provide the applicant with a certified copy of the investigative report and findings. The department shall also provide certified copies of the department\u8217\'3fs decision approving or denying the application together with the investigative report and findings to the appropriate prosecuting attorney in the city or county that prosecuted the scheduled violation and to the district court in the county that prosecuted the scheduled violation. The department may electronically provide copies of any decision approving or denying the application and the investigative report and findings to the district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who discovers that a record of conviction for a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ was entered by fraudulent use of the person\u8217\'3fs name or by use of other fraudulent identification may bypass the application process in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and move in district court to set aside the judgment of conviction within one year of discovery of the conviction. An applicant with an approved application under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall also move in district court to set aside the judgment of conviction in order to have the department expunge or alter the records of the department or rescind or modify an administrative sanction. If the district court grants the motion to set aside the judgment, the district court shall order the charging agency or official to modify the records of the agency or official to reflect the order setting aside the judgment. The clerk of the district court shall provide the court order setting aside the judgment, either by regular mail or electronic means, to the charging agency or official, and the department of transportation. The clerk of the district court shall also provide the applicant with a certified copy of the court order at no cost to the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the department\u8217\'3fs approval of an application pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the department shall not expunge or alter the records of the department or rescind or modify an administrative sanction unless the department receives an order from the district court setting aside the previous judgment of the court as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. Upon receiving a copy of an order from the district court setting aside the previous judgment of the court, the department shall expunge the record and shall rescind any administrative sanction imposed upon the applicant as a result of the judgment, unless the applicant is subject to sanctions for other reasons. The department may impose a new sanction if expunging the judgment would result in a lesser or different sanction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 124, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7811.9}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E23_30_2E1_2E1}{CANCELLATION, SUSPENSION, OR}{\*\bkmkend stylerid1_2E23_30_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{REVOCATION OF LICENSES}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.201}}}{\*\bkmkstart stylerid1_2E231_2E2_2E2}{\*\bkmkend stylerid1_2E231_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cancellation and return of license \u8212\'3f prohibition from issuance of commercial driver\u8217\'3fs license for false information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may cancel a driver\u8217\'3fs license upon determination of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the licensee was not entitled to the issuance of the license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the licensee failed to give required or correct information or committed fraud in making the application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon cancellation, the licensee shall immediately return the license to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon cancellation of a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit for providing false information or committing fraud in the application, the applicant shall not operate a commercial motor vehicle in this state and shall not be issued a license valid to operate a commercial motor vehicle for a period of sixty days.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall disqualify the commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit of a person convicted or suspected of fraud related to the testing for or issuance of a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit. The department shall adopt rules to administer this paragraph that substantially comply with }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.73(k)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d33; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.201}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a757}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.204}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.202}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.203}}}{\*\bkmkstart stylerid1_2E233_2E2_2E2}{\*\bkmkend stylerid1_2E233_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspending privileges of nonresidents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A nonresident\u8217\'3fs privilege to operate a motor vehicle on a highway in this state is subject to suspension or revocation for the same reasons and in the same manner as suspension or revocation of a resident\u8217\'3fs driver\u8217\'3fs license and is also subject to suspension as provided in }{{\f5\fs18\hyphpar0\qj{section 321.513}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d37; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.203}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a747}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.204}}}{\*\bkmkstart stylerid1_2E234_2E2_2E2}{\*\bkmkend stylerid1_2E234_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certification of conviction \u8212\'3f notification of commercial driver\u8217\'3fs disqualification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department is authorized, upon receiving a record of the conviction in this state of a nonresident operator of a motor vehicle for any offense under the motor vehicle laws of this state, to forward a certified written or electronic record of the conviction to the motor vehicle administrator in the licensing state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall notify the commercial driver\u8217\'3fs license information system and the commercial motor vehicle administrator in the licensing state, if applicable, of the disqualification of a commercial driver within ten days of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The disqualification of the commercial driver under section }}}{{\f5\fs18\hyphpar0\qj{321.201}}}{{\f5\fs18\hyphpar0\qj{ or section }}}{{\f5\fs18\hyphpar0\qj{321.208}}}{{\f5\fs18\hyphpar0\qj{ if the disqualification is for sixty days or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The suspension or revocation of a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit if the suspension or revocation is for sixty days or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cancellation of a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d41; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.204}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a758}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.208}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.205}}}{\*\bkmkstart stylerid1_2E235_2E2_2E2}{\*\bkmkend stylerid1_2E235_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conviction or administrative decision in another jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department is authorized to suspend or revoke the driver\u8217\'3fs license of a resident of this state or disqualify a resident of this state from operating a commercial motor vehicle for any of the following reasons:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving notice of the conviction of the resident in another state for an offense which, if committed in this state, would be grounds for the suspension or revocation of the license or disqualification of the person from operating a commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving notice of a final administrative decision in another state that the resident has acted in a manner which would be grounds for suspension or revocation of the license or disqualification of the person from operating a commercial motor vehicle in this state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d39; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.205}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a749}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 16, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 87, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1218, \'a758}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 8, \'a721}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210C}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.206}}}{\*\bkmkstart stylerid1_2E236_2E2_2E2}{\*\bkmkend stylerid1_2E236_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Surrender of license }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ duty of court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a person is convicted in court of an offense for which }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ requires mandatory revocation of the person\u8217\'3fs driver\u8217\'3fs license or, if the person\u8217\'3fs license is a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit and the conviction disqualifies the person from operating a commercial motor vehicle, the court shall require the person to surrender the driver\u8217\'3fs license held by the person and the court shall destroy the license or forward the license together with a record of the conviction to the department as provided in }{{\f5\fs18\hyphpar0\qj{section 321.491}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d32; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.206}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 143, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a759}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210D}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.207}}}{\*\bkmkstart stylerid1_2E237_2E2_2E2}{\*\bkmkend stylerid1_2E237_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Downgrade of commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall adopt rules for downgrading a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit to a noncommercial status upon a driver\u8217\'3fs failure to provide a medical examiner\u8217\'3fs certificate as required pursuant to }{{\f5\fs18\hyphpar0\qj{section 321.188, subsection 1}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{, upon a driver\u8217\'3fs failure to provide a self-certification of type of driving as required pursuant to }{{\f5\fs18\hyphpar0\qj{section 321.188, subsection 1}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{, or upon receiving notification of the driver\u8217\'3fs prohibited status pursuant to }{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.73(q)}}}{. The rules shall include procedures regarding notification of downgrade status to the commercial driver\u8217\'3fs license information system, termination of a downgrade process, and reinstatement of a commercial learner\u8217\'3fs permit or commercial driver\u8217\'3fs license after a downgrade, and shall substantially comply with }{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.71}}}{ and }{{\f5\fs18\hyphpar0\qj\cf1{383.73}}}{, as adopted by rule by the department.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 38, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 126, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.174}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.208}}}{\*\bkmkstart stylerid1_2E238_2E2_2E2}{\*\bkmkend stylerid1_2E238_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disqualification from operation of commercial motor vehicles \u8212\'3f noncommercial driver\u8217\'3fs license \u8212\'3f temporary license or permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle for one year upon a conviction or final administrative decision that the person has committed any of the following acts or offenses in any state or foreign jurisdiction while operating a commercial motor vehicle:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a commercial motor vehicle with an alcohol concentration, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321J.1}}}{{\f5\fs18\hyphpar0\qj{, of 0.04 or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a commercial motor vehicle when, as a result of prior violations committed while operating a commercial motor vehicle, the person\u8217\'3fs commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit is revoked, suspended, or canceled or the person is disqualified from operating a commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a commercial motor vehicle involved in a fatal accident and being convicted of manslaughter under }}}{{\f5\fs18\hyphpar0\qj{section 707.4}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{707.5}}}{{\f5\fs18\hyphpar0\qj{ or vehicular homicide under }}}{{\f5\fs18\hyphpar0\qj{section 707.6A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle for one year upon a conviction or final administrative decision that the person has committed any of the following acts or offenses in any state or foreign jurisdiction while operating a commercial motor vehicle or while operating a noncommercial motor vehicle and holding a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a motor vehicle while intoxicated, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refusal to submit to chemical testing required under }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Leaving the scene or failure to stop or render aid at the scene of an accident involving the person\u8217\'3fs vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A felony or aggravated misdemeanor involving the use of a motor vehicle, other than a felony or aggravated misdemeanor otherwise provided for in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle for three years if an act or offense described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{ occurred while the person was operating a commercial motor vehicle transporting hazardous materials as defined in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle for life if convicted or found to have committed two or more of the acts or offenses described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{ arising out of two or more separate incidents. However, a disqualification for life is subject to a reduction to a ten-year disqualification as provided in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.51}}}{{\f5\fs18\hyphpar0\qj{ as adopted by rule by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle for life upon a conviction that the person used a commercial motor vehicle in the commission of a felony or aggravated misdemeanor involving the manufacturing, distributing, or dispensing of a controlled substance as defined in }}}{{\f5\fs18\hyphpar0\qj{section 124.101}}}{{\f5\fs18\hyphpar0\qj{. A person is disqualified from operating a commercial motor vehicle for life upon a conviction that the person used a noncommercial motor vehicle in the commission of a felony or aggravated misdemeanor involving the manufacturing, distributing, or dispensing of a controlled substance as defined in }}}{{\f5\fs18\hyphpar0\qj{section 124.101}}}{{\f5\fs18\hyphpar0\qj{ and held a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit at the time the offense was committed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle for life upon a conviction that the person used a commercial motor vehicle in the commission of a felony involving an act or practice of human trafficking as defined in }}}{{\f5\fs18\hyphpar0\qj{section 710A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle if the person receives convictions for committing within any three-year period two or more of the following offenses while operating a commercial motor vehicle, or while operating a noncommercial motor vehicle and holding a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit if the convictions result in the revocation, cancellation, or suspension of the person\u8217\'3fs commercial driver\u8217\'3fs license, commercial learner\u8217\'3fs permit, or noncommercial motor vehicle driving privileges:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a commercial motor vehicle upon a highway when not issued a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a commercial motor vehicle upon a highway when not issued the proper class of commercial driver\u8217\'3fs license, commercial learner\u8217\'3fs permit, or endorsements for the specific vehicle group being operated or for the passengers or type of cargo being transported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a commercial motor vehicle upon a highway without immediate possession of a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit valid for the vehicle operated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Speeding fifteen miles per hour or more over the legal speed limit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reckless driving.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the traffic laws, except a parking violation or a vehicle weight violation, which arises in connection with a fatal traffic accident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following another motor vehicle too closely.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Improper lane changes in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.306}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violating a state or local law or ordinance on motor vehicle traffic control prohibiting texting while driving a commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violating a state or local law or ordinance on motor vehicle traffic control restricting or prohibiting the use of a hand-held mobile telephone while driving a commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The period of disqualification under }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{ shall be sixty days for two offenses within any three-year period and one hundred twenty days for three offenses within any three-year period. Multiple periods of disqualification shall be consecutive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle when the person\u8217\'3fs driving privilege is suspended or revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For no less than one hundred eighty days and no more than one year upon conviction for the first violation of an out-of-service order; for no less than two and not more than five years upon conviction for a second violation of an out-of-service order in separate incidents within a ten-year period; and for not less than three and not more than five years upon conviction for a third or subsequent violation of an out-of-service order in separate incidents within a ten-year period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For one year upon conviction for the first violation and for not less than three years and not more than five years upon conviction for a second or subsequent violation of an out-of-service order while transporting hazardous materials as defined in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.5}}}{{\f5\fs18\hyphpar0\qj{, or while operating a commercial motor vehicle designed to transport more than fifteen passengers including the driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle if the person is convicted of a first, second, or third railroad crossing at grade violation as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle for sixty days if the person is convicted of a first railroad crossing at grade violation under }}}{{\f5\fs18\hyphpar0\qj{section 321.341}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.343}}}{{\f5\fs18\hyphpar0\qj{ and the violation occurred while the person was operating a commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle for one hundred twenty days if the person is convicted of a second railroad crossing at grade violation under }}}{{\f5\fs18\hyphpar0\qj{section 321.341}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.343}}}{{\f5\fs18\hyphpar0\qj{, the violation occurred while the person was operating a commercial motor vehicle, and the violation occurred within three years after a first such violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle for one year if the person is convicted of a third or subsequent railroad crossing at grade violation under }}}{{\f5\fs18\hyphpar0\qj{section 321.341}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.343}}}{{\f5\fs18\hyphpar0\qj{, the violation occurred while the person was operating a commercial motor vehicle, and the violation occurred within three years after a first such violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving a record of a person\u8217\'3fs disqualifying conviction, administrative decision, suspension, or revocation, the department shall, by rule, without preliminary hearing and upon thirty days\u8217\'3f advance notice, disqualify the person from operating a commercial motor vehicle upon a highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is disqualified from operating a commercial motor vehicle if the person either refuses to submit to chemical testing required under }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ or submits to chemical testing and the results show an alcohol concentration as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321J.1}}}{{\f5\fs18\hyphpar0\qj{ of 0.04 or more. The department, upon receipt of the peace officer\u8217\'3fs certification, subject to penalty for perjury, that the peace officer had reasonable grounds to believe the person to have been operating a commercial motor vehicle with an alcohol concentration of 0.04 or more and that the person refused to submit to the chemical testing or submitted to chemical testing and the results show an alcohol concentration as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321J.1}}}{{\f5\fs18\hyphpar0\qj{ of 0.04 or more, shall, without preliminary hearing and upon thirty days\u8217\'3f advance notice, disqualify the person from operating a commercial motor vehicle upon a highway.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The effective date of disqualification shall be thirty days after notification. Immediate notice of disqualification may be served on a person operating a commercial motor vehicle who refused to submit to a test or whose test results indicate an alcohol concentration of 0.04 or more by the peace officer administering the chemical test or, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, the department may notify the person by first class mail. If immediate notice is served, the peace officer shall take the commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit of the driver, if issued within the state, and issue a temporary commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit effective for only thirty days. The peace officer shall immediately send the person\u8217\'3fs commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit to the department in addition to the officer\u8217\'3fs certification required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon notice, the disqualified person shall surrender the person\u8217\'3fs commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit to the department and the department may issue a driver\u8217\'3fs license valid only to operate a noncommercial motor vehicle upon payment of the fee for a replacement driver\u8217\'3fs license under }}}{{\f5\fs18\hyphpar0\qj{section 321.195}}}{{\f5\fs18\hyphpar0\qj{. The department shall notify the commercial driver\u8217\'3fs license information system of the disqualification if required to do so under }}}{{\f5\fs18\hyphpar0\qj{section 321.204}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the Iowa administrative procedure Act, }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, the filing of a petition for judicial review shall stay the disqualification pending the determination by the district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may reinstate a qualified person\u8217\'3fs privilege to operate a commercial motor vehicle after a period of disqualification and after payment of required fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the terms }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3facts\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3factions\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3foffenses\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean acts, actions, or offenses which occur on or after July 1, 1990.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.208}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a724 \u8211\'3f 26}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 55, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 96, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a722 \u8211\'3f 25}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1021, \'a75 \u8211\'3f 9}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 103, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a761 \u8211\'3f 66}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1017, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.204}}}{{\f5\fs12\hyphpar0\qj{, 321.218}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}{{\f5\fs12\hyphpar0\qj{, 321J.8}}}{{\f5\fs12\hyphpar0\qj{, 321J.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.208A}}}{\*\bkmkstart stylerid1_2E239_2E2_2E2}{\*\bkmkend stylerid1_2E239_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operation in violation of out-of-service order }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person required to hold a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit to operate a commercial motor vehicle shall not operate a commercial motor vehicle on the highways of this state in violation of an out-of-service order issued by a peace officer for a violation of the out-of-service rules adopted by the department. A driver who violates an out-of-service order commits a simple misdemeanor and shall be subject to the applicable fine in an amount in accordance with the civil penalty provided in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 386, Appendix B(b)(1)}}}{{\f5\fs18\hyphpar0\qj{, upon conviction for the first violation of an out-of-service order or subsequent violation of an out-of-service order in separate incidents within a ten-year period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer shall not knowingly allow, require, permit, or authorize an employee to drive a commercial motor vehicle in violation of an out-of-service order. An employer who violates }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor and shall be subject to a fine in an amount in accordance with the civil penalty provided in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 386, Appendix B(b)(2)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 55, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1178, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1021, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 126, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.209}}}{\*\bkmkstart stylerid1_2E24_30_2E2_2E2}{\*\bkmkend stylerid1_2E24_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mandatory revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department, upon thirty days\u8217\'3f notice and without preliminary hearing, shall revoke the license or operating privilege of an operator upon receiving a record of the operator\u8217\'3fs conviction for any of the following offenses, when such conviction has become final:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Manslaughter resulting from the operation of a motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A felony if during the commission of the felony a motor vehicle is used.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure to stop and render aid as required under the laws of this state or to otherwise comply with }}}{{\f5\fs18\hyphpar0\qj{section 321.261}}}{{\f5\fs18\hyphpar0\qj{ in the event of a motor vehicle accident resulting in the death or personal injury of another.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Perjury or the making of a false affidavit or statement under oath to the department under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or under any other law relating to the ownership or operation of motor vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conviction, or forfeiture of bail not vacated, upon two charges of reckless driving.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conviction of drag racing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eluding or attempting to elude a law enforcement vehicle as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.279}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d33, 5027-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.209}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1167, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 125, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1220, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 16, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1218, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 180, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210D}}}{{\f5\fs12\hyphpar0\qj{, 321.212}}}{{\f5\fs12\hyphpar0\qj{, 321.213}}}{{\f5\fs12\hyphpar0\qj{, 321.215}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.210}}}{\*\bkmkstart stylerid1_2E241_2E2_2E2}{\*\bkmkend stylerid1_2E241_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department is authorized to establish rules providing for the suspension of the license of an operator upon thirty days\u8217\'3f notice and without preliminary hearing upon a showing by its records or other sufficient evidence that the licensee:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an habitually reckless or negligent driver of a motor vehicle.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is an habitual violator of the traffic laws.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is physically or mentally incapable of safely operating a motor vehicle.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has permitted an unlawful or fraudulent use of the license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has committed an offense or acted in a manner in another state or foreign jurisdiction which in this state would be grounds for suspension or revocation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has committed a serious violation of the motor vehicle laws of this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is subject to a license suspension under }}}{{\f5\fs18\hyphpar0\qj{section 321.513}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to a suspension taking effect under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), (2), (3), (4), (5), or (6), the licensee shall have received thirty days\u8217\'3f advance notice of the effective date of the suspension. Notwithstanding the terms of the Iowa administrative procedure Act, }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, the filing of a petition for judicial review shall, except for suspensions under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), operate to stay the suspension pending the determination by the district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining suspension the department shall not consider the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violation of motor vehicle equipment standards if repairs are made within seventy-two hours of the violation and satisfactory evidence of repair is immediately sent to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violations of requirements to install and use safety belts, safety harnesses, and child restraint devices under }}}{{\f5\fs18\hyphpar0\qj{sections 321.445}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.446}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parking violations, meaning violation of a local authority parking ordinance or violation of }}}{{\f5\fs18\hyphpar0\qj{sections 321L.4}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.366, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and sections }}}{{\f5\fs18\hyphpar0\qj{321.354 through 321.361}}}{{\f5\fs18\hyphpar0\qj{ except }}}{{\f5\fs18\hyphpar0\qj{section 321.354, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The first two speeding violations within any twelve-month period of ten miles per hour or less over the legal speed limit in speed zones having a legal speed limit between thirty-four miles per hour and fifty-six miles per hour.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d35; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.210}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1100, \'a718, 19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1016, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1022, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1009, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1220, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 120, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 167, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 247, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 23, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7113, 172}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1105, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7243}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 14, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.12}}}{{\f5\fs12\hyphpar0\qj{, 321.178}}}{{\f5\fs12\hyphpar0\qj{, 321.180A}}}{{\f5\fs12\hyphpar0\qj{, 321.189}}}{{\f5\fs12\hyphpar0\qj{, 321.190}}}{{\f5\fs12\hyphpar0\qj{, 321.191}}}{{\f5\fs12\hyphpar0\qj{, 321.194}}}{{\f5\fs12\hyphpar0\qj{, 321.210C}}}{{\f5\fs12\hyphpar0\qj{, 321.212}}}{{\f5\fs12\hyphpar0\qj{, 321.213}}}{{\f5\fs12\hyphpar0\qj{, 321.215}}}{{\f5\fs12\hyphpar0\qj{, 321.218}}}{{\f5\fs12\hyphpar0\qj{, 321.372}}}{{\f5\fs12\hyphpar0\qj{, 321.555}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph e stricken}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.210A}}}{\*\bkmkstart stylerid1_2E242_2E2_2E2}{\*\bkmkend stylerid1_2E242_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspension for failure to pay fine, penalty, surcharge, or court costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall suspend the driver\u8217\'3fs license of a person who, upon conviction of violating a law regulating the operation of a motor vehicle, has failed to pay the criminal fine or penalty, surcharge, or court costs, as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the failure of a person to timely pay the fine, penalty, surcharge, or court costs the clerk of the district court shall notify the person by regular mail that if the fine, penalty, surcharge, or court costs remain unpaid after sixty days from the date of mailing, the clerk will notify the department of the failure for purposes of instituting suspension procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the failure of a person to pay the fine, penalty, surcharge, or court costs within sixty days\u8217\'3f notice by the clerk of the district court as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the clerk shall report the failure to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a report of a failure to pay the fine, penalty, surcharge, or court costs from the clerk of the district court, the department shall in accordance with its rules, suspend the person\u8217\'3fs driver\u8217\'3fs license until the fine, penalty, surcharge, or court costs are paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If after suspension, the person enters into an installment agreement with the county attorney, the county attorney\u8217\'3fs designee, or the department of revenue in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.210B}}}{{\f5\fs18\hyphpar0\qj{ to pay the fine, penalty, court cost, or surcharge, the person\u8217\'3fs license shall be reinstated by the department upon receipt of a report of an executed installment agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the county attorney or the county attorney\u8217\'3fs designee, while collecting delinquent court debt pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{, determines that the person has been convicted of an additional violation of a law regulating the operation of a motor vehicle, the county attorney or the county attorney\u8217\'3fs designee shall notify the clerk of the district court of the appropriate case numbers, and the clerk of the district court shall notify the department for the purpose of instituting suspension procedures pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 197, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1019, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 196, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 138, \'a790, 161, 162}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a785, 92}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.12}}}{{\f5\fs12\hyphpar0\qj{, 321.210B}}}{{\f5\fs12\hyphpar0\qj{, 321.212}}}{{\f5\fs12\hyphpar0\qj{, 321.215}}}{{\f5\fs12\hyphpar0\qj{, 321.218}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(50A)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.210B}}}{\*\bkmkstart stylerid1_2E243_2E2_2E2}{\*\bkmkend stylerid1_2E243_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Installment agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person\u8217\'3fs fine, penalty, surcharge, or court cost is deemed delinquent as provided in }}}{{\f5\fs18\hyphpar0\qj{section 602.8107, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and the person\u8217\'3fs driver\u8217\'3fs license has been suspended pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.210A}}}{{\f5\fs18\hyphpar0\qj{, or the clerk of the district court has reported the delinquency to the department as required by }}}{{\f5\fs18\hyphpar0\qj{section 321.210A}}}{{\f5\fs18\hyphpar0\qj{, the person may execute an installment agreement as defined in }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{ with the county attorney, the county attorney\u8217\'3fs designee, or the department of revenue, to pay the delinquent amount and the civil penalty assessed in }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{ in installments. Prior to execution of the installment agreement, the person shall provide the county attorney, the county attorney\u8217\'3fs designee, or the department of revenue with a financial statement in order for the parties to the agreement to determine the amount of the installment payments.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cases involving court debt assigned to a county attorney, a county attorney\u8217\'3fs designee, or the department of revenue shall remain so assigned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person enters into an installment agreement with the county attorney or the county attorney\u8217\'3fs designee, the person shall execute an installment agreement in the county where the fine, penalty, surcharge, or court cost was imposed. If the county where the fine, penalty, surcharge, or court cost was imposed does not have an installment agreement program, the person shall execute an installment agreement in the person\u8217\'3fs county of residence. If the county of residence does not have an installment agreement program, the person may execute an installment agreement with any county attorney or county attorney\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney, the county attorney\u8217\'3fs designee, or the department of revenue shall file or give notice of the installment agreement with the clerk of the district court in the county where the fine, penalty, surcharge, or court cost was imposed, within five days of execution of the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of an executed installment agreement and after the first installment payment, the clerk of the district court shall report the receipt of the executed installment agreement to the department of transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of the report from the clerk of the district court and payment of the reinstatement fee as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.191}}}{{\f5\fs18\hyphpar0\qj{, the department shall terminate the suspension if the suspension has not yet become effective. If the suspension has become effective, the department shall immediately reinstate the driver\u8217\'3fs license of the person unless the driver\u8217\'3fs license of the person is otherwise suspended, revoked, denied, or barred under another provision of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a driver\u8217\'3fs license is reinstated upon receipt of a report of an executed installment agreement the driver shall provide proof of financial responsibility pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321A.17}}}{{\f5\fs18\hyphpar0\qj{, if otherwise required by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A civil penalty assessed pursuant to section }}}{{\f5\fs18\hyphpar0\qj{321J.17}}}{{\f5\fs18\hyphpar0\qj{ shall be added to the amount owing under the installment agreement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court shall transmit to the department, from the first moneys collected, an amount equal to the amount of any civil penalty assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.17}}}{{\f5\fs18\hyphpar0\qj{ and added to the installment agreement. The department shall transmit the money received from the clerk of the district court pursuant to this paragraph to the treasurer of state who shall deposit one-half of the money in the separate fund established in }}}{{\f5\fs18\hyphpar0\qj{section 915.94}}}{{\f5\fs18\hyphpar0\qj{ and one-half of the money in the general fund of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, upon determination by the county attorney, the county attorney\u8217\'3fs designee, or the department of revenue that the person is in default, the county attorney, the county attorney\u8217\'3fs designee, or the department of revenue shall notify the clerk of the district court.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is in default and the person provides a new financial statement within fifteen days of the determination made pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ indicating that the person\u8217\'3fs financial condition has changed to such an extent that lower installment payments would have been required prior to the execution of the initial installment agreement under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the county attorney, the county attorney\u8217\'3fs designee, or the department of revenue shall not notify the clerk of the district court, and the person shall not be considered in default. The new installment payments shall be based upon the new financial statement filed in compliance with this subparagraph.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person making new installment payments after complying with the provisions of subparagraph (1) shall not be considered executing a new installment agreement for purposes of calculating the number of installment agreements a person may execute in a person\u8217\'3fs lifetime under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court, upon receipt of a notification of a default from the county attorney, the county attorney\u8217\'3fs designee, or the department of revenue, shall report the default to the department of transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a report of a default from the clerk of the district court, the department shall suspend the driver\u8217\'3fs license of a person as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.210A}}}{{\f5\fs18\hyphpar0\qj{. For purposes of suspension and reinstatement of the driver\u8217\'3fs license of a person in default, the suspension and any subsequent reinstatement shall be considered a suspension pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.210A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a new fine, penalty, surcharge, or court cost is imposed on a person after the person has executed an installment agreement with the county attorney, the county attorney\u8217\'3fs designee, or the department of revenue, and the new fine, penalty, surcharge, or court cost is deemed delinquent as provided in }}}{{\f5\fs18\hyphpar0\qj{section 602.8107, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and the person\u8217\'3fs driver\u8217\'3fs license has been suspended pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.210A}}}{{\f5\fs18\hyphpar0\qj{, the person may enter into a second installment agreement with the county attorney, county attorney\u8217\'3fs designee, or the department of revenue to pay the delinquent amount and the civil penalty, if assessed, in }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{ in installments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is eligible to enter into five installment agreements in the person\u8217\'3fs lifetime.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for a civil penalty assessed and collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{, any amount collected under the installment agreement by the county attorney or the county attorney\u8217\'3fs designee shall be distributed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 602.8107, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and any amount collected by the department of revenue shall be deposited with the clerk of the district court for distribution under }}}{{\f5\fs18\hyphpar0\qj{section 602.8108}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 196, \'a72, 17}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1018, \'a723, 31}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 138, \'a791, 161, 162}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1119, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a751, 86, 92, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210A}}}{{\f5\fs12\hyphpar0\qj{, 321J.17}}}{{\f5\fs12\hyphpar0\qj{, 331.756(5)(d)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.210C}}}{\*\bkmkstart stylerid1_2E244_2E2_2E2}{\*\bkmkend stylerid1_2E244_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Probation period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person whose driver\u8217\'3fs license or operating privileges have been suspended, revoked, or barred under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for a conviction of a moving traffic violation, or suspended, revoked, or barred under }}}{{\f5\fs18\hyphpar0\qj{section 321.205}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (5), must satisfactorily complete a twelve-month probation period beginning immediately after the end of the period of suspension, revocation, or bar. Upon a second conviction of a moving traffic violation which occurred during the probation period, the department may suspend the driver\u8217\'3fs license or operating privileges for an additional period equal in duration to the original period of suspension, revocation, or bar, or for one year, whichever is the shorter period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person whose driver\u8217\'3fs license or operating privileges have been revoked under }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{, must satisfactorily complete a twelve-month probation period beginning immediately after the end of the period of revocation. Upon conviction of a moving traffic violation which occurs during the probation period, the department may revoke the driver\u8217\'3fs license or operating privileges for an additional period equal in duration to the original period of revocation, or for one year, whichever is the shorter period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of determining a conviction under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the department shall not consider the first two speeding violations within the probation period that are ten miles per hour or less over the legal speed limit in speed zones having a legal speed limit between thirty-four miles per hour and fifty-six miles per hour.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1112, \'a710, 14, 16}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a789}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 196, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7173}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.210D}}}{\*\bkmkstart stylerid1_2E245_2E2_2E2}{\*\bkmkend stylerid1_2E245_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vehicular homicide suspension \u8212\'3f termination upon revocation of license \u8212\'3f reopening of suspension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a trial information or indictment is filed charging a person with the offense of homicide by vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 707.6A, subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{, the clerk of the district court shall, upon the filing of the information or indictment, forward notice to the department including the name and address of the party charged, the registration number of the vehicle involved, if known, the nature of the offense, and the date of the filing of the indictment or information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving notice from the clerk of the district court that an indictment or information has been filed charging an operator with homicide by vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 707.6A, subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{, the department shall notify the person that the person\u8217\'3fs driver\u8217\'3fs license will be suspended effective ten days from the date of issuance of the notice. The department shall adopt rules relating to the suspension of the license of an operator pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ which shall include, but are not limited to, procedures for the surrender of the person\u8217\'3fs license to the department upon the effective date of the suspension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person whose driver\u8217\'3fs license has been suspended pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not convicted of the charge of homicide by vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 707.6A, subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{, upon record entry of disposition of the charge, the clerk of the district court shall forward a notice including the name and address of the party charged, the registration number of the vehicle involved, the nature of the offense charged by indictment or information, the date of the filing of the indictment or information, and of the disposition of the charge to the department. Upon receipt of the notice from the clerk, the department shall automatically rescind the suspension and reinstate the person\u8217\'3fs driver\u8217\'3fs license without payment of any charge or penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving a record of conviction under }}}{{\f5\fs18\hyphpar0\qj{section 321.206}}}{{\f5\fs18\hyphpar0\qj{, for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 707.6A, subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{, and upon revocation of the person\u8217\'3fs license or operating privileges under }}}{{\f5\fs18\hyphpar0\qj{section 321.209}}}{{\f5\fs18\hyphpar0\qj{, the suspension under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall automatically terminate in favor of the revocation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1088, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1133, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321A.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.211}}}{\*\bkmkstart stylerid1_2E246_2E2_2E2}{\*\bkmkend stylerid1_2E246_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice and hearing \u8212\'3f appropriation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon suspending the license of a person as authorized, the department shall immediately notify the licensee in writing and upon the licensee\u8217\'3fs request shall afford the licensee an opportunity for a hearing before the department of inspections, appeals, and licensing as early as practical within thirty days after receipt of the request. The hearing shall be held by telephone conference unless the licensee and the department of inspections, appeals, and licensing agree to hold the hearing in the county in which the licensee resides or in some other county. Upon the hearing the department of inspections, appeals, and licensing may administer oaths and issue subpoenas for the attendance of witnesses and the production of relevant books and papers and may require a reexamination of the licensee. Upon the hearing and issuance of a recommendation by the department of inspections, appeals, and licensing, the state department of transportation shall either rescind its order of suspension or for good cause may extend the suspension of the license or revoke the license. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not preclude the director from attempting to effect an informal settlement under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is appropriated each year from the road use tax fund to the department of transportation two hundred twenty-five thousand dollars or as much thereof as is necessary to be used to pay the cost of notice and personal delivery of service, as necessary to meet the notice requirement of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The department shall adopt rules governing the payment of the cost of personal delivery of service. The reinstatement fees collected under }}}{{\f5\fs18\hyphpar0\qj{section 321.191}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited in the road use tax fund in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.145}}}{{\f5\fs18\hyphpar0\qj{, as reimbursement for the costs of notice under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer stopping a person for whom a notice of a suspension or revocation has been issued or to whom a notice of a hearing has been sent under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may personally serve such notice upon forms approved by the department to satisfy the notice requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The peace officer may confiscate the driver\u8217\'3fs license of such person if the license has been revoked or has been suspended subsequent to a hearing and the person has not forwarded the driver\u8217\'3fs license to the department as required.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d36; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.211}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 14, \'a724}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 198, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 273, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 317, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1267, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1238, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71966}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.211A}}}{\*\bkmkstart stylerid1_2E247_2E2_2E2}{\*\bkmkend stylerid1_2E247_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal of extended suspension or revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding any provision of law to the contrary, if a person was not served with notice of a suspension or revocation under }{{\f5\fs18\hyphpar0\qj{section 321.16}}}{, or }{{\f5\fs18\hyphpar0\qj{section 321J.9, subsection 4}}}{, or }{{\f5\fs18\hyphpar0\qj{section 321J.12, subsection 3}}}{, the person may appeal to the department an extension of the period of suspension or revocation based upon a conviction under }{{\f5\fs18\hyphpar0\qj{section 321.218}}}{ or }{{\f5\fs18\hyphpar0\qj{321J.21}}}{. At the hearing on the appeal, the sole issue shall be whether the department failed to send notice of the underlying suspension or revocation to the person at the address contained in the department\u8217\'3fs records. If the department determines it failed to send such notice, the department shall rescind the extended suspension or revocation resulting from the conviction and send notice of the department\u8217\'3fs determination to the court that rendered the conviction. Upon receipt of the notice, the court shall enter an order exonerating the person of the conviction and ordering that the record of the conviction be expunged by the clerk of the district court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 32, \'a745}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.212}}}{\*\bkmkstart stylerid1_2E248_2E2_2E2}{\*\bkmkend stylerid1_2E248_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Period of suspension or revocation \u8212\'3f surrender of license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.210A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.513}}}{{\f5\fs18\hyphpar0\qj{ the department shall not suspend a license for a period of more than one year, except that a license suspended because of incompetency to drive a motor vehicle shall be suspended until the department receives satisfactory evidence that the former holder is competent to operate a motor vehicle and a refusal to reinstate constitutes a denial of license within }}}{{\f5\fs18\hyphpar0\qj{section 321.215}}}{{\f5\fs18\hyphpar0\qj{; upon revoking a license the department shall not grant an application for a new license until the expiration of one year after the revocation, unless another period is specified by law.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A suspension under }}}{{\f5\fs18\hyphpar0\qj{section 321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (4), for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.216B}}}{{\f5\fs18\hyphpar0\qj{ shall not exceed six months. As soon as practicable after the period of suspension has expired, but not later than six months after the date of expiration, the department shall expunge information regarding the suspension from the person\u8217\'3fs driving record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not revoke a license under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.209, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, for more than thirty days nor less than five days as recommended by the trial court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall revoke a license for six months for a first offense under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.209, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, where the violation charged did not result in a personal injury or damage to property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department upon suspending or revoking a driver\u8217\'3fs license shall require that the license be surrendered to and be retained by the department. At the end of the period of suspension the license surrendered shall be reissued to the licensee upon payment of the reinstatement fee under }}}{{\f5\fs18\hyphpar0\qj{section 321.191}}}{{\f5\fs18\hyphpar0\qj{. At the end of a period of revocation the licensee must apply for a new driver\u8217\'3fs license.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d40, -d42, -d45; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.12, 5014.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.212}}}{, }{{\f5\fs18\hyphpar0\qj{321.213}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1167, \'a73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 197, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 16, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 164, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1218, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a796, 104}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.213}}}{\*\bkmkstart stylerid1_2E249_2E2_2E2}{\*\bkmkend stylerid1_2E249_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License suspensions or revocations due to violations by juvenile drivers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the entering of a dispositional order suspending or revoking the driver\u8217\'3fs license or operating privileges of the juvenile under }{{\f5\fs18\hyphpar0\qj{section 232.52, subsection 2}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{, the clerk of the juvenile court shall forward a copy of the adjudication and the dispositional order to the department. Notwithstanding }{{\f5\fs18\hyphpar0\qj{section 232.55}}}{, a final adjudication in a juvenile court that the child violated a provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or }{{\f5\fs18\hyphpar0\qj{chapter 321A}}}{ or }{{\f5\fs18\hyphpar0\qj{321J}}}{ constitutes a final conviction for purposes of }{{\f5\fs18\hyphpar0\qj{section 321.189, subsection 7}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{, and }{{\f5\fs18\hyphpar0\qj{sections 321.193}}}{, }{{\f5\fs18\hyphpar0\qj{321.194}}}{, }{{\f5\fs18\hyphpar0\qj{321.200}}}{, }{{\f5\fs18\hyphpar0\qj{321.209}}}{, }{{\f5\fs18\hyphpar0\qj{321.210}}}{, }{{\f5\fs18\hyphpar0\qj{321.215}}}{, }{{\f5\fs18\hyphpar0\qj{321.555}}}{, }{{\f5\fs18\hyphpar0\qj{321A.17}}}{, }{{\f5\fs18\hyphpar0\qj{321J.2}}}{, }{{\f5\fs18\hyphpar0\qj{321J.3}}}{, and }{{\f5\fs18\hyphpar0\qj{321J.4}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1070, \'a71}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C83, \'a7321.213}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a733}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a732}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a757}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 16, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 87, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 55, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1218, \'a761}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.147}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.213A}}}{\*\bkmkstart stylerid1_2E25_30_2E2_2E2}{\*\bkmkend stylerid1_2E25_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License suspension for juveniles adjudicated delinquent for certain drug or alcohol offenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the entering of a dispositional order under }{{\f5\fs18\hyphpar0\qj{section 232.52, subsection 2}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{, the clerk of the juvenile court shall forward a copy of the adjudication and the dispositional order suspending or revoking the driver\u8217\'3fs license or operating privileges of the juvenile to the department. The department shall suspend the license or operating privilege of the child for one year. The child may receive a temporary restricted license, if eligible, as provided in }{{\f5\fs18\hyphpar0\qj{section 321.215}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1172, \'a734}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 55, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1034, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1218, \'a762}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 132, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.147}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.213B}}}{\*\bkmkstart stylerid1_2E251_2E2_2E2}{\*\bkmkend stylerid1_2E251_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspension for failure to attend.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall establish procedures by rule for suspending the license of a juvenile who has been issued a driver\u8217\'3fs license and is not in compliance with the requirements of }{{\f5\fs18\hyphpar0\qj{section 299.1B}}}{ and issuing the juvenile a restricted work license under }{{\f5\fs18\hyphpar0\qj{section 321.178}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1172, \'a735}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1152, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 8, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1166, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.215}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.214}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.215}}}{\*\bkmkstart stylerid1_2E253_2E2_2E2}{\*\bkmkend stylerid1_2E253_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Temporary restricted license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, on application, may issue a temporary restricted license to a person whose noncommercial driver\u8217\'3fs license is suspended or revoked under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, allowing the person to drive to and from the person\u8217\'3fs home and specified places at specified times which can be verified by the department and which are required by any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs full-time or part-time employment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs continuing health care or the continuing health care of another who is dependent upon the person.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs continuing education while enrolled in an educational institution on a part-time or full-time basis and while pursuing a course of study leading to a diploma, degree, or other certification of successful educational completion.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs substance use disorder treatment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs court-ordered community service responsibilities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs appointments with the person\u8217\'3fs parole or probation officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, a temporary restricted license shall not be issued to a person whose license is revoked pursuant to a court order issued under }}}{{\f5\fs18\hyphpar0\qj{section 321.209, subsections 1 through 5}}}{{\f5\fs18\hyphpar0\qj{; to a juvenile whose license has been suspended or revoked pursuant to a dispositional order under }}}{{\f5\fs18\hyphpar0\qj{section 232.52, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for a violation of }}}{{\f5\fs18\hyphpar0\qj{chapter 124}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{453B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 126.3}}}{{\f5\fs18\hyphpar0\qj{; to a juvenile whose license has been suspended under }}}{{\f5\fs18\hyphpar0\qj{section 321.213B}}}{{\f5\fs18\hyphpar0\qj{; or to a person whose license has been suspended pursuant to a court order under }}}{{\f5\fs18\hyphpar0\qj{section 714.7D}}}{{\f5\fs18\hyphpar0\qj{. A temporary restricted license may be issued to a person whose license is revoked under }}}{{\f5\fs18\hyphpar0\qj{section 321.209, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, only if the person has no previous drag racing convictions. A person holding a temporary restricted license issued by the department under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not operate a motor vehicle for pleasure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon conviction and the suspension or revocation of a person\u8217\'3fs noncommercial driver\u8217\'3fs license under }}}{{\f5\fs18\hyphpar0\qj{section 321.209, subsection 5, 6, or 7,}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 321.210}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.210A}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.513}}}{{\f5\fs18\hyphpar0\qj{; or upon the denial of issuance of a noncommercial driver\u8217\'3fs license under }}}{{\f5\fs18\hyphpar0\qj{section 321.560}}}{{\f5\fs18\hyphpar0\qj{, based solely on offenses enumerated in }}}{{\f5\fs18\hyphpar0\qj{section 321.555, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 321.555, subsection 2}}}{{\f5\fs18\hyphpar0\qj{; or upon suspension or revocation of a juvenile\u8217\'3fs driver\u8217\'3fs license pursuant to a dispositional order under }}}{{\f5\fs18\hyphpar0\qj{section 232.52, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for a violation of }}}{{\f5\fs18\hyphpar0\qj{chapter 124}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{453B}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 126.3}}}{{\f5\fs18\hyphpar0\qj{; or upon suspension of a driver\u8217\'3fs license pursuant to a court order under }}}{{\f5\fs18\hyphpar0\qj{section 714.7D}}}{{\f5\fs18\hyphpar0\qj{, the person may apply to the department for a temporary restricted license to operate a motor vehicle for the limited purpose or purposes specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The application may be granted only if all of the following criteria are satisfied:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The temporary restricted license is requested only for a case of hardship or circumstances where alternative means of transportation do not exist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The temporary restricted license is restricted to the limited purpose or purposes specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ at times specified in the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proof of financial responsibility is established as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 321A}}}{{\f5\fs18\hyphpar0\qj{. However, such proof is not required if the driver\u8217\'3fs license was suspended under }}}{{\f5\fs18\hyphpar0\qj{section 321.210A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.513}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The temporary restricted license shall be canceled upon conviction of a moving traffic violation or upon a violation of a term of the license. A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmoving traffic violation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a parking violation as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.210}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The temporary restricted license is not valid to operate a commercial motor vehicle if a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit is required for the person\u8217\'3fs operation of the commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the department may issue a temporary restricted license to a person eligible for a temporary restricted license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the person is also eligible for a temporary restricted license under }}}{{\f5\fs18\hyphpar0\qj{section 321J.20}}}{{\f5\fs18\hyphpar0\qj{, provided the requirements of }}}{{\f5\fs18\hyphpar0\qj{ this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 321J.20}}}{{\f5\fs18\hyphpar0\qj{ are satisfied.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d43, -d44; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5014.15;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.215}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1022, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1219, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 16, \'a77 \u8211\'3f 9}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 55, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 143, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1218, \'a763 \u8211\'3f 65}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a78 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 141, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 196, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1097, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a734, 68}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a797 \u8211\'3f 99, 104}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71061}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 42, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.212}}}{{\f5\fs12\hyphpar0\qj{, 321.213}}}{{\f5\fs12\hyphpar0\qj{, 321.213A}}}{{\f5\fs12\hyphpar0\qj{, 321.560}}}{{\f5\fs12\hyphpar0\qj{, 321.561}}}{{\f5\fs12\hyphpar0\qj{, 321J.20}}}{{\f5\fs12\hyphpar0\qj{, 321J.20A}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E254_2E1_2E1}{LICENSES AND NONOPERATOR\u8217\'3fS}{\*\bkmkend stylerid1_2E254_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{IDENTIFICATION CARDS \u8212\'3f VIOLATIONS}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.216}}}{\*\bkmkstart stylerid1_2E255_2E2_2E2}{\*\bkmkend stylerid1_2E255_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unlawful use of license or nonoperator\u8217\'3fs identification card \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 4}}}{, for any person:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To display or cause or permit to be displayed or have in the person\u8217\'3fs possession a canceled, revoked, suspended, fictitious, or fraudulently altered driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To lend that person\u8217\'3fs driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card to another person or knowingly permit the use of the license by another.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To display or represent as one\u8217\'3fs own a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card not issued to that person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To fail or refuse to surrender to the department upon its lawful demand a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card which has been suspended, revoked, or canceled.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To permit an unlawful use of a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card issued to that person.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d46, -d52; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5015.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.216}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 84, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1090, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a752, 59}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a740}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.48}}}{{\f5\fs12\hyphpar0\qj{, 453A.4}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(4)(g)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.216A}}}{\*\bkmkstart stylerid1_2E256_2E2_2E2}{\*\bkmkend stylerid1_2E256_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Falsifying driver\u8217\'3fs licenses, nonoperator\u8217\'3fs identification cards, or forms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is a serious misdemeanor for a person to do any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make a driver\u8217\'3fs license, a nonoperator\u8217\'3fs vehicle identification card, or a blank driver\u8217\'3fs license form if the person has no authority or right to make the license, card, or form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Obtain, possess, or have in the person\u8217\'3fs control or on the person\u8217\'3fs premises, driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card forms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Obtain, possess, or have in the person\u8217\'3fs control or on the person\u8217\'3fs premises, a driver\u8217\'3fs license or a nonoperator\u8217\'3fs identification card, or blank driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card form, which has been made by a person having no authority or right to make the license, card, or form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Use a false or fictitious name in any application for a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card or to knowingly make a false statement or knowingly conceal a material fact or otherwise commit fraud on an application.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 84, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1090, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79, 10}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.48}}}{{\f5\fs12\hyphpar0\qj{, 453A.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.216B}}}{\*\bkmkstart stylerid1_2E257_2E2_2E2}{\*\bkmkend stylerid1_2E257_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card by underage person to obtain alcohol.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is under the age of twenty-one, who alters or displays or has in the person\u8217\'3fs possession a fictitious or fraudulently altered driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card and who uses the license to violate or attempt to violate }}}{{\f5\fs18\hyphpar0\qj{section 123.47}}}{{\f5\fs18\hyphpar0\qj{, commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{. The court shall forward a copy of the conviction to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be charged or prosecuted for a violation of this section if the person is immune from charge or prosecution pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 701.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 164, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1090, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1100, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a753, 59}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1080, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.48}}}{{\f5\fs12\hyphpar0\qj{, 321.212}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}{{\f5\fs12\hyphpar0\qj{, 701.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(4)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Legislative intent regarding effect on insurance rates; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/93/CH0164.pdf" }{\fldrslt \cf5 \f5 \fs12{{93 Acts, ch 164, \'a76}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.216C}}}{\*\bkmkstart stylerid1_2E258_2E2_2E2}{\*\bkmkend stylerid1_2E258_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card by underage person to obtain tobacco, tobacco products, alternative nicotine products, vapor products, or cigarettes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person who is under the age of twenty-one, who alters or displays or has in the person\u8217\'3fs possession a fictitious or fraudulently altered driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card and who uses the license or card to violate or attempt to violate }{{\f5\fs18\hyphpar0\qj{section 453A.2, subsection 2}}}{, commits a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 4}}}{. The court shall forward a copy of the conviction to the department.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1105, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a754, 59}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1106, \'a71, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7453A.4}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(4)(i)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.217}}}{\*\bkmkstart stylerid1_2E259_2E2_2E2}{\*\bkmkend stylerid1_2E259_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Perjury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who makes any false affidavit, or knowingly swears or affirms falsely to any matter or thing required by the terms of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to be sworn to or affirmed, is guilty of a class \u8220\'3fD\u8221\'3f felony.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d47; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5015.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.217}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Perjury, }{{\f5\fs12\hyphpar0\qj{\'a7720.2}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.218}}}{\*\bkmkstart stylerid1_2E26_30_2E2_2E2}{\*\bkmkend stylerid1_2E26_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operating without valid driver\u8217\'3fs license or when disqualified \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person whose driver\u8217\'3fs license or operating privilege has been denied, canceled, suspended, or revoked as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or as provided in }}}{{\f5\fs18\hyphpar0\qj{section 252J.8}}}{{\f5\fs18\hyphpar0\qj{, and who operates a motor vehicle upon the highways of this state while the license or privilege is denied, canceled, suspended, or revoked, commits a simple misdemeanor. In addition to any other penalties, the punishment imposed for a violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall include assessment of a fine of not less than two hundred fifty dollars nor more than one thousand five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sentence imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be suspended by the court, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{ or any other statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, upon receiving the record of the conviction of a person under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ upon a charge of operating a motor vehicle while the license of the person is suspended or revoked, shall, except for licenses suspended under }}}{{\f5\fs18\hyphpar0\qj{section 252J.8}}}{{\f5\fs18\hyphpar0\qj{, section }}}{{\f5\fs18\hyphpar0\qj{321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), or }}}{{\f5\fs18\hyphpar0\qj{section 321.210A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.513}}}{{\f5\fs18\hyphpar0\qj{, extend the period of suspension or revocation for an additional like period or for one year, whichever period is shorter.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department receives a record of a conviction of a person under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ but the person\u8217\'3fs driving record does not indicate what the original grounds of suspension were, the period of suspension under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be for a period not to exceed six months.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who operates a commercial motor vehicle upon the highways of this state when disqualified from operating the commercial motor vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 321.208}}}{{\f5\fs18\hyphpar0\qj{ or the imminent hazard provisions of }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7383.52}}}{{\f5\fs18\hyphpar0\qj{ commits a serious misdemeanor if a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit is required for the person to operate the commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, upon receiving the record of a conviction of a person under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ upon a charge of operating a commercial motor vehicle while the person is disqualified, shall extend the period of disqualification for an additional like period or for the time period specified in }}}{{\f5\fs18\hyphpar0\qj{section 321.208}}}{{\f5\fs18\hyphpar0\qj{, whichever is longer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d34, -d51; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5015.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.218}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1167, \'a74}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1142, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 195, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1220, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 83, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 164, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1090, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 153, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1030, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7174}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a7100, 104}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 98, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.211A}}}{{\f5\fs12\hyphpar0\qj{, 321.241}}}{{\f5\fs12\hyphpar0\qj{, 321J.4B}}}{{\f5\fs12\hyphpar0\qj{, 321N.3}}}{{\f5\fs12\hyphpar0\qj{, 901C.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.218A}}}{\*\bkmkstart stylerid1_2E261_2E2_2E2}{\*\bkmkend stylerid1_2E261_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil penalty \u8212\'3f disposition \u8212\'3f reinstatement.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1074, \'a754, 93}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.219}}}{\*\bkmkstart stylerid1_2E262_2E2_2E2}{\*\bkmkend stylerid1_2E262_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Permitting unauthorized minor to drive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not cause or knowingly permit the person\u8217\'3fs child or protected person under the age of eighteen years to drive a motor vehicle upon any highway when the minor is not authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d48; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5015.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.219}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1203, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7152}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1009, \'a749}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(4)(j)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.220}}}{\*\bkmkstart stylerid1_2E263_2E2_2E2}{\*\bkmkend stylerid1_2E263_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Permitting unauthorized person to drive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not knowingly authorize or permit a motor vehicle owned by the person or under the person\u8217\'3fs control to be driven upon a highway by a person who is not issued a driver\u8217\'3fs license valid for the vehicle\u8217\'3fs operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d50; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5015.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.220}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a744}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(4)(k)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.221}}}{\*\bkmkstart stylerid1_2E264_2E2_2E2}{\*\bkmkend stylerid1_2E264_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employing unlicensed chauffeur.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not employ as a chauffeur of a motor vehicle a person not then holding a class D driver\u8217\'3fs license or a commercial driver\u8217\'3fs license as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d49; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5015.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.221}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a762}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.222}}}{\*\bkmkstart stylerid1_2E265_2E2_2E2}{\*\bkmkend stylerid1_2E265_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Renting motor vehicle to another.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person shall rent a motor vehicle to any other person unless the latter person is then duly licensed hereunder or, in the case of a nonresident, then duly licensed under the laws of the state or country of residence except a nonresident whose home state or country does not require that an operator be licensed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5015.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.222}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.223}}}{\*\bkmkstart stylerid1_2E266_2E2_2E2}{\*\bkmkend stylerid1_2E266_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driver\u8217\'3fs license inspection for motor vehicle rental.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not rent a motor vehicle to another person without inspecting the driver\u8217\'3fs license of the person to whom the vehicle is to be rented and doing all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A comparison and verification of the signature on the driver\u8217\'3fs license with the signature of such person written in the inspecting person\u8217\'3fs presence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A comparison and verification of the person to whom the motor vehicle is to be rented with the photograph and other identification information on the person\u8217\'3fs driver\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A determination that the driver\u8217\'3fs license of the person to whom the vehicle is to be rented is valid for operating the vehicle to be rented.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5015.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.223}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a763}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.224}}}{\*\bkmkstart stylerid1_2E267_2E2_2E2}{\*\bkmkend stylerid1_2E267_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record kept.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every person renting a motor vehicle to another shall keep a record of the registration number of the motor vehicle so rented, the name and address of the person to whom the vehicle is rented, the number of the license of the latter person and the date and place when and where the license was issued. The record shall be open to inspection by any peace officer as defined in }{{\f5\fs18\hyphpar0\qj{section 801.4, subsection 11}}}{, paragraphs }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f, \u8220\'3fb\u8221\'3f, \u8220\'3fc\u8221\'3f}}}{ and }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{ or employee of the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5015.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.224}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 103, \'a73}}}{]}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.225 through 321.227}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E269_2E1_2E1}{OBEDIENCE TO AND EFFECT OF}{\*\bkmkend stylerid1_2E269_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{TRAFFIC LAWS}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.228}}}{\*\bkmkstart stylerid1_2E27_30_2E2_2E2}{\*\bkmkend stylerid1_2E27_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Provisions refer to highways \u8212\'3f exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ relating to the operation of vehicles refer exclusively to the operation of vehicles upon highways except:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where a different place is specifically referred to in a given section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 321.261 through 321.273}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{sections 321.277}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.280}}}{{\f5\fs18\hyphpar0\qj{ shall apply upon highways and elsewhere throughout the state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5017.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.228}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1178, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a791}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.229}}}{\*\bkmkstart stylerid1_2E271_2E2_2E2}{\*\bkmkend stylerid1_2E271_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Obedience to peace officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person shall willfully fail or refuse to comply with any lawful order or direction of any peace officer invested by law with authority to direct, control, or regulate traffic.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75064; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5017.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.229}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(14)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 14, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.230}}}{\*\bkmkstart stylerid1_2E272_2E2_2E2}{\*\bkmkend stylerid1_2E272_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public officers not exempt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ applicable to the drivers of vehicles upon the highways shall apply to the drivers of all vehicles owned or operated by the United States, this state or any county, city, district, or any other political subdivision of the state, subject to such specific exceptions as are set forth in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ with reference to authorized emergency vehicles.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5017.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.230}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.231}}}{\*\bkmkstart stylerid1_2E273_2E2_2E2}{\*\bkmkend stylerid1_2E273_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authorized emergency vehicles and police bicycles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of an authorized emergency vehicle, when responding to an emergency call or when in the pursuit of an actual or suspected perpetrator of a felony or misdemeanor, or in response to an incident dangerous to the public, or when responding to but not upon returning from a fire alarm, may exercise the privileges set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of any authorized emergency vehicle, may:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Park or stand an authorized emergency vehicle, irrespective of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disregard laws or regulations governing direction of movement for the minimum distance necessary before an alternative route that conforms to the traffic laws and regulations is available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Drive the vehicle on the shoulder or median of a highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disregard laws or regulations governing turning the vehicle in specified directions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Disregard laws or regulations governing overtaking or passing other motorists.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of an official fire department vehicle, police vehicle, rescue vehicle, ambulance, emergency medical services vehicle, or emergency management vehicle, or a peace officer riding a police bicycle in the line of duty, may do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proceed past a red or stop signal or stop sign, but only after slowing down to or maintaining a speed deemed necessary for safe operation by the driver based on information known to the driver at the time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exceed the maximum speed limits so long as the driver does not recklessly endanger life or property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer operating an authorized emergency vehicle may execute a pursuit intervention technique if such execution is reasonable under the circumstances based on the information perceived by the officer at the time, and the officer has completed a training course approved by the Iowa law enforcement academy that instructs participants in the proper execution of pursuit intervention techniques. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpursuit intervention technique\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a method by which a peace officer operating a motor vehicle in pursuit of a fleeing motor vehicle causes or attempts to cause the fleeing motor vehicle to stop, including by use of reasonable force. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to limit a peace officer\u8217\'3fs objectively reasonable use of force in connection with a pursuit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The exemptions granted to the driver of an authorized emergency vehicle under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ and to the driver of an official fire department vehicle, police vehicle, rescue vehicle, ambulance, emergency medical services vehicle, or emergency management vehicle as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall apply only when such vehicle is making use of an audible warning device meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.433}}}{{\f5\fs18\hyphpar0\qj{ or a visual signaling device authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The exemption granted under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be granted to a peace officer or reserve peace officer operating an authorized emergency vehicle without using an audible warning device or visual signaling device if such action occurs over the shortest distance necessary, does not recklessly endanger persons or property, and if the officer is pursuing a suspected violator of the speed restrictions imposed by or pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the purpose of determining the speed of travel of such suspected violator, or if the officer reasonably believes based on the facts and circumstances at the time that a suspected violator\u8217\'3fs knowledge of the officer\u8217\'3fs proximity may cause the suspected violator to destroy evidence of a suspected felony or aggravated misdemeanor, evade apprehension, or endanger the public or the officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The exemption granted under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be granted to the driver of an authorized emergency vehicle transporting a patient to a hospital without using a visual signaling device or audible warning device if a certified emergency medical care provider reasonably believes the patient\u8217\'3fs condition warrants rapid transport.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not relieve the driver of an authorized emergency vehicle or the rider of a police bicycle from the duty to drive or ride with due regard for the safety of all persons, nor shall such provisions protect the driver or rider from the consequences of the driver\u8217\'3fs or rider\u8217\'3fs reckless disregard for the safety of others.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5017.04, 5017.05, 5023.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7321.231, 321.232, 321.296; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.231}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 71, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1080, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1100, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a7118}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1022, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1087, \'a71 \u8211\'3f 4, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.231C}}}{{\f5\fs12\hyphpar0\qj{, 613.17}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(11)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 11}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.231A}}}{\*\bkmkstart stylerid1_2E274_2E2_2E2}{\*\bkmkend stylerid1_2E274_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authorized emergency vehicles }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ parades and events.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of an authorized emergency vehicle may operate the vehicle as part of an official governmental event for the purposes of the safety and security of an elected official, candidate for public office, or the public, or as part of a parade or other public service event if the parade or event is approved by the state or a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, at least one day prior to the date on which the parade or event will occur.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of law to the contrary, an authorized emergency vehicle operating in a parade or event may display any of the vehicle\u8217\'3fs lighting devices. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to exempt the driver of the authorized emergency vehicle from any duty to operate the vehicle with due regard for the safety of all persons.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1087, \'a75, 11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.231B}}}{\*\bkmkstart stylerid1_2E275_2E2_2E2}{\*\bkmkend stylerid1_2E275_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authorized emergency vehicles }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ immunity from liability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following shall not be liable for the consequence of any injury or loss arising from the operation of an authorized emergency vehicle in response to an emergency call or to an incident dangerous to the public unless the driver operates the authorized emergency vehicle with reckless disregard for the safety of persons or property:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fire fighter operating the authorized emergency vehicle who is certified by the fire service training bureau, as described in }}}{{\f5\fs18\hyphpar0\qj{section 100B.6}}}{{\f5\fs18\hyphpar0\qj{, as a fire apparatus driver operator, or an operator who has completed an emergency vehicle operations course and any applicable continuing education requirements established or approved by the fire service training bureau.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An emergency medical care provider, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 147A.1}}}{{\f5\fs18\hyphpar0\qj{, operating the authorized emergency vehicle who has completed an emergency vehicle operations course and any applicable continuing education requirements established or approved by the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{, or a reserve peace officer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 80D.1A}}}{{\f5\fs18\hyphpar0\qj{, operating the authorized emergency vehicle who has completed an emergency vehicle operations course and any applicable continuing education requirements established or approved by the Iowa law enforcement academy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An emergency management agency employee operating the authorized emergency vehicle who has completed an emergency vehicle operations course and any applicable continuing education requirements established or approved by the local or joint emergency management commission, and where the local or joint emergency management commission has adopted a written policy related to emergency vehicle operations. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femergency management agency employee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a member of the personnel, including but not limited to the coordinator, an operations officer, or an emergency management assistant, of a local or joint emergency management commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any entity, including a nonprofit corporation, on whose behalf the fire fighter, emergency medical care provider, peace officer, reserve peace officer, or emergency management agency employee is operating the authorized emergency vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The protections from liability set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ apply only when, in response to an emergency call or to an incident dangerous to the public, the driver operating the authorized emergency vehicle is utilizing a siren meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.433}}}{{\f5\fs18\hyphpar0\qj{ or flashing blue and red lights authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The protections from liability provided by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ apply in addition to any other defense to liability provided by law. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to lower the standard of recklessness to recover against any entity or authorized emergency vehicle driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of an authorized emergency vehicle, and any entity on whose behalf the driver is operating the authorized emergency vehicle, shall not be liable for any injury or loss arising from the operation of the authorized emergency vehicle unless reckless disregard for the safety of persons or property is proven by a preponderance of the evidence.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person brings a tort claim against the driver of an authorized emergency vehicle, a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, this state, or any other entity on whose behalf the driver is operating the authorized emergency vehicle, for any injury or loss arising from the operation of the authorized emergency vehicle, the court shall determine, on motion by any party or on its own motion, whether the person has presented sufficient, admissible evidence to support a prima facie finding of recklessness before the matter proceeds to trial.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1087, \'a76, 11, 12}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71062}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies to causes of action accrued on or after May 24, 2022; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1087, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.231C}}}{\*\bkmkstart stylerid1_2E276_2E2_2E2}{\*\bkmkend stylerid1_2E276_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fire fighters and emergency medical services members responding to emergency situations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 321.231}}}{{\f5\fs18\hyphpar0\qj{, the driver of a vehicle making use of a blue light pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.423, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or displaying fire fighter or emergency medical services registration plates issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34, subsection 10 or 10A}}}{{\f5\fs18\hyphpar0\qj{, may reasonably exceed the maximum speed limits based on the facts and circumstances at the time, only if all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver is a current member of a paid or volunteer fire department or emergency medical services agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver is responding to, but not returning from, an emergency call or fire alarm.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver has received emergency vehicle operations training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not relieve the driver from the duty to drive with due regard for the safety of all other persons, nor shall such provisions protect the driver from the consequences of the driver\u8217\'3fs reckless disregard for the safety of others.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court shall dismiss and expunge from a driver\u8217\'3fs record any excessive speed violation citations issued to a driver under circumstances in which the driver complied with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, if the driver presents to the court a signed statement from the applicable fire chief or chief officer of an emergency medical services agency providing details about the driver\u8217\'3fs operation of the vehicle while responding to an emergency call or fire alarm, which operation resulted in the citation. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a driver who holds a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1089, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.423}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.232}}}{\*\bkmkstart stylerid1_2E277_2E2_2E2}{\*\bkmkend stylerid1_2E277_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{ Speed detection jamming devices }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell, operate, or possess a speed detection jamming device, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, when the device is in a vehicle operated on the highways of this state or the device is held for sale in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to speed measuring devices purchased by, held for purchase for, or operated by peace officers using the devices in performance of their official duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A speed detection jamming device sold, operated, or possessed in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ may be seized by a peace officer and is subject to forfeiture as provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 809}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{809A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{\i\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSpeed detection jamming device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any active or passive device, instrument, mechanism, or equipment that is designed or intended to interfere with, disrupt, or scramble the radar or laser that is used by a peace officer to measure the speed of motor vehicles. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSpeed detection jamming device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include equipment that is legal under federal communications commission regulations, such as a citizens\u8217\'3f band radio, a ham radio, or other similar electronic equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSpeed measuring device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to devices commonly known as radar speed meters or laser speed meters.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{81 Acts, ch 109, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1133, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7158}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(14)(g)}}}{{\f5\fs12\hyphpar0\qj{, 809A.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 14, paragraph g }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.233}}}{\*\bkmkstart stylerid1_2E278_2E2_2E2}{\*\bkmkend stylerid1_2E278_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Road workers exempted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{, except }{{\f5\fs18\hyphpar0\qj{sections 321.277}}}{ and }{{\f5\fs18\hyphpar0\qj{321.280}}}{, does not apply to persons and motor vehicles and other equipment while actually engaged in work upon the surface of a highway officially closed to traffic but does apply to such persons and vehicles when traveling to or from such work. The minimum speed restriction of }{{\f5\fs18\hyphpar0\qj{section 321.285, subsection 5}}}{, and the provisions of }{{\f5\fs18\hyphpar0\qj{sections 321.297}}}{, }{{\f5\fs18\hyphpar0\qj{321.298}}}{, and }{{\f5\fs18\hyphpar0\qj{321.323}}}{ do not apply to road workers operating maintenance equipment on behalf of any state or local authority while engaged in road maintenance, road blading, snow and ice control and removal, and granular resurfacing work on a highway, whether or not the highway is closed to traffic.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5017.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.233}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1154, \'a71}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 167, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a736}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a764}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 104, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a7239}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.234}}}{\*\bkmkstart stylerid1_2E279_2E2_2E2}{\*\bkmkend stylerid1_2E279_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bicycles, animals, or animal-drawn vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person riding an animal or driving an animal drawing a vehicle upon a roadway is subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to the driver of a vehicle, except those provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ which by their nature can have no application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, including a peace officer, riding a bicycle on the highway is subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and has all the rights and duties under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to the driver of a vehicle, except those provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ which by their nature can have no application or those provisions for which specific exceptions have been set forth regarding police bicycles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person propelling a bicycle on the highway shall not ride other than upon or astride a permanent and regular seat attached to the bicycle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not use a bicycle on the highway to carry more persons at one time than the number of persons for which the bicycle is designed and equipped.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the use of a bicycle in a parade authorized by proper permit from local authorities.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5017.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.234}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 40, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 71, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.235B}}}{{\f5\fs12\hyphpar0\qj{, 321.236}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 9 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.234A}}}{\*\bkmkstart stylerid1_2E28_30_2E2_2E2}{\*\bkmkend stylerid1_2E28_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{All-terrain vehicles \u8212\'3f highway use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All-terrain vehicles shall not be operated on a highway unless one or more of the following conditions apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation is between sunrise and sunset and is incidental to the vehicle\u8217\'3fs use for agricultural purposes. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fincidental to the vehicle\u8217\'3fs use for agricultural purposes\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes stopping in the course of agricultural use to obtain fuel for the all-terrain vehicle or to obtain food or a nonalcoholic beverage for the operator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation is incidental to the vehicle\u8217\'3fs use for the purpose of surveying by a licensed engineer or land surveyor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The all-terrain vehicle is operated by an employee or agent of a political subdivision or public utility for the purpose of construction or maintenance on or adjacent to the highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The all-terrain vehicle is operated by an employee or agent of a public agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 34.1}}}{{\f5\fs18\hyphpar0\qj{ for the purpose of providing emergency services or rescue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The all-terrain vehicle is operated for the purpose of mowing, installing approved trail signs, or providing maintenance on a snowmobile or all-terrain vehicle trail designated by the department of natural resources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The all-terrain vehicle is operated on a primary highway in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321I.10, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a secondary road in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321I.10, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, or a city street in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321I.10, subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The all-terrain vehicle is crossing the highway pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321I.10, subsection 7}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating an all-terrain vehicle on a highway shall have a valid driver\u8217\'3fs license and operate the vehicle at speeds of thirty-five miles per hour or less. In addition, a person operating an all-terrain vehicle on a highway pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be at least eighteen years of age and have financial liability coverage in effect for the vehicle and carry proof of such financial liability coverage in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.20B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.1}}}{{\f5\fs18\hyphpar0\qj{, an all-terrain vehicle is a motor vehicle for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. Therefore, an all-terrain vehicle operated on a highway shall be equipped with the parts, lamps, and other equipment in proper condition and adjustment as required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for motor vehicles, including but not limited to the parts, lamps, and equipment required under }}}{{\f5\fs18\hyphpar0\qj{sections 321.386}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.387}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.404}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.432}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{321.437}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An all-terrain vehicle that is owned by the owner of land adjacent to a highway, other than an interstate road, may be operated by the owner of the all-terrain vehicle, or by a member of the owner\u8217\'3fs family, on the portion of the highway right-of-way that is between the shoulder of the roadway, or at least five feet from the edge of the roadway, and the owner\u8217\'3fs property line. A person operating an all-terrain vehicle within the highway right-of-way under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall comply with the registration, safety, and age requirements under }}}{{\f5\fs18\hyphpar0\qj{chapter 321I}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 35, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 108, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1001, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1132, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1036, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 141, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1186, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 32, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1105, \'a71 \u8211\'3f 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321I.1}}}{{\f5\fs12\hyphpar0\qj{, 321I.9}}}{{\f5\fs12\hyphpar0\qj{, 321I.10}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(a)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.235}}}{\*\bkmkstart stylerid1_2E281_2E2_2E2}{\*\bkmkend stylerid1_2E281_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Provisions uniform.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be applicable and uniform throughout this state and in all political subdivisions and municipalities in this state. Unless expressly authorized in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, a local authority shall not enact or enforce any rule or regulation in conflict with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Local authorities may, however, adopt additional traffic regulations which are not in conflict with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5017.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.235}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 66, \'a775}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.235A}}}{\*\bkmkstart stylerid1_2E282_2E2_2E2}{\*\bkmkend stylerid1_2E282_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Electric personal assistive mobility devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An electric personal assistive mobility device, which is a two-wheeled device as defined in }{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 20B}}}{, may be operated by a person at least sixteen years of age on sidewalks and bikeways in accordance with }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{None of the following are required for operation of an electric personal assistive mobility device:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensure or registration of the electric personal assistive mobility device under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Possession of a driver\u8217\'3fs license or permit by the operator of the electric personal assistive mobility device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proof of financial responsibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating an electric personal assistive mobility device on a sidewalk or bikeway shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Yield the right-of-way to other pedestrians.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Give an audible signal before overtaking and passing a pedestrian.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not operate an electric personal assistive mobility device at the times specified in }}}{{\f5\fs18\hyphpar0\qj{section 321.384}}}{{\f5\fs18\hyphpar0\qj{ unless the person or the electric personal assistive mobility device is equipped with a headlight visible from the front of the electric personal assistive mobility device and at least one red reflector visible from the rear of the electric personal assistive mobility device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 9A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1063, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a729, 35}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7397, 400}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1137, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.236}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9A)(a)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.235B}}}{\*\bkmkstart stylerid1_2E283_2E2_2E2}{\*\bkmkend stylerid1_2E283_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Low-speed electric bicycles }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ labels }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer or distributor of low-speed electric bicycles shall apply a label that is permanently affixed in a prominent location to each of the manufacturer\u8217\'3fs or distributor\u8217\'3fs low-speed electric bicycles. The label shall contain all of the following information printed in arial font with a font size not less than nine point type:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A classification number for the low-speed electric bicycle that corresponds with a class defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 36A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The low-speed electric bicycle\u8217\'3fs top assisted speed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The low-speed electric bicycle\u8217\'3fs motor wattage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not knowingly modify the speed capability or engagement of a low-speed electric bicycle such that the low-speed electric bicycle does not qualify for a class defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 36A}}}{{\f5\fs18\hyphpar0\qj{. If a person has modified the speed capability or engagement of a low-speed electric bicycle, the person shall affix a new label containing the information listed in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ to the modified low-speed electric bicycle. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A low-speed electric bicycle shall be manufactured and equipped in compliance with }}}{{\f5\fs18\hyphpar0\qj\cf1{16 C.F.R. pt. 1512}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A low-speed electric bicycle shall be manufactured to operate in such a manner that when the rider stops pedaling, applies the brakes, or the electric motor is disengaged, the electric motor assist ceases to function.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class 3 low-speed electric bicycle shall not be operated unless it is equipped with a speedometer that displays its speed in miles per hour.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under the age of sixteen shall not operate a class 3 low-speed electric bicycle. A person under the age of sixteen may ride as a passenger on a class 3 low-speed electric bicycle in compliance with }}}{{\f5\fs18\hyphpar0\qj{section 321.234, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a low-speed electric bicycle on a highway is subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to a rider of a bicycle on a highway and has all the rights and duties under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to a rider of a bicycle, except those provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ which by their nature can have no application, or except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for provisions of the Code made specifically applicable to low-speed electric bicycles in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, low-speed electric bicycles are not subject to provisions of the Code applicable to vehicles, including provisions relating to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensure, registration, titling, inspection, and proof of financial liability coverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Possession of a driver\u8217\'3fs license or permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A low-speed electric bicycle may be operated in any place where a bicycle is allowed to operate, including but not limited to streets, highways, roadways, shoulders, bicycle lanes, bikeways, and bicycle or multi-use paths.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not operate a class 3 low-speed electric bicycle on a bicycle lane or multi-use path in excess of the posted or applicable speed limit, or if there is no posted or applicable speed limit, twenty miles per hour.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 125, \'a75, 8, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(9A)(b)}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E284_2E1_2E1}{POWERS OF LOCAL AUTHORITIES}{\*\bkmkend stylerid1_2E284_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.236}}}{\*\bkmkstart stylerid1_2E285_2E2_2E2}{\*\bkmkend stylerid1_2E285_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers of local authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Local authorities shall not enact, enforce, or maintain any ordinance, rule, or regulation that is in conflict with, contrary to, or inconsistent with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. An ordinance, rule, or regulation that is in conflict with, contrary to, or inconsistent with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ that has been or is enacted by local authorities shall not have any force or effect. However, with respect to streets and highways under their jurisdiction and within the reasonable exercise of the police power, the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not be deemed to prevent local authorities from doing any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulating the standing or parking of vehicles.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parking meter, snow route, and overtime parking violations which are contested shall be charged and proceed before a court the same as other traffic violations. Filing fees and court costs shall be assessed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 602.8106, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 805.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for parking violation cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parking violations which are uncontested shall be charged and collected upon a simple notice of a fine payable to the city clerk. The fine for each violation charged under a simple notice of a fine shall be established by ordinance. The fine may be increased by five dollars if the parking violation is not paid within thirty days of the date upon which the violation occurred. Violations of }}}{{\f5\fs18\hyphpar0\qj{section 321L.4, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be charged and collected upon a simple notice of a one hundred dollar fine payable to the city clerk. Costs or other charges shall not be assessed. All fines collected by a city pursuant to this paragraph shall be retained by the city and all fines collected by a county pursuant to this paragraph shall be retained by the county, except as provided by an agreement between a city and a county treasurer for the collection of fines pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.553, subsection 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the local authority regulating the standing or parking of vehicles under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is located in a county where the renewal of registration of a vehicle shall be refused for unpaid restitution under }}}{{\f5\fs18\hyphpar0\qj{section 321.40}}}{{\f5\fs18\hyphpar0\qj{, the simple notice of fine under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall contain the following statement:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Failure to pay restitution owed by you can be grounds for refusing to renew your motor vehicle\u8217\'3fs registration.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the local authority regulating the standing or parking of vehicles under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is a county or is a city which has an agreement with a county treasurer by which the renewal of registration of a vehicle shall be refused for uncontested and unpaid parking fines under }}}{{\f5\fs18\hyphpar0\qj{section 321.40}}}{{\f5\fs18\hyphpar0\qj{, the simple notice of a fine under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall contain the following statement:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Failure to pay parking fines owed by you can be grounds for refusing to renew your motor vehicle\u8217\'3fs registration.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cities that enter into }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ agreements for the collection of delinquent parking fines in conjunction with renewal of motor vehicle registrations pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.40}}}{{\f5\fs18\hyphpar0\qj{ shall be responsible for computer programming costs incurred by the department to accommodate the collection and dissemination of delinquent parking ticket information to county treasurers, with each such city paying a per capita share of the costs as provided in this paragraph. The department\u8217\'3fs programming costs shall be paid by the first city to enter into such an agreement. Thereafter, cities that enter into such agreements on or before June 30, 2010, shall pay a pro rata share of the department\u8217\'3fs programming costs on or before September 30, 2010, to the city which first paid the costs, based on the respective populations of each city as of the last decennial census.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulating traffic by means of police officers or traffic-control signals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulating or prohibiting processions or assemblages on the highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designating particular highways as one-way highways and requiring that all vehicles thereon be moved in one specific direction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulating the speed of vehicles in public parks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designating any highway as a through highway and requiring that all vehicles stop or yield the right-of-way before entering or crossing the same or designating any intersection as a stop intersection and requiring all vehicles to stop at one or more entrances to such intersections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensing and regulating the operation of vehicles offered to the public for hire and used principally in intracity operation, except to the extent such licensure and regulation conflicts with }}}{{\f5\fs18\hyphpar0\qj{section 321.241}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 321N.11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 325A.6}}}{{\f5\fs18\hyphpar0\qj{, or any other provision of the Code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Restricting the use of highways as authorized in }}}{{\f5\fs18\hyphpar0\qj{sections 321.471 through 321.473}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulating or prohibiting the turning of vehicles at and between intersections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulating the operation of bicycles and requiring the registration and licensing of the same, including the requirement of a registration fee. However, the regulations shall not conflict with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.234}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing speed limits in public alleys and providing the penalty for violation thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designating highways or portions of highways as snow routes.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When conditions of snow or ice exist on the traffic surface of a designated snow route, it is unlawful for the driver of a vehicle to impede or block traffic if the driving wheels of the vehicle are not equipped with snow tires, tire chains, or a nonslip differential.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person charged with impeding or blocking traffic for lack of snow tires, chains, or nonslip differential shall have the charge dismissed upon a showing to the court that the person\u8217\'3fs motor vehicle was equipped with snow tires, chains, or a nonslip differential.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing a rural residence district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors of a county with respect to highways under its jurisdiction may establish, by ordinance or resolution, rural residence districts and may, by ordinance or resolution, regulate the speed and parking of vehicles within the rural residence district consistent with }}}{{\f5\fs18\hyphpar0\qj{sections 321.239}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.285}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{321.293}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before establishing a rural residence district, the board of supervisors shall hold a public hearing on the proposal, notice of which shall be published in a newspaper having a general circulation in the area where the proposed district is located at least twenty days before the date of hearing. The notice shall state the time and place of the hearing, the proposed location of the district, and other data considered pertinent by the board of supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulating or prohibiting the operation of electric personal assistive mobility devices authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.235A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of a local ordinance, rule, or regulation promulgated under the authority of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be prosecuted under the local ordinance, without reference to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18, -m20; C24, 27, 31, 35, \'a74992, 4995, 4997; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5018.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.236}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1111, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 40, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1056, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1238, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1102, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1151, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1170, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1122, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 169, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 147, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 54, \'a73, 4, 12}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 21, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7115, 252}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1101, \'a73, 24}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7167, 168}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.40}}}{{\f5\fs12\hyphpar0\qj{, 321.237}}}{{\f5\fs12\hyphpar0\qj{, 321.285}}}{{\f5\fs12\hyphpar0\qj{, 321.449}}}{{\f5\fs12\hyphpar0\qj{, 325A.13}}}{{\f5\fs12\hyphpar0\qj{, 331.362}}}{{\f5\fs12\hyphpar0\qj{, 364.3}}}{{\f5\fs12\hyphpar0\qj{, 602.8103}}}{{\f5\fs12\hyphpar0\qj{, 602.8106}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 805.6}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(1)(a)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(5)(a)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(a)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(8)(a)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For fines applicable to offenses charged as scheduled violations, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.237}}}{\*\bkmkstart stylerid1_2E286_2E2_2E2}{\*\bkmkend stylerid1_2E286_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Signs }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ requirement }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A traffic ordinance or regulation enacted under }}}{{\f5\fs18\hyphpar0\qj{section 321.236, subsection 4, 5, 6, 8, 12, or 13}}}{{\f5\fs18\hyphpar0\qj{, shall not be effective until signs, giving notice of such local traffic regulations as specified in the department manual on uniform traffic-control devices, are posted upon or at the entrances to the highway or part thereof affected as may be most appropriate and shall be erected at the expense of the local authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a city has adopted an ordinance as authorized in }}}{{\f5\fs18\hyphpar0\qj{section 321.236, subsection 12}}}{{\f5\fs18\hyphpar0\qj{, or an ordinance which prohibits standing or parking of vehicles upon a street or streets during any time when snow-removal operations are in progress and before such operations have resulted in the removal or clearance of snow from such street or streets, signs as specified in the department manual on uniform traffic-control devices, posted as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall be deemed sufficient notice of the existence of such restrictions.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5018.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.237}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1056, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7111}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.238}}}{\*\bkmkstart stylerid1_2E287_2E2_2E2}{\*\bkmkend stylerid1_2E287_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of electronic devices while driving }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ preemption of local legislation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ restricting the use of electronic devices by motor vehicle operators shall be implemented uniformly throughout the state. Such provisions shall preempt any county or municipal ordinance regarding the use of an electronic device by a motor vehicle operator. In addition, a county or municipality shall not adopt or continue in effect an ordinance regarding the use of an electronic device by a motor vehicle operator.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1105, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 14, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.362}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.239}}}{\*\bkmkstart stylerid1_2E288_2E2_2E2}{\*\bkmkend stylerid1_2E288_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Counties may restrict parking of vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county board of supervisors may adopt, amend, or repeal traffic ordinances to regulate or prohibit the standing or parking of vehicles within the right-of-way of any highway under its jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person violating a traffic ordinance adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be guilty of a misdemeanor and shall, upon conviction, be fined not to exceed twenty-five dollars, or be imprisoned not to exceed seven days in the county jail. The form and style of the information shall be in the name of the county and as against the person in violation of the traffic ordinance.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.239}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.236}}}{{\f5\fs12\hyphpar0\qj{, 331.362}}}{{\f5\fs12\hyphpar0\qj{, 602.8103}}}{{\f5\fs12\hyphpar0\qj{, 602.8106}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(1)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For fines applicable to offenses charged as scheduled violations, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 1, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.240}}}{\*\bkmkstart stylerid1_2E289_2E2_2E2}{\*\bkmkend stylerid1_2E289_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Altering center of gravity of vehicle.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by 96 Acts, ch 1152, \'a726. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.241}}}{\*\bkmkstart stylerid1_2E29_30_2E2_2E2}{\*\bkmkend stylerid1_2E29_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Regulation of taxicabs by local authorities }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ limits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local authority shall not enact, enforce, or maintain any ordinance, regulation, or rule that imposes a requirement on a person operating a taxicab having a seating capacity of less than seven passengers and not operating on a regular route or between specified points that is more restrictive than any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requiring the person to have a driver\u8217\'3fs license valid for the operation of the motor vehicle used as a taxicab that is not an instruction permit, special instruction permit, or temporary restricted license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prohibiting the person from operating the taxicab if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is restricted to operating motor vehicles equipped with an ignition interlock device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs driving privileges have been suspended, revoked, barred, canceled, denied, or disqualified in the prior three-year period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has been convicted of more than three moving violations in the prior three-year period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has been convicted of violating }}}{{\f5\fs18\hyphpar0\qj{section 321.218}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.277}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321J.21}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 321A.32, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, in the prior three-year period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has been convicted in the prior seven-year period of a felony, of violating }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{, or of any crime involving resisting law enforcement, dishonesty, injury to another person, damage to the property of another person, or operating a vehicle in a manner that endangers another person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is registered on the national sex offender registry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local authority shall not enact, enforce, or maintain any ordinance, regulation, or rule that requires a corporation, partnership, sole proprietorship, or other entity that sells or offers for sale transportation by taxicabs having a seating capacity of less than seven passengers and not operating on a regular route or between specified points to maintain a physical place of business in the local authority\u8217\'3fs jurisdiction as a condition of operating such taxicabs in the local authority\u8217\'3fs jurisdiction.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1101, \'a74, 24}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.236}}}{{\f5\fs12\hyphpar0\qj{, 325A.2}}}{{\f5\fs12\hyphpar0\qj{, 331.362}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.242 through 321.246}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.247}}}{\*\bkmkstart stylerid1_2E292_2E2_2E2}{\*\bkmkend stylerid1_2E292_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Golf cart operation on city streets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Incorporated areas may, upon approval of their governing body, allow the operation of golf carts on city streets by persons possessing a valid driver\u8217\'3fs license. However, a golf cart shall not be operated upon a city street which is a primary road extension through the city but shall be allowed to cross a city street which is a primary road extension through the city.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The golf carts shall be equipped with a slow moving vehicle sign and a bicycle safety flag and operate on the streets only from sunrise to sunset.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Golf carts operated on city streets shall be equipped with adequate brakes and shall meet any other safety requirements imposed by the governing body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Golf carts are not subject to the registration provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1041, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a746}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.362}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(b)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.248}}}{\*\bkmkstart stylerid1_2E293_2E2_2E2}{\*\bkmkend stylerid1_2E293_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Parks and cemeteries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Local authorities may by general rule, ordinance, or regulation exclude vehicles from any cemetery or ground used for the burial of the dead, or exclude vehicles used solely or principally for commercial purposes, from any park or part of a park system where such general rule, ordinance, or regulation is applicable equally and generally to all other vehicles used for the same purpose, if, at the entrance, or at each entrance if there be more than one, to such cemetery or park from which vehicles are so excluded, there shall have been posted a sign plainly legible from the middle of the public highway on which such cemetery or park opens, plainly indicating such exclusion and prohibition.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m20; C24, 27, 31, 35, \'a74994; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5018.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.248}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.249}}}{\*\bkmkstart stylerid1_2E294_2E2_2E2}{\*\bkmkend stylerid1_2E294_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{School zones.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Cities and counties shall have the power to establish school zones and provide for the stopping of all motor vehicles approaching the school zones, when movable stop signs have been placed in the streets in the cities and highways in counties at the limits of the zones, notwithstanding the provisions of any statute to the contrary. All traffic-control devices provided for school zones shall conform to specifications included in the manual of traffic-control devices adopted by the department, except the provision prohibiting the use of portable or part-time stop signs.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74997-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5018.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.249}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.250}}}{\*\bkmkstart stylerid1_2E295_2E2_2E2}{\*\bkmkend stylerid1_2E295_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Equitable reprisal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When the local authorities of other states shall, by the adoption of rules and regulations or otherwise, prohibit motor vehicles registered under the laws of this state from operating upon highways in any subdivision of such other state, the local authorities of this state may, by ordinance or otherwise, require the motor vehicles of the subdivisions of such other state while operating by their own power in this state to be registered under the laws of this state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74998; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5018.15;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.250}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.251}}}{\*\bkmkstart stylerid1_2E296_2E2_2E2}{\*\bkmkend stylerid1_2E296_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rights of owners of real property \u8212\'3f manufactured home communities or mobile home parks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prevent the owner of real property used by the public for purposes of vehicular travel by permission of the owner and not as matter of right from prohibiting such use, or from requiring other or different or additional conditions than those specified in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or otherwise regulating such use as may seem best to such owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of real property upon which a manufactured home community or mobile home park is located may elect to have the vehicular traffic provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or the ordinances, rules, or regulations of the local authority where the real property is located, apply to the real property and any persons located on the real property by granting authority to any peace officer to enforce the vehicular traffic provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or the ordinances, rules, or regulations of the local authority as well as any regulations or conditions imposed on the real property pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. An election made pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not create a higher priority for the enforcement of traffic laws on real property upon which a manufactured or mobile home is located than exists for the enforcement of traffic laws on public property.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written notice of election shall be filed with the designated officials of the local authority whose ordinances, rules, or regulations will govern the vehicular traffic. The appropriate officials shall be the city clerk and chief of police of the city in which the real property is located and the county sheriff and the county recorder of the county in which the real property is located. The notice shall include the legal description of the real property, the street address, if any, and the date and time when the owner wishes the election to become effective. The notice shall be signed by every titleholder of the real property and acknowledged by a notary public as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 9B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An election shall terminate fourteen days following the filing of a written notice of withdrawal with the designated officials of the local authority whose ordinances, rules, or regulations will govern.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftitleholder of real property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the person or entity whose name appears on the documents of title filed in the official county records as the owner of the real property upon which a manufactured home community or mobile home park is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The titleholder of real property under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ may elect to waive the right to have the vehicular traffic provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or the ordinances, rules, or regulations of the local authority where the real property is located, apply to the real property and any persons located on the real property, by recording a waiver with the county recorder of each county in which the property is located. The waiver shall include the legal description of the real property and shall bind the titleholder of the real property and any successors in interest. The waiver may only be rescinded if each law enforcement jurisdiction, in which the titleholder of real property wishes to obtain the benefit of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, consents to the rescission of the waiver through adoption of a resolution.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5018.16;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.251}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 91, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1068, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 109, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1050, \'a741, 60}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E297_2E1_2E1}{TRAFFIC SIGNS, SIGNALS, AND MARKINGS}{\*\bkmkend stylerid1_2E297_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.252}}}{\*\bkmkstart stylerid1_2E298_2E2_2E2}{\*\bkmkend stylerid1_2E298_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department to adopt sign manual.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt a manual and specifications for a uniform system of traffic-control devices consistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for use upon highways within this state. Such uniform system shall correlate with and so far as possible conform to the system then current as approved by the American association of state highway and transportation officials.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall include in its manual of traffic-control devices, specifications for a uniform system of highway signs for the purpose of guiding traffic to organized off-highway permanent camps, and camp areas, operated by recognized and established civic, religious, and nonprofit charitable organizations and to for-profit campgrounds and ski areas. The department shall purchase, install, and maintain the signs upon the prepayment of the costs by the organization or owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall also establish criteria for guiding traffic on all fully controlled-access, divided, multilaned highways including interstate highways to each tourist attraction which is located within thirty miles of the highway and receives fifteen thousand or more visitors annually. Nothing in}}}{{\f5\fs18\hyphpar0\qj{ this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to prohibit the department from erecting signs to guide traffic on these highways to tourist attractions which are located more than thirty miles from the highway or which receive fewer than fifteen thousand visitors annually.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall establish, by rule, the standards for tourist-oriented directional signs and shall annually review the list of attractions for which signing is in place. The rules shall conform to national standards for tourist-oriented directional signs adopted under }}}{{\f5\fs18\hyphpar0\qj{23 U.S.C. \'a7131(q)}}}{{\f5\fs18\hyphpar0\qj{ and to the manual of uniform traffic-control devices.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ A tourist attraction is not subject to a minimum number of visitors annually to qualify for tourist-oriented directional signing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules shall not be applicable to directional signs relating to historic sites on land owned or managed by state agencies, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.253A}}}{{\f5\fs18\hyphpar0\qj{. The rules shall include but are not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Criteria for eligibility for signing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Criteria for limiting or excluding businesses, activities, services, and sites that maintain signs that do not conform to the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 306B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 306C, subchapter II}}}{{\f5\fs18\hyphpar0\qj{, or other statutes or administrative rules regulating outdoor advertising.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions for a fee schedule to cover the direct and indirect costs of sign manufacture, erection, and maintenance, and related administrative costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions specifying maximum distances to eligible businesses, activities, services, and sites. Tourist-oriented directional signs may be placed on highways within the maximum travel distance that have the greatest traffic count per day, if sufficient space is available. If an adjacent landowner complains to the department about the placement of a tourist-oriented directional sign, the department shall attempt to reach an agreement with the landowner for relocating the sign. If possible, the sign shall be relocated from the place of objection. If the sign must be located on an objectionable place, it shall be located on the least objectionable place possible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions for trailblazing to facilities that are not on the crossroad. Appropriate trailblazing shall be installed over the most desirable routes on lesser traveled primary highways, secondary roads, and city streets leading to the tourist attraction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Criteria for determining when to permit advance signing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions specifying conditions under which the time of operation of a business, activity, service, or site is shown.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions for masking or removing signs during off seasons for businesses, activities, services, and sites operated on a seasonal basis. Faded signs shall be replaced and the commercial vendor charged for the cost of replacement based upon the fee schedule adopted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions specifying the maximum number of signs permitted per intersection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions for determining what businesses, activities, services, or sites are signed when there are more applicants than the maximum number of signs permitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions for removing signs when businesses, activities, services, or sites cease to meet minimum requirements for participation and related costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities shall adhere to the specifications for signs as established by the department, and shall purchase, install, and maintain signs in their respective jurisdictions upon prepayment by the organization of the cost of such purchase, installation, and maintenance. The department shall include in its manual of traffic-control devices specifications for a uniform system of traffic-control devices in legally established school zones.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, \'a74627; C31, 35, \'a74627, 5079-d7; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5019.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.252}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1060, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1183, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72112}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7317}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.342}}}{{\f5\fs12\hyphpar0\qj{, 668.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.253}}}{\*\bkmkstart stylerid1_2E299_2E2_2E2}{\*\bkmkend stylerid1_2E299_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department to erect signs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall place and maintain such traffic-control devices, conforming to its manual and specifications, upon all primary highways as it deems necessary to indicate and to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or to regulate, warn, or guide traffic. Whenever practical, the devices or signs shall be purchased from the director of the Iowa department of corrections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall post signs informing motorists of the penalties for speeding in a road work zone and that the scheduled fine for committing any other moving traffic violation in a road work zone is doubled.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, \'a74627; C31, 35, \'a74627, 5079-d7; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5019.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.253}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159, 160}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 114, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 104, \'a719}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1124, \'a78}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Analogous provisions, }{{\f5\fs12\hyphpar0\qj{\'a7321.345}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.253A}}}{\*\bkmkstart stylerid1_2E3_30_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Directional signs relating to historic sites on land owned or managed by state agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall place and maintain directional signs upon primary highways which provide information about historic sites which are located on land owned or managed by an agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 17A.2}}}{{\f5\fs18\hyphpar0\qj{. The signs shall conform to the manual of uniform traffic devices. However, the directional signs are not subject to requirements applicable to tourist-oriented directional signs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request by a city or county in which a historic site is located on land owned or managed by an agency, the department shall distribute a directional sign as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the city or county for erection upon roads or streets within their jurisdictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location of the historic site shall be memorialized on transportation maps of the state published under the direction of the department and generally made available to the public. However, if it is not reasonable and feasible to display specific historic sites on the state transportation map, the department shall consult with the agency managing the historic site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not erect, maintain, or distribute a directional sign or include on a transportation map information about a historic site located on land owned or managed by an agency if the department receives an objection by the agency.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1183, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.252}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.253B}}}{\*\bkmkstart stylerid1_2E3_301_2E2_2E2}{\*\bkmkend stylerid1_2E3_301_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Metric signs restricted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall not place a sign relating to a speed limit, distance, or measurement on a highway if the sign establishes the speed limit, distance, or measurement solely by using the metric system, unless specifically required by federal law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 118, \'a723}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.254}}}{\*\bkmkstart stylerid1_2E3_302_2E2_2E2}{\*\bkmkend stylerid1_2E3_302_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local authorities restricted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No local authority shall place or maintain any traffic-control device upon any highway under the jurisdiction of the department except by the latter\u8217\'3fs permission.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5019.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.254}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.255}}}{\*\bkmkstart stylerid1_2E3_303_2E2_2E2}{\*\bkmkend stylerid1_2E3_303_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local traffic-control devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Local authorities in their respective jurisdiction shall place and maintain such traffic-control devices upon highways under their jurisdiction as they may deem necessary to indicate and to carry out the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or local traffic ordinances or to regulate, warn, or guide traffic. All such traffic-control devices hereafter erected shall conform to the state manual and specifications.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5019.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.255}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.256}}}{\*\bkmkstart stylerid1_2E3_304_2E2_2E2}{\*\bkmkend stylerid1_2E3_304_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Obedience to official traffic-control devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No driver of a vehicle shall disobey the instructions of any official traffic-control device placed in accordance with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless at the time otherwise directed by a peace officer subject to the exceptions granted the driver of an authorized emergency vehicle.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5019.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.256}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 321E.17}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(8)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 8 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.257}}}{\*\bkmkstart stylerid1_2E3_305_2E2_2E2}{\*\bkmkend stylerid1_2E3_305_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Official traffic-control signal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstop at the official traffic-control signal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means stopping at the first opportunity at either the clearly marked stop line or before entering the crosswalk or before entering the intersection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Official traffic-control signals consisting of colored lights or colored lighted arrows shall regulate vehicle and pedestrian traffic in the following manner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsteady circular red\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light means vehicular traffic shall stop. Vehicular traffic shall remain standing until a signal to proceed is shown, or vehicular traffic, unless prohibited by a sign, may cautiously enter the intersection to make a right turn from the right lane of traffic or another lane designated for right turns, or a left turn from a one-way street to a one-way street from the left lane of traffic or another lane designated for left turns. Turns made under this paragraph shall be made in a manner that does not interfere with other vehicular or pedestrian traffic lawfully using the intersection. Pedestrian traffic facing a steady circular red light shall not enter the roadway unless the pedestrian can safely cross the roadway without interfering with any vehicular traffic.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsteady circular yellow\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsteady yellow arrow\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light means vehicular traffic is warned that the related green movement is being terminated and vehicular traffic shall no longer proceed into the intersection and shall stop. If the stop cannot be made in safety, a vehicle may be driven cautiously through the intersection. Pedestrian traffic is warned that there is insufficient time to cross the intersection and any pedestrian starting to cross the roadway shall yield the right-of-way to all vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsteady circular green\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light means vehicular traffic may proceed straight, turn right or turn left through the intersection unless otherwise specifically prohibited. Vehicular traffic shall yield the right-of-way to other vehicular and pedestrian traffic lawfully within the intersection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsteady green arrow\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light shown alone or with another official traffic-control signal means vehicular traffic may cautiously enter the intersection and proceed in the direction indicated by the arrow. Vehicular traffic shall yield the right-of-way to other vehicles and pedestrians lawfully within the intersection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fflashing circular red\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light means vehicular traffic shall stop and after stopping may proceed cautiously through the intersection yielding to all vehicles not required to stop or yield which are within the intersection or approaching so closely as to constitute a hazard, but then may proceed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fflashing yellow\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light means vehicular traffic shall proceed through the intersection or past such signal with caution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fflashing yellow arrow\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light shown alone or with another official traffic-control signal means vehicular traffic may cautiously enter the intersection and proceed only in the direction indicated by the arrow. Vehicular traffic shall yield the right-of-way to other vehicles and pedestrians lawfully within the intersection and any vehicle on the opposing approach which is approaching so closely as to constitute an immediate hazard during the time the driver is moving within the intersection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdon\u8217\'3ft walk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsteady upraised hand\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light is a pedestrian signal which means that pedestrian traffic facing the illuminated pedestrian signal shall not start to cross the roadway in the direction of the pedestrian signal, and pedestrian traffic in the crossing shall proceed to a safety zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fflashing upraised hand\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fupraised hand with countdown\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light is a pedestrian signal which means that pedestrian traffic facing the illuminated pedestrian signal shall not start to cross the roadway in the direction of the pedestrian signal, and pedestrian traffic in the crossing shall proceed to a safety zone. The }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fupraised hand with countdown\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light is a pedestrian signal that also provides the time remaining for the pedestrian to complete the crossing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwalk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwalking person\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ light is a pedestrian signal which means that pedestrian traffic facing the illuminated pedestrian signal may proceed to cross the roadway in the direction of the pedestrian signal and shall be given the right-of-way by drivers of all vehicles.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5019.06, 5019.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7321.257, 321.258; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.257}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1123, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 15, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(7)(a)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsections 7 and 9 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.258}}}{\*\bkmkstart stylerid1_2E3_306_2E2_2E2}{\*\bkmkend stylerid1_2E3_306_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Arrangement of lights on official traffic-control signals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Colored lights placed on a vertical official traffic-control signal face shall be arranged from the top to the bottom in the following order when used:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Circular red. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}