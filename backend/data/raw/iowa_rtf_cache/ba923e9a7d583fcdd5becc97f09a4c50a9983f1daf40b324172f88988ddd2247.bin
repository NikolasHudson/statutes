hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Right-turn green arrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Colored lights placed on a horizontal official traffic-control signal face shall be arranged from the left to the right in the following order when used:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Circular red.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Steady or flashing left-turn red arrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Steady or flashing right-turn red arrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Circular yellow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Steady left-turn yellow arrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Flashing left-turn yellow arrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Left-turn green arrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Circular green.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Straight-through green arrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Steady right-turn yellow arrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Flashing right-turn yellow arrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Right-turn green arrow.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.258}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1026, \'a777}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7147, 148}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.259}}}{\*\bkmkstart stylerid1_2E3_307_2E2_2E2}{\*\bkmkend stylerid1_2E3_307_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unauthorized signs, signals, or markings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall place, maintain, or display upon or in view of any highway any sign, signal, marking, or device which purports to be or is an imitation of or resembles an official parking sign, curb or other marking, traffic-control device or railroad sign or signal, or which attempts to direct the movement of traffic, or which hides from view or interferes with the effectiveness of any official traffic-control device or any railroad sign or signal, if such sign, signal, marking, or device has not been authorized by the department and local authorities with reference to streets and highways under their jurisdiction and no person shall place or maintain nor shall any public authority permit upon any highway any traffic sign or signal bearing thereon any commercial advertising. This shall not be deemed to prohibit the erection upon private property adjacent to highways of signs giving useful directional information of a type that cannot be mistaken for official signs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every such prohibited sign, signal, or marking is hereby declared to be a public nuisance and the authority having jurisdiction over the highway is hereby empowered to remove the same or cause it to be removed without notice.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5019.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.259}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Nuisances in general, }{{\f5\fs12\hyphpar0\qj{chapter 657}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.260}}}{\*\bkmkstart stylerid1_2E3_308_2E2_2E2}{\*\bkmkend stylerid1_2E3_308_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interference with devices, signs, or signals \u8212\'3f unlawful possession \u8212\'3f traffic signal preemption devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who willfully and intentionally, without lawful authority, attempts to or in fact alters, defaces, injures, knocks down, or removes an official traffic-control device, an authorized warning sign or signal or barricade, whether temporary or permanent, a railroad sign or signal, an inscription, shield, or insignia on any of such devices, signs, signals, or barricades, or any other part thereof, shall, upon conviction, be guilty of a simple misdemeanor and shall be required to make restitution to the affected jurisdiction. In addition to any other penalties, the punishment imposed for a violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall include assessment of a fine of not less than two hundred fifty dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is convicted under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of an act relating to a stop sign or a yield sign may be required to complete community service in addition to making restitution to the affected jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any person to have in the person\u8217\'3fs possession any official traffic-control device except by legal right or authority. Any person convicted of unauthorized possession of any official traffic-control device shall upon conviction be guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell, own, possess, or use a traffic signal preemption device except as permitted in connection with the lawful operation of an authorized emergency vehicle as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1}}}{{\f5\fs18\hyphpar0\qj{ or as otherwise authorized by the jurisdiction owning and operating an official traffic control signal. A person who is convicted of the unauthorized sale, ownership, possession, or use of a traffic signal preemption device is guilty of a simple misdemeanor. In addition to any other penalties, the punishment imposed for a violation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall include assessment of a fine of not less than two hundred fifty dollars, and if the violation involves the unauthorized use of a traffic signal preemption device, the person may also be required to complete community service.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftraffic signal preemption device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a device that, when activated, is capable of changing an official traffic control signal to green out of sequence.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5019.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.260}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1064, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 131, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 153, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 63, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a732, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(8)(c)}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E3_309_2E1_2E1}{ACCIDENTS}{\*\bkmkend stylerid1_2E3_309_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.261}}}{\*\bkmkstart stylerid1_2E31_30_2E2_2E2}{\*\bkmkend stylerid1_2E31_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Death or personal injuries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of any vehicle who knows or has reason to believe that the driver\u8217\'3fs vehicle was involved in an accident resulting in injury to or death of any person shall immediately stop the vehicle at the scene of the accident or as close as possible and if able, shall then return to and remain at the scene of the accident in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.263}}}{{\f5\fs18\hyphpar0\qj{. Every such stop shall be made without obstructing traffic more than is necessary.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the driver of a vehicle leaves the scene of an accident resulting in injury to or death of a person without knowledge or reason to believe that the driver\u8217\'3fs vehicle was involved in the accident, and later discovers that the driver\u8217\'3fs vehicle may have been involved in an accident that resulted in injury to or death of a person, the driver shall, as soon as reasonably possible, make a good-faith effort to immediately contact emergency services or make a 911 call and provide the dispatcher with any requested information described in }}}{{\f5\fs18\hyphpar0\qj{section 321.263}}}{{\f5\fs18\hyphpar0\qj{ and the location and possible time of the accident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person failing to stop or to comply with the requirements in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, in the event of an accident resulting in an injury to any person is guilty upon conviction of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, any person failing to stop or to comply with the requirements in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, in the event of an accident resulting in a serious injury to any person, is guilty upon conviction of an aggravated misdemeanor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the driver of a vehicle who knows or has reason to believe that the driver\u8217\'3fs vehicle caused an accident resulting in a serious injury to one or more persons, and who fails to stop or comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, is guilty upon conviction of a class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fserious injury\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.18}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person failing to stop or to comply with the requirements in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, in the event of an accident resulting in the death of a person, is guilty upon conviction of a class \u8220\'3fD\u8221\'3f felony.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the driver of a vehicle who knows or has reason to believe that the driver\u8217\'3fs vehicle caused an accident resulting in the death of one or more persons, and who fails to stop or comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, is guilty upon conviction of a class \u8220\'3fC\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall revoke the driver\u8217\'3fs license of a person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law to the contrary, any person who has suffered physical, emotional, or financial harm as the result of a motor vehicle accident from which another person who caused the accident failed to stop or to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be considered a victim pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 915, subchapter II}}}{{\f5\fs18\hyphpar0\qj{, for purposes of any related proceedings against the other person.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m23; C24, 27, 31, 35, \'a75072, 5074; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.261}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 103, \'a74}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1082, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 180, \'a72 \u8211\'3f 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.209}}}{{\f5\fs12\hyphpar0\qj{, 321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.484}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}{{\f5\fs12\hyphpar0\qj{, 321.555}}}{{\f5\fs12\hyphpar0\qj{, 515D.4}}}{{\f5\fs12\hyphpar0\qj{, 902.12}}}{{\f5\fs12\hyphpar0\qj{, 915.80}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.262}}}{\*\bkmkstart stylerid1_2E311_2E2_2E2}{\*\bkmkend stylerid1_2E311_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Leaving scene of traffic accident prohibited }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ vehicle damage only }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ removal of vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of any vehicle involved in an accident resulting only in damage to a vehicle which is driven or attended by any person shall immediately remove the driver\u8217\'3fs vehicle from the traveled portion of the roadway if the vehicle is operable and the removal can be achieved in a safe manner. The driver shall remove the vehicle to the shoulder, emergency lane, or median nearest to the scene of the accident such that the vehicle is completely off the traveled portion of the roadway, and shall then stop the vehicle. The driver shall remove the vehicle without obstructing traffic more than is necessary.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Another person at the scene of the accident may remove a vehicle involved in the accident in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to reduce the risk of a subsequent accident or to ensure the safety of persons at the scene of the accident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver shall remain at the scene of the accident until the driver has fulfilled the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.263}}}{{\f5\fs18\hyphpar0\qj{. Any person failing to remain at the scene of the accident or fulfill the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.263}}}{{\f5\fs18\hyphpar0\qj{ under such circumstances shall be guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m23; C24, 27, 31, 35, \'a75079; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.262}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 146, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a733, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.484}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(m)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.263}}}{\*\bkmkstart stylerid1_2E312_2E2_2E2}{\*\bkmkend stylerid1_2E312_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Information and aid \u8212\'3f leaving scene of personal injury accident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle involved in an accident resulting in injury to or death of a person or damage to a vehicle which is driven or attended by a person shall give the driver\u8217\'3fs name, address, and the registration number of the vehicle the driver is driving and shall upon request and if available exhibit the driver\u8217\'3fs driver\u8217\'3fs license to the person struck, the driver or occupant of, or the person attending the vehicle involved in the accident and shall render to a person injured in the accident reasonable assistance, including the transporting or arranging for the transporting of the person for medical treatment if it is apparent that medical treatment is necessary or if transportation for medical treatment is requested by the injured person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the accident causes the death of a person, all surviving drivers shall remain at the scene of the accident except to seek necessary aid or to report the accident to law enforcement authorities. Before leaving the scene of the fatal accident, each surviving driver shall leave the surviving driver\u8217\'3fs driver\u8217\'3fs license, automobile registration receipt, or other identification data at the scene of the accident. After leaving the scene of the accident, a surviving driver shall promptly report the accident to law enforcement authorities, and shall immediately return to the scene of the accident or inform the law enforcement authorities where the surviving driver can be located.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m23; C24, 27, 31, 35, \'a75072, 5079; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.263}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a768}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.261}}}{{\f5\fs12\hyphpar0\qj{, 321.262}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}{{\f5\fs12\hyphpar0\qj{, 321.555}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.264}}}{\*\bkmkstart stylerid1_2E313_2E2_2E2}{\*\bkmkend stylerid1_2E313_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Striking unattended vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The driver of any vehicle which collides with any vehicle which is unattended shall immediately stop and shall then and there either locate and notify the operator or owner of such vehicle of the name and address of the driver and owner of the vehicle striking the unattended vehicle or shall leave in a conspicuous place in the vehicle struck a written notice giving the name and address of the driver and of the owner of the vehicle doing the striking and a statement of the circumstances thereof. A person who violates }{{\f5\fs18\hyphpar0\qj{this section}}}{ commits a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75079; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.264}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1074, \'a734, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.484}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(n)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.265}}}{\*\bkmkstart stylerid1_2E314_2E2_2E2}{\*\bkmkend stylerid1_2E314_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Striking fixtures upon a highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The driver of a vehicle involved in an accident resulting in damage to property legally upon or adjacent to a highway shall take reasonable steps to locate and notify the owner, a peace officer, or person in charge of the damaged property of the damage and shall inform the person of the driver\u8217\'3fs name and address and the registration number of the vehicle causing the damage and shall, upon request and if available, exhibit the driver\u8217\'3fs license of the driver of the vehicle and shall report the accident when and as required in }{{\f5\fs18\hyphpar0\qj{section 321.266}}}{. A person who violates }{{\f5\fs18\hyphpar0\qj{this section}}}{ commits a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fo\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75079; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.265}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a735, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(o)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.266}}}{\*\bkmkstart stylerid1_2E315_2E2_2E2}{\*\bkmkend stylerid1_2E315_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reporting accidents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle involved in an accident resulting in injury to or death of any person shall immediately by the quickest means of communication give notice of such accident to the sheriff of the county in which said accident occurred, or the nearest office of the state patrol, or to any other peace officer as near as practicable to the place where the accident occurred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle involved in an accident resulting in injury to or death of any person, or total property damage to an apparent extent of one thousand five hundred dollars or more shall, within seventy-two hours after the accident, forward a written report of the accident to the department. However, such report is not required when the accident is investigated by a law enforcement agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every law enforcement officer who, in the regular course of duty, investigates a motor vehicle accident of which report must be made as required in }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, either at the time of and at the scene of the accident or thereafter by interviewing participants or witnesses shall, within twenty-four hours after completing such investigation, forward a written report of such accident to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 455B.386}}}{{\f5\fs18\hyphpar0\qj{, a carrier transporting hazardous material upon a public highway in this state, in the case of an accident involving the transportation of the hazardous material, shall immediately notify the police radio broadcasting system established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 693.1}}}{{\f5\fs18\hyphpar0\qj{ or shall notify a peace officer of the county or city in which the accident occurs. When a local law enforcement agency is informed of the accident, the agency shall notify the state patrol. A person who violates a provision of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a serious misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m23; C24, \'a75073, 5075, 5104; C27, 31, 35, \'a75073, 5075, 5105-a35, 5105-c21; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.266}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 103, \'a75}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 170, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 72, \'a71}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{97 Acts, ch 108, \'a715}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1074, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 35, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1157, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7169}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 85, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.265}}}{{\f5\fs12\hyphpar0\qj{, 321.267}}}{{\f5\fs12\hyphpar0\qj{, 321.271}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}{{\f5\fs12\hyphpar0\qj{, 321G.10}}}{{\f5\fs12\hyphpar0\qj{, 321I.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.267}}}{\*\bkmkstart stylerid1_2E316_2E2_2E2}{\*\bkmkend stylerid1_2E316_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supplemental reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may require any driver of a vehicle involved in an accident of which report must be made as provided in }{{\f5\fs18\hyphpar0\qj{section 321.266}}}{ to file supplemental reports whenever the original report is insufficient in the opinion of the department and may require witnesses of accidents to render reports to the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.267}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.267A}}}{\*\bkmkstart stylerid1_2E317_2E2_2E2}{\*\bkmkend stylerid1_2E317_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Traffic accidents involving certified law enforcement officers or other emergency responders \u8212\'3f reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any traffic accident involving the operation of a motor vehicle by a certified law enforcement officer or other emergency responder shall be reported to the department by the officer\u8217\'3fs or responder\u8217\'3fs employer. The officer\u8217\'3fs or responder\u8217\'3fs employer shall certify to the department whether or not the accident occurred in the line of duty while operating an official government vehicle or during the responder\u8217\'3fs deployment on an emergency call. Such a certification is effective only for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 321.200}}}{{\f5\fs18\hyphpar0\qj{, upon receiving a certification pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the department shall not include a notation of the accident described in the certification on the officer\u8217\'3fs or responder\u8217\'3fs driving record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not relieve a certified law enforcement officer or other emergency responder operating a motor vehicle of the duty to drive with due regard for the safety of all persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcertified law enforcement officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a law enforcement officer who is certified through the Iowa law enforcement academy as provided in }}}{{\f5\fs18\hyphpar0\qj{section 80B.13, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or a reserve peace officer certified through the Iowa law enforcement academy as provided in }}}{{\f5\fs18\hyphpar0\qj{section 80D.4A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fother emergency responder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a fire fighter certified as a fire fighter I pursuant to rules adopted under }}}{{\f5\fs18\hyphpar0\qj{chapter 100B}}}{{\f5\fs18\hyphpar0\qj{ and trained in emergency driving or an emergency medical care provider certified under }}}{{\f5\fs18\hyphpar0\qj{chapter 147A}}}{{\f5\fs18\hyphpar0\qj{ and trained in emergency driving.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1137, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1084, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1149, \'a717}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.268}}}{\*\bkmkstart stylerid1_2E318_2E2_2E2}{\*\bkmkend stylerid1_2E318_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driver unable to report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever the driver of a vehicle is physically incapable of making a required accident report and there was another occupant in the vehicle at the time of the accident capable of making a report, such occupant shall make or cause to be made said report.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.268}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.269}}}{\*\bkmkstart stylerid1_2E319_2E2_2E2}{\*\bkmkend stylerid1_2E319_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Accident report forms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall prepare and upon request supply to police departments, coroners, sheriffs, and other suitable agencies or individuals, forms for accident reports required hereunder, which reports shall call for sufficiently detailed information to disclose with reference to a traffic accident the cause, condition then existing, and the persons and vehicles involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every required accident report shall be made on a form approved by the department if said form is available.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.269}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.270}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.271}}}{\*\bkmkstart stylerid1_2E321_2E2_2E2}{\*\bkmkend stylerid1_2E321_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports confidential \u8212\'3f without prejudice \u8212\'3f exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All accident reports filed by a driver of a vehicle involved in an accident as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.266}}}{{\f5\fs18\hyphpar0\qj{ shall be in writing. The report shall be without prejudice to the individual so reporting and shall be for the confidential use of the department, except that upon the request of any person involved in the accident, the person\u8217\'3fs insurance company or its agent, or the attorney for such person, the department shall disclose the identity and address of other persons involved in the accident and may disclose the name of the insurance companies with whom the other persons have liability insurance. The department, upon written request of the person making the report, shall provide the person with a copy of that person\u8217\'3fs report. The written report filed with the department shall not be admissible in or used in evidence in any civil or criminal case arising out of the facts on which the report is based.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All written reports filed by a law enforcement officer as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.266}}}{{\f5\fs18\hyphpar0\qj{ shall be made available to any party to an accident, the party\u8217\'3fs insurance company or its agent, the party\u8217\'3fs attorney, the federal motor carrier safety administration, or the attorney general, on written request to the department and the payment of a fee of four dollars for each copy. If a copy of an investigating officer\u8217\'3fs report of a motor vehicle accident filed with the department is retained by the law enforcement agency of the officer who filed the report, a copy shall be made available to any party to the accident, the party\u8217\'3fs insurance company or its agent, the party\u8217\'3fs attorney, the federal motor carrier safety administration, other law enforcement agencies, or the attorney general, on written request and the payment of a fee. However, the attorney general and the federal motor carrier safety administration shall not be required by the department or the law enforcement agency to pay a fee for a copy of a report filed by a law enforcement or investigating officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, the date, time, specific location, and immediate facts and circumstances surrounding a crime or incident shall not be kept confidential under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, except in those unusual circumstances where disclosure would plainly and seriously jeopardize an investigation or pose a clear and present danger to the safety of an individual.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.271}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 14, \'a725}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 72, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1054, \'a71, 2}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 32, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 8, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 28, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.273}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.272}}}{\*\bkmkstart stylerid1_2E322_2E2_2E2}{\*\bkmkend stylerid1_2E322_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tabulation of reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall tabulate and may analyze all accident reports and shall publish annually or at more frequent intervals statistical information based thereon as to the number and circumstances of traffic accidents.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.272}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.273}}}{\*\bkmkstart stylerid1_2E323_2E2_2E2}{\*\bkmkend stylerid1_2E323_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{City may require reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any incorporated city or other municipality may by ordinance require that the driver of a vehicle involved in an accident shall also file with a designated city department a report of such accident or a copy of any report herein required to be filed with the department. All such reports shall be for the confidential use of the city department and subject to the provisions of }{{\f5\fs18\hyphpar0\qj{section 321.271}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5020.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.273}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.517}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.274}}}{\*\bkmkstart stylerid1_2E324_2E2_2E2}{\*\bkmkend stylerid1_2E324_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Accidents in cities over 15,000.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1998/CH1178.pdf" }{\fldrslt \cf5 \f5 \fs18{{98 Acts, ch 1178, \'a716}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E325_2E1_2E1}{OPERATION OF MOTORCYCLES AND}{\*\bkmkend stylerid1_2E325_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{MOTORIZED BICYCLES}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.275}}}{\*\bkmkstart stylerid1_2E326_2E2_2E2}{\*\bkmkend stylerid1_2E326_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operation of motorcycles and motorized bicycles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E326_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{General.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motor vehicle laws apply to the operators of motorcycles and motorized bicycles to the extent practically applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E326_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Riders.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E326_2E4_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E4_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Motorized bicycles.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a motorized bicycle on the highways shall not carry any other person on the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E326_2E4_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E4_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Motorcycles.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not operate or ride a motorcycle on the highways with another person on the motorcycle unless the motorcycle is designed to carry more than one person. The additional passenger may ride upon the permanent and regular seat if designed for two persons, or upon another seat firmly attached to the motorcycle at the rear of the operator. The motorcycle shall be equipped with footrests for the passenger unless the passenger is riding in a sidecar or enclosed cab. The motorcycle operator shall not carry any person nor shall any other person ride in a position that will interfere with the operation or control of the motorcycle or the view of the operator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E326_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Sitting position.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a motorcycle or motorized bicycle shall ride only upon the vehicle\u8217\'3fs permanent and regular attached seat. Every person riding upon the vehicle shall be sitting astride the seat, facing forward with one leg on either side of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E326_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Use of traffic lanes.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons shall not operate motorcycles or motorized bicycles more than two abreast in a single lane. Except for persons operating such vehicles two abreast, a motor vehicle shall not be operated in a manner depriving a motorcycle or motorized bicycle operator of the full use of a lane. A motorcycle or motorized bicycle shall not be operated between lanes of traffic or between adjacent lines or rows of vehicles. The operator of a motorcycle or motorized bicycle shall not overtake and pass in the same lane occupied by the vehicle being overtaken unless the vehicle being overtaken is a motorcycle or motorized bicycle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E326_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Headlights on.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not operate a 1977 or later model year motorcycle or any model year motorized bicycle upon the highways without displaying at least one lighted headlamp of the type described in }}}{{\f5\fs18\hyphpar0\qj{section 321.409}}}{{\f5\fs18\hyphpar0\qj{. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is subject to the exceptions with respect to parked vehicles as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E326_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Packages.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operator of a motorcycle or motorized bicycle shall not carry any package, bundle, or other article which prevents the operator from keeping both hands on the handlebars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E326_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Parades.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ do not apply to motorcycles or motorized bicycles when used in a parade authorized by proper permit from local authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E326_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E326_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Bicycle safety flags required on motorized bicycles.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When operated on a highway, a motorized bicycle shall have a bicycle safety flag which extends not less than five feet above the ground attached to the rear of the motorized bicycle. The bicycle safety flag shall be triangular in shape with an area of not less than thirty square inches, and be Day-Glo in color.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.275}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 184, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1075, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1178, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(b)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsections 6 and 9 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations of subsection 4 causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Lamps on parked vehicles, }{{\f5\fs12\hyphpar0\qj{\'a7321.395}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E327_2E1_2E1}{CRIMINAL OFFENSES}{\*\bkmkend stylerid1_2E327_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.276}}}{\*\bkmkstart stylerid1_2E328_2E2_2E2}{\*\bkmkend stylerid1_2E328_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of electronic device while driving.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectronic device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a device that is powered by electricity, including by a battery, and that is capable of being used to compose, send, receive, or read an electronic message, or that is capable of storing, retrieving on-demand, or displaying videos, movies, broadcast television images, visual images, or audio or video data files. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectronic device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to a telephone including a cellular telephone, personal digital assistant, portable or mobile computer including a tablet, two-way messaging device, electronic gaming device, and any substantially similar portable device that is used to initiate, store, or receive electronic communication, information, or data. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectronic device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a device that is physically or electronically integrated into a motor vehicle, including but not limited to an integrated global positioning system or navigation system when the destination is entered into such system before the vehicle is in motion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUse\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to holding, viewing, or manipulating an electronic device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fVoice-activated or hands-free mode\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an attachment, accessory, application, wireless connection, or built-in feature of an electronic device or motor vehicle that allows a person to use verbal commands or a single touch to activate or deactivate the device or a function or software application of the device. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fVoice-activated or hands-free mode\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include accessing nonnavigation video content, engaging in a video call, accessing or engaging in video streaming, accessing gaming data, or reading an electronic message or notification. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not use an electronic device while driving a motor vehicle unless the motor vehicle is at a complete stop off the traveled portion of the roadway, or as far away from the center of the roadway as is practicable if the vehicle cannot be entirely removed from the traveled portion of the roadway.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person does not violate }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by using an electronic device in a voice-activated or hands-free mode.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ relating to the use of an electronic device do not apply to the following persons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of a public safety agency, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 34.1}}}{{\f5\fs18\hyphpar0\qj{, performing official duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care professional in the course of an emergency situation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person receiving safety-related information including emergency or weather alerts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person using an electronic device for the purpose of reporting an emergency situation, including any continued communication with emergency personnel during the emergency situation or public transit personnel responding to a transit-specific situation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating an implement of husbandry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person using a two-way radio transmitter or receiver who is licensed with the federal communications commission in amateur radio service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of a public transit system, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 324A.1}}}{{\f5\fs18\hyphpar0\qj{, performing official duties while in a vehicle that is not in motion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A utility maintenance employee or contractor using an electronic device while in a utility maintenance vehicle, for the purpose of providing utility services including but not limited to cable, electric, natural gas, telephone, telecommunication, water, and wastewater treatment services, provided the employee or contractor is acting within the scope of their employment or agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A transportation network company driver, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321N.1}}}{{\f5\fs18\hyphpar0\qj{, while engaged in a prearranged ride, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321N.1}}}{{\f5\fs18\hyphpar0\qj{, provided the vehicle is not in motion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person using an electronic device for the purpose of accessing or using a fleet management system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to authorize a peace officer to confiscate an electronic device from the driver or occupant of a motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under}}}{{\f5\fs18\hyphpar0\qj{ section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fl\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be considered a moving violation for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a peace officer shall issue a warning memorandum in lieu of a citation to a person for violating }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. This paragraph is repealed January 1, 2026.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, in cooperation with the department of public safety, shall establish educational programs to foster compliance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1105, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 75, \'a71 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 14, \'a79, 10}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.449B}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 668.15A}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(l)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For homicide or serious injury by vehicle involving use of electronic device while driving, see }{{\f5\fs12\hyphpar0\qj{\'a7707.6A}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 stricken and rewritten}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 2, 3, and 4 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.277}}}{\*\bkmkstart stylerid1_2E329_2E2_2E2}{\*\bkmkend stylerid1_2E329_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reckless driving.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who drives any vehicle in such manner as to indicate either a willful or a wanton disregard for the safety of persons or property is guilty of reckless driving.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is convicted of reckless driving shall be guilty of a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74071; C97, \'a75039; S13, \'a71571-m19; C24, 27, 31, 35, \'a75028; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5022.04, 5022.05;}}}{ C46, 50, 54, 58, 62, \'a7321.283, 321.284; C66, 71, 73, \'a7321.283; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.277}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 59, \'a792}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.233}}}{{\f5\fs12\hyphpar0\qj{, 321.241}}}{{\f5\fs12\hyphpar0\qj{, 321N.3}}}{{\f5\fs12\hyphpar0\qj{, 668.15A}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 915.80}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.277A}}}{\*\bkmkstart stylerid1_2E33_30_2E2_2E2}{\*\bkmkend stylerid1_2E33_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Careless driving.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person commits careless driving if the person intentionally operates a motor vehicle on a public road or highway in any one of the following ways:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Creates or causes unnecessary tire squealing, skidding, or sliding upon acceleration or stopping.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Simulates a temporary race.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Causes any wheel or wheels to unnecessarily lose contact with the ground.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Causes the vehicle to unnecessarily turn abruptly or sway.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 147, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(6)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.278}}}{\*\bkmkstart stylerid1_2E331_2E2_2E2}{\*\bkmkend stylerid1_2E331_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Drag racing prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Engage in any motor vehicle speed contest or exhibition of speed on any street or highway of this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Aid or abet any motor vehicle speed contest or exhibition of speed on any street or highway of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A passenger shall not be considered as aiding and abetting. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmotor vehicle speed contest\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fexhibition of speed\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one or more persons competing in speed in excess of the applicable speed limit in vehicles on the public streets or highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who violates the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be guilty of a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, \'a7321.284; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.278}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1026, \'a7112}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7707.6A}}}{{\f5\fs12\hyphpar0\qj{, 707.8}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(5)(c)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.279}}}{\*\bkmkstart stylerid1_2E332_2E2_2E2}{\*\bkmkend stylerid1_2E332_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Eluding or attempting to elude pursuing law enforcement vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a motor vehicle commits a serious misdemeanor if the driver willfully fails to bring the motor vehicle to a stop or otherwise eludes or attempts to elude a marked or unmarked official law enforcement vehicle driven by a peace officer after being given a visual and audible signal to stop. The signal given by the peace officer shall be by flashing red light, or by flashing red and blue lights, and siren. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpeace officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those officers designated under }}}{{\f5\fs18\hyphpar0\qj{section 801.4, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a motor vehicle who commits a violation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and who has previously committed any violation under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is, upon conviction, guilty of an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a motor vehicle commits a class \u8220\'3fD\u8221\'3f felony if the driver willfully fails to bring the motor vehicle to a stop or otherwise eludes or attempts to elude a marked or unmarked official law enforcement vehicle that is driven by a peace officer after being given a visual and audible signal as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and in doing so exceeds the speed limit by twenty-five miles per hour or more.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a motor vehicle who commits a violation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and who has previously committed any violation under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is, upon conviction, guilty of a class \u8220\'3fC\u8221\'3f felony.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7321.279}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1069, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 31, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7153}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1147, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1028, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1121, \'a765, 70}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 183, \'a749, 52}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 42, \'a73 \u8211\'3f 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.209}}}{{\f5\fs12\hyphpar0\qj{, 321.555}}}{{\f5\fs12\hyphpar0\qj{, 321J.2}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 907.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.280}}}{\*\bkmkstart stylerid1_2E333_2E2_2E2}{\*\bkmkend stylerid1_2E333_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Assaults and homicide.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A conviction of the violation of any of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not be a bar to a prosecution for an assault or for a homicide committed by any person in operating motor vehicles.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m30; C24, 27, 31, 35, \'a75091; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5022.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.280}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.228}}}{{\f5\fs12\hyphpar0\qj{, 321.233}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.281}}}{\*\bkmkstart stylerid1_2E334_2E2_2E2}{\*\bkmkend stylerid1_2E334_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Actions against bicyclists.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a motor vehicle shall not steer the motor vehicle unreasonably close to or toward a person riding a bicycle on a highway, including the roadway or the shoulder adjacent to the roadway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not knowingly project any object or substance at or against a person riding a bicycle on a highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1193, \'a7143}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(14)(k)}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.282 and 321.283}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.284}}}{\*\bkmkstart stylerid1_2E336_2E2_2E2}{\*\bkmkend stylerid1_2E336_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Open containers in motor vehicles }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ drivers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a motor vehicle upon a public street or highway shall not possess in the passenger area of the motor vehicle an open or unsealed bottle, can, jar, or other receptacle containing an alcoholic beverage or a beverage containing any amount of tetrahydrocannabinol. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPassenger area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the area designed to seat the driver and passengers while the motor vehicle is in operation and any area that is readily accessible to the driver or a passenger while in their seating positions, including the glove compartment. An open or unsealed receptacle containing an alcoholic beverage or an otherwise lawful beverage containing tetrahydrocannabinol may be transported in the trunk of the motor vehicle. An unsealed receptacle containing an alcoholic beverage or an otherwise lawful beverage containing tetrahydrocannabinol may be transported behind the last upright seat of the motor vehicle if the motor vehicle does not have a trunk. A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under the age of twenty-one who possesses an alcoholic beverage in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.47}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 48, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1100, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1204, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 77, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1128, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 9, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.30}}}{{\f5\fs12\hyphpar0\qj{, 123.31A}}}{{\f5\fs12\hyphpar0\qj{, 123.31C}}}{{\f5\fs12\hyphpar0\qj{, 123.49}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(e)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.284A}}}{\*\bkmkstart stylerid1_2E337_2E2_2E2}{\*\bkmkend stylerid1_2E337_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Open containers in motor vehicles \u8212\'3f passengers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A passenger in a motor vehicle upon a public street or highway shall not possess in the passenger area of the motor vehicle an open or unsealed bottle, can, jar, or other receptacle containing an alcoholic beverage or a beverage containing any amount of tetrahydrocannabinol. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPassenger area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the area of a motor vehicle designed to seat the driver and passengers while the motor vehicle is in operation and any area that is readily accessible to the driver or a passenger while in their seating positions, including the glove compartment. An open or unsealed receptacle containing an alcoholic beverage or an otherwise lawful beverage containing tetrahydrocannabinol may be transported in the trunk of the motor vehicle. An unsealed receptacle containing an alcoholic beverage or an otherwise lawful beverage containing tetrahydrocannabinol may be transported behind the last upright seat of the motor vehicle if the motor vehicle does not have a trunk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a passenger being transported in a motor vehicle designed, maintained, or used primarily for the transportation of persons for compensation, or a passenger being transported in the living quarters of a motor home, motorsports recreational vehicle, manufactured or mobile home, travel trailer, or fifth-wheel travel trailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under the age of twenty-one years who possesses an alcoholic beverage in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.47}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not include a conviction for a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on the individual driving record of the person committing the violation and the conviction shall not be considered by the department in any proceeding for suspension, revocation, barring, or denying of the person\u8217\'3fs driver\u8217\'3fs license or upon any application for renewal of driving privileges.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 77, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1128, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1127, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 9, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.30}}}{{\f5\fs12\hyphpar0\qj{, 123.31A}}}{{\f5\fs12\hyphpar0\qj{, 123.31C}}}{{\f5\fs12\hyphpar0\qj{, 123.49}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(e)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Consumption or intoxication in public places, see }{{\f5\fs12\hyphpar0\qj{\'a7123.46}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 1 and 4 amended}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E338_2E1_2E1}{SPEED RESTRICTIONS}{\*\bkmkend stylerid1_2E338_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.285}}}{\*\bkmkstart stylerid1_2E339_2E2_2E2}{\*\bkmkend stylerid1_2E339_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Speed restrictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person driving a motor vehicle on a highway shall drive the same at a careful and prudent speed not greater than nor less than is reasonable and proper, having due regard to the traffic, surface, and width of the highway and of any other conditions then existing, and no person shall drive any vehicle upon a highway at a speed greater than will permit the person to bring it to a stop within the assured clear distance ahead, such driver having the right to assume, however, that all persons using said highway will observe the law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or except as posted pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 262.68}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.236, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 321.288, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 321.289}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.290}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.293}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.295}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{461A.36}}}{{\f5\fs18\hyphpar0\qj{, the following shall be the lawful speed and any speed in excess thereof shall be unlawful:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Twenty miles per hour in any business district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Twenty-five miles per hour in any residence or school district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Forty-five miles per hour in any suburban district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each school district as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 70}}}{{\f5\fs18\hyphpar0\qj{, shall be marked by distinctive signs as provided by the current manual of uniform traffic control devices adopted by the department and placed on the highway at the limits of such school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or by other speed restrictions, the speed limit for all vehicular traffic shall be fifty-five miles per hour.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A reasonable and proper speed is required, but not greater than fifty-five miles per hour at any time between sunrise and sunset, and not greater than fifty miles per hour at any time between sunset and sunrise, on secondary roads unless such roads are surfaced with concrete or asphalt or a combination of both, in which case the speed limits shall be the same as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. When the board of supervisors of any county shall determine upon the basis of an engineering and traffic investigation that the speed limit on any secondary road is greater than is reasonable and proper under the conditions found to exist at any intersection or other place or upon any part of a secondary road, the board shall determine and declare a reasonable and proper speed limit at the intersection or other part of the secondary road. The speed limits as determined by the board of supervisors shall be effective when appropriate signs giving notice of the speed limits are erected by the board of supervisors at the intersection or other place or part of the highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other speed restrictions, the speed limit for all vehicular traffic on fully controlled-access, divided, multilaned highways is sixty-five miles per hour. However, the speed limit for all vehicular traffic on highways that are part of the interstate road system, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 306.3}}}{{\f5\fs18\hyphpar0\qj{, is seventy miles per hour. The department may establish a speed limit of sixty-five miles per hour on certain divided, multilaned highways not otherwise described in this paragraph.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, on its own motion or in response to a recommendation of a metropolitan or regional planning commission or council of governments, may establish a lower speed limit on a highway described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffully controlled-access highway\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a highway that gives preference to through traffic by providing access connections with selected public roads only and by prohibiting crossings at grade or direct private driveway connections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A minimum speed may be established by the department on the highways referred to in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if warranted by engineering and traffic investigations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle, device, implement, or conveyance incapable of attaining and maintaining a speed of forty miles per hour shall be prohibited from using the interstate road system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph does not apply to an implement of husbandry that a person is authorized to operate on the segment of United States highway 65, and state highway 5, including where the highway designations overlap, between the highway\u8217\'3fs intersection with United States highway 6 and the highway\u8217\'3fs intersection with United States highway 69, or farther west if authorized by the department, prior to the date that segment of highway is designated a part of the interstate road system, if the segment of highway is designated a part of the interstate road system. The department may authorize an implement of husbandry to be operated on a segment of the highway described above farther west beyond the intersection with United States highway 69. This subparagraph is repealed on the date an alternative route for implements of husbandry is developed, deemed suitable by the department of transportation in consultation with the department of agriculture and land stewardship, and opened for traffic to bypass the segment of the interstate road system described in this subparagraph. The department of transportation shall notify the Iowa Code editor on that date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other speed restrictions, a self-propelled implement of husbandry equipped with flotation tires that is designed to be loaded and operated in the field and used exclusively for the application of organic or inorganic plant food materials, agricultural limestone, or agricultural chemicals shall not be operated on a highway at a speed in excess of thirty-five miles per hour.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other speed restrictions, the speed limit for all vehicular traffic on a street or highway on which a cattle guard is installed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 314.30}}}{{\f5\fs18\hyphpar0\qj{ is fifteen miles per hour between the point at which the cattle guard is installed and the point at which the street or highway terminates in a dead end.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for excessive speed in violation of a speed limit commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 5}}}{{\f5\fs18\hyphpar0\qj{. A person who operates a school bus at a speed which exceeds a limit established under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by ten miles per hour or less commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 10}}}{{\f5\fs18\hyphpar0\qj{. A person who violates any other provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m19, -m20; C24, 27, 31, 35, \'a75029, 5030; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5023.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.285}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 120, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 47, \'a73 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1173, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1126, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1191, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 165, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 143, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a7119}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1083, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a795}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a782}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1118, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 118, \'a72, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.233}}}{{\f5\fs12\hyphpar0\qj{, 321.236}}}{{\f5\fs12\hyphpar0\qj{, 321.291}}}{{\f5\fs12\hyphpar0\qj{, 321.292}}}{{\f5\fs12\hyphpar0\qj{, 321.293}}}{{\f5\fs12\hyphpar0\qj{, 331.362}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 723.4}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(5)(a)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(10)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Speed limits at regents institutions, see }{{\f5\fs12\hyphpar0\qj{\'a7262.68}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Speeding violations by implements of husbandry, see }{{\f5\fs12\hyphpar0\qj{\'a7321.383}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Speed limits in state parks and preserves, see }{{\f5\fs12\hyphpar0\qj{\'a7461A.36}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 5, paragraph e applies to the segment of the highway known as United States highway 65, and state highway 5, including where the highway designations overlap, on July 1, 2025, and shall apply to that segment of the highway thereafter regardless of whether the highway\u8217\'3fs designation is subsequently changed; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 118, \'a74}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5, paragraph e amended}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.286 and 321.287}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.288}}}{\*\bkmkstart stylerid1_2E341_2E2_2E2}{\*\bkmkend stylerid1_2E341_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Control of vehicle }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ reduced speed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a motor vehicle shall have the vehicle under control at all times.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a motor vehicle shall reduce the speed to a reasonable and proper rate:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When approaching and passing a person walking in the traveled portion of the public highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When approaching and passing an animal which is being led, ridden, or driven upon a public highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When approaching and traversing a crossing or intersection of public highways, or a sharp turn, curve, or steep descent in a public highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When approaching and passing an emergency warning device displayed in accordance with rules adopted under }}}{{\f5\fs18\hyphpar0\qj{section 321.449}}}{{\f5\fs18\hyphpar0\qj{, or an emergency vehicle displaying a revolving or flashing light.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When approaching and passing a slow moving vehicle displaying a reflective device or alternative reflective device as provided by }}}{{\f5\fs18\hyphpar0\qj{section 321.383}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When approaching and passing through a road work zone.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75031; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5023.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.288}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 167, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 170, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 296, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 102, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1083, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.285}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.289}}}{\*\bkmkstart stylerid1_2E342_2E2_2E2}{\*\bkmkend stylerid1_2E342_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Speed signs \u8212\'3f duty to install.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall furnish and place on primary roads or on extensions of primary roads within any city suitable standard signs showing the points at which the rate of speed changes and the maximum rate of speed in the district which the vehicle is entering. On all other main highways the city shall furnish and erect suitable signs giving similar information to traffic on such highways.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m20; C24, \'a75030; C27, 31, 35, \'a75030-b2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5023.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.289}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.285}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.290}}}{\*\bkmkstart stylerid1_2E343_2E2_2E2}{\*\bkmkend stylerid1_2E343_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special restrictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever the department shall determine upon the basis of an engineering and traffic investigation that any speed limit set forth in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is greater or less than is reasonable or safe under the conditions found to exist at any intersection or other place or upon any part of the primary road system or upon any part of a primary road extension, the department shall determine and declare a reasonable and safe speed limit which shall be effective when appropriate signs giving notice of the speed limit are erected at such intersection or other place or part of the highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever the council in any city shall determine upon the basis of an engineering and traffic investigation that any speed limit set forth in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is greater or less than is reasonable or safe under the conditions found to exist at any intersection or other place or upon any part of the city street system, except primary road extensions, said council shall determine and adopt by ordinance such higher or lower speed limit as it deems reasonable and safe. Such speed limit shall be effective when proper and appropriate signs giving notice of the speed limit are erected at such intersections or other place or part of the street.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5023.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.290}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1026, \'a7113}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.285}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.291}}}{\*\bkmkstart stylerid1_2E344_2E2_2E2}{\*\bkmkend stylerid1_2E344_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Information or notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In every charge of violation of }{{\f5\fs18\hyphpar0\qj{section 321.285}}}{ the citation or complaint, and also the notice to appear, shall specify the speed at which the defendant is alleged to have driven and the speed limit applicable within the district or at the location.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5023.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.291}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 47, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a7104}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7170}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.292}}}{\*\bkmkstart stylerid1_2E345_2E2_2E2}{\*\bkmkend stylerid1_2E345_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil action unaffected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{section 321.285}}}{ shall not be construed to relieve the plaintiff in any civil action from the burden of proving negligence upon the part of the defendant as the proximate cause of an accident.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5023.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.292}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 47, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a7116}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.293}}}{\*\bkmkstart stylerid1_2E346_2E2_2E2}{\*\bkmkend stylerid1_2E346_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local authorities may alter limits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Local authorities in their respective jurisdiction may in their discretion subject to the approval of the department authorize by ordinance higher speeds than those stated in }{{\f5\fs18\hyphpar0\qj{section 321.285}}}{ upon through highways or upon highways or portions thereof where stop or yield signs have been erected at the entrances thereto provided signs are erected giving notice of the authorized speed, but local authorities shall not have authority to authorize by ordinance a speed in excess of fifty-five miles per hour. If local authorities fail to authorize by ordinance higher speeds than those stated in }{{\f5\fs18\hyphpar0\qj{section 321.285}}}{ upon through highways or upon highways or portions thereof where stop signs have been erected at the entrances thereto, the department may recommend, upon the basis of an engineering and traffic investigation, to the local authorities that the speed limit be increased. If local authorities fail to increase the speed limit upon said recommendation of the department, said department shall declare a reasonable and safe speed limit which shall be effective when appropriate signs are erected giving notice thereof.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5023.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.293}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.236}}}{{\f5\fs12\hyphpar0\qj{, 321.285}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.294}}}{\*\bkmkstart stylerid1_2E347_2E2_2E2}{\*\bkmkend stylerid1_2E347_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Minimum speed regulation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not drive a motor vehicle at such a slow speed as to impede or block the normal and reasonable movement of traffic except when reduced speed is necessary for safe operation or in compliance with law. Peace officers are hereby authorized to enforce this provision by directions to drivers, and in the event of apparent willful disobedience to this provision and refusal to comply with direction of an officer in accordance herewith the continued slow operation by a driver shall be a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 8}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75021-c1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5023.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.294}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1203, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 137, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(8)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For minimum speed capability requirements, see }{{\f5\fs12\hyphpar0\qj{\'a7321.382}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.295}}}{\*\bkmkstart stylerid1_2E348_2E2_2E2}{\*\bkmkend stylerid1_2E348_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitation on bridge or elevated structures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not drive a vehicle on any public bridge or elevated structure at a speed which is greater than the maximum speed permitted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ on the street or highway at a point where said street or highway joins said bridge or elevated structure. However, if the maximum speed permitted on said street or highway differs from the maximum speed on any other street or highway joining said bridge or elevated structure, then the lowest of those maximum speeds shall be the maximum speed limit on said bridge or elevated structure unless the department, upon request from any local authority or upon its own initiative, has conducted an investigation of the bridge or other elevated structure constituting a part of the highway, and has found that the structure cannot with safety to itself withstand vehicles traveling at the speed otherwise permissible under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. Under those circumstances, the department shall determine and declare the maximum speed of vehicles which the structure can withstand, and shall cause or permit suitable signs stating such maximum speed to be erected and maintained at a distance of two hundred feet before each end of such structure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not drive a vehicle over any bridge or other elevated structure constituting a part of a highway at a speed which is greater than the maximum speed which can be maintained with safety to such bridge or structure, when the structure is signposted as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the trial of any person charged with driving a vehicle at a speed which is greater than the maximum speed which can be maintained with safety to such bridge or structure, proof of such determination of the maximum speed by said department and the existence of said signs shall constitute conclusive evidence of the maximum speed which can be maintained with safety to such bridge or structure.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5023.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.295}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1069, \'a746}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.285}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(5)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 5, paragraph d}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.296}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E35_30_2E1_2E1}{DRIVING ON RIGHT SIDE OF ROADWAY \u8212\'3f}{\*\bkmkend stylerid1_2E35_30_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{OVERTAKING AND PASSING \u8212\'3f TOWING}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.297}}}{\*\bkmkstart stylerid1_2E351_2E2_2E2}{\*\bkmkend stylerid1_2E351_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driving on right-hand side of roadway \u8212\'3f exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle shall be driven upon the right half of the roadway upon all roadways of sufficient width, except as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When overtaking and passing another vehicle proceeding in the same direction under the rules governing such movement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When an obstruction exists making it necessary to drive to the left of the center of the roadway, provided, any person so doing shall yield the right-of-way to all vehicles traveling in the proper direction upon the unobstructed portion of the roadway within such distance as to constitute an immediate hazard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a roadway divided into three marked lanes for traffic under the rules applicable thereon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a roadway restricted to one-way traffic.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any vehicle proceeding at less than the normal speed of traffic at the time and place and under the conditions then existing shall be driven in the right-hand lane then available for traffic upon all roadways, or as close as practicable to the right-hand curb or edge of the roadway, except when overtaking and passing another vehicle proceeding in the same direction or when preparing for a left turn at an intersection, an alley, private road or driveway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle shall not be driven upon any roadway having four or more lanes for moving traffic and providing for two-way movement of traffic, to the left of the center line of the roadway, except when authorized by official traffic-control devices designating certain lanes to the left side of the center of the roadway for use by traffic not otherwise permitted to use such lanes, or except as permitted under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed as prohibiting the crossing of the center line in making a left turn into or from an alley, private road, or driveway.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75019; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.297}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.233}}}{{\f5\fs12\hyphpar0\qj{, 321.298}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(e)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.298}}}{\*\bkmkstart stylerid1_2E352_2E2_2E2}{\*\bkmkend stylerid1_2E352_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Meeting and turning to right.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except as otherwise provided in }{{\f5\fs18\hyphpar0\qj{section 321.297}}}{, vehicles or persons on horseback meeting each other on any roadway shall yield one-half of the roadway by turning to the right.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7908; C73, \'a71000; C97, \'a71569; S13, \'a71569; C24, 27, 31, 35, \'a75020; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.298}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.233}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(7)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 7 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.299}}}{\*\bkmkstart stylerid1_2E353_2E2_2E2}{\*\bkmkend stylerid1_2E353_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Overtaking a vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The following rules shall govern the overtaking and passing of vehicles proceeding in the same direction, subject to those limitations, exceptions, and special rules hereinafter stated:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle overtaking another vehicle proceeding in the same direction shall pass to the left of the other vehicle at a safe distance and shall not again drive to the right side of the roadway until safely clear of the overtaken vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except when overtaking and passing on the right is permitted, the driver of an overtaken vehicle shall give way to the right in favor of the overtaking vehicle and shall not increase the speed of the overtaken vehicle until completely passed by the overtaking vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71569, 1571-m18; C24, 27, 31, 35, \'a75021, 5022; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.299}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7115}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(f)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Passing on right, }{{\f5\fs12\hyphpar0\qj{\'a7321.302}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.300 and 321.301}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.302}}}{\*\bkmkstart stylerid1_2E355_2E2_2E2}{\*\bkmkend stylerid1_2E355_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Overtaking and passing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise prohibited by law, the driver of a vehicle on a roadway with unobstructed pavement of sufficient width for two or more lines of traffic moving in the same direction as the vehicle being passed may overtake and pass upon the right of another vehicle which is making or about to make a left turn when such movement can be made in safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise prohibited by law, the driver of a vehicle may overtake and, allowing sufficient clearance, pass another vehicle proceeding in the same direction either upon the left or upon the right on a roadway with unobstructed pavement of sufficient width for four or more lines of moving traffic when such movement can be made in safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle shall not drive off the pavement or upon the shoulder of the roadway or upon the apron or roadway of an intersecting roadway in overtaking or passing on the right or the left.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.302}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1203, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 6, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a747}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(g)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.303}}}{\*\bkmkstart stylerid1_2E356_2E2_2E2}{\*\bkmkend stylerid1_2E356_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations on overtaking on the left.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A vehicle shall not be driven to the left side of the center of the roadway in overtaking and passing another vehicle proceeding in the same direction unless the left side is clearly visible and is free of oncoming traffic for a sufficient distance ahead to permit the overtaking and passing to be completely made without interfering with the safe operation of a vehicle approaching from the opposite direction or a vehicle overtaken. The overtaking vehicle shall return to the right-hand side of the roadway before coming within three hundred feet of a vehicle approaching from the opposite direction when traveling on a roadway having a legal speed limit in excess of thirty miles per hour, and the overtaking vehicle shall return to the right-hand side of the roadway before coming within one hundred feet of a vehicle approaching from the opposite direction when traveling on a roadway having a legal speed limit of thirty miles per hour or less.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.303}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 125, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.304}}}{\*\bkmkstart stylerid1_2E357_2E2_2E2}{\*\bkmkend stylerid1_2E357_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited passing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No vehicle shall, in overtaking and passing another vehicle or at any other time, be driven to the left side of the roadway under the following conditions:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When approaching the crest of a grade or upon a curve in the highway where the driver\u8217\'3fs view along the highway is obstructed for a distance of approximately seven hundred feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When approaching within one hundred feet of any narrow bridge, viaduct, or tunnel, when so signposted, or when approaching within one hundred feet of or traversing any intersection or railroad grade crossing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where official signs are in place directing that traffic keep to the right or a distinctive center line or off-center line is marked, which distinctive line also so directs traffic as declared in the sign manual adopted by the department of transportation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a75024-e1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.304}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(i)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(8)(e)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsections 6 and 8 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.305}}}{\*\bkmkstart stylerid1_2E358_2E2_2E2}{\*\bkmkend stylerid1_2E358_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{One-way roadways and rotary traffic islands.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a roadway designated and signposted for one-way traffic a vehicle shall be driven only in the direction designated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle passing around a rotary traffic island shall be driven only to the right of such island.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.305}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(j)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.306}}}{\*\bkmkstart stylerid1_2E359_2E2_2E2}{\*\bkmkend stylerid1_2E359_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Roadways laned for traffic.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever any roadway has been divided into three or more clearly marked lanes for traffic the following rules in addition to all others consistent herewith shall apply:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle shall be driven as nearly as practical entirely within a single lane and shall not be moved from such lane until the driver has first ascertained that such movement can be made with safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a roadway is divided into three lanes, a vehicle shall not be driven in the center lane except as follows: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When overtaking and passing another vehicle where the roadway is clearly visible and such center lane is clear of traffic within a safe distance. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In preparation for a left turn or where such center lane is at the time allocated exclusively to traffic moving in the direction the vehicle is proceeding and is signposted to give notice of such allocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Official signs may be erected directing slow-moving traffic to use a designated lane or allocating specified lanes to traffic moving in the same direction and drivers of vehicles shall obey the directions of every such sign.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles moving in a lane designated for slow-moving traffic shall yield the right-of-way to vehicles moving in the same direction in a lane not so designated when such lanes merge to form a single lane.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A portion of a highway provided with a lane for slow-moving vehicles does not become a roadway marked for three lanes of traffic.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.306}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1069, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.208}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(k)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.307}}}{\*\bkmkstart stylerid1_2E36_30_2E2_2E2}{\*\bkmkend stylerid1_2E36_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Following too closely.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The driver of a motor vehicle shall not follow another vehicle more closely than is reasonable and prudent, having due regard for the speed of such vehicles and the traffic upon and the condition of the highway.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.307}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(7)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 7}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.308}}}{\*\bkmkstart stylerid1_2E361_2E2_2E2}{\*\bkmkend stylerid1_2E361_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motor trucks and towed vehicles \u8212\'3f distance requirements.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 79, \'a74}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.309}}}{\*\bkmkstart stylerid1_2E362_2E2_2E2}{\*\bkmkend stylerid1_2E362_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Towing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not pull or tow by motor vehicle, for hire, another motor vehicle over any highway outside the limits of any incorporated city, except in case of temporary movement of a disabled motor vehicle to the place where repairs will be made, unless the person has complied with the provisions of }{{\f5\fs18\hyphpar0\qj{sections 321.57}}}{ and }{{\f5\fs18\hyphpar0\qj{321.58}}}{. Provided, however, if the person is a nonresident of the state of Iowa and has complied with the laws of the state of that person\u8217\'3fs residence governing licensing and registration as a transporter of motor vehicles, the person shall not be required to pay the fee provided in }{{\f5\fs18\hyphpar0\qj{section 321.58}}}{ but only to submit proof of the person\u8217\'3fs status as a bona fide manufacturer or transporter as may reasonably be required by the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75067-d9; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.309}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 79, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(12)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.310}}}{\*\bkmkstart stylerid1_2E363_2E2_2E2}{\*\bkmkend stylerid1_2E363_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Towing four-wheeled trailers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle shall not tow a four-wheeled trailer with a steering axle, or more than one trailer or semitrailer, or both in combination. However, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a motor home, motorsports recreational vehicle, multipurpose vehicle, motor truck, truck tractor or road tractor nor to a farm tractor towing a four-wheeled trailer, nor to a farm tractor or motor vehicle towing implements of husbandry, nor to a wagon box trailer used by a farmer in transporting produce, farm products, or supplies hauled to and from market.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any four-wheeled trailer towed by a truck tractor or road tractor shall be registered under the semitrailer provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.123}}}{{\f5\fs18\hyphpar0\qj{; provided that the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to motor vehicles drawing wagon box trailers used by a farmer in transporting produce, farm products, or supplies hauled to and from market, or to a four-wheeled trailer towed by a motorsports recreational vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5024.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.310}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1226, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1127, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(12)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph a }\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E364_2E1_2E1}{TURNING AND STARTING AND SIGNALS}{\*\bkmkend stylerid1_2E364_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{ON STOPPING AND TURNING}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.311}}}{\*\bkmkstart stylerid1_2E365_2E2_2E2}{\*\bkmkend stylerid1_2E365_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Turning at intersections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle intending to turn at an intersection shall do so as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Both the approach for a right turn and right turn shall be made as close as practical to the right-hand curb or edge of the roadway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approach for a left turn shall be made in that portion of the right half of the roadway nearest the center line thereof and after entering the intersection the left turn shall be made so as to depart from the intersection to the right of the center line of the roadway being entered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approach for a left turn from a two-way street into a one-way street shall be made in that portion of the right half of the roadway nearest the center line thereof and by passing to the right of such center line where it enters the intersection. A left turn from a one-way street into two-way street shall be made by passing to the right of the center line of the street being entered upon leaving the intersection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities in their respective jurisdictions may cause markers, buttons, or signs to be placed within or adjacent to intersections and thereby require and direct that a different course from that specified in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ be traveled by vehicles turning at an intersection, and when markers, buttons, or signs are so placed no driver of a vehicle shall turn a vehicle at an intersection other than as directed and required by such markers, buttons, or signs.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75033; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5025.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.311}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.354}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(l)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.312}}}{\*\bkmkstart stylerid1_2E366_2E2_2E2}{\*\bkmkend stylerid1_2E366_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Turning on curve or crest of grade.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No vehicle shall be turned so as to proceed in the opposite direction upon any curve, or upon the approach to, or near the crest of a grade or hill, where such vehicle cannot be seen by the driver of any other vehicle approaching from either direction within five hundred feet.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5025.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.312}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(6)(m)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.313}}}{\*\bkmkstart stylerid1_2E367_2E2_2E2}{\*\bkmkend stylerid1_2E367_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Starting parked vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person shall start a vehicle which is stopped, standing, or parked unless and until such movement can be made with reasonable safety.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5025.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.313}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(7)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 7}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.314}}}{\*\bkmkstart stylerid1_2E368_2E2_2E2}{\*\bkmkend stylerid1_2E368_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When signal required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person shall turn a vehicle from a direct course upon a highway unless and until such movement can be made with reasonable safety and then only after giving a clearly audible signal by sounding the horn if any pedestrian may be affected by such movement or after giving an appropriate signal in the manner provided in }{{\f5\fs18\hyphpar0\qj{sections 321.315 through 321.318}}}{ in the event any other vehicle may be affected by such movement.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75032; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5025.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.314}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7171}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.316}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(n)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.315}}}{\*\bkmkstart stylerid1_2E369_2E2_2E2}{\*\bkmkend stylerid1_2E369_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Signal continuous.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A signal of intention to turn right or left shall be given continuously during not less than the last one hundred feet traveled by the vehicle before turning when the speed limit is forty-five miles per hour or less and a continuous signal during not less than the last three hundred feet when the speed limit is in excess of forty-five miles per hour.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5025.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.315}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.314}}}{{\f5\fs12\hyphpar0\qj{, 321.316}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(o)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.316}}}{\*\bkmkstart stylerid1_2E37_30_2E2_2E2}{\*\bkmkend stylerid1_2E37_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Stopping.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not stop or suddenly decrease the speed of a vehicle without first giving an appropriate signal in the manner provided in }{{\f5\fs18\hyphpar0\qj{sections 321.314}}}{, }{{\f5\fs18\hyphpar0\qj{321.315}}}{, }{{\f5\fs18\hyphpar0\qj{321.317}}}{, and }{{\f5\fs18\hyphpar0\qj{321.318}}}{ to the driver of any vehicle immediately to the rear when there is opportunity to give such signal.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75032; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5025.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.316}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7172}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.314}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(p)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.317}}}{\*\bkmkstart stylerid1_2E371_2E2_2E2}{\*\bkmkend stylerid1_2E371_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Signals by hand and arm or signal device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The signals required under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may be given either by means of the hand and arm as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.318}}}{{\f5\fs18\hyphpar0\qj{, or by a mechanical or electrical directional signal device or light conforming to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Directional signal devices shall be designed with a white, yellow or amber lamp or lamps to be displayed on the front of vehicles and with a lamp or lamps of red, yellow or amber to be displayed on the rear of vehicles. Such devices shall be capable of clearly indicating any intention to turn either to the right or to the left and shall be visible and understandable during both daylight and darkness from a distance of at least one hundred feet from the front and rear of a vehicle equipped therewith.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for any person to sell or offer for sale or operate on the highways of the state any vehicle subject to registration under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ which has never been registered in this or any other state prior to January 1, 1954, unless the vehicle is equipped with a directional signal device of a type in compliance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. Motorcycles, motorized bicycles, and semitrailers and trailers less than forty inches in width are exempt from the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a vehicle is equipped with a directional signal device, such device shall at all times be maintained in good working condition. No directional signal device shall project a glaring or dazzling light. All directional signal devices shall be self-illuminated when in use while other lamps on the vehicle are lighted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever any vehicle or combination of vehicles is disabled or for other reason may present a vehicular traffic hazard requiring unusual care in approaching, overtaking or passing, the operator then may display on the vehicle or combination of vehicles four directional signals of a type complying with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ relating to directional signal devices in simultaneous operation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75032; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5025.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.317}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 170, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a717, 18}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.314}}}{{\f5\fs12\hyphpar0\qj{, 321.316}}}{{\f5\fs12\hyphpar0\qj{, 321.404A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.318}}}{\*\bkmkstart stylerid1_2E372_2E2_2E2}{\*\bkmkend stylerid1_2E372_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Method of giving hand and arm signals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All signals required under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ which may be given by hand and arm shall when so given be given from the left side of the vehicle and the following manner and interpretation thereof is suggested:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Left turn \u8212\'3f Hand and arm extended horizontally.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Right turn \u8212\'3f Hand and arm extended upward.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Stop or decrease of speed \u8212\'3f Hand and arm extended downward.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5025.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.318}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7173}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.314}}}{{\f5\fs12\hyphpar0\qj{, 321.316}}}{{\f5\fs12\hyphpar0\qj{, 321.317}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(q)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E373_2E1_2E1}{RIGHT-OF-WAY}{\*\bkmkend stylerid1_2E373_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.319}}}{\*\bkmkstart stylerid1_2E374_2E2_2E2}{\*\bkmkend stylerid1_2E374_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Entering intersections from different highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When two vehicles enter an intersection from different highways or public streets at approximately the same time, the driver of the vehicle on the left shall yield the right-of-way to the vehicle on the right.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rule contained in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ is modified at through highways and as otherwise stated in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75035; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5026.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.319}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 59, \'a793}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(7)(e)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 7 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.320}}}{\*\bkmkstart stylerid1_2E375_2E2_2E2}{\*\bkmkend stylerid1_2E375_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Left turns }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ yielding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The driver of a vehicle who intends to turn to the left within an intersection or into an alley, private road, or driveway shall yield the right-of-way to all vehicles approaching from the opposite direction which are within the intersection or so close as to constitute an immediate hazard. The driver, after yielding and giving a signal as required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, may make the left turn.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75035; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5026.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.320}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1021, \'a770}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(7)(f)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 7}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.321}}}{\*\bkmkstart stylerid1_2E376_2E2_2E2}{\*\bkmkend stylerid1_2E376_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Entering through highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The driver of a vehicle shall stop or yield as required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ at the entrance to a through highway and shall yield the right-of-way to other vehicles which have entered the intersection from said through highway or which are approaching so closely on said through highway as to constitute a hazard, but said driver having so yielded may proceed cautiously and with due care enter said through highway.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, \'a75079-b2, -b3; C31, 35, \'a75079-b2, -b3, -d2, -d3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5026.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.321}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(7)(g)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 7 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.322}}}{\*\bkmkstart stylerid1_2E377_2E2_2E2}{\*\bkmkend stylerid1_2E377_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vehicles entering stop or yield intersection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle approaching a stop intersection indicated by a stop sign shall stop at the first opportunity at either the clearly marked stop line or before entering the crosswalk or before entering the intersection or at the point nearest the intersecting roadway where the driver has a view of approaching traffic on the intersecting roadway before entering the intersection. Before proceeding, the driver shall yield the right-of-way to any vehicle on the intersecting roadway which has entered the intersection or which is approaching so closely as to constitute an immediate hazard during the time the driver is moving across or within the intersection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle approaching a yield sign shall slow to a speed reasonable for the existing conditions and, if required for safety, shall stop at the first opportunity at either the clearly marked stop line or before entering the crosswalk or before entering the intersection or at the point nearest the intersecting roadway where the driver has a view of approaching traffic on the intersecting roadway. After slowing or stopping, the driver shall yield the right-of-way to any vehicle on the intersecting roadway which has entered the intersection or which is approaching so closely as to constitute an immediate hazard during the time the driver is moving across or within the intersection.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, \'a75079-b2, -b3; C31, 35, \'a75079-b2, -b3, -d2, -d3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5026.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.322}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(8)(f)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 8 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.323}}}{\*\bkmkstart stylerid1_2E378_2E2_2E2}{\*\bkmkend stylerid1_2E378_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Moving vehicle backward on highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not cause a vehicle to be moved in a backward direction on a highway unless and until the vehicle can be backed with reasonable safety, and shall yield the right-of-way to any approaching vehicle on the highway or an intersecting highway which is so close as to constitute an immediate hazard.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.323}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a735}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.233}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(r)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.323A}}}{\*\bkmkstart stylerid1_2E379_2E2_2E2}{\*\bkmkend stylerid1_2E379_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Approaching certain stationary vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operator of a motor vehicle approaching a stationary authorized emergency vehicle that is displaying flashing lights, as permitted under }}}{{\f5\fs18\hyphpar0\qj{section 321.423}}}{{\f5\fs18\hyphpar0\qj{, shall approach the authorized emergency vehicle with due caution and shall proceed in one of the following manners, absent any other direction by a peace officer:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make a lane change into a lane not adjacent to the authorized emergency vehicle if possible in the existing safety and traffic conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a lane change under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ would be impossible, prohibited by law, or unsafe, reduce the speed of the motor vehicle to a reasonable and proper speed for the existing road and traffic conditions, which speed shall be less than the posted speed limit, and be prepared to stop.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operator of a motor vehicle approaching a stationary towing or recovery vehicle, a stationary utility maintenance vehicle, a stationary municipal maintenance vehicle, a stationary highway maintenance vehicle, a stationary construction vehicle, or a stationary solid waste or recycling collection service vehicle, that is displaying flashing lights, as permitted under }}}{{\f5\fs18\hyphpar0\qj{section 321.423}}}{{\f5\fs18\hyphpar0\qj{, shall approach the vehicle with due caution and shall proceed in one of the following manners, absent any other direction by a peace officer:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make a lane change into a lane not adjacent to the stationary motor vehicle if possible in the existing safety and traffic conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a lane change under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ would be impossible, prohibited by law, or unsafe, reduce the speed of the motor vehicle to a reasonable and proper speed for the existing road and traffic conditions, which speed shall be less than the posted speed limit, and be prepared to stop.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operator of a motor vehicle approaching a stationary motor vehicle that is continually displaying its emergency signal lamps flashing simultaneously shall approach the vehicle with due caution and shall proceed in one of the following manners, absent any other direction by a peace officer:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make a lane change into a lane not adjacent to the stationary motor vehicle if possible in the existing safety and traffic conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a lane change under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ would be impossible, prohibited by law, or unsafe, reduce the speed of the motor vehicle to a reasonable and proper speed for the existing road and traffic conditions, which speed shall be less than the posted speed limit, and be prepared to stop.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under section }}}{{\f5\fs18\hyphpar0\qj{805.8A, subsection 11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ which resulted in an accident causing bodily injury to or the death of another person may be subject to the following penalties in addition to the penalty provided for a scheduled violation in }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, or any other penalty provided by law:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a violation causing bodily injury to another person, a fine of five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a violation causing death, a fine of one thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving a record of a person\u8217\'3fs conviction for a violation under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ which resulted in an accident causing damage to the property of another person or bodily injury to or death of another person, the department shall suspend the person\u8217\'3fs driver\u8217\'3fs license or operating privileges, upon thirty days\u8217\'3f notice and without preliminary hearing, as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a violation causing damage to the property of another person, but not resulting in bodily injury to or death of another person, the department shall suspend the violator\u8217\'3fs driver\u8217\'3fs license or operating privileges for ninety days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a violation causing bodily injury to another person, the department shall suspend the violator\u8217\'3fs driver\u8217\'3fs license or operating privileges for one hundred eighty days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a violation causing death, the department shall suspend the violator\u8217\'3fs driver\u8217\'3fs license or operating privileges for one year.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1013, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 2, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1083, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 81, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 84, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1079, \'a71 \u8211\'3f 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(11)(a)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(11)(b)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.324}}}{\*\bkmkstart stylerid1_2E38_30_2E2_2E2}{\*\bkmkend stylerid1_2E38_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operation on approach of emergency vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fred light\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fblue light\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a light or lighting device that, when illuminated, will exhibit a solid flashing or strobing red or blue light.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the immediate approach of an authorized emergency vehicle with any lamp or device displaying a red light or red and blue lights, or an authorized emergency vehicle of a fire department displaying a blue light, or when the driver is giving audible signal by siren, exhaust whistle, or bell, the driver of every other vehicle shall yield the right-of-way and shall immediately drive to a position parallel to, and as close as possible to, the right-hand edge or curb of the highway clear of any intersection and shall stop and remain in such position until the authorized emergency vehicle has passed, except when otherwise directed by a police officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the approach of an authorized emergency vehicle, as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the driver of every streetcar shall immediately stop such car clear of any intersection and keep it in such position until the authorized emergency vehicle has passed, except when otherwise directed by a police officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not operate to relieve the driver of an authorized emergency vehicle from the duty to drive with due regard for the safety of all persons using the highway.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5026.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.324}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1045, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a795}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(11)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 11}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.324A}}}{\*\bkmkstart stylerid1_2E381_2E2_2E2}{\*\bkmkend stylerid1_2E381_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funeral processions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffuneral procession\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a procession of motor vehicles accompanying the body of a deceased person during daylight hours which is being escorted by a vehicle continually displaying its emergency signal lamps flashing simultaneously and using lighted headlamps and identifying flags, or an escort vehicle displaying a flashing or revolving red and amber light visible to pedestrians in all directions, and keeping all other motor vehicles with lighted headlamps in close formation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the immediate approach of a funeral procession, the driver of every other vehicle, except an authorized emergency vehicle, shall yield the right-of-way. An operator of a motor vehicle which is part of a funeral procession shall not be charged with violating traffic rules and regulations relating to traffic signals and devices while participating in the procession unless the operation is reckless.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The funeral establishment in charge of the funeral procession is liable only in connection with the procession for any negligent, reckless, or intentional act by the funeral establishment or any employee or agent of the funeral establishment that results in any death, personal injury or property damage suffered during a funeral procession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of an authorized emergency vehicle may operate the vehicle as part of a funeral procession, and a peace officer may provide traffic control relating to a funeral procession upon request or when necessary for the safety of all persons.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of law to the contrary, an authorized emergency vehicle operating in a funeral procession or for traffic control relating to a funeral procession may display any of the vehicle\u8217\'3fs lighting devices. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to exempt the driver of the authorized emergency vehicle from any duty to operate the vehicle with due regard for the safety of all persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1139, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a736, 93}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1087, \'a77, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.423}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(s)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Flashing lights, see }{{\f5\fs12\hyphpar0\qj{\'a7321.423}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E382_2E1_2E1}{PEDESTRIANS\u8217\'3f RIGHTS AND DUTIES}{\*\bkmkend stylerid1_2E382_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.325}}}{\*\bkmkstart stylerid1_2E383_2E2_2E2}{\*\bkmkend stylerid1_2E383_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pedestrians subject to signals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Pedestrians shall be subject to traffic-control signals at intersections as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, but at all other places pedestrians shall be accorded the privileges and shall be subject to the restrictions stated in }{{\f5\fs18\hyphpar0\qj{sections 321.327 through 321.331}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5027.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.325}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 59, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(9)(e)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 9 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.326}}}{\*\bkmkstart stylerid1_2E384_2E2_2E2}{\*\bkmkend stylerid1_2E384_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pedestrians on left.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Pedestrians shall at all times when walking on or along a highway, walk on the left side of such highway.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5027.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.326}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321O.4}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9)(f)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 9 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.327}}}{\*\bkmkstart stylerid1_2E385_2E2_2E2}{\*\bkmkend stylerid1_2E385_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pedestrians\u8217\'3f and bicyclists\u8217\'3f right-of-way.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where traffic-control signals are not in place or in operation, the driver of a vehicle shall yield the right-of-way, slowing down or stopping if need be to so yield, to a pedestrian or a person riding a bicycle crossing the roadway within any marked crosswalk or within any unmarked crosswalk at an intersection, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5027.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.327}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1203, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1137, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.325}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(7)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.328}}}{\*\bkmkstart stylerid1_2E386_2E2_2E2}{\*\bkmkend stylerid1_2E386_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Crossing at other than crosswalk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every pedestrian crossing a roadway at any point other than within a marked crosswalk or within an unmarked crosswalk at an intersection shall yield the right-of-way to all vehicles upon the roadway except that cities may restrict such a crossing by ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any pedestrian crossing a roadway at a point where a pedestrian tunnel or overhead pedestrian crossing has been provided shall yield the right-of-way to all vehicles upon the roadway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where traffic-control signals are in operation at any place not an intersection pedestrians shall not cross at any place except in a marked crosswalk.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5027.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.328}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.325}}}{{\f5\fs12\hyphpar0\qj{, 321.329}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9)(g)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 9 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.329}}}{\*\bkmkstart stylerid1_2E387_2E2_2E2}{\*\bkmkend stylerid1_2E387_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty of driver \u8212\'3f pedestrians crossing or working on highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.328}}}{{\f5\fs18\hyphpar0\qj{ every driver of a vehicle shall exercise due care to avoid colliding with any pedestrian upon any roadway and shall give warning by sounding the horn when necessary and shall exercise due care upon observing any child or any confused or incapacitated person upon a roadway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every driver of a vehicle shall yield the right-of-way to pedestrian workers engaged in maintenance or construction work on a highway whenever the driver is notified of the presence of such workers by a flagman or a warning sign.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5027.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.329}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.325}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(7)(i)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 7}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.330}}}{\*\bkmkstart stylerid1_2E388_2E2_2E2}{\*\bkmkend stylerid1_2E388_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of crosswalks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Pedestrians shall move, whenever practicable, upon the right half of crosswalks.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5027.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.330}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.325}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.331}}}{\*\bkmkstart stylerid1_2E389_2E2_2E2}{\*\bkmkend stylerid1_2E389_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pedestrians soliciting rides.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall stand in a roadway for the purpose of soliciting a ride from the driver of any private vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be construed so as to prevent any pedestrian from standing on that portion of the highway or roadway, not ordinarily used for vehicular traffic, for the purpose of soliciting a ride from the driver of any vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5027.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.331}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.325}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 9 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.332}}}{\*\bkmkstart stylerid1_2E39_30_2E2_2E2}{\*\bkmkend stylerid1_2E39_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{White canes restricted to blind persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purpose of guarding against accidents in traffic on the public thoroughfares, it shall be unlawful for any person except persons wholly or partially blind to carry or use on the streets, highways, and public places of the state any white canes or walking sticks which are white in color or white tipped with red.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.332}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7216C.8}}}{{\f5\fs12\hyphpar0\qj{, 321.334}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9)(i)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 9}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.333}}}{\*\bkmkstart stylerid1_2E391_2E2_2E2}{\*\bkmkend stylerid1_2E391_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty of drivers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any driver of a vehicle or operator of a motor-driven vehicle who approaches or comes in contact with a person wholly or partially blind carrying a cane or walking stick white in color or white tipped with red, or being led by a guide dog wearing a harness and walking on either side of or slightly in front of said blind person, shall immediately come to a complete stop, and take such precautions as may be necessary to avoid accident or injury to the person carrying a cane or walking stick white in color or white tipped with red or being led by a guide dog.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.333}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7216C.8}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(7)(j)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 7 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.334}}}{\*\bkmkstart stylerid1_2E392_2E2_2E2}{\*\bkmkend stylerid1_2E392_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall be fined not less than one dollar nor more than one hundred dollars for each offense, if the person does any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carries a cane or walking stick such as is prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 321.332}}}{{\f5\fs18\hyphpar0\qj{, but contrary to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fails to heed the approach of a person lawfully carrying a cane or walking stick that is white in color or white tipped with red, or who is being led by a guide dog.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fails to immediately come to a complete stop and take such precautions against accident or injury to a person described in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.334}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 59, \'a795}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For scheduled fine applicable to }{{\f5\fs12\hyphpar0\qj{\'a7321.332}}}{ violations, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 9 }\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.335 through 321.339}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.340}}}{\*\bkmkstart stylerid1_2E394_2E2_2E2}{\*\bkmkend stylerid1_2E394_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driving through safety zone.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No vehicle shall at any time be driven through or within a safety zone.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5028.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.340}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(6)(t)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E395_2E1_2E1}{SPECIAL STOPS REQUIRED}{\*\bkmkend stylerid1_2E395_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.341}}}{\*\bkmkstart stylerid1_2E396_2E2_2E2}{\*\bkmkend stylerid1_2E396_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Obedience to signal indicating approach of railroad train or railroad track equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a person driving a vehicle approaches a railroad grade crossing and warning is given by automatic signal, crossing gates, a flag person, or otherwise of the immediate approach of a railroad train or railroad track equipment, the driver of the vehicle shall stop the vehicle within fifty feet but not less than fifteen feet from the nearest rail and shall not proceed until the driver can do so safely.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle shall stop the vehicle and the vehicle shall remain standing and not traverse such a grade crossing when a crossing gate is lowered or when a human flagman gives or continues to give a signal of the approach or passage of a railroad train or railroad track equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ that occur at a railroad grade crossing that has a median barrier and that is established as a quiet zone in accordance with }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 222, subpt. C}}}{{\f5\fs18\hyphpar0\qj{, the person may attend and successfully complete, at the person\u8217\'3fs own expense, a driver improvement program approved by the department in lieu of the fine imposed under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2). To be eligible, the person shall notify the clerk of court prior to the date of the person\u8217\'3fs court appearance as indicated on the citation that the person intends to attend and successfully complete a driver improvement program, and shall submit to the clerk of court written verification that the person completed the driver improvement program, signed by the instructor of the program, within ninety days of the violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who notifies the clerk of court that the person intends to successfully complete a driver improvement program pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, but who does not submit the required written verification that the person successfully completed the driver improvement program to the clerk of court within ninety days of the violation, shall be assessed the fine described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ on the ninety-first day after the violation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.341}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 170, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1044, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a782}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1055, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.208}}}{{\f5\fs12\hyphpar0\qj{, 321.343A}}}{{\f5\fs12\hyphpar0\qj{, 321.344A}}}{{\f5\fs12\hyphpar0\qj{, 321.344B}}}{{\f5\fs12\hyphpar0\qj{, 321.484}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 14, paragraph h }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.342}}}{\*\bkmkstart stylerid1_2E397_2E2_2E2}{\*\bkmkend stylerid1_2E397_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Stop at certain railroad crossings \u8212\'3f posting warning.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of any vehicle approaching a railroad grade crossing across which traffic is regulated by a stop sign, a railroad sign directing traffic to stop, or an official traffic control signal displaying a flashing red or steady circular red colored light shall stop prior to driving across the railroad grade crossing at the first opportunity at either the clearly marked stop line or at a point near the crossing where the driver has a clear view of the approaching railroad train or railroad track equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, city or county shall be required to post the standard sign as prescribed by the manual on uniform traffic-control devices adopted by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.252}}}{{\f5\fs18\hyphpar0\qj{ in advance of each railroad grade crossing to warn the motorist that the motorist is approaching a railroad grade crossing. Upon properly posting all railroad grade crossings within its jurisdiction and upon implementing the standards established in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 307.26}}}{{\f5\fs18\hyphpar0\qj{, the department, city, or county shall not have any other affirmative duty to warn a motor vehicle operator approaching or at the railroad grade crossing.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.342}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1044, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.344A}}}{{\f5\fs12\hyphpar0\qj{, 321.344B}}}{{\f5\fs12\hyphpar0\qj{, 321.484}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 14, paragraph h }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.343}}}{\*\bkmkstart stylerid1_2E398_2E2_2E2}{\*\bkmkend stylerid1_2E398_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certain vehicles must stop.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a motor vehicle carrying passengers for hire, a school bus, or a vehicle carrying hazardous material and required to stop before driving across a railroad track by motor carrier safety rules adopted under }}}{{\f5\fs18\hyphpar0\qj{section 321.449}}}{{\f5\fs18\hyphpar0\qj{, before driving across at grade any track of a railroad, shall stop the vehicle within fifty feet but not less than fifteen feet from the nearest rail. While stopped, the driver shall listen and look in both directions for an approaching railroad train or railroad track equipment, and for signals indicating the approach of a railroad train or railroad track equipment, and shall not proceed until the driver can do so safely.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a commercial motor vehicle shall comply with all of the following provisions that apply to the driver:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the driver is not always required to stop at a railroad crossing, slow down when approaching the crossing and check that the railroad tracks are clear of an approaching railroad train or railroad track equipment before proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the driver is not always required to stop at a railroad crossing, stop before reaching the crossing if the railroad tracks are not clear.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refrain from proceeding through a railroad crossing if sufficient space is not available to drive completely through the crossing without stopping.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Obey a traffic-control device or the directions of an enforcement official at a railroad crossing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Have sufficient undercarriage clearance before negotiating a railroad crossing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No stop need be made at a crossing where a peace officer or a traffic-control device directs traffic to proceed. No stop need be made at a crossing designated by an \u8220\'3fexempt\u8221\'3f sign. An \u8220\'3fexempt\u8221\'3f sign shall be posted only where the tracks have been partially removed on either side of the roadway.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a75105-a33; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.343}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1200, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 170, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1044, \'a73, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.208}}}{{\f5\fs12\hyphpar0\qj{, 321.343A}}}{{\f5\fs12\hyphpar0\qj{, 321.344A}}}{{\f5\fs12\hyphpar0\qj{, 321.344B}}}{{\f5\fs12\hyphpar0\qj{, 321.484}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 14, paragraph h }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.343A}}}{\*\bkmkstart stylerid1_2E399_2E2_2E2}{\*\bkmkend stylerid1_2E399_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employer violations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An employer shall not knowingly allow, require, permit, or authorize a driver to operate a commercial motor vehicle in violation of }{{\f5\fs18\hyphpar0\qj{section 321.341}}}{ or }{{\f5\fs18\hyphpar0\qj{321.343}}}{ or any other federal or local law or regulation pertaining to railroad grade crossings. An employer who violates }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be subject to a fine in an amount in accordance with the civil penalty provided in }{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 386, Appendix B(b)(3)}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1021, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 126, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.344}}}{\*\bkmkstart stylerid1_2E4_30_30_2E2_2E2}{\*\bkmkend stylerid1_2E4_30_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Heavy equipment at crossing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall operate or move any caterpillar tractor, steam shovel, derrick, roller, or any equipment or structure having a normal operating speed of six or less miles per hour or a vertical body or load clearance of less than nine inches above the level surface of a roadway upon or across any tracks at a railroad grade crossing without first complying with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of the intended crossing shall be given to a superintendent of the railroad, and a reasonable time shall be given to the railroad to provide proper protection at the crossing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before making the crossing, the person operating or moving the vehicle or equipment shall first stop the vehicle or equipment not less than ten feet nor more than fifty feet from the nearest rail of the railroad and, while stopped, shall listen and look in both directions along the track for any approaching railroad train or railroad track equipment and for signals indicating the approach of a railroad train or railroad track equipment, and shall not proceed until the crossing can be made safely.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No such crossing shall be made when warning is given by automatic signal or crossing gates or a flagman or otherwise of the immediate approach of a railroad train or railroad track equipment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.344}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1044, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.344A}}}{{\f5\fs12\hyphpar0\qj{, 321.344B}}}{{\f5\fs12\hyphpar0\qj{, 321.484}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 14, paragraph h }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.344A}}}{\*\bkmkstart stylerid1_2E4_301_2E2_2E2}{\*\bkmkend stylerid1_2E4_301_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reported violations for failure to stop at a railroad crossing \u8212\'3f citations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employee of a railroad who observes a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.341}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.342}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.343}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.344}}}{{\f5\fs18\hyphpar0\qj{ may prepare a written report on a form provided by the department of public safety indicating that a violation has occurred. The railroad employee may deliver the report not more than seventy-two hours after the violation occurred to a peace officer of the state or a peace officer of the county or municipality in which the violation occurred. The report shall state the time and the location at which the violation occurred and shall include the registration plate number and a description of the vehicle involved in the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer may initiate an investigation not more than seven calendar days after receiving a report of a violation pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The peace officer may request that the owner of the vehicle supply information identifying the driver of the vehicle in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.484}}}{{\f5\fs18\hyphpar0\qj{, or in the case of a commercial motor vehicle, the peace officer may request that the employer of the driver provide information identifying the driver of the vehicle.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If from the investigation, the peace officer is able to identify the driver of the vehicle and has reasonable cause to believe a violation has occurred, the peace officer shall prepare a uniform traffic citation for the violation and shall serve it personally or by certified mail on the driver of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, from the investigation, the peace officer has reasonable cause to believe that a violation occurred but is unable to identify the driver, the peace officer shall serve a uniform traffic citation for the violation on the owner of the motor vehicle or, in the case of a commercial motor vehicle, on the employer of the driver. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 321.484}}}{{\f5\fs18\hyphpar0\qj{, in a proceeding where the peace officer who conducted the investigation was not able to identify the driver of the motor vehicle, proof that the motor vehicle described in the uniform traffic citation was used to commit the violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.341}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.342}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.343}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.344}}}{{\f5\fs18\hyphpar0\qj{, together with proof that the defendant named in the citation was the owner of the motor vehicle or, in the case of a commercial motor vehicle, the employer of the driver, at the time the violation occurred, constitutes a permissible inference that the owner or employer was the person who committed the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fowner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who holds the legal title to a motor vehicle; however, if the motor vehicle is the subject of a security agreement with a right of possession in the debtor, the debtor shall be deemed the owner for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, or if the motor vehicle is leased as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.493}}}{{\f5\fs18\hyphpar0\qj{, the lessee shall be deemed the owner for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1152, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 92, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1021, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.344B}}}{\*\bkmkstart stylerid1_2E4_302_2E2_2E2}{\*\bkmkend stylerid1_2E4_302_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Immediate safety threat \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A violation of }{{\f5\fs18\hyphpar0\qj{section 321.341}}}{, }{{\f5\fs18\hyphpar0\qj{321.342}}}{, }{{\f5\fs18\hyphpar0\qj{321.343}}}{, or }{{\f5\fs18\hyphpar0\qj{321.344}}}{ which creates an immediate threat to the safety of a person or property is a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1134, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 137, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(14)(h)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.345}}}{\*\bkmkstart stylerid1_2E4_303_2E2_2E2}{\*\bkmkend stylerid1_2E4_303_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Stop or yield at highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department, based on an engineering study, with reference to primary highways, and local authorities with reference to other highways under their jurisdiction may designate through highways and erect stop signs or yield signs, in accordance with specifications established by the department at specified entrances to the highway or may designate any intersection as a stop intersection or as a yield intersection and erect like signs at one or more entrances to such intersection.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, \'a75079-b3, -b4; C31, 35, \'a75079-b3, -b4, -d3, -d4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.345}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.347}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Analogous provision, }{{\f5\fs12\hyphpar0\qj{\'a7321.253}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.346}}}{\*\bkmkstart stylerid1_2E4_304_2E2_2E2}{\*\bkmkend stylerid1_2E4_304_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cost of signs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The cost of the signs on primary highways shall be paid out of the primary road fund. The cost of the signs on secondary roads shall be paid by the county.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, \'a75079-b4; C31, 35, \'a75079-b4, -d4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.346}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7128, 209}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.347}}}{\*\bkmkstart stylerid1_2E4_305_2E2_2E2}{\*\bkmkend stylerid1_2E4_305_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certain traffic control in cities subject to departmental approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding }{{\f5\fs18\hyphpar0\qj{section 321.345}}}{, at intersections of through highways with boulevards or heavy traffic streets in cities, the city council, subject to the approval of the department, may determine that the through highway traffic shall come to a stop, may erect traffic-control signals, or may adopt such other means of handling the traffic as may be deemed practical and proper.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-c1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.347}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 59, \'a796}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.349}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; headnote revised}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.348}}}{\*\bkmkstart stylerid1_2E4_306_2E2_2E2}{\*\bkmkend stylerid1_2E4_306_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations on cities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be unlawful for any city to close or obstruct any street or highway which is used as the extension of a primary road within such city, except at times of fires or for the purpose of doing construction or repair work on such street or highway, or for other reasons with the consent of the department, and it shall also be unlawful for any city to erect or cause to be erected or maintained any traffic sign or signal inconsistent with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-c2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.348}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.349}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.349}}}{\*\bkmkstart stylerid1_2E4_307_2E2_2E2}{\*\bkmkend stylerid1_2E4_307_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{sections 321.347}}}{ and }{{\f5\fs18\hyphpar0\qj{321.348}}}{ as concerns the erection and maintenance of \u8220\'3fstop\u8221\'3f and \u8220\'3fgo\u8221\'3f signals shall not apply to cities with a population of four thousand or over where said signals are situated within business districts of said city.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-c3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.349}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.350}}}{\*\bkmkstart stylerid1_2E4_308_2E2_2E2}{\*\bkmkend stylerid1_2E4_308_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Primary roads as through highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Primary roads, and extensions of primary roads within cities are hereby designated as through highways.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a75079-b1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.350}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.351}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.352}}}{\*\bkmkstart stylerid1_2E41_30_2E2_2E2}{\*\bkmkend stylerid1_2E41_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional signs \u8212\'3f cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county board of supervisors shall, at places deemed by them unusually dangerous on the local county roads, furnish and erect suitable warning signs. The cost of the signs shall be paid by the county.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5029.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.352}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7129, 209}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.353}}}{\*\bkmkstart stylerid1_2E411_2E2_2E2}{\*\bkmkend stylerid1_2E411_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Stop before crossing sidewalk \u8212\'3f right-of-way.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle emerging from a private roadway, alley, driveway, or building shall stop such vehicle immediately prior to driving onto the sidewalk area and thereafter the driver shall proceed into the sidewalk area only when the driver can do so without danger to pedestrian traffic and the driver shall yield the right-of-way to any vehicular traffic on the street into which the driver\u8217\'3fs vehicle is entering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle about to enter or cross a highway from a private road or driveway shall stop such vehicle immediately prior to driving on said highway and shall yield the right-of-way to all vehicles approaching on said highway.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75035; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5026.05, 5029.13;}}}{ C46, \'a7321.323, 321.353; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.353}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(6)(u)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E412_2E1_2E1}{STOPPING, STANDING, AND PARKING}{\*\bkmkend stylerid1_2E412_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.354}}}{\*\bkmkstart stylerid1_2E413_2E2_2E2}{\*\bkmkend stylerid1_2E413_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Stopping on traveled way.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ A person shall not stop, park, or leave standing an attended or unattended vehicle upon any highway outside of a business district, rural residence district, or residence district as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the paved part of the highway when it is practical to stop, park, or leave the vehicle off that part of the highway, however, a clear and unobstructed width of at least twenty feet of the paved part of the highway opposite the standing vehicle shall be left for the free passage of other vehicles. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpaved highway\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes an asphalt surfaced highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the main traveled part of a highway other than a paved highway when it is practical to stop, park, or leave the vehicle off that part of the highway. However, a clear and unobstructed width of that part of the highway opposite the standing vehicle shall be left to allow for the free passage of other vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A clear view of the stopped vehicle shall be available from a distance of two hundred feet in each direction upon the highway. However, school buses may stop on the highway for receiving and discharging pupils and all other vehicles shall stop for school buses which are stopped to receive or discharge pupils, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.372}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a vehicle making a turn as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.311}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ also does not apply to the stopping or parking of a maintenance vehicle operated by a highway authority on the main traveled way of any roadway when necessary to the function being performed and when early warning devices are properly displayed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75066; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5030.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.354}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1022, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1056, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1075, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a783}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}{{\f5\fs12\hyphpar0\qj{, 321.355}}}{{\f5\fs12\hyphpar0\qj{, 321.356}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(v)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.355}}}{\*\bkmkstart stylerid1_2E414_2E2_2E2}{\*\bkmkend stylerid1_2E414_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disabled vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 321.354}}}{ shall not apply to the driver of any vehicle which is disabled while on the paved or improved or main traveled portion of a highway in such manner and to such extent that it is impossible to avoid stopping and temporarily leaving such disabled vehicle in such position.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5030.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.355}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}{{\f5\fs12\hyphpar0\qj{, 321.356}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.356}}}{\*\bkmkstart stylerid1_2E415_2E2_2E2}{\*\bkmkend stylerid1_2E415_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Officers authorized to remove.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever any peace officer finds a vehicle standing upon a highway in violation of any of the provisions of }{{\f5\fs18\hyphpar0\qj{sections 321.354}}}{ and }{{\f5\fs18\hyphpar0\qj{321.355}}}{, such officer is hereby authorized to move such vehicle, or require the driver or other person in charge of the vehicle to move the same, to a position off the paved or improved or main traveled part of such highway.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5030.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.356}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a7117}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.357}}}{\*\bkmkstart stylerid1_2E416_2E2_2E2}{\*\bkmkend stylerid1_2E416_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Removed from bridge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever any peace officer finds a vehicle unattended upon any bridge or causeway or in any tunnel where such vehicle constitutes an obstruction to traffic, such officer is hereby authorized to provide for the removal of such vehicle to the nearest garage or other place of safety.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5030.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.357}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.358}}}{\*\bkmkstart stylerid1_2E417_2E2_2E2}{\*\bkmkend stylerid1_2E417_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Stopping, standing, or parking.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person shall stop, stand, or park a vehicle, except when necessary to avoid conflict with other traffic or in compliance with the directions of a police officer or traffic-control device, in any of the following places:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a sidewalk, except a bicycle may stop, stand, or park on a sidewalk if not prohibited by a local jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In front of a public or private driveway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within an intersection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within five feet of a fire hydrant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a crosswalk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ten feet upon the approach to any flashing beacon, stop sign, or traffic-control signal located at the side of a roadway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Between a safety zone and the adjacent curb or within ten feet of points on the curb immediately opposite the ends of a safety zone, unless any city indicates a different length by signs or markings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within fifty feet of the nearest rail of a railroad crossing, except when parked parallel with such rail and not exhibiting a red light.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within twenty feet of the driveway entrance to any fire station and on the side of a street opposite the entrance to any fire station within seventy-five feet of said entrance when properly signposted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alongside or opposite any street excavation or obstruction when such stopping, standing, or parking would obstruct traffic.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the roadway side of any vehicle stopped or parked at the edge or curb of a street.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon any bridge or other elevated structure upon a highway outside of cities or within a highway tunnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any place where official signs prohibit stopping or parking.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon any street within the corporate limits of a city when the same is prohibited by a general ordinance of uniform application relating to removal of snow or ice from the streets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In front of a curb cut or ramp which is located on public or private property in a manner which blocks access to the curb cut or ramp.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75057, 5058, 5060; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5030.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.358}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 40, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}{{\f5\fs12\hyphpar0\qj{, 321.359}}}{{\f5\fs12\hyphpar0\qj{, 602.8103}}}{{\f5\fs12\hyphpar0\qj{, 602.8106}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(1)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For fines applicable to offenses charged as scheduled violations, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 1, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.359}}}{\*\bkmkstart stylerid1_2E418_2E2_2E2}{\*\bkmkend stylerid1_2E418_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Moving other vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not move a vehicle not owned by that person into any prohibited area described in }{{\f5\fs18\hyphpar0\qj{section 321.358}}}{ or to a place that is an unlawful distance from a curb.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5030.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.359}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7174}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.360}}}{\*\bkmkstart stylerid1_2E419_2E2_2E2}{\*\bkmkend stylerid1_2E419_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Theaters, hotels, and auditoriums.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A space of not to exceed fifty feet is hereby reserved at the side of the street in front of any theater, auditorium, hotel having more than twenty-five sleeping rooms, or other buildings where large assemblages of people are being held, within which space, when clearly marked as such, no motor vehicle shall be left standing, parked, or stopped except in taking on or discharging passengers or freight, and then only for such length of time as is necessary for such purpose.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75059; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5030.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.360}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}{{\f5\fs12\hyphpar0\qj{, 602.8103}}}{{\f5\fs12\hyphpar0\qj{, 602.8106}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(1)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 1, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.361}}}{\*\bkmkstart stylerid1_2E42_30_2E2_2E2}{\*\bkmkend stylerid1_2E42_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional parking regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ every vehicle stopped or parked upon a roadway where there are adjacent curbs shall be so stopped or parked with the right-hand wheels of such vehicle parallel to and within eighteen inches of the right-hand curb.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities may by ordinance permit parking of vehicles with the left-hand wheels adjacent to and within eighteen inches of the left-hand curb of a one-way roadway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities may by ordinance permit angle or center parking on any roadway under their jurisdiction.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a74997, 5056; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5030.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.361}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}{{\f5\fs12\hyphpar0\qj{, 602.8103}}}{{\f5\fs12\hyphpar0\qj{, 602.8106}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(1)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For fines applicable to offenses charged as scheduled violations, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 1, paragraph a }\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E421_2E1_2E1}{MISCELLANEOUS RULES}{\*\bkmkend stylerid1_2E421_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.362}}}{\*\bkmkstart stylerid1_2E422_2E2_2E2}{\*\bkmkend stylerid1_2E422_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unattended motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person driving or in charge of a motor vehicle shall not permit the vehicle to stand unattended upon any perceptible grade without effectively setting the brake and turning the front wheels to the curb or side of the highway.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75038; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5031.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.362}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 8, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(1)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 1, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.363}}}{\*\bkmkstart stylerid1_2E423_2E2_2E2}{\*\bkmkend stylerid1_2E423_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Obstruction to driver\u8217\'3fs view.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall drive a vehicle when it is so loaded, or when there are in the front seat such number of persons, exceeding three, as to obstruct the view of the driver to the front or sides of the vehicle or as to interfere with the driver\u8217\'3fs control over the driving mechanism of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No passenger in a vehicle shall ride in such position as to interfere with the driver\u8217\'3fs view ahead or to the sides, or to interfere with the driver\u8217\'3fs control over the driving mechanism of the vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5031.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.363}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(6)(w)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.364}}}{\*\bkmkstart stylerid1_2E424_2E2_2E2}{\*\bkmkend stylerid1_2E424_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Preventing contamination of food by hazardous material.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Food intended for human consumption shall not be shipped in a vehicle or container which has been used to transport a hazardous material unless the vehicle or container has been purged of any hazardous material or the transportation is made in a manner that prevents any contact between the food and the hazardous material.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75031, 5043; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5031.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.364}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 170, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(13)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 13, paragraph c }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.365}}}{\*\bkmkstart stylerid1_2E425_2E2_2E2}{\*\bkmkend stylerid1_2E425_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Coasting prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The driver of a motor vehicle shall not drive with the source of motive power disengaged from the driving wheels except when disengagement is necessary to stop or to shift gears.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5031.04, 5031.05;}}}{ C46, 50, 54, 58, 62, \'a7321.365, 321.366; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.365}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 170, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(6)(x)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.366}}}{\*\bkmkstart stylerid1_2E426_2E2_2E2}{\*\bkmkend stylerid1_2E426_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Acts prohibited on fully controlled-access facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for a person, except a person operating highway maintenance equipment or an authorized emergency vehicle, to do any of the following on a fully controlled-access facility:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Drive a vehicle over, upon, or across a curb, central dividing section, or other separation or dividing line.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make a left turn or a semicircular or U-turn at a maintenance cross-over where an official sign prohibits the turn.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Drive a vehicle except in the proper lane provided for that purpose and in the proper direction and to the right of the central dividing curb, separation, section, or line.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Drive a vehicle into the facility from a local service road.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Stop, park, or leave standing a vehicle, whether attended or unattended, upon the paved portion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Stop, park, or leave standing a vehicle, whether attended or unattended, upon the shoulders, or the right-of-way except at designated rest areas or in case of an emergency or other dire necessity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ride a bicycle or use a pedestrian conveyance, or be a pedestrian, anywhere on a fully controlled-access facility. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffully controlled-access facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is a highway which gives preference to through traffic by providing access connections at interchanges with selected public roads only and by prohibiting crossings at grade or direct access at driveway connections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, \'a7306A.9; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.366}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1022, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1219, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7116}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 183, \'a750, 52}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1137, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(y)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.366A}}}{\*\bkmkstart stylerid1_2E427_2E2_2E2}{\*\bkmkend stylerid1_2E427_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Immunity from civil liability for certain vehicle operators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle who is exercising due care and who injures another person who is participating in a protest, demonstration, riot, or unlawful assembly or who is engaging in disorderly conduct and is blocking traffic in a public street or highway shall be immune from civil liability for the injury caused by the driver of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle who injures another person who is participating in a protest, demonstration, riot, or unlawful assembly or who is engaging in disorderly conduct and is blocking traffic in a public street or highway shall not be immune from civil liability if the actions leading to the injury caused by the driver of a vehicle constitute reckless or willful misconduct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall not apply if the injured person participating in a protest or demonstration was doing so with a valid permit allowing persons to protest or demonstrate on the public street or highway where the injury occurred.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 183, \'a751, 52}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.367}}}{\*\bkmkstart stylerid1_2E428_2E2_2E2}{\*\bkmkend stylerid1_2E428_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Following fire apparatus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The driver of any vehicle other than one on official business shall not follow any fire apparatus traveling in response to a fire alarm closer than five hundred feet or drive into or park such vehicle within the block where fire apparatus has stopped in answer to a fire alarm.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5031.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.367}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(11)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 11}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.368}}}{\*\bkmkstart stylerid1_2E429_2E2_2E2}{\*\bkmkend stylerid1_2E429_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Crossing fire hose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No vehicle shall be driven over any unprotected hose of a fire department when laid down on any street, private driveway, or streetcar track, to be used at any fire or alarm of fire, without the consent of the fire department official in command.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5031.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.368}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(11)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 11 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.369}}}{\*\bkmkstart stylerid1_2E43_30_2E2_2E2}{\*\bkmkend stylerid1_2E43_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Putting debris on highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not throw or deposit upon a highway any glass bottle, glass, nails, tacks, wire, cans, trash, garbage, rubbish, litter, offal, or any other debris. A person shall not throw or deposit upon a highway a substance likely to injure any person, animal, or vehicle upon the highway. A person who violates }{{\f5\fs18\hyphpar0\qj{this section}}}{ or }{{\f5\fs18\hyphpar0\qj{section 321.370}}}{ commits a misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a74808-a, -b; C24, 27, 31, 35, \'a713118; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5031.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.369}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 147, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 137, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.370}}}{{\f5\fs12\hyphpar0\qj{, 602.8108}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Litter on state water or land, see }{{\f5\fs12\hyphpar0\qj{\'a7455B.363}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.370}}}{\*\bkmkstart stylerid1_2E431_2E2_2E2}{\*\bkmkend stylerid1_2E431_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Removing injurious material.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who drops, or permits to be dropped or thrown, upon any highway any destructive or injurious material and other material as defined in }{{\f5\fs18\hyphpar0\qj{section 321.369}}}{ shall immediately remove the same or cause it to be removed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5031.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.370}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.369}}}{{\f5\fs12\hyphpar0\qj{, 602.8108}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 14, paragraph d }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.371}}}{\*\bkmkstart stylerid1_2E432_2E2_2E2}{\*\bkmkend stylerid1_2E432_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Clearing up wrecks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person removing a wrecked or damaged vehicle from a highway shall remove any glass or other injurious substance dropped upon the highway from such vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fp\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5031.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.371}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1140, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a737, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(14)(p)}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E433_2E1_2E1}{SCHOOL BUSES}{\*\bkmkend stylerid1_2E433_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.372}}}{\*\bkmkstart stylerid1_2E434_2E2_2E2}{\*\bkmkend stylerid1_2E434_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Discharging pupils \u8212\'3f stopping requirements \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{ shall be known and may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fKeep Aware Driving }}}{{\i\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\i\f5\fs18\hyphpar0\qj{ Youth Need School Safety Act\u8221\'3f}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a school bus used to transport children to and from a public or private school shall, when stopping to receive or discharge pupils, turn on flashing warning lamps at a distance of not less than three hundred feet nor more than five hundred feet from the point where the pupils are to be received or discharged from the bus if the speed limit at that point is forty-five miles per hour or greater and shall turn on flashing warning lamps at a distance of not less than one hundred fifty feet from the point where the pupils are to be received or discharged from the bus if the speed limit at that point is less than forty-five miles per hour. At the point of receiving or discharging pupils the driver of the bus shall bring the bus to a stop, turn off the amber flashing warning lamps, turn on the red flashing warning lamps, and extend the stop arm. After receiving or discharging pupils, the bus driver shall turn off all flashing warning lamps, retract the stop arm and proceed on the route. Except to the extent that reduced visibility is caused by fog, snow, or other weather conditions, a school bus shall not stop to receive or discharge pupils unless there is at least three hundred feet of unobstructed vision in each direction. However, the driver of a school bus is not required to use flashing warning lamps and the stop arm when receiving or discharging pupils at a designated loading and unloading zone at a school attendance center or at extracurricular or educational activity locations where students exiting the bus do not have to cross the street or highway.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a school district contracts with an urban transit system to transport children to and from a public or private school, the school bus which is provided by the urban transit system shall not be required to be equipped with flashing warning lights and a stop arm. If the school bus provided by an urban transit system is equipped with flashing warning lights and a stop arm, the driver of the school bus shall use the flashing warning light and stop arm as required by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school bus, when operating on a highway with four or more lanes shall not stop to load or unload pupils who must cross the highway, except at designated stops where pupils who must cross the highway may do so at points where there are official traffic control devices or police officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school bus shall, while carrying passengers, have its headlights turned on.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All pupils shall be received and discharged from the right front entrance of every school bus and if said pupils must cross the highway, they shall be required to pass in front of the bus, look in both directions, and proceed to cross the highway only on signal from the bus driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle, including the driver of a vehicle operating on a private road or driveway, when meeting a school bus with flashing amber warning lamps shall reduce the vehicle\u8217\'3fs speed to not more than twenty miles per hour, and shall bring the vehicle to a complete stop when the school bus stops and the stop signal arm is extended. The vehicle shall remain stopped until the stop signal arm is retracted after which time the driver may proceed with due caution.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle, including the driver of a vehicle operating on a private road or driveway, overtaking a school bus shall not pass a school bus when red or amber warning signal lights are flashing. The driver shall bring the vehicle to a complete stop no closer than fifteen feet from the school bus when it is stopped and the stop arm is extended, and the vehicle shall remain stopped until the stop arm is retracted and the school bus resumes motion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a vehicle upon a highway providing two or more lanes in each direction need not stop upon meeting a school bus which is traveling in the opposite direction even though the school bus is stopped.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a school bus who commits a violation of}}}{{\f5\fs18\hyphpar0\qj{ subsection 1}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{2}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ is subject to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a first offense under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the person is guilty of a simple misdemeanor punishable by a fine of at least three hundred forty-five dollars but not more than nine hundred thirty dollars or by imprisonment for not more than thirty days, or by both. The department may require the person to attend and successfully complete, at the person\u8217\'3fs own expense, a driver improvement program approved by the department in lieu of driver\u8217\'3fs license suspension for the offense pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.210}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a second or subsequent offense under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the person is guilty of a serious misdemeanor. }}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-c8, -c10, -c11; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5032.01, 5032.03;}}}{ C46, \'a7321.372, 321.374; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.372}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 108, \'a72, 3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 70, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1015, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a738, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.354}}}{{\f5\fs12\hyphpar0\qj{, 321.372A}}}{{\f5\fs12\hyphpar0\qj{, 321.373}}}{{\f5\fs12\hyphpar0\qj{, 321.378}}}{{\f5\fs12\hyphpar0\qj{, 321.380}}}{{\f5\fs12\hyphpar0\qj{, 321.423}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}{{\f5\fs12\hyphpar0\qj{, 321.484}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(10)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations of subsection 3 causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.372A}}}{\*\bkmkstart stylerid1_2E435_2E2_2E2}{\*\bkmkend stylerid1_2E435_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prompt investigation of reported violation of failing to obey school bus warning devices \u8212\'3f citation issued to driver or owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a school bus who observes a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.372, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, may prepare a written report on a form provided by the department of public safety indicating that a violation has occurred. The school bus driver or a school official may deliver the report not more than seventy-two hours after the violation occurred to a peace officer of the state or a peace officer of the county or municipality in which the violation occurred. The report shall state the time and the location at which the violation occurred and shall include the registration plate number and a description of the vehicle involved in the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not more than seven calendar days after receiving a report of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.372, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, from a school bus driver or a school official, the peace officer shall initiate an investigation of the reported violation and contact the owner of the motor vehicle involved in the reported violation and request that the owner supply information identifying the driver in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.484}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, from the investigation, the peace officer is able to identify the driver and has reasonable cause to believe a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.372, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, has occurred, the peace officer shall prepare a uniform traffic citation for the violation and shall serve it personally or by certified mail to the driver of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, from the investigation, the peace officer has reasonable cause to believe that a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.372, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, occurred but is unable to identify the driver, the peace officer shall serve a uniform traffic citation for the violation to the owner of the motor vehicle. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 321.484}}}{{\f5\fs18\hyphpar0\qj{, in a proceeding where the peace officer who conducted the investigation was not able to identify the driver of the motor vehicle, proof that the motor vehicle described in the uniform traffic citation was used to commit the violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.372, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, together with proof that the defendant named in the citation was the owner of the motor vehicle at the time the violation occurred, constitutes a permissible inference that the owner was the driver who committed the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fowner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who holds the legal title to a motor vehicle; however, if the motor vehicle is the subject of a security agreement with a right of possession in the debtor, the debtor shall be deemed the owner for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, or if the motor vehicle is leased as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.493}}}{{\f5\fs18\hyphpar0\qj{, the lessee shall be deemed the owner for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1203, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1101, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1164, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 92, \'a72, 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.378}}}{{\f5\fs12\hyphpar0\qj{, 321.380}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.373}}}{\*\bkmkstart stylerid1_2E436_2E2_2E2}{\*\bkmkend stylerid1_2E436_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Required construction \u8212\'3f rules adopted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every school bus except private passenger vehicles used as school buses shall be constructed and equipped to meet safety standards prescribed in rules adopted by the state board of education. Such rules shall conform to safety standards set forth in federal laws and regulations and shall conform, insofar as practicable, to the minimum standards for school buses recommended by the national conference on school transportation administered by the national commission on safety education and published by the national education association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules prescribed for school buses shall provide standards for structural strength, materials, and insulation of the school bus body; color; seat and aisle arrangement; dimension and construction of service door; control of the front door or doors; emergency door and its location and construction; windows; roof ventilators; heaters; location, filling, and draining of the fuel tank; bumpers and how they shall be attached to the bus; lettering and identification of the bus; stop signal arm; warning lights and flashing lights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules prescribed for school buses shall include special rules for passenger automobiles, and other vehicles designed to carry ten or fewer persons, including the driver, when used as school buses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules shall allow pickups designed to carry nine passengers or less, including the driver, and weighing ten thousand pounds or less, to be used as school buses if the pickup does not carry more passengers than there are safety belts or safety harnesses in the pickup as installed by the manufacturer and if the pickup is not operated while any passenger is present in the bed of the pickup. The operator of the pickup shall comply with the qualification, licensing, and instruction requirements set forth in }}}{{\f5\fs18\hyphpar0\qj{sections 321.375}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.376}}}{{\f5\fs18\hyphpar0\qj{, other than the requirement to obtain a commercial driver\u8217\'3fs license. However, the rules shall allow the board of directors of a school district to prohibit the use of pickups as school buses by the school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules shall allow used passenger vans designed to carry twelve or fewer passengers, including the driver, and weighing ten thousand pounds or less, to be used as school buses if the van does not carry more passengers than there are safety belts or safety harnesses in the van as installed by the manufacturer. The operator of the van shall comply with the qualification, licensing, and instruction requirements set forth in }}}{{\f5\fs18\hyphpar0\qj{sections 321.375}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.376}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pickup or passenger van operated pursuant to rules described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is subject to the limitations set forth in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 69}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every school bus shall be equipped with a comfortable seat for each child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles owned by private parties and used as school buses shall have reversed or covered the words \u8220\'3fschool bus\u8221\'3f wherever they appear on the vehicle when the vehicle is not in use as a school bus. It shall be unlawful to operate flashing stop warning signals on such privately owned vehicles except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.372}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No vehicle except a school bus shall be operated on a public highway if the vehicle is painted the color known as national school bus glossy yellow. A school bus which has been permanently converted for a purpose other than transporting pupils to or from school shall be painted a color other than national school bus glossy yellow, and shall have the \u8220\'3fschool bus\u8221\'3f signs, stop arm, and the special signal lamps removed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school bus may be equipped with a white flashing strobe light mounted on the roof of the bus to afford optimum visibility during periods of inclement weather. The light shall be installed and operated in accordance with rules promulgated by the department of education. Each new school bus put into initial service after January 1, 1977, shall be equipped with such a light.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-c9, -c10, -c11; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5032.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.373}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 146, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7282.8}}}{{\f5\fs12\hyphpar0\qj{, 321.378}}}{{\f5\fs12\hyphpar0\qj{, 321.379}}}{{\f5\fs12\hyphpar0\qj{, 321.380}}}{{\f5\fs12\hyphpar0\qj{, 321.423}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.374}}}{\*\bkmkstart stylerid1_2E437_2E2_2E2}{\*\bkmkend stylerid1_2E437_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspection \u8212\'3f seal of approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No vehicle shall be put into service as a school bus until it is given an original inspection to determine if it meets all legal and established uniform standards of construction for the protection of the health and safety of children to be transported. Vehicles which are approved shall be issued a seal of approval by the director of the department of education. All vehicles used as school buses shall be given a safety inspection at least once a year. Buses passing the inspection shall be issued an inspection seal of approval by the director of the department of education. The seal of original inspection and the annual seal of inspection shall be affixed to the lower right hand corner of the windshield.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.374}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1082, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.378}}}{{\f5\fs12\hyphpar0\qj{, 321.380}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.375}}}{\*\bkmkstart stylerid1_2E438_2E2_2E2}{\*\bkmkend stylerid1_2E438_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{School bus drivers \u8212\'3f qualifications \u8212\'3f grounds for suspension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A driver of a school bus must meet all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be at least eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be physically and mentally competent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not possess personal or moral habits which would be detrimental to the best interests of the safety and welfare of the children transported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Possess a current certificate of qualification for operation of a commercial motor vehicle issued by a physician licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{, physician assistant, advanced registered nurse practitioner, or chiropractor or any other person identified by federal and state law as authorized to perform physical examinations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to hiring an applicant for a school bus driver position, including a contract position, an employer shall have access to and shall review the information in the Iowa court information system available to the general public, the sex offender registry information under }}}{{\f5\fs18\hyphpar0\qj{section 692A.121}}}{{\f5\fs18\hyphpar0\qj{ available to the general public, the central registry for child abuse information established under }}}{{\f5\fs18\hyphpar0\qj{section 235A.14}}}{{\f5\fs18\hyphpar0\qj{, and the central registry for dependent adult abuse information established under }}}{{\f5\fs18\hyphpar0\qj{section 235B.5}}}{{\f5\fs18\hyphpar0\qj{ for information regarding the applicant. An employer shall follow the same procedure upon the renewal of an employee\u8217\'3fs or contract employee\u8217\'3fs school bus driver\u8217\'3fs license issued by the department of transportation valid for the operation of a school bus. An employer shall pay for the cost of the registry checks conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. An employer shall maintain documentation demonstrating compliance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following shall constitute grounds for the immediate suspension from duties of a school bus driver, including a part-time or substitute bus driver, pending a termination hearing by the board of directors of a public school district or the authorities in charge in a nonpublic school, or pending confirmation of the grounds by the employer of the school bus driver if the employer is not a school district or accredited nonpublic school:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Use of nonprescription controlled substances or alcoholic beverages during working hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a school bus while under the influence of nonprescription controlled substances or alcoholic beverages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraud in the procurement or renewal of a school bus driver\u8217\'3fs authorization to operate a school bus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission of or conviction for a public offense as defined by the Iowa criminal code, if the offense is relevant to and affects driving ability, or if the offense includes sexual involvement with a minor student with the intent to commit acts and practices proscribed under }}}{{\f5\fs18\hyphpar0\qj{sections 709.2 through 709.4}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 709.8}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{sections 725.1 through 725.3}}}{{\f5\fs18\hyphpar0\qj{, or student abuse as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232E.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The school bus driver is listed in the sex offender registry established under}}}{{\f5\fs18\hyphpar0\qj{ chapter 692A}}}{{\f5\fs18\hyphpar0\qj{, the central registry for child abuse information established under }}}{{\f5\fs18\hyphpar0\qj{section 235A.14}}}{{\f5\fs18\hyphpar0\qj{, or the central registry for dependent adult abuse information established under }}}{{\f5\fs18\hyphpar0\qj{section 235B.5}}}{{\f5\fs18\hyphpar0\qj{. A termination hearing conducted pursuant to this paragraph shall be limited to the question of whether the school bus driver was incorrectly listed in the registry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A change in circumstances indicating that the driver is no longer physically or mentally competent. For the purpose of an insulin-dependent diabetic, a change in circumstances includes the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Results of a glycosylated hemoglobin test indicating values less than 6.0 percent or greater than 9.5 percent unless accompanied by the required medical opinion that the event was incidental and not an indication of failure to control glucose levels.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Results of self-monitoring indicate glucose levels less than one hundred milligrams per deciliter or greater than three hundred milligrams per deciliter, until self-monitoring indicates compliance with specifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Experiencing a loss of consciousness or control relating to diabetes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failing to maintain or falsifying the required reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision to the contrary, an insulin-dependent diabetic may qualify under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for purposes of operating a school bus under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if a person identified by federal or state law as authorized to perform physical examinations annually provides a signed statement indicating that based upon an annual physical examination the individual is physically able to perform the required functions despite insulin dependency. The insulin-dependent diabetic shall not qualify to operate a school bus if, at minimum, the individual results of a glycosylated hemoglobin test indicate values less than 6.0 percent or greater than 9.5 percent on other than an incidental basis and not as a result of failure to control glucose levels. The statement shall also indicate that within the past three years the insulin-dependent diabetic has completed instruction to address diabetes management and driving safety, signs and symptoms of hypoglycemia and hyperglycemia, and what procedures must be followed if complications arise.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district or authorities in charge of the nonpublic school that employs or otherwise secures the services of an individual with an authorization who is an insulin-dependent diabetic shall monitor the insulin-dependent diabetic to determine that they are in compliance with all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Self-monitoring blood glucose and demonstrating conformance with requirements, more than one hundred milligrams per deciliter and less than three hundred milligrams per deciliter, within one hour before driving a school bus and approximately every four hours while on duty using a United States food and drug administration approved device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reporting immediately to the school district or school any failure to comply with specific glucose level requirements as listed in subparagraph (1) or loss of consciousness or control.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carrying a source of readily absorbable, fast-acting glucose while on duty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintaining a daily log of all glucose test results for the previous six-month period and providing copies to the school district or school, the examining physician or examining physician assistant, and the department of education upon request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submitting all required department of education forms within the prescribed timelines.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74960-d10; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5032.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.375}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 210, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 127, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1140, \'a734, 35, 48}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 180, \'a757 \u8211\'3f 59}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7121}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1047, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 88, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1066, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 159, \'a730}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7279.69}}}{{\f5\fs12\hyphpar0\qj{, 321.373}}}{{\f5\fs12\hyphpar0\qj{, 321.376}}}{{\f5\fs12\hyphpar0\qj{, 321.378}}}{{\f5\fs12\hyphpar0\qj{, 321.380}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph d amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.376}}}{\*\bkmkstart stylerid1_2E439_2E2_2E2}{\*\bkmkend stylerid1_2E439_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License \u8212\'3f authorization \u8212\'3f instruction requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to meeting the qualifications under }}}{{\f5\fs18\hyphpar0\qj{section 321.375}}}{{\f5\fs18\hyphpar0\qj{, a driver of a school bus shall hold a commercial driver\u8217\'3fs license issued by the department of transportation with a passenger endorsement and a school bus endorsement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If required by the school district, a school bus driver shall successfully complete an approved course of instruction for school bus drivers in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a temporary restricted license issued under }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ shall not operate a school bus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education shall refuse to issue an authorization to operate a school bus to any person who, after notice and opportunity for hearing, is determined to have met any of the grounds listed under }}}{{\f5\fs18\hyphpar0\qj{section 321.375, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The department of education shall take adverse action against any person who, after notice and opportunity for hearing, is determined to have met any of the grounds listed under }}}{{\f5\fs18\hyphpar0\qj{section 321.375, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. Such action may include a reprimand or warning of the person or the suspension or revocation of the person\u8217\'3fs authorization to operate a school bus. A hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.375, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be limited to the question of whether the person was incorrectly listed in the registry. The department of education shall recommend, and the state board of education shall adopt under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, rules and procedures for issuing and suspending or revoking authorization to operate a school bus in this state. Rules and procedures adopted shall include but are not limited to provisions for the revocation or suspension of, or refusal to issue, authorization to persons who are determined to have met any of the grounds listed under }}}{{\f5\fs18\hyphpar0\qj{section 321.375, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person applying for employment or employed as a school bus driver shall not be required to successfully complete an approved course of instruction for school bus drivers unless the school district for which the person drives a school bus requires successful completion of such course.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district may require successful completion of an approved course of instruction for school bus drivers. An approved course of instruction for school bus drivers includes one or more of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A course of instruction for school bus drivers approved by the department of education.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Entry-level driver training completed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.188, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if such training meets the requirements of }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 380, Appendix C}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 380, Appendix D}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education, in collaboration with the department of transportation, shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ on or before July 1, 2026, establishing requirements for providers of entry-level driver training to comply with this subparagraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rules must provide for minimum training content, contact hours, and proficiency standards, and must establish a standard training course duration that ensures each training course provides all entry-level driver training requirements and specified school bus driver training requirements, including but not limited to training necessary for a passenger endorsement and a school bus endorsement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other training as described in a resolution adopted by the school district, which may include but is not limited to certain portions of a course described in subparagraph (1) or (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a school district requires successful completion of an approved course of instruction for school bus drivers, a school bus driver shall complete the course before or within the first six months of employment and at least every twenty-four months thereafter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a school bus driver is required to complete an approved course of instruction for school bus drivers under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), and fails to provide an employer with a certificate of completion of the approved course, the employer shall report the failure to the department of education and the department shall revoke the driver\u8217\'3fs authorization to operate a school bus. The department of education shall send notice of the revocation to both the person whose school bus authorization has been revoked and the employer. A person whose school bus authorization has been revoked under this paragraph shall not be issued another authorization until certification of the completion of an approved course is received by the department of education, or until the person becomes a school bus driver in a school district that does not require successful completion of an approved course of instruction for school bus drivers under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), and the person is otherwise in compliance with }}}{{\f5\fs18\hyphpar0\qj{section 321.375}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 321.375}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdriver of a school bus\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool bus driver\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a mechanic, delivery driver, or other person operating an empty school bus for purposes other than the transportation of passengers. Such persons must still hold a commercial driver\u8217\'3fs license valid for the operation of a vehicle of the size and type operated, including a passenger endorsement, but are not required to hold a driver\u8217\'3fs license with a school bus endorsement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5032.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.376}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 222, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 201, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 127, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1140, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1047, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 138, \'a71 \u8211\'3f 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7285.8}}}{{\f5\fs12\hyphpar0\qj{, 321.373}}}{{\f5\fs12\hyphpar0\qj{, 321.378}}}{{\f5\fs12\hyphpar0\qj{, 321.380}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsections 1 and 3 and subsection 4 effective January 1, 2026; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2025/CH0138.pdf" }{\fldrslt \cf5 \f5 \fs12{{2025 Acts, ch 138, \'a73}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 1 and 3 stricken and rewritten}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 4 and former subsection 4 renumbered as 5}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.377}}}{\*\bkmkstart stylerid1_2E44_30_2E2_2E2}{\*\bkmkend stylerid1_2E44_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Regional transit system transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A vehicle operated by a regional transit system as defined in }{{\f5\fs18\hyphpar0\qj{section 324A.1}}}{ may only provide school transportation services pursuant to rules adopted by the state department of transportation in consultation with the department of education.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 13, \'a715}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.378}}}{{\f5\fs12\hyphpar0\qj{, 321.380}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.378}}}{\*\bkmkstart stylerid1_2E441_2E2_2E2}{\*\bkmkend stylerid1_2E441_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applicability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{sections 321.372 through 321.377}}}{, }{{\f5\fs18\hyphpar0\qj{this section}}}{, and }{{\f5\fs18\hyphpar0\qj{sections 321.379}}}{ and }{{\f5\fs18\hyphpar0\qj{321.380}}}{, shall apply to all public and nonpublic schools where children are transported to and from school.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5032.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.378}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7149}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.380}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.379}}}{\*\bkmkstart stylerid1_2E442_2E2_2E2}{\*\bkmkend stylerid1_2E442_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A school board, individual, or organization shall not purchase, construct, or contract for use, to transport pupils to or from school, any school bus which does not comply with the minimum requirements of }{{\f5\fs18\hyphpar0\qj{section 321.373}}}{ and any individual, or any member or officer of such board or organization who authorizes, the purchase, construction, or contract for any such bus not complying with these minimum requirements commits a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-c9, -c10, -c11; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5032.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.379}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1140, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.378}}}{{\f5\fs12\hyphpar0\qj{, 321.380}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.380}}}{\*\bkmkstart stylerid1_2E443_2E2_2E2}{\*\bkmkend stylerid1_2E443_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be the duty of all peace officers and of the state patrol to enforce the provisions of }{{\f5\fs18\hyphpar0\qj{sections 321.372 through 321.379}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5032.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.380}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1074, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 35, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7150}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.378}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E444_2E1_2E1}{SAFETY STANDARDS}{\*\bkmkend stylerid1_2E444_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.381}}}{\*\bkmkstart stylerid1_2E445_2E2_2E2}{\*\bkmkend stylerid1_2E445_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Movement of unsafe or improperly equipped vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 3}}}{, for any person to drive or move or for the owner to cause or knowingly permit to be driven or moved on any highway any vehicle or combination of vehicles which is in such unsafe condition as to endanger any person, or which does not contain those parts or is not at all times equipped with such lamps and other equipment in proper condition and adjustment as required in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or which is equipped with one or more unsafe tires or which is equipped in any manner in violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.381}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1203, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a750}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(3)(d)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.381A}}}{\*\bkmkstart stylerid1_2E446_2E2_2E2}{\*\bkmkend stylerid1_2E446_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operation of low-speed vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A low-speed vehicle shall not be operated on a street with a posted speed limit greater than thirty-five miles per hour. }{{\f5\fs18\hyphpar0\qj{This section}}}{ shall not prohibit a low-speed vehicle from crossing a street with a posted speed limit greater than thirty-five miles per hour.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1005, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(3)(e)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.382}}}{\*\bkmkstart stylerid1_2E447_2E2_2E2}{\*\bkmkend stylerid1_2E447_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Upgrade pulls \u8212\'3f minimum speed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A motor vehicle or combination of vehicles, which cannot proceed up a three percent grade, on dry concrete pavement, at a minimum speed of twenty miles per hour, shall not be operated upon the highways of this state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.382}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a770}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.23}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(f)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.383}}}{\*\bkmkstart stylerid1_2E448_2E2_2E2}{\*\bkmkend stylerid1_2E448_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exceptions \u8212\'3f slow vehicles identified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ with respect to equipment on vehicles does not apply to implements of husbandry, road machinery, or bulk spreaders and other fertilizer and chemical equipment defined as special mobile equipment, except as made applicable in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. However, the movement of implements of husbandry on a roadway is subject to safety rules adopted by the department of public safety. The safety rules shall prohibit the movement of any power unit towing more than one implement of husbandry, except implements of husbandry that are not self-propelled and are capable of being towed in tandem, from the manufacturer to the retail seller, from the retail seller to the farm purchaser, or from the manufacturer to the farm purchaser.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When operated on a highway in this state at a speed of thirty-five miles per hour or less, every farm tractor, or tractor with towed equipment, self-propelled implement of husbandry, road construction or maintenance vehicle, road grader, horse-drawn vehicle, or any other vehicle principally designed for use off the highway and any such tractor, implement, vehicle, or grader when manufactured for sale or sold at retail after December 31, 1971, shall be identified with a reflective device in accordance with the standards of the American society of agricultural engineers; however, this provision shall not apply to such vehicles when traveling in an escorted parade. If a person operating a vehicle drawn by a horse or mule objects to using a reflective device that complies with the standards of the American society of agricultural engineers for religious reasons, the vehicle may be identified by an alternative reflective device that is in compliance with rules adopted by the department of public safety. The reflective device or alternative reflective device shall be visible from the rear. A vehicle other than those specified in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not display a reflective device or an alternative reflective device. On vehicles operating at speeds above thirty-five miles per hour, the reflective device or alternative reflective device shall be removed or hidden from view.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Garbage collection vehicles, when operated on the streets or highways of this state at speeds of thirty-five miles per hour or less, may display a reflective device that complies with the standards of the American society of agricultural engineers. At speeds in excess of thirty-five miles per hour the device shall not be visible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, any person who violates any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who operates a self-propelled implement of husbandry at a speed which exceeds the limit of thirty-five miles per hour commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.383}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1254, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 186, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1080, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 102, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 108, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7117}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1023, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a739, 40, 93}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.288}}}{{\f5\fs12\hyphpar0\qj{, 321.398}}}{{\f5\fs12\hyphpar0\qj{, 321.438}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(g)}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(5)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For amber flashing light requirements, see }{{\f5\fs12\hyphpar0\qj{\'a7321.423, subsection 6}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E449_2E1_2E1}{LIGHTING EQUIPMENT}{\*\bkmkend stylerid1_2E449_2E1_2E1}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Exception to requirements of }{{\f5\fs12\qc{\'a7321.384 \u8211\'3f 321.423}}}{ for implements of husbandry operated as special mobile equipment during daylight hours, see }{{\f5\fs12\qc{\'a7321.1(32)}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.384}}}{\*\bkmkstart stylerid1_2E45_30_2E2_2E2}{\*\bkmkend stylerid1_2E45_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When lighted lamps required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every motor vehicle upon a highway within the state, at any time from sunset to sunrise, and at such other times when conditions such as fog, snow, sleet, or rain provide insufficient lighting to render clearly discernible persons and vehicles on the highway at a distance of five hundred feet ahead, shall display lighted headlamps as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.415}}}{{\f5\fs18\hyphpar0\qj{, subject to exceptions with respect to parked vehicles as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, an all-terrain vehicle shall display lighted headlamps as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.415}}}{{\f5\fs18\hyphpar0\qj{ at all times while the vehicle is operated on a highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever a requirement is established in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ as to the distance from which certain lamps and devices shall render objects visible or within which such lamps or devices shall be visible, that requirement shall apply during the times stated in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ upon a straight level unlighted highway under normal atmospheric conditions unless a different time or condition is expressly stated.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m17; C24, 27, 31, 35, \'a75044; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.384}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 59, \'a797}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1105, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.235A}}}{{\f5\fs12\hyphpar0\qj{, 321.392}}}{{\f5\fs12\hyphpar0\qj{, 321.394}}}{{\f5\fs12\hyphpar0\qj{, 321.395}}}{{\f5\fs12\hyphpar0\qj{, 321.397}}}{{\f5\fs12\hyphpar0\qj{, 321.398}}}{{\f5\fs12\hyphpar0\qj{, 321.405}}}{{\f5\fs12\hyphpar0\qj{, 321.415}}}{{\f5\fs12\hyphpar0\qj{, 321.418}}}{{\f5\fs12\hyphpar0\qj{, 321.419}}}{{\f5\fs12\hyphpar0\qj{, 321O.6}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Lamps on parked vehicles, }{{\f5\fs12\hyphpar0\qj{\'a7321.395}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.385}}}{\*\bkmkstart stylerid1_2E451_2E2_2E2}{\*\bkmkend stylerid1_2E451_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Headlamps on motor vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every motor vehicle other than a motorcycle, motorized bicycle, or all-terrain vehicle shall be equipped with at least two headlamps with at least one on each side of the front of the motor vehicle, which headlamps shall comply with the requirements and limitations set forth in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m17; C24, 27, 31, 35, \'a75044; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.385}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1105, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.385A}}}{{\f5\fs12\hyphpar0\qj{, 321.404A}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(i)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.385A}}}{\*\bkmkstart stylerid1_2E452_2E2_2E2}{\*\bkmkend stylerid1_2E452_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Citation for unlighted headlamp, rear lamp, or rear registration plate light.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A citation issued for failure to have headlamps as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.385}}}{{\f5\fs18\hyphpar0\qj{ shall first provide for a seventy-two hour period within which the person charged with the violation shall replace or repair the headlamp. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A citation issued for failure to have rear lamps as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.387}}}{{\f5\fs18\hyphpar0\qj{ or a rear registration plate light as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.388}}}{{\f5\fs18\hyphpar0\qj{ shall first provide for a seventy-two hour period within which the person charged with the violation shall replace or repair the lamps or light.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person complies with the directive to replace or repair the headlamp, rear lamps, or rear registration plate light within the allotted time period, the citation shall be expunged. If the person fails to comply within the allotted time period, the citation shall be processed in the same manner as other citations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A citation issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall include a written notice of replacement or repair which shall indicate the date of replacement or repair and the manner in which the replacement or repair occurred and which shall be returned to the issuing authority within the seventy-two hour time period.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1175, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a747}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321O.6}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.386}}}{\*\bkmkstart stylerid1_2E453_2E2_2E2}{\*\bkmkend stylerid1_2E453_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Headlamps on motorcycles, motorized bicycles, and all-terrain vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every motorcycle, motorized bicycle, and all-terrain vehicle shall be equipped with at least one and not more than two headlamps which shall comply with the requirements and limitations of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m17; C24, 27, 31, 35, \'a75047; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.386}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1105, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.234A}}}{{\f5\fs12\hyphpar0\qj{, 321.404A}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(j)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.387}}}{\*\bkmkstart stylerid1_2E454_2E2_2E2}{\*\bkmkend stylerid1_2E454_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rear lamps.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every motor vehicle and every vehicle which is being drawn at the end of a train of vehicles shall be equipped with a lighted rear lamp or lamps, exhibiting a red light plainly visible from a distance of five hundred feet to the rear. All lamps and lighting equipment originally manufactured on a motor vehicle shall be kept in working condition or shall be replaced with equivalent equipment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m17; C24, 27, 31, 35, \'a75045, 5046; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.387}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1175, \'a735}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.234A}}}{{\f5\fs12\hyphpar0\qj{, 321.385A}}}{{\f5\fs12\hyphpar0\qj{, 321.404A}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(k)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.388}}}{\*\bkmkstart stylerid1_2E455_2E2_2E2}{\*\bkmkend stylerid1_2E455_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Illuminating plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Either the rear lamp or a separate lamp shall be so constructed and placed as to illuminate with a white light the rear registration plate and render it clearly legible from a distance of fifty feet to the rear. When the rear registration plate is illuminated by an electric lamp other than the required rear lamp, the two lamps shall be turned on or off only by the same control switch at all times when headlamps are lighted. }{{\f5\fs18\hyphpar0\qj{This section}}}{ does not apply to commercial vehicles engaged exclusively in intrastate commerce that are dump trucks or that are used exclusively for the movement of construction materials and equipment to and from construction projects.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m17; C24, 27, 31, 35, \'a75045; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.388}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 195, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 35, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.385A}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(l)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.389}}}{\*\bkmkstart stylerid1_2E456_2E2_2E2}{\*\bkmkend stylerid1_2E456_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reflector required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every new motor vehicle, trailer, or semitrailer sold and every commercial vehicle operated on a highway shall be equipped at the rear, either as a part of the rear lamp or separately, with a red reflector meeting the requirements of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.389}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1021, \'a771}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(m)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.390}}}{\*\bkmkstart stylerid1_2E457_2E2_2E2}{\*\bkmkend stylerid1_2E457_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reflector requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever a red reflector is required or permitted to be used in substitution of lamps upon a vehicle under any one of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, such reflector shall be mounted upon the vehicle at a height not to exceed forty-two inches nor less than twenty inches above the ground upon which the vehicle stands, and every such reflector shall be so designed and maintained as to be visible at night from all distances within three hundred feet to fifty feet from such vehicle, except that on a commercial vehicle the reflector shall be visible from all distances within five hundred feet to fifty feet from such vehicle when directly in front of a motor vehicle displaying lawfully lighted headlamps as provided in }{{\f5\fs18\hyphpar0\qj{section 321.409}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74863; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5033.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.390}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(n)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.391}}}{\*\bkmkstart stylerid1_2E458_2E2_2E2}{\*\bkmkend stylerid1_2E458_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Approval of reflectors.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1997/CH0108.pdf" }{\fldrslt \cf5 \f5 \fs18{{97 Acts, ch 108, \'a749}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.392}}}{\*\bkmkstart stylerid1_2E459_2E2_2E2}{\*\bkmkend stylerid1_2E459_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Clearance and identification lights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every motor truck, and every trailer or semitrailer of over three thousand pounds gross weight, shall be equipped with the following lighting devices and reflectors in addition to other requirements of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and such devices shall be lighted at the times mentioned in }{{\f5\fs18\hyphpar0\qj{section 321.384}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every motor truck, whatever its size shall have the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On each side, one reflector, at or near the rear; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the rear, two reflectors, one at each side.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every motor truck, eighty inches or more in width shall have the following in addition to the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If thirty feet or less in overall length:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the front, two clearance lamps, one at each side; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the rear, two clearance lamps, one at each side.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If more than thirty feet in overall length:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the front, two clearance lamps, one at each side;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On each side, two side-marker lamps, one at or near the front, and one at or near the rear, and an additional reflector at or near the front; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the rear, two clearance lamps, one at each side.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every truck tractor or road tractor shall have the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the front, two clearance lamps, one at each side if the tractor cab is as wide as, or wider than, the widest part of the vehicle or vehicles towed;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On each side, one side-marker lamp at or near the front; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the rear, one tail lamp.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every trailer or semitrailer having a gross weight in excess of three thousand pounds shall have the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the front, two clearance lamps, one at each side, if the trailer is wider in its widest part than the cab of the vehicle towing it;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On each side, one side-marker lamp at or near the rear; two reflectors, one at or near the front and one at or near the rear; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the rear, two clearance lamps, one at each side; one stop light; one tail lamp; and two reflectors, one at each side.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every motor truck or combination of motor truck and trailer having a length in excess of thirty feet or a width in excess of eighty inches shall be equipped with three identification lights on both front and rear. Each such group shall be evenly spaced not less than six nor more than twelve inches apart along a horizontal line near the top of the vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75044-d1, -d2, 5105-c19; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.392}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(o)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.393}}}{\*\bkmkstart stylerid1_2E46_30_2E2_2E2}{\*\bkmkend stylerid1_2E46_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Color and mounting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lighting device or reflector, when mounted on or near the front of a motor truck or trailer, except a school bus, shall not display any other color than white, yellow, or amber.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No lighting device or reflector, when mounted on or near the rear of any motor truck or trailer, shall display any other color than red, except that the stop light may be red, yellow, or amber.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Clearance lamps shall be mounted on the permanent structure of the vehicle in such manner as to indicate the extreme width of the vehicle or its load.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit the use of a lighting device or reflector displaying an amber light when such lighting device or reflector is mounted on a motor truck, trailer, tractor, or motor grader owned by the state, or any political subdivision of the state, including any local authority, while such equipment is being used for snow removal, sanding, maintenance, or repair of the public streets or highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit the use of a lighting device or reflector displaying an amber, white, or blue light when the lighting device or reflector is rear-facing and mounted on a motor truck, trailer, tractor, truck-mounted snow blower, or motor grader owned by the state or any political subdivision of the state, including any local authority, while the equipment is being used for snow and ice treatment or removal on the public streets or highways.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.393}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 83, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 81, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1002, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 97, \'a71, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(p)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.394}}}{\*\bkmkstart stylerid1_2E461_2E2_2E2}{\*\bkmkend stylerid1_2E461_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lamp or flag on projecting load.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever the load upon any vehicle extends to the rear four feet or more beyond the bed or body of such vehicle there shall be displayed at the extreme rear end of the load, at the times specified in }{{\f5\fs18\hyphpar0\qj{section 321.384}}}{, a red light or lantern plainly visible from a distance of at least five hundred feet to the sides and rear. The red light or lantern required under }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be in addition to the red rear light required upon every vehicle. At any other time there shall be displayed at the extreme rear end of such load a red flag or cloth not less than sixteen inches square.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.394}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.395}}}{\*\bkmkstart stylerid1_2E462_2E2_2E2}{\*\bkmkend stylerid1_2E462_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lamps on parked vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever a vehicle is parked or stopped upon a roadway or shoulder adjacent to the roadway, outside of a business district whether attended or unattended during the times mentioned in }{{\f5\fs18\hyphpar0\qj{section 321.384}}}{, such vehicle shall be equipped with one or more lamps which shall exhibit a white or amber light on the roadway side visible from a distance of five hundred feet to the front of such vehicle and a red light visible from a distance of five hundred feet to the rear, except that local authorities may provide by ordinance or resolution that no lights need be displayed upon any such vehicle when stopped or parked in accordance with local parking regulations upon a highway where there is sufficient light to reveal any person or object within a distance of five hundred feet upon such highway. Any lighted headlamps upon a parked vehicle shall be depressed or dimmed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75054; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.395}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1178, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.396}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(6)(z)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 6}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.396}}}{\*\bkmkstart stylerid1_2E463_2E2_2E2}{\*\bkmkend stylerid1_2E463_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exception.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 321.395}}}{ shall not apply when an accident extinguishes said light and renders a vehicle incapable of use, and when the person in control of the vehicle erects, at the earliest opportunity after the accident, such proper light at or near the vehicle as will give warning of the presence of said vehicle.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75055; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.396}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.397}}}{\*\bkmkstart stylerid1_2E464_2E2_2E2}{\*\bkmkend stylerid1_2E464_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lamps on bicycles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every bicycle shall be equipped with a lamp on the front exhibiting a white light, at the times specified in }{{\f5\fs18\hyphpar0\qj{section 321.384}}}{, visible from a distance of at least three hundred feet to the front and with a lamp on the rear exhibiting a red light visible from a distance of three hundred feet to the rear; except that a red reflector may be used in lieu of a rear light. A peace officer riding a police bicycle is not required to use either front or rear lamps if duty so requires.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75045-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.397}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 71, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a721}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(9)(j)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 9 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.398}}}{\*\bkmkstart stylerid1_2E465_2E2_2E2}{\*\bkmkend stylerid1_2E465_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lamps on other vehicles and equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All vehicles, including animal-drawn vehicles and including those referred to in }{{\f5\fs18\hyphpar0\qj{section 321.383}}}{ not specifically required to be equipped with lamps, shall at the times specified in }{{\f5\fs18\hyphpar0\qj{section 321.384}}}{ be equipped with at least one lighted lamp or lantern exhibiting a white light visible from a distance of five hundred feet to the front of such vehicle and, except for animal-drawn vehicles, with a lamp or lantern exhibiting a red light visible from a distance of five hundred feet to the rear. Animal-drawn vehicles shall be equipped with a flashing amber light visible from a distance of five hundred feet to the rear of the vehicle during the time specified in }{{\f5\fs18\hyphpar0\qj{section 321.384}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75045-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.398}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7175}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.423}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(q)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.399 through 321.401}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.402}}}{\*\bkmkstart stylerid1_2E467_2E2_2E2}{\*\bkmkend stylerid1_2E467_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Spot lamps.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any motor vehicle may be equipped with not to exceed one spot lamp and every lighted spot lamp shall be so aimed and used upon approaching another vehicle that no part of the high-intensity portion of the beam will be directed to the left of the prolongation of the extreme left side of the vehicle nor more than one hundred feet ahead of the vehicle.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75051; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.402}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(r)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.403}}}{\*\bkmkstart stylerid1_2E468_2E2_2E2}{\*\bkmkend stylerid1_2E468_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Auxiliary driving lamps.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any motor vehicle may be equipped with not to exceed three auxiliary driving lamps mounted on the front at a height not less than twelve inches nor more than forty-two inches above the level surface upon which the vehicle stands, and every such auxiliary driving lamp or lamps shall meet the requirements and limitations set forth in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75050; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.403}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(s)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.404}}}{\*\bkmkstart stylerid1_2E469_2E2_2E2}{\*\bkmkend stylerid1_2E469_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Signal lamps and signal devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every motor vehicle shall be equipped with a signal lamp or signal device which is so constructed and located on the vehicle as to give a signal of intention to stop, which shall be red or yellow in color, which signal shall be plainly visible and understandable in normal sunlight and at night from a distance of one hundred feet to the rear but shall not project a glaring or dazzling light.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.404}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.234A}}}{{\f5\fs12\hyphpar0\qj{, 321.404A}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(t)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.404A}}}{\*\bkmkstart stylerid1_2E47_30_2E2_2E2}{\*\bkmkend stylerid1_2E47_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Light-restricting devices prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not operate a motor vehicle, motorcycle, or motorized bicycle on the highways of this state if it is equipped with a device that restricts the light output of a headlamp required under }}}{{\f5\fs18\hyphpar0\qj{section 321.385}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.386}}}{{\f5\fs18\hyphpar0\qj{, a rear lamp required under }}}{{\f5\fs18\hyphpar0\qj{section 321.387}}}{{\f5\fs18\hyphpar0\qj{, a signal lamp or signal device required under }}}{{\f5\fs18\hyphpar0\qj{section 321.404}}}{{\f5\fs18\hyphpar0\qj{, or a directional signal device as described in }}}{{\f5\fs18\hyphpar0\qj{section 321.317}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to a scheduled fine under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 13, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a752}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(u)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.405}}}{\*\bkmkstart stylerid1_2E471_2E2_2E2}{\*\bkmkend stylerid1_2E471_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Self-illumination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All mechanical signal devices shall be self-illuminated when in use at the times mentioned in }{{\f5\fs18\hyphpar0\qj{section 321.384}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.405}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.406}}}{\*\bkmkstart stylerid1_2E472_2E2_2E2}{\*\bkmkend stylerid1_2E472_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cowl lamps.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1045, \'a71}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.407}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.408}}}{\*\bkmkstart stylerid1_2E474_2E2_2E2}{\*\bkmkend stylerid1_2E474_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Back-up lamps.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle may be equipped with a back-up lamp either separately or in combination with another lamp.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A back-up lamp shall not be continuously lighted when the motor vehicle is in forward motion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75050; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.17;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.408}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1140, \'a713}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.409}}}{\*\bkmkstart stylerid1_2E475_2E2_2E2}{\*\bkmkend stylerid1_2E475_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mandatory lighting equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the headlamps or the auxiliary driving lamp or the auxiliary passing lamp or combination thereof on motor vehicles other than motorcycles or motorized bicycles shall be so arranged that the driver may select at will between distributions of light projected to different elevations and the lamps may, in addition, be so arranged that selection can be made automatically, subject to the following limitations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There shall be an uppermost distribution of light, or composite beam, so aimed and of sufficient intensity to reveal persons and vehicles at a distance of at least three hundred fifty feet ahead for all conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There shall be a lowermost distribution of light, or composite beam so aimed and of sufficient intensity to reveal persons and vehicles at a distance of at least one hundred feet ahead. On a straight level road under any condition of loading none of the high-intensity portion of the beam shall be directed to strike the eyes of an approaching driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every new motor vehicle, other than a motorcycle or motorized bicycle which has multiple-beam road-lighting equipment shall be equipped with a beam indicator, which shall be lighted whenever the uppermost distribution of light from the headlamps is in use, and shall not otherwise be lighted. The indicator shall be so designed and located that when lighted it will be readily visible without glare to the driver of the vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75049, 5052; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.18 \u8211\'3f 5034.22;}}}{ C46, 50, 54, \'a7321.409 \u8211\'3f 321.413; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.409}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1061, \'a7118}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7176}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.275}}}{{\f5\fs12\hyphpar0\qj{, 321.390}}}{{\f5\fs12\hyphpar0\qj{, 321.415}}}{{\f5\fs12\hyphpar0\qj{, 321.417}}}{{\f5\fs12\hyphpar0\qj{, 321.418}}}{{\f5\fs12\hyphpar0\qj{, 321O.6}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(v)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.410 through 321.414}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.415}}}{\*\bkmkstart stylerid1_2E477_2E2_2E2}{\*\bkmkend stylerid1_2E477_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Required usage of lighting devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever a motor vehicle is being operated on a roadway or shoulder during the times specified in }}}{{\f5\fs18\hyphpar0\qj{section 321.384}}}{{\f5\fs18\hyphpar0\qj{, the driver shall use a distribution of light, or composite beam, directed high enough and of sufficient intensity to reveal persons and vehicles at a safe distance in advance of the vehicle, subject to the following requirements and limitations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever a driver of a vehicle approaches an oncoming vehicle within one thousand feet, the driver shall use a distribution of light, or composite beam, so aimed that the glaring rays are not projected into the eyes of the oncoming driver. The lowermost distribution of light, or composite beam, specified in }}}{{\f5\fs18\hyphpar0\qj{section 321.409, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall be deemed to avoid glare at all times, regardless of road contour and loading.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever the driver of a vehicle follows another vehicle within four hundred feet to the rear, except when engaged in the act of overtaking and passing, the driver shall use a distribution of light permissible under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ other than the uppermost distribution of light specified in }}}{{\f5\fs18\hyphpar0\qj{section 321.409, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, do not apply to motorcycles or motorized bicycles being operated between sunrise and sunset.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.23 \u8211\'3f 5034.25;}}}{ C46, 50, 54, \'a7321.414 \u8211\'3f 321.416; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.415}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1175, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7175}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.384}}}{{\f5\fs12\hyphpar0\qj{, 321.418}}}{{\f5\fs12\hyphpar0\qj{, 456A.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(w)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.416}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.417}}}{\*\bkmkstart stylerid1_2E479_2E2_2E2}{\*\bkmkend stylerid1_2E479_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Single-beam road-lighting equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Headlamps arranged to provide a single distribution of light not supplemented by auxiliary driving lamps shall be permitted on motor vehicles manufactured and sold prior to July 1, 1938, in lieu of multiple-beam road-lighting equipment specified in }{{\f5\fs18\hyphpar0\qj{section 321.409}}}{ if the single distribution of light complies with the following requirements and limitations:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The headlamps shall be so aimed that when the vehicle is not loaded none of the high-intensity portion of the light shall at a distance of twenty-five feet ahead project higher than a level of five inches below the level of the center of the lamp from which it comes, and in no case higher than forty-two inches above the level on which the vehicle stands at a distance of seventy-five feet ahead.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The intensity of the light shall be sufficient to reveal persons and vehicles at a distance of at least two hundred feet.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75049; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.26;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.417}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1069, \'a797}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.418}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.418}}}{\*\bkmkstart stylerid1_2E48_30_2E2_2E2}{\*\bkmkend stylerid1_2E48_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alternate road-lighting equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any motor vehicle may be operated under the conditions specified in }{{\f5\fs18\hyphpar0\qj{section 321.384}}}{ when equipped with two lighted lamps upon the front thereof capable of revealing persons and objects seventy-five feet ahead in lieu of lamps required in }{{\f5\fs18\hyphpar0\qj{sections 321.409}}}{ and }{{\f5\fs18\hyphpar0\qj{321.415}}}{, or }{{\f5\fs18\hyphpar0\qj{section 321.417}}}{, provided, however, that at no time shall it be operated at a speed in excess of twenty miles per hour.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.27;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.418}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.419}}}{\*\bkmkstart stylerid1_2E481_2E2_2E2}{\*\bkmkend stylerid1_2E481_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Number of driving lamps required or permitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{At all times specified in }{{\f5\fs18\hyphpar0\qj{section 321.384}}}{ at least two lighted lamps, except where one only is permitted, shall be displayed, one on each side at the front of every motor vehicle except when such vehicle is parked subject to the regulations governing lights on parked vehicles.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.28;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.419}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(x)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Lamps on parked vehicles, }{{\f5\fs12\hyphpar0\qj{\'a7321.395}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.420}}}{\*\bkmkstart stylerid1_2E482_2E2_2E2}{\*\bkmkend stylerid1_2E482_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Number of lamps lighted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever a motor vehicle equipped with headlamps as required in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is also equipped with any auxiliary lamps or a spot lamp or any other lamp on the front of the vehicle, that projects a beam of an intensity greater than three hundred candlepower, not more than a total of four of any such lamps on the front of the vehicle shall be lighted at any one time when upon a highway.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.29;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.420}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7177}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a772}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(y)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.421}}}{\*\bkmkstart stylerid1_2E483_2E2_2E2}{\*\bkmkend stylerid1_2E483_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special restrictions on lamps.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any lighted lamp or illuminating device upon a motor vehicle other than headlamps, spot lamps, or auxiliary driving lamps which projects a beam of light of an intensity greater than three hundred candlepower shall be so directed that no part of the beam will strike the level of the roadway on which the vehicle stands at a distance of more than seventy-five feet from the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.30;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.421}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1203, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a753}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(z)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.422}}}{\*\bkmkstart stylerid1_2E484_2E2_2E2}{\*\bkmkend stylerid1_2E484_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Red light in front }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ rear lights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall drive or move any vehicle or equipment upon any highway with any lamp or device thereon displaying or reflecting a red light visible from directly in front thereof. No person shall display any color of light other than red on the rear of any vehicle, except that stop lights and directional signals may be red, yellow, or amber.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to authorized emergency vehicles, or school buses and vehicles as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.423, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.31;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.422}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1069, \'a798}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(aa)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Exception for certain slow-moving vehicles, see }{{\f5\fs12\hyphpar0\qj{\'a7321.383}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.423}}}{\*\bkmkstart stylerid1_2E485_2E2_2E2}{\*\bkmkend stylerid1_2E485_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Flashing lights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E485_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E485_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmergency medical care provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 147A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFire department\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a paid or volunteer fire protection service provided by a benefited fire district under }}}{{\f5\fs18\hyphpar0\qj{chapter 357B}}}{{\f5\fs18\hyphpar0\qj{ or by a county, municipality or township, or a private corporate organization that has a valid contract to provide fire protection service for a benefited fire district, county, municipality, township or governmental agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMember\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is a member in good standing of a fire department or a person who is an emergency medical care provider employed by an ambulance, rescue, or first response service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E485_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E485_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Prohibited lights.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A flashing light on or in a motor vehicle is prohibited except as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On an authorized emergency vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a vehicle as a means of indicating a right or left turn, a mechanical failure, or an emergency stop or intent to stop.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a motor vehicle used by a rural mail carrier when stopping or stopped on or near a highway in the process of delivering mail, if such a light is any shade of color between white and amber and if it is mounted as a dome light on the roof of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a vehicle being operated under an excess size permit issued under }}}{{\f5\fs18\hyphpar0\qj{chapter 321E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A flashing blue light on a vehicle upon which a blue light is permitted pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A flashing white light, including a flashing headlamp, is permitted on a vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Flashing red and amber warning lights on a school bus as described in }}}{{\f5\fs18\hyphpar0\qj{section 321.372}}}{{\f5\fs18\hyphpar0\qj{, and a white flashing strobe light mounted on a school bus as permitted under }}}{{\f5\fs18\hyphpar0\qj{section 321.373, subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A flashing amber light is permitted on a towing or recovery vehicle, a utility maintenance vehicle, a municipal maintenance vehicle, a highway maintenance vehicle, a construction vehicle, a solid waste or recycling collection service vehicle, or a vehicle operated in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 321.398}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.453}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Modulating headlamps in conformance with }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7571.108 S7.9.4.}}}{{\f5\fs18\hyphpar0\qj{ are permitted on a motorcycle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a vehicle being operated as an escort vehicle for a funeral procession as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.324A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E485_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E485_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Blue light.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A blue light shall not be used on any vehicle except for the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle owned or exclusively operated by a fire department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle authorized by the chief of the fire department if the vehicle is owned by a member of the fire department, the request for authorization is made by the member on forms provided by the department, necessity for authorization is demonstrated in the request, and the member has received emergency vehicle operations training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle authorized by the chief officer of an emergency medical services agency, if the vehicle is owned by a member of the emergency medical services agency, the request for authorization is made by the member on forms provided by the department, and necessity for authorization to respond to an emergency call or fire alarm under }}}{{\f5\fs18\hyphpar0\qj{section 321.231C}}}{{\f5\fs18\hyphpar0\qj{ is demonstrated in the request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle, other than a vehicle described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1) or (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor truck, trailer, tractor, truck-mounted snow blower, or motor grader owned by the state or any political subdivision of the state, including any local authority, if the blue light is rear-facing and used in conjunction with amber and white lighting devices or reflectors while the equipment is being used for snow and ice treatment or removal on the public streets or highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not use only a blue light on a vehicle unless the vehicle meets the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), (2), or (3).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E485_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E485_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Expiration of authority.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The authorization shall expire at midnight on the thirty-first day of December five years from the year in which it was issued, or when the vehicle is no longer owned by the member, or when the member has ceased to be an active member of the fire department or of an ambulance, rescue, or first response service, or when the member has used the blue or white light beyond the scope of its authorized use. A person issued an authorization under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), shall return the authorization to the fire chief upon expiration or upon a determination by the fire chief or the department that the authorization should be revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E485_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E485_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{When used.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate of authorization shall be carried at all times with the certificate of registration of the authorized vehicle and the operator of the vehicle shall not illuminate the blue or white light except in any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the member is en route to the scene of a fire or is responding to an emergency in the line of duty requiring the services of the member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the authorized vehicle is transporting a person requiring emergency care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the authorized vehicle is at the scene of an emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The use of the blue or white light in or on a private motor vehicle shall be for identification purposes only.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E485_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E485_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Amber flashing light.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A farm tractor, farm tractor with towed equipment, self-propelled implement of husbandry, road construction or maintenance vehicle, road grader, or other vehicle principally designed for use off the highway which, when operated on a primary or secondary road, is operated at a speed of thirty-five miles per hour or less, shall be equipped with and display an amber flashing light visible from the rear at any time from sunset to sunrise. If the amber flashing light is obstructed by the towed equipment, the towed equipment shall also be equipped with and display an amber flashing light as required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. All vehicles specified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ which are manufactured for sale or sold in this state shall be equipped with an amber flashing light in accordance with the standards of the American society of agricultural engineers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E485_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E485_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Flashing white light.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.373, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fi\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a flashing white light shall only be used on a vehicle in the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a vehicle owned or exclusively operated by an ambulance, rescue, or first response service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a vehicle authorized by the director of health and human services when all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vehicle is owned by a member of an ambulance, rescue, or first response service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The request for authorization is made by the member on forms provided by the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Necessity for authorization is demonstrated in the request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The head of an ambulance, rescue, or first response service certifies that the member is in good standing and recommends that the authorization be granted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On an authorized emergency vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a motor truck, trailer, tractor, truck-mounted snow blower, or motor grader owned by the state or any political subdivision of the state, including any local authority, if the white light is rear-facing and used in conjunction with amber and blue lighting devices or reflectors while the equipment is being used for snow and ice treatment or removal on the public streets or highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a motor truck or trailer owned and operated by the department equipped with an impact attenuator and audible warning system, if the flashing white light is rear-facing on the audible warning system and used in conjunction with amber lighting devices or reflectors while the motor truck or trailer is being used for slow-moving maintenance operations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a vehicle or other equipment not owned and operated by the department when used in road work zones on state or local highways as authorized by the department. The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ regarding the vehicles or equipment eligible to use a flashing white light under this subparagraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of health and human services shall adopt rules to establish issuance standards, including allowing local emergency medical service providers to issue certificates of authorization, and shall adopt rules to establish certificate of authorization revocation procedures.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.32;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.423}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 37, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1225, \'a71 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 131, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1087, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 41, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1034, \'a721 \u8211\'3f 23}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1045, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a729 \u8211\'3f 31}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 81, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 84, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1002, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1079, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 97, \'a72 \u8211\'3f 5, 9}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1089, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71063 \u8211\'3f 1065}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.231C}}}{{\f5\fs12\hyphpar0\qj{, 321.323A}}}{{\f5\fs12\hyphpar0\qj{, 321.422}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(ab)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Exception for certain slow-moving vehicles, see }{{\f5\fs12\hyphpar0\qj{\'a7321.383}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.424}}}{\*\bkmkstart stylerid1_2E486_2E2_2E2}{\*\bkmkend stylerid1_2E486_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authorized emergency vehicle lights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding any provision of law to the contrary:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle may be equipped with a combination of interior and exterior lights, flashing headlamps, and flashing tail lamps as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An official law enforcement, fire department, emergency medical services, or emergency management vehicle owned by the state or a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, may be equipped with flashing headlamps.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle owned by the state, a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, or a private emergency medical services company delivering services to the state, a municipality, or a hospital pursuant to a written contract, or a privately owned vehicle designated as an authorized emergency vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.451}}}{{\f5\fs18\hyphpar0\qj{, shall be equipped with a combination of operational red and blue lights. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle equipped with an interior or exterior light bar must have the light bar positioned such that front and rear facing red lights are on the driver\u8217\'3fs side of the vehicle and front and rear facing blue lights are on the passenger\u8217\'3fs side of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle equipped with an interior or exterior light bar with red and blue flashing lights may be equipped with flashing or solid white lights scattered among or between a clear or colored lens that displays a red or blue flashing light.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle may be equipped with one or more lights capable of emitting a split red and blue steady or flashing light, which may be mounted on or in the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle may be equipped with one or more lights on the side of the vehicle capable of emitting red and blue light, red and white light, or blue and white light.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle may be equipped with one or more lights with a clear or colored lens.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An official law enforcement, fire, rescue, emergency medical services, or emergency management vehicle may be equipped with lights or light bars containing one or more rear zone amber lights or amber directional arrows, which shall be in addition to any other required lighting equipment. An authorized emergency vehicle shall not be equipped with an amber light positioned on the front or side of the vehicle. However, an aerial fire apparatus may be equipped with amber flashing lights on the outriggers of the apparatus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle may be equipped with one or more steady, oscillating, or flashing white lights, flashing headlamps, or flashing reverse lamps, which shall be in addition to any other required lighting equipment. A light bar shall not be equipped or used to display flashing white lights visible from the rear of the vehicle. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit an authorized emergency vehicle owned by the state or a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, from being equipped with or using a spotlight or exterior light bar capable of displaying a steady white light for use as a work light, alley light, search light, or take down light.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle owned by a state or a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, that is primarily used as an incident command vehicle may be equipped with one or more steady or flashing green lights, which shall be in addition to any other required lighting equipment. A steady or flashing green light equipped pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be activated unless the vehicle is being used as a stationary incident command post at the location of an emergency incident, an official training exercise, or for maintenance or demonstration purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An official fire department or emergency medical services vehicle purchased, delivered, or refurbished on or after July 1, 2021, shall be equipped with a master warning switch to activate all emergency lights on the vehicle, in addition to one or more switches to separately activate or isolate the front, side, and rear warning lights.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 97, \'a76, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(3)(ac)}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.425 through 321.429}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E488_2E1_2E1}{BRAKES, HITCHES, AND SWAY CONTROL}{\*\bkmkend stylerid1_2E488_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.430}}}{\*\bkmkstart stylerid1_2E489_2E2_2E2}{\*\bkmkend stylerid1_2E489_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Brake, hitch, and control requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every motor vehicle, other than a motorcycle, or motorized bicycle, when operated upon a highway shall be equipped with brakes adequate to control the movement of and to stop and hold such vehicle, including two separate means of applying the brakes, each of which means shall be effective to apply the brakes to at least two wheels. If these two separate means of applying the brakes are connected in any way, they shall be so constructed that failure of any one part of the operating mechanism shall not leave the motor vehicle without brakes on at least two wheels.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every motorcycle and motorized bicycle, when operated upon a highway, shall be equipped with at least one brake, which may be operated by hand or foot.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every trailer, semitrailer, or travel trailer of a gross weight of three thousand pounds or more shall be equipped with brakes adequate to control the movement of and to stop and hold such vehicle when operated on the highways of this state. Every trailer, semitrailer, or travel trailer with a gross weight of three thousand pounds or more shall be equipped with a separate, auxiliary means of applying the brakes on the trailer, semitrailer, or travel trailer from the cab of the towing vehicle, or with self-actuating brakes, and shall also be equipped with a weight equalizing hitch with a sway control. Trailers or semitrailers with a truck or truck tractor need only comply with the brake requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, every new motor vehicle, trailer, or semitrailer hereafter sold in this state and operated upon the highways shall be equipped with service brakes upon all wheels of every such vehicle with the following exceptions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any motorcycle or motorized bicycle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any trailer or semitrailer of less than three thousand pounds gross weight need not be equipped with brakes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Trucks and truck tractors equipped with three or more axles and manufactured before July 25, 1980, need not have brakes on the front wheels, except that such vehicles equipped with two or more front axles shall be equipped with brakes on at least one of the axles; however, the service brakes of the vehicle shall comply with the performance requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.431}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only such brakes on the vehicle or vehicles being towed in a driveaway-towaway operation need be operative as may be necessary to ensure compliance by the combination of vehicles with the performance requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.431}}}{{\f5\fs18\hyphpar0\qj{. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdriveaway-towaway\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ operation as used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ means any operation in which any motor vehicle or motor vehicles, new or used, constitute the commodity being transported, when one set or more of wheels of any such motor vehicle or motor vehicles are on the roadway during the course of transportation, whether or not any such motor vehicle furnishes the motive power.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m17; C24, 27, 31, 35, \'a75039; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.39;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.430}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1044, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a724}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1068, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a784}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.189}}}{{\f5\fs12\hyphpar0\qj{, 321.464}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(ad)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.431}}}{\*\bkmkstart stylerid1_2E49_30_2E2_2E2}{\*\bkmkend stylerid1_2E49_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Performance ability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The service brakes upon any motor vehicle or combination of motor vehicles, when upon dry asphalt or concrete pavement surface free from loose material where the grade does not exceed one percent, when traveling twenty miles per hour shall be adequate:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To stop such vehicle or vehicles having a gross weight of less than five thousand pounds within a distance of thirty feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To stop such vehicle or vehicles having a gross weight in excess of five thousand pounds within a distance of forty-five feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Under the conditions specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the hand brake shall be adequate to hold the vehicle or vehicles stationary on any grade upon which operated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Under the conditions specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the service brakes upon a motor vehicle equipped with two-wheel brakes only, and when permitted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall be adequate to stop the vehicle within a distance of forty-five feet and the hand brake adequate to stop the vehicle within a distance of fifty-five feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All braking distances specified in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall apply to all vehicles mentioned, whether such vehicles are not loaded or are loaded to the maximum capacity permitted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All brakes shall be maintained in good working order and shall be so adjusted as to operate as equally as practicable with respect to the wheels on opposite sides of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fae\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m17; C24, 27, 31, 35, \'a75039; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.40;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.431}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1140, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7151}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a741, 93}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.189}}}{{\f5\fs12\hyphpar0\qj{, 321.430}}}{{\f5\fs12\hyphpar0\qj{, 321.464}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(ae)}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E491_2E1_2E1}{MISCELLANEOUS EQUIPMENT AND DRIVER SAFETY PROVISIONS}{\*\bkmkend stylerid1_2E491_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.432}}}{\*\bkmkstart stylerid1_2E492_2E2_2E2}{\*\bkmkend stylerid1_2E492_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Horns and warning devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every motor vehicle when operated upon a highway shall be equipped with a horn in good working order and capable of emitting sound audible under normal conditions from a distance of not less than two hundred feet, but no horn or other warning device shall emit an unreasonably loud or harsh sound or a whistle. The driver of a motor vehicle shall when reasonably necessary to ensure safe operation give audible warning with the horn but shall not otherwise use such horn when upon a highway.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m17; C24, 27, 31, 35, \'a75040, 5041; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.41;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.432}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1043, \'a785}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.234A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(af)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.433}}}{\*\bkmkstart stylerid1_2E493_2E2_2E2}{\*\bkmkend stylerid1_2E493_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sirens, whistles, air horns, and bells prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle shall not be equipped with and a person shall not use upon a vehicle any siren, whistle, or bell, except as otherwise permitted in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or any other provision of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is permissible but not required that any commercial vehicle be equipped with a theft alarm signal device which is so arranged that it cannot be used by the driver as an ordinary warning signal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any authorized emergency vehicle may be equipped with a siren, whistle, air horn, or bell capable of emitting sound audible under normal conditions from a distance of not less than five hundred feet. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency medical services program, fire department, or law enforcement agency may equip one or more vehicles with an air horn or a low-frequency siren.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An official fire department vehicle, emergency medical services program vehicle, or law enforcement vehicle owned by the state, a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, or a corporation providing emergency medical services, that was purchased, delivered, or refurbished on or after July 1, 2022, excluding an all-terrain vehicle or a special service vehicle, shall be equipped with an electric or electronic siren capable of emitting at least two distinct siren tones, and one or more compatible siren speakers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized emergency vehicle\u8217\'3fs siren, whistle, air horn, or bell shall not be used except when the vehicle is operated in response to an emergency call, an incident dangerous to the public, an official training exercise, in a parade or designated public service event, for maintenance or demonstration purposes, or in the immediate pursuit of an actual or suspected violator of the law, and the driver of the vehicle shall sound the siren, whistle, air horn, or bell when the driver reasonably believes necessary to warn pedestrians and other drivers of the approach of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A towing or recovery vehicle, unless owned by the state or a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, shall not be equipped with a siren.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric siren\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an audible warning device that produces sound using an electric motor with an attached rotating slotted or perforated disc.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectronic siren\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an audible warning device that produces sound electronically using amplifiers and electromagnetic speakers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLow-frequency siren\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a siren that produces low-frequency sound waves and is used in addition to an electric or electronic siren.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.42;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.433}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1080, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 97, \'a77, 9}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1087, \'a78, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.231}}}{{\f5\fs12\hyphpar0\qj{, 321.231B}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(ag)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.434}}}{\*\bkmkstart stylerid1_2E494_2E2_2E2}{\*\bkmkend stylerid1_2E494_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bicycle sirens or whistles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A bicycle shall not be equipped with and a person shall not use upon a bicycle any siren or whistle. }{{\f5\fs18\hyphpar0\qj{This section}}}{ shall not apply to bicycles ridden by peace officers in the line of duty.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.43;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.434}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 71, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(9)(k)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 9 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.435}}}{\*\bkmkstart stylerid1_2E495_2E2_2E2}{\*\bkmkend stylerid1_2E495_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motorcycles equipped with detachable stabilizing wheels.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding any other provision of law, a motor vehicle that is originally designed as a two-wheeled motorcycle and is modified using conversion hardware which allows for the attachment and detachment of two stabilizing rear wheels may be operated on a highway with the stabilizing wheels attached in accordance with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ applicable to motorcycles. A motorcycle shall not be determined to be reconstructed based on the sole fact that two stabilizing wheels have been added as described in }{{\f5\fs18\hyphpar0\qj{this section.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 15, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.436}}}{\*\bkmkstart stylerid1_2E496_2E2_2E2}{\*\bkmkend stylerid1_2E496_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mufflers, prevention of noise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every motor vehicle shall at all times be equipped with a muffler in good working order and in constant operation to prevent excessive or unusual noise and annoying smoke, and no person shall use a muffler cutout, bypass or similar device upon a motor vehicle on a highway.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m18; C24, 27, 31, 35, \'a75061 \u8211\'3f 5063; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.45;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.436}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(3)(ah)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.437}}}{\*\bkmkstart stylerid1_2E497_2E2_2E2}{\*\bkmkend stylerid1_2E497_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mirrors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every motor vehicle shall be equipped with a mirror so located as to reflect to the driver a view of the highway for a distance of at least two hundred feet to the rear of such vehicle. Any motor vehicle so loaded, or towing another vehicle in such manner, as to obstruct the view in a rear view mirror located in the driver\u8217\'3fs compartment shall be equipped with a side mirror so located that the view to the rear will not be obstructed; however, when such vehicle is not loaded or towing another vehicle the side mirrors shall be retracted or removed. All van or van type motor vehicles shall be equipped with outside mirrors of unit magnification, each with not less than nineteen point five square inches of reflective surface, installed with stable supports on both sides of the vehicle, located so as to provide the driver a view to the rear along both sides of the vehicle, and adjustable in both the horizontal and vertical directions to view the rearward scene.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 321E}}}{{\f5\fs18\hyphpar0\qj{, a combination of vehicles coupled together which is used exclusively for the transportation of passenger vehicles, light delivery trucks, panel delivery trucks, pickups, boats, and recreational chassis, may permanently attach a convex-type mirror on either or both of the vertical supports, forward of the steering axle of the power unit, provided that the mirror shall not extend beyond the limit of any other rearview mirror on the vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75105-c20; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.46;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.437}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1210, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.234A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph b }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.438}}}{\*\bkmkstart stylerid1_2E498_2E2_2E2}{\*\bkmkend stylerid1_2E498_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Windshields and windows.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not drive a motor vehicle equipped with a windshield, sidewings, or side or rear windows which do not permit clear vision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not operate on the highway a motor vehicle equipped with a front windshield, a side window to the immediate right or left of the driver, or a sidewing forward of and to the left or right of the driver which is excessively dark or reflective so that it is difficult for a person outside the motor vehicle to see into the motor vehicle through the windshield, window, or sidewing.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules establishing a minimum measurable standard of transparency which shall apply to violations of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a person who operates a motor vehicle owned or leased by a federal, state, or local law enforcement agency if the operation is part of the person\u8217\'3fs official duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every motor vehicle except a motorcycle, or a vehicle included in the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.383}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 321.115}}}{{\f5\fs18\hyphpar0\qj{ shall be equipped with a windshield in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.444}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.47;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.438}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 125, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 183, \'a753}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(3)(ai)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.439}}}{\*\bkmkstart stylerid1_2E499_2E2_2E2}{\*\bkmkend stylerid1_2E499_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Windshield wipers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The windshield on every motor vehicle shall be equipped with a device for cleaning rain, snow, or other moisture from the windshield, which device shall be so constructed as to be controlled or operated by the driver of the vehicle.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.48;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.439}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(3)(aj)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.440}}}{\*\bkmkstart stylerid1_2E5_30_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_30_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restrictions as to tire equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every solid rubber tire on a vehicle shall have rubber on its entire traction surface at least one inch thick above the edge of the flange of the entire periphery. Any pneumatic tire on a vehicle shall be considered unsafe if it has:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any part of the ply or cord exposed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any bump, bulge or separation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tread design depth of less than one-sixteenth of an inch measured in any two or more adjacent tread grooves, exclusive of tie bars or, for those tires with tread wear indicators, worn to the level of the tread wear indicators in any two tread grooves.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A marking \u8220\'3fnot for highway use\u8221\'3f, \u8220\'3ffor racing purposes only\u8221\'3f, \u8220\'3funsafe for highway use\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tread or sidewall cracks, cuts or snags deep enough to expose the body cord.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such other conditions as may be reasonably demonstrated to render it unsafe.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Been regrooved or recut below the original tread design depth, excepting special tires which have extra under tread rubber and are identified as such, or if a pneumatic tire was originally designed without grooves or tread.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle, except an implement of husbandry, equipped with either solid rubber or pneumatic tires shall not be operated where the weight per inch of tire width is greater than five hundred seventy-five pounds per inch of tire width based on the tire width rating, except on a steering axle, in which case six hundred pounds per inch of tire width is permitted based on the tire width rating.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75065-c1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.49;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.440}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 100, \'a72, 3, 12}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a778}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(3)(ak)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.441}}}{\*\bkmkstart stylerid1_2E5_301_2E2_2E2}{\*\bkmkend stylerid1_2E5_301_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Metal tires prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person shall operate or move on a paved highway any motor vehicle, trailer, or semitrailer having any metal tire or metal track in contact with the roadway.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74918, 4919; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.50;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.441}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(3)(al)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.442}}}{\*\bkmkstart stylerid1_2E5_302_2E2_2E2}{\*\bkmkend stylerid1_2E5_302_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Projections on wheels.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No tire on a vehicle moved on a highway shall have on its periphery any block, stud, flange, cleat, or spike or any other protuberances of any material other than rubber which projects beyond the tread of the traction surface of the tire except that it shall be permissible to use:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Farm machinery with tires having protuberances which will not injure the highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tire chains of reasonable proportions upon any vehicle when required for safety because of snow, ice, or other conditions tending to cause a vehicle to skid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pneumatic tires with inserted ice grips or tire studs projecting not more than one-sixteenth inch beyond the tread of the traction surface of the tire upon any vehicle from November 1 of each year to April 1 of the following year, except that a school bus and fire department emergency apparatus may use such tires at any time.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-1a; C24, 27, 31, 35, \'a75068, 5070; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.51;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.442}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(3)(am)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.443}}}{\*\bkmkstart stylerid1_2E5_303_2E2_2E2}{\*\bkmkend stylerid1_2E5_303_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special permits authorized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department and local authorities in their respective jurisdictions shall review any application for a special permit and may, with good cause being shown, issue special permits authorizing the operation upon a highway of traction engines or tractors having movable tracks with transverse corrugations upon the periphery of such movable tracks or farm tractors or other farm machinery, the operation of which upon a highway would otherwise be prohibited under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75069; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.52;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.443}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; headnote revised}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.444}}}{\*\bkmkstart stylerid1_2E5_304_2E2_2E2}{\*\bkmkend stylerid1_2E5_304_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Safety glass.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall sell any new motor vehicle nor shall any motor vehicle, manufactured since July 1, 1935, be registered, or operated unless such vehicle is equipped with safety glass wherever glass is used in doors, windows, and windshields. Replacements of glass in doors, windows, or windshields shall be of safety glass.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSafety glass\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any product composed of glass, so manufactured, fabricated, or treated as substantially to prevent shattering and flying of the glass when struck or broken. Safety glass and glazing materials shall comply with federal motor vehicle safety standard number 205 as published in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7571.205}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a74991-f1, -f4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.53, 5034.54, 5034.55;}}}{ C46, 50, 54, 58, 62, \'a7321.444, 321.445, 321.446; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.444}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1080, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.438}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(3)(an)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.445}}}{\*\bkmkstart stylerid1_2E5_305_2E2_2E2}{\*\bkmkend stylerid1_2E5_305_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Safety belts and safety harnesses \u8212\'3f use required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for motorcycles or motorized bicycles, 1966 model year or newer motor vehicles subject to registration in Iowa shall be equipped with safety belts and safety harnesses which conform with federal motor vehicle safety standard numbers 209 and 210 as published in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7571.209 \u8211\'3f 571.210}}}{{\f5\fs18\hyphpar0\qj{ and with prior federal motor vehicle safety standards for seat belt assemblies and seat belt assembly anchorages applicable for the motor vehicle\u8217\'3fs model year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver and front seat occupants of a type of motor vehicle that is subject to registration in Iowa, except a motorcycle or a motorized bicycle, shall each wear a properly adjusted and fastened safety belt or safety harness any time the vehicle is in forward motion on a street or highway in this state except that a child under eighteen years of age shall be secured as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.446}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver or front seat occupants of a motor vehicle which is not required to be equipped with safety belts or safety harnesses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver and front seat occupants of a motor vehicle who are actively engaged in work which requires them to alight from and reenter the vehicle at frequent intervals, providing the vehicle does not exceed twenty-five miles per hour between stops.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver of a motor vehicle while performing duties as a rural letter carrier for the United States postal service. This exemption applies only between the first delivery point after leaving the post office and the last delivery point before returning to the post office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Passengers on a bus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person possessing a written certification from a health care provider licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{151}}}{{\f5\fs18\hyphpar0\qj{ on a form provided by the department that the person is unable to wear a safety belt or safety harness due to physical or medical reasons. The certification shall specify the time period for which the exemption applies. The time period shall not exceed twelve months, at which time a new certification may be issued unless the certifying health care provider is from a United States military facility, in which case the certificate may specify a longer period of time or a permanent exemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Front seat occupants of an authorized emergency vehicle while they are being transported in an emergency. However, this exemption does not apply to the driver of the authorized emergency vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, in cooperation with the department of public safety and the department of education, shall establish educational programs to foster compliance with the safety belt and safety harness usage requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver and front seat passengers may be each charged separately for improperly used or nonused equipment under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. However, the driver shall not be charged for a violation committed by a passenger who is fourteen years of age or older unless the passenger is unable to properly fasten a seat belt due to a temporary or permanent disability. The owner of the motor vehicle may be charged for equipment violations under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonuse of a safety belt or safety harness by a person is not admissible or material as evidence in a civil action brought for damages in a cause of action arising prior to July 1, 1986.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a cause of action arising on or after July 1, 1986, brought to recover damages arising out of the ownership or operation of a motor vehicle, the failure to wear a safety belt or safety harness in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered evidence of comparative fault under }}}{{\f5\fs18\hyphpar0\qj{section 668.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. However, except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.446, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, the failure to wear a safety belt or safety harness in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be admitted to mitigate damages, but only under the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parties seeking to introduce evidence of the failure to wear a safety belt or safety harness in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ must first introduce substantial evidence that the failure to wear a safety belt or safety harness contributed to the injury or injuries claimed by the plaintiff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the evidence supports such a finding, the trier of fact may find that the plaintiff\u8217\'3fs failure to wear a safety belt or safety harness in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ contributed to the plaintiff\u8217\'3fs claimed injury or injuries, and may reduce the amount of the plaintiff\u8217\'3fs recovery by an amount not to exceed twenty-five percent of the damages awarded after any reductions for comparative fault.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ providing exceptions from application of }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ for front seats and front seat passengers of motor vehicles owned, leased, rented, or primarily used by persons with disabilities who use collapsible wheelchairs.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.445}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1016, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1009, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1211, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 120, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1080, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1113, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1079, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1186, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1009, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}{{\f5\fs12\hyphpar0\qj{, 321.446}}}{{\f5\fs12\hyphpar0\qj{, 321.555}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 14, paragraph c }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.446}}}{\*\bkmkstart stylerid1_2E5_306_2E2_2E2}{\*\bkmkend stylerid1_2E5_306_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child restraint devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child under one year of age and weighing less than twenty pounds who is being transported in a motor vehicle subject to registration, except a school bus or motorcycle, shall be secured during transit in a rear-facing child restraint system that is used in accordance with the manufacturer\u8217\'3fs instructions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child under six years of age who does not meet the description in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and who is being transported in a motor vehicle subject to registration, except a school bus or motorcycle, shall be secured during transit by a child restraint system that is used in accordance with the manufacturer\u8217\'3fs instructions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child at least six years of age but under eighteen years of age who is being transported in a motor vehicle subject to registration, except a school bus or motorcycle, shall be secured during transit by a child restraint system that is used in accordance with the manufacturer\u8217\'3fs instructions or by a safety belt or safety harness of a type approved under }}}{{\f5\fs18\hyphpar0\qj{section 321.445}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Peace officers acting on official duty. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transportation of children in 1965 model year or older vehicles, authorized emergency vehicles, buses, or motor homes or motorsports recreational vehicles, except when a child is transported in a motor home\u8217\'3fs or motorsports recreational vehicle\u8217\'3fs passenger seat situated directly to the driver\u8217\'3fs right. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transportation of a child who has been certified by a physician licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or a physician assistant licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{ as having a medical, physical, or mental condition that prevents or makes inadvisable securing the child in a child restraint system, safety belt, or safety harness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A back seat occupant of a motor vehicle for whom no safety belt is available because all safety belts are being used by other occupants or cannot be used due to the use of a child restraint system in the seating position for which a belt is provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. Violations shall be charged as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An operator who transports a passenger under fourteen years of age in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{ may be charged with a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a passenger fourteen years of age or older is unable to properly fasten a seatbelt due to a temporary or permanent disability, an operator who transports such a person in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ may be charged with a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Otherwise, a passenger fourteen years of age or older who violates }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall be charged in lieu of the operator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a child under fourteen years of age, or a child fourteen years of age or older who is unable to fasten a seatbelt due to a temporary or permanent disability, is being transported in a taxicab or in a personal vehicle operated by a transportation network company driver, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321N.1}}}{{\f5\fs18\hyphpar0\qj{, in a manner that is not in compliance with }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{, the parent, legal guardian, or other responsible adult traveling with the child shall be served with a citation for a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in lieu of the taxicab operator or transportation network company driver. Otherwise, if a passenger being transported in the taxicab or in a personal vehicle operated by a transportation network company driver is fourteen years of age or older, the citation shall be served on the passenger in lieu of the taxicab operator or transportation network company driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is first charged for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and who has not purchased or otherwise acquired a child restraint system shall not be convicted if the person produces in court, within a reasonable time, proof that the person has purchased or otherwise acquired a child restraint system which meets federal motor vehicle safety standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure to use a child restraint system, safety belts, or safety harnesses as required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not constitute negligence nor is the failure admissible as evidence in a civil action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fchild restraint system\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a specially designed seating system, including a belt-positioning seat or a booster seat, that meets federal motor vehicle safety standards set forth in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7571.213}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1016, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1069, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1113, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7123}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1186, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1127, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1101, \'a75, 24}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1066, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210}}}{{\f5\fs12\hyphpar0\qj{, 321.445}}}{{\f5\fs12\hyphpar0\qj{, 321.555}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(c)}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.447 and 321.448}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.449}}}{\*\bkmkstart stylerid1_2E5_308_2E2_2E2}{\*\bkmkend stylerid1_2E5_308_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motor carrier safety rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not operate a commercial vehicle on the highways of this state except in compliance with rules adopted by the department of public safety, in consultation with the department of transportation, under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. The rules shall be consistent with the federal motor carrier safety regulations promulgated under }}}{{\f5\fs18\hyphpar0\qj{United States Code, Tit. 49}}}{{\f5\fs18\hyphpar0\qj{, and found in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pts. 385, 390 }}}{{\f5\fs18\hyphpar0\qj\cf1{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj\cf1{ 399}}}{{\f5\fs18\hyphpar0\qj{ and adopted under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of public safety, in consultation with the department of transportation, shall also adopt rules concerning hours of service for drivers of vehicles operated for hire and designed to transport seven or more persons, including the driver. The rules shall not apply to vehicles offered to the public for hire that are used principally in intracity operation and that are regulated by local authorities pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.236}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ authorizing a person who is at least eighteen years of age or over, but under twenty-one years of age, to be licensed to operate a commercial motor vehicle in interstate commerce if the person holds a valid commercial driver\u8217\'3fs license and is authorized under federal law to operate a commercial motor vehicle in interstate commerce.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ concerning driver qualifications, hours of service, and recordkeeping requirements do not apply to the operators of public utility trucks, trucks hauling gravel, construction trucks and equipment, trucks moving implements of husbandry, and special trucks, other than a truck tractor, operating intrastate. Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, trucks for hire on construction projects are not exempt from }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ concerning driver age qualifications do not apply to drivers for private and for-hire motor carriers which operate solely intrastate. The minimum age for the exempted intrastate operations is eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for drivers of commercial vehicles shall not apply to a driver of a commercial vehicle who is engaged exclusively in intrastate commerce, when the commercial vehicle\u8217\'3fs gross vehicle weight rating is twenty-six thousand pounds or less, unless the vehicle is used to transport hazardous materials requiring a placard or if the vehicle is designed to transport more than fifteen passengers, including the driver. For the purpose of complying with the hours of service recordkeeping requirements under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7395.1(e)(1)(v)(A \u8211\'3f D)}}}{{\f5\fs18\hyphpar0\qj{, a driver\u8217\'3fs report of daily beginning and ending on-duty time submitted to the motor carrier at the end of each workweek shall be considered acceptable motor carrier time records.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition, rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a driver operating intrastate for a farm operation as defined in }}}{{\f5\fs18\hyphpar0\qj{section 352.2}}}{{\f5\fs18\hyphpar0\qj{, or for an agricultural interest when the commercial vehicle is operated between the farm as defined in }}}{{\f5\fs18\hyphpar0\qj{section 352.2}}}{{\f5\fs18\hyphpar0\qj{ and another farm, between the farm and a market for farm products, or between the farm and an agribusiness location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A driver or a driver-salesperson for a private carrier, who is not for hire and who is engaged exclusively in intrastate commerce, may drive twelve hours, be on duty sixteen hours in a twenty-four-hour period, and be on duty seventy hours in seven consecutive days or eighty hours in eight consecutive days. A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdriver-salesperson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7395.2}}}{{\f5\fs18\hyphpar0\qj{, as adopted by the department of public safety by rule. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For-hire drivers who are engaged exclusively in intrastate commerce and who operate trucks and truck tractors exclusively for the movement of construction materials and equipment to and from construction projects may also drive twelve hours, be on duty sixteen hours in a twenty-four-hour period, and be on duty seventy hours in seven consecutive days or eighty hours in eight consecutive days. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ concerning physical and medical qualifications for drivers of commercial vehicles engaged in intrastate commerce shall not be construed as disqualifying any individual who was employed as a driver of commercial vehicles engaged in intrastate commerce whose physical or medical condition existed prior to July 29, 1996.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ concerning physical and medical qualifications for a driver shall not apply to a farmer or a farmer\u8217\'3fs hired help when operating a vehicle owned by the farmer while it is being used in connection with the intrastate transportation of fertilizers and chemicals used in the farmer\u8217\'3fs crop production.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ concerning physical and medical qualifications for a driver shall not apply to a farmer or a farmer\u8217\'3fs hired help when operating a vehicle owned by the farmer while it is being used in connection with the intrastate transportation of agricultural commodities or feed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not impose any requirements which impose any restrictions upon a person operating an implement of husbandry or pickup to transport fertilizers and pesticides in that person\u8217\'3fs agricultural operations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to vehicles engaged in intrastate commerce and used in combination, provided the gross vehicle weight rating of the towing unit is ten thousand pounds or less and the gross combination weight rating is twenty-six thousand pounds or less.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the course of enforcing the motor carrier safety rules adopted by the department of public safety under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, the department of public safety\u8217\'3fs peace officers are authorized, at reasonable times and places and with reasonable notice, to enter a motor carrier\u8217\'3fs place of business for the purpose of performing a motor carrier safety audit or compliance review. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ by itself permits the seizure of the property of a motor carrier. Any audit or review shall be conducted in compliance with the federal motor carrier safety regulations in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pts. 105 }}}{{\f5\fs18\hyphpar0\qj\cf1{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj\cf1{ 185, 382, 383, 385, and 390 }}}{{\f5\fs18\hyphpar0\qj\cf1{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj\cf1{ 399}}}{{\f5\fs18\hyphpar0\qj{. A peace officer of the department of public safety is authorized to inspect and copy motor carrier records required by }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pts. 105 }}}{{\f5\fs18\hyphpar0\qj\cf1{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj\cf1{ 185, 382, 383, 385, and 390 }}}{{\f5\fs18\hyphpar0\qj\cf1{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj\cf1{ 399}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.58;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.449}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 170, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1083, \'a73 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1278, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 47, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 171, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1063, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a717, 29}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 96, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1134, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 8, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a740, 41}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 41, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 85, \'a712 \u8211\'3f 14}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 4, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.288}}}{{\f5\fs12\hyphpar0\qj{, 321.343}}}{{\f5\fs12\hyphpar0\qj{, 321.449B}}}{{\f5\fs12\hyphpar0\qj{, 325A.2}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(13)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 13, paragraph b }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.449A}}}{\*\bkmkstart stylerid1_2E5_309_2E2_2E2}{\*\bkmkend stylerid1_2E5_309_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rail crew transport drivers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A driver of a motor vehicle operated for hire which is designed to transport seven or more persons but fewer than sixteen persons including the driver and is used to transport railroad workers to or from their places of employment or during the course of their employment is subject to the following limitations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver shall not drive such a vehicle more than ten hours following eight consecutive hours of uninterrupted rest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver shall not drive such a vehicle for any period after having been on duty for fifteen hours following eight consecutive hours of uninterrupted rest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The driver shall not accept a call for service from the driver\u8217\'3fs employer during a period of uninterrupted rest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the following definitions apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmployer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a railroad worker transportation company, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 327F.39}}}{{\f5\fs18\hyphpar0\qj{, for whom the driver performs a service, either for wages or as an independent contractor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOn duty\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all time from the time a driver begins work or is required to be ready to work until the time the driver is relieved from work and all responsibility for performing work, whether or not the driver is compensated for all of the time. A driver may drive more than one assigned trip, as long as the trip falls within the on-duty period. A driver }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbegins work\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ when the driver enters a transport vehicle to begin a trip assignment and is not }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frelieved from work\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ until the driver has exited the transport vehicle for the final time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUninterrupted rest\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that the employer shall not communicate with the driver by telephone, pager, or in any other manner that could reasonably be expected to disrupt the driver\u8217\'3fs rest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 13}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 47, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327F.39}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(13)(b)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.449B}}}{\*\bkmkstart stylerid1_2E51_30_2E2_2E2}{\*\bkmkend stylerid1_2E51_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Texting or using a mobile telephone while operating a commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person subject to rules adopted by the department of public safety pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.449}}}{{\f5\fs18\hyphpar0\qj{ shall not operate a commercial motor vehicle while engaged in texting as prohibited by }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7392.80}}}{{\f5\fs18\hyphpar0\qj{, except in an emergency or as otherwise permitted under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7392.80}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person subject to rules adopted by the department of public safety pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.449}}}{{\f5\fs18\hyphpar0\qj{ shall not operate a commercial motor vehicle while using a hand-held mobile telephone as prohibited by }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7392.82}}}{{\f5\fs18\hyphpar0\qj{, except in an emergency or as otherwise permitted under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7392.82}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 13}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be considered a moving violation for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A conviction for a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be in lieu of a conviction for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.276}}}{{\f5\fs18\hyphpar0\qj{ if the violations are based on the same facts and circumstances.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1017, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 85, \'a715}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(13)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional penalties for violations causing serious injury or death, see }{{\f5\fs12\hyphpar0\qj{\'a7321.482A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.450}}}{\*\bkmkstart stylerid1_2E511_2E2_2E2}{\*\bkmkend stylerid1_2E511_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hazardous materials transportation regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not transport or have transported or shipped within this state any hazardous material except in compliance with rules adopted by the department of public safety under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. The rules shall be consistent with the federal hazardous materials regulations adopted under }}}{{\f5\fs18\hyphpar0\qj{United States Code, Tit. 49}}}{{\f5\fs18\hyphpar0\qj{, and found in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pts. 107, 171 to 173, 177, 178, and 180}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ concerning physical and medical qualifications for drivers of commercial vehicles engaged in intrastate commerce shall not be construed as disqualifying any individual who was employed as a driver of commercial vehicles engaged in intrastate commerce, and whose physical or medical condition existed, prior to July 29, 1996.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ pertaining to compliance with regulations adopted under }}}{{\f5\fs18\hyphpar0\qj{United States Code, Tit. 49}}}{{\f5\fs18\hyphpar0\qj{, and found in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7177.804}}}{{\f5\fs18\hyphpar0\qj{, shall not apply to retail dealers of fertilizers, petroleum products, and pesticides and their employees while delivering fertilizers, petroleum products, and pesticides to farm customers within a one-hundred-mile radius of their retail place of business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a farmer or employees of a farmer when transporting an agricultural hazardous material, except class 2 material, between the sites in the farmer\u8217\'3fs agricultural operations unless the material is being transported on the interstate highway system. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffarmer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person engaged in the production or raising of crops, poultry, or livestock; }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffarmer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a person who is a commercial applicator of agricultural chemicals or fertilizers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, a driver who is engaged exclusively in intrastate commerce and who operates a truck or truck tractor exclusively for the movement of refined oil products may drive twelve hours, be on duty sixteen hours in a twenty-four-hour period, and be on duty seventy hours in seven consecutive days, or eighty hours in eight consecutive days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ applicable to the transportation of any fuel used in race car engines shall not apply to the transportation of such fuel if the fuel is contained in the fuel cells of a race car being transported in a trailer and the fuel cells are certified by SFI foundation, inc.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5034.59;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.450}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 170, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1083, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 70, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 186, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 127, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a727, 28}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1178, \'a75, 17}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 8, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a7177}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1127, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 85, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 4, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321O.4}}}{{\f5\fs12\hyphpar0\qj{, 325A.2}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(13)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 13, paragraph c }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.451}}}{\*\bkmkstart stylerid1_2E512_2E2_2E2}{\*\bkmkend stylerid1_2E512_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Emergency vehicles \u8212\'3f certificate of designation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director or the director\u8217\'3fs designee may designate a privately owned vehicle as an authorized emergency vehicle and issue a certificate of designation for the vehicle, upon written request being made on forms provided by the department and showing necessity for the designation. A certificate of designation may be issued for the following privately owned vehicles:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ambulance or fire or rescue vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state or county medical examiner vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle owned by a sheriff or full-time paid deputy sheriff if the authorized emergency vehicle designation is requested by the sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle owned by a chief of police or any officer of the police department if the authorized emergency vehicle designation is requested by the chief of police.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle owned by a chief of a full-time paid fire department if the authorized emergency vehicle designation is requested by the chief of the fire department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A towing or recovery vehicle, subject to rules adopted by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle owned by a certified chief or certified fire officer of a volunteer fire department, a fire department comprised of a combination of volunteer and paid members, or a nonprofit corporation that delivers emergency services on behalf of a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, pursuant to a written contract, if the application for a certificate of designation is requested by the certified chief or certified fire officer of the fire department. However, the department shall not approve an application received pursuant to this paragraph unless the owner of the vehicle has completed an emergency vehicle operations course approved by the fire service training bureau, as described in }}}{{\f5\fs18\hyphpar0\qj{section 100B.6}}}{{\f5\fs18\hyphpar0\qj{, provided proof of certification as a fire officer, and provided proof of financial liability coverage or risk pool coverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle owned by a chief, medical director, or certified medical provider of an authorized emergency medical service, if the application for a certificate of designation is requested by the chief, medical officer, or medical director of the authorized emergency medical service. However, the department shall not approve an application received pursuant to this paragraph unless the owner of the vehicle has completed an emergency vehicle operations course approved by the department of health and human services, and provided proof of financial liability coverage or risk pool coverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application for a certificate of designation must include the name of the owner of the vehicle, vehicle identification information, a description of the vehicle\u8217\'3fs equipment, and a description of how the vehicle will be used as an authorized emergency vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate of designation shall at all times be carried with the registration receipt for the vehicle to which the certificate refers. The certificate may be revoked by the director upon a showing of abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public or private entity shall not require an employee or volunteer to apply for or maintain a certificate of designation pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ as a condition of employment or of permitting the person to continue to volunteer. A person shall not be required to operate or use a vehicle designated as an authorized emergency vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to exempt the state or a municipality, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 670.1}}}{{\f5\fs18\hyphpar0\qj{, from any duty to purchase, equip, maintain, or otherwise provide authorized emergency vehicles to meet any requirement to provide public services, including law enforcement, fire protection, rescue, emergency medical services, or emergency management.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.451}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 37, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a734, 35}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1087, \'a79 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71066}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.424}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E513_2E1_2E1}{SIZE, WEIGHT, AND LOAD}{\*\bkmkend stylerid1_2E513_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.452}}}{\*\bkmkstart stylerid1_2E514_2E2_2E2}{\*\bkmkend stylerid1_2E514_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope and effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not drive or move, and the owner of such vehicle shall not cause or knowingly permit to be driven or moved, on any highway any vehicle or vehicles of a size or weight exceeding the limitations stated in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and the maximum size and weight of vehicles herein specified shall be lawful throughout this state, and local authorities shall have no power or authority to alter said limitations except as express authority is granted in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.452}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1140, \'a715}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.453}}}{\*\bkmkstart stylerid1_2E515_2E2_2E2}{\*\bkmkend stylerid1_2E515_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Size, weight, load, and permit exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Except as provided in sections }}}{{\f5\fs18\hyphpar0\qj{321.463}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.471}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{321.474}}}{{\f5\fs18\hyphpar0\qj{, the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ governing size, weight, and load and the permit requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 321E}}}{{\f5\fs18\hyphpar0\qj{ do not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fire apparatus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Road maintenance equipment owned by, under lease to, or used in the performance of a contract with any state or local authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Implements of husbandry when moved or moving upon a highway that is not a portion of the interstate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Equipment used primarily for construction of permanent conservation practices on agricultural land when moved or moving upon a highway that is not a portion of the interstate, so long as the equipment is without payload and the movement does not violate posted weight limitations on bridges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hydroexcavation equipment used primarily for digging and excavation when moved or moving upon a highway that is not a portion of the interstate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle that is carrying an implement of husbandry or equipment used primarily for construction of permanent conservation practices and is exempted from the permit requirements under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be equipped with an amber flashing light visible from the rear. If the amber flashing light is obstructed by the loaded implement or equipment, the loaded implement or equipment shall also be equipped with and display an amber flashing light. The vehicle shall also be equipped with warning flags on that portion of the vehicle which protrudes into oncoming traffic, and shall only operate from thirty minutes prior to sunrise to thirty minutes following sunset.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle that is operated by a farmer and that is carrying an implement of husbandry between fields, locations for repair, or locations for storage of the implement of husbandry shall be exempt from any requirement to obtain a permit under }}}{{\f5\fs18\hyphpar0\qj{section 321.463}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.471}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.474}}}{{\f5\fs18\hyphpar0\qj{. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to exempt such a vehicle from any requirement or restriction other than a requirement to obtain a permit, including but not limited to requirements or restrictions relating to size, weight, load, lighting, flags, equipment, or manner of operation. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffarmer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 142D.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.453}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1154, \'a73}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1254, \'a73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1210, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 186, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1087, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1198, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1003, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1223, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 108, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1087, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7104}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 81, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 6, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.423}}}{{\f5\fs12\hyphpar0\qj{, 321E.2}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; headnote revised}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.454}}}{\*\bkmkstart stylerid1_2E516_2E2_2E2}{\*\bkmkend stylerid1_2E516_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Width of vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total outside width of a vehicle or the load on the vehicle shall not exceed eight feet six inches.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the total outside width of a vehicle or combination of vehicles transporting a divisible load of hay, straw, stover, or bagged livestock bedding shall not exceed twelve feet five inches. However, if hay, straw, stover, or bagged livestock bedding is moved on an implement of husbandry and the total width of load of the implement of husbandry exceeds twelve feet five inches, the implement of husbandry is not subject to the permit requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 321E}}}{{\f5\fs18\hyphpar0\qj{. If a divisible load of hay, straw, stover, or bagged livestock bedding is moved on any other vehicle or combination of vehicles subject to registration, the moves are subject to the permit requirements for transporting loads exceeding twelve feet five inches in width as required under }}}{{\f5\fs18\hyphpar0\qj{chapter 321E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The limitations on the total outside width of a vehicle, the load on the vehicle, or a combination of vehicles set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ do not include safety equipment on a vehicle or incidental appurtenances or retracted awnings on motor homes, motorsports recreational vehicles, travel trailers, or fifth-wheel travel trailers if the incidental appurtenance or retracted awning is less than six inches in width.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, \'a75067, 5104; C27, \'a75067, 5105-a32; C31, 35, \'a75067, 5105-a32, 5105-c18; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.454}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 9, \'a75, 8}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 186, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 189, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1087, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1127, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1054, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}{{\f5\fs12\hyphpar0\qj{, 321E.8}}}{{\f5\fs12\hyphpar0\qj{, 321E.9}}}{{\f5\fs12\hyphpar0\qj{, 321E.10}}}{{\f5\fs12\hyphpar0\qj{, 321E.17}}}{{\f5\fs12\hyphpar0\qj{, 321E.26}}}{{\f5\fs12\hyphpar0\qj{, 321E.29B}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph c }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.455}}}{\*\bkmkstart stylerid1_2E517_2E2_2E2}{\*\bkmkend stylerid1_2E517_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Projecting loads on passenger vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No passenger-type vehicle shall be operated on any highway with any load carried thereon extending beyond the line of the fenders on the left side of such vehicle nor extending more than six inches beyond the line of the fenders on the right side thereof. Passengers shall not ride on any part of any vehicle unless it is expressly designed either for passenger use or designed for carrying livestock, merchandise, or freight.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75067-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.455}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}{{\f5\fs12\hyphpar0\qj{, 321E.9}}}{{\f5\fs12\hyphpar0\qj{, 321E.26}}}{{\f5\fs12\hyphpar0\qj{, 321E.29B}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph c }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.456}}}{\*\bkmkstart stylerid1_2E518_2E2_2E2}{\*\bkmkend stylerid1_2E518_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Height of vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle unladen or with load shall not exceed a height of thirteen feet six inches.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a vehicle or combination of vehicles coupled together and used exclusively for the transportation of passenger vehicles, light delivery trucks, panel delivery trucks, pickup trucks, or recreational vehicle chassis may operate with a height not to exceed fourteen feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a vehicle or combination of vehicles transporting a divisible load of hay, straw, stover, or bagged livestock bedding may operate with a height not to exceed fourteen feet six inches.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to require any railroad or public authorities to provide sufficient vertical clearance to permit the operation of such vehicle upon the highways of this state. Any damage to highways, highway or railroad structures, or underpasses caused by the height of any vehicle provided for by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be borne by the operator or owner of the vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75067-d2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.456}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1182, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 100, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1054, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}{{\f5\fs12\hyphpar0\qj{, 321E.8}}}{{\f5\fs12\hyphpar0\qj{, 321E.9}}}{{\f5\fs12\hyphpar0\qj{, 321E.17}}}{{\f5\fs12\hyphpar0\qj{, 321E.26}}}{{\f5\fs12\hyphpar0\qj{, 321E.29B}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph c }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.457}}}{\*\bkmkstart stylerid1_2E519_2E2_2E2}{\*\bkmkend stylerid1_2E519_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Maximum length.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A combination of four vehicles is not allowed on the highways of this state, except for power units saddle mounted on other power units which shall be restricted to a maximum overall length of ninety-seven feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum length of any motor vehicle or combination of vehicles operated on the highways of this state is as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A single truck, unladen or with load, shall not have an overall length, inclusive of front and rear bumpers, in excess of forty-five feet. When determining the overall length of a single truck, the following shall be excluded:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cargo extending not more than three feet beyond the front bumper and not more than four feet beyond the rear bumper when transporting motor vehicles, boats, and chassis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An unladen cargo carrying device extending no greater than twenty-four inches from the rear of the bed of the truck.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cargo carrying device with load.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A single bus shall not have an overall length, inclusive of front and rear bumpers, in excess of forty-five feet, except that buses constructed so as to contain a flexible part allowing articulation shall not exceed sixty-one feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufactured or mobile home not in excess of forty-eight feet in length may be drawn by any motor vehicle, except a motor truck, provided that the manufactured or mobile home and its towing unit are not in excess of an overall length of sixty feet. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a light delivery truck, panel delivery truck, or \u8220\'3fpickup\u8221\'3f is not a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmotor truck\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. A portable livestock loading chute not in excess of a length of thirteen feet including its hitch or tongue may be drawn by any vehicle or combination of vehicles, provided that the vehicle or combination of vehicles drawing the loading chute is not in excess of the legal length provided for such vehicles or combinations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A combination of three vehicles coupled together one of which is a motor vehicle, unladen or with load, other than a truck tractor, shall not have an overall length, inclusive of front and rear bumpers, in excess of seventy feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle or combination of vehicles may be operated upon the highways of this state, irrespective of the length and weight limitations imposed by the laws of this state, if the motor vehicle or combination of vehicles is operated within the corporate limits of a city abutting a border of this state and such operations have been approved by ordinance of the city council and if the length and weight of the motor vehicle or combination of vehicles is in conformity with the laws relating to length and weight of the abutting state. If a city council has authorized such operation upon highways within the corporate limits, then the limit of travel for such motor vehicles or combination of vehicles within the state is extended to the commercial zones as described by federal regulations concerning interstate commerce, }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a71048.101}}}{{\f5\fs18\hyphpar0\qj{, and to the interstate system as provided in }}}{{\f5\fs18\hyphpar0\qj{23 U.S.C. \'a7127}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{49 U.S.C. \'a731112(c)}}}{{\f5\fs18\hyphpar0\qj{, as amended by }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 104-59}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trailer or semitrailer, laden or unladen, shall not have an overall length in excess of fifty-three feet when operating in a truck tractor-semitrailer combination exclusive of retractable extensions used to support the load. However, when a trailer or semitrailer is used exclusively for the transportation of passenger vehicles, light delivery trucks, panel delivery trucks, pickup trucks, recreational vehicle chassis, or boats, the load carried on the trailer or semitrailer may extend up to three feet beyond the front bumper and up to four feet beyond the rear bumper of the trailer or semitrailer. A lowboy semitrailer, laden or unladen, which is designed and exclusively used for the transportation of construction equipment shall not have an overall length in excess of fifty-seven feet when used in a truck tractor-semitrailer combination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trailer or semitrailer, laden or unladen, shall not have an overall length in excess of twenty-eight feet six inches when operating in a truck tractor-semitrailer-trailer combination or truck tractor-semitrailer-semitrailer combination. When the semitrailers in a truck tractor-semitrailer-semitrailer combination are connected by a rigid frame extension including a fifth-wheel connection point attached to the rear frame of the first semitrailer, the length of the frame extension shall not be included when determining the overall length of the first semitrailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Power units designed to carry cargo, when used in combination with a trailer or semitrailer shall not exceed sixty-five feet in overall length for the combination exclusive of retractable extensions used to support the load. However, if a combination of vehicles is used exclusively for the transportation of passenger vehicles, light delivery trucks, panel delivery trucks, pickup trucks, recreational vehicle chassis, or boats, the load may extend up to three feet beyond the front bumper of the power unit and up to four feet beyond the rear bumper of the trailer or semitrailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A stinger-steered automobile transporter shall not have an overall length exceeding eighty feet, exclusive of retractable extensions used to support the load and all other devices or appurtenances related to the safe and efficient operation of the vehicle, except that the load may extend up to four feet beyond the front bumper and up to six feet beyond the rear bumper.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor home or motorsports recreational vehicle shall not have an overall length, excluding front and rear bumpers and safety equipment, in excess of forty-five feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A combination of two vehicles coupled together, one of which is a motor home, shall not have an overall length in excess of sixty-five feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A combination of two vehicles coupled together, one of which is a travel trailer or fifth-wheel travel trailer, shall not have an overall length in excess of sixty-five feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and to the extent allowed under federal law, the maximum length of a towaway trailer transporter combination operated on the highways of this state is eighty-five feet. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftowaway trailer transporter combination\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a combination of vehicles consisting of a towing vehicle and two unladen trailers or unladen semitrailers in which the trailers or semitrailers constitute inventory property of the manufacturer intended for sale and which are being transported from a trailer manufacturer to a trailer distributor or authorized trailer dealer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the department is authorized to adopt rules providing for economic export corridors for the transportation of goods or products manufactured in Iowa to or through the state of South Dakota and for the return of unladen semitrailers or unladen full trailers used for the transportation of those goods or products. The rules may authorize the operation of the following combinations of vehicles on an economic export corridor:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A truck tractor-semitrailer-semitrailer converted to a full trailer by use of a dolly equipped with a fifth wheel which is considered a part of the trailer for all purposes, and not a separate unit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A truck tractor-semitrailer-full trailer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A truck tractor-semitrailer-semitrailer combination, where the semitrailers are connected by a rigid frame extension including a fifth wheel connection point attached to the rear frame of the first semitrailer. The length of the frame extension shall not be included when determining the overall length of the first semitrailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules adopted pursuant to this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall provide that combinations of vehicles authorized to operate on an economic export corridor shall meet all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The length of the combination of vehicles, excluding the length of the truck tractor, shall not exceed eighty-one and one-half feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The length of either semitrailer or full trailer shall not exceed forty-five feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The weight of the second semitrailer or full trailer shall not exceed the weight of the first semitrailer by more than three thousand pounds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The gross weight of the combination of vehicles shall not exceed eighty thousand pounds and the combination of vehicles shall not exceed the gross axle weight limits of }}}{{\f5\fs18\hyphpar0\qj{section 321.463, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The load on each semitrailer or full trailer in the combination shall be an indivisible load. For the purpose of issuing permits for height or width under }}}{{\f5\fs18\hyphpar0\qj{chapter 321E}}}{{\f5\fs18\hyphpar0\qj{, the combination of vehicles shall be considered an indivisible load so long as the load on each semitrailer or full trailer in the combination remains an indivisible load.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An economic export corridor established by the department shall not include any segment of the interstate system or any part of the national network of highways identified pursuant to }}}{{\f5\fs18\hyphpar0\qj\cf1{23 C.F.R. pt. 658}}}{{\f5\fs18\hyphpar0\qj{. This subparagraph does not prohibit operation on any segment of the interstate system or part of the national network of highways that is permitted under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fn\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffull trailer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7390.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and to the extent allowed under federal law, a combination of two vehicles coupled together, one of which is a motorsports recreational vehicle, shall not have an overall length in excess of eighty-five feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and to the extent allowed under federal law, a vehicle or combination of vehicles transporting a divisible load of hay, straw, stover, or bagged livestock bedding shall not have an overall length in excess of seventy-five feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fire fighting apparatus and vehicles operated during daylight hours when transporting poles, pipe, machinery, or other objects of a structural nature which cannot be readily disassembled when required for emergency repair of public service facilities or properties are not subject to the limitations on overall length of vehicles and combinations of vehicles imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. However, for operation during nighttime hours, these vehicles and the load being transported shall be equipped with a sufficient number of clearance lamps on both sides and marker lamps at the extreme ends of the projecting load to clearly mark the dimensions of the load. A member of the state patrol shall also be notified prior to the operation of the vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75067-d4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.457}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1056, \'a72, 3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 9, \'a76 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 116, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1077, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 186, \'a76 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1208, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 34, \'a72 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 31, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 87, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1087, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1199, \'a778}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1004, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1089, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1219, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1074, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1075, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a716, 29}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a721, 22}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 35, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a730, 31}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 143, \'a716, 35}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1090, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1127, \'a714, 15}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 46, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 23, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1054, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}{{\f5\fs12\hyphpar0\qj{, 321E.8}}}{{\f5\fs12\hyphpar0\qj{, 321E.9}}}{{\f5\fs12\hyphpar0\qj{, 321E.10}}}{{\f5\fs12\hyphpar0\qj{, 321E.11}}}{{\f5\fs12\hyphpar0\qj{, 321E.17}}}{{\f5\fs12\hyphpar0\qj{, 321E.26}}}{{\f5\fs12\hyphpar0\qj{, 321E.29B}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph c }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.458}}}{\*\bkmkstart stylerid1_2E52_30_2E2_2E2}{\*\bkmkend stylerid1_2E52_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Loading beyond front.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The load upon any vehicle operated alone, or the load upon the front vehicle of a combination of vehicles, shall not extend more than three feet beyond the front wheels of such vehicle or the front bumper of such vehicle if it is equipped with such a bumper.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.458}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph c }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.459}}}{\*\bkmkstart stylerid1_2E521_2E2_2E2}{\*\bkmkend stylerid1_2E521_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dual axle requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Axles of a motor vehicle, trailer, or semitrailer which are less than forty inches apart center to center shall be considered as a single axle for the purpose of determining permissible gross weight under }{{\f5\fs18\hyphpar0\qj{section 321.463}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75067-d3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.459}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.460}}}{\*\bkmkstart stylerid1_2E522_2E2_2E2}{\*\bkmkend stylerid1_2E522_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Spilling loads on highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A vehicle shall not be driven or moved on any highway by any person unless such vehicle is so constructed or loaded or the load securely covered as to prevent any of its load from dropping, sifting, leaking, or otherwise escaping or its load covering from dropping from the vehicle, except that sand may be dropped for the purpose of securing traction, or water or other substance may be sprinkled on a roadway in cleaning or maintaining such roadway. The provisions of }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall not apply to vehicles loaded with hay or stover or the products listed in }{{\f5\fs18\hyphpar0\qj{section 321.466, subsections 4 and 5}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.460}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(13)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 13, paragraph c }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.461}}}{\*\bkmkstart stylerid1_2E523_2E2_2E2}{\*\bkmkend stylerid1_2E523_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trailers and towed vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When one vehicle is towing another the drawbar or other connection shall not exceed fifteen feet from one vehicle to the other except the connection between any two vehicles transporting poles, pipe, machinery, or other objects of structural nature which cannot readily be dismembered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the towing vehicle is a motor truck and the towed vehicle is a single trailer with a single point of articulation at the hitch connection, the drawbar or other connection shall not exceed twenty-one feet. The length of the drawbar or other connection shall be measured from the centerline of the hitch assembly on the towing vehicle to the front of the body of the towed vehicle. A vehicle which has a drawbar or other connection which measures between fifteen and twenty-one feet in length shall have at least one yellow reflector visible on each vertical face of the drawbar or other connection, located near the midpoint between the towing and the towed vehicle. A vehicle which has a drawbar or other connection which measures between fifteen and twenty-one feet in length shall have affixed to the rear of the towed vehicle a sign indicating that the vehicle is a towed vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.461}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 31, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.462}}}{\*\bkmkstart stylerid1_2E524_2E2_2E2}{\*\bkmkend stylerid1_2E524_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Drawbars and safety chains.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When one vehicle is towing or pulling another vehicle the drawbar or other connection shall be of sufficient strength to pull all weight towed thereby and shall be fastened to the frame of the towing vehicle in such manner as to prevent sidesway, and in addition to such principal connection there shall be a safety chain which shall be so fastened as to be capable of holding the towed vehicle should the principal connection for any reason fail.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.462}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1278, \'a733}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a729}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.463}}}{\*\bkmkstart stylerid1_2E525_2E2_2E2}{\*\bkmkend stylerid1_2E525_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Maximum gross weight \u8212\'3f exceptions \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An axle may be divided into two or more parts, except that all parts in the same vertical transverse plane shall be considered as one axle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The gross weight on any one axle of a vehicle, or of a combination of vehicles, operated on the highways of this state, shall not exceed twenty thousand pounds on an axle equipped with pneumatic tires, and shall not exceed fourteen thousand pounds on an axle equipped with solid rubber tires. The gross weight on any tandem axle of a vehicle, or any combination of vehicles, shall not exceed thirty-four thousand pounds on an axle equipped with pneumatic tires. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to implements of husbandry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, indivisible loads operating under the permit requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 321E.7}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321E.8}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321E.9}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321E.29A}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{321E.29B}}}{{\f5\fs18\hyphpar0\qj{, and divisible loads operating under the permit requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321E.26}}}{{\f5\fs18\hyphpar0\qj{, shall be allowed a maximum of twenty thousand pounds per axle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the weight on any one axle of a self-propelled implement of husbandry used exclusively for the application of organic or inorganic plant food materials, agricultural limestone, or agricultural chemicals operated on the highways of this state shall not exceed twenty-five thousand pounds.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A self-propelled implement of husbandry used exclusively for the application of organic or inorganic plant food materials, agricultural limestone, or agricultural chemicals shall comply with the other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter}}}{{\f5\fs18\hyphpar0\qj{ when operated over a bridge in this state, other than any provision limiting the weight on any one axle to less than twenty-five thousand pounds. A local authority may issue a special permit, based on a statewide standard developed by the department, allowing the operation over a bridge within its jurisdiction of such a self-propelled implement of husbandry with a weight in excess of the weights allowed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the weight on any one axle of a fence-line feeder, grain cart, or tank wagon operated on the highways of this state shall not exceed twenty-four thousand pounds from February 1 through May 31 or twenty-eight thousand pounds from June 1 through January 31, provided, however, that the maximum gross vehicle weight of the fence-line feeder, grain cart, or tank wagon shall not exceed ninety-six thousand pounds.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, a tracked implement of husbandry operated on the highways of this state shall not have a maximum gross weight in excess of ninety-six thousand pounds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fence-line feeder, grain cart, tank wagon, or tracked implement of husbandry shall comply with the other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and chapter when operated over a bridge in this state. A local authority may issue a special permit, based on a statewide standard developed by the department, allowing the operation over a bridge within its jurisdiction of a fence-line feeder, grain cart, tank wagon, or tracked implement of husbandry with a weight in excess of the weights allowed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHighway\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a bridge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFence-line feeder, grain cart, or tank wagon\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any fence-line feeder, grain cart, or tank wagon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of law to the contrary, a motor vehicle equipped with an engine fueled primarily by natural gas may exceed any applicable maximum gross weight limit under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, up to a maximum gross weight of eighty-two thousand pounds, by an amount equal to the difference between the weight of the vehicle attributable to the natural gas tank and fueling system installed in the vehicle and the weight of a comparable diesel fuel tank and fueling system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of law to the contrary, a motor vehicle described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ equipped with an auxiliary power or idle reduction technology unit that reduces fuel use and emissions during engine idling may exceed any applicable maximum gross weight limit under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ by five hundred fifty pounds or the weight of the auxiliary power or idle reduction technology unit, whichever is less. This paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply unless the operator of the vehicle provides to the department of public safety a written certification of the weight of the auxiliary power or idle reduction technology unit, demonstrates or certifies to the department of public safety that the idle reduction technology unit is fully functional at all times, and carries with the operator the written certification of the weight of the auxiliary power or idle reduction technology unit in the vehicle at all times to present to law enforcement in the event the vehicle is suspected of violating any applicable weight restrictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum gross weight allowed to be carried on a vehicle or combination of vehicles on highways which are part of the primary road system is as follows:}}}\par}{}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qc\fi0\ri0\li0{\f5\fs16\hyphpar0\qc}{MAXIMUM GROSS WEIGHT TABLE \u8212\'3f PRIMARY HIGHWAYS}{\f5\fs16\hyphpar0\qc}\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0{Distance}\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0{{\f5\fs16\hyphpar0\qj{\~\~}}}{in feet}{{\f5\fs16\hyphpar0\qj{\~\~\~\~\~\~}}}{2 Axles}{{\f5\fs16\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~}}}{3 Axles}{{\f5\fs16\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{4 Axles}{{\f5\fs16\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{5 Axles}{{\f5\fs16\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{6 Axles}{\f5\fs16\hyphpar0\qj}{7 Axles}\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0{\f5\fs16\hyphpar0\qj}\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0{{\f5\fs16\hyphpar0\qj{\~\~}}}{{\f5\fs16\hyphpar0\qj{\~\~}}}{4}{{\f5\fs16\hyphpar0\qj{\~\~\~\~\~\~}}}{34,000}\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0{{\f5\fs16\hyphpar0\qj{\~\~}}}{{\f5\fs16\hyphpar0\qj{\~\~}}}{5}{{\f5\fs16\hyphpar0\qj{\~\~\~\~\~\~}}}{34,000}\par}{\pard\plain\keep\keepn\f5\fs16\hyphpar0\qj\fi0\ri0\li0\sa0\par}{\pard\plain\keep\ke