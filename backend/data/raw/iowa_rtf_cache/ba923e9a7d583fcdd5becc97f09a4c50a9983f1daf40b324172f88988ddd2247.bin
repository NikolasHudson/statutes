i0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is a veteran who has filed for a military tax exemption on property in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is registered to vote in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person enrolls the person\u8217\'3fs child to be educated in a public elementary or secondary school in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is receiving public assistance from this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person resides or has continuously remained in this state for a period exceeding thirty days except for infrequent or brief absences.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has accepted employment or engages in any trade, profession, or occupation within this state, except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.55}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of issuing commercial learner\u8217\'3fs permits and commercial driver\u8217\'3fs licenses under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, there is a rebuttable presumption that a natural person is a resident of this state if all of the following conditions exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is enrolled in a commercial driver\u8217\'3fs license training program administered by an Iowa-based motor carrier, or its subsidiary, designated by the department as a third-party tester pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.187}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is in the process of applying for a commercial learner\u8217\'3fs permit for the purpose of completing the training program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is residing in this state for the duration of the training program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply if such application results in noncompliance with }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 384}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include either of the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is attending a college or university in this state, if the person has a domicile in another state and has a valid driver\u8217\'3fs license issued by the state of domicile. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the armed forces who is stationed in Iowa, provided that the member\u8217\'3fs vehicles are properly registered in the member\u8217\'3fs state of residency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation, association, partnership, company, firm, or other aggregation of individuals whose principal place of business is located within this state is a resident of this state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 125, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a788}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a782}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.182}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.2}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administration and enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided by law, the state department of transportation shall administer and enforce the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The division of state patrol of the department of public safety shall enforce the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ relating to traffic on the public highways of the state, including those relating to the safe and legal operation of passenger cars, motorcycles, motor trucks, buses, and other commercial motor vehicles, and to see that proper safety rules are observed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state department of transportation and the department of public safety shall cooperate to ensure the proper and adequate enforcement of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of revenue shall administer and enforce the collection of the fee for new registration as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.105A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74863; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1074, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 35, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 85, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a783}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.3}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and duties of director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director is hereby vested with the power and is charged with the duty of observing, administering, and enforcing the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.4}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commissioner of public safety is authorized to adopt and promulgate administrative rules governing procedures as may be necessary to carry out the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{; and to carry out any other laws the enforcement of which is vested in the department of public safety.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75004; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.5}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty to obey.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All local officials charged with the administration and enforcement of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be governed in their official acts by the rules promulgated by the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75005; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.5}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.6}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reciprocal enforcement \u8212\'3f patrol beats.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{There shall be reciprocal cooperation between the members of the department, the state department of public safety and local authorities in the enforcing of local and state traffic laws and in making inspections, although }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall not be construed to give the state department of public safety any right to establish regular patrol beats inside municipal limits unless requested for a special occasion or emergency by the mayor of such city or the sheriff of the county.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75017; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1023, \'a7157}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.7}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Seal of department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may adopt an official seal.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.8}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Director to prescribe forms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall prescribe and provide suitable forms of applications, registration cards, certificates of title and all other forms requisite or deemed necessary to carry out the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and any other laws, the enforcement and administration of which are vested in the department except manufacturer\u8217\'3fs or importer\u8217\'3fs certificates. Manufacturer\u8217\'3fs and importer\u8217\'3fs certificates shall be provided by the manufacturer or importer and be in the form prescribed by the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 41, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.9}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority to administer oaths and acknowledge signatures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Officers and employees of the department designated by the director, county officials authorized under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to issue motor vehicle registrations and titles, and county officials authorized under }{{\f5\fs18\hyphpar0\qj{chapter 321M}}}{ to issue driver\u8217\'3fs licenses are authorized, for the purpose of administering the motor vehicle laws, to administer oaths and acknowledge signatures, and shall do so without fee.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 8, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.10}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certified copies of records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director and officers of the department designated by the director are authorized to prepare under the seal of the department and provide upon request a certified copy of any record of the department, charging a fee of fifty cents for each document so authenticated, and every such certified copy shall be admissible in any proceeding in any court in like manner as the original and shall be considered to be true and accurate unless shown otherwise by an objecting party. The seal of the department may be applied electronically on certified copies of records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any records or certified copies of records prepared pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and any certified abstract, or a copy of a certified abstract, of the operating record of a driver or a motor vehicle owner prepared pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 321A}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{ shall be received in evidence if determined to be relevant, in any court, preliminary hearing, grand jury proceeding, civil proceeding, administrative hearing, or forfeiture proceeding in the same manner and with the same force and effect as if the director or the director\u8217\'3fs designee had testified in person.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1075, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1010, \'a787}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1018, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.11}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records of department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All records of the department, other than those made confidential or not permitted to be open in accordance with 18 U.S.C. \'a72721 et seq., adopted as of a specific date by rule of the department, shall be open to public inspection during office hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, personal information shall not be disclosed to a requester, except as provided in 18 U.S.C. \'a72721, unless the person whose personal information is requested has provided express written consent allowing disclosure of the person\u8217\'3fs personal information. As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpersonal information\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means information that identifies a person, including a person\u8217\'3fs photograph, social security number, driver\u8217\'3fs license number, name, address, telephone number, and medical or disability information, but does not include information on vehicular accidents, driving violations, and driver\u8217\'3fs status or a person\u8217\'3fs zip code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the department shall not release personal information to a person, other than to an officer or employee of a law enforcement agency, an employee of a federal or state agency or political subdivision in the performance of the employee\u8217\'3fs official duties, a contract employee of the department of inspections, appeals, and licensing in the conduct of an investigation, or a licensed private investigation agency or a licensed security service or a licensed employee of either, if the information is requested by the presentation of a registration plate number. In addition, an officer or employee of a law enforcement agency may release the name, address, and telephone number of a motor vehicle registrant to a person requesting the information by the presentation of a registration plate number if the officer or employee of the law enforcement agency believes that the release of the information is necessary in the performance of the officer\u8217\'3fs or employee\u8217\'3fs duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not release personal information that is in the form of a person\u8217\'3fs photograph or digital image or a digital reproduction of a person\u8217\'3fs photograph to a person other than an officer or employee of a law enforcement agency, an employee of a federal or state agency or political subdivision in the performance of the employee\u8217\'3fs official duties, a contract employee of the department of inspections, appeals, and licensing in the conduct of an investigation, or a licensed private investigation agency or a licensed security service or a licensed employee of either, regardless of whether a person has provided express written consent to disclosure of the information. The department may collect reasonable fees for copies of records or other services provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 22.3}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.10}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{622.46}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1102, \'a71, 3}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1035, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 198, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1133, \'a72, 18}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 90, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71964}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.11A}}}{{\f5\fs12\hyphpar0\qj{, 321.183}}}{{\f5\fs12\hyphpar0\qj{, 321A.3}}}{{\f5\fs12\hyphpar0\qj{, 692.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.11A}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Personal information disclosure \u8212\'3f exception.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 321.11}}}{{\f5\fs18\hyphpar0\qj{, the department, upon request, shall provide personal information that identifies a person by the social security number of the person to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of revenue for the purposes of collecting debt and administering the setoff program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 421.65}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The judicial branch for the purpose of collecting court debt pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The social security number obtained by the department of revenue or the judicial branch shall retain its confidentiality and shall only be used for the purposes provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1172, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1064, \'a713, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a773, 74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.12}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Destruction of records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may destroy any records of the department which have been maintained on file for three years and which the director deems obsolete and of no further service in carrying out the powers and duties of the department, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating records relating to a person who has been issued a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit shall be maintained on file in accordance with rules adopted by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following records may be destroyed according to the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records concerning suspensions authorized under }}}{{\f5\fs18\hyphpar0\qj{section 321.210, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (7), and }}}{{\f5\fs18\hyphpar0\qj{section 321.210A}}}{{\f5\fs18\hyphpar0\qj{ may be destroyed six months after the suspension is terminated and the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.191}}}{{\f5\fs18\hyphpar0\qj{ have been satisfied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records concerning suspensions and surrender of licenses or registrations required under }}}{{\f5\fs18\hyphpar0\qj{section 321A.31}}}{{\f5\fs18\hyphpar0\qj{ for failing to maintain proof of financial responsibility, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321A.1}}}{{\f5\fs18\hyphpar0\qj{, may be destroyed six months after the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 321.191}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321A.29}}}{{\f5\fs18\hyphpar0\qj{ have been satisfied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall not destroy any operating records pertaining to arrests or convictions for operating while intoxicated, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or operating records pertaining to revocations for violations of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2A}}}{{\f5\fs18\hyphpar0\qj{, except that a conviction or revocation under }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{ that is not subject to }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 383}}}{{\f5\fs18\hyphpar0\qj{ shall be deleted from the operating records twelve years after the date of conviction or the effective date of revocation. Convictions or revocations that are retained in the operating records for more than twelve years under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be considered only for purposes of disqualification actions under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt.}}}{{\f5\fs18\hyphpar0\qj\cf1{\~\~}}}{{\f5\fs18\hyphpar0\qj\cf1{383}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1164, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 55, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a71, 37}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7169}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a7176}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a7102}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.13}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority to grant or refuse applications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall examine and determine the genuineness, regularity, and legality of every application made to the department, and may investigate or require additional information. The department may reject any application if not satisfied of the genuineness, regularity, or legality of the application or the truth of any statement made within the application, or for any other reason, when authorized by law. The department may retain possession of any record or document until the investigation of the application is completed if it appears that the record or document is fictitious or unlawfully or erroneously issued and shall not return the record or document if it is determined to be fictitious or unlawfully or erroneously issued.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 118, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.14}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Seizure of documents and plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department is authorized to take possession of any registration card, certificate of title, permit, or registration plate, certificate of inspection or any inspection document or form, upon expiration, revocation, cancellation, or suspension thereof, or which is fictitious, or which has been unlawfully or erroneously issued.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1032, \'a752}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.15}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Publication of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall issue, in pamphlet or electronic form, such parts of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ together with such rules, instructions, and explanatory matter as may seem advisable. Such information shall be distributed as determined by the department and shall be furnished to each county treasurer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75018; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.15;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.15}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1013, \'a72, 35}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.1A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.16}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Giving of notices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the department is authorized or required to give notice under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or any other law regulating the operation of vehicles, unless a different method of giving notice is expressly prescribed, notice shall be given either by personal delivery to the person to be so notified or by personal service in the manner of original notice by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.305(1)}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, or by first class mail addressed to the person at the address shown in the records of the department, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. The department shall adopt rules regarding the giving of notice by first class mail, the updating of addresses in department records, and the development of affidavits verifying the mailing of notices under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 321J}}}{{\f5\fs18\hyphpar0\qj{. A person\u8217\'3fs refusal to accept or a claim of failure to receive a notice of revocation, suspension, or bar mailed by first class mail to the person\u8217\'3fs last known address shall not be a defense to a charge of driving while suspended, revoked, denied, or barred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proof of the giving of notice by personal service may be made by the certificate of any officer or employee of the department or affidavit of any person over eighteen years of age, naming the person to whom such notice was given and specifying the time, place, and manner of the giving thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a peace officer serves notice of immediate suspension or revocation of a driver\u8217\'3fs license as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or any other chapter, the peace officer may destroy the license or send the license to the department.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5000.16;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.16}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 121, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 32, \'a741}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 143, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.211A}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E25_2E1_2E1}{REGISTRATION, CERTIFICATE OF TITLE,}{\*\bkmkend stylerid1_2E25_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{AND PROOF OF SECURITY AGAINST}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{FINANCIAL LIABILITY}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.17}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Misdemeanor to violate registration provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 2}}}{, for any person to drive or move or for an owner knowingly to permit to be driven or moved upon the highway a vehicle of a type required to be registered under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ which is not registered, or for which the appropriate fees have not been paid, except as provided in }{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 3}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75085; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1152, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a749, 59}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a732}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(a)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.18}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vehicles subject to registration \u8212\'3f exception.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every motor vehicle, trailer, and semitrailer when driven or moved upon a highway shall be subject to the registration provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ except:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any such vehicle driven or moved upon a highway in conformance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ relating to manufacturers, transporters, dealers, or nonresidents as contemplated by }}}{{\f5\fs18\hyphpar0\qj{section 321.53}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{, or under a temporary registration permit issued by the department as hereinafter authorized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any such vehicle which is driven or moved upon a highway only for the purpose of crossing such highway from one property to another.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any implement of husbandry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any special mobile equipment as defined in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any vehicle which is used exclusively for interplant purposes, in the operation of an industrial or manufacturing plant, consisting of a single unit comprising a group of buildings separated by streets, alleys, or railroad tracks, and which vehicle is used solely to transport materials from one part of the plant to another or from an adjacent railroad track to the plant and in so doing incidentally using said streets or alleys for not more than one thousand feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any vehicle which is propelled by electric power obtained from overhead trolley wires, but not operated upon rails.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any school bus in this state used exclusively for the transportation of pupils to and from school or a school function or for the purposes provided in }}}{{\f5\fs18\hyphpar0\qj{section 285.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 285.10, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, or used exclusively for the transportation of children enrolled in a federal head start program. Upon application the department shall, without charge, issue a registration certificate and registration plates. The plates shall be attached to the front and rear of each bus exempt from registration under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any mobile home or manufactured home and any temporary undercarriage used solely for transporting manufactured homes, modular homes, or other portable buildings used or intended to be used for human occupancy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any trailer that is used exclusively for the transportation, display, and distribution of flags honoring deceased veterans in parades or ceremonies held on Memorial Day, Veterans Day, or other patriotic occasions as authorized by resolution of the local government of the community where the parade or ceremony takes place. A trailer exempt from registration under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall only be used on city streets or secondary roads on the day of a parade or ceremony specified in the local government\u8217\'3fs resolution, and a copy of the resolution shall be carried at all times in the vehicle pulling the trailer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74864; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.18}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a74}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 118, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 131, \'a71, 6}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a765, 142}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a768}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.20B}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 423.1}}}{{\f5\fs12\hyphpar0\qj{, 423B.2}}}{{\f5\fs12\hyphpar0\qj{, 452A.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.18A}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records of implements of husbandry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person selling at retail new implements of husbandry with a retail list price in excess of five thousand dollars upon which the manufacturer has affixed a vehicle identification number, shall maintain for ten years a record of the number, the name and address of the purchaser, and the date of sale.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 97, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.19}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemptions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ distinguishing plates }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ definitions of urban transit company and regional transit system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following vehicles are exempted from the payment of the registration fees imposed by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, except as provided for urban transit companies in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, but are not exempt from the penalties provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All vehicles owned or leased for a period of sixty days or more by the government and used in the transaction of official business by the representatives of foreign governments or by officers, boards, or departments of the government of the United States, and by the state, counties, municipalities and other political subdivisions of the state including vehicles used by an urban transit company operated by a municipality or a regional transit system, and self-propelling vehicles used neither for the conveyance of persons for hire, pleasure, or business nor for the transportation of freight other than those used by an urban transit company operated by a municipality or a regional transit system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All fire trucks, providing they are not owned and operated for a pecuniary profit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorized emergency vehicles used only in disaster relief owned and operated by an organization not operated for pecuniary profit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall furnish, on application, free of charge, distinguishing plates for vehicles thus exempted, which plates except plates on state patrol vehicles shall bear the word \u8220\'3fofficial\u8221\'3f and the department shall keep a separate record.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration plates issued for state patrol vehicles, except unmarked patrol vehicles, shall bear two red stars on a yellow background, one before and one following the registration number on the plate, which registration number shall be the officer\u8217\'3fs badge number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration plates issued for county sheriff\u8217\'3fs patrol vehicles shall display one seven-pointed gold star followed by the letter \u8220\'3fS\u8221\'3f and the call number of the vehicle. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, the director of the department of administrative services or the director of transportation may order the issuance of regular registration plates for any exempted vehicle used by any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Peace officers or federal law enforcement officers in the enforcement of the law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons enforcing }}}{{\f5\fs18\hyphpar0\qj{chapter 124}}}{{\f5\fs18\hyphpar0\qj{ and other laws relating to controlled substances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons in the department of justice, disease investigators of the department of health and human services, the department of inspections, appeals, and licensing, and the department of revenue, who are regularly assigned to conduct investigations which cannot reasonably be conducted with a vehicle displaying \u8220\'3fofficial\u8221\'3f state registration plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons who are federal agents or officers regularly assigned to conduct investigations which cannot reasonably be conducted with a vehicle displaying \u8220\'3fofficial\u8221\'3f registration plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons in the Iowa lottery authority whose regularly assigned duties relating to security or the carrying of lottery tickets cannot reasonably be conducted with a vehicle displaying \u8220\'3fofficial\u8221\'3f registration plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons in the economic development authority who are regularly assigned duties relating to existing industry expansion or business attraction, and mental health professionals or health care professionals who provide off-site or in-home medical or mental health services to clients of publicly funded programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of sale of exempted vehicles, the exempted governmental body, upon the sale of the exempted vehicle, may issue for in-transit purposes a pasteboard card bearing the words \u8220\'3fVehicle in Transit\u8221\'3f, the name of the official body from which the vehicle was purchased, together with the date of the purchase plainly marked in at least one-inch letters, and other information required by the department. The in-transit card is valid for use only within forty-eight hours after the purchase date as indicated on the bill of sale which shall be carried by the driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUrban transit company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person, firm, corporation, company, or municipality which operates buses or trolley cars or both, primarily upon the streets of cities over well-defined routes between certain termini, for the transportation of passengers for a uniform fare, and which accepts for passengers all who present themselves for transportation without discrimination up to the limit of the capacity of each vehicle. Included are street railways, plants, equipment, property, and rights, used and useful in the transportation of passengers. Motor carriers and interurbans subject to the jurisdiction of the state department of transportation, and taxicabs, are not included.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall furnish distinguishing plates for vehicles used by urban transit companies operated by a municipality. No other provision of law providing for the payment of taxes, registration, or license fees for vehicles shall be applicable to any bus, car, or vehicle for the transportation of passengers owned and operated by any urban transit company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Chapter 326}}}{{\f5\fs18\hyphpar0\qj{ is not applicable to urban transit companies or systems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRegional transit system\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a public transit system serving one county or all or part of a multicounty area whose boundaries correspond to the same boundaries as those of the regional planning areas designated by the governor, except as agreed upon by the department. Privately chartered bus services and uses other than providing services that are open and public on a shared ride basis shall not be construed to be a regional transit system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each county board of supervisors within the region is responsible for determining the service and funding within its county. However, the administration and overhead support services for the overall regional transit system shall be consolidated into one existing or new agency to be mutually agreed upon by the participating members. }}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74867, 4922; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.03;}}}{ C46, 50, 54, 58, 62, \'a7321.19; C66, 71, 73, \'a7321.19, 386C.1 \u8211\'3f 386C.3; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 40, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1253, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 67, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 115, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1042, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1244, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1034, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1066, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1211, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 158, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1028, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1074, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 141, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7244}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a7109, 121}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7142}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 35, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1022, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a797}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71056, 1965, 2460}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.362}}}{{\f5\fs12\hyphpar0\qj{, 321.39}}}{{\f5\fs12\hyphpar0\qj{, 321.166}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 721.8}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Plates, see }{{\f5\fs12\hyphpar0\qj{\'a7321.22}}}{, }{{\f5\fs12\hyphpar0\qj{321.170}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.20}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application for registration and certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, an owner of a vehicle, or a lessor of a vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 321F}}}{{\f5\fs18\hyphpar0\qj{ which has a gross vehicle weight of less than ten thousand pounds, which is subject to registration, shall make application to any county treasurer for the initial registration and issuance of a certificate of title for the vehicle upon the appropriate form furnished by the department. However, upon the transfer of ownership, the owner of a vehicle subject to the apportioned registration provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ shall make application for issuance of a certificate of title to either the department or any county treasurer. The owner of a vehicle purchased pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 578A.7}}}{{\f5\fs18\hyphpar0\qj{ shall present documentation that such sale was completed in compliance with that section. The application shall be accompanied by a fee of thirty dollars, and shall bear the owner\u8217\'3fs signature. A nonresident owner of two or more vehicles subject to registration may make application for initial registration and issuance of a certificate of title for all vehicles subject to registration to any county treasurer. The owner of a mobile home or manufactured home shall make application for a certificate of title under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ from the county treasurer of the county where the mobile home or manufactured home is located. The application shall contain:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The full legal name; social security number or Iowa driver\u8217\'3fs license number or Iowa nonoperator\u8217\'3fs identification card number; date of birth; bona fide residence; and mailing address of the owner and of the lessee if the vehicle is being leased. If the owner or lessee is a firm, association, or corporation, the application shall contain the bona fide business address and federal employer identification number of the owner or lessee. Up to three owners\u8217\'3f names may be listed on the application. If the vehicle is a leased vehicle, the application shall state whether the notice of registration renewal shall be sent to the lessor or to the lessee and whether the lessor or the lessee shall receive the refund of the annual registration fee, if any. Information relating to the lessee of a vehicle shall not be required on an application for registration and a certificate of title for a vehicle with a gross vehicle weight rating of ten thousand pounds or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the vehicle including, insofar as the specified data may exist with respect to a given vehicle, the make, model, type of body, the number of cylinders, the type of motor fuel used, the vehicle identification number or other assigned number, and whether new or used and, if a new vehicle, the date of sale by the manufacturer or dealer to the person intending to operate the vehicle. If the vehicle is a new low-speed vehicle, the manufacturer\u8217\'3fs or importer\u8217\'3fs certificate required to accompany the application under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall certify that the vehicle was manufactured in compliance with the national highway traffic safety administration standards for low-speed vehicles in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7571.500}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such further information as may reasonably be required by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement of the applicant\u8217\'3fs title and of all liens or encumbrances upon the vehicle and the names and mailing addresses of all persons having any interest in the vehicle and the nature of every such interest. When the application refers to a new vehicle, it shall be accompanied by a manufacturer\u8217\'3fs or importer\u8217\'3fs certificate duly assigned as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.45}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of the fee for new registration to be paid under }}}{{\f5\fs18\hyphpar0\qj{section 321.105A}}}{{\f5\fs18\hyphpar0\qj{, the amount of tax to be paid under }}}{{\f5\fs18\hyphpar0\qj{section 423.26, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or the amount of tax to be paid under }}}{{\f5\fs18\hyphpar0\qj{section 423.26A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle is owned by a nonresident but is subject to issuance of an Iowa certificate of title or registration, the application shall also contain the full legal name, Iowa driver\u8217\'3fs license number or Iowa nonoperator\u8217\'3fs identification card number, date of birth, bona fide residence, and mailing address of the primary user of the vehicle. If the primary user is a firm, association, or corporation, the application shall contain the bona fide business address and federal employer identification number of the primary user. The primary user\u8217\'3fs name and address shall not be printed on the registration receipt or the certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding contrary provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ regarding titling and registration by means other than electronic means, the department shall develop and implement a program to allow for electronic applications, titling, initial registrations, and funds transfers for vehicles subject to registration in order to improve the efficiency and timeliness of the processes and to reduce costs for all parties involved. The program shall also provide for the electronic submission of any statement required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, except where prohibited by federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including rules relating to the method for providing signatures for applications and statements required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ that are made by electronic means.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, SS15, \'a71571-m2; C24, 27, 31, 35, \'a74869, 5008, 5009; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.20}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a75}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 46, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 108, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 194, \'a71, 12}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 8, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1005, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a739 \u8211\'3f 41, 47}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1134, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2003 Acts, 1st Ex, ch 2, \'a7163, 205}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a73, 35}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 34, \'a73, 26}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1018, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a713, 21, 50, 51}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1108, \'a73, 15}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1083, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1095, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 50, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a71, 2, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.29}}}{{\f5\fs12\hyphpar0\qj{, 321.47}}}{{\f5\fs12\hyphpar0\qj{, 321.50}}}{{\f5\fs12\hyphpar0\qj{, 321.52A}}}{{\f5\fs12\hyphpar0\qj{, 321.109}}}{{\f5\fs12\hyphpar0\qj{, 321.126}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 435.27}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Surcharge imposed; }{{\f5\fs12\hyphpar0\qj{\'a7321.52A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.20A}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate of title and registration fees }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ commercial vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the owner of a commercial vehicle subject to the apportioned registration provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ may make application to the department or any county treasurer for a certificate of title. The owner of a commercial vehicle purchased pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 578A.7}}}{{\f5\fs18\hyphpar0\qj{ shall present documentation that such sale was completed in compliance with that section. The application for certificate of title shall be made within thirty days of purchase or transfer and shall be accompanied by a thirty-dollar title fee and the appropriate fee for new registration. The department or the county treasurer shall deliver the certificate of title to the owner if there is no security interest. If there is a security interest, the title, when issued, shall be delivered to the first secured party. Delivery may be made using electronic means.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner of more than fifty commercial vehicles subject to the apportioned registration provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ who is issued a certificate of title under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be subject to annual registration fees until the commercial vehicle is driven or moved upon the highways. The annual registration fee due shall be prorated for the remaining unexpired months of the registration year. Ownership of the commercial vehicle shall not be transferred until annual registration fees have been paid to the department.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 118, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1089, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a74, 35}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a714, 21, 52}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 50, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a73, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.47}}}{{\f5\fs12\hyphpar0\qj{, 321.52A}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Surcharge imposed, }{{\f5\fs12\hyphpar0\qj{\'a7321.52A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.20B}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Financial liability coverage \u8212\'3f proof required \u8212\'3f violations \u8212\'3f penalties \u8212\'3f exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 321A}}}{{\f5\fs18\hyphpar0\qj{, which requires certain persons to maintain proof of financial responsibility, a person shall not drive a motor vehicle on the highways of this state unless financial liability coverage, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 24B}}}{{\f5\fs18\hyphpar0\qj{, is in effect for the motor vehicle and unless the driver has in the motor vehicle the proof of financial liability coverage card issued for the motor vehicle, or if the vehicle is registered in another state, other evidence that financial liability coverage is in effect for the motor vehicle. A proof of financial liability coverage card may be produced in paper or electronic format. Acceptable electronic formats include electronic images displayed on a cellular telephone or any other portable electronic device that has a display screen with touch input or a miniature keyboard.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be conclusively presumed that a motor vehicle driven upon a parking lot which is available to the public without charge or which is available to customers or invitees of a business or facility without charge was driven on the highways of this state in order to enter the parking lot, and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be applicable to such a motor vehicle. As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fparking lot\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes access roads, drives, lanes, aisles, entrances, and exits to and from a parking lot described in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the operator of a motor vehicle owned by or leased to the United States, this state or another state, or any political subdivision of this state or of another state, or to a motor vehicle which is subject to }}}{{\f5\fs18\hyphpar0\qj{section 325A.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An insurance company transacting business in this state shall issue to its insured owners of motor vehicles registered in this state a financial liability coverage card for each motor vehicle insured. Each financial liability coverage card shall identify the registration number or vehicle identification number of the motor vehicle insured and shall indicate the expiration date of the applicable insurance coverage. The financial liability coverage card shall also contain the name and address of the insurer or the name of the insurer and the name and address of the insurance agency, the name of the insured, and an emergency telephone number of the insurer or emergency telephone number of the insurance agency. An insurance company may issue a financial liability coverage card in either paper format or, if requested by the insured, electronic format.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules regarding the contents of a financial liability coverage card to be issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a fleet owner who is issued a certificate of self-insurance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321A.34, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, is not required to maintain in each vehicle a financial liability coverage card with the individual registration number or the vehicle identification number of the vehicle included on the card. Such fleet owner shall be required to maintain a financial liability coverage card in each vehicle in the fleet including information deemed appropriate by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An association of individual members that is issued a certificate of self-insurance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321A.34, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, is required to maintain in each vehicle of an individual member a financial liability coverage card that complies with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and in addition contains information relating to the association and the association\u8217\'3fs certificate of self-insurance as is deemed appropriate by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the financial liability coverage for a motor vehicle which is registered in this state is canceled or terminated effective prior to the expiration date indicated on the financial liability coverage card issued for the vehicle, the person to whom the financial liability coverage card was issued shall destroy the card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a peace officer stops a motor vehicle registered in this state and the driver is unable to provide proof of financial liability coverage, the peace officer shall do one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a warning memorandum to the driver.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a citation to the driver.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a citation and remove the motor vehicle\u8217\'3fs license plates and registration receipt.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon removing the license plates and registration receipt, the peace officer shall deliver the plates for destruction, as appropriate, and forward the registration receipt and evidence of the violation, as determined by the department, to the county treasurer of the county in which the motor vehicle is registered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motor vehicle may be driven for a time period of up to forty-eight hours after receiving the citation solely for the purpose of removing the motor vehicle from the highways of this state, unless the driver\u8217\'3fs operating privileges are otherwise suspended. After receiving the citation, the driver shall keep the citation in the motor vehicle at all times while driving the motor vehicle as provided in this subparagraph, as proof of the driver\u8217\'3fs privilege to drive the motor vehicle for such limited time and purpose.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a citation, remove the motor vehicle\u8217\'3fs license plates and registration receipt, and impound the motor vehicle. The peace officer shall deliver the plates for destruction, as appropriate, and forward the registration receipt and evidence of the violation, as determined by the department, to the county treasurer of the county in which the motor vehicle is registered.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle which is impounded may be claimed by a person if the owner provides proof of financial liability coverage and proof of payment of any applicable fine and the costs of towing and storage for the motor vehicle. If the motor vehicle is not claimed within thirty days after impoundment, the motor vehicle may be treated as an abandoned vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.89}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a security interest in a motor vehicle which is impounded pursuant to this subparagraph shall be notified of the impoundment within seventy-two hours of the impoundment of the motor vehicle and shall have the right to claim the motor vehicle upon the payment of all fees. However, if the value of the vehicle is less than the security interest, all fees shall be divided equally between the lienholder and the political subdivision impounding the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner or driver of a motor vehicle who is charged with a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and issued a citation under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3) or (4), is subject to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner or driver who produces to the clerk of court, prior to the date of the individual\u8217\'3fs court appearance as indicated on the citation, proof that financial liability coverage was in effect for the motor vehicle at the time the person was stopped and cited, or, if the driver is not the owner of the motor vehicle, proof that liability coverage was in effect for the driver with respect to the motor vehicle being driven at the time the driver was stopped and cited, in the same manner as if the motor vehicle were owned by the driver, shall be given a receipt indicating that such proof was provided and be subject to one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person was cited pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), the owner or driver shall provide a copy of the receipt to the county treasurer of the county in which the motor vehicle is registered and the owner shall be assessed a fifteen dollar administrative fee by the county treasurer who shall issue new license plates and registration to the person after payment of the fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person was cited pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (4), the owner or driver, after the owner provides proof of financial liability coverage to the clerk of court, may claim the motor vehicle after such person pays any applicable fine and the costs of towing and storage for the motor vehicle, and the owner or driver provides a copy of the receipt and the owner pays to the county treasurer of the county in which the motor vehicle is registered a fifteen dollar administrative fee, and the county treasurer shall issue new license plates and registration to the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner or driver who is charged with a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and is unable to show that financial liability coverage was in effect for the motor vehicle at the time the person was stopped and cited may do either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sign an admission of violation on the citation and remit to the clerk of court a scheduled fine as provided in }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. Upon payment of the fine to the clerk of court of the county where the citation was issued, payment of a fifteen dollar administrative fee to the county treasurer of the county in which the motor vehicle is registered, and providing proof of payment of any applicable fine and proof of financial liability coverages to the county treasurer of the county in which the motor vehicle is registered, the treasurer shall issue new license plates and registration to the owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Request an appearance before the court on the matter. If the matter goes before the court, and the owner or driver is found guilty of a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the court may impose a fine as provided in }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or the court may order the person to perform unpaid community service instead of the fine. Upon the payment of the fine or the entry of the order for unpaid community service, the person shall provide proof of payment or entry of such order and the county treasurer of the county in which the motor vehicle is registered shall issue new license plates and registration to the owner upon the owner providing proof of financial liability coverage and paying a fifteen dollar administrative fee to the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner or driver cited for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, who produces to the clerk of court prior to the date of the person\u8217\'3fs court appearance as indicated on the citation proof that financial liability coverage was in effect for the motor vehicle at the time the person was stopped and cited, shall not be convicted of such violation and the citation issued shall be dismissed by the court. Upon dismissal, the court or clerk of court shall assess the costs of the action against the defendant named on the citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the motor vehicle is not registered in this state and the driver is a nonresident, the peace officer shall do one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a warning memorandum to the driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a citation. An owner or driver who produces to the clerk of court prior to the date of the person\u8217\'3fs court appearance as indicated on the citation proof that the financial liability coverage was in effect for the motor vehicle at the time the person was stopped and cited, or if the driver is not the owner of the motor vehicle, proof that liability coverage was in effect for the driver with respect to the motor vehicle being driven at the time the driver was stopped and cited in the same manner as if the motor vehicle were owned by the driver, shall be given a receipt indicating that proof was provided, and the citation issued shall be dismissed by the court. Upon dismissal, the court or clerk of court shall assess the costs of the action against the defendant named on the citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a motor vehicle identified in }}}{{\f5\fs18\hyphpar0\qj{section 321.18, subsection 1, 2, 3, 4, 5, 6, or 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a lienholder who has a security interest in a motor vehicle subject to the registration requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, so long as such lienholder maintains financial liability coverage for any motor vehicle driven or moved by the lienholder in which the lienholder has an interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a motor vehicle owned by a motor vehicle dealer or wholesaler licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of transportation and the commissioner of insurance shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 139, \'a72, 17, 18}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1100, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1121, \'a71 \u8211\'3f 4, 8, 9}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 110, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 114, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 151, \'a723 \u8211\'3f 25}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1144, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 215, \'a7105}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1031, \'a7111}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 103, \'a75, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.54}}}{{\f5\fs12\hyphpar0\qj{, 321.55}}}{{\f5\fs12\hyphpar0\qj{, 321.89}}}{{\f5\fs12\hyphpar0\qj{, 321.234A}}}{{\f5\fs12\hyphpar0\qj{, 321.515}}}{{\f5\fs12\hyphpar0\qj{, 321.516}}}{{\f5\fs12\hyphpar0\qj{, 321A.34}}}{{\f5\fs12\hyphpar0\qj{, 321K.1}}}{{\f5\fs12\hyphpar0\qj{, 321N.4}}}{{\f5\fs12\hyphpar0\qj{, 322.7B}}}{{\f5\fs12\hyphpar0\qj{, 326.25}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(f)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.21}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special mobile equipment plates.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1999/CH0013.pdf" }{\fldrslt \cf5 \f5 \fs18{{99 Acts, ch 13, \'a728, 29}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2000/CH1154.pdf" }{\fldrslt \cf5 \f5 \fs18{{2000 Acts, ch 1154, \'a746, 50}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.22}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Urban and regional transit equipment certificates and plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An urban transit company or system having a franchise to operate in any city and any regional transit system may make application to the department, upon forms furnished by the department, for a certificate containing a distinguishing number and for one or more pairs of registration plates to be attached to the front and rear of buses owned or operated by the transit company or system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall issue to the applicant a certificate, or certificates, containing but not limited to the applicant\u8217\'3fs name and address, the distinguishing number assigned to the applicant, and such other information deemed necessary by the department for proper identification of the buses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall issue registration plates to the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall issue the certificates and plates without fee.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.22}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1253, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 195, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1244, \'a742}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 130, \'a722}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.23}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Titles to specially constructed and reconstructed vehicles, street rods, replica vehicles, and foreign vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle to be registered is a specially constructed vehicle, reconstructed vehicle, street rod, replica vehicle, or foreign vehicle, such fact shall be stated in the application. A fee of thirty dollars shall be paid by the person making the application upon issuance of a certificate of title by any county treasurer. For a specially constructed vehicle, reconstructed vehicle, street rod, or replica vehicle subject to registration, the application shall be accompanied by a statement from the department authorizing the motor vehicle to be titled and registered in this state. The owner of a specially constructed vehicle, reconstructed vehicle, street rod, replica vehicle, or foreign vehicle purchased pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 578A.7}}}{{\f5\fs18\hyphpar0\qj{ shall present documentation that such sale was completed in compliance with that section.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall cause a physical inspection to be made of all specially constructed vehicles, reconstructed vehicles, street rods, and replica vehicles upon application for a certificate of title by the owner, to determine whether the motor vehicle complies with the definition of specially constructed vehicle, reconstructed vehicle, street rod, or replica vehicle in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and to determine that the integral component parts are properly identified and that the rightful ownership is established before issuing the owner the authority to have the motor vehicle registered and titled. The purpose of the physical inspection under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not to determine whether the motor vehicle is in a condition safe to operate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a specially constructed vehicle, reconstructed vehicle, street rod, or replica vehicle shall apply for a certificate of title and registration for the vehicle at the county treasurer\u8217\'3fs office within thirty days of the inspection. For a foreign vehicle which has been registered outside this state, the owner shall surrender to the treasurer all registration plates, registration cards, and certificates of title, or if the vehicle to be registered is from a nontitle state, the evidence of foreign registration and ownership as may be prescribed by the department except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon completion of every specially constructed vehicle, reconstructed vehicle, street rod, or replica vehicle, the owner shall certify on a form prescribed by the department that such vehicle is in compliance with all equipment specifications required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where in the course of operation of a vehicle registered in another state it is desirable to retain registration of said vehicle in such other state, such applicant need not surrender but shall submit for inspection said evidence of such foreign registration and the treasurer upon a proper showing shall register said vehicle in this state but shall not issue a certificate of title for such vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event an applicant for initial registration of a foreign vehicle for which a certificate of title has been issued is able to furnish evidence of being the registered owner of the vehicle to any county treasurer, although unable to surrender such certificate of title, the county treasurer may issue a registration receipt and plates upon receipt of the required annual registration fee and the fee for new registration but shall not issue a certificate of title thereto. Upon surrender of the certificate of title from the foreign state, the county treasurer shall issue a certificate of title to the owner, or person entitled thereto, of such vehicle as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The owner of a vehicle registered under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be required to obtain a certificate of title in this state and may transfer ownership of the vehicle to a motor vehicle dealer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ or an insurance carrier authorized to do business in this state if, at the time of the transfer, the certificate of title is held by a secured party and the dealer or insurance carrier, as applicable, has forwarded to the secured party the sum necessary to discharge the security interest pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.48, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle which does not meet the equipment requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ due to the particular use for which it is designed or intended, may be registered by the department upon payment of appropriate fees and after inspection and certification by the department that the vehicle is not in an unsafe condition. A person is not required to have a certificate of title to register a vehicle under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. If the owner elects to have a certificate of title issued for the vehicle, a fee of thirty dollars shall be paid by the person making the application upon issuance of a certificate of title. If the department\u8217\'3fs inspection reveals that the vehicle may be safely operated only under certain conditions or on certain types of roadways, the department may restrict the registration to limit operation of the vehicle to the appropriate conditions or roadways. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to snowmobiles as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321G.1}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{Section 321.382}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a vehicle registered under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ which is operated exclusively by a person with a disability who has obtained a persons with disabilities parking permit as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321L.2}}}{{\f5\fs18\hyphpar0\qj{, if the persons with disabilities parking permit is carried in or on the vehicle and shown to a peace officer on request.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.23}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 9, \'a74, 8}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1158, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 247, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1171, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 70, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1044, \'a75, 8}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a715, 21, 53}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a7127}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[A change in fee amount in subsection 1, paragraph a, by }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a715}}}{, inadvertently overwritten and omitted beginning with the 2009 Code Supplement through Code 2023]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 50, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1027, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a74, 5, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.30}}}{{\f5\fs12\hyphpar0\qj{, 321.47}}}{{\f5\fs12\hyphpar0\qj{, 321.52A}}}{{\f5\fs12\hyphpar0\qj{, 321.67}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Surcharge imposed; }{{\f5\fs12\hyphpar0\qj{\'a7321.52A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.23A}}}{\*\bkmkstart stylerid1_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Affidavit of correction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When information is printed incorrectly on a certificate of title, application for certificate of title, damage disclosure statement, or other document required for a title transfer or when these documents contain an alteration or erasure, the county treasurer may accept a notarized affidavit of correction. }{{\f5\fs18\hyphpar0\qj{This section}}}{ does not apply to an odometer certification statement. The department shall consult with a representative of the Iowa state county treasurer\u8217\'3fs association and shall promulgate rules and adopt a standard affidavit form or forms to administer }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1092, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.24}}}{\*\bkmkstart stylerid1_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of registration and certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of the application for title and payment of the required fees for a motor vehicle, trailer, or semitrailer, the county treasurer or the department shall, when satisfied as to the application\u8217\'3fs genuineness and regularity, and, in the case of a mobile home or manufactured home, that taxes are not owing under }}}{{\f5\fs18\hyphpar0\qj{chapter 423}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{435}}}{{\f5\fs18\hyphpar0\qj{, issue a certificate of title and, except for a mobile home or manufactured home, a registration receipt, and shall file the application, the manufacturer\u8217\'3fs or importer\u8217\'3fs certificate, the certificate of title, or other evidence of ownership, as prescribed by the department. The registration receipt shall be delivered to the owner and shall contain upon its face the date issued, the name and address of the owner, the registration number assigned to the vehicle, the amount of the fee paid, the type of fuel used, a description of the vehicle as determined by the department, and a form for notice of transfer of the vehicle. The name and address of any lessee of the vehicle shall not be printed on the registration receipt or certificate of title. Up to three owners may be listed on the registration receipt and certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer shall maintain in the county record system information contained on the registration receipt. The information shall be accessible by registration number and shall be open for public inspection during reasonable business hours. Copies the department requires shall be sent to the department in the manner and at the time the department directs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate of title must contain upon its face the identical information required upon the face of the registration receipt. In addition, the certificate of title must contain a statement of the owner\u8217\'3fs title, the title number assigned to the owner or owners of the vehicle, and a statement of all security interests and encumbrances as shown in the application, upon the vehicle described, including the nature of the security interest, date of perfection, and name and mailing address of the secured party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the prior certificate of title is from another state and indicates that the vehicle was rebuilt, the new certificate of title and registration receipt shall contain the designation \u8220\'3fREBUILT\u8221\'3f printed on its face together with the name of the state issuing the prior title. The designation shall be retained on the face of all subsequent certificates of title and registration receipts for the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the prior certificate of title is from another state and indicates that the vehicle was junked, an Iowa junking certificate shall be issued according to }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{. If the prior certificate of title from another state indicates that the vehicle is salvaged and not rebuilt or is a salvage certificate of title, an Iowa salvage certificate of title shall be issued and a \u8220\'3fSALVAGE\u8221\'3f designation shall be retained on all subsequent Iowa certificates of title and registration receipts for the vehicle, unless the owner has surrendered the prior certificate of title and a salvage theft examination certificate, as provided under }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and the salvage theft examination certificate was properly executed within thirty days of the date the owner was assigned the prior certificate of title. The department may require that subsequent Iowa certificates of title retain other states\u8217\'3f designations which indicate that a vehicle had incurred prior damage. The department shall determine the manner in which other states\u8217\'3f rebuilt, salvage, or other designations are to be indicated on Iowa titles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the prior certificate of title is from another state and indicates that the vehicle was returned to the manufacturer pursuant to a law of another state similar to }}}{{\f5\fs18\hyphpar0\qj{chapter 322G}}}{{\f5\fs18\hyphpar0\qj{, the new registration receipt and certificate of title, and all subsequent registration receipts and certificates of title issued for the vehicle, shall contain a designation indicating the vehicle was returned to the manufacturer. The department shall determine the manner in which other states\u8217\'3f designations are to be indicated on Iowa registration receipts and certificates of title. The department may determine that a \u8220\'3fREBUILT\u8221\'3f or \u8220\'3fSALVAGE\u8221\'3f designation supersedes the designation required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and include the \u8220\'3fREBUILT\u8221\'3f or \u8220\'3fSALVAGE\u8221\'3f designation on the registration receipt and certificate of title in lieu of the designation required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate shall contain the name of the county treasurer or of the department and, if the certificate of title is printed, the signature of the county treasurer, the deputy county treasurer, or the department director or deputy designee. The certificate of title shall contain upon the reverse side a form for assignment of title or interest and warranty by the owner, for reassignments by a dealer licensed in this state or in another state if the state in which the dealer is licensed permits Iowa licensed dealers to similarly reassign certificates of title. However, titles for mobile homes or manufactured homes shall not be reassigned by licensed dealers. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 17}}}{{\f5\fs18\hyphpar0\qj{, as used in }}}{{\f5\fs18\hyphpar0\qj{this subsection,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdealer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means every person engaged in the business of buying, selling, or exchanging vehicles of a type required to be registered under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The original certificate of title shall be delivered to the owner if there is no security interest. Otherwise the certificate of title shall be delivered by the county treasurer or the department to the person holding the first security interest. Delivery may be made using electronic means.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer or the department shall maintain in the county or department records system the information contained on the certificate of title and the name and address of the previous owner. The information must be accessible by title certificate number for a period of three years from the date of notification of cancellation of title or date that a new title has been issued as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. Copies the department requires shall be sent to the department in the manner and at the time the department directs. The department shall designate a uniform system of title numbers to indicate the county of issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle shall be registered for the registration year. A vehicle registered for the first time in this state shall be registered for the remaining unexpired months of the registration year and pay an annual registration fee prorated for the remaining unexpired months of the registration year plus a fee for new registration if applicable pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.105A}}}{{\f5\fs18\hyphpar0\qj{. Except for a vehicle registered under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{, a vehicle registered for the first time during the eleventh month of the owner\u8217\'3fs registration year may be registered for the remaining unexpired months of the registration year as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or for the remaining unexpired months of the registration year and for the next registration year, upon payment of the applicable registration fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the county treasurer or department is not satisfied as to the ownership of the vehicle or that there are no undisclosed security interests in it, or if a junking certificate has been issued for the vehicle but a certificate of title will not be reissued under }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and the vehicle qualifies as an antique vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 321.115, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the county treasurer or department may register the vehicle but shall, as a condition of issuing a certificate of title and registration receipt, require the applicant to first receive approval by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines the value of the vehicle is one thousand dollars or less and the vehicle is twelve model years old or older, the department shall notify the applicant, and the department or county treasurer may issue a certificate of title and registration receipt. The applicant shall apply for a certificate of title and registration within thirty days of the department\u8217\'3fs notification of determination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines the value of the vehicle is more than one thousand dollars or the vehicle is less than twelve model years old, the applicant shall file with the department a bond in the form prescribed by the department and executed by the applicant, and either accompanied by the deposit of cash with the department or also executed by a person authorized to conduct a surety business in this state. The owner of a vehicle subject to the bond requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall apply for a certificate of title and registration for the vehicle at the county treasurer\u8217\'3fs office within thirty days of issuance of written authorization from the department. The bond shall be in an amount equal to one and one-half times the current value of the vehicle, as determined by the department, and conditioned to indemnify any prior owner and secured party and any subsequent purchaser of the vehicle or person acquiring any security interest in it, and their respective successors in interest, against any expense, loss, or damage, including reasonable attorney fees, by reason of the issuance of the certificate of title for the vehicle or on account of any defect in or undisclosed security interest upon the right, title, and interest of the applicant in and to the vehicle. Any such interested person has a right of action to recover on the bond for any breach of its conditions, but the aggregate liability of the surety to all persons shall not exceed the amount of the bond. The bond, and any deposit accompanying it, shall be returned at the end of three years or earlier if the vehicle is no longer registered in this state and the currently valid certificate of title is surrendered to the department, unless the department has been notified of the pendency of an action to recover on the bond. The department may authorize issuance of a certificate of title as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for a vehicle with an unreleased security interest upon presentation of satisfactory evidence that the security interest has been extinguished or that the holder of the security interest cannot be located to release the security interest as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.50}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement and administer }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74873; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.24}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a78}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a73, 38}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 108, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 130, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1089, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 185, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1116, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 142, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1104, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1199, \'a777}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 45, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a742, 47}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1028, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1047, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0002.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2003 Acts, 1st Ex, ch 2, \'a7164, 205}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a75, 35}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 143, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1018, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a731, 93}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1036, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1059, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.46}}}{{\f5\fs12\hyphpar0\qj{, 321.52}}}{{\f5\fs12\hyphpar0\qj{, 321.69}}}{{\f5\fs12\hyphpar0\qj{, 321.152}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(b)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Certain trailers exempt, see }{{\f5\fs12\hyphpar0\qj{\'a7321.123}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.25}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application for registration and title \u8212\'3f cards attached.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle may be operated upon the highways of this state without registration plates for a period of forty-five days after the date of delivery of the vehicle to the purchaser from a dealer if a card bearing the words \u8220\'3fregistration applied for\u8221\'3f is attached on the rear of the vehicle. The card shall have plainly stamped or stenciled the registration number of the dealer from whom the vehicle was purchased and the date of delivery of the vehicle. In addition, a dealer licensed to sell new motor vehicles may attach the card to a new motor vehicle delivered by the dealer to the purchaser even if the vehicle was purchased from an out-of-state dealer and the card shall bear the registration number of the dealer that delivered the vehicle. A dealer shall not issue a card to a person known to the dealer to be in possession of registration plates which may be attached to the vehicle. A dealer shall not issue a card unless an application for initial registration and certificate of title has been made by the purchaser and a receipt issued to the purchaser of the vehicle showing the fee paid by the person making the application. Dealers\u8217\'3f records shall indicate the agency to which the fee is sent and the date the fee is sent. The dealer shall forward the application by the purchaser to the county treasurer or state office within thirty calendar days from the date of delivery of the vehicle. However, if the vehicle is subject to a security interest and has been offered for sale pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.48, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the dealer shall forward the application by the purchaser to the county treasurer or state office within thirty calendar days from the date of the delivery of the vehicle to the purchaser.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall, upon request by any dealer, furnish \u8220\'3fregistration applied for\u8221\'3f cards free of charge. Only cards furnished by the department shall be used. Only one card shall be issued in accordance with this subsection for each vehicle purchased.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m10; C24, 27, 31, 35, \'a74880; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7321.25; C77, \'a7321.25 \u8211\'3f 321.27; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.25}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 82, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 47, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 108, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 13, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1016, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a76, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.46}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(c)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.26}}}{\*\bkmkstart stylerid1_2E39_2E2_2E2}{\*\bkmkend stylerid1_2E39_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Multiple registration periods and adjustments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There are established twelve registration periods for the registration of vehicles by the county treasurer. Each registration period shall commence on the first day of each calendar month following the month of the birth of the owner of the vehicle and end on the last day of the twelfth month.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer may adjust the registration renewal or expiration date of vehicles for which the county treasurer is responsible for renewal under }}}{{\f5\fs18\hyphpar0\qj{section 321.40}}}{{\f5\fs18\hyphpar0\qj{ when deemed necessary to equalize the number of vehicles registered in each twelve-month period or for the administrative efficiency of the county treasurer\u8217\'3fs office. The adjustment shall be accomplished by delivery of a written notice to the vehicle owner of the adjustment and allowance of a credit for the remaining months of the unused portion of the annual registration fee, rounded to the nearest whole dollar, which amount shall be deducted from the annual registration fee due at the time of registration. Upon receipt of the notification the owner shall, within thirty days, surrender the registration card and registration plates to any county treasurer, except that the registration plates shall not be surrendered if validation stickers or other emblems are used to designate the month and year of expiration of registration. Upon payment of the annual registration fee, less the credit allowed for the remaining months of the unused portion of the annual registration fee, the county treasurer that adjusted the registration renewal or expiration date of the vehicle shall issue a new registration card and registration plates, validation stickers, or emblems which indicate the month and year of expiration of registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Except for motor trucks or truck tractors registered by the county treasurer pursuant to sections }}}{{\f5\fs18\hyphpar0\qj{321.120}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.121}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{321.122}}}{{\f5\fs18\hyphpar0\qj{, vehicles subject to registration which are owned by a person other than a natural person shall be registered for a registration year as determined by the county treasurer.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a734, 38}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 24, \'a78, 12}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 103, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 38, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a77, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.27}}}{\*\bkmkstart stylerid1_2E4_30_2E2_2E2}{\*\bkmkend stylerid1_2E4_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Implementation of twelve-month registration period.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1997/CH0108.pdf" }{\fldrslt \cf5 \f5 \fs18{{97 Acts, ch 108, \'a749}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.28}}}{\*\bkmkstart stylerid1_2E41_2E2_2E2}{\*\bkmkend stylerid1_2E41_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Failure to register.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the owner of a vehicle fails to register the vehicle under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the treasurer shall withhold the registration of the vehicle for any period or periods for which it appears that registration should have been made, until the fee for the period or periods is paid.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74870; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.28}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 66, \'a769}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.101}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.29}}}{\*\bkmkstart stylerid1_2E42_2E2_2E2}{\*\bkmkend stylerid1_2E42_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Renewal not permitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any vehicle that was once registered in the state, but which was removed from and no longer subject to registration in this state, shall, upon being returned to this state and becoming again subject to registration, be initially registered again in accordance with }{{\f5\fs18\hyphpar0\qj{section 321.20}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74876; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.29}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 66, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a78, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.30}}}{\*\bkmkstart stylerid1_2E43_2E2_2E2}{\*\bkmkend stylerid1_2E43_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Grounds for refusing registration or title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department or the county treasurer shall refuse registration and issuance of a certificate of title or any transfer of title and registration upon any of the following grounds:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the application contains any false or fraudulent statement or that the applicant has failed to furnish required information or reasonable additional information requested by the department or that the applicant is not entitled to registration and issuance of a certificate of title of the vehicle under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the vehicle is mechanically unfit or unsafe to be operated or moved upon the highways, providing such condition is revealed by a member of this department, or any peace officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the department or the county treasurer has reasonable ground to believe that the vehicle is a stolen or embezzled vehicle or that the granting of registration and issuance of a certificate of title would constitute a fraud against the rightful owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the registration of the vehicle stands suspended or revoked, or the person applying for registration is prohibited from registering a motor vehicle, for any reason as provided in the motor vehicle laws of this state, except that the department and the county treasurer shall not refuse registration and issuance of a certificate of title or transfer of title as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321A.5}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321A.17}}}{{\f5\fs18\hyphpar0\qj{, or in accordance with rules adopted by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the required registration fees have not been paid except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.48}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a vehicle subject only to a certificate of title or a manufactured home, that the required use tax has not been paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If application for registration and certificate of title for a new vehicle is not accompanied by a manufacturer\u8217\'3fs or importer\u8217\'3fs certificate duly assigned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If application for a transfer of registration and issuance of a certificate of title for a used vehicle registered in this state is not accompanied by a certificate of title duly assigned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If application and supporting documents are insufficient to authorize the issuance of a certificate of title as provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, except that an initial registration or transfer of registration may be issued as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.23}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a mobile home or manufactured home, that taxes are owing under }}}{{\f5\fs18\hyphpar0\qj{chapter 435}}}{{\f5\fs18\hyphpar0\qj{ for a previous year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a mobile home or manufactured home converted from real estate, real estate taxes which are delinquent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a commercial motor vehicle has been assigned to be operated by a commercial motor carrier whose ability to operate has been terminated or denied by a federal agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant is under eighteen years of age, unless the applicant has an Iowa driver\u8217\'3fs license or the application is being made by more than one applicant and one of the applicants is at least eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided for in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the department or the county treasurer shall refuse registration and issuance of a certificate of title unless the vehicle bears a manufacturer\u8217\'3fs label pursuant to }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 567}}}{{\f5\fs18\hyphpar0\qj{ certifying that the vehicle meets federal motor vehicle safety standards.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A military vehicle, other than a vehicle that runs on continuous tracks or wheels and tracks, that was originally manufactured for and sold directly to the armed forces of the United States in conformity with contractual specifications, as provided in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7571.7}}}{{\f5\fs18\hyphpar0\qj{, may be registered and issued a certificate of title if the owner provides satisfactory evidence to the department that the vehicle is substantially in compliance with federal motor vehicle safety standards. The department may adopt rules as necessary concerning the registration and titling of military vehicles in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department or the county treasurer shall refuse registration of a vehicle if the applicant for registration of the vehicle has failed to pay the required annual registration fee or the fee for new registration of any vehicle owned or previously owned when the fee was required to be paid by the applicant, and for which vehicle the registration was suspended or revoked under }}}{{\f5\fs18\hyphpar0\qj{section 321.101, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 321.101A}}}{{\f5\fs18\hyphpar0\qj{, until the fee is paid together with any accrued penalties.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.30}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1164, \'a71}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1251, \'a79}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 98, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 108, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 55, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 194, \'a72, 12}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7245}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a710, 41}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 126, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1018, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a756, 57}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1091, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 67, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.101}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Refusal to renew, see }{{\f5\fs12\hyphpar0\qj{\'a7321.40}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.31}}}{\*\bkmkstart stylerid1_2E44_2E2_2E2}{\*\bkmkend stylerid1_2E44_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A state and county records system shall be maintained in the following manner:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E44_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E44_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{State records system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall install and maintain a records system which must contain the name and address of the vehicle owner, current and previous registration number, vehicle identification number, make, model, style, date of purchase, registration certificate number, maximum gross weight, weight, list price or value of the vehicle as fixed by the department, fees paid, date of payment, and the name and address of the previous owner. The records system must also contain a record of the certificate of title including such information as the department deems necessary. The information to be kept in the records system shall be entered within forty-eight hours after receipt insofar as is practical. The records system shall constitute the permanent record of ownership of each vehicle titled under the laws of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may make photostatic, microfilm, or other photographic copies of certificates of title, registration receipts, or other records, reports or documents which are required to be retained by the department. When copies have been made, the department may destroy the original records in such manner as prescribed by the director. The photostatic, microfilm, or other photographic copies, when no longer of use, may be destroyed in the manner prescribed by the director, subject to the approval of the state records commission. Photostatic, microfilm, or other photographic copies of records shall be admissible in evidence when duly certified and authenticated by the officer having custody and control of the copies of records. Records of vehicle certificates of title may be destroyed seven years after the date of issue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall maintain a records system of delinquent accounts owed to the state using information provided through the computerized data bank established in }}}{{\f5\fs18\hyphpar0\qj{section 421.17}}}{{\f5\fs18\hyphpar0\qj{. The department and county treasurers shall use the information maintained in the records system to determine if applicants for renewal of registration have delinquent accounts, charges, fees, loans, taxes, or other indebtedness owed to or being collected by the state as provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 421.65}}}{{\f5\fs18\hyphpar0\qj{. The director and the director of revenue shall establish procedures for updating the delinquent accounts records to add and remove accounts, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E44_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E44_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{County records system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each county treasurer\u8217\'3fs office shall maintain a county records system for vehicle registration and certificate of title documents. The records system must consist of information from the certificate of title, including the date of perfection and cancellation of security interests, information from the registration receipt, and the name and address of the previous owner. The information shall be maintained in a manner approved by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records of vehicle certificates of title for vehicles that are delinquent for five or more consecutive years may be destroyed by the county treasurer. Automated files, optical disks, microfiche records, and photostatic, microfilm or other photographic copies of records shall be admissible in evidence when duly certified and authenticated by the officer having custody and control of the records.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m2; C24, 27, 31, 35, \'a75010; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.15;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.31}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 185, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 194, \'a73, 12}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7246}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a76, 35}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1064, \'a714, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a773, 74}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1059, \'a72, 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.32}}}{\*\bkmkstart stylerid1_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Registration card carried and exhibited }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exception.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle\u8217\'3fs registration card shall at all times be carried in the vehicle to which it refers and shall be shown to any peace officer upon the officer\u8217\'3fs request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply when the registration card is being used for the purpose of making application for renewal of registration or upon a transfer of registration for that vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m11; C24, 27, 31, 35, \'a74879; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.16;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.32}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 27, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a789}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.33}}}{\*\bkmkstart stylerid1_2E46_2E2_2E2}{\*\bkmkend stylerid1_2E46_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exception.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1069, \'a7140.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{\'a7321.32}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.34}}}{\*\bkmkstart stylerid1_2E47_2E2_2E2}{\*\bkmkend stylerid1_2E47_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Plates or validation sticker furnished \u8212\'3f retained by owner \u8212\'3f special plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E47_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Plates issued.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer upon receiving application, accompanied by proper fee, for registration of a vehicle shall issue to the owner one registration plate for a motorcycle, motorized bicycle, autocycle, truck tractor, trailer, or semitrailer and two registration plates for every other motor vehicle. The registration plates, including special registration plates, shall be assigned to the owner of a vehicle. When the owner of a registered vehicle transfers or assigns ownership of the vehicle to another person, the owner shall remove the registration plates from the vehicle. The owner shall forward the plates to any county treasurer or the owner may have the plates assigned to another vehicle within thirty days after transfer, upon payment of the fees required by law. The owner shall immediately affix registration plates retained by the owner to another vehicle owned or acquired by the owner, providing the owner complies with }}}{{\f5\fs18\hyphpar0\qj{section 321.46}}}{{\f5\fs18\hyphpar0\qj{. The department shall adopt rules providing for the assignment of registration plates to the transferee of a vehicle for which a credit is allowed under }}}{{\f5\fs18\hyphpar0\qj{section 321.46, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E47_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Validation stickers.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of issuing new registration plates each registration year for a vehicle renewing registration, the department may reassign the registration plates previously issued to the vehicle and may adopt and prescribe an annual validation sticker indicating payment of annual registration fees. The department shall issue one validation sticker for each set of registration plates. The sticker must specify the month and year of expiration of the registration plates. The sticker shall be displayed only on the rear registration plate, except that the sticker shall be displayed on the front registration plate of a truck tractor. A validation sticker issued for the upcoming registration year prior to the expiration of the applicable current registration year does not invalidate the registration, and is not required to be displayed on the registered vehicle\u8217\'3fs registration plate until the owner would be considered to be driving a motor vehicle with an expired registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.39}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state department of transportation shall adopt rules to provide for the placement of the motor vehicle registration validation sticker.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E47_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Radio operators plates.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of an automobile, motorcycle, trailer, or motor truck who holds an amateur radio license issued by the federal communications commission may, upon written application to the county treasurer accompanied by a fee of five dollars, order special registration plates bearing the call letters authorized the radio station covered by the person\u8217\'3fs amateur radio license. When received by the county treasurer, such special registration plates shall be issued to the applicant in exchange for the registration plates previously issued to the person. Not more than one set of special registration plates may be issued to an applicant. Said fee shall be in addition to and not in lieu of the fee for regular registration plates. Special registration plates must be surrendered upon expiration of the owner\u8217\'3fs amateur radio license and the owner shall thereupon be entitled to the owner\u8217\'3fs regular registration plates. The county treasurer shall validate special plates in the same manner as regular registration plates, upon payment of five dollars in addition to the regular annual registration fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E47_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Permanent plates.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of issuing annual registration plates for trailers, semitrailers, motor trucks, and truck tractors, the department may issue a permanent registration plate for trailers, semitrailers, motor trucks, and truck tractors licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{, upon payment of the appropriate registration fee. Payment of fees for trailers and semitrailers for a permanent registration plate shall, at the option of the registrant, be made at five-year intervals or on an annual basis. Fees from five-year payments shall not be reduced or prorated. Payment of fees for motor trucks and truck tractors shall be made on an annual basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E47_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Personalized registration plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application and the payment of a fee of twenty-five dollars, the director may issue to the owner of a motor vehicle registered in this state or a trailer or travel trailer registered in this state, personalized registration plates marked with up to seven initials, letters, or combination of numerals and letters requested by the owner. However, personalized registration plates for autocycles, motorcycles, and motorized bicycles shall be marked with no more than six initials, letters, or combinations of numerals and letters. Upon receipt of the personalized registration plates, the applicant shall surrender the regular registration plates to the county treasurer. The fee for issuance of the personalized registration plates shall be in addition to the regular annual registration fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer shall validate personalized registration plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ at an annual fee of five dollars in addition to the regular annual registration fee. A person renewing a personalized registration plate within one month following the time requirements under }}}{{\f5\fs18\hyphpar0\qj{section 321.40}}}{{\f5\fs18\hyphpar0\qj{ may renew the personalized plate without paying the additional registration fee under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ but shall pay the five-dollar fee in addition to the regular annual registration fee and any penalties subject to regular registration plate holders for late renewal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid to the treasurer of state and credited by the treasurer of state as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.145}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E47_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Sample vehicle registration plates.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicle registration plates displaying the general design of regular registration plates, with the word \u8220\'3fsample\u8221\'3f displayed on the plate, may be furnished to any person upon payment of a fee of three dollars, except that such plates may be furnished to governmental agencies without cost. Sample registration plates shall not be attached to a vehicle moved on the highways of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E47_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Collegiate plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application and payment of the proper fees, the director may issue to the owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, motor truck, motor home, multipurpose vehicle, trailer over two thousand pounds, or travel trailer registered in this state, collegiate registration plates created pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Upon receipt of the collegiate registration plates, the applicant shall surrender the regular registration plates to the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collegiate registration plates shall be designed for each of the three state universities. The collegiate registration plates shall be designated as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The letters \u8220\'3fISU\u8221\'3f followed by a four-digit number all in cardinal on a gold background for Iowa state university of science and technology.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The letters \u8220\'3fUNI\u8221\'3f followed by a four-digit number all in purple on a gold background for the university of northern Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The letters \u8220\'3fUI\u8221\'3f followed by a four-digit number all in black on a gold background for the state university of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the letter-number designation provided under subparagraphs (1) through (3), the collegiate registration plates may be designated in the manner provided for personalized registration plates under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in the colors designated for the respective universities under subparagraphs (1) through (3).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fees for a collegiate registration plate are as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A registration fee of twenty-five dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special collegiate registration fee of twenty-five dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{These fees are in addition to the regular annual registration fee. The fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall credit monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to Iowa state university of science and technology, the university of northern Iowa, and the state university of Iowa respectively, the amount of the special collegiate registration fees collected in the previous month for collegiate registration plates designed for the university. The moneys credited are appropriated to the respective universities to be used for scholarships for students attending the universities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer shall validate collegiate registration plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ at an annual fee of five dollars in addition to the regular annual registration fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A collegiate registration plate shall not be issued if its combination of alphanumeric characters are identical to those contained on a current personalized registration plate issued under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{. However, the owner of a motor vehicle who has a personalized registration plate issued for the motor vehicle may, after proper application and payment of fees, be issued a collegiate registration plate containing the same alphanumeric characters as those on the personalized plate. Upon receipt of the collegiate registration plates, the owner shall surrender the personalized registration plates to the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7A.}}}{\*\bkmkstart stylerid1_2E47_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Collegiate plates \u8212\'3f Private four-year colleges and universities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application by a private four-year college or university located in this state and payment of the initial set-up costs for establishing the collegiate plate, the department, in consultation with the college or university, may design a special collegiate registration plate displaying the colors associated with the college or university.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application and payment of the proper fees, the director may issue to the owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, motor truck, motor home, multipurpose vehicle, trailer over two thousand pounds, or travel trailer registered in this state, collegiate registration plates created pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The fee for the issuance of collegiate registration plates is twenty-five dollars, which fee is in addition to the regular annual registration fee for the vehicle. An applicant may obtain a personalized collegiate registration plate upon payment of the additional fee for a personalized plate as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ in addition to the collegiate plate fee and the regular registration fee. The county treasurer shall validate collegiate registration plates issued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ in the same manner as regular registration plates, upon payment of five dollars in addition to the regular annual registration fee. Upon receipt of the collegiate registration plates, the applicant shall surrender the regular registration plates to the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A personalized collegiate registration plate shall not be issued if its combination of alphanumeric characters are identical to those contained on a current personalized registration plate issued under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{. However, the owner of a motor vehicle who has a personalized registration plate issued for the motor vehicle may, after proper application and payment of fees, be issued a collegiate registration plate containing the same alphanumeric characters as those on the personalized plate. Upon receipt of the collegiate registration plates, the owner shall surrender the personalized registration plates to the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E47_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Medal of honor plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motorcycle, trailer, or motor truck who has been awarded the medal of honor may, upon written application to the department, order special registration plates which shall be red, white, and blue in color and shall bear an emblem of the medal of honor and an identifying number. Each applicant applying for special registration plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may order only one set of registration plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The application is subject to approval by the department and the special registration plates shall be issued at no charge to the applicant in exchange for the registration plates previously issued to the person. A person who is issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is exempt from payment of any annual registration fee for the motor vehicle bearing the special plates. The department shall validate the special plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The department shall not issue special registration plates until service organizations in the state have furnished the department either the special dies or the cost of the special dies necessary for the manufacture of the special registration plate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surviving spouse of a person who was issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may continue to use the special plates subject to registration of the special plates in the surviving spouse\u8217\'3fs name. If the surviving spouse remarries, the surviving spouse shall return the special plates to the department and the department shall issue regular registration plates to the surviving spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8A.}}}{\*\bkmkstart stylerid1_2E47_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Ex-prisoner of war special plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motorcycle, trailer, or motor truck who was a prisoner of war during a time of military conflict may, upon written application to the department, order only one set of special registration plates with an ex-prisoner of war processed emblem. The emblem shall be designed by the department in cooperation with the adjutant general and shall signify that the owner was a prisoner of war as described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The application is subject to approval by the department, in consultation with the adjutant general. The special plates shall be issued at no charge and are subject to an annual registration fee of fifteen dollars. The county treasurer shall validate the special plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surviving spouse of a person who was issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may continue to use or apply for and use the special plates subject to registration of the special plates in the surviving spouse\u8217\'3fs name and upon payment of the annual registration fee. If the surviving spouse remarries, the surviving spouse shall return the special plates to the department and the department shall issue regular registration plates to the surviving spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E47_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Leased vehicles.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration plates under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including disabled veteran plates specified in }}}{{\f5\fs18\hyphpar0\qj{section 321.105}}}{{\f5\fs18\hyphpar0\qj{, may be issued to the lessee of a motor vehicle if the lessee provides evidence of a lease for a period of more than sixty days and if the lessee complies with the requirements, under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, for issuance of the specific registration plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E47_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Fire fighter plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application and payment of the proper fees, the director may issue fire fighter plates to the owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motor truck, motor home, multipurpose vehicle, motorcycle, trailer, or travel trailer if the owner is a current or retired member of a paid or volunteer fire department. The special registration plates, designed by the department in cooperation with representatives designated by the Iowa fire fighters\u8217\'3f associations, signify that the applicant is a current or retired member of a paid or volunteer fire department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application shall be approved by the department in consultation with representatives designated by the Iowa fire fighters\u8217\'3f associations, and the special registration plates shall be issued to the applicant in exchange for the registration plates previously issued to the person. An applicant who is the owner of a business-trade truck or special truck shall not be issued special fire fighter registration plates for more than one vehicle. The fee for the special plates is twenty-five dollars which shall be paid in addition to the regular annual registration fee. An applicant may obtain personalized fire fighter plates upon payment of the additional fee for personalized plates as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ in addition to the special fire fighter fee and the regular registration fee. Personalized plates authorized by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be limited to no more than five initials, letters, or combinations of numerals and letters. The department shall validate the special plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ at the regular annual registration fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall transfer monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the Paul Ryan memorial fire fighter safety training fund created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 100B.12}}}{{\f5\fs18\hyphpar0\qj{ the amount of the special fees collected in the previous month for the fire fighter plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a person is considered to be retired if the person is recognized by the chief of the fire department where the individual served, and on record, as officially retired from the fire department. Special fire fighter registration plates shall be surrendered in exchange for regular registration plates upon termination of the motor vehicle owner\u8217\'3fs membership in the paid or volunteer fire department, unless the person is a retired member in good standing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10A.}}}{\*\bkmkstart stylerid1_2E47_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Emergency medical services plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a motor vehicle referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ who is a current member of a paid or volunteer emergency medical services agency may, upon written application to the department, order special registration plates with an emergency medical services distinguishing processed emblem, designed by the department in cooperation with representatives designated by the Iowa emergency medical services association, which emblem signifies that the applicant is a current member of a paid or volunteer emergency medical services agency. The application shall be approved by the department, in consultation with representatives designated by the Iowa emergency medical services association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special plate fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the annual validation of letter-number designated emergency medical services plates, and }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the issuance and annual validation of personalized emergency medical services plates shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall transfer monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the emergency medical services fund created in }}}{{\f5\fs18\hyphpar0\qj{section 135.25}}}{{\f5\fs18\hyphpar0\qj{ the amount of the special fees collected in the previous month for issuance of emergency medical services plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E47_2E16_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E16_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Natural resources plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application and payment of the proper fees, the director may issue natural resources plates to the owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motor truck, motor home, multipurpose vehicle, motorcycle, trailer, or travel trailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Natural resources plates shall be designed by the department in cooperation with the department of natural resources which design shall include on the plate the name of the county where the vehicle is registered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special natural resources fee for letter-number designated natural resources plates is forty-five dollars. The fee for personalized natural resources plates is forty-five dollars which shall be paid in addition to the special natural resources fee of forty-five dollars. The fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall credit monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the Iowa resources enhancement and protection fund created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455A.18}}}{{\f5\fs18\hyphpar0\qj{, the amount of the special natural resources fees collected in the previous month for the natural resources plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From the moneys credited to the Iowa resources enhancement and protection fund under subparagraph (1), ten dollars of the fee collected for each natural resources plate issued, and fifteen dollars from each renewal fee, shall be allocated to the department of natural resources wildlife bureau to be used for nongame wildlife programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of the special registration plates, the applicant shall surrender the current registration plates to the county treasurer. The county treasurer shall validate the special registration plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The annual special natural resources fee for letter-number designated plates is twenty-five dollars which shall be paid in addition to the regular annual registration fee. The annual fee for personalized natural resources plates is five dollars which shall be paid in addition to the annual special natural resources fee and the regular annual registration fee. The annual special natural resources fee shall be credited as provided under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11A.}}}{\*\bkmkstart stylerid1_2E47_2E17_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E17_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Love our kids plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application and payment of the proper fees, the director may issue \u8220\'3flove our kids\u8221\'3f plates to the owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motor truck, motor home, multipurpose vehicle, motorcycle, trailer, or travel trailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Love our kids plates shall be designed by the department in cooperation with the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special fee for letter-number designated love our kids plates is thirty-five dollars. The fee for personalized love our kids plates is twenty-five dollars, which shall be paid in addition to the special love our kids fee of thirty-five dollars. The fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall transfer monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the department of health and human services the amount of the special fees collected in the previous month for the love our kids plates. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys transferred under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not revert to the general fund of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of the special registration plates, the applicant shall surrender the current registration plates to the county treasurer. The county treasurer shall validate the special registration plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The annual special love our kids fee for letter-number designated plates is ten dollars, which shall be paid in addition to the regular annual registration fee. The annual fee for personalized love our kids plates is five dollars, which shall be paid in addition to the annual special love our kids fee and the regular annual registration fee. The annual love our kids fee shall be credited as provided under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11B.}}}{\*\bkmkstart stylerid1_2E47_2E18_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E18_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Motorcycle rider education plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application and payment of the proper fees, the director may issue \u8220\'3fmotorcycle rider education\u8221\'3f plates to the owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motor truck, motor home, multipurpose vehicle, motorcycle, trailer, or travel trailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Motorcycle rider education plates shall be designed by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special fee for letter-number designated motorcycle rider education plates is thirty-five dollars. The fee for personalized motorcycle rider education plates is twenty-five dollars, which shall be paid in addition to the special motorcycle rider education fee of thirty-five dollars. The fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall transfer monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the department for use in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.179}}}{{\f5\fs18\hyphpar0\qj{, the amount of the special fees collected in the previous month for the motorcycle rider education plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of the special registration plates, the applicant shall surrender the current registration plates to the county treasurer. The county treasurer shall validate the special registration plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The annual special motorcycle rider education fee for letter-number designated plates is ten dollars, which shall be paid in addition to the regular annual registration fee. The annual fee for personalized motorcycle rider education plates is five dollars, which shall be paid in addition to the annual special motorcycle rider education fee and the regular annual registration fee. The annual motorcycle rider education fee shall be credited as provided under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11C.}}}{\*\bkmkstart stylerid1_2E47_2E19_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E19_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Blackout plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application and payment of the proper fees, the director may issue blackout plates to the owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motor truck, motor home, multipurpose vehicle, motorcycle, trailer, or travel trailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Blackout plates shall be designed by the department. A blackout plate\u8217\'3fs background shall be black, and the plate\u8217\'3fs letters and numbers shall be white.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special blackout fee for letter-number designated blackout plates is thirty-five dollars. An applicant may obtain personalized blackout plates upon payment of the fee for personalized plates as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, which is in addition to the special blackout fee. The fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid monthly to the treasurer of state and deposited in the road use tax fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of the special registration plates, the applicant shall surrender the current registration plates to the county treasurer. The county treasurer shall validate the special registration plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The annual special blackout fee for letter-number designated plates is ten dollars which shall be paid in addition to the regular annual registration fee. The annual fee for personalized blackout plates is five dollars which shall be paid in addition to the annual special blackout fee and the regular annual registration fee. The annual special blackout fee shall be credited as provided under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not condition the issuance of blackout plates on the receipt of any number of orders for blackout plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11D.}}}{\*\bkmkstart stylerid1_2E47_2E2_30_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E2_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Flying our colors plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application and payment of the proper fees, the director may issue flying our colors plates to the owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motor truck, motor home, multipurpose vehicle, motorcycle, trailer, or travel trailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Flying our colors plates shall be designed by the department. Flying our colors plates shall be navy along the top and red along the bottom, and contain a white space in the middle of the plate which shall include the plate\u8217\'3fs letters and numbers in black and a gray image of a bald eagle behind the plate\u8217\'3fs letters and numbers. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The special flying our colors fee for letter-number designated flying our colors plates is thirty-five dollars. An applicant may obtain personalized flying our colors plates upon payment of the fee for personalized plates as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, which is in addition to the special fee. The fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid monthly to the treasurer of state and deposited in the road use tax fund.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall credit monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the flood mitigation fund created under }}}{{\f5\fs18\hyphpar0\qj{section 418.10}}}{{\f5\fs18\hyphpar0\qj{, the amount of the special fees collected in the previous month for flying our colors plates. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of the special registration plates, the applicant shall surrender the current registration plates to the county treasurer. The county treasurer shall validate the special registration plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The annual special flying our colors fee for letter-number designated flying our colors plates is ten dollars which shall be paid in addition to the regular annual registration fee. The annual fee for personalized flying our colors plates is five dollars which shall be paid in addition to the annual special flying our colors fee and the regular annual registration fee. The annual special flying our colors fee shall be credited as provided under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{\*\bkmkstart stylerid1_2E47_2E21_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E21_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Special registration plates \u8212\'3f general provisions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a motor vehicle subject to registration pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motor truck, motor home, multipurpose vehicle, motorcycle, trailer, or travel trailer may, upon written application to the department, order special registration plates with a distinguishing processed emblem as authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or as approved by the department. The fee for the issuance of special registration plates is twenty-five dollars for each vehicle, unless otherwise provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, which fee is in addition to the regular annual registration fee. The county treasurer shall validate special registration plates with a distinguishing processed emblem in the same manner as regular registration plates, upon payment of five dollars in addition to the regular annual registration fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a special registration plate with a distinguishing processed emblem as authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or as approved by the department, the applicant shall surrender the regular registration plates to the county treasurer. An applicant no longer eligible for a special registration plate shall surrender the special vehicle registration plates to the county treasurer for issuance of regular registration plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant may, upon payment of the additional fee for a personalized plate as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, obtain a personalized special registration plate with a processed emblem. Personalized plates authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ with the processed emblem shall be limited to no more than five initials, letters, or combinations of numerals and letters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special registration plate issued for a motorcycle, autocycle, or motorized bicycle under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be designated in the manner provided for personalized registration plates under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12A.}}}{\*\bkmkstart stylerid1_2E47_2E22_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E22_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Special registration plates \u8212\'3f armed forces services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner of a vehicle referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ who applies for any type of special registration plates associated with service in the United States armed forces shall be issued one set of the special registration plates at no charge, but shall be subject to the annual registration fee of fifteen dollars, if the owner is eligible for, but has relinquished to the department or the county treasurer or has not been issued, ex-prisoner of war or legion of merit special registration plates under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner of a vehicle referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ who applies for any type of special registration plates associated with service in the United States armed forces shall be issued one set of the special registration plates at no charge and subject to no annual registration fee if the owner is eligible for, but has relinquished to the department or the county treasurer or has not been issued, medal of honor registration plates under }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{ or disabled veteran registration plates under }}}{{\f5\fs18\hyphpar0\qj{section 321.105}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner shall provide the appropriate information regarding the owner\u8217\'3fs eligibility for any of the special registration plates described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and regarding the owner\u8217\'3fs eligibility for the special registration plates for which the owner has applied, as required by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surviving spouse of a person who was issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may continue to use the special plates subject to registration of the special plates in the surviving spouse\u8217\'3fs name and upon payment of the same annual registration fee, if applicable. If the surviving spouse remarries, the surviving spouse shall return the special plates to the department and the department shall issue regular registration plates to the surviving spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{\*\bkmkstart stylerid1_2E47_2E23_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E23_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Special plates displaying organization decal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a motor vehicle subject to registration pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motor truck, motor home, multipurpose vehicle, motorcycle, trailer, or travel trailer may upon request be issued special registration plates that contain a space reserved for the placement of an organization decal. If the special plates are requested at the time of initial application for registration and certificate of title for the vehicle, no special plate fee is required other than the regular annual registration fee for the vehicle. If the special plates are requested as replacement plates, the owner shall surrender the current regular or special registration plates in exchange for the special plates and shall pay a replacement plate fee of five dollars. The county treasurer shall validate special plates with an organization decal in the same manner as regular plates, upon payment of the annual registration fee.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant may obtain a personalized special registration plate with space reserved for an organization decal, subject to the additional fees for a personalized plate as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{. Personalized plates with space reserved for an organization decal shall be limited to no more than five initials, letters, or combinations of numerals and letters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An organization may apply to the department for approval to issue a decal to be displayed on vehicle registration plates. To qualify for such approval, an organization shall meet the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The primary activity or interest of the organization serves the community, contributes to the welfare of others, and is not discriminatory in its purpose, nature, activity, or name.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and purpose of the organization do not promote any specific product or brand name that is provided for sale.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The organization is a nonprofit corporation which is exempt from taxation under }}}{{\f5\fs18\hyphpar0\qj{section 501(c)(3) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and is organized under the laws of this state or authorized to do business within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may accept an application for a decal design from a group of nonprofit organizations with a common purpose, provided that each organization within the group meets the requirements for a qualifying organization established by the department under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An organization desiring to issue a decal shall submit an application to the department on a form to be provided by the department. Along with the application, the organization shall furnish to the department all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the articles of incorporation for the organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the charter or by-laws for the organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any Internal Revenue Service rulings concerning the organization\u8217\'3fs nonprofit tax exemption status.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A color copy of the completed decal design.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A clear and concise explanation of the purpose of the decal, all eligibility requirements for purchasing the decal, and fees to be charged for the decal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certification by the person who has legal rights to the decal design allowing use of the design.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information required by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall consider a proposed decal design based upon criteria established by the department, which shall include but not be limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A decal shall not promote a specific religion, faith, or anti-religious sentiment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A decal shall not have any sexual connotation and shall not be vulgar, prejudiced, hostile, insulting, or racially or ethnically degrading.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon approval by the department of an organization\u8217\'3fs application to issue a decal and approval of the design of the decal, the organization is responsible for the production, administration, and issuance of the decal. An organization shall not issue a decal that has not been approved by the department or alter the approved design of a decal without the department\u8217\'3fs approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not display a decal on a vehicle registration plate other than a decal approved by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ as necessary to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{\*\bkmkstart stylerid1_2E47_2E24_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E24_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Persons with disabilities special plates.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ or an owner of a trailer used to transport a wheelchair who is a person with a disability, or who is the parent or guardian of a child who resides with the parent or guardian owner and who is a person with a disability, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321L.1}}}{{\f5\fs18\hyphpar0\qj{, may, upon written application to the department, order special registration plates with a persons with disabilities processed emblem designed by the department bearing the international symbol of accessibility. The special registration plates with a persons with disabilities processed emblem shall only be issued if the application is accompanied with a statement from a physician licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{149}}}{{\f5\fs18\hyphpar0\qj{, a physician assistant licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{, an advanced registered nurse practitioner licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{, a chiropractor licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 151}}}{{\f5\fs18\hyphpar0\qj{, an occupational therapist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148B}}}{{\f5\fs18\hyphpar0\qj{, or a physical therapist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148A}}}{{\f5\fs18\hyphpar0\qj{, written on the physician\u8217\'3fs, physician assistant\u8217\'3fs, nurse practitioner\u8217\'3fs, chiropractor\u8217\'3fs, occupational therapist\u8217\'3fs, or physical therapist\u8217\'3fs stationery, stating the nature of the applicant\u8217\'3fs or the applicant\u8217\'3fs child\u8217\'3fs disability and such additional information as required by rules adopted by the department, including proof of residency of a child who is a person with a disability. If the application is approved by the department, the special registration plates with a persons with disabilities processed emblem shall be issued to the applicant. There shall be no fee in addition to the regular annual registration fee for the special registration plates with a persons with disabilities processed emblem. The authorization for special registration plates with a persons with disabilities processed emblem shall not be renewed without the applicant furnishing evidence to the department that the owner of the vehicle or the owner\u8217\'3fs child is still a person with a disability as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321L.1}}}{{\f5\fs18\hyphpar0\qj{. An owner who has a child who is a person with a disability shall provide satisfactory evidence to the department that the child with a disability continues to reside with the owner. The registration plates with a persons with disabilities processed emblem shall be surrendered in exchange for regular registration plates as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ when the owner of the vehicle or the owner\u8217\'3fs child no longer qualifies as a person with a disability as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321L.1}}}{{\f5\fs18\hyphpar0\qj{ or when the owner\u8217\'3fs child who is a person with a disability no longer resides with the owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{\*\bkmkstart stylerid1_2E47_2E25_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E25_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Legion of merit special plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a motor vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, autocycle, motorcycle, trailer, or motor truck who has been awarded the legion of merit shall be issued one set of special registration plates with a legion of merit processed emblem, upon written application to the department and presentation of satisfactory proof of the award of the legion of merit as established by the Congress of the United States. The emblem shall be designed by the department in cooperation with the adjutant general and shall signify that the owner was awarded the legion of merit. The application is subject to approval by the department, in consultation with the adjutant general. The special plates shall be issued at no charge and are subject to an annual registration fee of fifteen dollars. The county treasurer shall validate the special plates in the same manner as regular registration plates are validated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surviving spouse of a person who was issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may continue to use or apply for and use the special plates subject to registration of the special plates in the surviving spouse\u8217\'3fs name and upon payment of the annual registration fee. If the surviving spouse remarries, the surviving spouse shall return the special plates to the department and the department shall issue regular registration plates to the surviving spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{\*\bkmkstart stylerid1_2E47_2E26_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E26_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{National guard special plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ who is a member of the national guard, as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 29A}}}{{\f5\fs18\hyphpar0\qj{, may, upon written application to the department, order special registration plates with a national guard processed emblem with the emblem designed by the department in cooperation with the adjutant general which emblem signifies that the applicant is a member of the national guard. The application shall be approved by the department in consultation with the adjutant general. The special plate fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the annual validation of letter-number designated national guard plates, and }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the issuance and annual validation of personalized national guard plates shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall transfer monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the veterans license fee fund created in }}}{{\f5\fs18\hyphpar0\qj{section 35A.11}}}{{\f5\fs18\hyphpar0\qj{ the amount of the special fees collected under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in the previous month for national guard plates. Special registration plates with a national guard processed emblem shall be surrendered, as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, in exchange for regular registration plates upon termination of the owner\u8217\'3fs membership in the active national guard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, an owner who is approved for special registration plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be issued one set of special registration plates with a national guard processed emblem at no charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surviving spouse of a person who was issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may continue to use or apply for and use the special plates subject to registration of the special plates in the surviving spouse\u8217\'3fs name and upon payment of the annual five-dollar special plate fee and the regular annual registration fee for the vehicle. If the surviving spouse remarries, the surviving spouse shall return the special plates to the department and the department shall issue regular registration plates to the surviving spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{\*\bkmkstart stylerid1_2E47_2E27_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E27_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Pearl Harbor special plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ who was at Pearl Harbor, Hawaii, as a member of the armed services of the United States on December 7, 1941, may, upon written application to the department, order special registration plates with a Pearl Harbor processed emblem. The emblem shall be designed by the department in consultation with service organizations. The application is subject to approval by the department. The special plate fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the annual validation of letter-number designated Pearl Harbor plates, and }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the issuance and annual validation of personalized Pearl Harbor plates shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall transfer monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the veterans license fee fund created in }}}{{\f5\fs18\hyphpar0\qj{section 35A.11}}}{{\f5\fs18\hyphpar0\qj{ the amount of the special fees collected under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in the previous month for Pearl Harbor plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, an owner who is approved for special registration plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be issued one set of special registration plates with a Pearl Harbor processed emblem at no charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surviving spouse of a person who was issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may continue to use or apply for and use the special plates subject to registration of the special plates in the surviving spouse\u8217\'3fs name and upon payment of the annual five-dollar special plate fee and the regular annual registration fee for the vehicle. If the surviving spouse remarries, the surviving spouse shall return the special plates to the department and the department shall issue regular registration plates to the surviving spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{\*\bkmkstart stylerid1_2E47_2E28_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E28_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Purple heart special plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ who was awarded a purple heart medal by the United States government for wounds received in military or naval combat against an armed enemy of the United States may, upon written application to the department and presentation of satisfactory proof of the award of the purple heart medal, order special registration plates with a purple heart processed emblem. The design of the emblem shall include a representation of a purple heart medal and ribbon. The application is subject to approval by the department in consultation with the adjutant general. The special plate fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the annual validation of letter-number designated purple heart plates, and }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the issuance and annual validation of personalized purple heart plates shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall transfer monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the veterans license fee fund created in }}}{{\f5\fs18\hyphpar0\qj{section 35A.11}}}{{\f5\fs18\hyphpar0\qj{ the amount of the special fees collected under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in the previous month for purple heart plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, an owner who is approved for special registration plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be issued one set of special registration plates with a purple heart processed emblem at no charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surviving spouse of a person who was issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may continue to use or apply for and use the special plates subject to registration of the special plates in the surviving spouse\u8217\'3fs name and upon payment of the annual five-dollar special plate fee and the regular annual registration fee for the vehicle. If the surviving spouse remarries, the surviving spouse shall return the special plates to the department and the department shall issue regular registration plates to the surviving spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{\*\bkmkstart stylerid1_2E47_2E29_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E29_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{United States armed forces retired special plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ who is a retired member of the United States armed forces may, upon written application to the department and upon presentation of satisfactory proof of membership, order special registration plates with a United States armed forces retired processed emblem. The emblem shall be designed by the department in consultation with service organizations. The application is subject to approval by the department. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a person is considered to be retired if the person is recognized by the United States armed forces as retired from the United States armed forces. The special plate fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the annual validation of letter-number designated armed forces retired plates, and }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the issuance and annual validation of personalized armed forces retired plates shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall transfer monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the veterans license fee fund created in }}}{{\f5\fs18\hyphpar0\qj{section 35A.11}}}{{\f5\fs18\hyphpar0\qj{ the amount of the special fees collected under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in the previous month for armed forces retired plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, an owner who is approved for special registration plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be issued one set of special registration plates with an armed forces retired processed emblem at no charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surviving spouse of a person who was issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may continue to use or apply for and use the special plates subject to registration of the special plates in the surviving spouse\u8217\'3fs name and upon payment of the annual five-dollar special plate fee and the regular annual registration fee for the vehicle. If the surviving spouse remarries, the surviving spouse shall return the special plates to the department and the department shall issue regular registration plates to the surviving spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{\*\bkmkstart stylerid1_2E47_2E3_30_2E1_2E2}{\*\bkmkend stylerid1_2E47_2E3_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Silver or bronze star plates.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{ who was awarded a silver or a bronze star by the United States government, may, upon written application to the department and presentation of satisfactory proof of the award of the silver or bronze star, order special registration plates with a silver or bronze star processed emblem. The emblem shall be designed by the department in consultation with the adjutant general. The special plate fees collected by the director under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the annual validation of letter-number designated silver star and bronze star plates, and }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, from the issuance and annual validation of personalized silver star and bronze star plates shall be paid monthly to the treasurer of state and deposited in the road use tax fund. The treasurer of state shall transfer monthly from the statutory allocations fund created under }}}{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to the veterans license fee fund created in }}}{{\f5\fs18\hyphpar0\qj{section 35A.11}}}{{\f5\fs18\hyphpar0\qj{ the amount of the special fees collected under }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in the previous month for silver star and bronze star plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, an owner who is approved for special registration plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be issued one set of special registration plates with a silver star or bronze star processed emblem at no charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The surviving spouse of a person who was issued special plates under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may continue to use or apply for and use the special plates subject to registration of the special plates in the surviving spouse\u8217\'3fs name and upon payment of the annual five-dollar special plate fee and the regular annual registration fee for the vehicle. If the surviving spouse remarries, the surviving spouse shall return the special plates to the department and the department shall issue regular registration plates to the surviving spouse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0