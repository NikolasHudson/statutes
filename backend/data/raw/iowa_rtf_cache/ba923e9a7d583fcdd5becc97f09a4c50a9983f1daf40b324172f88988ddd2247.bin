~\~\~\~\~\~\~\~\~\~\~\~\~}}}{\f5\fs18\hyphpar0\qj}{$2,100}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Over 19,000 pounds up to and }\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{including 20,000 pounds}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{\f5\fs18\hyphpar0\qj}{$2,200}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Over 20,000 pounds}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{$2,200 plus ten cents }\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{per pound in excess}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{of 20,000 pounds}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fines for gross weight violations for vehicles or combinations of vehicles shall be assessed at one-half of the fine rate schedule for axle, tandem axle, and groups of axles weight violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided, the amount of the fine to be assessed shall be computed on the difference between the actual weight and the maximum legal weight specified in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The schedule of fines may be assessed in addition to any other penalties provided for in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Overloads on axles and tandem axles and overloads on groups of axles or on an entire vehicle or combination of vehicles shall be considered as separate violations of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not issue or execute, or cause to be issued or executed, a bill of lading, manifest, or shipping document of any kind which states a false weight of the cargo set forth on such bill, manifest, or document, which is less than the actual weight of the cargo.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person operating a vehicle or combination of vehicles equipped with a retractable axle may raise the axle when necessary to negotiate a turn, provided that the retractable axle is lowered within one thousand feet following completion of the turn. This paragraph does not apply to a vehicle or combination of vehicles operated on an interstate highway, including a ramp to or from an interstate highway, or on a bridge.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle or combination of vehicles operated with a retractable axle raised as permitted under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is exempt from the weight limitations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ as long as the vehicle or combination of vehicles is in compliance with the weight limitations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ when the retractable axle is lowered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit the operation of a vehicle or combination of vehicles equipped with a retractable axle with the retractable axle raised when the vehicle or combination of vehicles is in compliance with the weight limitations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ with the retractable axle raised.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75065; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.463}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 110, \'a71}}}{, }{{\f5\fs18\hyphpar0\qj{ch 111}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 200, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1238, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1199, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1089, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 100, \'a75, 12}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1103, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1178, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 108, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1040, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a723 \u8211\'3f 25}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a733, 55}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 20, \'a75 \u8211\'3f 7, 12, 13}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 143, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a7121}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1139, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 27, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 149, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 15, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 138, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 158, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7152}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 140, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 85, \'a717}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.453}}}{{\f5\fs12\hyphpar0\qj{, 321.457}}}{{\f5\fs12\hyphpar0\qj{, 321.459}}}{{\f5\fs12\hyphpar0\qj{, 321.466}}}{{\f5\fs12\hyphpar0\qj{, 321.473}}}{{\f5\fs12\hyphpar0\qj{, 321E.2}}}{{\f5\fs12\hyphpar0\qj{, 321E.7}}}{{\f5\fs12\hyphpar0\qj{, 321E.8}}}{{\f5\fs12\hyphpar0\qj{, 321E.9}}}{{\f5\fs12\hyphpar0\qj{, 321E.9A}}}{{\f5\fs12\hyphpar0\qj{, 321E.16}}}{{\f5\fs12\hyphpar0\qj{, 321E.17}}}{{\f5\fs12\hyphpar0\qj{, 321E.26}}}{{\f5\fs12\hyphpar0\qj{, 321E.27}}}{{\f5\fs12\hyphpar0\qj{, 321E.29}}}{{\f5\fs12\hyphpar0\qj{, 321E.29A}}}{{\f5\fs12\hyphpar0\qj{, 321E.29B}}}{{\f5\fs12\hyphpar0\qj{, 321E.30}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(e)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For scheduled fines listed in subsection 11, violations are charged and fines are applied pursuant to }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph\~e }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.464}}}{\*\bkmkstart stylerid1_2E526_2E2_2E2}{\*\bkmkend stylerid1_2E526_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Investigation as to safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director upon registering any vehicle under the laws of this state which vehicle is designed and used primarily for the transportation of property or for the transportation of ten or more persons, may require such information and may make such investigation or test as necessary to enable the director to determine whether such vehicle may safely be operated upon the highways in compliance with all the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The director shall register every such vehicle for a permissible gross weight not exceeding the limitations set forth in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Every such vehicle shall meet the following requirements:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be equipped with brakes as required in }}}{{\f5\fs18\hyphpar0\qj{sections 321.430}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.431}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every motor vehicle to be operated outside of business and residence districts shall have motive power adequate to propel at a reasonable speed such vehicle and any load thereon or to be drawn thereby.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.464}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.465}}}{\*\bkmkstart stylerid1_2E527_2E2_2E2}{\*\bkmkend stylerid1_2E527_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Weighing vehicles and removal of excess.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any peace officer having reason to believe that the weight of a vehicle and load is unlawful is authorized to require the driver to stop and submit to a weighing of the same either by means of portable or stationary scales and may require that such vehicle be driven to the nearest public scales.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an officer upon weighing a vehicle and load determines that the weight is unlawful, the officer may require the driver to stop the vehicle in a suitable place until such portion of the load is removed as may be necessary to reduce the gross weight of the vehicle to the limit as permitted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. All material so unloaded shall be cared for by the owner or operator of the vehicle at the risk of the owner or operator. The owner or operator of an overweight vehicle, designed to transport solid waste and domiciled within the state, which is transporting solid waste, shall not be required to unload any portion of the load, if the load is indivisible, in a place other than a facility which is permitted to handle solid waste disposal, processing, or recycling. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsolid waste\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means waste which is acceptable at a local sanitary landfill and the solid waste shall be considered to be an indivisible load.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A driver of a vehicle who fails or refuses to stop and submit the vehicle and load to a weighing, or who fails or refuses when directed by an officer upon a weighing of the vehicle to stop the vehicle and otherwise comply with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon weighing a vehicle and load, as above provided, if such load is a sealed load, the weight officer shall issue a certificate setting forth the weights as determined by the weight officer and the seal number or numbers, if requested by the operator.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74921-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.465}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1170, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1087, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321E.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.466}}}{\*\bkmkstart stylerid1_2E528_2E2_2E2}{\*\bkmkend stylerid1_2E528_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Increased loading capacity \u8212\'3f reregistration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ The owner of a motor truck, truck tractor, or road tractor, if the owner\u8217\'3fs operation has not resulted in a conviction or action pending under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, may increase the gross weight registration of the vehicle to a higher gross weight registration by payment of one-twelfth of the difference between the annual fee for the higher gross weight and the amount of the fee for the gross weight at which the vehicle is registered, multiplied by the number of unexpired months of the registration year. If the owner\u8217\'3fs operation has resulted in a conviction or action pending under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, any increase in the gross weight registration shall be obtained by payment of the difference between the annual fee for the higher gross weight and the amount of the fee for the gross weight at which the vehicle is registered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon conversion of a truck to a truck tractor or a truck tractor to a truck, an increased gross weight registration of the proper type may be obtained for the vehicle by payment, except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.106}}}{{\f5\fs18\hyphpar0\qj{, of one-twelfth of the difference between the annual fee for the higher gross weight and the amount of the annual fee for the gross weight at which the vehicle is registered, multiplied by the number of unexpired months of the registration year from the date of the conversion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The registered gross weight of a vehicle or combination of vehicles may also be increased by installing and using an auxiliary axle or axles, and the combined registered gross weight of the vehicle and auxiliary axle or axles shall determine the total registered gross weight. An auxiliary axle shall not be used to convert a single axle to a tandem axle unless equipped with a device to equalize the load carried by the single axle and the auxiliary axle when in tandem and when in motion or when standing, and the load transmitted to the highway by either the single axle or the auxiliary axle shall not exceed that permitted for a single axle, nor shall the load transmitted to the highway when in tandem and when in motion or when standing, exceed that permitted for a tandem axle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not operate a motor truck, trailer, truck tractor, road tractor, semitrailer, or combination thereof, or any such vehicle equipped with a transferable auxiliary axle or axles, on the public highways with a gross weight exceeding the gross weight for which it is registered by more than five percent; provided, however, that any vehicle or vehicle combination referred to in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, while carrying a load of raw farm products, soil fertilizers including ground limestone, raw dairy products, livestock, live poultry, or eggs, or a special truck, while carrying a load of distillers grains, may be operated with a gross weight of twenty-five percent in excess of the gross weight for which it is registered. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to allow the operation of a special truck on the public highways with a gross weight exceeding the maximum gross weight allowed under }}}{{\f5\fs18\hyphpar0\qj{section 321.463, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ cracked or ground soybeans, sorgo, corn, wheat, rye, oats, or other grain shall be deemed to be raw farm products, provided that such products are being directly delivered to a farm, from the place where the whole grain had been delivered from a farm for the purpose of cracking or grinding and immediate delivery to the farm to which such cracked or ground products are being delivered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The truck operator shall have in the truck operator\u8217\'3fs possession a receipt showing place of processing on the return trip.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, \'a74921; C31, 35, \'a74921-c1, -c2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.15;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.466}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 110, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a731, 32, 38}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 113, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 103, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 138, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.123}}}{{\f5\fs12\hyphpar0\qj{, 321.460}}}{{\f5\fs12\hyphpar0\qj{, 321E.2}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(12)(d)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Vehicles carrying farm products, see also }{{\f5\fs12\hyphpar0\qj{\'a7321.460}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 12, paragraph d }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.467}}}{\*\bkmkstart stylerid1_2E529_2E2_2E2}{\*\bkmkend stylerid1_2E529_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Retractable axles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle which is a model year 1999 or later vehicle shall not operate on a highway of this state with a retractable axle unless the weight on the retractable axle can only be adjusted by means of a manual device located on the vehicle that is not accessible to the operator of the vehicle during operation of the vehicle. However, the controls for raising and lowering the retractable axle may be accessible to the operator of the vehicle while the vehicle is in operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 100, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a718}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.468 through 321.470}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.471}}}{\*\bkmkstart stylerid1_2E531_2E2_2E2}{\*\bkmkend stylerid1_2E531_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local authorities may restrict.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities with respect to a highway under their jurisdiction may by ordinance or resolution prohibit the operation of vehicles upon the highway or impose restrictions as to the weight of vehicles to be operated upon the highway for a total period of not to exceed ninety days in any one calendar year, whenever the highway by reason of deterioration, rain, snow, or other climatic conditions will be seriously damaged or destroyed unless the use of vehicles on the highway is prohibited or the permissible weights reduced. The ordinance or resolution shall not apply to implements of husbandry as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1}}}{{\f5\fs18\hyphpar0\qj{, implements of husbandry loaded on hauling units for transporting the implements to locations for repair, or fire apparatus and road maintenance equipment owned by, under lease to, or used in the performance of a contract with a state or local authority.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates the provisions of the ordinance or resolution shall, upon conviction or a plea of guilty, be subject to a fine determined by dividing the difference between the actual weight and the maximum weight established by the ordinance or resolution by one hundred, and multiplying the quotient by two dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities may issue special permits during periods the restrictions are in effect to permit limited operation of vehicles upon specified routes with loads in excess of any restrictions imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, but not in excess of load restrictions imposed by any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and the authorities shall issue the permits upon a showing that there is a need to move to market farm produce of the type subject to rapid spoilage or loss of value or to move to any farm feeds or fuel for home heating purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a finding that a bridge or culvert does not meet established standards set forth by state and federal authorities, local authorities may by ordinance or resolution impose limitations for an indefinite period of time on the weight of vehicles upon bridges or culverts located on highways under their sole jurisdiction. The limitations shall be effective when signs giving notice of the limitations are erected. The ordinance or resolution shall not apply to implements of husbandry loaded on hauling units for transporting the implements to locations for purposes of repair or to fire apparatus or road maintenance equipment owned by, under lease to, or used in the performance of a contract with a state or local authority.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates the ordinance or resolution shall, upon conviction or a guilty plea, be subject to a fine determined by dividing the difference between the actual weight of the vehicle and the maximum weight allowed by the ordinance or resolution by one hundred and multiplying the quotient by two dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities may issue or approve special permits allowing the operation over a bridge or culvert of vehicles with weights in excess of restrictions imposed under the ordinance or resolution, but not in excess of load restrictions imposed by any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The local authority shall issue such a permit for not to exceed eight weeks upon a showing of agricultural hardship. The operator of a vehicle which is the subject of a permit issued under this paragraph shall carry the permit while operating the vehicle and shall show the permit to any peace officer upon request.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, \'a74996; C31, 35, \'a74686-c1, 4996; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.20;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.471}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 162, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 108, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 208, \'a752, 53}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7100}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.236}}}{{\f5\fs12\hyphpar0\qj{, 321.453}}}{{\f5\fs12\hyphpar0\qj{, 321.463}}}{{\f5\fs12\hyphpar0\qj{, 321.472}}}{{\f5\fs12\hyphpar0\qj{, 321E.17}}}{{\f5\fs12\hyphpar0\qj{, 331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.472}}}{\*\bkmkstart stylerid1_2E532_2E2_2E2}{\*\bkmkend stylerid1_2E532_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Signs posted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The local authority enacting any ordinance or resolution authorized under }{{\f5\fs18\hyphpar0\qj{section 321.471}}}{ shall erect and maintain signs designating the ordinance or resolution at each end of that portion of any highway or at the location of any bridge or culvert affected thereby, and the ordinance or resolution shall not be effective unless and until the signs are erected and maintained.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74686-c1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.21;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.472}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 162, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.236}}}{{\f5\fs12\hyphpar0\qj{, 321.463}}}{{\f5\fs12\hyphpar0\qj{, 331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.473}}}{\*\bkmkstart stylerid1_2E533_2E2_2E2}{\*\bkmkend stylerid1_2E533_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{ Limitations on trucks by local authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities with respect to highways under their jurisdiction may also, by ordinance or resolution, prohibit the operation of trucks or other commercial vehicles, or may impose limitations as to the weight thereof, on designated highways, which prohibitions and limitations shall be designated by appropriate signs placed on such highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities may issue special permits, during periods such restrictions are in effect, to permit limited operation of vehicles upon specified routes with loads in excess of any restrictions imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, but not in excess of load restrictions imposed by any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and such authorities shall issue such permits upon a showing that there is a need to move to market farm produce or to move to any farm, feeds or fuel for home heating purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates the provisions of an ordinance or resolution adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall, upon conviction or a plea of guilty, be subject to a fine determined by dividing the difference between the actual weight and the maximum weight established by the ordinance or resolution by one hundred, and multiplying the quotient by two dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fine for violation of a special permit issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall be based upon the difference between the actual weight of the vehicle and load and the maximum weight allowed by the permit in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.463}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.22;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.473}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 131, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1178, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 49, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.236}}}{{\f5\fs12\hyphpar0\qj{, 331.362}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.474}}}{\*\bkmkstart stylerid1_2E534_2E2_2E2}{\*\bkmkend stylerid1_2E534_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department may restrict.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall have authority, as granted to local authorities, to determine by resolution and to impose restrictions as to the weight of vehicles, except implements of husbandry as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1}}}{{\f5\fs18\hyphpar0\qj{, implements of husbandry loaded on hauling units for transporting the implements to locations for repair, and fire apparatus and road maintenance equipment owned by, under lease to, or used in the performance of a contract with a state or local authority, operated upon any highway under the jurisdiction of the department for a definite period of time not to exceed twelve months. The restrictions shall be effective when signs giving notice of the restrictions and the expiration date of the restrictions are erected upon the affected highway or portion of highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a finding that a bridge or culvert does not meet established standards set forth by state and federal authorities, the department may impose, by resolution, restrictions for an indefinite period of time on the weight of vehicles operated upon bridges or culverts located on highways under its jurisdiction. The restrictions shall be effective when signs giving notice of the restrictions are erected. The restrictions shall not apply to implements of husbandry loaded on hauling units for transporting the implements to locations for purposes of repair or to fire apparatus or road maintenance equipment owned by, under lease to, or used in the performance of a contract with a state or local authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of restrictions imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a triple axle is any group of three or more consecutive axles where the centers of any consecutive axles are more than forty inches apart and where the centers of the extreme axles are more than eighty-four inches apart but not more than one hundred sixty-eight inches apart. Where triple axle restrictions are imposed, the signs erected by the department shall give notice of the restrictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who violates a restriction imposed by resolution pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, upon conviction or a plea of guilty, is subject to a fine determined by dividing the difference between the actual weight of the vehicle and the maximum weight allowed by the restriction by one hundred and multiplying the quotient by two dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue special permits, during periods the restrictions are in effect, to permit limited operation of vehicles upon specified routes with loads in excess of any restrictions imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, but not in excess of load restrictions imposed by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The department shall issue a special permit for not to exceed eight weeks upon a showing of agricultural hardship. The department shall issue special permits to trucks moving farm produce, which decays or loses its value if not speedily put to its intended use, to market upon a showing to the department that there is a requirement for trucking the produce, or to trucks moving any farm feeds or fuel necessary for home heating purposes. The operator of a vehicle which is the subject of a permit issued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall carry the permit while operating the vehicle and shall show the permit to any peace officer upon request.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75066; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.23;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.474}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 110, \'a73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 108, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 208, \'a754, 55}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7119}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.453}}}{{\f5\fs12\hyphpar0\qj{, 321.463}}}{{\f5\fs12\hyphpar0\qj{, 321E.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.475}}}{\*\bkmkstart stylerid1_2E535_2E2_2E2}{\*\bkmkend stylerid1_2E535_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Liability for damage \u8212\'3f rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person driving any vehicle, object, or contrivance upon any highway or highway structure shall be liable for all damage which said highway or structure may sustain as a result of any illegal operation, driving, or moving of such vehicle, object, or contrivance, or as a result of operation, driving, or moving any vehicle, object, or contrivance weighing in excess of the maximum weight in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ but authorized by a special permit issued as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever such driver is not the owner of such vehicle, object, or contrivance, but is so operating, driving, or moving the same with the express or implied permission of said owner, then said owner and driver shall be jointly and severally liable for any such damage. Such damage may be recovered in a civil action brought by the authorities in control of such highway or highway structure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, stating the department\u8217\'3fs policy for recovery of damages to highways or highway structures pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The policy shall exclude from recoverable damages the costs of traffic control at the scene of an accident.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5035.24;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.475}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 67, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.476}}}{\*\bkmkstart stylerid1_2E536_2E2_2E2}{\*\bkmkend stylerid1_2E536_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Stopping, weighing, and inspecting vehicles by state patrol.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the state patrol of the department of public safety is authorized to do any of the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Stop any motor vehicle or trailer on the highways for the purposes of weighing and inspection, to weigh and inspect the same and to enforce the provisions of the motor vehicle laws relating to the registration, size, weight, and load of motor vehicles and trailers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Weigh and inspect vehicles which have moved from a highway onto private property under circumstances which indicate that the load of the vehicle, if any, is substantially the same as the load which the vehicle carried before moving onto the private property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who prevents or in any manner obstructs an officer attempting to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.476}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 85, \'a718}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.481}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.477}}}{\*\bkmkstart stylerid1_2E537_2E2_2E2}{\*\bkmkend stylerid1_2E537_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employees as peace officers }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ maximum age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may designate by resolution certain of its employees upon each of whom there is conferred the authority of a peace officer to investigate and enforce all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Laws relating to motor vehicle records, documents, credentials, procedures, and revenues, including but not limited to crimes and abuse of authority associated with fraud, identity theft, vehicle titles and registration, dealer licenses, and authorized vehicle recycler licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Laws relating to motor vehicle fraud including but not limited to the state and federal odometer laws, including as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 307.37}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.71}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employees designated as peace officers pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall have the same powers conferred by law on peace officers for the use of force in emergent circumstances and the apprehension of violators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employees designated as peace officers pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not exercise the powers of a peace officer set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ within the limits of any city, except as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When so ordered by the direction of the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When request is made by the mayor of any city, with the approval of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When request is made by the sheriff or county attorney of any county, with the approval of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While in the pursuit of law violators or in investigating law violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While making any inspection provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or any additional inspection ordered by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The limitations specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall in no way be construed as a limitation on the ability of employees designated as peace officers pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to use force in defense of life or property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum age for a person employed as a peace officer pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is sixty-five years of age.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.477}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1183, \'a7110}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 149, \'a73, 5}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 85, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a720.3}}}{{\f5\fs12\hyphpar0\qj{, 80B.6}}}{{\f5\fs12\hyphpar0\qj{, 97B.49B}}}{{\f5\fs12\hyphpar0\qj{, 321.481}}}{{\f5\fs12\hyphpar0\qj{, 801.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.478}}}{\*\bkmkstart stylerid1_2E538_2E2_2E2}{\*\bkmkend stylerid1_2E538_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bond.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Prior to entering upon the discharge of the employee\u8217\'3fs duties as such peace officer, each of said designated employees shall furnish to the department a surety bond to the state in the sum of five hundred dollars, conditioned upon the faithful discharge of the peace officer\u8217\'3fs duties.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.478}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.481}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.479}}}{\*\bkmkstart stylerid1_2E539_2E2_2E2}{\*\bkmkend stylerid1_2E539_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Badge of authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall supply each of said employees so designated with a badge of authority, bearing a serial number, which shall be conspicuously displayed by the employee while in the performance of the employee\u8217\'3fs duties as such peace officer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.479}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.481}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.480}}}{\*\bkmkstart stylerid1_2E54_30_2E2_2E2}{\*\bkmkend stylerid1_2E54_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitation on expense.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 85, \'a724}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.481}}}{\*\bkmkstart stylerid1_2E541_2E2_2E2}{\*\bkmkend stylerid1_2E541_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{No impairment of other authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Nothing in }{{\f5\fs18\hyphpar0\qj{sections 321.476 through 321.479}}}{ shall be so construed as to limit or impair the authority or duties of other peace officers in the enforcement of the motor vehicle laws or any portion thereof.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.481}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7154}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 85, \'a720}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E542_2E2_2E1}{CRIMINAL RESPONSIBILITY}{\*\bkmkend stylerid1_2E542_2E2_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.482}}}{\*\bkmkstart stylerid1_2E543_2E2_2E2}{\*\bkmkend stylerid1_2E543_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations \u8212\'3f simple misdemeanors unless otherwise provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is a simple misdemeanor for a person to do an act forbidden or to fail to perform an act required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ unless the violation is by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or other law of this state declared to be a serious or aggravated misdemeanor or a felony. }{{\f5\fs18\hyphpar0\qj{Chapter 232}}}{ has no application in the prosecution of offenses committed in violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ which are simple misdemeanors.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71569, 1571-2a, -m21, -m22, -m26, -m27, -m29, 4808-b; SS15, \'a71571-m12a; C24, \'a74903, 5081, 5089, 13119; C27, \'a74903, 5055-b4, 5081, 5089, 13119; C31, \'a74686-c2, 4903, 5055-b4, 5079-d6, 5081, 5089, 13119; C35, \'a74686-c2, 4903, 4991-f5, 5024-e3, 5055-b4, 5067-e2, 5079-d6, 5081, 5089, 13119; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5036.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.482}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1067, \'a733}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.182}}}{{\f5\fs12\hyphpar0\qj{, 321.482A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.482A}}}{\*\bkmkstart stylerid1_2E544_2E2_2E2}{\*\bkmkend stylerid1_2E544_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations causing serious injury or death \u8212\'3f additional penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding }{{\f5\fs18\hyphpar0\qj{section 321.482}}}{, a person who is convicted of operating a motor vehicle in violation of }{{\f5\fs18\hyphpar0\qj{section 321.256}}}{, }{{\f5\fs18\hyphpar0\qj{321.257}}}{, }{{\f5\fs18\hyphpar0\qj{section 321.275, subsection 4}}}{, }{{\f5\fs18\hyphpar0\qj{section 321.276}}}{, }{{\f5\fs18\hyphpar0\qj{321.297}}}{, }{{\f5\fs18\hyphpar0\qj{321.298}}}{, }{{\f5\fs18\hyphpar0\qj{321.299}}}{, }{{\f5\fs18\hyphpar0\qj{321.302}}}{, }{{\f5\fs18\hyphpar0\qj{321.303}}}{, }{{\f5\fs18\hyphpar0\qj{321.304}}}{, }{{\f5\fs18\hyphpar0\qj{321.305}}}{, }{{\f5\fs18\hyphpar0\qj{321.306}}}{, }{{\f5\fs18\hyphpar0\qj{321.307}}}{, }{{\f5\fs18\hyphpar0\qj{ 321.311}}}{, }{{\f5\fs18\hyphpar0\qj{321.319}}}{, }{{\f5\fs18\hyphpar0\qj{321.320}}}{, }{{\f5\fs18\hyphpar0\qj{321.321}}}{, }{{\f5\fs18\hyphpar0\qj{321.322}}}{, }{{\f5\fs18\hyphpar0\qj{321.323}}}{, }{{\f5\fs18\hyphpar0\qj{321.324}}}{, }{{\f5\fs18\hyphpar0\qj{321.324A}}}{, }{{\f5\fs18\hyphpar0\qj{321.327}}}{, }{{\f5\fs18\hyphpar0\qj{321.329}}}{, }{{\f5\fs18\hyphpar0\qj{321.333}}}{, }{{\f5\fs18\hyphpar0\qj{ section 321.372, subsection 3}}}{, or }{{\f5\fs18\hyphpar0\qj{section 321.449B}}}{, causing serious injury to or the death of another person may be subject to the following penalties in addition to the penalty provided for a scheduled violation in }{{\f5\fs18\hyphpar0\qj{section 805.8A}}}{ or any other penalty provided by law:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a violation causing serious injury, a fine of five hundred dollars or suspension of the violator\u8217\'3fs driver\u8217\'3fs license or operating privileges for not more than ninety days, or both. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fserious injury\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.18}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a violation causing death, a fine of one thousand dollars or suspension of the violator\u8217\'3fs driver\u8217\'3fs license or operating privileges for not more than one hundred eighty days, or both.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1021, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1105, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a7123}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1015, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1083, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1017, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 79, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1166, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 14, \'a711}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Unnumbered paragraph 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.483}}}{\*\bkmkstart stylerid1_2E545_2E2_2E2}{\*\bkmkend stylerid1_2E545_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Felony penalty }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who is convicted of a violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ which constitutes a felony, and for which another punishment is not otherwise provided, is guilty of a class \u8220\'3fD\u8221\'3f felony.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75081; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5036.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.483}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1021, \'a773}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.92}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.484}}}{\*\bkmkstart stylerid1_2E546_2E2_2E2}{\*\bkmkend stylerid1_2E546_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Offenses by owners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for the owner, or any other person, employing or otherwise directing the driver of any vehicle to require or knowingly to permit the operation of such vehicle upon a highway in any manner contrary to law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a vehicle shall not be held responsible for a violation of a provision regulating the stopping, standing, or parking of a vehicle, whether the provision is contained in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{chapter 321L}}}{{\f5\fs18\hyphpar0\qj{, or an ordinance or other regulation or rule, if the owner establishes that at the time of the violation the vehicle was in the custody of an identified person other than the owner pursuant to a lease as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 321F}}}{{\f5\fs18\hyphpar0\qj{ or pursuant to a rental agreement as defined in }}}{{\f5\fs18\hyphpar0\qj{section 516D.3}}}{{\f5\fs18\hyphpar0\qj{. The furnishing to the county attorney where the charge is pending of a copy of the lease prescribed by }}}{{\f5\fs18\hyphpar0\qj{section 321F.6}}}{{\f5\fs18\hyphpar0\qj{ or rental agreement that was in effect for the vehicle at the time of the alleged violation shall be prima facie evidence that the vehicle was in the custody of an identified person other than the owner within the meaning of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Upon receipt of such evidence, the appropriate authority shall dismiss as against the owner of the vehicle any citation issued for a violation within the meaning of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ that occurred while the vehicle was in the custody of the identified person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a peace officer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{ has reasonable cause to believe the driver of a motor vehicle has violated }}}{{\f5\fs18\hyphpar0\qj{section 321.261}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.262}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.264}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.341}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.342}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.343}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.344}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.372}}}{{\f5\fs18\hyphpar0\qj{, the officer may request any owner of the motor vehicle to supply information identifying the driver. When requested, the owner of the vehicle shall identify the driver to the best of the owner\u8217\'3fs ability. However, the owner of the vehicle is not required to supply identification information to the officer if the owner believes the information is self-incriminating.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75085; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5037.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.484}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 49, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1144, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 247, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1152, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1034, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1061, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 151, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 54, \'a75, 12}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.40}}}{{\f5\fs12\hyphpar0\qj{, 321.344A}}}{{\f5\fs12\hyphpar0\qj{, 321.372A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.485}}}{\*\bkmkstart stylerid1_2E547_2E2_2E2}{\*\bkmkend stylerid1_2E547_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice to appear \u8212\'3f promise to appear.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever a peace officer has reasonable cause to believe that a person has violated any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ punishable as a simple, serious, or aggravated misdemeanor, such officer may:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Immediately arrest such person and take the person before a magistrate; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Without arresting the person, either}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare a written citation to appear in court containing the name and address of such person, the driver\u8217\'3fs license number, if any, the registration number, if any, of the person\u8217\'3fs vehicle, the offense charged, and the time and place the person shall appear in court; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare a memorandum of the alleged traffic violation containing the name and address of such person, the registration number, if any, of the person\u8217\'3fs vehicle, the offense alleged to have been committed, and such other information as may be prescribed by the commissioner of public safety with the concurrence of the director of transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the officer prepares either a citation or a memorandum as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the alleged offender shall be requested to sign it. If the person signs, the person may be released without arrest. In case a citation is issued, the signing shall constitute a written promise to appear as stated in the citation. A copy of the citation shall be presented to the person named therein. If a memorandum is prepared, the original shall be retained by the officer, and a copy shall be sent to the department, and a copy shall be presented to the person named therein.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For preparing the summons or memorandum referred to in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, there shall be charged to the person named in the summons or memorandum, upon conviction, a fee of two dollars. The fee shall be assessed as part of the court costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of copies and the form of the citations and memorandums authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be as prescribed by the commissioner of public safety with the concurrence of the director of transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a traffic offense which must be charged upon a uniform citation and complaint as provided in }}}{{\f5\fs18\hyphpar0\qj{section 805.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75082; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5037.02, 5037.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7321.485, 321.486; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.485}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7130, 209}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a772}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.486}}}{\*\bkmkstart stylerid1_2E548_2E2_2E2}{\*\bkmkend stylerid1_2E548_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authorized bond forms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When bond or bail is required under }{{\f5\fs18\hyphpar0\qj{section 811.2}}}{ to guarantee appearance for any offense charged under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the following nonexclusive forms shall be permitted subject to the following limitations:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A current guaranteed arrest bond certificate as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 30}}}{{\f5\fs18\hyphpar0\qj{, shall be considered sufficient surety if the defendant is charged with an offense where the penalty does not exceed one thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A valid credit card, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 537.1301, subsection 17}}}{{\f5\fs18\hyphpar0\qj{, may be used and is sufficient surety when the defendant is charged with a scheduled offense under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{805.8B}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{805.8C}}}{{\f5\fs18\hyphpar0\qj{. The defendant may use a credit card for bail purposes only in accordance with rules of the department of public safety adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5037.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.486}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a772}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 137, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 6, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.487}}}{\*\bkmkstart stylerid1_2E549_2E2_2E2}{\*\bkmkend stylerid1_2E549_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violation of promise to appear.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person willfully violating a citation to appear in court given as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, is guilty of a simple misdemeanor, regardless of the disposition of the charge upon which the person was cited. Venue shall be in the county where the defendant was to appear or in the county where the person resides.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An appearance in response to such citation may be made either in person or by counsel.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5037.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.487}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1140, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.9}}}{{\f5\fs12\hyphpar0\qj{, 805.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.488}}}{\*\bkmkstart stylerid1_2E55_30_2E2_2E2}{\*\bkmkend stylerid1_2E55_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Procedure not exclusive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall govern all peace officers in making arrests without a warrant for violations of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ for offenses committed in their presence, but the procedure prescribed in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not be exclusive of any other method prescribed by law for the arrest and prosecution of a person.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5037.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.488}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7155}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.489}}}{\*\bkmkstart stylerid1_2E551_2E2_2E2}{\*\bkmkend stylerid1_2E551_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record inadmissible in a civil action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No record of the conviction of any person for any violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be admissible as evidence in any court in any civil action.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5037.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.489}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.490}}}{\*\bkmkstart stylerid1_2E552_2E2_2E2}{\*\bkmkend stylerid1_2E552_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conviction not to affect credibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The conviction of a person upon a charge of violating any provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or other traffic regulation less than a felony shall not affect or impair the credibility of such person as a witness in any civil or criminal proceeding.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5037.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.490}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.491}}}{\*\bkmkstart stylerid1_2E553_2E2_2E2}{\*\bkmkend stylerid1_2E553_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Convictions and recommendations for suspension to be reported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every district judge, district associate judge, and judicial magistrate shall keep a full record of every case in which a person is charged with any violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or of any other law regulating the operation of vehicles on highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ten days after the conviction or forfeiture of bail of a person upon a charge of violating any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or other law regulating the operation of vehicles on highways every magistrate of the court or clerk of the district court of record in which the conviction occurred or bail was forfeited shall prepare and immediately forward to the department an abstract of the record of the case. The abstract of the record of the case must be certified by the person preparing it to be true and correct.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certified abstract of the record of the case prepared for the department shall only be available to the public from the department. A noncertified record of conviction or forfeiture of bail shall be available to the public from the judicial branch. The clerk of the district court shall collect a fee of fifty cents for each noncertified copy of any record of conviction or forfeiture of bail furnished to any requester except the department or other local, state, or federal government entity. Moneys collected under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be transferred to the department as appropriated receipts, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{, to enhance the efficiency of the department to process records and information between the department and the Iowa court information system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{, the judicial branch shall be the provider of public electronic access to the clerk\u8217\'3fs records of convictions and forfeitures of bail through the Iowa court information system and shall, if all such records are provided monthly to a vendor, collect a fee from such vendor for the period beginning on July 1, 1997, and ending on June 30, 1999, which is the greater of three thousand dollars per month or the actual direct cost of providing the records. On and after July 1, 1999, if all such records are provided monthly to a vendor, the judicial branch shall collect a fee from such vendor which is the greater of ten thousand dollars per month or the actual direct cost of providing the records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The abstract must be made upon a form furnished by the department or by copying a uniform citation and complaint or by using an electronic process which accurately reproduces or forms a durable medium for accurately and legibly reproducing an unaltered image or reproduction of the citation, and must include the name and address of the party charged, the registration number of the vehicle involved, the nature of the offense, the date of hearing, the plea, the judgment, or whether the bail was forfeited, the amount of the fine or forfeiture, and any court recommendation, if any, that the person\u8217\'3fs driver\u8217\'3fs license be suspended. The department shall consider and act upon the recommendation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every clerk of a court of record shall also forward a like report to the department upon the conviction of any person of manslaughter or other felony in the commission of which a vehicle was used.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The failure, refusal, or neglect of an officer to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall constitute misconduct in office and shall be grounds for removal from office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All abstracts received by the department under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be open to public inspection during reasonable business hours.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m23; C24, 27, 31, 35, \'a75076 \u8211\'3f 5078; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5037.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.491}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 16, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1074, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1218, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1047, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1178, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 96, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 207, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7166}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.206}}}{{\f5\fs12\hyphpar0\qj{, 321.555}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(51)}}}{{\f5\fs12\hyphpar0\qj{, 805.6}}}{{\f5\fs12\hyphpar0\qj{, 805.9}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E554_2E2_2E1}{LAW ENFORCEMENT}{\*\bkmkend stylerid1_2E554_2E2_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.492}}}{\*\bkmkstart stylerid1_2E555_2E2_2E2}{\*\bkmkend stylerid1_2E555_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Peace officers\u8217\'3f authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer is authorized to stop a vehicle to require exhibition of the driver\u8217\'3fs license of the driver, to serve a summons or memorandum of traffic violation, to inspect the condition of the vehicle, to inspect the vehicle with reference to size, weight, cargo, log book, bills of lading or other manifest of employment, tires, and safety equipment, or to inspect the registration certificate, the compensation certificate, travel order, or permit of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer having probable cause to stop a vehicle may require exhibition of the proof of financial liability coverage card issued for the vehicle if the vehicle is a motor vehicle registered in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All peace officers as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f, \u8220\'3fb\u8221\'3f, \u8220\'3fc\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may, having reasonable grounds that equipment violations exist, conduct spot inspections.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may designate employees under the supervision of the department\u8217\'3fs administrator of motor vehicles to conduct spot inspections.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.492}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71936}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 139, \'a76, 7, 17, 18}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1100, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1121, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a751}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.492A}}}{\*\bkmkstart stylerid1_2E556_2E2_2E2}{\*\bkmkend stylerid1_2E556_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Quotas on citations prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A political subdivision or agency of the state shall not order, mandate, require, or in any other manner, directly or indirectly, suggest to a peace officer employed by the political subdivision or agency that the peace officer shall issue a certain number of traffic citations, police citations, memorandums of traffic violations, or memorandums of faulty equipment on a daily, weekly, monthly, quarterly, or yearly basis.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 226, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1034, \'a725}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.492B}}}{\*\bkmkstart stylerid1_2E557_2E2_2E2}{\*\bkmkend stylerid1_2E557_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of unmanned aerial vehicle for traffic law enforcement prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The state or a political subdivision of the state shall not use an unmanned aerial vehicle for traffic law enforcement.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1111, \'a71}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E558_2E1_2E1}{CIVIL LIABILITY}{\*\bkmkend stylerid1_2E558_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.493}}}{\*\bkmkstart stylerid1_2E559_2E2_2E2}{\*\bkmkend stylerid1_2E559_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Liability for damages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOwner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the person to whom the certificate of title for the vehicle has been issued or assigned or to whom a manufacturer\u8217\'3fs or importer\u8217\'3fs certificate of origin for the vehicle has been delivered or assigned. However, if the vehicle is leased, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fowner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the person to whom the vehicle is leased, not the person to whom the certificate of title for the vehicle has been issued or assigned or to whom the manufacturer\u8217\'3fs or importer\u8217\'3fs certificate of origin for the vehicle has been delivered or assigned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLeased\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the transfer of the possession or right to possession of a vehicle to a lessee for a valuable consideration for a continuous period of twelve months or more, pursuant to a written agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in all cases where damage is done by any motor vehicle by reason of negligence of the driver, and driven with the consent of the owner, the owner of the motor vehicle shall be liable for such damage.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a vehicle with a gross vehicle weight rating of seven thousand five hundred pounds or more who rents the vehicle for less than a year under an agreement which requires an insurance policy covering at least the minimum levels of financial responsibility prescribed by law, shall not be deemed to be the owner of the vehicle for the purpose of determining financial responsibility for the operation of the vehicle or for the acts of the operator in connection with the vehicle\u8217\'3fs operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has made a bona fide sale or transfer of the person\u8217\'3fs right, title, or interest in or to a motor vehicle and who has delivered possession of the motor vehicle to the purchaser or transferee shall not be liable for any damage thereafter resulting from negligent operation of the motor vehicle by another, but the purchaser or transferee to whom possession was delivered shall be deemed the owner. The provisions of}}}{{\f5\fs18\hyphpar0\qj{ section 321.45, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall not apply in determining, for the purpose of fixing liability under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, whether such sale or transfer was made.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74964, 5026; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5002.07, 5037.09;}}}{ C46, 50, 54, 58, 62, \'a7321.51, 321.493; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.493}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 136, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7101}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.45}}}{{\f5\fs12\hyphpar0\qj{, 321.344A}}}{{\f5\fs12\hyphpar0\qj{, 321.372A}}}{{\f5\fs12\hyphpar0\qj{, 321A.1}}}{{\f5\fs12\hyphpar0\qj{, 321P.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Exemption from execution denied, }{{\f5\fs12\hyphpar0\qj{\'a7627.7}}}{ }\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.494 through 321.497}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E561_2E1_2E1}{ACTIONS AGAINST NONRESIDENTS}{\*\bkmkend stylerid1_2E561_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.498}}}{\*\bkmkstart stylerid1_2E562_2E2_2E2}{\*\bkmkend stylerid1_2E562_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legal effect of use and operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The acceptance by any nonresident of this state of the privileges extended by the laws of this state to nonresident operators or owners of operating a motor vehicle, or having the same operated, within this state shall be deemed to be all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agreement by the nonresident that the nonresident shall be subject to the jurisdiction of the district court of this state over all civil actions and proceedings against the nonresident for damages to person or property growing or arising out of such use and operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An appointment by such nonresident of the director of this state as the nonresident\u8217\'3fs lawful attorney upon whom may be served all original notices of suit pertaining to such actions and proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agreement by such nonresident that any original notice of suit so served shall be of the same legal force and validity as if personally served on the nonresident in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNonresident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include any person who was, at the time of the accident or event, a resident of the state of Iowa but who removed from the state before the commencement of such action or proceedings.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of the vehicle whether it is being used and operated personally by the owner, or by the owner\u8217\'3fs agent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agent using and operating the vehicle for the agent\u8217\'3fs principal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who is in charge of the vehicle and of the use and operation thereof with the express or implied consent of the owner.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d11; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.498}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1069, \'a7102}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a784}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a778}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.499}}}{\*\bkmkstart stylerid1_2E563_2E2_2E2}{\*\bkmkend stylerid1_2E563_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f defined.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 90, \'a7216}}}{{\f5\fs18\hyphpar0\qj{. See }}}{{\f5\fs18\hyphpar0\qj{\'a7321.498}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.500}}}{\*\bkmkstart stylerid1_2E564_2E2_2E2}{\*\bkmkend stylerid1_2E564_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Original notice \u8212\'3f form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The original notice of suit filed with the director of transportation against a nonresident shall be in form and substance the same as provided in }\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.1901}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{, form 2, Iowa court rules.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d13; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.500}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a773}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1119, \'a7106}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.501}}}{\*\bkmkstart stylerid1_2E565_2E2_2E2}{\*\bkmkend stylerid1_2E565_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Manner of service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The plaintiff in any action against a nonresident shall cause the original notice of suit to be served by doing all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By filing a copy of the original notice of suit with the director, together with a fee of two dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By mailing to the defendant, and to each of the defendants if there are more than one, within ten days after said filing with the director, by restricted certified mail addressed to the defendant at the defendant\u8217\'3fs last known residence or place of abode, a notification of the filing with the director.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d14; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.501}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7178}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a774}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.502}}}{{\f5\fs12\hyphpar0\qj{, 321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.502}}}{\*\bkmkstart stylerid1_2E566_2E2_2E2}{\*\bkmkend stylerid1_2E566_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notification to nonresident \u8212\'3f form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The notification, provided for in }{{\f5\fs18\hyphpar0\qj{section 321.501}}}{, shall be in substantially the following form, to wit:}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{To }{{\f5\fs18\hyphpar0\qj{........................}}}{ (Here insert the name of each defendant and the defendant\u8217\'3fs residence or last known place of abode as definitely as known.)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{You will take notice that an original notice of suit against you, a copy of which is hereto attached, was duly served upon you at Des Moines, Iowa, by filing a copy of said notice on the }{{\f5\fs18\hyphpar0\qj{............}}}{ day of }{{\f5\fs18\hyphpar0\qj{................}}}{, }{{\f5\fs18\hyphpar0\qj{............}}}{, with the director of transportation of the state of Iowa.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Dated at }{{\f5\fs18\hyphpar0\qj{........................}}}{, Iowa, this }{{\f5\fs18\hyphpar0\qj{............}}}{ day of }{{\f5\fs18\hyphpar0\qj{................}}}{, }{{\f5\fs18\hyphpar0\qj{............}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{....................................}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Plaintiff.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{By}{{\f5\fs18\hyphpar0\qj{............................}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{Attorney for plaintiff.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d15; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.502}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 24, \'a746}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.504}}}{{\f5\fs12\hyphpar0\qj{, 321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.503}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.504}}}{\*\bkmkstart stylerid1_2E568_2E2_2E2}{\*\bkmkend stylerid1_2E568_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Optional notification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In lieu of mailing the notification described in }{{\f5\fs18\hyphpar0\qj{section 321.502}}}{ to the defendant in a foreign state, the plaintiff may cause the notification to be personally served in the foreign state on the defendant by any adult person not a party to the suit, by delivering the notification to the defendant or by offering to make such delivery in case the defendant refuses to accept delivery.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d17; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.504}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7156}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a759}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.505}}}{\*\bkmkstart stylerid1_2E569_2E2_2E2}{\*\bkmkend stylerid1_2E569_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Proof of service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Proof of the filing of a copy of said original notice of suit with the director, and proof of the mailing or personal delivery of said notification to said nonresident shall be made by affidavit of the party doing said acts. All affidavits of service shall be endorsed upon or attached to the originals of the papers to which they relate. All proofs of service, including the restricted certified mail return receipt, shall be forthwith filed with the clerk of the district court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d18; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.505}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.506}}}{\*\bkmkstart stylerid1_2E57_30_2E2_2E2}{\*\bkmkend stylerid1_2E57_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Actual service within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ relative to service of original notice of suit on nonresidents shall not be deemed to prevent actual personal service in this state upon the nonresident in the time, manner, form, and under the conditions provided for service on residents.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d19; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.506}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a7123}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.507}}}{\*\bkmkstart stylerid1_2E571_2E2_2E2}{\*\bkmkend stylerid1_2E571_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Venue of actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Actions against nonresidents as contemplated by }{{\f5\fs18\hyphpar0\qj{sections 321.498}}}{, }{{\f5\fs18\hyphpar0\qj{321.500 through 321.502}}}{, }{{\f5\fs18\hyphpar0\qj{321.504 through 321.506}}}{, and }{{\f5\fs18\hyphpar0\qj{321.508 through 321.512}}}{ may be brought in the county of which plaintiff is a resident, or in the county in which the injury was received, or damage done.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d20; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.507}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7179}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.511}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.508}}}{\*\bkmkstart stylerid1_2E572_2E2_2E2}{\*\bkmkend stylerid1_2E572_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Continuances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The court in which such action is pending shall grant such continuances to a nonresident defendant as may be necessary to afford the nonresident defendant reasonable opportunity to defend said action.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d21; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.508}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.509}}}{\*\bkmkstart stylerid1_2E573_2E2_2E2}{\*\bkmkend stylerid1_2E573_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty of director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall keep a record of all notices of suit filed with the director, shall not permit said filed notices to be taken from the director\u8217\'3fs office except on an order of court, and shall, on request, and without fee, furnish any defendant with a certified copy of the notice in which the person is defendant.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d22; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.12;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.509}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.510}}}{\*\bkmkstart stylerid1_2E574_2E2_2E2}{\*\bkmkend stylerid1_2E574_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expenses and attorney fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If judgment is rendered against the plaintiff, upon the trial of said action, said judgment shall include the reasonable expenses incurred by the defendant and the defendant\u8217\'3fs attorney in appearing to and defending against said action, provided that in the judgment of the trial court said action was commenced maliciously or without probable cause.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d23; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.510}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}{{\f5\fs12\hyphpar0\qj{, 321.511}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.511}}}{\*\bkmkstart stylerid1_2E575_2E2_2E2}{\*\bkmkend stylerid1_2E575_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dismissal }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The dismissal of an action after the nonresident has entered a general appearance under the substituted service authorized in }{{\f5\fs18\hyphpar0\qj{section 321.498}}}{, }{{\f5\fs18\hyphpar0\qj{sections 321.500 through 321.502}}}{, and }{{\f5\fs18\hyphpar0\qj{sections 321.504 through 321.510}}}{, shall bar the recommencement of the same action against the same defendant unless the recommenced action is accompanied by actual personal service of the original notice of suit on the defendant in this state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75079-d24; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5038.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.511}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7157}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.512}}}{\*\bkmkstart stylerid1_2E576_2E2_2E2}{\*\bkmkend stylerid1_2E576_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Action against insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any contract insuring the liability of a nonresident motorist in Iowa shall, in the event of the death of said nonresident, be considered an asset of the nonresident\u8217\'3fs estate having a situs in Iowa in any civil action arising out of a motor vehicle accident in which said nonresident may be liable.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.512}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.507}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.513}}}{\*\bkmkstart stylerid1_2E577_2E2_2E2}{\*\bkmkend stylerid1_2E577_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonresident traffic violator compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E577_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E577_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Authority to compact.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may enter into nonresident violator compacts with other jurisdictions. The compacts shall contain in substantially the same form the following provisions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E577_2E3_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E577_2E3_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of the nonresident violator compact, unless the context requires otherwise:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCitation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a summons, ticket, or other official document issued by a police officer for a traffic violation containing an order which requires the motorist to respond.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCollateral\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means cash or other security deposited to secure an appearance for trial, following the issuance by a police officer of a citation for a traffic violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCourt\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a court of law or traffic tribunal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDriver\u8217\'3fs license\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a license or privilege to operate a motor vehicle issued under the laws of the home jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHome jurisdiction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the jurisdiction that issued the driver\u8217\'3fs license of the traffic violator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIssuing jurisdiction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the jurisdiction in which the traffic citation was issued to the motorist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fJurisdiction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a state, territory, or possession of the United States, the District of Columbia, or the Commonwealth of Puerto Rico.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMotorist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a driver of a motor vehicle operating in a party jurisdiction other than the home jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal recognizance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an agreement by a motorist made at the time of issuance of the traffic citation that the motorist will comply with the terms of that traffic citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPolice officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a peace officer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{ authorized by the party jurisdiction to issue a citation for a traffic violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTerms of the citation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those options expressly stated upon the citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E577_2E3_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E577_2E3_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Procedure for issuing jurisdiction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When issuing a citation for a traffic violation, a police officer shall issue the citation to a motorist who possesses a driver\u8217\'3fs license issued by a party jurisdiction and shall not, except as provided in subparagraph (2) of this paragraph, require the motorist to post collateral to secure appearance, if the officer receives the motorist\u8217\'3fs signed personal recognizance that the motorist will comply with the terms of the citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless prohibited by law, personal recognizance is acceptable. If mandatory appearance is required by law, the appearance must take place immediately following issuance of the citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon failure of a motorist to comply with the terms of a traffic citation, the appropriate official shall report the failure to comply to the licensing authority of the jurisdiction in which the traffic citation was issued, and that licensing authority shall transmit the information contained in the report to the licensing authority in the home jurisdiction of the motorist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensing authority of the issuing jurisdiction shall not suspend for failure to comply with the terms of a traffic citation the driving privilege of a motorist for whom a report has been transmitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensing authority of the issuing jurisdiction shall not transmit a report on a violation if the date of transmission is more than six months after the date the traffic citation was issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensing authority of the issuing jurisdiction shall not transmit a report on a violation where the date of issuance of the citation predates the most recent effective date of entry for the two jurisdictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E577_2E3_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E577_2E3_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Procedure for home jurisdiction.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a report of a failure to comply, the licensing authority of the home jurisdiction shall notify the motorist and initiate a suspension action, in accordance with the home jurisdiction\u8217\'3fs procedures, to suspend the motorist\u8217\'3fs driver\u8217\'3fs license until satisfactory evidence of compliance with the terms of the traffic citation has been furnished to the home jurisdiction licensing authority. Due process safeguards shall be accorded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{\*\bkmkstart stylerid1_2E577_2E3_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E577_2E3_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Exceptions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of the nonresident violator compact do not apply to parking or standing violations, highway weight limit violations, and violations of law governing the transportation of hazardous materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{\*\bkmkstart stylerid1_2E577_2E3_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E577_2E3_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Additional provisions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonresident violator compact may contain other provisions the director reasonably determines are necessary or appropriate for inclusion in the compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E577_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E577_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rules.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ as necessary to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E577_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E577_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Enforcement.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The agencies and officers of this state and its political subdivisions shall enforce the nonresident violator compacts and shall do all things appropriate to accomplish their purpose and intent.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7321.513}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71937}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.203}}}{{\f5\fs12\hyphpar0\qj{, 321.210}}}{{\f5\fs12\hyphpar0\qj{, 321.212}}}{{\f5\fs12\hyphpar0\qj{, 321.215}}}{{\f5\fs12\hyphpar0\qj{, 321.218}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E578_2E1_2E1}{AUTOMATED DRIVING SYSTEMS}{\*\bkmkend stylerid1_2E578_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.514}}}{\*\bkmkstart stylerid1_2E579_2E2_2E2}{\*\bkmkend stylerid1_2E579_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this section}}}{ and }{{\f5\fs18\hyphpar0\qj{sections 321.515 through 321.519}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAutomated driving system\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the hardware and software collectively capable of performing the entire dynamic driving task on a sustained basis, regardless of whether the system is limited to a specific operational design domain, if any.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConventional human driver\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a natural person who manually controls the in-vehicle accelerating, braking, steering, and transmission gear selection input devices in order to operate a motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDriverless-capable vehicle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a system-equipped vehicle capable of performing the entire dynamic driving task within the automated driving system\u8217\'3fs operational design domain, if any, including but not limited to achievement of a minimal risk condition without intervention or supervision by a conventional human driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDynamic driving task\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all real-time operational and tactical functions required to operate a motor vehicle on a highway in traffic within an automated driving system\u8217\'3fs specific operational design domain, if any. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDynamic driving task\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include any strategic function such as trip scheduling or the selection of destinations and waypoints.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMinimal risk condition\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a reasonably safe state to which an automated driving system brings a system-equipped vehicle upon experiencing a performance-relevant failure of the system that renders the system unable to perform the entire dynamic driving task, including but not limited to removing the vehicle to the nearest shoulder if the vehicle is capable of doing so, bringing the vehicle to a complete stop, and activating the vehicle\u8217\'3fs emergency signal lamps.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOn-demand driverless-capable vehicle network\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a transportation service network that uses a software application or other digital means to dispatch driverless-capable vehicles for the purposes of transporting persons or goods, including transportation for hire as defined in }}}{{\f5\fs18\hyphpar0\qj{section 325A.1}}}{{\f5\fs18\hyphpar0\qj{, and public transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOperational design domain\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a set of constraints used to define the domain under which an automated driving system is designed to properly operate, including but not limited to types of highways, speed ranges, environmental conditions such as weather or time of day, and other constraints.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSystem-equipped vehicle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a motor vehicle equipped with an automated driving system.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 75, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.519}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.515}}}{\*\bkmkstart stylerid1_2E58_30_2E2_2E2}{\*\bkmkend stylerid1_2E58_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A driverless-capable vehicle may operate on the public highways of this state without a conventional human driver physically present in the vehicle, if the vehicle meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vehicle is capable of achieving a minimal risk condition if a malfunction of the automated driving system occurs that renders the system unable to perform the entire dynamic driving task within the system\u8217\'3fs intended operational design domain, if any.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While in driverless operation, the vehicle is capable of operating in compliance with the applicable traffic and motor vehicle safety laws and regulations of this state that govern the performance of the dynamic driving task, unless an exemption has been granted to the vehicle by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vehicle has been certified by the vehicle\u8217\'3fs manufacturer to be in compliance with all applicable federal motor vehicle safety standards, except to the extent an exemption has been granted for the vehicle under applicable federal law or by the national highway traffic safety administration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a system-equipped vehicle capable of performing the entire dynamic driving task within the automated driving system\u8217\'3fs operational design domain on the public highways of this state while a conventional human driver is present in the vehicle shall be lawful. During such operation, the conventional human driver shall possess a valid driver\u8217\'3fs license pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.174}}}{{\f5\fs18\hyphpar0\qj{ and shall be subject to the financial liability coverage requirements and penalties set forth under }}}{{\f5\fs18\hyphpar0\qj{section 321.20B}}}{{\f5\fs18\hyphpar0\qj{. The conventional human driver shall operate the system-equipped vehicle according to the manufacturer\u8217\'3fs requirements and specifications, and shall regain manual control of the vehicle when prompted by the automated driving system.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An automated driving system, while engaged, shall be designed to operate within the system\u8217\'3fs operational design domain in compliance with the applicable traffic and motor vehicle safety laws and regulations of this state that govern the performance of the dynamic driving task, unless an exemption has been granted to the vehicle by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the motor vehicle laws of this state shall not be construed to require a conventional human driver to operate a driverless-capable vehicle that is being operated by an automated driving system. The automated driving system, while engaged, shall be deemed to fulfill any physical acts required of a conventional human driver to perform the dynamic driving task.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 75, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.514}}}{{\f5\fs12\hyphpar0\qj{, 321.519}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.516}}}{\*\bkmkstart stylerid1_2E581_2E2_2E2}{\*\bkmkend stylerid1_2E581_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Before a system-equipped vehicle is allowed to operate on the public highways of this state, the owner shall obtain financial liability coverage for the vehicle. A system-equipped vehicle shall not operate on the highways of this state unless financial liability coverage is in effect for the vehicle and unless proof of financial liability coverage is carried in the vehicle pursuant to }{{\f5\fs18\hyphpar0\qj{section 321.20B}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 75, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.514}}}{{\f5\fs12\hyphpar0\qj{, 321.519}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.517}}}{\*\bkmkstart stylerid1_2E582_2E2_2E2}{\*\bkmkend stylerid1_2E582_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Accidents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In the event of an accident in which a system-equipped vehicle is involved, the vehicle shall remain at the scene of the accident and the operation of the vehicle shall otherwise comply with }{{\f5\fs18\hyphpar0\qj{sections 321.261 through 321.273}}}{ where applicable and to the extent possible, and the vehicle\u8217\'3fs owner or a person on behalf of the vehicle\u8217\'3fs owner shall promptly report the accident to law enforcement authorities. If a system-equipped vehicle fails to remain at the scene of an accident or the operation of the vehicle fails to otherwise comply with }{{\f5\fs18\hyphpar0\qj{sections 321.261 through 321.273}}}{ where applicable and to the extent possible as required by }{{\f5\fs18\hyphpar0\qj{this section}}}{, the vehicle\u8217\'3fs failure shall be imputed to the vehicle\u8217\'3fs owner, and the vehicle\u8217\'3fs owner may be charged and convicted of a violation of }{{\f5\fs18\hyphpar0\qj{sections 321.261 through 321.273}}}{, as applicable.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 75, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.514}}}{{\f5\fs12\hyphpar0\qj{, 321.519}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.518}}}{\*\bkmkstart stylerid1_2E583_2E2_2E2}{\*\bkmkend stylerid1_2E583_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{On-demand driverless-capable vehicle network.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person may operate an on-demand driverless-capable vehicle network. An on-demand driverless-capable vehicle network may be used to facilitate the transportation of persons or goods, including transportation for hire as defined in }{{\f5\fs18\hyphpar0\qj{section 325A.1}}}{, and public transportation. An on-demand driverless-capable vehicle network may connect passengers to driverless-capable vehicles either exclusively or as part of a digital network that also connects passengers to conventional human drivers who provide transportation services, consistent with }{{\f5\fs18\hyphpar0\qj{chapter 321N}}}{ or any other applicable laws, in vehicles that are not driverless-capable vehicles.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 75, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.514}}}{{\f5\fs12\hyphpar0\qj{, 321.519}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.519}}}{\*\bkmkstart stylerid1_2E584_2E2_2E2}{\*\bkmkend stylerid1_2E584_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Automated driving systems and system-equipped vehicles shall be governed by }}}{{\f5\fs18\hyphpar0\qj{sections 321.514 through 321.518}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and all applicable traffic and motor vehicle safety laws and regulations of this state. Automated driving systems and system-equipped vehicles shall be regulated exclusively by the department. The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{sections 321.514 through 321.518}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A political subdivision of the state shall not impose requirements, including but not limited to performance standards, specific to the operation of system-equipped vehicles, automated driving systems, or on-demand driverless-capable vehicle networks that are in addition to the requirements set forth under }}}{{\f5\fs18\hyphpar0\qj{sections 321.514 through 321.518}}}{{\f5\fs18\hyphpar0\qj{. A political subdivision of the state shall not impose a tax on system-equipped vehicles, automated driving systems, or on-demand driverless-capable vehicle networks where such tax relates specifically to the operation of system-equipped vehicles, automated driving systems, or on-demand driverless-capable vehicle networks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sections 321.514 through 321.518}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ do not apply to personal delivery devices operated pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 321O}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 75, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 119, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.514}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.520 through 321.554}}}{Reserved.}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E586_2E1_2E1}{HABITUAL OFFENDER}{\*\bkmkend stylerid1_2E586_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.555}}}{\*\bkmkstart stylerid1_2E587_2E2_2E2}{\*\bkmkend stylerid1_2E587_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Habitual offender defined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this section}}}{ and }{{\f5\fs18\hyphpar0\qj{sections 321.556 through 321.562}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhabitual offender\u8221\'3f}}}{ means any person who has accumulated convictions for separate and distinct offenses described in }{{\f5\fs18\hyphpar0\qj{subsection 1, 2, or 3}}}{, committed after July 1, 1974, for which final convictions have been rendered, as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Three or more of the following offenses, either singularly or in combination, within a six-year period:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Manslaughter resulting from the operation of a motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a motor vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or its predecessor statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Driving a motor vehicle while the person\u8217\'3fs driver\u8217\'3fs license is suspended, denied, revoked, or barred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Perjury or the making of a false affidavit or statement under oath to the department of public safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An offense punishable as a felony under the motor vehicle laws of Iowa or any felony in the commission of which a motor vehicle is used.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure to stop and leave information, to render aid, or to otherwise comply with }}}{{\f5\fs18\hyphpar0\qj{sections 321.261}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.263}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eluding or attempting to elude a pursuing law enforcement vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.279}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Serious injury by a vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 707.6A, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six or more of any separate and distinct offenses within a two-year period in the operation of a motor vehicle, which are required to be reported to the department by }}}{{\f5\fs18\hyphpar0\qj{section 321.491}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 321C}}}{{\f5\fs18\hyphpar0\qj{, except equipment violations, parking violations as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.210}}}{{\f5\fs18\hyphpar0\qj{, violations of registration laws, violations of }}}{{\f5\fs18\hyphpar0\qj{sections 321.445}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.446}}}{{\f5\fs18\hyphpar0\qj{, operating a vehicle with an expired license or permit, failure to appear, weights and measures violations and speeding violations of less than fifteen miles per hour over the legal speed limit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The offenses included in }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ shall be deemed to include offenses under any valid town, city or county ordinance paralleling and substantially conforming to the provisions of the Code concerning such offenses.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.555}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1167, \'a710}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1016, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1022, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1009, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1220, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 296, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a774 \u8211\'3f 76}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 87, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1105, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 180, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 14, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.213}}}{{\f5\fs12\hyphpar0\qj{, 321.215}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}{{\f5\fs12\hyphpar0\qj{, 321.560}}}{{\f5\fs12\hyphpar0\qj{, 321.562}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.556}}}{\*\bkmkstart stylerid1_2E588_2E2_2E2}{\*\bkmkend stylerid1_2E588_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice and hearing \u8212\'3f findings and order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, upon review of the record of convictions of any person, the department determines that the person appears to be a habitual offender, the department shall immediately notify the person in writing and afford the licensee an opportunity for a hearing. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, the notice shall meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.16}}}{{\f5\fs18\hyphpar0\qj{ and shall be served in the manner provided in that section. Service of notice on any nonresident of this state may be made in the same manner as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.498 through 321.506}}}{{\f5\fs18\hyphpar0\qj{. A peace officer stopping a person for whom a notice has been issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may personally serve the notice upon forms approved by the department to satisfy the notice requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A peace officer may confiscate the driver\u8217\'3fs license of a person if the license has been revoked or has been suspended subsequent to a hearing and the person has not forwarded the driver\u8217\'3fs license to the department as required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The hearing shall be conducted as provided in }}}{{\f5\fs18\hyphpar0\qj{section 17A.12}}}{{\f5\fs18\hyphpar0\qj{ before the department in the county where the alleged events occurred, unless the director and the person agree that the hearing may be held in some other county, or the hearing may be held by telephone conference at the discretion of the agency conducting the hearing. The hearing shall be recorded and its scope shall be limited to the issue of whether the person notified is a habitual offender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An abstract certified by the director of transportation may be admitted as evidence as provided in }}}{{\f5\fs18\hyphpar0\qj{section 622.43}}}{{\f5\fs18\hyphpar0\qj{, at the hearing, and shall be prima facie evidence that the person named in the abstract was duly convicted by the court in which the conviction or holding was made of each offense shown by the abstract. If the person named in the abstract denies conviction of any of the relevant convictions contained in the abstract, the person shall have the burden of proving that the conviction is untrue. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a conviction is relevant if it is for one of the offenses listed in }}}{{\f5\fs18\hyphpar0\qj{section 321.555}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department finds that the person is not the same person named in the abstract, or otherwise concludes that the person is not a habitual offender as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.555}}}{{\f5\fs18\hyphpar0\qj{, the department shall issue a decision dismissing the proceedings. If the department\u8217\'3fs findings and conclusions are that the person is a habitual offender, the department shall issue an order prohibiting the person from operating a motor vehicle on the highways of this state for the period specified in }}}{{\f5\fs18\hyphpar0\qj{section 321.560}}}{{\f5\fs18\hyphpar0\qj{. If a person is found to be a habitual offender, the person shall surrender all licenses or permits to operate a motor vehicle in this state to the department. A person who is found to be a habitual offender may be assessed a fee by the department to cover the costs of the habitual offender proceedings. Fees assessed shall be paid before the person may be issued a license or permit to operate a motor vehicle in this state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.556}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 143, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1073, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1133, \'a713}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 32, \'a746}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.555}}}{{\f5\fs12\hyphpar0\qj{, 321.562}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.557 through 321.559}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.560}}}{\*\bkmkstart stylerid1_2E59_30_2E2_2E2}{\*\bkmkend stylerid1_2E59_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Period of revocation \u8212\'3f temporary restricted licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license to operate a motor vehicle in this state shall not be issued to any person declared to be a habitual offender under }}}{{\f5\fs18\hyphpar0\qj{section 321.555, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, for a period of not less than two years nor more than six years from the date of the final decision of the department under }}}{{\f5\fs18\hyphpar0\qj{section 17A.19}}}{{\f5\fs18\hyphpar0\qj{ or the date on which the district court upholds the final decision of the department, whichever occurs later.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A temporary restricted license may be issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.215, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, to a person declared to be a habitual offender under }}}{{\f5\fs18\hyphpar0\qj{section 321.555, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A temporary restricted license may be issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.20}}}{{\f5\fs18\hyphpar0\qj{ to a person declared to be a habitual offender due to a combination of the offenses listed under }}}{{\f5\fs18\hyphpar0\qj{section 321.555, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license to operate a motor vehicle in this state shall not be issued to any person declared to be a habitual offender under }}}{{\f5\fs18\hyphpar0\qj{section 321.555, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for a period of one year from the date of the final decision of the department under }}}{{\f5\fs18\hyphpar0\qj{section 17A.19}}}{{\f5\fs18\hyphpar0\qj{ or the date on which the district court upholds the final decision of the department, whichever occurs later.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ that establish a point system which shall be used to determine the period for which a person who is declared to be a habitual offender under }}}{{\f5\fs18\hyphpar0\qj{section 321.555, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall not be issued a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is determined to be a habitual offender while the person\u8217\'3fs license is already revoked for being a habitual offender under }}}{{\f5\fs18\hyphpar0\qj{section 321.555}}}{{\f5\fs18\hyphpar0\qj{ shall not be issued a license to operate a motor vehicle in this state for a period of not less than two years nor more than six years. The revocation period may commence either on the date of the final decision of the department under }}}{{\f5\fs18\hyphpar0\qj{section 17A.19}}}{{\f5\fs18\hyphpar0\qj{ or the date on which the district court upholds the final decision of the department, whichever occurs later, or on the date the previous revocation expires.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.560}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 143, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1034, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1138, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7154}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1097, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1110, \'a71, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.215}}}{{\f5\fs12\hyphpar0\qj{, 321.555}}}{{\f5\fs12\hyphpar0\qj{, 321.556}}}{{\f5\fs12\hyphpar0\qj{, 321.561}}}{{\f5\fs12\hyphpar0\qj{, 321.562}}}{{\f5\fs12\hyphpar0\qj{, 321J.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.561}}}{\*\bkmkstart stylerid1_2E591_2E2_2E2}{\*\bkmkend stylerid1_2E591_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Punishment for violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be unlawful for any person found to be a habitual offender to operate any motor vehicle in this state during the period of time specified in }{{\f5\fs18\hyphpar0\qj{section 321.560}}}{ except for a habitual offender who has been granted a temporary restricted license pursuant to }{{\f5\fs18\hyphpar0\qj{section 321.215, subsection 2}}}{. A person violating }{{\f5\fs18\hyphpar0\qj{this section}}}{ commits an aggravated misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.561}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 34, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 143, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1034, \'a727}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 132, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.555}}}{{\f5\fs12\hyphpar0\qj{, 321.562}}}{{\f5\fs12\hyphpar0\qj{, 321J.4B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.562}}}{\*\bkmkstart stylerid1_2E592_2E2_2E2}{\*\bkmkend stylerid1_2E592_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rule of construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Nothing in }{{\f5\fs18\hyphpar0\qj{sections 321.555 through 321.561}}}{ or }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be construed as amending, modifying, or repealing any existing law of this state or any ordinance of any political subdivision relating to the operation of motor vehicles, the licensing of persons to operate motor vehicles, or providing penalties for the violation thereof.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.562}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1092, \'a780}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.555}}}\par}}