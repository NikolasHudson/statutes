, ch 1118, \'a7155}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 38, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1080, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71057, 1058, 1418}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 144, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1083, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a79, 26}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 51, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.709}}}{{\f5\fs12\hyphpar0\qj{, 35A.11}}}{{\f5\fs12\hyphpar0\qj{, 100B.12}}}{{\f5\fs12\hyphpar0\qj{, 257.31}}}{{\f5\fs12\hyphpar0\qj{, 321.105}}}{{\f5\fs12\hyphpar0\qj{, 321.145}}}{{\f5\fs12\hyphpar0\qj{, 321.166}}}{{\f5\fs12\hyphpar0\qj{, 321.231C}}}{{\f5\fs12\hyphpar0\qj{, 321L.1}}}{{\f5\fs12\hyphpar0\qj{, 321L.2}}}{{\f5\fs12\hyphpar0\qj{, 321L.2A}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 364.3}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(e)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph a amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.35}}}{\*\bkmkstart stylerid1_2E48_2E2_2E2}{\*\bkmkend stylerid1_2E48_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Plates \u8212\'3f reflective material \u8212\'3f bidding procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All motor vehicle registration plates shall be treated with a reflective material according to specifications proposed by the director and approved by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not enter into any contract requiring an expenditure of at least five hundred thousand dollars for the manufacture of motor vehicle registration plates to be reissued to owners under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ unless competitive bidding procedures as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 8A, subchapter III}}}{{\f5\fs18\hyphpar0\qj{, are followed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.35}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 118, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7247}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.36}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.37}}}{\*\bkmkstart stylerid1_2E5_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Display of plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration plates issued for a motor vehicle other than an autocycle, motorcycle, motorized bicycle, or truck tractor shall be attached to the motor vehicle, one in the front and the other in the rear. The registration plate issued for an autocycle, motorcycle, or other vehicle required to be registered under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be attached to the rear of the vehicle. The registration plate issued for a truck tractor shall be attached to the front of the truck tractor. The special plate issued to a dealer shall be attached on the rear of the vehicle when operated on the highways of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle, other than a truck registered for more than five tons, autocycle, motorcycle, or truck tractor, which is model year 1948 or older, and a reconstructed or specially constructed vehicle built to resemble a model year 1948 vehicle or older, may display one registration plate on the rear of the vehicle if the other registration plate issued to the vehicle is carried in the vehicle at all times when the vehicle is operated on a public highway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for the owner of a vehicle to place any frame around or over the registration plate which does not permit full view of all numerals and letters printed on the registration plate.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m11; C24, 27, 31, 35, \'a74877; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.21;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.37}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a756}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.57}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(f)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 1 and 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.38}}}{\*\bkmkstart stylerid1_2E51_2E2_2E2}{\*\bkmkend stylerid1_2E51_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Plates }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ method of attaching \u8212\'3f imitations prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every registration plate shall at all times be securely fastened in a horizontal position to the vehicle for which it is issued so as to prevent the plate from swinging and at a height of not less than twelve inches from the ground, measuring from the bottom of the plate, in a place and position to be clearly visible and shall be maintained free from foreign materials and in a condition to be clearly legible. An imitation plate or plates imitating or purporting to imitate the official registration plate of any other state or territory of the United States or of any foreign government shall not be fastened to the vehicle.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m11; C24, 27, 31, 35, \'a74877; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.22;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.38}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 195, \'a732}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.57}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(g)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.39}}}{\*\bkmkstart stylerid1_2E52_2E2_2E2}{\*\bkmkend stylerid1_2E52_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expiration of registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Except as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ every vehicle registration, registration card, and registration plate shall expire as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For vehicles registered by the county treasurer, at midnight on the last day of the registration year. A person shall not be considered to be driving a motor vehicle with an expired registration for a period of one month following the expiration date of the vehicle registration. The one-month period shall be the same as the period defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.134, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For vehicles on which the first installment of an annual registration fee has been paid, at midnight on the last day of June or the first business day of July when June 30 falls on Saturday, Sunday, or a holiday; for vehicles on which the second installment of an annual registration fee has been paid, at midnight on the last day of December or the first business day of January when December 31 falls on Saturday, Sunday, or a holiday.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For vehicles registered without payment of annual registration fees as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.19}}}{{\f5\fs18\hyphpar0\qj{, when designated by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration for every vehicle registered by the county treasurer shall expire upon transfer of ownership.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m16; C24, 27, 31, 35, \'a74868; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.23;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.39}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a75, 38}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{89 Acts, ch 83, \'a742}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 24, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a778}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.34}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.40}}}{\*\bkmkstart stylerid1_2E53_2E2_2E2}{\*\bkmkend stylerid1_2E53_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application for renewal \u8212\'3f notification \u8212\'3f reasons for refusal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Application for renewal for a vehicle registered under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be made on or after the first day of the month prior to the month of expiration of registration and up to and including the last day of the month following the month of expiration of registration. The application for renewal shall be submitted to the county treasurer of the county of the owner\u8217\'3fs residence; or if a nonresident, to the county treasurer of the county where the primary users of the vehicle are located; or if a lessor of the vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 321F}}}{{\f5\fs18\hyphpar0\qj{ which has a gross vehicle weight of less than ten thousand pounds, to the county treasurer of the county of the lessee\u8217\'3fs residence; or if a firm, association, or corporation with vehicles in multiple counties, to the county treasurer of the county where the primary user of the vehicle is located. The registration shall be renewed upon payment of the appropriate annual registration fee. Application for renewal for a vehicle registered under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ shall be made on or after the first day of the month prior to the month of expiration of registration and up to and including the last day of the month of expiration of registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before the fifteenth day of the eleventh month of a vehicle\u8217\'3fs registration year, the department shall create an electronic file and the county treasurer shall send a statement of fees due to the appropriate owner of record. After the department has generated the electronic file used to produce statements for a registration month, and before the fifteenth day of the month following expiration of a vehicle\u8217\'3fs registration year, the department shall create a subsequent electronic file and the county treasurer shall send a statement of fees due to the appropriate owner of record for any vehicle subsequently registered for that registration month. The statement shall be mailed or electronically transmitted to the most current address of record, showing information sufficient to identify the vehicle and a listing of the various fees as appropriate. Failure to receive a statement shall have no effect upon the accrual of penalty at the appropriate date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration receipts issued for renewals shall have the word \u8220\'3frenewal\u8221\'3f imprinted thereon and, if the owner making a renewal application has been issued a certificate of title, the title number shall appear on the registration receipt. All registration receipts for renewals shall be typewritten or printed by other mechanical means. The applicant shall receive a registration receipt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer shall refuse to renew the registration of a vehicle registered to a person when notified by the department through the distributed teleprocessing network that the person has not paid restitution as defined under }}}{{\f5\fs18\hyphpar0\qj{section 910.1, subsection 10}}}{{\f5\fs18\hyphpar0\qj{, to a clerk of the court located within the state. Each clerk of court shall, on a daily basis, notify the department through the Iowa court information system of the full name and social security number of all persons who owe delinquent restitution and whose restitution obligation has been satisfied or canceled. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the transfer of a registration or the issuance of a new registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer shall refuse to renew the registration of a vehicle registered to the applicant for renewal of registration if the applicant has failed to pay any local vehicle taxes due in that county on that vehicle or any other vehicle owned or previously owned by the applicant until such local vehicle taxes are paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department or the county treasurer shall refuse to renew the registration of a vehicle registered to the applicant if the department or the county treasurer knows that the applicant has a delinquent account, charge, fee, loan, taxes, or other indebtedness owed to or being collected by the state, from information provided pursuant to sections }}}{{\f5\fs18\hyphpar0\qj{421.17}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{421.65}}}{{\f5\fs18\hyphpar0\qj{. An applicant may contest this action by initiating a contested case proceeding with the agency that referred the debt for collection pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 421.65}}}{{\f5\fs18\hyphpar0\qj{. The department of revenue and the department of transportation shall notify the county treasurers through the distributed teleprocessing network of persons who owe such a delinquent account, charge, fee, loan, taxes, or other indebtedness.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A county treasurer, in cooperation with the department of revenue, may collect from a person applying for renewal of a vehicle registration delinquent taxes, including penalties and interest owed to the state, and nontax liabilities being collected by the central collection unit of the department of revenue pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 421.17, subsection 27}}}{{\f5\fs18\hyphpar0\qj{. The applicant may remit full payment of the balance owed including applicable penalties and interest, along with a processing fee of five dollars, to the county treasurer at the time of registration renewal. Upon full payment of the required balance owed including applicable penalties and interest, the processing fee, and the vehicle registration fee, the county treasurer shall issue the registration to the person. A county treasurer collecting on behalf of the department of revenue shall update the vehicle registration records through the distributed teleprocessing network on a daily basis for all persons who have paid taxes or other balances owed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A county treasurer shall forward all funds collected for the department of revenue to the department of revenue. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department or the county treasurer shall refuse to renew the registration of a vehicle registered to an applicant if the department or the county treasurer knows that the applicant has not paid a civil penalty imposed on the applicant pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321N.3, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. An applicant may contest this action by initiating a contested case proceeding with the department. The department shall notify the county treasurers through the distributed teleprocessing network of persons who have not paid such civil penalties.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer of the county of an applicant\u8217\'3fs residence and in which the applicant\u8217\'3fs vehicle is registered, in cooperation with the department, may collect a civil penalty imposed on the applicant pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321N.3, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, when the applicant applies for renewal of a vehicle registration. The applicant may remit full payment of the civil penalty, along with a processing fee of five dollars, to the county treasurer at the time of registration renewal. Upon full payment of the civil penalty, the processing fee, and the vehicle registration fee, the county treasurer shall issue the registration to the applicant. A county treasurer collecting a civil penalty on behalf of the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall update the vehicle registration records through the distributed teleprocessing network on a daily basis for all applicants who have paid civil penalties pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A county treasurer shall forward all funds collected on behalf of the department to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer shall refuse to renew the registration of a vehicle registered to an applicant if the county treasurer knows that the applicant has one or more uncontested, delinquent parking tickets issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.236, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, owing to the county, or owing to a city with which the county has an agreement authorized under }}}{{\f5\fs18\hyphpar0\qj{section 331.553}}}{{\f5\fs18\hyphpar0\qj{. However, a county treasurer may renew the registration if the treasurer determines that an error was made by the county or city in identifying the vehicle involved in the parking violation or if the citation has been dismissed as against the owner of the vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.484}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the transfer of a registration or the issuance of a new registration. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 28E.10}}}{{\f5\fs18\hyphpar0\qj{, a county treasurer may utilize the department\u8217\'3fs vehicle registration and titling system to facilitate the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When application is made for the renewal of a motor vehicle registration on or after December 1, 1982, the person in whose name the registration is recorded shall notify the county treasurer of the type of fuel used by the vehicle if the type of fuel used is different from that which is shown on the registration receipt. If a motor vehicle registration indicates that the vehicle uses or may use a special fuel as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 452A}}}{{\f5\fs18\hyphpar0\qj{ the county treasurer shall issue a special fuel user identification sticker. The person who owns or controls the vehicle shall affix the sticker in a prominent place on the vehicle adjacent to the place where the special fuel is delivered into the motor vehicle fuel supply tank.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court shall notify the county treasurer of any delinquent court debt, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{, which is being collected by the department of revenue pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8107, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or the county attorney pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.8107, subsection 4}}}{{\f5\fs18\hyphpar0\qj{. The county treasurer shall refuse to renew the vehicle registration of the applicant upon such notification from the clerk of the district court in regard to such applicant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the applicant enters into or renews an installment agreement as defined in }}}{{\f5\fs18\hyphpar0\qj{section 602.8107}}}{{\f5\fs18\hyphpar0\qj{, that is satisfactory to the department of revenue, the county attorney, or the county attorney\u8217\'3fs designee, the department of revenue, county attorney, or a county attorney\u8217\'3fs designee shall provide the county treasurer with written or electronic notice of the installment agreement within five days of entering into the installment agreement. The county treasurer shall temporarily lift the registration hold on an applicant for a period of ten days if the treasurer receives such notice in order to allow the applicant to register a vehicle for the year. If the applicant remains in compliance with the installment agreement entered into with the department of revenue or the county attorney or the county attorney\u8217\'3fs designee, subsequent lifts of registration holds shall be granted without additional restrictions.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m6; C24, 27, 31, 35, \'a74875; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.24;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.40}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1218, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a76, 7, 38}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 32, \'a778}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 77, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 87, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 57, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 169, \'a71, 10}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 194, \'a74, 12}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a712, 61}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1028, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1043, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7248}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 54, \'a71, 12}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 126, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1172, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7250}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1146, \'a72, 3, 26}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 138, \'a789, 161, 162}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1101, \'a72, 24}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a792, 93}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1064, \'a715, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a784, 92}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a773, 74}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 86, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a710, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.26}}}{{\f5\fs12\hyphpar0\qj{, 321.34}}}{{\f5\fs12\hyphpar0\qj{, 321.152}}}{{\f5\fs12\hyphpar0\qj{, 321.153}}}{{\f5\fs12\hyphpar0\qj{, 321.236}}}{{\f5\fs12\hyphpar0\qj{, 331.553}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 364.2}}}{{\f5\fs12\hyphpar0\qj{, 421.17}}}{{\f5\fs12\hyphpar0\qj{, 422.20}}}{{\f5\fs12\hyphpar0\qj{, 422.72}}}{{\f5\fs12\hyphpar0\qj{, 423B.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.41}}}{\*\bkmkstart stylerid1_2E54_2E2_2E2}{\*\bkmkend stylerid1_2E54_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Change of address or name or fuel type.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever any person after making application for or obtaining the registration of a vehicle shall move from the address named in the application or shown upon a registration card such person shall within ten days thereafter notify the county treasurer of the county in which the registration of said vehicle is of record, in writing of the person\u8217\'3fs old and new addresses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever the name of any person who has made application for or obtained the registration of a vehicle is thereafter legally changed such person shall within ten days notify the county treasurer of the county in which the title of said vehicle is of record, of such former and new name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has registered a vehicle in a county, other than the county designated on the vehicle registration plate, may apply to the county treasurer where the vehicle is registered for new registration plates upon payment of a fee of five dollars and the return of the former county registration plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a motor vehicle is modified to use a different fuel type or to use more than one fuel type the person in whose name the vehicle is registered shall within thirty days notify the county treasurer of the county in which the registration of the vehicle is of record of the new fuel type or alternative fuel types. The county treasurer shall make the record of such changes available to the department of revenue. If the vehicle uses or may use a special fuel the county treasurer shall issue a special fuel identification sticker.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.25;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.41}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1218, \'a72}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(h)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.42}}}{\*\bkmkstart stylerid1_2E55_2E2_2E2}{\*\bkmkend stylerid1_2E55_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lost or damaged certificates, cards, and plates \u8212\'3f replacements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a registration card, plate, or pair of plates is lost or becomes illegible, the owner shall immediately apply for replacement. The fee for a replacement registration card is three dollars. The fee for a replacement plate or pair of plates other than a replacement of a special plate issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.60}}}{{\f5\fs18\hyphpar0\qj{ is five dollars. The fee for replacement of a special plate issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.60}}}{{\f5\fs18\hyphpar0\qj{ is forty dollars. When the owner has furnished information required by the department and paid the proper fee, a duplicate, substitute, or new registration card, plate, or pair of plates may be issued. The county treasurer or the department may waive the fee for a replacement plate if the plate is lost during a documented accident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a certificate of title is lost or destroyed, the owner or lienholder shall apply for a replacement copy of the original certificate of title. The owner or lienholder of a motor vehicle may also apply for a replacement copy of the original certificate of title upon surrender of the original certificate of title with the application. The application shall be made to the department or any county treasurer. The application shall be signed by the owner or lienholder and accompanied by a fee of thirty dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After five days, the department or county treasurer shall issue a replacement copy using the applicant\u8217\'3fs most recent bona fide address; however, the five-day waiting period does not apply to an applicant who is a lienholder or to an applicant who has surrendered the original certificate of title to the department or county treasurer. The replacement copy shall be clearly marked \u8220\'3freplacement\u8221\'3f and shall include security interests and liens. When a replacement copy has been issued, the previous certificate is void. The department or county treasurer is not authorized to refund fees collected for a replacement title under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 321.52A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a security interest noted on the face of an original certificate of title was released by the lienholder on a separate form pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.50, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, and the signature of the lienholder, or the person executing the release on behalf of the lienholder, is notarized, but the lienholder has not delivered the original certificate to the appropriate party as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.50, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, the owner may apply for and receive a replacement certificate of title without the released security interest noted thereon. The lienholder shall return the original certificate of title to the department or to any county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A new purchaser or transferee is entitled to receive an original title upon presenting the assigned replacement copy to any county treasurer. At the time of purchase, a purchaser may require the seller to indemnify the purchaser and all future purchasers of the vehicle against any loss which may be suffered due to claims on the original certificate. A person recovering an original certificate of title for which a replacement has been issued shall surrender the original certificate to the county treasurer or the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a county treasurer mails vehicle registration documents which become lost or are damaged in transit through the United States postal service, the person to whom the documents were being sent may apply for reissuance without cost. The application shall be made with the county treasurer who originally issued the documents not less than twenty days from the date the documents were placed with the United States postal service. If the original documents are received after reissuance of duplicates, the original documents shall be surrendered to the county treasurer within five days of the time they are received.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m5; C24, 27, 31, 35, \'a74886; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.26;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7321.42}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 102, \'a71}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a751}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 209, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 13, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1016, \'a743, 47}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1013, \'a711, 35}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 34, \'a74, 26}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1068, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a716, 21}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1124, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a711, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.52A}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 648.22A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Surcharge imposed; }{{\f5\fs12\hyphpar0\qj{\'a7321.52A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.43}}}{\*\bkmkstart stylerid1_2E56_2E2_2E2}{\*\bkmkend stylerid1_2E56_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{New identifying numbers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may assign a distinguishing number to a vehicle when the vehicle identification number on the vehicle is destroyed or obliterated and issue to the owner a special plate bearing the distinguishing number which shall be affixed to the vehicle in a position to be determined by the director. The vehicle shall be registered and titled under the distinguishing number in lieu of the former vehicle identification number within thirty days of issuance of the distinguishing number.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a75083-b4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.27;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.43}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1067, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 8, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 179, \'a7126}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.44}}}{\*\bkmkstart stylerid1_2E57_2E2_2E2}{\*\bkmkend stylerid1_2E57_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules governing change of engines, drivetrain assemblies, and related parts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall adopt and enforce rules governing registration and titling of motor vehicles as deemed necessary by the director and compatible with the public interest with respect to the change or substitution of engines, drivetrain assemblies or related parts in any motor vehicle.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5001.28;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.44}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1278, \'a732}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.44A}}}{\*\bkmkstart stylerid1_2E58_2E2_2E2}{\*\bkmkend stylerid1_2E58_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Voluntary contribution \u8212\'3f anatomical gift public awareness and transplantation fund \u8212\'3f amount retained by county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For each application for registration or renewal, the county treasurer or the department shall request through use of a written form, and, if the application is made in person, through verbal communication, that an applicant make a voluntary contribution of one dollar or more to the anatomical gift public awareness and transplantation fund established pursuant to }{{\f5\fs18\hyphpar0\qj{section 142C.15}}}{. One hundred percent of the moneys collected by the county and one hundred percent of the moneys collected by the department in the form of contributions shall be remitted to the treasurer of state for deposit in the fund to be used for the purposes specified for the fund. However, up to five percent of the moneys collected by the county may be retained by the county treasurer for deposit in the general fund of the county. The director shall adopt rules to administer }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1076, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 121, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1107, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7142C.15}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E59_2E1_2E1}{TRANSFERS OF TITLE OR INTEREST}{\*\bkmkend stylerid1_2E59_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.45}}}{\*\bkmkstart stylerid1_2E6_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Title must be transferred with vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No manufacturer, importer, dealer, or other person shall sell or otherwise dispose of a new vehicle subject to registration under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to a dealer to be used by such dealer for purposes of display and lease or resale without delivering to such dealer a manufacturer\u8217\'3fs or importer\u8217\'3fs certificate duly executed and with such assignments thereon as may be necessary to show title in the purchaser thereof; nor shall such dealer purchase or acquire a new vehicle that is subject to registration without obtaining from the seller thereof such manufacturer\u8217\'3fs or importer\u8217\'3fs certificate. In addition to the assignments stated herein, such manufacturer\u8217\'3fs or importer\u8217\'3fs certificate shall contain thereon the identification and description of the vehicle delivered and the name and address of the dealer to whom said vehicle was originally sold over the signature of an authorized official of the manufacturer or importer who made the original delivery.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each new mobile home, manufactured home, travel trailer, and camping trailer said manufacturer\u8217\'3fs or importer\u8217\'3fs certificate shall also contain thereon the exterior length and exterior width of said vehicle not including any area occupied by any hitching device, and the manufacturer\u8217\'3fs shipping weight.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Completed motor vehicles, other than class \u8220\'3fB\u8221\'3f motor homes, which are converted, modified, or altered shall retain the identity and model year of the original manufacturer of the vehicle. Motor homes and all other motor vehicles manufactured from chassis or incomplete motor vehicles manufactured by another may have the identity and model year assigned by the final manufacturer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a glider kit vehicle shall take the identity of the new cab and the new frame used in the assembly of the glider kit vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ A person shall not acquire any right, title, claim, or interest in or to any vehicle subject to registration under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ from the owner thereof except by virtue of a certificate of title issued or assigned to the person for such vehicle or by virtue of a manufacturer\u8217\'3fs or importer\u8217\'3fs certificate delivered to the person for such vehicle and waiver or estoppel shall not operate in favor of any person claiming title to or interest in any vehicle against a person having possession of the certificate of title or manufacturer\u8217\'3fs or importer\u8217\'3fs certificate for such vehicle for a valuable consideration except in the following cases:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The perfection of a lien or security interest as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.50}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The perfection of a security interest in new or used vehicles held as inventory for sale as provided in uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554, article 9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A dispute between a buyer and the selling dealer who has failed to deliver or procure the certificate of title as promised.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for the purposes of }}}{{\f5\fs18\hyphpar0\qj{section 321.493}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vehicle is disposed of pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An insurer obtains a salvage certificate of title for a vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except in the cases enumerated in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, no court in any case at law or equity shall recognize the right, title, claim, or interest of any person in or to any vehicle subject to registration sold or disposed of, or mortgaged or encumbered, unless evidenced by a certificate of title or manufacturer\u8217\'3fs or importer\u8217\'3fs certificate duly issued or assigned in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the transfer of any registered vehicle, the owner, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall endorse an assignment and warranty of title upon the certificate of title for such vehicle with a statement of all liens and encumbrances thereon, and the owner shall deliver the certificate of title to the purchaser or transferee at the time of delivering the vehicle except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The owner shall indicate to the transferee the name of the county in which the vehicle was last registered and the registration expiration date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After acquiring a used mobile home or manufactured home to be titled in Iowa, a manufactured or mobile home retailer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 103A.51}}}{{\f5\fs18\hyphpar0\qj{, shall within thirty days apply for and obtain from the county treasurer of the county where the mobile home or manufactured home is located a new certificate of title for the mobile home or manufactured home. In the event that there is a prior lien or encumbrance to be released, as required by }}}{{\f5\fs18\hyphpar0\qj{section 321.50, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, the thirty-day time period in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not begin to run until the lien or encumbrance is released.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m9; C24, 27, 31, 35, \'a74961; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5002.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.45}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a710}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 130, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1215, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 57, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1085, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a712, 35}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1090, \'a717, 26}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a790}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 96, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 103, \'a78, 21}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 52, \'a71, 14}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 31, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7103A.55}}}{{\f5\fs12\hyphpar0\qj{, 321.20}}}{{\f5\fs12\hyphpar0\qj{, 321.46}}}{{\f5\fs12\hyphpar0\qj{, 321.49}}}{{\f5\fs12\hyphpar0\qj{, 321.67}}}{{\f5\fs12\hyphpar0\qj{, 321.104}}}{{\f5\fs12\hyphpar0\qj{, 321.493}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(i)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.46}}}{\*\bkmkstart stylerid1_2E61_2E2_2E2}{\*\bkmkend stylerid1_2E61_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{New title and registration upon transfer of ownership \u8212\'3f credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transferee shall, within thirty calendar days after purchase or transfer, apply for and obtain from any county treasurer a new initial registration and a new certificate of title for the vehicle, except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.25}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.48}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{322G.12}}}{{\f5\fs18\hyphpar0\qj{, or when the transferee obtains the vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. In the case of a mobile home or manufactured home, the transferee shall, within thirty calendar days after purchase or transfer, apply for and obtain from the county treasurer of the county where the mobile home or manufactured home is located a new certificate of title. The transferee shall present with the application the certificate of title endorsed and assigned by the previous owner and shall indicate the name of the county in which the vehicle was last registered and the registration expiration date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon filing the application for a new initial registration and a new title, the applicant shall pay a title fee of thirty dollars, an annual registration fee prorated for the remaining unexpired months of the registration year, and a fee for new registration if applicable. A manufacturer applying for a certificate of title pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 322G.12}}}{{\f5\fs18\hyphpar0\qj{ shall pay a title fee of twenty dollars. However, a title fee shall not be charged to a manufactured or mobile home retailer applying for a certificate of title for a used mobile home or manufactured home, titled in Iowa, as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.45, subsection 4}}}{{\f5\fs18\hyphpar0\qj{. The county treasurer, if satisfied of the genuineness and regularity of the application, and in the case of a mobile home or manufactured home, that taxes are not owing under }}}{{\f5\fs18\hyphpar0\qj{chapter 435}}}{{\f5\fs18\hyphpar0\qj{, and that applicant has complied with all the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall issue a new certificate of title and, except for a mobile home, manufactured home, or a vehicle returned to and accepted by a manufacturer as described in }}}{{\f5\fs18\hyphpar0\qj{section 322G.12}}}{{\f5\fs18\hyphpar0\qj{, a registration card to the purchaser or transferee, shall cancel the prior registration for the vehicle, and shall forward the necessary copies to the department on the date of issuance, as prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 321.24}}}{{\f5\fs18\hyphpar0\qj{. Mobile homes or manufactured homes titled under }}}{{\f5\fs18\hyphpar0\qj{chapter 448}}}{{\f5\fs18\hyphpar0\qj{ that have been subject under }}}{{\f5\fs18\hyphpar0\qj{section 446.18}}}{{\f5\fs18\hyphpar0\qj{ to a public bidder sale in a county shall be titled in the county\u8217\'3fs name, with no fee, and the county treasurer shall issue the title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant shall be entitled to a credit for that portion of the annual registration fee of the vehicle sold, traded, transferred, or junked which had not expired prior to the transfer of ownership of the vehicle. The annual registration fee for the new registration for the vehicle acquired shall be reduced by the amount of the credit. The credit shall be computed on the basis of the number of months remaining in the registration year, rounded to the nearest whole dollar. The credit shall be subject to the following limitations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The credit shall be claimed within six months from the date the vehicle for which credit is granted was sold, traded, transferred, or junked. After six months, all credits shall be disallowed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any credit granted to the owner of a vehicle which has been sold, traded, transferred, or junked may only be claimed by that person toward the annual registration fee for another vehicle purchased and the credit may not be sold, transferred, or assigned to any other person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the amount of the credit is computed to be an amount of less than ten dollars, a credit shall be disallowed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To claim a credit for the unexpired annual registration fee on a junked vehicle, the county treasurer shall disallow any claim for credit unless the owner presents a junking certificate or other evidence as required by the department to the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A credit shall not be allowed to any person who has made claim to receive a refund under }}}{{\f5\fs18\hyphpar0\qj{section 321.126}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the credit allowed exceeds the amount of the annual registration fee for the vehicle acquired, the owner may claim a refund under }}}{{\f5\fs18\hyphpar0\qj{section 321.126, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for the balance of the credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The credit shall be computed on the unexpired number of months computed from the date of purchase of the vehicle acquired.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the annual registration fee upon application is delinquent, the applicant shall be required to pay the delinquent fee from the first day the annual registration fee was due prorated to the month of application for new title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The seller or transferor may file an affidavit on forms prescribed and provided by the department with any county treasurer certifying the sale or transfer of ownership of the vehicle and the assignment and delivery of the certificate of title for the vehicle. Upon receipt of the affidavit, the county treasurer shall file the affidavit with the copy of the registration receipt for the vehicle on file in the treasurer\u8217\'3fs office and on that day the treasurer shall note receipt of the affidavit in the vehicle registration and titling system. Upon filing the affidavit, it shall be presumed that the seller or transferor has assigned and delivered the certificate of title for the vehicle. For a leased vehicle, the lessor licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 321F}}}{{\f5\fs18\hyphpar0\qj{ or the lessee may file an affidavit as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ certifying that the lease has expired or been terminated and the date that the leased vehicle was surrendered to the lessor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a new registration for a vehicle transferred to the applicant by a spouse, parent, or child of the applicant, or by operation of law upon inheritance, devise or bequest, from the applicant\u8217\'3fs spouse, parent, or child, or by a former spouse pursuant to a decree of dissolution of marriage, is entitled to a credit to be applied to the annual registration fee for the transferred vehicle. A credit shall not be allowed unless the vehicle to which the credit applies is registered within the time specified under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The credit shall be computed on the basis of the number of unexpired months remaining in the registration year of the former owner computed from the date the vehicle was transferred, computed to the nearest whole dollar. The credit may exceed the amount of the annual registration fee for the transferred vehicle. When the amount of the credit is computed to be an amount of less than ten dollars, the credit shall be disallowed. The credit shall not be sold, transferred, or assigned to any other person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a motor vehicle is leased and the lessee purchases the vehicle upon termination of the lease, the lessor shall, upon claim by the lessee with the lessor within six months of the purchase, assign the annual registration fee credit and registration plates for the leased motor vehicle to the lessee. Credit shall be applied as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m9; C24, 27, 31, 35, \'a74962; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5002.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.46}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a711}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a78, 38}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 24, \'a72 \u8211\'3f 4, 12}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 82, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 87, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 130, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1215, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1154, \'a71 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 87, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1047, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a713, 14, 35}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 34, \'a75, 26}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a712, 13}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a717, 21, 80}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 22, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1110, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 52, \'a72, 14}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a712, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.34}}}{{\f5\fs12\hyphpar0\qj{, 321.47}}}{{\f5\fs12\hyphpar0\qj{, 321.48}}}{{\f5\fs12\hyphpar0\qj{, 321.52}}}{{\f5\fs12\hyphpar0\qj{, 321.52A}}}{{\f5\fs12\hyphpar0\qj{, 321.105}}}{{\f5\fs12\hyphpar0\qj{, 321.109}}}{{\f5\fs12\hyphpar0\qj{, 321.113}}}{{\f5\fs12\hyphpar0\qj{, 321.121}}}{{\f5\fs12\hyphpar0\qj{, 321.122}}}{{\f5\fs12\hyphpar0\qj{, 321.126}}}{{\f5\fs12\hyphpar0\qj{, 322G.12}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(j)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Surcharge imposed; }{{\f5\fs12\hyphpar0\qj{\'a7321.52A}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.46A}}}{\*\bkmkstart stylerid1_2E62_2E2_2E2}{\*\bkmkend stylerid1_2E62_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Change from apportioned registration }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An owner changing a vehicle\u8217\'3fs registration from apportioned registration under }{{\f5\fs18\hyphpar0\qj{chapter 326}}}{ to registration under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be entitled to a credit on the vehicle\u8217\'3fs annual registration fees under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The credit may be allowed when the owner surrenders to the county treasurer proof of apportioned registration provided by the department. The amount of the credit shall be calculated based on the unexpired complete calendar months remaining in the registration year from the date the application is filed with the county treasurer.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 108, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.47}}}{\*\bkmkstart stylerid1_2E63_2E2_2E2}{\*\bkmkend stylerid1_2E63_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Transfers by operation of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If ownership of a vehicle is transferred by operation of law upon inheritance, devise or bequest, dissolution decree, order in bankruptcy, insolvency, replevin, foreclosure or execution sale, abandoned vehicle sale, or when the engine of a motor vehicle is replaced by another engine, or a vehicle is sold or transferred to satisfy an artisan\u8217\'3fs lien as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 577}}}{{\f5\fs18\hyphpar0\qj{, a landlord\u8217\'3fs lien as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 570}}}{{\f5\fs18\hyphpar0\qj{, a self-service storage facility lien as provided in }}}{{\f5\fs18\hyphpar0\qj{section 578A.7}}}{{\f5\fs18\hyphpar0\qj{, a storage lien as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 579}}}{{\f5\fs18\hyphpar0\qj{, a judgment in an action for abandonment of a manufactured or mobile home as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 555B}}}{{\f5\fs18\hyphpar0\qj{, upon presentation of an affidavit relating to the disposition of a valueless mobile, modular, or manufactured home as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 555C}}}{{\f5\fs18\hyphpar0\qj{, or repossession is had upon default in performance of the terms of a security agreement, any county treasurer or, in the case of a mobile home or manufactured home, the county treasurer of the county where the mobile home or manufactured home is located, upon the surrender of the prior certificate of title or the manufacturer\u8217\'3fs or importer\u8217\'3fs certificate, or when that is not possible, upon presentation of satisfactory proof to the county treasurer of ownership and right of possession to the vehicle and upon payment of a fee of thirty dollars and the presentation of an application for initial registration and certificate of title, may issue to the applicant a registration card for the vehicle and a certificate of title to the vehicle. A person entitled to ownership of a vehicle under a decree of dissolution shall surrender a reproduction of a certified copy of the dissolution and upon fulfilling the other requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is entitled to a certificate of title and registration receipt issued in the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The persons entitled under the laws of descent and distribution to the possession and ownership of a vehicle owned in whole or in part by a decedent who died intestate, upon filing an affidavit stating the name and date of death of the decedent, the right to possession and ownership of the persons filing the affidavit, and that there has been no administration of the decedent\u8217\'3fs estate, which instrument must also contain an agreement by the affiant to indemnify creditors of the decedent who would be entitled to levy execution upon the motor vehicle to the extent of the value of the motor vehicle, shall, upon complying with the other title transfer requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, be issued a registration card for the decedent\u8217\'3fs interest in the vehicle and a certificate of title to the vehicle. If a decedent died testate, and either the will is not probated or is admitted to probate without administration, the persons entitled to the possession and ownership of a vehicle owned in whole or in part by the decedent may file an affidavit and, upon complying with the other title transfer requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall be issued a registration card for the decedent\u8217\'3fs interest in the vehicle and a certificate of title to the vehicle. The affidavit must contain the same information and indemnity agreement as is required in cases of intestacy under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. For a death occurring before January 1, 2025, a requirement of }}}{{\f5\fs18\hyphpar0\qj{chapter 450}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered satisfied by the filing of the affidavit provided for in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. If, from the records in the office of the county treasurer, there appear to be any liens on the vehicle, the certificate of title must contain a statement of the liens unless the application is accompanied by proper evidence of the satisfaction or extinction of such liens. Evidence of extinction includes but is not limited to an affidavit of the applicant stating that a security interest was foreclosed as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 554, article 9, part 6}}}{{\f5\fs18\hyphpar0\qj{. The department shall waive the certificate of title fee and surcharge required under }}}{{\f5\fs18\hyphpar0\qj{sections 321.20}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.20A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.23}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.46}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.52}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{321.52A}}}{{\f5\fs18\hyphpar0\qj{ if the person entitled to possession and ownership of a vehicle, as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, is the surviving spouse of a decedent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An affiant under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is the agent of the owner of the vehicle solely for the purpose of completing the odometer disclosure statement under }}}{{\f5\fs18\hyphpar0\qj{section 321.71}}}{{\f5\fs18\hyphpar0\qj{ and regulations promulgated under }}}{{\f5\fs18\hyphpar0\qj{49 U.S.C. ch. 327}}}{{\f5\fs18\hyphpar0\qj{, and found in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt. 580}}}{{\f5\fs18\hyphpar0\qj{. The affiant may submit any required odometer disclosure statement together with the affidavit required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever ownership of a vehicle is transferred under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the registration plates shall be removed and forwarded to any county treasurer, or to the department if the vehicle is owned by a nonresident. Upon transfer the vehicle shall not be operated upon the highways of this state until the person entitled to possession of the vehicle applies for and obtains initial registration for the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m9; C24, 27, 31, 35, \'a74963; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5002.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.47}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1243, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 119, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 154, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 83, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1149, \'a7165, 187}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1092, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 34, \'a76, 26}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a718, 21}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1119, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1138, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1076, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 50, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 38, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 143, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a713, 26}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 148, \'a728, 53, 54}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.52A}}}{{\f5\fs12\hyphpar0\qj{, 321.69}}}{{\f5\fs12\hyphpar0\qj{, 321.104}}}{{\f5\fs12\hyphpar0\qj{, 321.105A}}}{{\f5\fs12\hyphpar0\qj{, 321.113}}}{{\f5\fs12\hyphpar0\qj{, 321.121}}}{{\f5\fs12\hyphpar0\qj{, 321.122}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 555C.3}}}{{\f5\fs12\hyphpar0\qj{, 578A.7}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(k)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Surcharge imposed; }{{\f5\fs12\hyphpar0\qj{\'a7321.52A}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 2 applies retroactively to vehicles transferred on or after July 1, 2022; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 143, \'a72}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 2, paragraph a applies retroactively to January 1, 2025, to the estates of decedents dying on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 148, \'a754}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph a amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.48}}}{\*\bkmkstart stylerid1_2E64_2E2_2E2}{\*\bkmkend stylerid1_2E64_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vehicles acquired for resale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the transferee of a vehicle is a dealer who holds the vehicle for resale and operates the vehicle only for purposes incident to a resale and displays a dealer plate on the vehicle or does not drive such vehicle or permit it to be driven upon the highways, such transferee shall not be required to obtain a new registration or a new certificate of title but upon transferring title or interest to another person shall execute and acknowledge an assignment and warranty of title upon the certificate of title assigned to the person and deliver the same to the person to whom such transfer is made.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A dealer licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 322C}}}{{\f5\fs18\hyphpar0\qj{ who has acquired a vehicle for resale which is subject to a security interest as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.50}}}{{\f5\fs18\hyphpar0\qj{ and who has forwarded to the secured party the sum necessary to discharge the security interest may offer the vehicle for sale prior to the receipt from the county treasurer of the certificate of title for the vehicle with the lien discharged for a period of not more than thirty days from the date the vehicle was acquired and the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.104, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall not apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A foreign registered vehicle purchased or otherwise acquired by a dealer for the purpose of resale shall be issued a certificate of title for the vehicle by any county treasurer upon proper application as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and upon payment of a fee of fifteen dollars and the dealer is exempt from the payment of any and all registration fees for the vehicle. The application for certificate of title shall be made within thirty days after the vehicle comes within the border of the state. However, a dealer acquiring a vehicle registered in another state which permits Iowa dealers to reassign that state\u8217\'3fs certificates of title shall not be required to obtain a new initial registration or a new certificate of title and upon transferring title or interest to another person shall execute an assignment upon the certificate of title for the vehicle to the person to whom the transfer is made and deliver the assigned certificate of title to the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, requirements in those subsections for obtaining title to a vehicle or acknowledging assignment and warranty of title do not apply to a dealer who sells a motor vehicle to a purchaser in a consignment transaction authorized under }}}{{\f5\fs18\hyphpar0\qj{section 322.7B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a transaction in which a vehicle is traded to a dealer as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 322C}}}{{\f5\fs18\hyphpar0\qj{ toward the purchase price of another vehicle and each vehicle is owned in whole or in part by the same person, the person acquiring the vehicle from the dealer shall be entitled to a credit under }}}{{\f5\fs18\hyphpar0\qj{section 321.46}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A transferee of a new completed motor vehicle shall obtain a certificate of title for the vehicle but is not required to pay the annual registration fee for the vehicle, provided all of the following apply: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transferee is an equipment dealer licensed as a motor vehicle dealer under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transferee purchases the vehicle at retail for the purpose of modifying the vehicle as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.105A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (31), prior to selling it as a used vehicle to a business or government entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transferee operates the vehicle only for purposes incidental to a resale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transferee displays a dealer plate on the vehicle or does not drive the vehicle or permit it to be driven upon the highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to prohibit a dealer from obtaining a new certificate of title or new registration in the same manner as other purchasers.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74965; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5002.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.48}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a79, 38}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 82, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1169, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1215, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1116, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 8, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1065, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a714, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.23}}}{{\f5\fs12\hyphpar0\qj{, 321.25}}}{{\f5\fs12\hyphpar0\qj{, 321.30}}}{{\f5\fs12\hyphpar0\qj{, 321.46}}}{{\f5\fs12\hyphpar0\qj{, 321.49}}}{{\f5\fs12\hyphpar0\qj{, 321.50}}}{{\f5\fs12\hyphpar0\qj{, 321.52A}}}{{\f5\fs12\hyphpar0\qj{, 321.71}}}{{\f5\fs12\hyphpar0\qj{, 321.104}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(l)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Surcharge imposed; }{{\f5\fs12\hyphpar0\qj{\'a7321.52A}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.49}}}{\*\bkmkstart stylerid1_2E65_2E2_2E2}{\*\bkmkend stylerid1_2E65_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Time limit \u8212\'3f penalty \u8212\'3f power of attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.52}}}{{\f5\fs18\hyphpar0\qj{, if an application for transfer of registration and certificate of title is not submitted to any county treasurer within thirty days of the date of assignment or transfer of title, or within thirty days of the date of delivery to the purchaser if the vehicle is subject to a security interest and was offered for sale pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.48, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a penalty of ten dollars shall accrue against the applicant, and no registration card or certificate of title shall be issued to the applicant for the vehicle until the penalty is paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certificates of title to vehicles may be assigned by an attorney in fact of the owner under a power of attorney appointed and so empowered on forms provided by the department. Such power of attorney shall be filed by the transferee with the application for title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufactured or mobile home retailer who acquires a used mobile home or manufactured home, titled in Iowa, and who does not apply for and obtain a certificate of title from the county treasurer of the county where the manufactured or mobile home is located within thirty days of the date of acquisition, as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.45, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, is subject to a penalty of ten dollars. A certificate of title shall not be issued to the manufactured or mobile home retailer until the penalty is paid.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74966; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5002.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.49}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 209, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 130, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 47, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1154, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 96, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a715, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.50}}}{\*\bkmkstart stylerid1_2E66_2E2_2E2}{\*\bkmkend stylerid1_2E66_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Security interest provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A security interest in a vehicle subject to registration under the laws of this state, except trailers whose empty weight is two thousand pounds or less, and except new or used vehicles held by a dealer or manufacturer as inventory for sale, is perfected by the delivery to any county treasurer of an application for certificate of title which lists the security interest, or an application for notation of security interest signed by the owner or by one owner of a vehicle owned jointly by more than one person, or signed through electronic means as determined by the department, or a certificate of title from another jurisdiction which shows the security interest, and payment of a fee of twenty dollars for each security interest shown. The security interest in a mobile home or manufactured home is perfected by the delivery to the county treasurer of the county where the certificate of title was issued or, in the case of a new certificate, to the county treasurer where the certificate will be issued, of an application for certificate of title which lists the security interest, or an application for notation of security interest signed by the owner or by one owner when owned jointly by more than one person, or signed through electronic means as determined by the department, or a certificate of title from another jurisdiction which shows the security interest, and payment of a fee of twenty dollars for each security interest shown. The department shall require the federal employer identification number of a secured party who is a firm, association, or corporation or, if a natural person, the social security number. Upon delivery of the application and payment of the fee, the county treasurer shall note the date of delivery on the application. If the delivery is by electronic means and the time is electronically recorded on the application along with the date, the time shall be included with the date on all subsequent documents and records where the date of perfection is required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The date of delivery shall be the date of perfection of the security interest in the vehicle, regardless of the date the security interest is noted on the certificate of title. Up to three security interests may be perfected against a vehicle and shown on an Iowa certificate of title. If the owner or secured party is in possession of the certificate of title, it must also be delivered at this time. If a vehicle is subject to a security interest when brought into this state, the validity of the security interest and the date of perfection is determined by }}}{{\f5\fs18\hyphpar0\qj{section 554.9303}}}{{\f5\fs18\hyphpar0\qj{. Delivery as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ constitutes perfection of a security interest on a certificate of title for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 554}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of the application and the required fee, if the certificate of title was not delivered to the county treasurer along with the application, the county treasurer shall notify the holder of the certificate of title to deliver to the county treasurer, within five days from the receipt of notice, the certificate of title to permit notation of the security interest. If the holder of the certificate of title fails to deliver it within five days, the holder shall be liable to anyone harmed by the holder\u8217\'3fs failure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of the application, the certificate of title, if any, and the required fee, the county treasurer shall note the security interest and the date of perfection of the security interest on the certificate of title. The county treasurer shall also note the security interest and the date of perfection of the security interest in the county records system. Upon receipt of a certificate of title issued by a foreign jurisdiction, on which a security interest has been noted, the county treasurer shall note the security interest and the date the security interest was noted on the foreign certificate of title, if available, or if not, the date of issuance of the foreign certificate of title, on the face of the new certificate of title. The county treasurer shall also note the security interest and the date that was noted on the certificate of title in the county records system. The county treasurer shall then deliver the certificate of title to the first secured party as shown thereon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, if a security interest has been delivered by electronic means, the county treasurer or department shall not print a certificate of title until all security interests have been released, but shall provide the first security interest holder with an electronic record of the certificate of title. When a vehicle is subject to an electronic lien, the certificate of title for the vehicle shall be considered to be physically held by the lienholder for purposes of compliance with odometer disclosure requirements under }}}{{\f5\fs18\hyphpar0\qj{section 321.71}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.48, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when a security interest is discharged, the holder shall note a cancellation of the security interest on the face of the certificate of title over the holder\u8217\'3fs signature or may note the cancellation of the security interest on a separate, notarized release form or letter. The holder shall deliver the certificate of title and the form or letter, if applicable, to any county treasurer. In the case of a security interest that has been delivered by electronic means, the holder shall notify the department or the county treasurer, in a manner prescribed by the department, of the release of the security interest. The county treasurer shall immediately note the cancellation of the security interest on the face of the certificate of title, if applicable, and in the county records system. The county treasurer shall on the same day deliver the certificate of title, if applicable, and the separate, notarized release form or letter, if applicable, to the then first secured party or, if there is no such person, to the person as directed by the owner, in writing, on a form prescribed by the department or, if there is no person designated, then to the owner. The cancellation of the security interest shall be noted on the certificate of title by the county treasurer without charge. The holder of a security interest discharged by payment who fails to release the security interest within fifteen days after being requested in writing to do so shall forfeit to the person making the payment the sum of twenty-five dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a lien has been released by the lienholder but has not been sent to the county of record for clearance of the lien, any county may note the release on the face of the title and shall notify the county of record that the lien has been released as of the specified date and make entry upon the computer system. Notification to the county of record shall be made by an automated statewide system or by sending a photocopy of the released title to the county of record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a security interest is discharged, the lienholder shall note the cancellation of the security interest on the face of the title and, if applicable, may note the cancellation of the security interest on a form prescribed by the department and deliver a copy of the form in lieu of the title to the department or to any county treasurer. The form may be delivered by electronic means. The department or county treasurer shall note the release of the security interest upon the statewide computer system and the county\u8217\'3fs records. A copy of the form, if used, shall be attached to the title by the lienholder, if the title is held by the lienholder, and shall be evidence of the release of the security interest. If the title is held by the lienholder, the lienholder shall deliver the title to the first lienholder, or if there is no such person, to the person as designated by the owner, or if there is no such person designated, to the owner. If a certificate of title has not been issued, upon release of a security interest, the lienholder shall notify the department or the county treasurer, in a manner prescribed by the department, of the release of the security interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a security interest noted on an Iowa certificate of title and appearing in the statewide computer system and the county\u8217\'3fs records shall be presumed to be discharged upon presentation of a valid certificate of title subsequently issued by a foreign jurisdiction on which the security interest is no longer noted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, when an application for registration and issuance of a certificate of title is made by the means described in }}}{{\f5\fs18\hyphpar0\qj{section 321.20, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and the application includes a certificate of title upon which a security interest has been discharged by the secured party and the cancellation of the security interest is noted by the secured party on the certificate of title above the secured party\u8217\'3fs signature, the county treasurer shall not require any other notation of the cancellation of the security interest on the face of the certificate of title, and the county treasurer shall update such release on the applicable program or computer system. A dealer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 322C}}}{{\f5\fs18\hyphpar0\qj{ is authorized to sell such a vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.48, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554, article 9}}}{{\f5\fs18\hyphpar0\qj{, shall apply to all transactions intended to create a security interest in vehicles except as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request of any person, the county treasurer shall certify whether there are, on the date and hour stated therein, any security interests or liens against a vehicle and the name and address of each secured party. The uniform fee for a certification shall be two dollars if the request for the certification is on a form conforming to standards prescribed by the secretary of state; otherwise, three dollars. Upon request and payment of the appropriate fee, the county treasurer shall furnish a certified copy of any security interests for a uniform fee of one dollar per page.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74967; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5002.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.50}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 5, \'a73, 5}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 260, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a77, 44, 47}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1149, \'a7166, 187}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 8, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a715 \u8211\'3f 17, 35}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1092, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1034, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 50, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a716, 17, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.24}}}{{\f5\fs12\hyphpar0\qj{, 321.42}}}{{\f5\fs12\hyphpar0\qj{, 321.45}}}{{\f5\fs12\hyphpar0\qj{, 321.48}}}{{\f5\fs12\hyphpar0\qj{, 321.131}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.51}}}{\*\bkmkstart stylerid1_2E67_2E2_2E2}{\*\bkmkend stylerid1_2E67_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Terminal rental adjustment clause \u8212\'3f vehicle leases that are not sales or security interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An agreement involving the leasing of a motor vehicle or trailer does not create a sale or security interest solely because the agreement provides for an increase or decrease adjustment in the rental price of the motor vehicle or trailer based upon the amount realized upon sale or other disposition of the motor vehicle or trailer following the termination of the lease.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1052, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.52}}}{\*\bkmkstart stylerid1_2E68_2E2_2E2}{\*\bkmkend stylerid1_2E68_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Out-of-state sales \u8212\'3f junked, dismantled, wrecked, or salvage vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a vehicle is sold outside the state for purposes other than for junk, the owner, dealer or otherwise, shall detach the registration plates and registration card and shall indicate on the registration card the name and address of the foreign purchaser or transferee over the person\u8217\'3fs signature. Unless the registration plates are legally attached to another vehicle, the owner shall surrender the registration plates and registration card to the county treasurer, who shall cancel the records, destroy the registration plates, and forward the registration card to the department. The department shall make a notation on the records of the out-of-state sale and, after a reasonable period, may destroy the files for that particular vehicle. The department is not authorized to make a refund of annual registration fees on a vehicle sold out of state unless it receives the registration card completed as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purchaser or transferee of a motor vehicle subject to registration for which a certificate of title is issued which is sold for scrap or junk shall surrender the certificate of title, properly endorsed and signed by the previous owner, to any county treasurer, and shall apply for a junking certificate from the county treasurer, within thirty days after assignment of the certificate of title, except when the vehicle is disposed of pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The county treasurer shall issue to such person without fee a junking certificate. A junking certificate shall authorize the holder to possess, transport, or transfer by endorsement the ownership of the junked vehicle. A certificate of title shall not again be issued for the vehicle subsequent to the issuance of a junking certificate except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The county treasurer shall cancel the record of the vehicle. The junking certificate shall be printed on the registration receipt form and shall be imprinted with the words \u8220\'3fjunking certificate\u8221\'3f, as prescribed by the department. A space for transfer by endorsement shall be on the junking certificate. A separate form for the notation of the transfer of component parts shall be attached to the junking certificate when the certificate is issued.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a motor vehicle subject to registration that does not have a certificate of title or a junking certificate may dispose of the vehicle to a vehicle recycler licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 321H}}}{{\f5\fs18\hyphpar0\qj{ for scrap or junk if the vehicle is twelve model years old or older and is acquired by the vehicle recycler for reasonable consideration equaling less than one thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a vehicle for which a certificate of title is issued is junked or dismantled by the owner, the owner shall detach the registration plates and surrender the plates to the county treasurer, unless the plates are properly assigned to another vehicle. The owner shall also surrender the certificate of title to the county treasurer, except when the vehicle is disposed of pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the surrender of the certificate of title and application for junking certificate, the county treasurer shall issue to the person, without fee, a junking certificate, which shall authorize the holder to possess, transport, or transfer ownership of the junked vehicle by endorsement of the junking certificate. The county treasurer shall hold the surrendered certificate of title, registration receipt, application for junking certificate, and, if applicable, the registration plates for a period of fourteen days following the issuance of a junking certificate under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within the fourteen-day period, the person who was issued the junking certificate and to whom the vehicle was titled or assigned may surrender to the county treasurer the junking certificate, and upon the person\u8217\'3fs payment of appropriate fees and taxes and payment of any credit for annual registration fees received by the person for the vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 321.46, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the county treasurer shall issue to the person a certificate of title for the vehicle. After the expiration of the fourteen-day period, a county treasurer shall not issue a certificate of title for a junked vehicle for which a junking certificate is issued. The county treasurer shall cancel the record of the vehicle and forward the certificate of title to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, upon application and a showing of good cause, the department may issue a certificate of title to a person after the fourteen-day period for a junked vehicle for which a junking certificate has been issued. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fgood cause\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that the junking certificate was obtained by mistake or inadvertence. If a person\u8217\'3fs application to the department is denied, the person may make application for a certificate of title under the procedure as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.24, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, if the vehicle qualifies as an antique vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 321.115, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or the person may seek judicial review as provided under }}}{{\f5\fs18\hyphpar0\qj{sections 17A.19}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{17A.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law to the contrary, an insurer may apply for and be issued a salvage certificate of title for a motor vehicle without surrendering the certificate of title or manufacturer\u8217\'3fs or importer\u8217\'3fs statement of origin properly assigned if ownership of the vehicle was transferred, or will transfer, to the insurer pursuant to a settlement with the previous owner of the vehicle arising from circumstances involving damage to the vehicle, and at least thirty days have expired since the effective date of such settlement. To obtain a salvage certificate of title pursuant to this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the insurer shall submit an application for a salvage certificate of title to any county treasurer. The application shall be accompanied by an affidavit from the insurer in which the insurer certifies it has made at least two written attempts to obtain a properly assigned certificate of title or manufacturer\u8217\'3fs or importer\u8217\'3fs statement of origin for the vehicle by contacting the previous owner of the vehicle and all lienholders of record by certified mail or a similar service that provides proof of service using a return receipt, and has been unable to obtain the title or statement of origin. The failure of a previous owner or lienholder to provide a properly assigned certificate of title or manufacturer\u8217\'3fs or importer\u8217\'3fs statement of origin shall be deemed to be a waiver by the previous owner or lienholder of all rights, title, claim, and interest in the vehicle. The application shall also be accompanied by the application fee required under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and proof of payment of the total amount of the settlement by the insurer to the previous owner of the vehicle. Upon receiving an application that complies with this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the county treasurer shall issue a salvage certificate of title to the insurer which shall be free and clear of all liens and claims of ownership and shall bear the word \u8220\'3fSALVAGE\u8221\'3f stamped or printed on the face of the title in a manner prescribed by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle rebuilder or a person engaged in the business of buying, selling, or exchanging vehicles of a type required to be registered in this state, upon acquisition of a wrecked or salvage vehicle, shall surrender the certificate of title or manufacturer\u8217\'3fs or importer\u8217\'3fs statement of origin properly assigned, together with an application for a salvage certificate of title, to any county treasurer within thirty days after the date of assignment of the certificate of title for the wrecked or salvage motor vehicle. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies only to vehicles with a fair market value of five hundred dollars or more, based on the value before the vehicle became wrecked or salvage. Upon payment of a fee of twenty dollars, the county treasurer shall issue a salvage certificate of title which shall bear the word \u8220\'3fSALVAGE\u8221\'3f stamped or printed on the face of the title in a manner prescribed by the department. A salvage certificate of title may be assigned to an educational institution, a new motor vehicle dealer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{, a person engaged in the business of purchasing bodies, parts of bodies, frames or component parts of vehicles for sale as scrap metal, a salvage pool, or an authorized vehicle recycler licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 321H}}}{{\f5\fs18\hyphpar0\qj{. An authorized vehicle recycler licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 321H}}}{{\f5\fs18\hyphpar0\qj{ or a new motor vehicle dealer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ may assign or reassign an Iowa salvage certificate of title or a salvage certificate of title from another state to any person, and the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.24, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, requiring issuance of an Iowa salvage certificate of title shall not apply. A vehicle on which ownership has transferred to an insurer of the vehicle as a result of a settlement with the owner of the vehicle arising out of damage to, or unrecovered theft of, the vehicle shall be deemed to be a wrecked or salvage vehicle and the insurer shall comply with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to obtain a salvage certificate of title within thirty days after the date of assignment of the certificate of title of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a wrecked or salvage vehicle has been repaired, the owner may apply for a regular certificate of title by paying the appropriate fees and surrendering the salvage certificate of title and a properly executed salvage theft examination certificate. A motor vehicle with a gross vehicle weight rating of thirty thousand pounds or more is not subject to the salvage theft examination otherwise required under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and the owner of such vehicle is not required to submit a salvage theft examination certificate. The county treasurer shall issue a regular certificate of title which shall bear a designation printed on the face of the title and printed on the registration receipt indicating that the vehicle was previously titled on a salvage certificate of title in a form approved by the department. This designation shall be included on every Iowa certificate of title and registration receipt issued thereafter for the vehicle. However, if ownership of a stolen vehicle has been transferred to an insurer organized under the laws of this state or admitted to do business in this state, or if the transfer was the result of a settlement with the owner of the vehicle arising from damage to or the unrecovered theft of the vehicle, and if the insurer certifies to the county treasurer on a form approved by the department that the insurance company has received one or more written estimates which state that the retail cost of repairs including labor, parts, and other materials of all damage to the vehicle is less than three thousand dollars, the county treasurer shall issue to the insurance company the regular certificate of title and registration receipt without this designation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A salvage theft examination shall be made by a peace officer who has been specially certified and recertified when required by the Iowa law enforcement academy to do salvage theft examinations. The Iowa law enforcement academy shall determine standards for training and certification, conduct training, and may approve alternative training programs which satisfy the academy\u8217\'3fs standards for training and certification. The owner of the salvage vehicle shall make the vehicle available for examination at a time and location designated by the peace officer doing the examination. The owner may obtain a permit to drive the vehicle to and from the examination location by submitting a repair affidavit to the agency performing the examination stating that the vehicle is reasonably safe for operation and listing the repairs which have been made to the vehicle. The owner must be present for the examination and have available for inspection the salvage title, bills of sale for all essential parts changed, if applicable, and the repair affidavit. The examination shall be for the purposes of determining whether the vehicle or repair components have been stolen. The examination is not a safety inspection and a signed salvage theft examination certificate shall not be construed by any court of law to be a certification that the vehicle is safe to be operated. There shall be no cause of action against the peace officer or the agency conducting the examination or the county treasurer for failure to discover or note safety defects. If the vehicle passes the theft examination, the peace officer shall indicate that the vehicle passed examination on the salvage theft examination certificate. The permit and salvage theft examination certificate shall be on controlled forms prescribed and furnished by the department. The owner shall pay a fee of fifty dollars at the time the examination is scheduled. The agency performing the examinations shall retain forty dollars of the fee and shall pay five dollars of the fee to the department and five dollars of the fee to the treasurer of state for deposit in the general fund of the state. Moneys deposited to the general fund under this paragraph shall be used by the Iowa law enforcement academy to provide for the special training, certification, and recertification of officers as required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwrecked or salvage vehicle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a damaged motor vehicle subject to registration for which the cost of repair exceeds seventy percent of the fair market value of the vehicle, as determined in accordance with rules adopted by the department, before the vehicle became damaged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to carry out }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74887; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5002.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.52}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 102, \'a73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1169, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 67, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 209, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1089, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1215, \'a78 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 185, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 296, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 142, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 260, \'a71225, 1226}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1104, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 131, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1107, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 45, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1070, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1120, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 143, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1018, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a747, 48}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a719, 21, 82}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 52, \'a73, 4, 14}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 31, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 30, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1036, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a718, 19, 26}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7165}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.24}}}{{\f5\fs12\hyphpar0\qj{, 321.45}}}{{\f5\fs12\hyphpar0\qj{, 321.46}}}{{\f5\fs12\hyphpar0\qj{, 321.47}}}{{\f5\fs12\hyphpar0\qj{, 321.49}}}{{\f5\fs12\hyphpar0\qj{, 321.52A}}}{{\f5\fs12\hyphpar0\qj{, 321.67}}}{{\f5\fs12\hyphpar0\qj{, 321.69}}}{{\f5\fs12\hyphpar0\qj{, 321.100}}}{{\f5\fs12\hyphpar0\qj{, 321.104}}}{{\f5\fs12\hyphpar0\qj{, 321.126}}}{{\f5\fs12\hyphpar0\qj{, 322C.6}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(m)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Surcharge imposed; }{{\f5\fs12\hyphpar0\qj{\'a7321.52A}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.52A}}}{\*\bkmkstart stylerid1_2E69_2E2_2E2}{\*\bkmkend stylerid1_2E69_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate of title surcharge \u8212\'3f allocation of moneys.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to the fee required for the issuance of a certificate of title under }{{\f5\fs18\hyphpar0\qj{section 321.20}}}{, }{{\f5\fs18\hyphpar0\qj{321.20A}}}{, }{{\f5\fs18\hyphpar0\qj{321.23}}}{, }{{\f5\fs18\hyphpar0\qj{321.42}}}{, }{{\f5\fs18\hyphpar0\qj{321.46}}}{, }{{\f5\fs18\hyphpar0\qj{321.47}}}{, }{{\f5\fs18\hyphpar0\qj{321.48}}}{, or }{{\f5\fs18\hyphpar0\qj{321.52}}}{, a surcharge of five dollars shall be required. Of each surcharge collected under those sections, the county treasurer shall remit five dollars to the office of treasurer of state for deposit as set forth in }{{\f5\fs18\hyphpar0\qj{section 321.145, subsection 2}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 267, \'a7607}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 118, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1117, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 188, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1121, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a735}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a7116}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.42}}}{{\f5\fs12\hyphpar0\qj{, 321.47}}}{{\f5\fs12\hyphpar0\qj{, 321.145}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_30_2E1_2E1}{PERMITS TO NONRESIDENT OWNERS}{\*\bkmkend stylerid1_2E7_30_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.53}}}{\*\bkmkstart stylerid1_2E71_2E2_2E2}{\*\bkmkend stylerid1_2E71_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonresident owners of passenger vehicles and trucks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A nonresident owner, except as provided in }{{\f5\fs18\hyphpar0\qj{sections 321.54}}}{ and }{{\f5\fs18\hyphpar0\qj{321.55}}}{, of a private passenger motor vehicle, not operated for hire, may operate or permit the operation of such vehicle within this state without registering such vehicle in, or paying any fees to, this state subject to the condition that such vehicle at all times when operated in this state is duly registered in, and displays upon it a valid registration plate or plates issued for such vehicle in the place of residence of such owner. A nonresident who leases a vehicle from a resident owner shall not be considered a nonresident owner of such vehicle for the purpose of exemption under }{{\f5\fs18\hyphpar0\qj{this section}}}{. }{{\f5\fs18\hyphpar0\qj{This section}}}{ shall be operative to the extent that under the laws of the foreign country, state, territory, or federal district of such nonresident owner\u8217\'3fs residence like exemptions and privileges are granted to vehicles registered under the laws, and owned by residents, of this state. A truck, truck tractor, trailer or semitrailer owned by a nonresident and operated on Iowa highways must have displayed upon it a valid registration plate or plates and a valid registration certificate, card, or other official evidence of its allowable weight in the state, district or county in which it is registered.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m16; C24, 27, 31, 35, \'a74865; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5003.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.53}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.54}}}{\*\bkmkstart stylerid1_2E72_2E2_2E2}{\*\bkmkend stylerid1_2E72_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Registration and financial liability coverage required of certain nonresident carriers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonresident owners of foreign vehicles operated within this state for the intrastate transportation of persons or property for compensation or for the intrastate transportation of merchandise shall register and maintain financial liability coverage as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.20B}}}{{\f5\fs18\hyphpar0\qj{ for each vehicle and pay the same fees required for like vehicles owned by residents of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fintrastate transportation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as used herein shall mean the transportation for compensation of persons or property originating at any point or place in the state of Iowa and destined to any other point or place in said state irrespective of the route or highway or highways traversed, including the crossing of any state line of the state of Iowa, or the ticket or bill of lading issued and used for such transportation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5003.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.54}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 139, \'a73, 17, 18}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1121, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.53}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(13)(a)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fines, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 13, paragraph a }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.55}}}{\*\bkmkstart stylerid1_2E73_2E2_2E2}{\*\bkmkend stylerid1_2E73_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Registration and financial liability coverage required for certain vehicles owned or operated by nonresidents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident owner or operator engaged in remunerative employment within this state or carrying on business within this state and owning or operating a motor vehicle, trailer, or semitrailer within this state shall register and maintain financial liability coverage as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.20B}}}{{\f5\fs18\hyphpar0\qj{ for each vehicle and pay the same fees for registration as are paid for like vehicles owned by residents of this state. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a person commuting from the person\u8217\'3fs residence in another state or whose employment is seasonal or temporary, not exceeding ninety days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident owner of a motor vehicle operated within this state by a resident of this state shall register the vehicle and shall maintain financial liability coverage as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.20B}}}{{\f5\fs18\hyphpar0\qj{ for the vehicle. The nonresident owner shall pay the same fees for registration as are paid for like vehicles owned by residents of this state. However, registration under this paragraph is not required for vehicles being operated by residents temporarily for not more than ninety days. For purposes of this paragraph, a vehicle is not operated in the state temporarily, and is therefore subject to registration and the owner is required to pay the applicable fees, if the vehicle is located in Iowa for more than ninety consecutive or nonconsecutive days and is operated on an Iowa highway by an Iowa resident during that time. It is unlawful for a resident to operate within the state an unregistered motor vehicle required to be registered under this paragraph. The ninety-day temporary period of operation provided for under this paragraph does not apply to a vehicle owned by a shell business as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or after July 1, 2013, if the department, in consultation with the department of revenue, determines that the nonresident owner of a vehicle is a partnership, limited liability company, or corporation that is a shell business, it shall be rebuttably presumed that the Iowa resident in control of the vehicle is the actual owner of the vehicle, that the vehicle is subject to registration in this state, and that payment of the fee for new registration for the vehicle is owed by the Iowa resident.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Factors which indicate that a partnership, limited liability company, or corporation is a shell business include but are not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The partnership, limited liability company, or corporation lacks a specific business activity or purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The partnership, limited liability company, or corporation fails to maintain a physical location in the foreign state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The partnership, limited liability company, or corporation fails to employ individual persons and provide those persons with internal revenue service form W-2 wage and tax statements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The partnership, limited liability company, or corporation fails to file federal tax returns, or fails to file a required state tax return in the foreign state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Factors which indicate that a person is in control of a vehicle include but are not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person was the initial purchaser of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person operated or stored the vehicle in Iowa for any period of time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is a partner, member, or shareholder of the nonresident partnership, limited liability company, or corporation that purports to be the owner of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is insured to drive the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines that the nonresident owner of a vehicle is a shell business, the department shall notify the Iowa resident in control of the vehicle in writing that the Iowa resident is required to obtain an Iowa certificate of title and registration for the vehicle and pay the fee for new registration owed for the vehicle not later than thirty days from the date of the notice.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5003.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.55}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 58, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 139, \'a74, 17, 18}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1121, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7160}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1A}}}{{\f5\fs12\hyphpar0\qj{, 321.53}}}{{\f5\fs12\hyphpar0\qj{, 321.105A}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(n)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2 }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.56}}}{\*\bkmkstart stylerid1_2E74_2E2_2E2}{\*\bkmkend stylerid1_2E74_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Repair of out-of-state commercial motor vehicles \u8212\'3f permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operator of a commercial motor vehicle which is not registered within the state as required pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ or which does not have an interstate fuel permit, as required under }}}{{\f5\fs18\hyphpar0\qj{chapter 452A}}}{{\f5\fs18\hyphpar0\qj{, may enter the state and travel to a commercial vehicle dealer or repair facility and exit the state if all of the following circumstances apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commercial motor vehicle is entering the state solely for the purposes of maintenance and repair to the commercial motor vehicle and is exiting the state after having completed vehicle maintenance or repair.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the operator has obtained a temporary entry or exit permit from the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commercial motor vehicle is unladen.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall provide a temporary entry and exit permit to a commercial motor vehicle operator which authorizes the operator to enter and exit the state as allowed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Any operator of a commercial motor vehicle who has in the operator\u8217\'3fs possession the permit allowing entry into the state and exit from the state shall not be charged with a registration violation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ or with a motor fuel tax violation under }}}{{\f5\fs18\hyphpar0\qj{chapter 452A}}}{{\f5\fs18\hyphpar0\qj{, except for violations of }}}{{\f5\fs18\hyphpar0\qj{section 452A.74A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcommercial motor vehicle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 132, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1142, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a747}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E75_2E1_2E1}{SPECIAL PLATES TO MANUFACTURERS,}{\*\bkmkend stylerid1_2E75_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{TRANSPORTERS, WHOLESALERS,}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{AND DEALERS}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.57}}}{\*\bkmkstart stylerid1_2E76_2E2_2E2}{\*\bkmkend stylerid1_2E76_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operation under special plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A dealer owning any vehicle of a type otherwise required to be registered under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may operate or move the vehicle upon the highways solely for purposes of transporting, testing, demonstrating, or selling the vehicle without registering the vehicle, upon condition that the vehicle display in the manner prescribed in }}}{{\f5\fs18\hyphpar0\qj{sections 321.37}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.38}}}{{\f5\fs18\hyphpar0\qj{ a special plate issued to the owner as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.58 through 321.62}}}{{\f5\fs18\hyphpar0\qj{. A dealer may operate or move upon the highways a vehicle owned by the dealer for either private or business purposes, including hauling a load or towing a trailer, without registering it if the vehicle is in the dealer\u8217\'3fs inventory and is continuously offered for sale at retail, and there is displayed on it a special plate issued to the dealer as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.58 through 321.62}}}{{\f5\fs18\hyphpar0\qj{. A dealer may operate or move upon the highways an unregistered vehicle owned by a lessor licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 321F}}}{{\f5\fs18\hyphpar0\qj{ solely for the purpose of delivering the vehicle to the owner or transporting the vehicle to or from an auction if there is displayed on the vehicle a special plate issued to the dealer as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.58 through 321.62}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition, while a service customer is having the customer\u8217\'3fs own vehicle serviced or repaired by the dealer, the service customer of the dealer may operate upon the highways a motor vehicle owned by the dealer, except a motor truck or truck tractor, upon which there is displayed a special plate issued to the dealer, provided all of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are complied with.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Also a transporter may operate or move any vehicle of like type upon the highways solely for the purpose of delivery upon likewise displaying thereon like plates issued to the transporter as provided in these sections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 321.58 through 321.62}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to any vehicles offered for hire, work or service vehicles owned by a transporter or dealer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A dealer licensed as a wholesaler for a new motor vehicle model under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ may operate a new motor vehicle of that model, owned by the wholesaler, upon the highway when there is displayed on the vehicle a special plate issued to the wholesaler as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.58 through 321.62}}}{{\f5\fs18\hyphpar0\qj{ and when operated solely for the purposes of demonstration, show, or exhibition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ that manufactures ambulances, rescue vehicles, or fire vehicles may operate or move a new ambulance, rescue vehicle, or fire vehicle manufactured and owned by the manufacturer solely for purposes of transporting, demonstrating, showing, or exhibiting the vehicle when there is displayed on the vehicle a special plate issued to the manufacturer as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.58 through 321.62}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m14; C24, 27, 31, 35, \'a74888, 4894, 4895; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5004.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.57}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a712}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1175, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 139, \'a75, 17}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1121, \'a75, 9}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1090, \'a718, 26}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 102, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7166}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.309}}}{{\f5\fs12\hyphpar0\qj{, 321E.10}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(o)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.58}}}{\*\bkmkstart stylerid1_2E77_2E2_2E2}{\*\bkmkend stylerid1_2E77_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All dealers, transporters, and new motor vehicle wholesalers licensed under }{{\f5\fs18\hyphpar0\qj{chapter 322}}}{, upon payment of a fee of seventy dollars for a two-year period or part thereof, may make application to the department upon the appropriate form for a certificate containing a general distinguishing number and for one or more special plates as appropriate to various types of vehicles subject to registration. The applicant shall also submit proof of the applicant\u8217\'3fs status as a bona fide transporter, new motor vehicle wholesaler licensed under }{{\f5\fs18\hyphpar0\qj{chapter 322}}}{, or dealer, as reasonably required by the department. Dealers in new vehicles shall furnish satisfactory evidence of a valid franchise with the manufacturer of the vehicles authorizing the dealership.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m14; C24, 27, 31, 35, \'a74888; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5004.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.58}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a713}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1175, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1016, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 153, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1063, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1119, \'a748}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1068, \'a742, 57}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1090, \'a719, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.57}}}{{\f5\fs12\hyphpar0\qj{, 321.59}}}{{\f5\fs12\hyphpar0\qj{, 321.115}}}{{\f5\fs12\hyphpar0\qj{, 321.309}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.59}}}{\*\bkmkstart stylerid1_2E78_2E2_2E2}{\*\bkmkend stylerid1_2E78_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department, upon granting an application made as provided under }{{\f5\fs18\hyphpar0\qj{section 321.58}}}{, shall issue to the applicant a certificate containing the applicant\u8217\'3fs name and address and the general distinguishing number assigned to the applicant.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m14; C24, 27, 31, 35, \'a74890, 4891; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5004.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.59}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a7100}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.57}}}{{\f5\fs12\hyphpar0\qj{, 321.115}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.60}}}{\*\bkmkstart stylerid1_2E79_2E2_2E2}{\*\bkmkend stylerid1_2E79_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of special plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall issue special plates as applied for, which shall display the general distinguishing number assigned to the applicant. Each plate so issued shall also contain a number or symbol identifying the plate and distinguishing it from every other plate bearing the same general distinguishing number. The fee for each special plate is forty dollars for a two-year period or part thereof. The fee for a special plate used on a vehicle that is hauling a load or towing a trailer is seven hundred fifty dollars for a two-year period or part thereof.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m14; C24, 27, 31, 35, \'a74892; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5004.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.60}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a757}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a743, 57}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a728}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.42}}}{{\f5\fs12\hyphpar0\qj{, 321.57}}}{{\f5\fs12\hyphpar0\qj{, 321.115}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.61}}}{\*\bkmkstart stylerid1_2E8_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expiration of special plates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A special plate shall expire at midnight on December 31 of even-numbered years. A person shall not be considered to be driving a vehicle with an expired registration for one month following the expiration date of the special plate.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m16; C24, 27, 31, 35, \'a74868; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5004.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.61}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1175, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1068, \'a744, 57}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.57}}}{{\f5\fs12\hyphpar0\qj{, 321.115}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.62}}}{\*\bkmkstart stylerid1_2E81_2E2_2E2}{\*\bkmkend stylerid1_2E81_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every transporter or dealer shall keep a written record of the vehicles upon which such special plates are used, which record shall be open to inspection by any police officer or any officer or employee of the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5004.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.62}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.57}}}{{\f5\fs12\hyphpar0\qj{, 321.115}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(p)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.63}}}{\*\bkmkstart stylerid1_2E82_2E2_2E2}{\*\bkmkend stylerid1_2E82_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Different places of business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a transporter or dealer has an established place of business in more than one city, the transporter or dealer shall secure a separate and distinct certificate of registration and number plates for each such place of business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a dealer has more than one established place of business, the dealer may designate one such location in this state for purposes of keeping all the dealer\u8217\'3fs books and records, regardless of the line-make of motor vehicles to which such books and records pertain, by submitting a written certification to the department in a manner approved by the department.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m14; C24, 27, 31, 35, \'a74889; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5004.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.63}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1095, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.64}}}{\*\bkmkstart stylerid1_2E83_2E2_2E2}{\*\bkmkend stylerid1_2E83_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Implementation of multiyear licensing and issuance of special plates.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by 98 Acts, ch 1075, \'a732. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E84_2E2_2E1}{PUBLIC GARAGE RECORDS}{\*\bkmkend stylerid1_2E84_2E2_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.65}}}{\*\bkmkstart stylerid1_2E85_2E2_2E2}{\*\bkmkend stylerid1_2E85_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Garage record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every person or corporation operating a public garage shall keep for public inspection a record of the registration number and engine serial number or manufacturer\u8217\'3fs vehicle identification number of every motor vehicle offered for sale or taken in for repairs in said garage.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, \'a74988 \u8211\'3f 4990; C31, 35, \'a74990-c1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5004.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.65}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 179, \'a7127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.66}}}{\*\bkmkstart stylerid1_2E86_2E2_2E2}{\*\bkmkend stylerid1_2E86_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty to hold vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The proprietor of a garage and the proprietor\u8217\'3fs employees upon discovering that the engine number of a motor vehicle has been altered or obliterated shall immediately notify some member of the department or peace officer of the county in which the garage is located, and hold said vehicle for a period of twenty-four hours or until investigation shall have been made by such peace officer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74991; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5004.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.66}}}{]}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E87_2E1_2E1}{USED MOTOR VEHICLE REQUIREMENTS }{{\f5\fs18\qc{\u8212\'3f}}}{ NEW AND USED MOTOR VEHICLE DISCLOSURE REQUIREMENTS}{\*\bkmkend stylerid1_2E87_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.67}}}{\*\bkmkstart stylerid1_2E88_2E2_2E2}{\*\bkmkend stylerid1_2E88_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate of title must be executed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person, except as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.23}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.45}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall sell or otherwise dispose of a registered vehicle or a vehicle subject to registration without delivering to the purchaser or transferee thereof a certificate of title with such assignment thereon as may be necessary to show title in the purchaser.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall purchase or otherwise acquire or bring into this state a registered vehicle or a vehicle subject to registration without obtaining a certificate of title thereto except for temporary use or as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 321.23}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.45}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74898; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5005.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.67}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 52, \'a75, 14}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 31, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(2)(q)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.68}}}{\*\bkmkstart stylerid1_2E89_2E2_2E2}{\*\bkmkend stylerid1_2E89_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale in bulk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any dealer in this state to sell and transfer the dealer\u8217\'3fs stock of used motor vehicles in bulk unless the dealer complies with the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vendor shall file with the county treasurer and the department, duplicate inventories of all used motor vehicles proposed to be transferred, giving the factory number, last registration number, if any, and description of each such used motor vehicle and the name and address of proposed vendee, with a certification signed by both the vendee and the vendor that the certificates of title pertaining to all the used motor vehicles listed on the inventory have been duly assigned to the vendee as prescribed in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vendee shall, if the vendee has not already secured a dealer\u8217\'3fs registration, immediately secure such registration from the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the completion of such requirements the department shall certify to the county treasurer that such used motor vehicles are, from and after a date to be set by the department, the property of the vendee.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74899; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5005.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.68}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.69}}}{\*\bkmkstart stylerid1_2E9_30_2E2_2E2}{\*\bkmkend stylerid1_2E9_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Damage disclosure statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate of title shall not be issued for a motor vehicle unless a damage disclosure statement has been made by the transferor of the vehicle and is furnished with the application for certificate of title. A damage disclosure statement shall be provided by the transferor to the transferee in a transfer of ownership of a motor vehicle. The new certificate of title and registration receipt shall state on the face whether a prior owner had disclosed that the vehicle was damaged to the extent that it was a wrecked or salvage vehicle as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The damage disclosure statement required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall, at a minimum, state whether the transferor knows if the vehicle was titled as a salvage, rebuilt, or flood vehicle in this or any other state prior to the transferor\u8217\'3fs ownership of the vehicle and, if not, whether the transferor knows if the vehicle was damaged to the extent that it was a wrecked or salvage vehicle as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, during or prior to the transferor\u8217\'3fs ownership of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The damage disclosure statement shall be provided by the transferor to the transferee at or before the time of sale. If the transferor is not a resident of this state or if the transferee acquired the vehicle by operation of law as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.47}}}{{\f5\fs18\hyphpar0\qj{, the transferee shall not be required to submit a damage disclosure statement from the transferor with the transferee\u8217\'3fs application for title unless the state of the transferor\u8217\'3fs residence requires a damage disclosure statement. However, the transferee shall submit a damage disclosure statement with the transferee\u8217\'3fs application for title indicating whether a salvage, rebuilt, or flood title had ever existed for the vehicle, and if not, whether the vehicle was damaged to the extent that it was a wrecked or salvage vehicle as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, during or prior to the transferor\u8217\'3fs ownership of the vehicle, and the year, make, and vehicle identification number of the motor vehicle. The transferee shall not be required to indicate whether the vehicle was damaged to the extent that it was a wrecked or salvage vehicle as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if the transferor\u8217\'3fs certificate of title is from another state and if it indicates that the vehicle is salvaged and not rebuilt or is another state\u8217\'3fs salvage certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lessee who has executed a lease as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321F.1}}}{{\f5\fs18\hyphpar0\qj{ shall provide a damage disclosure statement to the lessor at the termination of the lease. The damage disclosure statement shall be made on a separate disclosure document and shall state whether the vehicle was damaged during the term of the lease to the extent that it was a wrecked or salvage vehicle as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The lessee\u8217\'3fs damage disclosure statement shall not be submitted with the application for title, but the lessor shall retain the lessee\u8217\'3fs damage disclosure statement for five years following the date of the statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall retain each damage disclosure statement received and copies shall be available to the public and the attorney general upon request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorized vehicle recyclers licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 321H}}}{{\f5\fs18\hyphpar0\qj{ and motor vehicle dealers licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ shall maintain copies of all damage disclosure statements where the recycler or dealer is either the transferor or the transferee for five years following the date of the statement. The copies shall be made available to the department or the attorney general upon request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The damage disclosure statements shall be made on the back of the certificate of title if the title is available to the transferor at the time of sale. If the title is not available at the time of sale or if the face of the transferor\u8217\'3fs Iowa title contains no indication that the vehicle was previously salvaged or titled as a salvage, rebuilt, or flood vehicle and the transferor knows or reasonably should know that the vehicle was previously salvaged or titled as a salvage, rebuilt, or flood vehicle in another state, the transferor shall make the disclosure on a separate disclosure document. The damage disclosure statement forms shall be as approved by the department. The treasurer shall not accept a damage disclosure statement and issue a title unless the back of the title or separate disclosure document has been fully completed and signed and dated by the transferee and the transferor, if applicable. If a separate damage disclosure document from a prior owner is required to be furnished with the application for title, the transferor shall provide a copy of the separate damage disclosure document to the transferee at or before the time of sale.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the information required in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a separate disclosure document shall state whether the vehicle\u8217\'3fs certificate of title indicates the existence of damage prior to the period of the transferor\u8217\'3fs ownership of the vehicle and whether the vehicle was titled as a salvage, rebuilt, or flood vehicle during the period of the transferor\u8217\'3fs ownership of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, authorized vehicle recycler licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 321H}}}{{\f5\fs18\hyphpar0\qj{, or motor vehicle dealer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ shall not be liable to a subsequent owner, driver, or passenger of a vehicle because a prior owner or lessee gave a false or inaccurate damage disclosure statement or failed to disclose that the vehicle had previously been damaged and repaired or had been titled on a salvage, rebuilt, or flood certificate of title unless the person, recycler, or dealer knew or reasonably should have known that the prior owner or lessee gave a false or inaccurate damage disclosure statement or failed to disclose that the vehicle had been damaged and repaired or had been titled on a salvage, rebuilt, or flood certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for }}}{{\f5\fs18\hyphpar0\qj{subsections 10 and 11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to motor trucks and truck tractors with a gross vehicle weight rating of sixteen thousand pounds or more, vehicles more than seven model years old, autocycles, motorcycles, motorized bicycles, and special mobile equipment. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does apply to motor homes. The requirement in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ that the new certificate of title and registration receipt shall state on the face whether a prior owner had disclosed that the vehicle was damaged to the extent that it was a wrecked or salvage vehicle as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, does not apply to a vehicle with a certificate of title bearing a designation that the vehicle was previously titled on a salvage certificate of title pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or to a vehicle with a certificate of title bearing a \u8220\'3fREBUILT\u8221\'3f or \u8220\'3fSALVAGE\u8221\'3f designation pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.24, subsection 4 or 5}}}{{\f5\fs18\hyphpar0\qj{. Except for }}}{{\f5\fs18\hyphpar0\qj{subsections 10 and 11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to new motor vehicles with a true mileage, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.71}}}{{\f5\fs18\hyphpar0\qj{, of one thousand miles or less, unless such vehicle has incurred damage as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell, lease, or trade a motor vehicle if the person knows or reasonably should know that the motor vehicle contains a nonoperative air bag that is part of an inflatable restraint system, or that the motor vehicle has had an air bag removed and not replaced, unless the person clearly discloses, in writing, to the person to whom the person is selling, leasing, or trading the vehicle, prior to the sale, lease, or trade, that the air bag is missing or nonoperative. In addition, a lessee who has executed a lease as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321F.1}}}{{\f5\fs18\hyphpar0\qj{ shall provide the disclosure statement required in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to the lessor upon termination of the lease.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The written disclosure required by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deemed to be a damage disclosure statement for the purposes of }}}{{\f5\fs18\hyphpar0\qj{subsections 6, 8, and 11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who knowingly makes a false damage disclosure statement or fails to make a damage disclosure statement required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a fraudulent practice. Failure of a person, authorized vehicle recycler licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 321H}}}{{\f5\fs18\hyphpar0\qj{, or motor vehicle dealer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ to comply with any duty imposed by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ constitutes a violation of }}}{{\f5\fs18\hyphpar0\qj{section 714.16, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules as necessary to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1104, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 45, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1034, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1063, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 56, \'a71 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1007, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a740, 41}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a788}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a7103}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a713}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7714H.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fraudulent practices, see }{{\f5\fs12\hyphpar0\qj{\'a7714.8 }}}{{\f5\fs12\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs12\hyphpar0\qj{ 714.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.69A}}}{\*\bkmkstart stylerid1_2E91_2E2_2E2}{\*\bkmkend stylerid1_2E91_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disclosure of repairs to new vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person licensed as a new motor vehicle dealer pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ shall not be required to disclose to a prospective or actual buyer or lessee of a new motor vehicle repairs of damage to or adjustments on or replacements of parts with new parts on the motor vehicle if all of the following are true:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The repairs, adjustments, or replacements were made to achieve compliance with factory specifications.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The actual cost of any labor or parts charged to or performed by the dealer for any such repairs, adjustments, or parts does not exceed four percent of the manufacturer\u8217\'3fs suggested retail price.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The dealer posts in a conspicuous place notice that repairs, adjustments, or replacements will be disclosed upon request.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The dealer discloses any such repairs, adjustments, or replacements upon request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ take precedence over and shall supersede }}}{{\f5\fs18\hyphpar0\qj{section 714.16, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, unnumbered paragraph 4, and }}}{{\f5\fs18\hyphpar0\qj{section 714H.4, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person licensed as a new motor vehicle dealer pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ shall disclose in writing, at or before the time of sale or lease, to the buyer or lessee of a new motor vehicle that the vehicle has been subject to any repairs of damage to or adjustments on or replacements of parts with new parts if the actual cost of any labor or parts charged to or performed by the dealer for any such repairs, adjustments, or parts exceeds four percent of the manufacturer\u8217\'3fs suggested retail price. The written disclosure shall include the signature of the buyer or lessee and be in a form and in a format approved by the attorney general by rule. A dealer shall retain a copy of each written disclosure issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for five years from the date of issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmanufacturer\u8217\'3fs suggested retail price\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the amount required to be disclosed by a dealer pursuant to }}}{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a71232(f)(4)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is an unlawful practice pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is a prohibited practice or act pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 714H.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 90, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a729, 30}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7322C.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.70}}}{\*\bkmkstart stylerid1_2E92_2E2_2E2}{\*\bkmkend stylerid1_2E92_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dealer vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A dealer licensed under }{{\f5\fs18\hyphpar0\qj{chapter 322}}}{ shall not be required to register any vehicle owned by the dealer which is being held for sale or trade, provided the annual registration fee was not delinquent at the time the vehicle was acquired by the dealer. When a dealer ceases to hold any vehicle for sale or trade or the vehicle otherwise becomes subject to registration under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ the annual registration fee and delinquent annual registration fee, if any, shall be due for the registration year.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74901; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5005.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.70}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a711, 38}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a771}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.71}}}{\*\bkmkstart stylerid1_2E93_2E2_2E2}{\*\bkmkend stylerid1_2E93_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Odometer requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ the following words and phrases shall have the meanings respectively ascribed to them:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIntent and purpose of }}}{{\i\f5\fs18\hyphpar0\qj{this section}}}{{\i\f5\fs18\hyphpar0\qj{\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is and shall mean to achieve the end that odometers of motor vehicles shall at all times correctly show the true mileage that the motor vehicle has been driven.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTrue mileage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is the actual mileage the motor vehicle has been driven.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall knowingly tamper with, adjust, alter, change, set back, disconnect or fail to connect the odometer of any motor vehicle, or cause any of the foregoing to occur to an odometer of a motor vehicle, so as to reflect a lower mileage than the true mileage driven by the motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall conspire with any other person to evade the intent and purpose of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall with the intent to defraud operate a motor vehicle on any street or highway knowing that the odometer of the motor vehicle is disconnected or nonfunctional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall advertise for sale, sell, use or install on any part of a motor vehicle or on any odometer in a motor vehicle any device which causes the odometer to register any mileage other than the true mileage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event any odometer is repaired or replaced, the reading of the repaired or replaced odometer shall be set at the reading of the odometer repaired or replaced immediately prior to repair or replacement, but where the odometer is incapable of registering the same mileage the odometer shall be adjusted to read zero and any adjustment made in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be deemed a violation of any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate of title shall not be issued for a motor vehicle which is equipped with an odometer by the manufacturer, unless an odometer statement which is in compliance with federal law and regulations has been made by the transferor of the vehicle and is furnished with the application for certificate of title, or unless an exemption applies under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7580.17}}}{{\f5\fs18\hyphpar0\qj{. The new certificate of title shall record on its face the odometer reading and the word \u8220\'3factual\u8221\'3f if the true mileage is known. If the odometer reading is not the true mileage or the true mileage is unknown, the words \u8220\'3fnot actual\u8221\'3f shall be recorded. If the odometer reading is greater than the odometer can mechanically count, the words \u8220\'3fexceeds the mechanical limits\u8221\'3f shall be recorded. However, a certificate of title may be issued for a motor vehicle to a person who moves into this state if the person acquired ownership of the motor vehicle prior to moving to this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who knowingly makes or delivers a false odometer statement as required by }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{ shall be guilty of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless an exemption applies under }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7580.17}}}{{\f5\fs18\hyphpar0\qj{ or unless a certificate of title has been issued for the vehicle in the name of the dealer, an Iowa licensed motor vehicle dealer shall not have in possession as inventory for sale a used motor vehicle acquired by the dealer for which the dealer does not possess an odometer statement by the transferor which is in compliance with federal law and regulations. Transfer of a new motor vehicle with an ownership document which is a manufacturer\u8217\'3fs statement of origin requires an odometer statement only when transferred at retail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A transferee of a motor vehicle reassigning the certificate of title to such motor vehicle pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 321.48, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall not be guilty of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if such transferee has in the transferee\u8217\'3fs possession an odometer statement by the transferor which is in compliance with federal law and regulations and if the transferee has no knowledge that the statement is false and that the transferee has no knowledge that the odometer does not reflect the true mileage of such motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, which rules shall be in compliance with the federal }}}{{\f5\fs18\hyphpar0\qj{Truth in Mileage Act of 1986}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 99-579}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. pt.\~580}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a fraudulent practice.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1243, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1131, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1100, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1006, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7307.37}}}{{\f5\fs12\hyphpar0\qj{, 321.47}}}{{\f5\fs12\hyphpar0\qj{, 321.50}}}{{\f5\fs12\hyphpar0\qj{, 321.69}}}{{\f5\fs12\hyphpar0\qj{, 321.477}}}{{\f5\fs12\hyphpar0\qj{, 322.4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fraudulent practices, see }{{\f5\fs12\hyphpar0\qj{\'a7714.8 }}}{{\f5\fs12\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs12\hyphpar0\qj{ 714.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.71A}}}{\*\bkmkstart stylerid1_2E94_2E2_2E2}{\*\bkmkend stylerid1_2E94_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Counterfeit, nonfunctional, and unsafe air bags.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounterfeit air bag\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an air bag displaying a mark identical or similar to the genuine mark of a motor vehicle manufacturer without authorization from the manufacturer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNonfunctional air bag\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an air bag that was previously deployed or damaged, or has an electric fault that is detected by a motor vehicle\u8217\'3fs air bag diagnostic system after the air bag is installed in the motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who manufactures, imports, installs, reinstalls, sells, or offers to sell any device with the intent that the device replace an air bag in a motor vehicle, and who knows that the device is a counterfeit air bag, nonfunctional air bag, or air bag that does not comply with federal safety requirements as provided in }}}{{\f5\fs18\hyphpar0\qj\cf1{49 C.F.R. \'a7571.208}}}{{\f5\fs18\hyphpar0\qj{, is guilty of an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who manufactures, imports, installs, reinstalls, sells, offers to sell, or tampers with any device that causes a motor vehicle\u8217\'3fs diagnostic system to inaccurately indicate that the motor vehicle is equipped with a functional air bag when a counterfeit or nonfunctional air bag is installed, or when no air bag is installed, with the intent to mislead the owner or operator of the motor vehicle into believing that the motor vehicle is equipped with a functional air bag, is guilty of an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is an unlawful practice under }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 94, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 72, \'a72, 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7714H.3}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E95_2E1_2E1}{SPECIAL ANTITHEFT LAW}{\*\bkmkend stylerid1_2E95_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.72}}}{\*\bkmkstart stylerid1_2E96_2E2_2E2}{\*\bkmkend stylerid1_2E96_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Report of stolen and recovered motor vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every peace officer upon receiving reliable information that any vehicle registered under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ has been stolen shall immediately report the theft to the department unless prior thereto information has been received of the recovery of the vehicle. Any officer upon receiving information that any vehicle, which the officer has previously reported as stolen, has been recovered, shall immediately report the fact of the recovery to the law enforcement agency which originated the theft report and to the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a713417-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.72}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 103, \'a71}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.74}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.73}}}{\*\bkmkstart stylerid1_2E97_2E2_2E2}{\*\bkmkend stylerid1_2E97_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports by owners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner, or person having a lien or encumbrance upon a registered vehicle which has been stolen or embezzled, may notify the department of such theft or embezzlement, but in the event of an embezzlement may make such report only after having procured the issuance of a warrant for the arrest of the person charged with such embezzlement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every owner or other person who has given any such notice must notify the department of a recovery of such vehicle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.73}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.74}}}{\*\bkmkstart stylerid1_2E98_2E2_2E2}{\*\bkmkend stylerid1_2E98_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Action by department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department, upon receiving a report of a stolen or embezzled vehicle as provided in }{{\f5\fs18\hyphpar0\qj{section 321.72}}}{ or }{{\f5\fs18\hyphpar0\qj{321.73}}}{ or through the national motor vehicle title information system, shall file and appropriately index the same and shall immediately suspend the registration of the vehicle so reported and shall not transfer the certificate of title or registration of the vehicle until such time as the department is notified that the vehicle has been recovered.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.74}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1013, \'a718, 35}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.75 through 321.77}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.78}}}{\*\bkmkstart stylerid1_2E1_30_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Injuring or tampering with vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who either individually or in association with one or more other persons willfully injures or tampers with any vehicle or breaks or removes any part or parts of or from a vehicle without the consent of the owner is guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.78}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7322C.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.79}}}{\*\bkmkstart stylerid1_2E1_301_2E2_2E2}{\*\bkmkend stylerid1_2E1_301_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Intent to injure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who with intent to commit any malicious mischief, injury, or other crime climbs into or upon a vehicle whether it is in motion or at rest or with like intent attempts to manipulate any of the levers, starting mechanism, brakes, or other mechanism or device of a vehicle while the same is at rest and unattended or with like intent sets in motion any vehicle while the same is at rest and unattended is guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.79}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.80}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.81}}}{\*\bkmkstart stylerid1_2E1_303_2E2_2E2}{\*\bkmkend stylerid1_2E1_303_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presumptive evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whoever shall conceal, barter, sell, possess or dispose of any vehicle or component part which has been stolen, or shall disguise, alter, or change such vehicle or component part or the vehicle identification number or component part number thereof, or remove or change the registration plate thereon, or do any act designed to prevent identification of such vehicle or component part, shall be presumed to have knowledge that such vehicle or component part had been stolen.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75093; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.10;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.81}}}{]}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.82 and 321.83}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.84}}}{\*\bkmkstart stylerid1_2E1_305_2E2_2E2}{\*\bkmkend stylerid1_2E1_305_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Seizure of vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be the duty of any peace officer who finds a vehicle or component part, the vehicle identification number or component part number of which has been altered, defaced, or tampered with, and who has reasonable cause to believe that the possessor of the vehicle or component part wrongfully holds it, to forthwith seize it, either with or without warrant, and deliver it to the sheriff of the county in which it is seized.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a75083-b1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.84}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.85}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.85}}}{\*\bkmkstart stylerid1_2E1_306_2E2_2E2}{\*\bkmkend stylerid1_2E1_306_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Stolen vehicles or component parts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a vehicle or component part is seized under }{{\f5\fs18\hyphpar0\qj{section 321.84}}}{ or is stolen or embezzled, and is not claimed by the owner before the date on which the person charged with its stealing or embezzling is convicted, the officer having the vehicle or component part in the officer\u8217\'3fs custody shall, on that date by certified mail, notify the department that the officer has the vehicle or component part in the officer\u8217\'3fs possession, giving a full and complete description of it, including all vehicle identification numbers and component part numbers. If there is a dispute regarding a claim for the vehicle or component part, the agency holding the vehicle or component part shall conduct an evidentiary hearing to adjudicate the claim.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, \'a712222; C27, 31, 35, \'a75083-b2, 12222; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.85}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 64, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.323}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.86}}}{\*\bkmkstart stylerid1_2E1_307_2E2_2E2}{\*\bkmkend stylerid1_2E1_307_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice by director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall, if the owner appears of record in the director\u8217\'3fs office, notify the owner of the fact that the vehicle or component part is in the custody of the officer, and if not of record in the director\u8217\'3fs office, the director shall mail the description to the county treasurer of each county.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a712223; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.15;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.86}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.323}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.87}}}{\*\bkmkstart stylerid1_2E1_308_2E2_2E2}{\*\bkmkend stylerid1_2E1_308_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Delivery to owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If, within forty days thereafter, the owner of the vehicle or component part appears and properly identifies it, the officer having the vehicle or component part in custody shall deliver it to such owner upon payment by the owner of the costs incurred incident to the apprehension of the vehicle or component part and the location of the owner.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, \'a712224; C27, 31, 35, \'a75083-b3, 12224; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.16;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.87}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.323}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.88}}}{\*\bkmkstart stylerid1_2E1_309_2E2_2E2}{\*\bkmkend stylerid1_2E1_309_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Failure of owner to claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the owner does not appear within forty days, the motor vehicle shall be deemed abandoned and the officer having possession of the motor vehicle shall proceed as provided in }{{\f5\fs18\hyphpar0\qj{section 321.89, subsections 3 and 5}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, \'a712225; C27, 31, 35, \'a75083-b3, 12225; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.17;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.88}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.323}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.89}}}{\*\bkmkstart stylerid1_2E11_30_2E2_2E2}{\*\bkmkend stylerid1_2E11_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abandoned vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E11_30_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_30_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 321.90}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.91}}}{{\f5\fs18\hyphpar0\qj{ unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAbandoned vehicle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle that has been left unattended on public property for more than twenty-four hours and lacks current registration plates or two or more wheels or other parts which renders the vehicle totally inoperable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle that has remained illegally on public property for more than twenty-four hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle that has been unlawfully parked on private property or has been placed on private property without the consent of the owner or person in control of the property for more than twenty-four hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle that has been legally impounded by order of a police authority and has not been reclaimed for a period of ten days. However, a police authority may declare the vehicle abandoned within the ten-day period by commencing the notification process in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any vehicle parked on the highway determined by a police authority to create a hazard to other vehicle traffic.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle that has been impounded pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.4B}}}{{\f5\fs18\hyphpar0\qj{ by order of the court and whose owner has not paid the impoundment fees after notification by the person or agency responsible for carrying out the impoundment order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDemolisher\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 321H}}}{{\f5\fs18\hyphpar0\qj{ whose business it is to convert a vehicle to junk, processed scrap, or scrap metal, or otherwise to wreck or dismantle vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPolice authority\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state patrol, any law enforcement agency of a county or city, or any special security officer employed by the state board of regents under }}}{{\f5\fs18\hyphpar0\qj{section 262.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E11_30_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E11_30_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Authority to take possession of abandoned vehicles.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A police authority, upon the authority\u8217\'3fs own initiative or upon the request of any other authority having the duties of control of highways or traffic, shall take into custody an abandoned vehicle on public property and may take into custody an abandoned vehicle on private property. The police authority may employ its own personnel, equipment, and facilities or hire a private entity, equipment, and facilities for the purpose of removing, preserving, storing, or disposing of abandoned vehicles. A property owner or other person in control of private property may employ a private entity who is a garagekeeper, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.90}}}{{\f5\fs18\hyphpar0\qj{, to dispose of an abandoned vehicle, and the private entity may take into custody the abandoned vehicle without a police authority\u8217\'3fs initiative. If a police authority employs a private entity to dispose of abandoned vehicles, the police authority shall provide the private entity with the names and addresses of the registered owners, all lienholders of record, and any other known claimant to the vehicle or the personal property found in the vehicle. The owners, lienholders, or other claimants of the abandoned vehicle shall not have a cause of action against a private entity for action taken under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the private entity provides notice as required by }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E11_30_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E11_30_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Notification of owner, lienholders, and other claimants.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A police authority or private entity that takes into custody an abandoned vehicle shall send notice by certified mail that the vehicle has been taken into custody no more than twenty days after taking custody of the vehicle. Notice shall be sent to the last known address of record of the last known registered owner of the vehicle, all lienholders of record, and any other known claimant to the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice shall be deemed given when mailed. The notice shall include all of the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the year, make, model, and vehicle identification number of the vehicle. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location of the facility where the vehicle is being held.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information for the persons receiving the notice of their right to reclaim the vehicle and personal property contained therein within ten days after the effective date of the notice. Persons may reclaim the vehicle or personal property upon payment of all towing, preservation, and storage charges resulting from placing the vehicle in custody and upon payment of the costs of notice required pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that failure of the owner, lienholders, or claimants to exercise their right to reclaim the vehicle or personal property within the time provided shall be deemed a waiver by the owner, lienholders, and claimants of all right, title, claim, and interest in the vehicle or personal property. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that failure to reclaim the vehicle or personal property is deemed consent for the police authority or private entity to sell the vehicle at a public auction or dispose of the vehicle to a demolisher and to dispose of the personal property by sale or destruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the abandoned vehicle was taken into custody by a private entity without a police authority\u8217\'3fs initiative, the notice shall state that the private entity may claim a garagekeeper\u8217\'3fs lien as described in }}}{{\f5\fs18\hyphpar0\qj{section 321.90, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and may proceed to sell or dispose of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the abandoned vehicle was taken into custody by a police authority or by a private entity hired by a police authority, the notice shall state that any person claiming rightful possession of the vehicle or personal property who disputes the planned disposition of the vehicle or personal property by the police authority or private entity or of the assessment of fees and charges provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may ask for an evidentiary hearing before the police authority to contest those matters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the persons receiving notice do not ask for a hearing or exercise their right to reclaim the vehicle or personal property within the ten-day reclaiming period, the owner, lienholders, or claimants shall no longer have any right, title, claim, or interest in or to the vehicle or the personal property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court in any case in law or equity shall not recognize any right, title, claim, or interest of the owner, lienholders, or claimants after the expiration of the ten-day reclaiming period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it is impossible to determine with reasonable certainty the identities and addresses of the last registered owner and all lienholders, notice by one publication in one newspaper of general circulation in the area where the vehicle was abandoned shall be sufficient to meet all requirements of notice under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The published notice may contain multiple listings of abandoned vehicles but shall be published within the same time requirements and contain the same information as prescribed for mailed notice in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E11_30_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E11_30_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Reclamation of abandoned vehicles.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to driving an abandoned vehicle away from the premises, a person who received or who is reclaiming the vehicle on behalf of a person who received notice under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall present to the police authority or private entity, as applicable, the person\u8217\'3fs valid driver\u8217\'3fs license and proof of financial liability coverage as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.20B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E11_30_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E11_30_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Auction of abandoned vehicles.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an abandoned vehicle has not been reclaimed as provided for in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the police authority or private entity shall make a determination as to whether or not the vehicle shall be sold for use upon the highways. If the vehicle is not sold for use upon the highways, it shall be sold for junk, or demolished and sold as scrap. The police authority or private entity shall sell the vehicle at public auction. Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a police authority or private entity may dispose of the vehicle to a demolisher for junk without public auction after complying with the notification procedures in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The purchaser of the vehicle takes title free and clear of all liens and claims of ownership, shall receive a sales receipt from the police authority or private entity, and is entitled to register the vehicle and receive a certificate of title if sold for use upon the highways. If the vehicle is sold or disposed of to a demolisher for junk, the demolisher shall make application for a junking certificate to the county treasurer within thirty days of purchase and shall surrender the sales receipt in lieu of the certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From the proceeds of the sale of an abandoned vehicle the police authority, if the police authority did not hire a private entity, shall reimburse itself for the expenses of the auction, the costs of towing, preserving, and storing which resulted from placing the abandoned vehicle in custody, all notice and publication costs incurred pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the cost of inspection, and any other costs incurred except costs of bookkeeping and other administrative costs. Any remainder from the proceeds of a sale shall be held for the owner of the vehicle or entitled lienholder for ninety days, and shall then be deposited in the road use tax fund. The costs to police authorities of auction, towing, preserving, storage, and all notice and publication costs, and all other costs which result from placing abandoned vehicles in custody, whenever the proceeds from a sale of the abandoned vehicles are insufficient to meet these expenses and costs, shall be paid from the road use tax fund and are the obligation of the last owner or owners, jointly and severally.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of transportation shall establish by rule a claims procedure to be followed by police authorities in obtaining expenses and costs from the fund and procedures for reimbursement of expenses and costs to a private entity hired by a police authority to take custody of an abandoned vehicle. If a private entity has been hired by a police authority, the police authority shall file a claim with the department for reimbursement of towing fees which shall be paid from the road use tax fund.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.89}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 64, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 123, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1158, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1238, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1126, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1074, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1016, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 35, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 64, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a723, 24}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 22, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 174, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a767, 187}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.323}}}{{\f5\fs12\hyphpar0\qj{, 80.39}}}{{\f5\fs12\hyphpar0\qj{, 321.20B}}}{{\f5\fs12\hyphpar0\qj{, 321.88}}}{{\f5\fs12\hyphpar0\qj{, 321.90}}}{{\f5\fs12\hyphpar0\qj{, 321.91}}}{{\f5\fs12\hyphpar0\qj{, 321J.4B}}}{{\f5\fs12\hyphpar0\qj{, 555B.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 2 applies retroactively to July 1, 2021; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1021, \'a7187}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.90}}}{\*\bkmkstart stylerid1_2E111_2E2_2E2}{\*\bkmkend stylerid1_2E111_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disposal of abandoned motor vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E111_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E111_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Garagekeepers and abandoned motor vehicles.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any motor vehicle left in a garage operated for commercial purposes after the period for which the vehicle was to remain on the premises shall, after notice by certified mail to the last known registered owner of the vehicle addressed to the owner\u8217\'3fs last known address of record to reclaim the vehicle within ten days of the date of the notice, be deemed an abandoned motor vehicle unless reclaimed by the owner within such ten-day period or the owner notifies the garagekeeper in writing within such period of time that such vehicle is not an abandoned motor vehicle and shall be reported by the garagekeeper to the police authority. If the identity or address of the last registered owner of the motor vehicle cannot be determined, the vehicle shall be deemed an abandoned motor vehicle on the eleventh day after the period for which the vehicle was to remain on the premises unless reclaimed by the owner within the ten-day period or the owner notifies the garagekeeper in writing within such period of time that such vehicle is not an abandoned motor vehicle and shall be reported by the garagekeeper to the police authority. All abandoned motor vehicles left in garages may be taken into custody by a police authority upon the request of the garagekeeper and sold in accordance with the procedures set forth in }}}{{\f5\fs18\hyphpar0\qj{section 321.89, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, unless the motor vehicle is reclaimed. The proceeds of the sale shall be first applied to the garagekeeper\u8217\'3fs charges for towing and storage, and any surplus proceeds shall be distributed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.89, subsection 5}}}{{\f5\fs18\hyphpar0\qj{. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to impair any lien of a garagekeeper under the laws of this state, or the right of a garagekeeper to foreclose the garagekeeper\u8217\'3fs lien, provided that a garagekeeper shall be deemed to have abandoned the garagekeeper\u8217\'3fs artisan lien when such vehicle is taken into custody by the police authority. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fgaragekeeper\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any operator of a parking place or establishment, motor vehicle storage facility, or establishment for the servicing, repair, or maintenance of motor vehicles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E111_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E111_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Disposal to demolisher.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person, firm, corporation, or unit of government upon whose property or in whose possession is found any abandoned motor vehicle, or any person being the owner of a motor vehicle whose title certificate is faulty, lost, or destroyed and is thereby unable to transfer title to the motor vehicle, may apply to the police authority of the jurisdiction in which the motor vehicle is situated for authority to sell, give away, or otherwise dispose of the motor vehicle to a demolisher.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application shall set out the name and address of the applicant, and the year, make, model, and vehicle identification number of the motor vehicle, if ascertainable, together with any other identifying features, and shall contain a concise statement of the facts surrounding the abandonment, or a statement that the title of the motor vehicle is lost or destroyed, or the reasons for the defect of title in the owner. The applicant shall execute an affidavit stating that the facts alleged are true and that no material fact has been withheld. An order for disposal obtained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.8, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, satisfies the application requirements of this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the police authority finds that the application is executed in proper form, and shows that the motor vehicle has been abandoned upon the property of the applicant, or if it shows that the motor vehicle is not abandoned but that the applicant appears to be the rightful owner, the police authority shall follow appropriate notification procedures as set forth in }}}{{\f5\fs18\hyphpar0\qj{section 321.89, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, except that in the case of an order for disposal obtained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.8, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, no notification is required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the abandoned motor vehicle is not reclaimed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.89, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or no lienholder objects to the disposal in the case of an owner-applicant, the police authority shall give the applicant a certificate of authority allowing the applicant to obtain a junking certificate for the motor vehicle. The applicant shall make application for a junking certificate to the county treasurer within thirty days of receipt of the certificate of authority and surrender the certificate of authority in lieu of the certificate of title. The demolisher shall accept the junking certificate in lieu of the certificate of title to the motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 321.89}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.91}}}{{\f5\fs18\hyphpar0\qj{, any person, firm, corporation, or unit of government upon whose property or in whose possession is found any abandoned motor vehicle, or any person being the owner of a motor vehicle whose title certificate is faulty, lost, or destroyed, may dispose of such motor vehicle to a demolisher for junk without a title and without the notification procedures of }}}{{\f5\fs18\hyphpar0\qj{section 321.89, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, if the motor vehicle lacks an engine or two or more wheels or other structural part which renders the vehicle totally inoperable. The police authority shall give the applicant a certificate of authority. The owner shall apply to the county treasurer for a junking certificate within thirty days of receipt of the certificate of authority and shall surrender the certificate of authority in lieu of the certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of an abandoned motor vehicle and all lienholders shall no longer have any right, title, claim, or interest in or to the motor vehicle; and no court in any case in law or equity shall recognize any right, title, claim, or interest of any owner or lienholders after the disposal of the motor vehicle to a demolisher.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any proceeds from the sale of an abandoned motor vehicle to a demolisher under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, by one other than the owner of the vehicle, except the sale of a vehicle pursuant to an order for disposal obtained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.8, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, shall first be applied to that person\u8217\'3fs expenses in effecting the sale, including storage, towing, and disposal charges, and any surplus shall be distributed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.89, subsection 5}}}{{\f5\fs18\hyphpar0\qj{. The proceeds from the sale of a vehicle disposed of pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 555B.8, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, shall be distributed in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 555B.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E111_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E111_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Duties of demolishers.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any demolisher who purchases or otherwise acquires an abandoned motor vehicle for junk under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall junk, scrap, wreck, dismantle, or demolish such motor vehicle. A demolisher shall not junk, scrap, wreck, dismantle, or demolish a vehicle until the demolisher has obtained the junking certificate issued for the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A demolisher shall keep an accurate and complete record of all motor vehicles purchased or received by the demolisher in the course of the demolisher\u8217\'3fs business. These records shall contain the name and address of the person from whom each motor vehicle was purchased or received and the date when the purchases or receipts occurred. The records shall be open for inspection by any police authority at any time during normal business hours. Any record required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be kept by the demolisher for at least one year after the transaction to which it applies.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.90}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1138, \'a712 \u8211\'3f 14}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 118, \'a714, 15}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 179, \'a7128}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1018, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.323}}}{{\f5\fs12\hyphpar0\qj{, 321.89}}}{{\f5\fs12\hyphpar0\qj{, 321.91}}}{{\f5\fs12\hyphpar0\qj{, 555B.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.91}}}{\*\bkmkstart stylerid1_2E112_2E2_2E2}{\*\bkmkend stylerid1_2E112_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitation on liability \u8212\'3f penalty for abandonment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person, firm, corporation, unit of government, garagekeeper or police authority upon whose property an abandoned vehicle is found or who disposes of such abandoned vehicle in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 321.89}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.90}}}{{\f5\fs18\hyphpar0\qj{ shall be liable for damages by reason of the removal, sale, or disposal of such vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who abandons a vehicle is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 14}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.91}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1203, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 137, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1101, \'a735}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.323}}}{{\f5\fs12\hyphpar0\qj{, 321.89}}}{{\f5\fs12\hyphpar0\qj{, 321.90}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(14)(b)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.92}}}{\*\bkmkstart stylerid1_2E113_2E2_2E2}{\*\bkmkend stylerid1_2E113_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Altering or changing numbers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E113_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E113_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Fraudulent intent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No person shall with fraudulent intent, deface, destroy, or alter the vehicle identification number or component part number or other distinguishing number or identification mark of a vehicle or component part, including a rebuilt identification, nor shall a person place or stamp a serial, engine, or other number or mark upon a vehicle or component part, except one assigned thereto by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The year of manufacture of a fence-line feeder, grain cart, or tank wagon manufactured on or after July 1, 2001, shall be permanently made a part of the identification plate on the vehicle. A person shall not fraudulently alter, deface, or attempt to fraudulently alter or deface the year of manufacture or other product identification number on a fence-line feeder, grain cart, or tank wagon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is a felony punishable as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.483}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit the restoration of an original vehicle identification number, component part number, or other number or mark when the restoration is made by the department, nor prevent a manufacturer from placing, in the ordinary course of business, numbers or marks upon vehicles or component parts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E113_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E113_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Vehicles without identification numbers.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who knowingly buys, receives, disposes of, sells, offers for sale, or has in the person\u8217\'3fs possession a vehicle, or a component part of a vehicle, from which the vehicle identification number, rebuilt identification, or component part number has been removed, defaced, covered, altered, or destroyed for the purpose of concealing or misrepresenting the identity of the vehicle or component part is guilty of a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m12a; C24, 27, 31, 35, \'a75080; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.09, 5006.21;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7321.80, 321.92; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.92}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1089, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a7117}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321H.6}}}{{\f5\fs12\hyphpar0\qj{, 321H.8}}}{{\f5\fs12\hyphpar0\qj{, 322.3}}}{{\f5\fs12\hyphpar0\qj{, 322.6}}}{{\f5\fs12\hyphpar0\qj{, 322C.3}}}{{\f5\fs12\hyphpar0\qj{, 322C.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Similar provisions, }{{\f5\fs12\hyphpar0\qj{\'a7714.8(5)}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.93}}}{\*\bkmkstart stylerid1_2E114_2E2_2E2}{\*\bkmkend stylerid1_2E114_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Defense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Under a charge of possessing a vehicle or component part, the vehicle identification number or component part number of which is defaced, altered, or tampered with, it shall be a complete defense that the accused at the time of such possession had in the accused\u8217\'3fs possession a certificate of title from the officer whose duty it is to register vehicles and component parts in the state in which the vehicle or component part is registered, showing good and sufficient reason why numbers are defaced, changed, or tampered with, the original vehicle identification number or component part number, and the ownership of the vehicle or component part.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75083; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.22;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.93}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.94}}}{\*\bkmkstart stylerid1_2E115_2E2_2E2}{\*\bkmkend stylerid1_2E115_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Test to determine true number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Where it appears that a vehicle identification number or component part number has been altered, defaced or tampered with, any peace officer, or any other person acting under a peace officer\u8217\'3fs direction, may apply any recognized process or test to the part containing the number for the purpose of determining the true number.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a75083-b5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.23;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.94}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 103, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.95}}}{\*\bkmkstart stylerid1_2E116_2E2_2E2}{\*\bkmkend stylerid1_2E116_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Right of inspection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Peace officers shall have the authority to inspect any vehicle or component part in possession of a vehicle rebuilder, vehicle salvager, used vehicle parts dealer, or any person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{, or found upon the public highway or in any public garage, enclosure, or property in which vehicles or component parts are kept for sale, storage, hire, or repair and for that purpose may enter any such public garage, enclosure, or property. Every vehicle rebuilder, vehicle salvager, used vehicle parts dealer, or any person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{, or a person having used engines or transmissions which are component parts for sale shall keep an accurate and complete record of all vehicles demolished and of such component parts purchased or received for resale as component parts in the course of business. These records shall contain the name and address of the person from whom each such vehicle or component part was purchased or received and the date when the purchase or receipt occurred or the junking certificate if required for the vehicle. These records shall be open for inspection by any peace officer at any time during normal business hours. Records required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be kept for at least three years after the transaction which they record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates this section commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a75083-b6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.24;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.95}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 130, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7805.8A(14)(j)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable scheduled fine, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8A}}}{, subsection 14, paragraph j}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.96}}}{\*\bkmkstart stylerid1_2E117_2E2_2E2}{\*\bkmkend stylerid1_2E117_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited plates }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ certificates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not display or cause or permit to be displayed, or have in the person\u8217\'3fs possession, a vehicle identification number or component part number except as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or a canceled, revoked, altered, or fictitious registration number plates, registration receipt, or certificate of title, as the same are respectively provided for in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75084; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5006.25;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.96}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1140, \'a73}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E118_2E1_2E1}{OFFENSES AGAINST REGISTRATION LAWS}{\*\bkmkend stylerid1_2E118_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{AND SUSPENSION OR REVOCATION}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{OF REGISTRATION}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.97}}}{\*\bkmkstart stylerid1_2E119_2E2_2E2}{\*\bkmkend stylerid1_2E119_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fraudulent applications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who fraudulently uses a false or fictitious name in any application for the registration of, or certificate of title to, a vehicle or knowingly makes a false statement or knowingly conceals a material fact or otherwise commits a fraud in any such application is guilty of a fraudulent practice.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m26; C24, 27, 31, 35, \'a75088; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5007.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.97}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7322C.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fraudulent practices, see }{{\f5\fs12\hyphpar0\qj{\'a7714.8 }}}{{\f5\fs12\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs12\hyphpar0\qj{ 714.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.98}}}{\*\bkmkstart stylerid1_2E12_30_2E2_2E2}{\*\bkmkend stylerid1_2E12_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operation without registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Except as otherwise expressly permitted in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a person shall not operate and an owner shall not knowingly permit to be operated upon any highway any vehicle required to be registered and titled under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ unless:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A valid registration card and registration plate or plates issued for the vehicle for the current registration year are attached to and displayed on the vehicle when and as required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{; and }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate of title has been issued for the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75085; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5007.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.98}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 176, \'a750, 59}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a777}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7322C.6}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(r)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.99}}}{\*\bkmkstart stylerid1_2E121_2E2_2E2}{\*\bkmkend stylerid1_2E121_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fraudulent use of registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not knowingly lend to another a registration card, registration plate, special plate, or permit issued to the person if the other person desiring to borrow the card, plate, or permit would not be entitled to the use of it. A person shall not knowingly permit the use of a registration card, registration plate, special plate, or permit issued to the person by one not entitled to it, nor shall a person knowingly display upon a vehicle a registration card, registration plate, special plate, or permit not issued for that vehicle under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. A person convicted of a violation of }{{\f5\fs18\hyphpar0\qj{this section}}}{ is guilty of a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 2}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m12a; C24, 27, 31, 35, \'a74878, 5080; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5007.03;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.99}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 125, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1055, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a735}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321H.6}}}{{\f5\fs12\hyphpar0\qj{, 321H.8}}}{{\f5\fs12\hyphpar0\qj{, 322.3}}}{{\f5\fs12\hyphpar0\qj{, 322.6}}}{{\f5\fs12\hyphpar0\qj{, 322C.3}}}{{\f5\fs12\hyphpar0\qj{, 322C.6}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(s)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.100}}}{\*\bkmkstart stylerid1_2E122_2E2_2E2}{\*\bkmkend stylerid1_2E122_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{False evidences of registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is a fraudulent practice for any person to commit any of the following acts:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To alter with a fraudulent intent any certificate of title, manufacturer\u8217\'3fs or importer\u8217\'3fs certificate, registration card, registration plate, manufacturer\u8217\'3fs vehicle identification plate, or permit issued by the department or county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To forge or counterfeit any such document or plate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To hold or use any such document or plate knowing the same to have been so altered, forged, or falsified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To hold or use any certificate of title, manufacturer\u8217\'3fs or importer\u8217\'3fs certificate, registration card, registration plate, manufacturer\u8217\'3fs vehicle identification plate, or permit issued by the department or county treasurer, for any vehicle to which such document or plate is not legally assigned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To transfer in any manner or to offer to transfer in any manner a certificate of title, manufacturer\u8217\'3fs or importer\u8217\'3fs certificate to any vehicle on which a salvage certificate of title or junking certificate is required under }}}{{\f5\fs18\hyphpar0\qj{section 321.52}}}{{\f5\fs18\hyphpar0\qj{, with knowledge or reason to believe that the certificate will be used for a vehicle other than the vehicle for which the certificate is issued. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTransfer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ means to sell, exchange, change possession or ownership or convey in any manner.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m12a; C24, 27, 31, 35, \'a75080; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5007.04;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.100}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 97, \'a744}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7322C.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fraudulent practices, see }{{\f5\fs12\hyphpar0\qj{\'a7714.8 }}}{{\f5\fs12\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs12\hyphpar0\qj{ 714.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.101}}}{\*\bkmkstart stylerid1_2E123_2E2_2E2}{\*\bkmkend stylerid1_2E123_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspension or revocation of registration or cancellation of certificate of title by department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department is hereby authorized to suspend or revoke the registration of a vehicle, registration card, registration plate, or any nonresident or other permit in any of the following events:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the department is satisfied that such registration card, plate, or permit was fraudulently or erroneously issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the department determines that a registered vehicle is mechanically unfit or unsafe to be operated or moved upon the highways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a registered vehicle has been dismantled or wrecked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the department determines that the required annual registration fee has not been paid and the fee is not paid upon reasonable notice and demand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a registration card, registration plate, or permit is knowingly displayed upon a vehicle other than the one for which issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the department determines that the owner has committed any offense under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ involving the registration card, plate, or permit to be suspended or revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the department is so authorized under any other provision of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a commercial motor vehicle has been assigned to be operated by a commercial motor carrier whose ability to operate has been terminated or denied by a federal agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall cancel a certificate of title that appears to have been improperly issued or fraudulently obtained or, in the case of a mobile home or manufactured home, if taxes were owing under }}}{{\f5\fs18\hyphpar0\qj{chapter 435}}}{{\f5\fs18\hyphpar0\qj{ at the time the certificate was issued and have not been paid. However, before the certificate to a mobile home or manufactured home for which taxes were owing can be canceled, notice and opportunity to pay the taxes must be given to the person to whom the certificate was issued. Upon cancellation of a certificate of title, the department shall notify the county treasurer who issued it, who shall enter the cancellation upon the records. The department shall also notify the person to whom the certificate of title was issued, as well as each lienholder who has a perfected lien, of the cancellation and shall demand the surrender of the certificate of title, but the cancellation shall not affect the validity of any perfected lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of suspension or revocation of the registration of a vehicle, registration card, registration plate, or any nonresident or other permit under the terms of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be by personal delivery of the notice to the person to be so notified or by certified mail addressed to the person at the person\u8217\'3fs address as shown on the registration record. A return acknowledgment is not necessary to prove such latter service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a vehicle, for which the registration has been suspended or revoked pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 321.101A}}}{{\f5\fs18\hyphpar0\qj{, is transferred to a bona fide purchaser for value without actual knowledge of such suspension or revocation, then the vehicle shall be deemed to be registered and the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 321.28}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.30}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not be applicable to such vehicle for the failure of the previous owner to pay the required fees.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a75090; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5007.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.101}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a714}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 55, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 188, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1016, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 153, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1013, \'a719, 35}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 126, \'a755}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a784}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.30}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.101A}}}{\*\bkmkstart stylerid1_2E124_2E2_2E2}{\*\bkmkend stylerid1_2E124_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revocation of registration by county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county treasurer may revoke the registration and registration plates of a vehicle if the annual registration fee or the fee for new registration is paid by check, electronic payment, or credit card and the check, electronic payment, or credit card is not honored by the payer\u8217\'3fs financial institution or credit card company, upon reasonable notice and demand. The owner of the vehicle or person in possession of the registration and registration plates for the vehicle shall immediately return the revoked registration and registration plates to the appropriate county treasurer\u8217\'3fs office.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1016, \'a713}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1070, \'a78, 31}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a785}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.30}}}{{\f5\fs12\hyphpar0\qj{, 321.101}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.102}}}{\*\bkmkstart stylerid1_2E125_2E2_2E2}{\*\bkmkend stylerid1_2E125_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspending or revoking special registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department is also authorized to suspend or revoke a certificate or the special plates issued to a manufacturer, transporter, or dealer upon determining that any said person is not lawfully entitled thereto or has made or knowingly permitted any illegal use of such plates or has committed fraud in the registration of vehicles or failed to give notices of transfer when and as required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5007.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.102}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.103}}}{\*\bkmkstart stylerid1_2E126_2E2_2E2}{\*\bkmkend stylerid1_2E126_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Owner to return evidences of registration and title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever the department as authorized hereunder cancels, suspends, or revokes the registration of a vehicle, or certificate of title, or registration card, or registration plate or plates, or any nonresident or other permit or the registration of any dealer, the owner or person in possession of the same shall immediately return the evidences of registration, certificate of title, or plates so canceled, suspended, or revoked to the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5007.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.103}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.104}}}{\*\bkmkstart stylerid1_2E127_2E2_2E2}{\*\bkmkend stylerid1_2E127_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penal offenses against title law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is a simple misdemeanor punishable as a scheduled violation under }{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 2}}}{, for any person to commit any of the following acts:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To operate any motor vehicle upon the highways upon which the certificate of title has been canceled, or while a certificate of registration of a motor vehicle is suspended or revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a dealer or a person acting on behalf of a dealer to acquire, purchase, hold or display for sale a motor vehicle without having obtained a manufacturer\u8217\'3fs or importer\u8217\'3fs certificate or a certificate of title, or assignments thereof, unless otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To fail to surrender a certificate of title, registration card, or registration plates upon cancellation, suspension, or revocation of the certificate or registration by the department and notice as prescribed in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To sell, offer for sale, or transfer a motor vehicle, trailer, or semitrailer, except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.47}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.48}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 321.52, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, without obtaining a certificate of title in the name of the seller or transferor or without delivering to the purchaser or transferee a certificate of title or a manufacturer\u8217\'3fs or importer\u8217\'3fs certificate duly assigned to the purchaser or transferee as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To violate any of the other provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or any lawful rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a manufactured or mobile home retailer to sell or transfer a mobile home or manufactured home without delivering to the purchaser or transferee a certificate of title or a manufacturer\u8217\'3fs or importer\u8217\'3fs certificate properly assigned to the purchaser, or to transfer a mobile home or manufactured home without disclosing to the purchaser the owner of the mobile home or manufactured home in a manner prescribed by the department pursuant to rules, or to fail to apply for and obtain a certificate of title for a used mobile home or manufactured home, titled in Iowa, acquired by the manufactured or mobile home retailer within thirty days from the date of acquisition as required under }}}{{\f5\fs18\hyphpar0\qj{section 321.45, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71571-m24; C24, 27, 31, 35, \'a75086; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5007.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.104}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a715}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 195, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1237, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 130, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 188, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1154, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 52, \'a76, 14}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 31, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.48}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(t)}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E128_2E1_2E1}{REGISTRATION FEES}{\*\bkmkend stylerid1_2E128_2E1_2E1}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Local vehicle tax; see }{{\f5\fs12\qc{chapter 423B}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.105}}}{\*\bkmkstart stylerid1_2E129_2E2_2E2}{\*\bkmkend stylerid1_2E129_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual registration fee required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An annual registration fee shall be paid for each vehicle operated upon the public highways of this state unless the vehicle is specifically exempted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If a vehicle, which has been registered for the current registration year, is transferred during the registration year, the transferee shall reregister the vehicle as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.46}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual registration fee shall be paid to the county treasurer at the same time the application is made for the registration or reregistration of the motor vehicle or trailer. An owner may, when applying for registration or reregistration of a motor vehicle or trailer, request that the plates be mailed to the owner\u8217\'3fs post office address. The owner\u8217\'3fs request shall be accompanied by a mailing fee as determined annually by the director in consultation with the Iowa county treasurers association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application by a financial institution, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.61}}}{{\f5\fs18\hyphpar0\qj{, and approval of the application by the county treasurer, the county treasurer in any county may authorize the financial institution to receive applications for renewal of vehicle registrations and payment of the annual registration fees. The annual registration fees shall be delivered to the county treasurer at the time the county treasurer has processed the vehicle registration application. Annual registration fees received with vehicle registration applications shall be designated as public funds only upon receipt of such funds by the county treasurer from the financial institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the payment of an annual registration fee for each trailer and semitrailer to be issued a registration plate under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{, an additional registration fee may be paid for a period of four subsequent registration years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seriously disabled veterans who have been provided with an automobile or other vehicle by the United States government under the provisions of }}}{{\f5\fs18\hyphpar0\qj{38 U.S.C. \'a73901 }}}{{\f5\fs18\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs18\hyphpar0\qj{ 3904}}}{{\f5\fs18\hyphpar0\qj{, shall be exempt from payment of the registration fee provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for that vehicle, and shall be provided, without fee, with one set of regular registration plates or one set of any type of special registration plates associated with service in the United States armed forces for which the disabled veteran qualifies under }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{. The disabled veteran, to be able to claim the benefit, must be a resident of the state of Iowa. In lieu of the set of regular or special military registration plates available without fee, the disabled veteran may obtain a set of nonmilitary special registration plates or personalized plates issued under }}}{{\f5\fs18\hyphpar0\qj{section 321.34}}}{{\f5\fs18\hyphpar0\qj{ by paying the additional fees associated with those plates.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m7; C24, 27, 31, 35, \'a74904; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.01;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.105}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a712, 38}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 123, \'a7125, 209}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1182, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 118, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 108, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1216, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1018, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7109}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725.1}}}{{\f5\fs12\hyphpar0\qj{, 321.34}}}{{\f5\fs12\hyphpar0\qj{, 321.105A}}}{{\f5\fs12\hyphpar0\qj{, 321.145}}}{{\f5\fs12\hyphpar0\qj{, 321.166}}}{{\f5\fs12\hyphpar0\qj{, 321L.2}}}{{\f5\fs12\hyphpar0\qj{, 326.2}}}{{\f5\fs12\hyphpar0\qj{, 331.427}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Collection of mobile home tax, }{{\f5\fs12\hyphpar0\qj{\'a7435.24}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.105A}}}{\*\bkmkstart stylerid1_2E13_30_2E2_2E2}{\*\bkmkend stylerid1_2E13_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fee for new registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E13_30_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following terms, when used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall have the following meanings, except in those instances where the context clearly indicates otherwise:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOwner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1}}}{{\f5\fs18\hyphpar0\qj{. For purposes of the fee for new registration imposed on leased vehicles under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fowner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flessor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPurchase\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any transfer, exchange, or barter, conditional or otherwise, in any manner or by any means whatsoever, for consideration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E13_30_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Fee imposed \u8212\'3f exemptions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the annual registration fee required under }}}{{\f5\fs18\hyphpar0\qj{section 321.105}}}{{\f5\fs18\hyphpar0\qj{, a \u8220\'3ffee for new registration\u8221\'3f is imposed in the amount of ten dollars plus five percent of the purchase price for each vehicle subject to registration. The fee for new registration shall be paid by the owner of the vehicle to the county treasurer at the time application is made for a new initial registration and certificate of title, if applicable. A new registration receipt shall not be issued until the fee has been paid. The county treasurer or the department of transportation shall require every applicant for a new registration receipt for a vehicle subject to registration to supply information as the county treasurer or the director deems necessary as to the time of purchase, the purchase price, and other information relative to the purchase of the vehicle. On or before the tenth day of each month, the county treasurer or the department of transportation shall remit to the department of revenue the amount of the fees for new registration collected during the preceding month.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpurchase price\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies to the measure subject to the fee for new registration. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPurchase price\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be determined in the same manner as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsales price\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is determined for purposes of computing the tax imposed upon the sales price of tangible personal property under }}}{{\f5\fs18\hyphpar0\qj{chapter 423}}}{{\f5\fs18\hyphpar0\qj{, pursuant to the definition of sales price in }}}{{\f5\fs18\hyphpar0\qj{section 423.1}}}{{\f5\fs18\hyphpar0\qj{. The following are exempt from the fee for new registration imposed by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of any cash rebate which is provided by a motor vehicle manufacturer to the purchaser of the vehicle subject to registration so long as the rebate is applied to the purchase price of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In transactions, except those subject to subparagraph division (b), in which a vehicle subject to registration is traded toward the purchase price of another vehicle subject to registration, the portion of the purchase price which is not valued in money, whether received in money or not, if the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vehicle traded to the retailer is the type of vehicle normally sold in the regular course of the retailer\u8217\'3fs business.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vehicle traded to the retailer is intended by the retailer to be ultimately sold at retail or is intended to be used by the retailer or another in the remanufacturing of a like vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a transaction between persons, neither of which is a retailer of vehicles subject to registration, in which a vehicle subject to registration is traded toward the purchase price of another vehicle subject to registration, the amount of the trade-in value allowed on the vehicle subject to registration traded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person listed on the title and registration of the newly acquired vehicle must be the same person listed on the title and registration of the traded vehicle being traded in order to exclude the trade-in value from the purchase price. Additionally, the following trades qualify under this subparagraph division (c):}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trade between spouses, if the traded vehicle and the acquired vehicle are titled in the name of one or both of the spouses, with no outside party named on the title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trade between lineal family members, including adopted and step relationships, if one of the family members from the title of the traded vehicle is also on the title of the newly acquired vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trade involving an entity, if one of the owners listed on the title of the traded vehicle is an entity. If multiple names appear on the title, the names must be separated by \u8220\'3for\u8221\'3f. For purposes of trades under this subparagraph subdivision, a sole proprietorship shall not be distinguished from an individual owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trade in which the vehicle being purchased is titled in the name of an individual other than the owner of the traded vehicle due to the cosigning requirements of a financial institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fair market value of a replacement motor vehicle owned by a motor vehicle dealer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ which is being registered by that dealer and is not otherwise exempt from the fee for new registration, if all of the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motor vehicle being registered is being placed in service as a replacement motor vehicle for a motor vehicle registered by the motor vehicle dealer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motor vehicle being registered is taken from the motor vehicle dealer\u8217\'3fs inventory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Use tax or the fee for new registration on the motor vehicle being replaced was paid by the motor vehicle dealer when that motor vehicle was registered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The replaced motor vehicle is returned to the motor vehicle dealer\u8217\'3fs inventory for sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application for registration and title of the motor vehicle being registered is filed with the county treasurer within two weeks of the date the replaced motor vehicle is returned to the motor vehicle dealer\u8217\'3fs inventory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motor vehicle being registered is placed in the same or substantially similar service as the replaced motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the fee for new registration on a vehicle registered in this state by the manufacturer of that vehicle from a manufacturer\u8217\'3fs statement of origin is calculated on the base value of fifty percent of the retail list price of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following are exempt from the fee for new registration imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, as long as a valid affidavit is filed with the county treasurer at the time of application for registration:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Entities listed in }}}{{\f5\fs18\hyphpar0\qj{section 423.3, subsections 17, 18, 19, 20, 21, 22, 26, 27, 28, 31, and 79}}}{{\f5\fs18\hyphpar0\qj{, to the extent that those entities are exempt from the tax imposed on the sale of tangible personal property sold at retail in the state to consumers or users.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsections 41, 64A, 71, 85, and 88}}}{{\f5\fs18\hyphpar0\qj{, except such vehicles subject to registration which are designed primarily for carrying persons, when purchased for lease and actually leased to a lessee for use outside the state of Iowa and the subsequent sole use in Iowa is in interstate commerce or interstate transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles subject to registration which are transferred from an entity doing business within this state to another entity doing business within this state if all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The receiving entity was formed by the transferring entity for the purpose of continuing the business.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(A)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All ownership remains the same and in the same proportions as the previous ownership with no fewer or additional owners or replacement owners.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(B)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a sole proprietorship, the spouse of the sole proprietor may stand in place of the sole proprietor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This exemption also applies where the vehicles subject to registration are transferred from a corporation as part of the liquidation of the corporation to its stockholders if within three months of such transfer the stockholders retransfer those vehicles subject to registration to a sole proprietorship, partnership, or limited liability company for the purpose of continuing the business of the corporation when all of the incidents of ownership are owned by the same person or persons who were stockholders of the corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an exemption under this subparagraph, a receiving entity shall have been in existence for not longer than twenty-four months.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles subject to registration which are transferred from a corporation that is primarily engaged in the business of leasing vehicles subject to registration to a corporation that is primarily engaged in the business of leasing vehicles subject to registration when the transferor and transferee corporations are part of the same controlled group for federal income tax purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles registered or operated under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ and used substantially in interstate commerce. For purposes of this subparagraph (5), }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsubstantially in interstate commerce\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that a minimum of twenty-five percent of the miles operated by the vehicle accrues in states other than Iowa. This subparagraph (5) applies only to vehicles which are registered for a gross weight of thirteen tons or more.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this subparagraph (5), trailers and semitrailers registered or operated under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ are deemed to be used substantially in interstate commerce and to be registered for a gross weight of thirteen tons or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of this subparagraph (5), if a vehicle meets the requirement that twenty-five percent of the miles operated accrues in states other than Iowa in each year of the first four-year period of operation, the exemption from the fee for new registration shall continue until the vehicle is sold or transferred. If the vehicle is found to have not met the exemption requirements or the exemption was revoked, the value of the vehicle upon which the fee for new registration shall be imposed is based on the original purchase price if revocation or nonqualification for this exemption occurs during the first year following registration. If revocation or nonqualification for this exemption occurs after the first year following registration, the value of the vehicle upon which the fee shall be imposed is the book or market value, whichever is less, at the time the exemption requirements were not met or the exemption was revoked.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles, excluding autocycles, motorcycles, and motorized bicycles, subject to registration in any state when purchased for rental or registered and titled by a motor vehicle dealer licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ for rental use, and held for rental for a period of one hundred twenty days or more and actually rented for periods of sixty days or less by a person regularly engaged in the business of renting vehicles, including but not limited to motor vehicle dealers licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{ who rent automobiles to users, if the rental of the vehicles is subject to taxation under }}}{{\f5\fs18\hyphpar0\qj{section 423.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 423C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles subject to registration in this state for which the applicant for registration has paid to another state a state sales, use, or occupational tax, or paid the equivalent sales or excise tax of another country to that country. However, if the tax paid to another state or country is less than the fee for new registration calculated for the vehicle, the difference shall be the amount to be collected as the fee for new registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle subject to registration in this state which is owned by a person who has moved from another state or country with the intention of changing residency to Iowa, provided that the vehicle was purchased for use in the state or country from which the applicant moved and was not, at or near the time of purchase, purchased for use in Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle that was previously registered in this state and was subsequently registered in another state is not subject to the fee for new registration when it is again registered in this state, provided that the applicant for registration has maintained ownership of the vehicle since its initial registration in this state and has previously paid the use tax or fee for new registration for the vehicle in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles transferred by operation of law as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.47}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles for which ownership is transferred to or from a revocable or irrevocable trust, if no consideration is present.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles transferred to the surviving corporation for no consideration as a result of a corporate merger according to the laws of this state in which the merging corporation is immediately extinguished and dissolved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles purchased in this state by a nonresident for removal to the nonresident\u8217\'3fs state of residence if the purchaser applies to the county treasurer for a transit plate under }}}{{\f5\fs18\hyphpar0\qj{section 321.109}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(14)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles purchased by a licensed motor vehicle dealer for resale or primarily for use by the dealer\u8217\'3fs customers while the customers\u8217\'3f vehicles are being serviced or repaired by the dealer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(15)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles purchased by a wholesaler of new motor vehicles licensed under }}}{{\f5\fs18\hyphpar0\qj{section 322.27A}}}{{\f5\fs18\hyphpar0\qj{ for resale by the same wholesaler.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(16)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Homemade vehicles built from parts purchased at retail, upon which the consumer paid a tax to the seller, but only on such vehicles never before registered. This exemption does not apply for vehicles subject to registration which are made by a manufacturer engaged in the business for the purpose of sales or rental.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(17)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles titled under a salvage certificate of title. However, when such a vehicle has been repaired and a regular certificate of title is applied for, the fee for new registration is due as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the owner of the vehicle is a licensed recycler, unless the applicant is licensed as a vehicle dealer, the fee for new registration applies based on the fair market value of the vehicle, with deduction allowed for the cost of parts, supplies, and equipment for which sales tax was paid and which were used to rebuild the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the owner is a person who is not licensed as a recycler or vehicle dealer, the fee for new registration applies based on the fair market value of the vehicle, with deduction allowed for the cost of parts, frames, chassis, auto bodies, or supplies that were purchased to rebuild the vehicle and for which sales tax was paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(18)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle delivered to a resident Native American Indian on a reservation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(19)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle transferred from one individual to another individual as a gift in a transaction in which no consideration is present.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(20)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle given by a corporation as a gift to a retiring employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(21)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle sold by an entity where the profits from the sale are used by or donated to a nonprofit entity which is exempt from federal income taxation pursuant to section 501(c)(3) of the Internal Revenue Code, a government entity, or a nonprofit private educational institution, and where the entire proceeds from the sale of the vehicle are expended for any of the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Educational.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Religious.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Charitable. A charitable act is an act done out of goodwill, benevolence, and a desire to add to or to improve the good of humankind in general or any class or portion of humankind, with no pecuniary profit inuring to the person performing the service or giving the gift.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(22)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle given or sold to be subsequently awarded as a raffle prize under }}}{{\f5\fs18\hyphpar0\qj{chapter 99B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(23)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle won as a raffle prize under }}}{{\f5\fs18\hyphpar0\qj{chapter 99B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(24)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle that is directly and primarily used in the recycling or reprocessing of waste products.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(25)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles subject to registration under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ when purchased for lease and titled by the lessor licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 321F}}}{{\f5\fs18\hyphpar0\qj{ and actually leased for a period of six months or more if the lease of the vehicle is subject to the fee for new registration under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ or exempt from the fee for new registration pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lessor may maintain the exemption under this subparagraph (25) for a qualifying lease that terminates at the conclusion or prior to the contracted expiration date if the lessor does not use the vehicle for any purpose other than for lease.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once the vehicle is used by the lessor for a purpose other than for lease, the exemption under this subparagraph (25) no longer applies and, unless there is another exemption from the fee for new registration, the fee for new registration is due on the fair market value of the vehicle determined at the time the lessor uses the vehicle for a purpose other than for lease, payable to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the lessor holds the vehicle exclusively for sale, the fee for new registration is due and payable on the purchase price of the vehicle at the time of purchase pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(26)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle repossessed by a licensed vehicle dealer pursuant to the uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554}}}{{\f5\fs18\hyphpar0\qj{, provided there is a valid lien on the title and the dealer anticipates reselling the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(27)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle repossessed by a financial institution or an individual by means of a foreclosure affidavit pursuant to the uniform commercial code, }}}{{\f5\fs18\hyphpar0\qj{chapter 554}}}{{\f5\fs18\hyphpar0\qj{, provided there is a valid lien on the vehicle and the foreclosure affidavit is used for the sole purpose of retaining possession of the vehicle until a new buyer is found. However, if the financial institution or individual uses the foreclosure affidavit to take title to the vehicle and register the vehicle, the fee for new registration shall be due based on the outstanding loan amount on the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(28)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A damaged vehicle acquired by an insurance company from a client or financial institution, provided the insurance company has a vehicle dealers license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(29)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle returned to a manufacturer and titled in the manufacturer\u8217\'3fs name under }}}{{\f5\fs18\hyphpar0\qj{section 322G.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(30)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle purchased directly by a federal, state, or local governmental agency and titled in an individual\u8217\'3fs name pursuant to a governmental program authorized by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(31)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A new completed motor vehicle purchased at retail by an equipment dealer who is licensed as a motor vehicle dealer under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{, provided that all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The equipment dealer modifies the vehicle as provided in subparagraph division (b), subparagraph subdivision (i) or (ii).}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total value of the work performed and the equipment installed on the vehicle equals or exceeds eighty percent of the purchase price paid for the new vehicle.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 322.3}}}{{\f5\fs18\hyphpar0\qj{, the equipment dealer sells the modified vehicle as a used vehicle to a purchaser that is a business or government entity, and not an individual consumer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this subparagraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fequipment dealer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who does at least one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rebuilds new completed motor vehicles by fabricating, altering, adding, or replacing essential parts, components, or equipment for the purpose of building an ambulance, rescue vehicle, fire vehicle, or towing or recovery vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Installs cranes, hook loaders, buckets, aerial ladders, tanks, or special equipment on new completed motor trucks with a gross vehicle weight rating of fourteen thousand five hundred pounds or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E13_30_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Leased vehicles.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fee for new registration is imposed in an amount equal to ten dollars plus five percent of the leased price for each vehicle subject to registration which is leased by a lessor licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 321F}}}{{\f5\fs18\hyphpar0\qj{ for a period of six months or more. The fee for new registration shall be paid by the owner of the vehicle to the county treasurer from whom the registration receipt or certificate of title is obtained. A registration receipt for a vehicle subject to registration or issuance of a certificate of title shall not be issued until the fee for new registration is paid in the initial instance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of the lease price subject to the fee for new registration shall be computed on each separate lease transaction by taking the total of the lease payments, plus the down payment, and excluding the following charges, if included as part of the lease payment:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Title fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annual registration fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fee for new registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Federal excise taxes attributable to the sale of the vehicle to the owner or to the lease of the vehicle by the owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Optional service or warranty contracts subject to tax pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 423.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Manufacturer\u8217\'3fs rebate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refundable deposit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Finance charges, if any, on items listed in subparagraphs (1) through (8).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any or all of the items in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) through (8), are excluded from the lease price subject to the fee for new registration, the owner shall maintain adequate records of the amounts of those items. If the parties to a lease enter into an agreement providing that the fee for new registration is to be paid by the lessee or included in the monthly lease payments to be paid by the lessee, the total cost of the fee for new registration shall not be included in the computation of the lease price for the purpose of the fee for new registration under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The county treasurer or the department of transportation shall require every applicant for a registration receipt for a vehicle subject to a fee for new registration to supply information as the county treasurer or the director deems necessary as to the date of the lease transaction, the lease price, and other information relative to the lease of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before the tenth day of each month, the county treasurer or the department of transportation shall remit to the department of revenue the amount of the fees for new registration collected during the preceding month.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the lease is terminated or voided prior to the termination date contained in the lease agreement, no refund shall be allowed for a fee for new registration previously paid under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 322G.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following are exempt from the fee for new registration imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ as long as a valid affidavit is filed with the county treasurer at the time of application for registration:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vehicles leased to entities listed in }}}{{\f5\fs18\hyphpar0\qj{section 423.3, subsections 17, 18, 19, 20, 21, 22, 26, 27, 28, 31, and 79}}}{{\f5\fs18\hyphpar0\qj{, to the extent that those entities are exempt from the tax imposed on the sale of tangible personal property sold at retail in the state to consumers or users.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle leased directly to a federal, state, or local governmental agency and titled in an individual\u8217\'3fs name pursuant to a governmental program authorized by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle leased between affiliates, when the lessor has paid the fee imposed in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ on the leased vehicle prior to the lease.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this subparagraph:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAffiliate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a lessor that directly or indirectly controls, is controlled with or by, or is under common control with the lessee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fControl\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcontrolled\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(A)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a United States corporation, the ownership, directly or indirectly, of fifty percent or more of the voting power to elect directors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(B)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a foreign corporation, if the voting power to elect the directors is less than fifty percent, the maximum amount allowed by applicable law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(C)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of an entity other than a corporation, fifty percent or more ownership interest in the entity, or the power to direct the management of the entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E13_30_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Administration and enforcement \u8212\'3f director of revenue.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of revenue in consultation with the department of transportation shall administer and enforce the fee for new registration as nearly as possible in conjunction with the administration and enforcement of the state use tax law, except that portion of the law which implements the streamlined sales and use tax agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 422.25, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 422.30}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.67}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{422.68}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 422.69, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 422.70}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.71}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.72}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.74}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{422.75}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 423.14, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{sections 423.23}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{423.24}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{423.25}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{423.33}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{423.35}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{423.37 through 423.42}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{423.45}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{423.47}}}{{\f5\fs18\hyphpar0\qj{, consistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, apply with respect to the fees for new registration authorized under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in the same manner and with the same effect as if the fees for new registration were retail use taxes within the meaning of those statutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E13_30_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Collections by dealers.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an amount of the fee for new registration represented by a dealer to the purchaser of a vehicle is computed upon a purchase price that is not subject to the fee for new registration or the amount represented is in excess of the actual amount subject to the fee and the amount represented is actually paid by the purchaser to the dealer, the excess amount of fee for new registration paid shall be returned to the purchaser upon notification to the dealer by the department that an excess payment exists.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an amount of the fee for new registration represented by a dealer to a purchaser is computed upon a purchase price that is not subject to the fee for new registration or the amount represented is in excess of the actual amount subject to the fee and the amount represented is actually paid by the purchaser to the dealer, the excess amount of fee for new registration paid shall be returned to the purchaser upon proper notification to the dealer by the purchaser that an excess payment exists. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProper\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ notification is written notification which allows a dealer at least sixty days to respond and which contains enough information to allow a dealer to determine the validity of a purchaser\u8217\'3fs claim that an excess amount of fee for new registration has been paid. No cause of action shall accrue against a dealer for excess fee for new registration paid until sixty days after proper notification has been given the dealer by the purchaser.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the circumstances described in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a dealer has the option to either return any excess amount of fee for new registration paid to a purchaser, or to remit the amount which a purchaser has paid to the dealer to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E13_30_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Refunds.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fee for new registration is not refundable, except in the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a vehicle is sold and later returned to the seller and the entire purchase price is refunded by the seller, the purchaser is entitled to a refund of the fee for new registration paid. To obtain a refund, the purchaser shall make application on forms provided by the department and show proof that the entire purchase price was returned and that the fee for new registration had been paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a vehicle manufacturer reimburses a purchaser for the fee for new registration paid on a returned defective vehicle, the manufacturer may obtain a refund from the department by providing proof that the fee was paid and the purchaser reimbursed in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 322G}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines that, as a result of a mistake, an amount of the fee for new registration has been paid which was not due, such amount shall be refunded to the vehicle owner by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A claim for refund under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ that has not been filed with the department within three years after the fee for new registration was paid shall not be allowed by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E13_30_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Penalties.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E13_30_2E9_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E9_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{False statement.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who willfully makes a false statement in regard to the purchase price of a vehicle subject to a fee for new registration or willfully attempts in any manner to evade payment of the fee required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a fraudulent practice. A person who willfully makes a false statement in regard to the purchase price of such a vehicle with the intent to evade payment of the fee for new registration or willfully attempts in any manner to evade payment of the fee required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be assessed a penalty of seventy-five percent of the amount of the fee unpaid and required to be paid on the actual purchase price less trade-in allowance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E13_30_2E9_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E9_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Evasion fee.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa resident found to be in control of a vehicle which is owned by a shell business and for which the fee for new registration has not been paid, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.55, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, is guilty of a fraudulent practice. An Iowa resident found to be in control of a vehicle which is owned by a shell business and for which the fee for new registration has not been paid, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.55, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be assessed a penalty of seventy-five percent of the amount of the fee unpaid and required to be paid on the actual purchase price less trade-in allowance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E13_30_2E9_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E9_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Failure to file.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to file an application for certificate of title or registration with the county treasurer fails to file such application or registration on or before the due date for such application or registration, a penalty in the amount of ten percent of the fee for new registration due shall be added to the fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{\*\bkmkstart stylerid1_2E13_30_2E9_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E13_30_2E9_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Underpayment.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to file an application for certificate of title or registration with the county treasurer files such application or registration with any inaccurate information that results in the person paying less than the full amount of the fee for new registration, penalties, or interest that was due at the time of application, a penalty in the amount of five percent of the fee for new registration due shall be added to the fee.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a7128}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7251, 263}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 60, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7122 \u8211\'3f 124}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1145, \'a71, 17}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 110, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7161}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1065, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1110, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1123, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 86, \'a713 \u8211\'3f 19, 49}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1138, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a720, 21, 26}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1172, \'a71, 4, 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.2}}}{{\f5\fs12\hyphpar0\qj{, 321.20}}}{{\f5\fs12\hyphpar0\qj{, 321.24}}}{{\f5\fs12\hyphpar0\qj{, 321.48}}}{{\f5\fs12\hyphpar0\qj{, 321.129}}}{{\f5\fs12\hyphpar0\qj{, 321.145}}}{{\f5\fs12\hyphpar0\qj{, 321.152}}}{{\f5\fs12\hyphpar0\qj{, 322G.12}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 421.60}}}{{\f5\fs12\hyphpar0\qj{, 423.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fraudulent practices, see }{{\f5\fs12\hyphpar0\qj{\'a7714.8 }}}{{\f5\fs12\hyphpar0\qj{\u8211\'3f}}}{{\f5\fs12\hyphpar0\qj{ 714.14}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph f, subparagraph (3) applies retroactively to January 1, 2015, but refunds of taxes, interest, or penalties arising from the enactment of }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 11722024 Acts, ch 1172}}}{, for leases or rentals occurring between that date and May 17, 2024, not allowed; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1172, \'a73, 5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.106}}}{\*\bkmkstart stylerid1_2E131_2E2_2E2}{\*\bkmkend stylerid1_2E131_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Registration for fractional part of year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a motor truck, truck tractor, or road tractor is registered by the county treasurer pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.120}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.121}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.122}}}{{\f5\fs18\hyphpar0\qj{ and there is no delinquency and the registration is made in February or succeeding months through November, the annual registration fee shall be prorated for the remaining unexpired months of the registration year. A fee shall not be required for the month of December for a vehicle registered on a calendar year basis on which there is no delinquency. However, when such a vehicle is registered in November, the vehicle may be registered for the remaining unexpired months of the registration year or for the remaining unexpired months of the registration year and for the next registration year, upon payment of the applicable registration fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a vehicle is registered under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{ and there is no delinquency and the registration is made in the second through eleventh month of the registration year, the annual registration fee shall be prorated for the remaining unexpired months of the registration year. However, when such a vehicle is registered in the eleventh month of the registration year, the vehicle may be registered for the remaining unexpired months of the registration year and for the next registration year, upon payment of the applicable registration fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a vehicle is registered on a birth month basis and there is no delinquency and the registration is made in the month after the beginning of the registration year or succeeding months, the annual registration fee shall be prorated for the remaining unexpired months of the registration year. A fee shall not be required for the month of the owner\u8217\'3fs birthday for a vehicle on which there is no delinquency. However, when a vehicle registered on a birth month basis is registered during the eleventh month of the registration year, the vehicle may be registered for the remaining unexpired months of the registration year or for the remaining unexpired months of the registration year and for the next registration year, upon payment of the applicable registration fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a fee computed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ contains a fractional part of a dollar, the fee shall be computed to the nearest whole dollar. A fee computed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be less than five dollars. The fee so computed shall be deemed to be the annual registration fee for the remainder of the registration year. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to vehicles registered under }}}{{\f5\fs18\hyphpar0\qj{chapter 326}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A reduction in the annual registration fee shall not be allowed by the department until the applicant files satisfactory evidence to prove that there is no delinquency in registration.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m7; C24, 27, 31, 35, \'a74905; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.02;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.106}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a713, 38}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 24, \'a75, 12}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1028, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1093, \'a79, 40}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 103, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.466}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{321.107 and 321.108}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.109}}}{\*\bkmkstart stylerid1_2E133_2E2_2E2}{\*\bkmkend stylerid1_2E133_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual registration fee computed \u8212\'3f transit fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual fee for all motor vehicles including vehicles designated by manufacturers as station wagons, 1993 and subsequent model year multipurpose vehicles, and 2010 and subsequent model year motor trucks with an unladen weight of ten thousand pounds or less, except motor trucks registered under }}}{{\f5\fs18\hyphpar0\qj{section 321.122}}}{{\f5\fs18\hyphpar0\qj{, business-trade trucks, special trucks, motor homes, motorsports recreational vehicles, ambulances, hearses, autocycles, motorcycles, motorized bicycles, and 1992 and older model year multipurpose vehicles, shall be equal to one percent of the value as fixed by the department plus forty cents for each one hundred pounds or fraction thereof of weight of vehicle, as fixed by the department. The weight of a motor vehicle, fixed by the department for registration purposes, shall include the weight of a battery, heater, bumpers, spare tire, and wheel. Provided, however, that for any new vehicle purchased in this state by a nonresident for removal to the nonresident\u8217\'3fs state of residence the purchaser may make application to any county treasurer for a transit plate for which a fee of ten dollars shall be paid. And provided, however, that for any used vehicle held by a registered dealer and not currently registered in this state, or for any vehicle held by an individual and currently registered in this state, when purchased in this state by a nonresident for removal to the nonresident\u8217\'3fs state of residence, the purchaser may make application to any county treasurer for a transit plate for which a fee of three dollars shall be paid. The county treasurer shall issue a nontransferable certificate of registration for which no refund shall be allowed; and the transit plates shall be void thirty days after issuance. Such purchaser may apply for a certificate of title by surrendering the manufacturer\u8217\'3fs or importer\u8217\'3fs certificate or certificate of title, duly assigned as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. In this event, the county treasurer shall, when satisfied with the genuineness and regularity of the application, and upon payment of a fee of thirty dollars, issue a certificate of title in the name and address of the nonresident purchaser delivering the title to the owner. If there is a security interest noted on the title, the county treasurer shall mail to the secured party an acknowledgment of the notation of the security interest. The county treasurer shall not release a security interest that has been noted on a title issued to a nonresident purchaser as provided in this paragraph. The application requirements of }}}{{\f5\fs18\hyphpar0\qj{section 321.20}}}{{\f5\fs18\hyphpar0\qj{ apply to a title issued as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, except that a natural person who applies for a certificate of title shall provide either the person\u8217\'3fs social security number, passport number, or driver\u8217\'3fs license number, whether the license was issued by this state, another state, or another country. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ relating to multipurpose vehicles are effective for all 1993 and subsequent model years. The annual registration fee for multipurpose vehicles that are 1992 model years and older shall be in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.124}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual registration fee shall be sixty dollars for a vehicle with permanently installed equipment manufactured for and necessary to assist a person with a disability who is either the owner or lessee of the vehicle or a member of the owner\u8217\'3fs or lessee\u8217\'3fs household in entry and exit of the vehicle or if the owner or lessee of the vehicle or a member of the owner\u8217\'3fs or lessee\u8217\'3fs household uses a wheelchair as the only means of mobility. This paragraph applies only to vehicles that are otherwise subject to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and to motor trucks with an unladen weight of ten thousand pounds or less that are otherwise subject to }}}{{\f5\fs18\hyphpar0\qj{section 321.122}}}{{\f5\fs18\hyphpar0\qj{. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fuses a wheelchair\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include use of a wheelchair due to a temporary injury or medical condition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Dealers may, in addition to other provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, purchase from the department in-transit permits, for which a fee of two dollars per permit shall be paid at time of purchase. One such permit shall be displayed on each vehicle purchased from a dealer by a nonresident for removal to the state of the nonresident\u8217\'3fs residence, and one such permit shall also be displayed on each vehicle not currently registered in Iowa and purchased by an Iowa dealer for removal to the dealer\u8217\'3fs place of business in this state. The permits shall be void fifteen days after issuance by the selling dealer. Each permit shall contain the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words \u8220\'3fin-transit\u8221\'3f in bold type.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The dealer\u8217\'3fs license number.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date issued.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purchaser\u8217\'3fs name and address.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word \u8220\'3fIowa\u8221\'3f in bold type.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words \u8220\'3fgood for fifteen days after the date of issuance\u8221\'3f.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other information the director requires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sales invoice verifying the sale shall be in the possession of the driver of the vehicle in transit and shall be signed by the owner or an authorized individual of the issuing dealership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Motor vehicles brought into the state on a transit sticker for the purpose of installation of special equipment may also be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of an unregistered motor vehicle or motor vehicle for which the registration is delinquent may make application to any county treasurer for a temporary thirty-day permit for a fee of twenty-five dollars. The permit shall authorize the motor vehicle to be driven or towed upon the highway, but shall not authorize a motor truck or truck tractor to haul or tow a load. The permit fee shall not be considered a registration fee or exempt the owner from payment of all other fees, registration fees, and penalties due. If the annual registration fee for the motor vehicle is delinquent, the annual registration fee and penalty shall continue to accrue until paid. The permit fee shall not be prorated, refunded, or used as credit as provided under }}}{{\f5\fs18\hyphpar0\qj{section 321.46}}}{{\f5\fs18\hyphpar0\qj{. The permit shall be displayed in the upper left-hand corner of the rear window of all motor vehicles, except motorcycles. Permits issued for a motorcycle shall be attached to the rear of the motorcycle.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74908; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.05;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.109}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1007, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1019, \'a71, 8}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1222, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1232, \'a7401, 412}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 165, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1013, \'a720, 35}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 8, \'a712, 13}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a716, 41}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1042, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a73, 11, 20, 21, 88}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1035, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1127, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1145, \'a722, 23, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7312.2}}}{{\f5\fs12\hyphpar0\qj{, 321.17}}}{{\f5\fs12\hyphpar0\qj{, 321.34}}}{{\f5\fs12\hyphpar0\qj{, 321.105A}}}{{\f5\fs12\hyphpar0\qj{, 321.110}}}{{\f5\fs12\hyphpar0\qj{, 321.113}}}{{\f5\fs12\hyphpar0\qj{, 321.115A}}}{{\f5\fs12\hyphpar0\qj{, 321.116}}}{{\f5\fs12\hyphpar0\qj{, 321.122}}}{{\f5\fs12\hyphpar0\qj{, 321.124}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.110}}}{\*\bkmkstart stylerid1_2E134_2E2_2E2}{\*\bkmkend stylerid1_2E134_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rejecting fractional dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When the annual registration fee, computed according to }{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{, totals a fraction over a certain number of dollars the fee shall be arrived at by computing to the nearest even dollar.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a74908-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.06;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.110}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a789}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.111}}}{\*\bkmkstart stylerid1_2E135_2E2_2E2}{\*\bkmkend stylerid1_2E135_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conversion of car \u8212\'3f effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any motor vehicle originally registered as a passenger car and thereafter converted into a truck with a loading capacity of less than one thousand pounds, shall be registered as a passenger car.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a74908-g1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.07;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.111}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.112}}}{\*\bkmkstart stylerid1_2E136_2E2_2E2}{\*\bkmkend stylerid1_2E136_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Minimum motor vehicle fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No motor vehicle, except as provided in }{{\f5\fs18\hyphpar0\qj{section 321.117}}}{, shall be registered for a registration year for less than ten dollars.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74909; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.08;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.112}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a714, 38}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 143, \'a711, 35}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1124, \'a737}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.113}}}{\*\bkmkstart stylerid1_2E137_2E2_2E2}{\*\bkmkend stylerid1_2E137_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Automatic reduction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual registration fee for a motor vehicle shall not be automatically reduced under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the fee is based on the value and weight of the motor vehicle as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a motor vehicle is more than seven model years old, the part of the annual registration fee that is based on the value of the vehicle shall be seventy-five percent of the rate as fixed when the motor vehicle was new and the total fee shall not be less than fifty dollars; except that if the registration is a renewal for a vehicle registered to the same owner prior to January 1, 2009, the annual registration fee shall not be more than the fee paid for the previous registration year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a motor vehicle is more than nine model years old, the part of the annual registration fee that is based on the value of the vehicle shall be fifty percent of the rate as fixed when the motor vehicle was new and the total fee shall not be less than fifty dollars; except that if the registration is a renewal for a vehicle registered to the same owner prior to January 1, 2009, the annual registration fee shall not be more than the fee paid for the previous registration year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if a motor vehicle is twelve model years old or older, the annual registration fee is fifty dollars; except that if the registration is a renewal for a vehicle registered to the same owner prior to January 1, 2009, the annual registration fee shall not be more than the fee paid for the previous registration year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the registration is a renewal for a motor vehicle registered as an antique vehicle by the same owner prior to January 1, 2009, the annual registration fee shall be twenty-three dollars for a motor vehicle that is model year 1970 through 1983 and sixteen dollars for a motor vehicle that is model year 1969 or older.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of determining the portion of an annual registration fee under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that is based upon the value of the motor vehicle, sixty percent of the annual registration fee is attributable to the value of the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fowner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a surviving spouse who is required to transfer title pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.46}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321.47}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71571-m7; C24, 27, 31, 35, \'a74910; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.09;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.113}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a715, 38}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a74, 24}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a74, 11, 90}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 38, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.115}}}{{\f5\fs12\hyphpar0\qj{, 321.115A}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.114}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.115}}}{\*\bkmkstart stylerid1_2E139_2E2_2E2}{\*\bkmkend stylerid1_2E139_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Antique vehicles \u8212\'3f model year plates permitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle twenty-five years old or older may be registered as an antique vehicle. The annual registration fee is the fee provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.113}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.122}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.124}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a motor truck, truck tractor, road tractor, or motor home that is twenty-five years old or older who desires to use the vehicle exclusively for exhibition or educational purposes at state or county fairs, or at other places where the vehicle may be exhibited for entertainment or educational purposes, may register the vehicle as a \u8220\'3flimited use\u8221\'3f vehicle in accordance with }}}{{\f5\fs18\hyphpar0\qj{sections 321.58 through 321.62}}}{{\f5\fs18\hyphpar0\qj{. The \u8220\'3flimited use\u8221\'3f registration under this paragraph permits driving of the vehicle upon the public roads to and from state and county fairs or other places of entertainment or education for exhibition or educational purposes and to and from service stations for the purpose of receiving necessary maintenance, or for the purposes of transporting, testing, demonstrating, or selling the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of a motor vehicle registered under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may display authentic Iowa registration plates from the model year of the motor vehicle, furnished by the person and approved by the department, in lieu of the current and valid Iowa registration plates issued for the vehicle, provided that the current and valid Iowa registration plates and the registration card issued for the vehicle are simultaneously carried within the vehicle and are available for inspection to any peace officer upon the officer\u8217\'3fs request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sale of a motor vehicle twenty years old or older which is primarily of value as a collector\u8217\'3fs item and not as transportation is not subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{, and any person may sell such a vehicle at retail without a license as required under }}}{{\f5\fs18\hyphpar0\qj{chapter 322}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Truck tractors and semitrailers used in combination for exhibition and educational purposes may be registered and driven according to the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. Truck tractors and semitrailers registered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be used to haul loads.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a74911-f1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.11;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.115}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 101, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1204, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1175, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1068, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 143, \'a712, 35}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a7120, 131}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1124, \'a735, 37}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a7136}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a737}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.24}}}{{\f5\fs12\hyphpar0\qj{, 321.52}}}{{\f5\fs12\hyphpar0\qj{, 321.438}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(u)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.115A}}}{\*\bkmkstart stylerid1_2E14_30_2E2_2E2}{\*\bkmkend stylerid1_2E14_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Replica vehicles and street rods \u8212\'3f model year plates permitted \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle may be registered as a replica vehicle or street rod. The annual registration fee is the fee provided for in }}}{{\f5\fs18\hyphpar0\qj{section 321.109}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.113}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.122}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.124}}}{{\f5\fs18\hyphpar0\qj{. The owner of a vehicle registered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may display registration plates from or representing the model year of the motor vehicle or the model year of the motor vehicle the registered vehicle is designed to resemble, furnished by the person and approved by the department, in lieu of the current and valid Iowa registration plates issued for the vehicle, provided that the current and valid Iowa registration plates and the registration card issued for the vehicle are simultaneously carried within the vehicle and are available for inspection to any peace officer upon the officer\u8217\'3fs request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Truck tractors and semitrailers registered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be used to haul loads.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8A, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1044, \'a76, 8}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1190, \'a738}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}{{\f5\fs12\hyphpar0\qj{, 805.8A(2)(v)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.116}}}{\*\bkmkstart stylerid1_2E141_2E2_2E2}{\*\bkmkend stylerid1_2E141_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Battery electric and plug-in hybrid electric motor vehicle fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each battery electric motor vehicle subject to an annual registration fee under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and operated on the public highways of this state, the owner shall pay an annual battery electric motor vehicle registration fee, which shall be in addition to the annual registration fee imposed for the vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbattery electric motor vehicle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a motor vehicle equipped with electrical drivetrain components and not equipped with an internal combustion engine, that is propelled exclusively by one or more electrical motors using electrical energy stored in a battery or other energy storage device that can be recharged by plugging into an electrical outlet or electric vehicle charging station. The amount of the fee shall be one hundred thirty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For each plug-in hybrid electric motor vehicle subject to an annual registration fee under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and operated on the public highways of this state, the owner shall pay an annual plug-in hybrid electric motor vehicle registration fee, which shall be in addition to the annual registration fee imposed for the vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 321.109, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fplug-in hybrid electric motor vehicle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a motor vehicle equipped with electrical drivetrain components, an internal combustion engine, and a battery or other energy storage device that can be recharged by plugging into an electrical outlet or electric vehicle charging station. The amount of the fee shall be sixty-five dollars.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 151, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a772}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.117}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.117}}}{\*\bkmkstart stylerid1_2E142_2E2_2E2}{\*\bkmkend stylerid1_2E142_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motorcycle, autocycle, ambulance, and hearse fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For all motorcycles and autocycles the annual registration fee shall be twenty dollars. For all motorized bicycles the annual registration fee shall be seven dollars. When the motorcycle or autocycle is more than five model years old, the annual registration fee shall be ten dollars. The annual registration fee for ambulances and hearses shall be fifty dollars. Passenger car plates shall be issued for ambulances and hearses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the fee required for a motorcycle under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the owner of a motorcycle that is a battery electric motor vehicle or plug-in hybrid electric motor vehicle, as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.116}}}{{\f5\fs18\hyphpar0\qj{, shall pay an annual electric motorcycle registration fee. The amount of the fee shall be nine dollars.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74912; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5008.13;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7321.117}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1062, \'a717, 38}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a791}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1098, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 151, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a773}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.112}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.118}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.119}}}{\*\bkmkstart stylerid1_2E144_2E2_2E2}{\*\bkmkend stylerid1_2E144_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Church buses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For motor vehicles designed to carry nine passengers or more which are owned and used exclusively by a church or religious organization to transport passengers to and from activities of or sponsored by the church or religious organization and not operated for rent or hire for purposes unrelated to the activities of the church or religious organization, the annual registration fee shall be twenty-five dollars.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7321.119}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1305, \'a762}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a792}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.557}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321.120}}}{\*\bkmkstart stylerid1_2E145_2E2_2E2}{\*\bkmkend stylerid1_2E145_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Business-trade trucks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual registration fee for a business-trade truck shall be determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.122, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application for a new registration, an owner who registers a motor vehicle as a business-trade truck shall be required to provide proof or affirm that the vehicle meets the definition of a business-trade truck. The department may adopt rules as necessary to prescribe the documentation required of the applicant as proof or affirmation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ but shall not require that such documentation be notarized. If requested by the department of transportation or a county treasurer, the department of revenue shall confirm or refute, according to the most recent records available, that an applicant for registration of a business-trade truck is either a corporation, limited liability company, or partnership or a person who files a schedule C or schedule F form for federal income tax purposes and that the corporation, limited liability company, partnership, or person is allowed a depreciation deduction with respect to the vehicle under section 167 of the Internal Revenue Code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon approval of the application and payment of the proper fees, the county treasurer shall issue regular registration plates for the business-trade truck. The department may adopt rules requiring the use of a sticker or other means to identify motor vehicles registered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines by audit or other means that a person has registered a vehicle as a business-trade truck that is not qualified for such registration, the person shall be required to pay the difference between the regular annual registration fees owed for the vehicle for each year the vehicle was registered in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the fees actually paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department determines by audit or other means that the person had knowingly registered a vehicle as a business-trade truck that is not qualified for such registration, the person shall be required to pay a penalty for improper registration in the amount of seven hundred fifty dollars for each registration year in which the vehicle was registered in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, not to exceed two thousand two hundred fifty dollars.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1113, \'a75, 11}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 68, \'a72, 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.26}}}{{\f5\fs12\hyphpar0\qj{, 321.106}}}{{\f5\fs12\hyphpar0\qj{, 321.134}}}{{\f5\fs12\hyphpar0\qj{, 321.152}}}{{\f5\fs12\hyphpar0\qj{, 331.557}}}{{\f5\fs12\hyphpar0\qj{, 422.20}}}{{\f5\fs12\hyphpar0\qj{, 422.72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\q