As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fApproved local program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a school district\u8217\'3fs program for four-year-old children approved by the department of education to provide high quality preschool instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of the department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPreschool program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the statewide preschool program for four-year-old children created in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchool district approved to participate in the preschool program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a school district that meets the school district requirements under }}}{{\f5\fs18\hyphpar0\qj{section 256C.3}}}{{\f5\fs18\hyphpar0\qj{ and has been approved by the department to participate in the preschool program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state board of education.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 148, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256C.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statewide preschool program for four-year-old children \u8212\'3f purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statewide preschool program for four-year-old children is established. The purpose of the preschool program is to provide an opportunity for all young children in the state to enter school ready to learn by expanding voluntary access to quality preschool curricula for all children who are four years old.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board shall adopt rules in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ as necessary to implement the preschool program as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 148, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256C.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Preschool program requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E7_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Eligible children.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who is a resident of Iowa and is four years of age on or before September 15 of a school year shall be eligible to enroll in the preschool program under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If such a child is enrolled under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the child shall be considered to be of compulsory attendance age as provided in }}}{{\f5\fs18\hyphpar0\qj{section 299.1A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If space and funding are available, including funding from another school district account or fund from which preschool program expenditures are authorized by law, a school district approved to participate in the preschool program may enroll and pay the cost of attendance for a younger or older child in the preschool program; however, the child shall not be counted for state funding purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E7_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Teacher requirements.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual serving as a teacher in the preschool program must meet all of the following qualifications:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual is either employed by or under contract with the school district implementing the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual is appropriately licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 256, subchapter VII, part 3,}}}{{\f5\fs18\hyphpar0\qj{ and meets requirements under }}}{{\f5\fs18\hyphpar0\qj{chapter 284}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual possesses a bachelor\u8217\'3fs or graduate degree from an accredited college or university with a major in early childhood education or other appropriate major identified in rule by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A teacher in the preschool program shall collaborate with other agencies, organizations, and boards in the community to further the program\u8217\'3fs capacity to meet the diverse needs of the children taught by the teacher and the families of the children, such as needs for early care, health, and human services. In addition, a teacher in the preschool program shall work to maintain relationships with each child\u8217\'3fs family in order to enhance the child\u8217\'3fs development in all settings by collaborating with providers of parent education and family support opportunities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E7_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Program requirements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board shall adopt rules to further define the following preschool program requirements which shall be used to determine whether or not a local program implemented by a school district approved to implement the preschool program qualifies as an approved local program:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maximum and minimum teacher-to-child ratios and class sizes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Applicable state and federal program standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Student learning standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions for the integration of children from other state and federally funded preschools.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collaboration with participating families, early care providers, and community partners including but not limited to early childhood Iowa area boards, head start programs, shared visions and other programs provided under the auspices of the child development coordinating council, licensed child care centers, registered child development homes, area education agencies, child care resource and referral services provided under }}}{{\f5\fs18\hyphpar0\qj{section 237A.26}}}{{\f5\fs18\hyphpar0\qj{, early childhood special education programs, services funded by Tit. I of the federal }}}{{\f5\fs18\hyphpar0\qj{Elementary and Secondary Education Act of 1965}}}{{\f5\fs18\hyphpar0\qj{, and family support programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A minimum of ten hours per week of instruction delivered on the skills and knowledge included in the student learning standards developed for the preschool program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parental involvement in the local program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provision for ensuring that children receiving care from other child care arrangements can participate in the preschool program with minimal disruption due to transportation and movement from one site to another. The children participating in the preschool program may be transported by the school district to activities associated with the program along with other children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E7_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{School district requirements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board shall adopt rules to further define the following requirements of school districts implementing the preschool program:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Methods of demonstrating community readiness to implement high-quality instruction in a local program shall be identified. The potential provider shall submit a collaborative program proposal that demonstrates the involvement of multiple community stakeholders including but not limited to, and only as applicable, parents, the school district, accredited nonpublic schools and faith-based representatives, the area education agency, the early childhood Iowa area board, representatives of business, head start programs, shared visions and other programs provided under the auspices of the child development coordinating council, center-based and home-based providers of child care services, human services, public health, and economic development programs. The methods may include but are not limited to a school district providing evidence of a public hearing on the proposed programming and written documentation of collaboration agreements between the school district, existing community providers, and other community stakeholders addressing operational procedures and other critical measures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to implementation of }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ agreements between a school district and community-based providers of services to four-year-old children, a four-year-old child who is enrolled in a child care center or child development home licensed or registered under }}}{{\f5\fs18\hyphpar0\qj{chapter 237A}}}{{\f5\fs18\hyphpar0\qj{, or in an existing public or private preschool program, shall be eligible for services provided by the school district\u8217\'3fs local preschool program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district shall participate in data collection and performance measurement processes and reporting as defined by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Professional development for school district preschool teachers shall be addressed in the school district\u8217\'3fs professional development plan implemented in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 284.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E7_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Department requirements.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall implement an application and selection process for school district participation in the preschool program that includes but is not limited to the enrollment requirements provided under }}}{{\f5\fs18\hyphpar0\qj{section 256C.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall track the progress of students served by a school district preschool program and the students\u8217\'3f performance in elementary and secondary education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall implement procedures to monitor the quality of the programming provided under the preschool program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board, in collaboration with the department, shall ensure that the administrative rules adopted to support the preschool program emphasize that children\u8217\'3fs access to the program is voluntary, that the preschool foundation aid provided to a school district is provided based upon the enrollment of eligible students in the school district\u8217\'3fs local program regardless of whether an eligible student is a resident of the school district, and that agreements entered into by a school district for the provision of programming in settings other than the school district\u8217\'3fs facilities are between the school district and the private provider.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 148, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 215, \'a7100}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1181, \'a767, 74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7303, 304}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 78, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 140, \'a730, 58, 59}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 153, \'a712, 14, 15}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72553}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256C.1}}}{{\f5\fs12\hyphpar0\qj{, 256C.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256C.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funding provisions \u8212\'3f enrollment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E8_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{General.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State funding provided under the preschool program shall be based upon the enrollment of eligible students in the preschool programming provided by a school district approved to participate in the preschool program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school district approved to participate in the preschool program may authorize expenditures for the district\u8217\'3fs preschool programming from any of the revenue sources available to the district from the sources listed in }}}{{\f5\fs18\hyphpar0\qj{chapter 298A}}}{{\f5\fs18\hyphpar0\qj{, provided the expenditures are within the uses permitted for the revenue source. In addition, the use of the revenue source for preschool or prekindergarten programming must have been approved prior to any expenditure from the revenue source for the district\u8217\'3fs approved local program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Funding provided under the preschool program is intended to supplement, not supplant, existing public funding for preschool programming.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Preschool foundation aid funding shall not be commingled with the other state aid payments made under }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{ to a school district and shall be accounted for by the local school district separately from the other state aid payments. Preschool foundation aid payments made to school districts are miscellaneous income for purposes of }}}{{\f5\fs18\hyphpar0\qj{chapter 257}}}{{\f5\fs18\hyphpar0\qj{. A school district shall maintain a separate listing within its budget for preschool foundation aid payments received and expenditures made. A school district shall certify to the department of education that preschool foundation aid funding received by the school district was used to supplement, not supplant, moneys otherwise received and used by the school district for preschool programming.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Preschool foundation aid funding shall not be used for the costs of constructing a facility in connection with an approved local program. Preschool foundation aid funding may be used by approved local programs and community providers for any purpose determined by the board of directors of the school district to meet standards for high-quality preschool instruction and for purposes that directly or indirectly benefit students enrolled in the approved local program, including but not limited to professional development for preschool teachers, instructional equipment and supplies, material and equipment designed to develop pupils\u8217\'3f large and small motor skills, translation services, playground equipment and repair costs, food and beverages used by children in the approved local program, safety equipment, facility rental fees, and for other direct costs that enhance the approved local program, including by contracting with community partners for any such services. Preschool foundation aid funding may be used by approved local programs for the costs of transportation involving children participating in the preschool program. The costs of transporting other children associated with the preschool program or transported as provided in }}}{{\f5\fs18\hyphpar0\qj{section 256C.3, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, may be prorated by the school district. Preschool foundation aid funding received by an approved local program that remains unexpended and unobligated at the end of a fiscal year beginning on or after July 1, 2017, shall be used to build the approved local program\u8217\'3fs preschool program capacity in the next succeeding fiscal year excluding that portion of such unexpended and unobligated funding that the school district authorizes for transfer for deposit in the school district\u8217\'3fs flexibility account established under }}}{{\f5\fs18\hyphpar0\qj{section 298A.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if the statutory requirements for the use of such funding are met. For purposes of determining whether a school district has authority to transfer preschool foundation aid funding for deposit in the school district\u8217\'3fs flexibility account established under }}}{{\f5\fs18\hyphpar0\qj{section 298A.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the school district must have provided preschool programming during the fiscal year for which funding remains unexpended and unobligated to all eligible students for whom a timely application for enrollment was submitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The receipt of funding by a school district for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the need for additional funding for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or the enrollment count of eligible students under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered to be unusual circumstances, create an unusual need for additional funds, or qualify under any other circumstances that may be used by the school budget review committee to grant supplemental aid to or establish a modified supplemental amount for a school district under }}}{{\f5\fs18\hyphpar0\qj{section 257.31}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2015, and each succeeding fiscal year, of the amount of preschool foundation aid received by a school district for a fiscal year in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{, not more than five percent may be used by the school district for administering the district\u8217\'3fs approved local program. Outreach activities and rent for facilities not owned by the school district are permissive uses of the administrative funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fiscal year beginning July 1, 2015, and each succeeding fiscal year, of the amount of preschool foundation aid received by a school district for a fiscal year in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{, not less than ninety-five percent of the per pupil amount shall be passed through to a community-based provider for each pupil enrolled in the district\u8217\'3fs approved local program. For the fiscal year beginning July 1, 2015, and each succeeding fiscal year, not more than ten percent of the amount of preschool foundation aid passed through to a community-based provider may be used by the community-based provider for administrative costs. The costs of outreach activities and rent for facilities not owned by the school district are permissive administrative costs. The costs of transportation involving children participating in the preschool program and other children may be prorated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E8_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Eligible student enrollment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be included as an eligible student in the enrollment count of the preschool programming provided by a school district approved to participate in the preschool program, a child must be four years of age by September 15 in the base year and attending the school district\u8217\'3fs approved local program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The enrollment count of eligible students shall not include a child who is included in the enrollment count determined under }}}{{\f5\fs18\hyphpar0\qj{section 257.6}}}{{\f5\fs18\hyphpar0\qj{ or a child who is served by a program already receiving state or federal funds for the purpose of the provision of four-year-old preschool programming while the child is being served by the program. Such preschool programming includes but is not limited to child development assistance programs provided under }}}{{\f5\fs18\hyphpar0\qj{chapter 256A}}}{{\f5\fs18\hyphpar0\qj{, special education programs provided under }}}{{\f5\fs18\hyphpar0\qj{section 256B.9}}}{{\f5\fs18\hyphpar0\qj{, school ready children grant programs and other programs provided under }}}{{\f5\fs18\hyphpar0\qj{chapter 256I}}}{{\f5\fs18\hyphpar0\qj{, and federal head start programs and the services funded by Tit. I of the federal }}}{{\f5\fs18\hyphpar0\qj{Elementary and Secondary Education Act of 1965}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 148, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1181, \'a768, 74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7305}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a723, 42}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a710, 42, 103, 108}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 140, \'a731, 58, 59}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1132, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 153, \'a713 \u8211\'3f 15}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 154, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256C.3}}}{{\f5\fs12\hyphpar0\qj{, 256C.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256C.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funding formula.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E9_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 256C.4}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBase year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbudget year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fregular program state cost per pupil\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool district\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the same as defined or described in }}}{{\f5\fs18\hyphpar0\qj{chapter 257}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible student\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a child who meets eligibility requirements under }}}{{\f5\fs18\hyphpar0\qj{section 256C.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPreschool budget enrollment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the figure that is equal to fifty percent of the actual enrollment of eligible students in the preschool programming provided by a school district approved to participate in the preschool program on October 1 of the base year, or the first Monday in October if October 1 falls on a Saturday or Sunday.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPreschool foundation aid\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the product of the regular program state cost per pupil for the budget year multiplied by the school district\u8217\'3fs preschool budget enrollment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E9_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Preschool foundation aid district amount.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the initial school year for which a school district approved to participate in the preschool program receives that approval and implements the preschool program, the funding for the preschool foundation aid payable to that school district shall be paid from the appropriation made for that school year in }}}{{\f5\fs18\hyphpar0\qj{section 256C.6}}}{{\f5\fs18\hyphpar0\qj{, Code 2011, or in another appropriation made for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. For that school year, the preschool foundation aid payable to the school district is the product of the regular program state cost per pupil for the school year multiplied by sixty percent of the school district\u8217\'3fs eligible student enrollment on the date in the school year determined by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For budget years subsequent to the initial school year for which a school district approved to participate in the preschool program receives that initial approval and implements the preschool program, the funding for the preschool foundation aid payable to that school district shall be paid from the appropriation made in }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{. Continuation of a school district\u8217\'3fs participation in the preschool program for a second or subsequent budget year is subject to the approval of the department based upon the school district\u8217\'3fs compliance with accountability provisions and the department\u8217\'3fs on-site review of the school district\u8217\'3fs implementation of the preschool program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E9_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Aid payments.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Preschool foundation aid shall be paid as part of the state aid payments made to school districts in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E9_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Administration and oversight.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided by law for a fiscal year, of the amount appropriated for that fiscal year for payment of preschool foundation aid statewide, the department may use an amount sufficient to fund up to three full-time equivalent positions which shall be in addition to the number of positions authorized for the fiscal year, as necessary to provide administration and oversight of the preschool program.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 148, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1181, \'a769, 74}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 131, \'a791, 101}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a735}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{256C.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Phase-in \u8212\'3f appropriations.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by its own terms; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2007/CH0148.pdf" }{\fldrslt \cf5 \f5 \fs18{{2007 Acts, ch 148, \'a76}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}}