\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F815}{\*\bkmkend codeChapter_5F815}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 815}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{COSTS \u8212\'3f COMPENSATION AND FEES \u8212\'3f INDIGENT DEFENSE}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a713B.4}}}{{\f5\fs12\qc{, 81.13}}}{{\f5\fs12\qc{, 232.141}}}{{\f5\fs12\qc{, 600A.6B}}}{{\f5\fs12\qc{, 600A.6C}}}{{\f5\fs12\qc{, 801.1}}}{{\f5\fs12\qc{, 822.2}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Deferral of costs in civil and criminal proceedings; see }{{\f5\fs12\qc{chapter 610}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Costs incurred by a privately retained attorney representing an indigent person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall not authorize the payment of state funds for the costs incurred in the legal representation of an indigent person represented by a privately retained attorney unless the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are satisfied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for the payment of state funds for the costs incurred in the legal representation of an indigent person that is submitted by the privately retained attorney shall be filed with the court in the county in which the case was filed and include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the attorney\u8217\'3fs fee agreement for the representation, including hourly rate, amount of retainer or other moneys received, and number of hours of work completed by the attorney to date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A showing that the costs are reasonable and necessary for the representation of the indigent person in a case for which counsel could have been appointed under }}}{{\f5\fs18\hyphpar0\qj{section 815.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An itemized accounting of all compensation paid to the attorney including the amount of any retainer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of compensation earned by the attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information on any expected additional costs to be paid or owed by the indigent person to the attorney for the representation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A signed financial affidavit completed by the indigent person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The privately retained attorney shall submit a copy of the application and all attached documents to the state public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall not grant the application and authorize all or a portion of the payment to be made from state funds unless the court determines, after reviewing the application and supporting documents, that all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The represented person is indigent and unable to pay for the costs sought to be paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs are reasonable and necessary for the representation of the indigent person in a case for which counsel could have been appointed under }}}{{\f5\fs18\hyphpar0\qj{section 815.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The moneys paid or to be paid to the privately retained attorney by or on behalf of the indigent person are insufficient to pay all or a portion of the costs sought to be paid from state funds.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining whether the moneys paid or to be paid to the attorney are insufficient for purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court shall add the hours previously worked to the hours expected to be worked to finish the case and multiply that sum by the hourly rate of compensation specified under }}}{{\f5\fs18\hyphpar0\qj{section 815.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the product calculated in subparagraph (1) is greater than the moneys paid or to be paid to the attorney by or on behalf of the indigent person, the moneys shall be considered insufficient to pay all or a portion of the costs sought to be paid from state funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the private attorney is retained on a flat fee agreement, and a precise record of hours worked is not available, the attorney shall provide the court a reasonable estimate of the time expended to allow the court to make the calculation pursuant to this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Either the privately retained attorney for the indigent person or a representative from the office of the state public defender may participate in a hearing on the application by telephone. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court finds the payment of the costs incurred or to be incurred by a privately retained attorney are reasonable and necessary, the order of the court shall specify the maximum amount of costs which the attorney may incur without further court order, and that the actual amount of such costs to be allowed are subject to review by the state public defender for reasonableness. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following entry of an order allowing costs to be incurred by a privately retained attorney representing an indigent person, the attorney or a claimant referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 9}}}{{\f5\fs18\hyphpar0\qj{ seeking payment or reimbursement for costs shall submit a claim for payment in accordance with the rules of the state public defender. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the privately retained attorney or claimant referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 9}}}{{\f5\fs18\hyphpar0\qj{ seeking payment or reimbursement for costs pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ fails to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the state public defender may deny all or a part of the costs requested. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ applies to payments to witnesses under }}}{{\f5\fs18\hyphpar0\qj{section 815.4}}}{{\f5\fs18\hyphpar0\qj{, evaluators, investigators, and certified shorthand reporters, and for other costs incurred by a privately retained attorney in the legal representation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to restrict the payment of costs on behalf of indigent persons represented on a pro bono basis.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 51, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Grand jury clerks and other officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The clerk of the grand jury and any assistant clerks and bailiffs of the grand jury appointed by the court, shall receive such compensation as may be set by the court with the approval of the county board of supervisors for time actually and necessarily employed in the performance of the duties prescribed in }\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of criminal procedure 2.3}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a75256; S13, \'a75256; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13696, 13699;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7770.19, 770.22; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7815.2}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.1303}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Witnesses called to county attorney investigations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Witnesses subpoenaed by the county attorney pursuant to }\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of criminal procedure 2.5}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{ shall receive the same fees and mileage as are allowed witnesses in the district court, and shall be paid in the same manner in which witnesses before the grand jury are paid except that such fees and mileage shall be certified only by the county attorney.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7815.3}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.756(68)}}}{{\f5\fs12\hyphpar0\qj{, 602.1303}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special witnesses for indigents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for an expert or other witnesses under }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{Iowa rule of criminal procedure 2.20}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{ shall include a statement attesting that the attorney advised the indigent person of the application, the expected expenses, and the potential for reimbursement of the expenses pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 815.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall authorize the securing of a witness prior to the witness incurring any expenses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall either set in advance a maximum dollar amount of the claim for expenses or approve the final amount of the claim for expenses as reasonable compensation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender shall only approve the claim for the expenses of the witness if the securing of the witness was authorized by the court and either the maximum dollar amount of the claim for expenses was set prior to the expenses being incurred or the court has approved the final amount of the claim for expenses as reasonable compensation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A witness secured for an indigent person under }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{Iowa rule of criminal procedure 2.20}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{ shall file a claim for compensation with the state public defender as required by the rules of the state public defender, and the claim shall be supported by an itemization specifying the time expended, services rendered, and expenses incurred on behalf of the indigent person.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7815.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 175, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1063, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7815.1}}}{{\f5\fs12\hyphpar0\qj{, 815.5}}}{{\f5\fs12\hyphpar0\qj{, 815.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expert witnesses for state and defense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding the provisions of }{{\f5\fs18\hyphpar0\qj{section 622.72}}}{, reasonable compensation as determined by the court shall be awarded expert witnesses, expert witnesses for an indigent person referred to in }{{\f5\fs18\hyphpar0\qj{section 815.4}}}{, or expert witnesses called by the state in criminal cases.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7815.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 175, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7211}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Witnesses for indigents, see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0{{\f5\fs12\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs12{{\f5\b\fs12\hyphpar0\qj\cf5{R.Cr.P. 2.20(4)}}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees to material witnesses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Persons confined as material witnesses shall, for each day of confinement, receive such fees as are set by the district court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7815.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees to attorneys.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An attorney who has not entered into a contract authorized under }}}{{\f5\fs18\hyphpar0\qj{section 13B.4}}}{{\f5\fs18\hyphpar0\qj{ and who is appointed by the court to represent any person pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 814.11}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{815.10}}}{{\f5\fs18\hyphpar0\qj{ shall be entitled to reasonable compensation and expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For appointments made on or after July 1, 1999, through June 30, 2006, the reasonable compensation shall be calculated on the basis of sixty dollars per hour for class \u8220\'3fA\u8221\'3f felonies, fifty-five dollars per hour for class \u8220\'3fB\u8221\'3f felonies, and fifty dollars per hour for all other cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For appointments made on or after July 1, 2006, through June 30, 2007, the reasonable compensation shall be calculated on the basis of sixty-five dollars per hour for class \u8220\'3fA\u8221\'3f felonies, sixty dollars per hour for all other felonies, sixty dollars per hour for misdemeanors, and fifty-five dollars per hour for all other cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For appointments made on or after July 1, 2007, through June 30, 2019, the reasonable compensation shall be calculated on the basis of seventy dollars per hour for class \u8220\'3fA\u8221\'3f felonies, sixty-five dollars per hour for class \u8220\'3fB\u8221\'3f felonies, and sixty dollars per hour for all other cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For appointments made on or after July 1, 2019, through June 30, 2021, the reasonable compensation shall be calculated on the basis of seventy-three dollars per hour for class \u8220\'3fA\u8221\'3f felonies, sixty-eight dollars per hour for class \u8220\'3fB\u8221\'3f felonies, and sixty-three dollars per hour for all other cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For appointments made on or after July 1, 2021, through June 30, 2022, the reasonable compensation shall be calculated on the basis of seventy-six dollars per hour for class \u8220\'3fA\u8221\'3f felonies, seventy-one dollars per hour for class \u8220\'3fB\u8221\'3f felonies, and sixty-six dollars per hour for all other cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For appointments made on or after July 1, 2022, through June 30, 2023, the reasonable compensation shall be calculated on the basis of seventy-eight dollars per hour for class \u8220\'3fA\u8221\'3f felonies, seventy-three dollars per hour for class \u8220\'3fB\u8221\'3f felonies, and sixty-eight dollars per hour for all other cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For appointments made on or after July 1, 2023, through June 30, 2024, the reasonable compensation shall be calculated on the basis of eighty-three dollars per hour for class \u8220\'3fA\u8221\'3f felonies, seventy-eight dollars per hour for class \u8220\'3fB\u8221\'3f felonies, and seventy-three dollars per hour for all other cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For appointments made on or after July 1, 2024, through June 30, 2025, the reasonable compensation shall be calculated on the basis of eighty-six dollars per hour for class \u8220\'3fA\u8221\'3f felonies, eighty-one dollars per hour for class \u8220\'3fB\u8221\'3f felonies, and seventy-six dollars per hour for all other cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For appointments made on or after July 1, 2025, the reasonable compensation shall be calculated on the basis of eighty-eight dollars per hour for class \u8220\'3fA\u8221\'3f felonies, eighty-three dollars per hour for class \u8220\'3fB\u8221\'3f felonies, and seventy-eight dollars per hour for all other cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The expenses shall include any sums as are necessary for investigations in the interest of justice, and the cost of obtaining the transcript of the trial record and briefs if an appeal is filed. The attorney need not follow the case into another county or into the appellate court unless so directed by the court. If the attorney follows the case into another county or into the appellate court, the attorney shall be entitled to compensation as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Only one attorney fee shall be so awarded in any one case except that in class \u8220\'3fA\u8221\'3f felony cases, two may be authorized if both attorneys are appointed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 815.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a72561 \u8211\'3f 2563; R60, \'a71578, 4168 \u8211\'3f 4170; C73, \'a73829 \u8211\'3f 3831; C97, \'a75314; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13774;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7775.5; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7815.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1187, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1193, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1115, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1084, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1166, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 213, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1063, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 163, \'a734, 35}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 166, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a7176}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1146, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a7154}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 113, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1156, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 154, \'a719, 20}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.78}}}{{\f5\fs12\hyphpar0\qj{, 222.13A}}}{{\f5\fs12\hyphpar0\qj{, 229.2}}}{{\f5\fs12\hyphpar0\qj{, 229.8}}}{{\f5\fs12\hyphpar0\qj{, 815.1}}}{{\f5\fs12\hyphpar0\qj{, 815.9}}}{{\f5\fs12\hyphpar0\qj{, 815.11}}}{{\f5\fs12\hyphpar0\qj{, 815.14}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 9 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 10 and former subsection 10 renumbered as 11}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.7A}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Travel time for attorney or guardian ad litem.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compensation for time spent by an attorney or guardian ad litem traveling outside of the attorney\u8217\'3fs or guardian ad litem\u8217\'3fs county of domicile is payable when the travel is reasonable and necessary to represent the indigent client and shall be calculated at a rate of thirty-five dollars per hour. Compensation for travel for a court proceeding other than a trial or other contested proceeding shall only be paid if the attorney or guardian ad litem files a motion for a remote hearing and the motion is denied. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not affect any allowable compensation for time spent traveling already compensated pursuant to any other applicable provision of law. The hours compensated for travel outside the county of domicile shall not apply to a cap on the maximum work hours to which the attorney or guardian ad litem may be subject.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compensation for travel for an arraignment, pretrial conference, scheduling conference, or any other uncontested or nontestimonial judicial proceeding, for which a request for a remote hearing was denied, paid to the attorney or guardian ad litem from the indigent defense fund created in }}}{{\f5\fs18\hyphpar0\qj{section 815.11}}}{{\f5\fs18\hyphpar0\qj{ shall be reimbursed by the judicial branch.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcounty of domicile\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the address the attorney or guardian ad litem has on file with the office of the state public defender.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 113, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1156, \'a722}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.8}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sheriffs\u8217\'3f fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For delivering defendants under the change of venue provisions of }\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/2.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of criminal procedure 2.11}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{ or transferring arrested persons under }{{\f5\fs18\hyphpar0\qj{section 804.24}}}{, sheriffs are entitled to the same fees as are allowed for the conveyance of persons to institutions under }{{\f5\fs18\hyphpar0\qj{section 331.655}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a73277; R60, \'a74741; C73, \'a74382; C97, \'a75355; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13825;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7778.16; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7815.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 21, \'a748}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.655}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.9}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Indigency determined \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapters 13B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{229A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{232}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{665}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{812}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{814}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{822}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 811.1A}}}{{\f5\fs18\hyphpar0\qj{, and the rules of criminal procedure, a person is indigent if the person is entitled to an attorney appointed by the court as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is entitled to an attorney appointed by the court to represent the person if the person has an income level at or below one hundred twenty-five percent of the United States poverty level as defined by the most recently revised poverty income guidelines published by the United States department of health and human services, unless the court determines that the person is able to pay for the cost of an attorney to represent the person on the pending case. In making the determination of a person\u8217\'3fs ability to pay for the cost of an attorney, the court shall consider not only the person\u8217\'3fs income, but also the availability of any assets subject to execution, including but not limited to cash, stocks, bonds, and any other property which may be applied to the satisfaction of judgments, and the seriousness of the charge or nature of the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person with an income level greater than one hundred twenty-five percent, but at or below two hundred percent, of the most recently revised poverty income guidelines published by the United States department of health and human services shall not be entitled to an attorney appointed by the court, unless the court makes a written finding that not appointing counsel on the pending case would cause the person substantial hardship. In determining whether substantial hardship would result, the court shall consider not only the person\u8217\'3fs income, but also the availability of any assets subject to execution, including but not limited to cash, stocks, bonds, and any other property which may be applied to the satisfaction of judgments, and the seriousness of the charge or nature of the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person with an income level greater than two hundred percent of the most recently revised poverty income guidelines published by the United States department of health and human services shall not be entitled to an attorney appointed by the court, unless the person is charged with a felony and the court makes a written finding that not appointing counsel would cause the person substantial hardship. In determining whether substantial hardship would result, the court shall consider not only the person\u8217\'3fs income, but also the availability of any assets subject to execution, including but not limited to cash, stocks, bonds, and any other property which may be applied to the satisfaction of judgments, and the seriousness of the charge or nature of the case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A determination of whether a person is entitled to an appointed attorney shall be made on the basis of an affidavit of financial status submitted at the time of the person\u8217\'3fs initial appearance or at such later time as a request for court appointment of counsel is made. The state public defender shall adopt rules prescribing the form and content of the affidavit of financial status. The affidavit of financial status shall be signed under penalty of perjury and shall contain sufficient information to allow the determination to be made of whether the person is entitled to an appointed attorney under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. If the person is granted an appointed attorney, the affidavit of financial status shall be filed and permanently retained in the person\u8217\'3fs court file.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person is granted an appointed attorney, the person shall be required to reimburse the state for the total cost of legal assistance provided to the person pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLegal assistance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall include not only the expense of the public defender or an appointed attorney, but also transcripts, witness fees, expenses, and any other goods or services required by law to be provided to an indigent person entitled to an appointed attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the appointed attorney is a public defender, the attorney shall submit a report to the court specifying the total hours of service plus expenses incurred in providing legal assistance to the person, unless the court has ordered that the cost of legal assistance is not required to be reimbursed to the state. In a criminal case, the report shall be submitted within a reasonable period of time after the date of sentencing, acquittal, or dismissal. In a case other than a criminal case, the report shall be submitted within a reasonable period of time after the date of any court ruling or the conclusion of a trial held in the case, or if the case is dismissed within a reasonable period of time after the date of dismissal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the appointed attorney is a private attorney or is employed by a nonprofit organization, the state public defender shall report to the clerk of the district court the amounts of any approved claims for compensation and expenses paid on behalf of a person receiving legal assistance after such claims have been reviewed and paid by the state public defender unless the appointed attorney is paid other than on an hourly rate basis and the state public defender has notified the appointed attorney that the attorney is responsible for reporting the attorney\u8217\'3fs total hours of service plus expenses to the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the appointed attorney has been notified by the state public defender that the attorney is responsible for reporting to the court the total hours of service plus expenses incurred in providing legal assistance to a person, the attorney shall submit a report to the court in the same manner as a public defender submits a report pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The amount of the attorney fees to be included in the total cost of legal assistance required to be reimbursed shall be calculated using the hours of service stated in the report at the hourly rate of compensation specified under }}}{{\f5\fs18\hyphpar0\qj{section 815.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person receiving legal assistance is convicted in a criminal case, the total costs and fees incurred for legal assistance shall be ordered paid when the reports submitted pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ are received by the court, and the court shall order the payment of such amounts as restitution, to the extent to which the person is reasonably able to pay, or order the performance of community service in lieu of such payments, in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 910}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person receiving legal assistance is acquitted in a criminal case or is a party in a case other than a criminal case, the court shall order the payment of all or a portion of the total costs and fees incurred for legal assistance, to the extent the person is reasonably able to pay, after an inquiry which includes notice and reasonable opportunity to be heard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When ordering payment of all or a portion of the total costs and fees incurred for legal assistance under }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{, the court may order payment of the costs and fees in reasonable installments as provided in }}}{{\f5\fs18\hyphpar0\qj{section 909.3}}}{{\f5\fs18\hyphpar0\qj{, or may order the entire amount due and payable. If any costs and fees are not paid at the time specified in the order of the court, a judgment shall be entered against the person for any unpaid amount. Such judgment may be enforced by the state in the same manner as a civil judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person is granted an appointed attorney or has received legal assistance in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the person is employed, the person shall execute an assignment of wages. An order for assignment of income, in a reasonable amount to be determined by the court, shall be entered by the court. The state public defender shall prescribe forms for use in wage assignments and court orders entered under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 3}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{6}}}{{\f5\fs18\hyphpar0\qj{, a minor granted a court-appointed attorney or guardian ad litem under }}}{{\f5\fs18\hyphpar0\qj{section 232.11}}}{{\f5\fs18\hyphpar0\qj{ in a juvenile proceeding shall not be ordered to reimburse costs and fees incurred for legal assistance except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710137, 10201}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 175, \'a723, 24}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1193, \'a79 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1115, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1067, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1084, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1063, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 56, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 88, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.10}}}{{\f5\fs12\hyphpar0\qj{, 125.76}}}{{\f5\fs12\hyphpar0\qj{, 331.756(5)(a)}}}{{\f5\fs12\hyphpar0\qj{, 331.756(5)(c)}}}{{\f5\fs12\hyphpar0\qj{, 331.756(5)(d)}}}{{\f5\fs12\hyphpar0\qj{, 598.7}}}{{\f5\fs12\hyphpar0\qj{, 801.4}}}{{\f5\fs12\hyphpar0\qj{, 814.11}}}{{\f5\fs12\hyphpar0\qj{, 815.4}}}{{\f5\fs12\hyphpar0\qj{, 815.10}}}{{\f5\fs12\hyphpar0\qj{, 815.10A}}}{{\f5\fs12\hyphpar0\qj{, 815.14}}}{{\f5\fs12\hyphpar0\qj{, 908.2A}}}{{\f5\fs12\hyphpar0\qj{, 910.1}}}{{\f5\fs12\hyphpar0\qj{, 910.2}}}{{\f5\fs12\hyphpar0\qj{, 910.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.9A}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Recovery of indigent defense costs.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1999/CH0135.pdf" }{\fldrslt \cf5 \f5 \fs18{{99 Acts, ch 135, \'a731}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.10}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of counsel by court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court, for cause and upon its own motion or upon application by an indigent person or a public defender, shall appoint the state public defender\u8217\'3fs designee pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 13B.4}}}{{\f5\fs18\hyphpar0\qj{ to represent an indigent person at any stage of the criminal, postconviction, contempt, commitment under }}}{{\f5\fs18\hyphpar0\qj{chapter 229A}}}{{\f5\fs18\hyphpar0\qj{, termination under }}}{{\f5\fs18\hyphpar0\qj{chapter 600A}}}{{\f5\fs18\hyphpar0\qj{, detention under }}}{{\f5\fs18\hyphpar0\qj{section 811.1A}}}{{\f5\fs18\hyphpar0\qj{, competency under }}}{{\f5\fs18\hyphpar0\qj{chapter 812}}}{{\f5\fs18\hyphpar0\qj{, parole revocation if applicable under }}}{{\f5\fs18\hyphpar0\qj{section 908.2A}}}{{\f5\fs18\hyphpar0\qj{, or juvenile proceedings or on appeal of any criminal, postconviction, contempt, commitment under }}}{{\f5\fs18\hyphpar0\qj{chapter 229A}}}{{\f5\fs18\hyphpar0\qj{, termination under }}}{{\f5\fs18\hyphpar0\qj{chapter 600A}}}{{\f5\fs18\hyphpar0\qj{, detention under }}}{{\f5\fs18\hyphpar0\qj{section 811.1A}}}{{\f5\fs18\hyphpar0\qj{, competency under }}}{{\f5\fs18\hyphpar0\qj{chapter 812}}}{{\f5\fs18\hyphpar0\qj{, parole revocation under }}}{{\f5\fs18\hyphpar0\qj{chapter 908}}}{{\f5\fs18\hyphpar0\qj{, or juvenile action in which the indigent person is entitled to legal assistance at public expense. However, in juvenile cases, the court may directly appoint an existing nonprofit corporation established for and engaged in the provision of legal services for juveniles. An appointment shall not be made unless the person is determined to be indigent under }}}{{\f5\fs18\hyphpar0\qj{section 815.9}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An indigent person is entitled to the appointment of one attorney in all cases, except the court may appoint two attorneys in class \u8220\'3fA\u8221\'3f felony cases and in cases where an assistant state public defender from the wrongful convictions division of the office of the state public defender enters an appearance after a private attorney has been appointed to represent the indigent person. However, in a class \u8220\'3fA\u8221\'3f felony case, a person who is represented by a privately retained attorney or by an attorney who has agreed to represent the person is not entitled to have an attorney appointed to represent the person based upon the indigence of the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a criminal proceeding in which an indigent person is entitled to legal assistance at public expense is a proceeding where the person faces the possibility of imprisonment under the applicable criminal statute or ordinance. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not require the appointment of an attorney if the indigent person does not request the appointment of an attorney or waives the right to an appointed attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the state public defender or the state public defender\u8217\'3fs designee is unable to represent an indigent person, the court shall appoint an attorney who has a contract with the state public defender to represent the person in the particular type of case and in the county in which the case is pending.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines that no contract attorney is available to represent the person, the court may appoint a noncontract attorney. The order of appointment shall include a specific finding that no contract attorney was available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The appointment of an attorney shall be on a rotational or equalization basis, considering the experience of the attorney, the difficulty of the case, and the geographic proximity of the attorney\u8217\'3fs office to the courthouse and client.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An attorney who has been retained or has agreed to represent a person and subsequently applies to the court for appointment to represent that person because the person is indigent shall notify the state public defender of the application. Upon the filing of the application, the attorney shall provide the state public defender with a copy of any representation agreement, and information on any moneys earned or paid to the attorney prior to the appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An attorney appointed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not liable to a person represented by the attorney for damages as a result of a conviction in a criminal case unless the court determines in a postconviction proceeding or on direct appeal that the person\u8217\'3fs conviction resulted from ineffective assistance of counsel, and the ineffective assistance of counsel is the proximate cause of the damage. In juvenile or civil proceedings, an attorney appointed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not liable to a person represented by the attorney for damages unless it has been determined that the attorney has provided ineffective assistance of counsel, and the ineffective assistance of counsel is the proximate cause of the damage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state public defender may adopt rules setting forth additional uniform standard procedures for the appointment of counsel and uniform forms for appointment.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710138, 10201}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 268, \'a7436, 439}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1187, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1040, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1115, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1067, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1017, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1084, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 107, \'a78, 14}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1063, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 56, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 88, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1060, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.4}}}{{\f5\fs12\hyphpar0\qj{, 13B.9}}}{{\f5\fs12\hyphpar0\qj{, 22.7(44)}}}{{\f5\fs12\hyphpar0\qj{, 815.1}}}{{\f5\fs12\hyphpar0\qj{, 815.7}}}{{\f5\fs12\hyphpar0\qj{, 815.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.10A}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Claims for compensation and expense reimbursement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An attorney other than a public defender who has been appointed by the court under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ must submit a claim to the state public defender for compensation and reimbursement of expenses incurred in the representation of an indigent person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Claims for compensation and reimbursement submitted by an attorney and claims for any other expenses paid from the indigent defense fund are not considered timely unless the claim is submitted to the state public defender within forty-five days of the date of service, as defined by the state public defender in rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An attorney shall obtain court approval prior to exceeding the fee limitations established by the state public defender pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 13B.4}}}{{\f5\fs18\hyphpar0\qj{. An attorney may exceed the fee limitations if good cause for exceeding the fee limitations is shown. An attorney may obtain court approval after exceeding the fee limitations if good cause excusing the attorney\u8217\'3fs failure to seek approval prior to exceeding the fee limitations is shown. However, failure to file an application to exceed a fee limitation prior to exceeding the fee limitation does not constitute good cause. The order approving an application to exceed the fee limitations shall be effective from the date of filing the application unless the court order provides an alternative effective date. The application and the court order approving the application to exceed fee limitations and any other order affecting the amount of compensation or reimbursement shall be submitted with any claim for compensation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for an application to exceed fee limitations by an attorney or guardian ad litem representing a juvenile in a juvenile proceeding, an application to exceed fee limitations shall include a statement attesting that the attorney advised the indigent person of the application, and the potential for reimbursement of the attorney fees pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 815.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the information is not submitted as required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and under the rules of the state public defender, the claim for compensation may be denied until the information is provided. Upon receipt of the required information, the state public defender may approve reasonable and necessary compensation, as provided for in the administrative rules and the law.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1067, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1040, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1061, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1063, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 56, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.11}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appropriations for indigent defense }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fund created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Costs incurred for legal representation by a court-appointed attorney under }}}{{\f5\fs18\hyphpar0\qj{chapter 229A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{665}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{822}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{908}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 232.141, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 598.23A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{600A.6B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{814.9}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{814.10}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{814.11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{815.4}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{815.7}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{815.10}}}{{\f5\fs18\hyphpar0\qj{, or for payment of the services of a court-appointed guardian ad litem under }}}{{\f5\fs18\hyphpar0\qj{section 600A.6C, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, on behalf of an indigent shall be paid from moneys appropriated by the general assembly to the office of the state public defender in the department of inspections, appeals, and licensing and deposited in an account to be known as the indigent defense fund, except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. Costs incurred representing an indigent defendant in a contempt action, representing an indigent juvenile in a juvenile court proceeding, or representing a person pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 13B.13}}}{{\f5\fs18\hyphpar0\qj{ are also payable from the fund. However, costs incurred in any administrative proceeding or in any other proceeding under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 598}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{600}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{600A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{633}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{633A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{814}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{915}}}{{\f5\fs18\hyphpar0\qj{ or other provisions of the Code or administrative rules are not payable from the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs and fees associated with translators, foreign language interpreters, and sign language interpreters are not payable from this fund. The costs and fees of sign language interpreters shall be paid by the county pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 622B.7}}}{{\f5\fs18\hyphpar0\qj{, and the costs and fees of translators and foreign language interpreters shall be paid pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 622A.3}}}{{\f5\fs18\hyphpar0\qj{ from moneys appropriated by the general assembly to the judicial branch revolving fund created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.1302, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710139, 10201}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 195, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1187, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1171, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1115, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1067, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 51, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1040, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 107, \'a79, 14}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1030, \'a782}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1041, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 22, \'a7106}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1061, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1040, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 77, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72040}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1112, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713B.1}}}{{\f5\fs12\hyphpar0\qj{, 13B.4A}}}{{\f5\fs12\hyphpar0\qj{, 22.7(10)}}}{{\f5\fs12\hyphpar0\qj{, 232.141}}}{{\f5\fs12\hyphpar0\qj{, 600A.6B}}}{{\f5\fs12\hyphpar0\qj{, 600A.6C}}}{{\f5\fs12\hyphpar0\qj{, 815.7A}}}{{\f5\fs12\hyphpar0\qj{, 815.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.12}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trial jury expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The clerk of the district court shall pay fees and mileage due petit jurors, and the costs of food, lodging, and transportation when provided for petit jurors.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710140, 10201}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.13}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Payment of prosecution costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The county or city which has the duty to prosecute a criminal action shall pay the costs of depositions taken on behalf of the prosecution, the costs of transcripts requested by the prosecution, and in criminal actions prosecuted by the county or city under county or city ordinance the fees that are payable to the clerk of the district court for services rendered and the court costs taxed in connection with the trial of the action or appeals from the judgment. The county or city shall pay witness fees and mileage in trials of criminal actions prosecuted by the county or city under county or city ordinance. These fees and costs are recoverable by the county or city from the defendant unless the defendant is found not guilty or the action is dismissed, in which case the state shall pay the witness fees and mileage in cases prosecuted under state law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710141, 10201}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1178, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1301, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 197, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.424}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.14}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fee for public defender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The amount of restitution for the expense of the public defender for each case under }{{\f5\fs18\hyphpar0\qj{section 910.3}}}{ or the total cost of legal assistance required to be reimbursed under }{{\f5\fs18\hyphpar0\qj{section 815.9, subsection 3}}}{, shall include all expenses incurred in the representation of the person combined with the attorney fees for the public defender calculated at the same hourly rate of compensation specified under }{{\f5\fs18\hyphpar0\qj{section 815.7}}}{. The expense of the public defender may exceed the fee limitations established in }{{\f5\fs18\hyphpar0\qj{section 13B.4}}}{. The expense of the public defender required to be reimbursed is subject to a determination of the extent to which the person is reasonably able to pay, as provided for in }{{\f5\fs18\hyphpar0\qj{section 815.9}}}{ and }{{\f5\fs18\hyphpar0\qj{chapter 910}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1067, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1063, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{815.15}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations of local ordinances }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ reimbursement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an attorney is appointed in a case to represent an indigent person for an alleged violation of a local ordinance that may require a term of confinement, the office of the state public defender shall seek reimbursement from the political subdivision of the state that was the plaintiff in the case for the compensation paid to and the expenses incurred by the attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A political subdivision of the state shall reimburse the office of the state public defender for the compensation and expenses paid from the indigent defense fund in }}}{{\f5\fs18\hyphpar0\qj{section 815.11}}}{{\f5\fs18\hyphpar0\qj{ to an attorney who represented the indigent person pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 88, \'a76, 7}}}\par}}