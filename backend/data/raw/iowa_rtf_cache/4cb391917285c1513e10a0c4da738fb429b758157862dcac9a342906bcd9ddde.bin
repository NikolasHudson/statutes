\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F123}{\*\bkmkend codeChapter_5F123}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 123}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{ALCOHOLIC BEVERAGE CONTROL}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a799B.3}}}{{\f5\fs12\qc{, 99B.12}}}{{\f5\fs12\qc{, 99B.43}}}{{\f5\fs12\qc{, 99B.53}}}{{\f5\fs12\qc{, 99B.55}}}{{\f5\fs12\qc{, 125.2}}}{{\f5\fs12\qc{, 137F.1}}}{{\f5\fs12\qc{, 232C.4}}}{{\f5\fs12\qc{, 421.17}}}{{\f5\fs12\qc{, 523H.1}}}{{\f5\fs12\qc{, 537A.10}}}{{\f5\fs12\qc{, 714.16}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E2_2E2}{GENERAL PROVISIONS RELATING TO ALCOHOLIC BEVERAGES}{\*\bkmkend stylerid1_2E5_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7123.122}}}{{\f5\fs12\qc{, 123.171}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.1}}}{\*\bkmkstart stylerid1_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public policy declared.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa Alcoholic Beverage Control Act\u8221\'3f}}}{, and shall be deemed an exercise of the police power of the state, for the protection of the welfare, health, peace, morals, and safety of the people of the state, and all its provisions shall be liberally construed for the accomplishment of that purpose. It is declared to be public policy that the traffic in alcoholic liquors is so affected with a public interest that it should be regulated to the extent of prohibiting all traffic in them, except as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.001;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1122, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.2}}}{\*\bkmkstart stylerid1_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General prohibition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is unlawful to manufacture for sale, sell, offer or keep for sale, possess, or transport alcoholic liquor, wine, or beer except upon the terms, conditions, limitations, and restrictions enumerated in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.003;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.3; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.3}}}{\*\bkmkstart stylerid1_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAir common carrier\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person engaged in transporting passengers for hire in interstate or foreign commerce by aircraft and operating regularly scheduled flights under a certificate of public convenience issued by the civil aeronautics board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAlcohol\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the product of distillation of any fermented liquor rectified one or more times, whatever may be the origin thereof, and includes synthetic ethyl alcohol.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAlcoholic beverage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any beverage containing more than one-half of one percent of alcohol by volume including alcoholic liquor, wine, and beer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAlcoholic liquor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the varieties of liquor defined in }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 49}}}{{\f5\fs18\hyphpar0\qj{ which contain more than six and twenty-five hundredths percent of alcohol by volume, beverages made as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{ which beverages contain more than six and twenty-five hundredths percent of alcohol by volume but which are not wine as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 53}}}{{\f5\fs18\hyphpar0\qj{, high alcoholic content beer as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 22}}}{{\f5\fs18\hyphpar0\qj{, or canned cocktails as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{, and every other liquid or solid, patented or not, containing spirits and every beverage obtained by the process described in }}}{{\f5\fs18\hyphpar0\qj{subsection 53}}}{{\f5\fs18\hyphpar0\qj{ containing more than twenty-one and twenty-five hundredths percent of alcohol by volume, and susceptible of being consumed by a human being, for beverage purposes. Alcohol manufactured in this state for use as fuel pursuant to an experimental distilled spirits plant permit or its equivalent issued by the federal bureau of alcohol, tobacco and firearms is not an }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3falcoholic liquor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fApplication\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a written request for the issuance of a permit, license, or certificate that is supported by a verified statement of facts and submitted electronically, or in a manner prescribed by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBeer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any liquid capable of being used for beverage purposes made by the fermentation of an infusion in potable water of barley, malt, and hops, with or without unmalted grains or decorticated and degerminated grains or made by the fermentation of or by distillation of the fermented products of fruit, fruit extracts, or other agricultural products, containing more than one-half of one percent of alcohol by volume but not more than six and twenty-five hundredths percent of alcohol by volume.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBrewer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person who manufactures beer for the purpose of sale, barter, exchange, or transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBrewpub\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a commercial establishment authorized to sell beer at retail for consumption on or off the premises that is operated by a person who holds a class \u8220\'3fC\u8221\'3f or special class \u8220\'3fC\u8221\'3f retail alcohol license and who also holds a special class \u8220\'3fA\u8221\'3f beer permit that authorizes the holder to manufacture and sell beer pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBroker\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who represents or promotes alcoholic liquor within the state on behalf of the holder of a distiller\u8217\'3fs certificate of compliance, a manufacturer\u8217\'3fs license, or a class \u8220\'3fA\u8221\'3f native distilled spirits license. An employee of the holder of a distiller\u8217\'3fs certificate of compliance, a manufacturer\u8217\'3fs license, or a class \u8220\'3fA\u8221\'3f native distilled spirits license is not a broker.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCanned cocktail\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a mixed drink or cocktail, the alcohol component of which is primarily composed of alcoholic liquor, that is premixed and packaged in a metal can and contains more than one-half of one percent of alcohol by volume but not more than fifteen percent of alcohol by volume. A mixed drink or cocktail mixed and packaged in a metal can pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), shall not be considered a canned cocktail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a municipal corporation but not including a county, township, school district, or any special purpose district or authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClub\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any nonprofit corporation or association of individuals, which is the owner, lessee, or occupant of a permanent building or part thereof, membership in which entails the prepayment of regular dues and is not operated for a profit other than such profits as would accrue to the entire membership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommercial establishment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a place of business which is at all times equipped with sufficient tables and seats to accommodate twenty-five persons at one time, and the licensed premises of which conform to the standards and specifications of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the alcoholic beverages commission established by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompleted application\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an application where all necessary fees have been paid in full, any required bonds have been submitted, the applicant has provided all information requested by the department, and the application meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 123.92, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDesignated security employee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an agent, contract employee, independent contractor, servant, or employee of a licensee or permittee who works in a security position in any capacity at a commercial establishment licensed or permitted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of the department of revenue or the director\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDistillery\u8221\'3f, \u8220\'3fwinery\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbrewery\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean not only the premises where alcohol or spirits are distilled, wine is fermented, or beer is brewed, but in addition mean a person owning, representing, or in charge of such premises and the operations conducted there, including the blending and bottling or other handling and preparation of alcoholic liquor, wine, or beer in any form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGrape brandy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means brandy produced by the distillation of fermented grapes or grape juice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGrocery store\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any retail establishment, the business of which consists of the sale of food, food products, or beverages for consumption off the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHigh alcoholic content beer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means beer which contains more than six and twenty-five hundredths percent of alcohol by volume, but not more than nineteen percent of alcohol by volume, that is made by the fermentation of an infusion in potable water of barley, malt, and hops, with or without unmalted grains or decorticated and degerminated grains. Not more than one and five-tenths percent of the volume of a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhigh alcoholic content beer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may consist of alcohol derived from added flavors and other nonbeverage ingredients containing alcohol. The added flavors and other nonbeverage ingredients may not include added caffeine or other added stimulants including but not limited to guarana, ginseng, and taurine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHotel\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmotel\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means premises licensed by the department of inspections, appeals, and licensing and regularly or seasonally kept open in a bona fide manner for the lodging of transient guests, and with twenty or more sleeping rooms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fImport\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the transporting or ordering or arranging the transportation of alcoholic liquor, wine, or beer into this state whether by a resident of this state or not.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fImporter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the person who transports or orders, authorizes, or arranges the transportation of alcoholic liquor, wine, or beer into this state whether the person is a resident of this state or not.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The terms }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fin accordance with the provisions of }}}{{\i\f5\fs18\hyphpar0\qj{this chapter}}}{{\i\f5\fs18\hyphpar0\qj{\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpursuant to the provisions of }}}{{\i\f5\fs18\hyphpar0\qj{this title}}}{{\i\f5\fs18\hyphpar0\qj{\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or similar terms shall include all rules and regulations of the department adopted to aid in the administration or enforcement of those provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInstitutional investor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who maintains a diversified portfolio of investments through a state or federally chartered bank, a mutual fund, a retirement plan or account created by an employer, the person, or another individual to provide retirement benefits or deferred compensation to the person, a private investment firm, or a holding company publicly traded on the New York stock exchange, the American stock exchange, or NASDAQ stock market and who has a majority of investments in businesses other than businesses that manufacture, bottle, wholesale, or sell at retail alcoholic beverages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLegal age\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means twenty-one years of age or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{29.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensed premises\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpremises\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all rooms, enclosures, contiguous areas, or places susceptible of precise description satisfactory to the director where alcoholic beverages, wine, or beer is sold or consumed under authority of a retail alcohol license, wine permit, or beer permit. A single licensed premises may consist of multiple rooms, enclosures, areas, or places if they are wholly within the confines of a single building or contiguous grounds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{30.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal authority\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the city council of any incorporated city in this state, or the county board of supervisors of any county in this state, which is empowered by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to approve or deny applications for retail alcohol licenses; empowered to recommend that such licenses be granted and issued by the department; and empowered to take other actions reserved to them by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{31.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufacture\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means to distill, rectify, ferment, brew, make, mix, concoct, or process any substance capable of producing a beverage containing more than one-half of one percent of alcohol by volume and includes blending, bottling, or the preparation for sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{32.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMixed drink or cocktail\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an alcoholic beverage, composed in whole or in part of alcoholic liquor, wine, or beer, that is combined with other alcoholic beverages or nonalcoholic beverages or ingredients including but not limited to ice, water, soft drinks, or flavorings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{33.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNative brewery\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business which manufactures beer or high alcoholic content beer and is operated by a person who holds a class \u8220\'3fA\u8221\'3f beer permit that authorizes the holder to manufacture and sell beer pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{34.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNative distilled spirits\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means spirits fermented, distilled, or, for a period of two years, barrel matured on the licensed premises of the native distillery where fermented, distilled, or matured. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNative distilled spirits\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also includes blended or mixed spirits comprised solely of spirits fermented, distilled, or, for a period of two years, barrel matured at a native distillery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{35.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNative distillery\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business with an operating still which produces and manufactures native distilled spirits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{36.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNative wine\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means wine manufactured pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.176}}}{{\f5\fs18\hyphpar0\qj{ by a manufacturer of native wine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{37.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPackage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any container or receptacle used for holding alcoholic liquor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{38.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPermit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flicense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an express written authorization issued by the department for the manufacture or sale, or both, of alcoholic liquor, wine, or beer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{39.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any individual, association, or partnership, any corporation, limited liability company, or other similar legal entity, any club, hotel or motel, or any municipal corporation owning or operating a bona fide airport, marina, park, coliseum, auditorium, or recreational facility in or at which the sale of alcoholic liquor, wine, or beer is only an incidental part of the ownership or operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{40.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson of good moral character\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person who meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has such financial standing and good reputation as will satisfy the director that the person will comply with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and all laws, ordinances, and regulations applicable to the person\u8217\'3fs operations under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, the director shall not require the person to post a bond to meet the requirements of this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is not prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 123.40}}}{{\f5\fs18\hyphpar0\qj{ from obtaining a retail alcohol license or a wine or beer permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the applicant is a citizen of the United States and a resident of this state, or licensed to do business in this state in the case of a corporation. Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in the case of a partnership, only one general partner need be a resident of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has not been convicted of a felony. However, if the person\u8217\'3fs conviction of a felony occurred more than five years before the date of the application for a license or permit, and if the person\u8217\'3fs rights of citizenship have been restored by the governor, the director may determine that the person is of good moral character notwithstanding such conviction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ apply to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each of the officers, directors, and partners of such person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who directly or indirectly owns or controls ten percent or more of any class of stock of such person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who directly or indirectly has an interest of ten percent or more in the ownership or profits of such person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{41.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPharmacy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a drug store in which drugs and medicines are exposed for sale and sold at retail, or in which prescriptions of licensed physicians and surgeons, dentists, prescribing psychologists, or veterinarians are compounded and sold by a registered pharmacist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{42.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPrivate place\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a location which, at the time alcoholic beverages are kept, dispensed, or consumed, meets all of the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general public does not have access to the location and attendees are limited to bona fide social hosts and invited guests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location is not of a commercial nature.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Goods or services are neither sold nor purchased at the location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location is not a licensed premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Admission fees or other kinds of entrance fees, fare, ticket, donation or charges are not made or are required of the invited guests to enter the location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{43.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic place\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any place, building, or conveyance to which the public has or is permitted access.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{44.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResidence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the place where a person resides, permanently or temporarily.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{45.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRetail alcohol license\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a class \u8220\'3fB\u8221\'3f, class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, class \u8220\'3fE\u8221\'3f, or class \u8220\'3fF\u8221\'3f retail alcohol license, or a special class \u8220\'3fB\u8221\'3f or special class \u8220\'3fC\u8221\'3f retail native wine license issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{46.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRetailer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person who shall sell, barter, exchange, offer for sale, or have in possession with intent to sell any alcoholic liquor, wine, or beer for consumption either on or off the premises where sold.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{47.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prohibited }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsale\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of alcoholic liquor, wine, or beer under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ includes soliciting for sales, taking orders for sales, keeping or exposing for sale, delivery or other trafficking for a valuable consideration promised or obtained, and procuring or allowing procurement for any other person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{48.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchool\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a public or private school or that portion of a public or private school which provides facilities for teaching any grade from kindergarten through grade twelve.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{49.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSpirits\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any beverage which contains alcohol obtained by distillation mixed with drinkable water and other substances in solution, including, but not limited to, brandy, rum, whisky, and gin.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{50.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnincorporated town\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a compactly populated area recognized as a distinct place with a distinct place-name which is not itself incorporated or within the corporate limits of a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{51.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWarehouse\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any premises or place primarily constructed or used or provided with facilities for the storage in transit or other temporary storage of perishable goods or for the conduct of normal warehousing business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{52.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWholesaler\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person, other than a vintner, brewer or bottler of beer or wine, who shall sell, barter, exchange, offer for sale, have in possession with intent to sell, deal or traffic in alcoholic liquor, wine, or beer. A wholesaler shall not sell for consumption upon the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{53.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWine\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any beverage containing more than six and twenty-five hundredths percent of alcohol by volume but not more than twenty-one and twenty-five hundredths percent of alcohol by volume obtained by the fermentation of the natural sugar contents of fruits or other agricultural products but excluding any product containing alcohol derived from malt or by the distillation process from grain, cereal, molasses, or cactus.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f5, 1921-f97; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.005, 1921.096;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.5, 124.2; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.3}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 55, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a75 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1122, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7724, 725}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1088, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 161, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1017, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1201, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 143, \'a71, 2, 17}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 13, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1032, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1185, \'a7118}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a787, 88, 96}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 17, \'a71 \u8211\'3f 3, 17}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 30, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a71, 24}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1112, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a71, 39}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 8, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 107, \'a71, 2, 6}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 155, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a716 \u8211\'3f 19, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71872, 2351 \u8211\'3f 2354}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 157, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 31, \'a71, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a77D.16}}}{{\f5\fs12\hyphpar0\qj{, 99F.4}}}{{\f5\fs12\hyphpar0\qj{, 123.31}}}{{\f5\fs12\hyphpar0\qj{, 123.31A}}}{{\f5\fs12\hyphpar0\qj{, 123.32}}}{{\f5\fs12\hyphpar0\qj{, 123.35}}}{{\f5\fs12\hyphpar0\qj{, 123.43}}}{{\f5\fs12\hyphpar0\qj{, 123.127}}}{{\f5\fs12\hyphpar0\qj{, 123.130}}}{{\f5\fs12\hyphpar0\qj{, 123.175}}}{{\f5\fs12\hyphpar0\qj{, 123A.2}}}{{\f5\fs12\hyphpar0\qj{, 142D.2}}}{{\f5\fs12\hyphpar0\qj{, 455B.301}}}{{\f5\fs12\hyphpar0\qj{, 455C.1}}}{{\f5\fs12\hyphpar0\qj{, 455C.5}}}{{\f5\fs12\hyphpar0\qj{, 455C.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 10 and 32 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.4}}}{\*\bkmkstart stylerid1_2E5_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alcoholic beverage control.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department of revenue shall administer and enforce the laws of this state concerning alcoholic beverage control.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f15; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.015;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.15; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a7731}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72355}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.38A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.5}}}{\*\bkmkstart stylerid1_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alcoholic beverages commission created }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ appointment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ removal }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ vacancies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An alcoholic beverages commission is created within the department. The commission is composed of five members, not more than three of whom shall belong to the same political party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members shall be appointed by the governor, subject to confirmation by the senate. Appointments shall be for five-year staggered terms beginning and ending as provided by }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{. A member may be reappointed for one additional term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the commission shall be chosen on the basis of managerial ability and experience as business executives. Not more than two members of the commission may be the holder of or have an interest in a permit or license to manufacture alcoholic liquor, wine, or beer or to sell alcoholic liquor, wine, or beer at wholesale or retail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any commission member shall be subject to removal for any of the causes and in the manner provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 66}}}{{\f5\fs18\hyphpar0\qj{ relating to removal from office. Removal shall not be in lieu of any other punishment that may be prescribed by the laws of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any vacancy on the commission shall be filled in the same manner as regular appointments are made for the unexpired portion of the regular term.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.006;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.6; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7732}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72356}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.13}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.6}}}{\*\bkmkstart stylerid1_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commission meetings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commission shall meet on or before July 1 of each year for the purpose of selecting one of its members as chairperson for the succeeding year. The commission shall meet at the call of the chairperson or director or when three members file a written request for a meeting. Written notice of the time and place of each meeting shall be given to each member of the commission. A majority of the commission members shall constitute a quorum.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f10; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.010;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.10; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 17, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72357}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.7}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall supervise the daily operations of the department under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and shall execute the alcoholic beverage control policies of the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7735}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72358}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.8}}}{\*\bkmkstart stylerid1_2E5_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission, in addition to the duties specifically enumerated in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, shall serve in an advisory capacity to the director and department. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may provide advice and make recommendations regarding the actions of the director under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to the following instances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Purchases of alcoholic liquor for resale by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The establishment of wholesale prices of alcoholic liquor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.16}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1122, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a7737}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7726, 727}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72359}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7193, 194}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.9}}}{\*\bkmkstart stylerid1_2E5_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers of director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director, in executing the alcoholic beverage control functions of the department, shall have the following duties and powers:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To receive alcoholic liquors on a bailment system for resale by the department in the manner set forth in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To rent, lease, or equip any building or any land necessary to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To lease all plants and lease or buy equipment necessary to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To appoint clerks, agents, or other employees required for carrying out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{; to dismiss employees for cause; to assign employees to divisions and bureaus as created by the director within the department; and to designate their title, duties, and powers. All employees of the department for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ are subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 8A, subchapter IV}}}{{\f5\fs18\hyphpar0\qj{, unless exempt under }}}{{\f5\fs18\hyphpar0\qj{section 8A.412}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To grant and issue beer permits, wine permits, retail alcohol licenses, and other licenses; and to suspend or revoke all such permits and licenses for cause under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To license, inspect, and control the manufacture of alcoholic beverages and regulate the entire alcoholic beverage industry in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To accept alcoholic liquors ordered delivered to the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 809A}}}{{\f5\fs18\hyphpar0\qj{, and offer for sale and deliver the alcoholic liquors to class \u8220\'3fE\u8221\'3f retail alcohol licensees, unless the director determines that the alcoholic liquors may be adulterated or contaminated. If the director determines that the alcoholic liquors may be adulterated or contaminated, the director shall order their destruction.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f16; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.016;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.16; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 157, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 90, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1122, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a7738}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7728 \u8211\'3f 730}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1133, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7185}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7204}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1008, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a720, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72360, 2361}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.38A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.10}}}{\*\bkmkstart stylerid1_2E5_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director, with the advice of the commission and subject to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{, may adopt rules as necessary to carry out }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The director\u8217\'3fs authority under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ extends to but is not limited to the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing the duties of officers, clerks, agents, or other employees of the department under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and regulating their conduct while in the discharge of their duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulating the management, equipment, and merchandise of state warehouses in and from which alcoholic liquors are transported, kept, or sold and prescribing the books and records to be kept therein.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulating the purchase of alcoholic liquor generally and the furnishing of the liquor to class \u8220\'3fE\u8221\'3f retail alcohol licensees under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and determining the classes, varieties, and brands of alcoholic liquors to be kept in state warehouses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing forms or information blanks to be used for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing the nature and character of evidence which shall be required to establish legal age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing for the issuance and electronic distribution of price lists which show the price to be paid by class \u8220\'3fE\u8221\'3f retail alcohol licensees for each brand, class, or variety of liquor kept for sale by the department, providing for the filing or posting of prices charged in sales between class \u8220\'3fA\u8221\'3f beer and class \u8220\'3fA\u8221\'3f wine permit holders and retailers, as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and establishing or controlling the prices based on minimum standards of fill, quantity, or alcoholic content for each individual sale of alcoholic beverages as deemed necessary for retail or consumer protection. However, the department shall not regulate markups, prices, discounts, allowances, or other terms of sale at which alcoholic liquor may be purchased by the retail public or retail alcohol licensees from class \u8220\'3fE\u8221\'3f retail alcohol licensees or at which wine may be purchased and sold by class \u8220\'3fA\u8221\'3f and retail wine permittees, or change, nullify, or vary the terms of an agreement between a holder of a vintner certificate of compliance and a class \u8220\'3fA\u8221\'3f wine permittee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing the official seals, labels, or other markings which shall be attached to or stamped on packages of alcoholic liquor sold under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing, subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the days and hours during which state warehouses shall be kept open for the purpose of the sale and delivery of alcoholic liquors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing the place and the manner in which alcoholic liquor may be lawfully kept or stored by the licensed manufacturer under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing the time, manner, means, and method by which distillers, vendors, or others authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may deliver or transport alcoholic liquors and prescribing the time, manner, means, and methods by which alcoholic liquor may be lawfully conveyed, carried, or transported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing, subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the conditions and qualifications necessary for the obtaining of licenses and permits and the books and records to be kept and the remittances to be made by those holding licenses and permits and providing for the inspection of the records of all such licensees and permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing for the issuance of combination licenses and permits with fees consistent with individual license and permit fees as may be necessary for the efficient administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing for the issuance of a waiver for an individual of legal age desiring to import alcoholic liquor, wine, or beer in excess of the amount provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.22}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{\~}}}{{\f5\fs18\hyphpar0\qj{123.122}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{123.171}}}{{\f5\fs18\hyphpar0\qj{, as applicable. The waiver shall be limited to those individuals who were domiciled outside the state within one year of the request for a waiver and shall provide that any alcoholic liquor, wine, or beer imported pursuant to the waiver shall be for personal consumption only in a private home or other private accommodation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing the uniform fee to be assessed against a retail alcohol licensee, except a class \u8220\'3fB\u8221\'3f, special class \u8220\'3fB\u8221\'3f, or class \u8220\'3fE\u8221\'3f retail alcohol licensee, to cover the administrative costs incurred by the department resulting from the failure of the licensee to maintain dramshop liability insurance coverage pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.92, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing the uniform fee, not to exceed one hundred dollars, to be assessed against a licensee or permittee under this chapter for a contested case hearing conducted by the department or by an administrative law judge from the department of inspections, appeals, and licensing which results in administrative action taken against the licensee or permittee by the department.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f17; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.017;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.17; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.21}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1122, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a7739}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7731, 732}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7204}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1008, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1096, \'a71, 6, 7}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a721, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71873, 2362, 2363}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7195}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.11}}}{\*\bkmkstart stylerid1_2E5_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Compensation and expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Members of the commission, the director, and other employees of the department shall be allowed their actual and necessary expenses while traveling on business of the department under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ outside of their place of residence, however, an itemized account of such expenses shall be verified by the claimant and approved by the director. If such account is paid, the same shall be filed with the department and be and remain a part of its permanent records. Each member appointed to the commission is entitled to receive reimbursement of actual expenses incurred while attending meetings. Each member of the commission may also be eligible to receive compensation as provided in }{{\f5\fs18\hyphpar0\qj{section 7E.6}}}{. All expenses and salaries of commission members, the director, and other employees shall be paid from appropriations for such purposes and the department shall be subject to the budget requirements of }{{\f5\fs18\hyphpar0\qj{chapter 8}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f11; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.011;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72364}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.12}}}{\*\bkmkstart stylerid1_2E5_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemption from suit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{ A commission member or officer or employee of the department shall not be personally liable for damages sustained by any person due to the act of such member, officer, or employee performed in the reasonable discharge of the member\u8217\'3fs, officer\u8217\'3fs, or employee\u8217\'3fs duties as enumerated in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f13; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.013;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a7204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72365}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.13}}}{\*\bkmkstart stylerid1_2E5_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibitions on commission members and employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Commission members, officers, and employees of the department under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not, while holding such office or position, do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hold any other office or position under the laws of this state, or any other state or territory or of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Engage in any occupation, business, endeavor, or activity which would or does conflict with their duties under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Directly or indirectly, use their office or employment to influence, persuade, or induce any other officer, employee, or person to adopt their political views or to favor any particular candidate for an elective or appointive public office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Directly or indirectly, solicit or accept, in any manner or way, any money or other thing of value for any person seeking an elective or appointive public office, or to any political party or any group of persons seeking to become a political party.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.5, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a commission member or department employee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not, directly or indirectly, individually, or as a member of a partnership or shareholder in a corporation, have any interest in dealing in or in the manufacture of alcoholic liquor, wine, or beer, and shall not receive any kind of profit nor have any interest in the purchase or sale of alcoholic liquor, wine, or beer by persons so authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit any member or employee from lawfully purchasing and keeping alcoholic liquor, wine, or beer in the member\u8217\'3fs or employee\u8217\'3fs possession for personal use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any officer or employee violating }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or any other provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall, in addition to any other penalties provided by law, be subject to suspension or discharge from employment. Any commission member shall, in addition to any other penalties provided by law, be subject to removal from office as provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 66}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f14; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.014;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.14; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a741, 204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72366}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.14}}}{\*\bkmkstart stylerid1_2E5_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alcoholic beverage control law enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of public safety is the primary alcoholic beverage control law enforcement authority for this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney, the county sheriff and the sheriff\u8217\'3fs deputies, and the police department of every city, and the department, shall be supplementary aids to the department of public safety for purposes of alcoholic beverage control law enforcement. Any neglect, misfeasance, or malfeasance shown by any peace officer included in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be sufficient cause for the peace officer\u8217\'3fs removal as provided by law. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to affect the duties and responsibilities of any county attorney or peace officer with respect to law enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of public safety shall have full access to all records, reports, audits, tax reports and all other documents and papers in the department pertaining to liquor licensees and wine and beer permittees and their business.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f94; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.093;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.93; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 35, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72367}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.653}}}{{\f5\fs12\hyphpar0\qj{, 331.756(24)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.15}}}{\*\bkmkstart stylerid1_2E5_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Favors from licensee or permittee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person responsible for the administration or enforcement of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not accept or solicit donations, gratuities, political advertising, gifts, or other favors, directly or indirectly, from any retail alcohol licensee, wine permittee, or beer permittee.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f27; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.027;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.27; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.18}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a722, 88}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.16}}}{\*\bkmkstart stylerid1_2E5_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall cause to be prepared an annual report to the governor of the state, ending with June 30 of each fiscal year, on the operation and financial position of the department under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ for the preceding fiscal year. The report shall include but is not limited to the following information:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amount of profit or loss from department operations under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The current balance of the beer and liquor control fund, and the amount transferred from the fund to the treasurer of state during the period covered by the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All other funds on hand and the source from which derived.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total quantity and particular kind of alcoholic liquor sold.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The increase or decrease of liquor sales from the previous reporting period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of retail alcohol licenses, wine permits, and beer permits issued, by class, the number in effect on the last day included in the report, and the number which have been suspended or revoked during the period covered by the report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amount of fees paid to the department from retail alcohol licenses, wine permits, and beer permits, in gross, and the amount of retail alcohol license fees returned to local subdivisions of government as provided under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f53; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.053;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.53; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.55}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7748}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a723, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72368, 2369}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.17}}}{\*\bkmkstart stylerid1_2E5_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Beer and liquor control fund }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ allocations to substance use disorder programs }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ use of civil penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There shall be established within the office of the treasurer of state a fund to be known as the beer and liquor control fund. The fund shall consist of any moneys appropriated by the general assembly for deposit in the fund and moneys received from the sale of alcoholic liquors by the department, from the issuance of permits and licenses, and of moneys and receipts received by the department from any other source under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of administrative services shall periodically transfer from the beer and liquor control fund to the general fund of the state those revenues of the department which are not necessary for the purchase of liquor for resale by the department, or for remittances to local authorities or other sources as required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or for other obligations and expenses of the department which are paid from such fund.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All moneys received by the department from the issuance of vintner\u8217\'3fs certificates of compliance and wine permits shall be transferred by the director of the department of administrative services to the general fund of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if gaming revenues under }}}{{\f5\fs18\hyphpar0\qj{sections 99D.17}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{99F.11}}}{{\f5\fs18\hyphpar0\qj{ are insufficient in a fiscal year to meet the total amount of such revenues directed to be deposited in the revenue bonds debt service fund and the revenue bonds federal subsidy holdback fund during the fiscal year pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 8.57, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the difference shall be paid from moneys deposited in the beer and liquor control fund prior to transfer of such moneys to the general fund pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ and prior to the transfer of such moneys pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsections 5 and 6}}}{{\f5\fs18\hyphpar0\qj{. If moneys deposited in the beer and liquor control fund are insufficient during the fiscal year to pay the difference, the remaining difference shall be paid from moneys deposited in the beer and liquor control fund in subsequent fiscal years as such moneys become available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer of state shall, each quarter, prepare an estimate of the gaming revenues and of the moneys to be deposited in the beer and liquor control fund that will become available during the remainder of the appropriate fiscal year for the purposes described in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The department of management, the department of inspections, appeals, and licensing, and the department shall take appropriate actions to provide that the sum of the amount of gaming revenues available to be deposited into the revenue bonds debt service fund and the revenue bonds federal subsidy holdback fund during a fiscal year and the amount of moneys to be deposited in the beer and liquor control fund available to be deposited into the revenue bonds debt service fund and the revenue bonds federal subsidy holdback fund during such fiscal year will be sufficient to cover any anticipated deficiencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After any transfer provided for in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ is made, the department shall transfer into a special revenue account in the general fund of the state, a sum of money at least equal to seven percent of the gross amount of sales made by the department from the beer and liquor control fund on a monthly basis but not less than nine million dollars annually. Of the amounts transferred, one million dollars shall be transferred to the behavioral health fund established under }}}{{\f5\fs18\hyphpar0\qj{section 225A.7}}}{{\f5\fs18\hyphpar0\qj{. Any amounts received in excess of the amounts transferred to the behavioral health fund shall be considered part of the general fund balance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After any transfers provided for in }}}{{\f5\fs18\hyphpar0\qj{subsections 3 and 5}}}{{\f5\fs18\hyphpar0\qj{, the department shall receive a transfer from the beer and liquor control fund and before any other transfer to the general fund, an amount sufficient to pay the costs incurred by the department for collecting and properly disposing of the liquor containers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After any transfers provided for in }}}{{\f5\fs18\hyphpar0\qj{subsections 3, 5, and 6}}}{{\f5\fs18\hyphpar0\qj{, and before any other transfer to the general fund, the department shall transfer to the economic development authority from the beer and liquor control fund two million dollars annually for statewide tourism marketing services and efforts pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 15.275}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After any transfers provided for in }}}{{\f5\fs18\hyphpar0\qj{subsections 3, 5, 6, and 7}}}{{\f5\fs18\hyphpar0\qj{ are made, and before any other transfer to the general fund, the department shall transfer to the economic development authority from the beer and liquor control fund the lesser of two hundred fifty thousand dollars or one percent of the gross sales of native distilled spirits by all class \u8220\'3fA\u8221\'3f native distilled spirits license holders made by the department for the purposes of promoting Iowa wine, beer, and spirits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Civil penalties imposed and collected by the department under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be credited to the general fund of the state. The moneys from the civil penalties shall be used by the department, subject to appropriation by the general assembly, for the purposes of providing educational programs, information and publications for alcoholic beverage licensees and permittees, local authorities, and law enforcement agencies regarding the laws and rules which govern the alcoholic beverages industry, and for promoting compliance with alcoholic beverage laws and rules.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f50; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.050;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.50; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.53}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a745 \u8211\'3f 47}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7603, 747}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1151, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1250, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1242, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 199, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 179, \'a7144, 146}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 126, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 173, \'a731, 32, 36}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1184, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a7136}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 171, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1140, \'a730, 32}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1148, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71358, 1874, 2370}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 116, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a714 \u8211\'3f 16, 137, 185, 186}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7135}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 169, \'a735 \u8211\'3f 37}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.57}}}{{\f5\fs12\hyphpar0\qj{, 15.275}}}{{\f5\fs12\hyphpar0\qj{, 15E.117}}}{{\f5\fs12\hyphpar0\qj{, 24.14}}}{{\f5\fs12\hyphpar0\qj{, 123.24}}}{{\f5\fs12\hyphpar0\qj{, 123.39}}}{{\f5\fs12\hyphpar0\qj{, 123.183}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendments to section by }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1161, \'a714 \u8211\'3f 16}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{, effective July 1, 2025; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1161, \'a7137}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 8 stricken}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Former subsection 9 amended and renumbered as 8}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Former subsection 10 renumbered as 9}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.18}}}{\*\bkmkstart stylerid1_2E5_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appropriations.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Department appropriations for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by the treasurer of state upon the orders of the director, in such amounts and at such times as the director deems necessary to carry on operations in accordance with the terms of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f52; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.052;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.52; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.54}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a7204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72371}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{123.19 through 123.21}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.22}}}{\*\bkmkstart stylerid1_2E5_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State monopoly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department has the exclusive right of importation into the state of all forms of alcoholic liquor, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and a person shall not import alcoholic liquor, except that an individual of legal age may import and have in the individual\u8217\'3fs possession an amount of alcoholic liquor not exceeding nine liters per calendar month that the individual personally obtained outside the state. Alcoholic liquor imported by an individual pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be for personal consumption only in a private home or other private accommodation. A distillery shall not sell alcoholic liquor within the state to any person but only to the department, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ vests in the department exclusive control within the state as purchaser of all alcoholic liquor sold by distilleries within the state or imported, except beer and wine, and except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The department shall receive alcoholic liquor on a bailment system for resale by the department in the manner set forth in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The department shall act as the sole wholesaler of alcoholic liquor to class \u8220\'3fE\u8221\'3f retail alcohol licensees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, acting individually or through another acting for the person, shall not directly or indirectly, or upon any pretense or by any device, do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Manufacture, sell, exchange, barter, dispense, give in consideration of the purchase of any property or of any services or in evasion of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or keep for sale, or have possession of any alcoholic liquor, except as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Own, keep, or be in any way concerned, engaged, or employed in owning or keeping, any alcoholic liquor with intent to violate any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or authorize or permit the same to be done.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Manufacture, own, sell, or have possession of any manufactured or compounded article, mixture or substance, not in a liquid form, and containing alcohol which may be converted into a beverage by a process of pressing or straining the alcohol therefrom, or any instrument intended for use and capable of being used in the manufacture of alcoholic liquor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Own or have possession of any material used exclusively in the manufacture of alcoholic liquor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Use or have possession of any material with intent to use it in the manufacture of alcoholic liquors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, alcohol may be manufactured for industrial and nonbeverage purposes by persons who have qualified for that purpose as provided by the laws of the United States and the laws of this state. Such alcohol, so manufactured, may be denatured, transported, used, possessed, sold, and bartered and dispensed, subject to the limitations, prohibitions and restrictions imposed by the laws of the United States and this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person may manufacture, sell, or transport ingredients and devices other than alcohol for the making of homemade wine or beer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7924 \u8211\'3f 928; R60, \'a71559, 1563, 1583, 1587; C73, \'a71523, 1540 \u8211\'3f 1542, 1555; C97, \'a72382; SS15, \'a72382; C24, 27, 31, \'a71924; C35, \'a71921-f54, 1924; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.054, 1924;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.54, 125.3; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.22}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7733}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 161, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1096, \'a72, 6}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a724, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72372}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.10}}}{{\f5\fs12\hyphpar0\qj{, 123.26}}}{{\f5\fs12\hyphpar0\qj{, 123.28}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.23}}}{\*\bkmkstart stylerid1_2E5_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Distiller\u8217\'3fs certificate of compliance \u8212\'3f injunction \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any manufacturer, distiller, or importer of alcoholic liquors shipping, selling, or having alcoholic liquors brought into this state for resale by the state shall, as a condition precedent to the privilege of so trafficking in alcoholic liquors in this state, annually make application for and hold a distiller\u8217\'3fs certificate of compliance which shall be issued by the director for that purpose. No brand of alcoholic liquor shall be sold by the department in this state unless the manufacturer, distiller, importer, and all other persons participating in the distribution of that brand in this state have obtained a certificate. The certificate of compliance shall expire at the end of one year from the date of issuance and shall be renewed for a like period upon application to the director unless otherwise suspended or revoked for cause. Each completed application for a certificate of compliance or renewal shall be submitted electronically, or in a manner prescribed by the director, and shall be accompanied by a fee of two hundred dollars payable to the department. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ need not apply to a manufacturer, distiller, or importer who ships or sells in this state no more than eleven gallons or its case equivalent during any fiscal year as a result of \u8220\'3fspecial orders\u8221\'3f which might be placed, as defined and allowed by departmental rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of applying for a certificate of compliance, each applicant shall submit to the department electronically, or in a manner prescribed by the director, the name and address of its authorized agent for service of process which shall remain effective until changed for another, and a list of names and addresses of all representatives, employees, or attorneys whom the applicant has appointed in the state of Iowa to represent it for any purpose. The listing shall be amended by the certificate holder as necessary to keep the listing current with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director and the attorney general are authorized to require any certificate holder or person listed as the certificate holder\u8217\'3fs representative, employee, or attorney to disclose such financial and other records and transactions as may be considered relevant in discovering violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or of rules and regulations of the department under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or of any other provision of law by any person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall subject the holder of a distiller\u8217\'3fs certificate of compliance to the general penalties provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall constitute grounds for imposition of a civil penalty, suspension of the certificate, or revocation of the certificate, after notice and opportunity for a hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. However, willful failure to comply with requirements which may be imposed under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ is grounds for suspension or revocation of the certificate of compliance only.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not require the listing of those persons who are employed on premises where alcoholic liquors are manufactured, processed, bottled, or packaged in Iowa or persons who are thereafter engaged in the transporting of such alcoholic liquors to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general may also proceed pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 714.16}}}{{\f5\fs18\hyphpar0\qj{ in order to gain compliance with }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and may obtain an injunction prohibiting any further violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or other provisions of law. Any violation of that injunction shall be punished as contempt of court pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 665}}}{{\f5\fs18\hyphpar0\qj{ except that the maximum fine that may be imposed shall not exceed fifty thousand dollars.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1237, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7204}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2016, \'a7123.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 119, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a77, 15}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72373}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}{{\f5\fs12\hyphpar0\qj{, 123.35}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.24}}}{\*\bkmkstart stylerid1_2E5_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alcoholic liquor sales by the department }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ dishonored payments }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ liquor prices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall sell alcoholic liquor at wholesale only. The department shall sell alcoholic liquor to class \u8220\'3fE\u8221\'3f retail alcohol licensees only. The department shall offer the same price on alcoholic liquor to all class \u8220\'3fE\u8221\'3f retail alcohol licensees without regard for the quantity of purchase or the distance for delivery. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The price of alcoholic liquor sold by the department shall consist of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufacturer\u8217\'3fs price.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A markup of up to fifty percent of the wholesale price paid by the department for the alcoholic liquor. The department may increase the markup on selected kinds of alcoholic liquor sold by the department if the average return to the department on all sales of alcoholic liquor does not exceed the wholesale price paid by the department and the fifty percent markup.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A split case charge in an amount determined by the department when alcoholic liquor is sold in quantities which require a case to be split.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A bottle surcharge in an amount sufficient, when added to the amount not refunded to class \u8220\'3fE\u8221\'3f retail alcohol licensees pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455C.2}}}{{\f5\fs18\hyphpar0\qj{, to pay the costs incurred by the department for collecting and properly disposing of the liquor containers. The amount collected pursuant to this paragraph, in addition to any amounts not refunded to class \u8220\'3fE\u8221\'3f retail alcohol licensees pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455C.2}}}{{\f5\fs18\hyphpar0\qj{, shall be deposited in the beer and liquor control fund established under }}}{{\f5\fs18\hyphpar0\qj{section 123.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may accept from a class \u8220\'3fE\u8221\'3f retail alcohol licensee electronic funds transferred by automated clearing house, wire transfer, or another method deemed acceptable by the director, in payment of alcoholic liquor. If a payment is subsequently dishonored, the department shall cause a notice of nonpayment and penalty to be served upon the class \u8220\'3fE\u8221\'3f retail alcohol licensee or upon any person in charge of the licensed premises. The notice shall state that if payment or satisfaction for the dishonored payment is not made within ten days of the service of notice, the licensee\u8217\'3fs retail alcohol license may be suspended under }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{. The notice of nonpayment and penalty shall be in a form prescribed by the director, and shall be sent by certified mail.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If upon notice and hearing under }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ and pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ concerning a contested case hearing, the director determines that the class \u8220\'3fE\u8221\'3f retail alcohol licensee failed to satisfy the obligation for which the payment was issued within ten days after the notice of nonpayment and penalty was served on the licensee as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the director may suspend the licensee\u8217\'3fs class \u8220\'3fE\u8221\'3f retail alcohol license for a period not to exceed ten days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may refuse to sell alcoholic liquor to a class \u8220\'3fE\u8221\'3f retail alcohol licensee who tenders a payment which is subsequently dishonored until the outstanding obligation is satisfied.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f20, 1921-f41; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.020, 1921.041;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.20, 123.41; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.24}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 56, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1246, \'a7734}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 22, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1158, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1242, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a76 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a725, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72374}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.176}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.25}}}{\*\bkmkstart stylerid1_2E5_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consumption on premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An officer, clerk, agent, or employee of the department employed in a state-owned warehouse under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not allow any alcoholic beverage to be consumed on the premises, nor shall a person consume any alcoholic liquor on the premises except for testing or sampling purposes only.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f23; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.023;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.23; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.25}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1122, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7735}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72375}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.26}}}{\*\bkmkstart stylerid1_2E5_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restrictions on sales }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ seals }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ labeling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Alcoholic liquor shall not be sold by a class \u8220\'3fE\u8221\'3f retail alcohol licensee except in a sealed container with identifying markers as prescribed by the director and affixed in the manner prescribed by the director, and no such container shall be opened upon the premises of a state warehouse. The department shall cooperate with the department of natural resources so that only one identifying marker or mark is needed to satisfy the requirements of }{{\f5\fs18\hyphpar0\qj{this section}}}{ and }{{\f5\fs18\hyphpar0\qj{section 455C.5, subsection 1}}}{. Possession of alcoholic liquors which do not carry the prescribed identifying markers is a violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ except as provided in }{{\f5\fs18\hyphpar0\qj{section 123.22}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f24; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.024;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.24; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.26}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1246, \'a7736}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 22, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a726, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72376}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.28}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.27}}}{\*\bkmkstart stylerid1_2E5_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sales and deliveries prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is unlawful to transact the sale or delivery of alcoholic liquor in, on, or from the premises of a state warehouse:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the closing hour as established by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On any legal holiday except those designated by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During other periods or days as designated by the director.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f25; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.025;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.25; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.27}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 6, \'a711}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1122, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7737}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 161, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72377}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.28}}}{\*\bkmkstart stylerid1_2E5_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restrictions on transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is lawful to transport, carry, or convey alcoholic liquors from the place of purchase by the department to a state warehouse or depot established by the department or from one such place to another and, when so permitted by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, it is lawful for the department, a common carrier, or other person to transport, carry, or convey alcoholic liquor sold from a state warehouse, depot, or point of purchase by the state to any place to which the liquor may be lawfully delivered under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall deliver alcoholic liquor purchased by class \u8220\'3fE\u8221\'3f retail alcohol licensees. Class \u8220\'3fE\u8221\'3f retail alcohol licensees may deliver alcoholic liquor purchased by class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, or class \u8220\'3fF\u8221\'3f retail alcohol licensees, and class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, or class \u8220\'3fF\u8221\'3f retail alcohol licensees may transport alcoholic liquor purchased from class \u8220\'3fE\u8221\'3f retail alcohol licensees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A common carrier or other person shall not break or open or allow to be broken or opened a container or package containing alcoholic liquor or use or drink or allow to be used or drunk any alcoholic liquor while it is being transported or conveyed. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a private person from transporting individual bottles or containers of alcoholic liquor exempted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.22}}}{{\f5\fs18\hyphpar0\qj{ and individual bottles or containers bearing the identifying mark prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 123.26}}}{{\f5\fs18\hyphpar0\qj{ which have been opened previous to the commencement of the transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not affect the right of a retail alcohol license holder to purchase, possess, or transport alcoholic liquors subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f26; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.026;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.26; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.28}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 6, \'a712}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1275, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 196, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1020, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7738}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 170, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a727, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72378}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Open containers in motor vehicles, see }{{\f5\fs12\hyphpar0\qj{\'a7321.284}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.29}}}{\*\bkmkstart stylerid1_2E5_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Patent and proprietary products and sacramental wine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit the sale of patent and proprietary medicines, tinctures, food products, extracts, toiletries, perfumes, and similar products, which are not susceptible of use as a beverage, but which contain alcoholic liquor, wine, or beer as one of their ingredients. These products may be sold through ordinary wholesale and retail businesses without a license or permit issued by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a member of the clergy of any religious denomination which uses vinous liquor in its sacramental ceremonies from purchasing, receiving, possessing, and using vinous liquor for sacramental purposes.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72171; C35, \'a71921-f27, 2171; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.027, 2171;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.27, 134.1; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.29}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1246, \'a7739, 740}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 161, \'a74 \u8211\'3f 6}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 91, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72379}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.30}}}{\*\bkmkstart stylerid1_2E5_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Retail alcohol licenses }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ classes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retail alcohol license may be issued to any person who is of good moral character as defined by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the state of Iowa, or any state agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 669.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As a condition for issuance of a retail alcohol license or wine or beer permit, the applicant must give consent to members of the fire, police, and health departments and the building inspector of cities; the county sheriff or deputy sheriff; members of the department of public safety; representatives of the department and of the department of inspections, appeals, and licensing; certified police officers; and any official county health officer to enter upon areas of the premises where alcoholic beverages are stored, served, or sold, without a warrant during business hours of the licensee or permittee to inspect for violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or ordinances and regulations that cities and boards of supervisors may adopt. However, a subpoena issued under }}}{{\f5\fs18\hyphpar0\qj{section 421.17}}}{{\f5\fs18\hyphpar0\qj{ or a warrant is required for inspection of private records, a private business office, or attached living quarters. Persons who are not certified peace officers shall limit the scope of their inspections of licensed premises to the regulatory authority under which the inspection is conducted. All persons who enter upon a licensed premises to conduct an inspection shall present appropriate identification to the owner of the establishment or the person who appears to be in charge of the establishment prior to commencing an inspection; however, this provision does not apply to undercover criminal investigations conducted by peace officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As a further condition for the issuance of a class \u8220\'3fE\u8221\'3f retail alcohol license, the applicant shall post a bond in a sum of not less than five thousand nor more than fifteen thousand dollars as determined on a sliding scale established by the department; however, a bond shall not be required if all purchases of alcoholic liquor from the department by the licensee are made by means that ensure that the department will receive full payment in advance of delivery of the alcoholic liquor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fE\u8221\'3f retail alcohol license may be issued to a city council for premises located within the limits of the city if there are no class \u8220\'3fE\u8221\'3f retail alcohol licensees operating within the limits of the city and no other applications for a class \u8220\'3fE\u8221\'3f license for premises located within the limits of the city at the time the city council\u8217\'3fs application is filed. If a class \u8220\'3fE\u8221\'3f retail alcohol license is subsequently issued to a private person for premises located within the limits of the city, the city council shall surrender its license to the department within one year of the date that the class \u8220\'3fE\u8221\'3f retail alcohol licensee begins operating, liquidate any remaining assets connected with the liquor store, and cease operating the liquor store.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retail alcohol license shall not be issued for premises which do not constitute a safe and proper place or building and which do not conform to all applicable laws, ordinances, resolutions, and health and fire regulations. A licensee shall not have or maintain any interior access to residential or sleeping quarters unless permission is granted by the director in the form of a living quarters permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Retail alcohol licenses issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be of the following classes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class \u8220\'3fB\u8221\'3f.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fB\u8221\'3f retail alcohol license may be issued and shall authorize the holder to purchase wine from a class \u8220\'3fA\u8221\'3f wine permittee only and beer from a class \u8220\'3fA\u8221\'3f beer permittee only, and to sell wine and beer in original unopened containers at retail to patrons for consumption off the licensed premises.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fB\u8221\'3f retail alcohol license may sell wine to class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, and class \u8220\'3fF\u8221\'3f retail alcohol licensees for resale for consumption on the premises. Such wine sales shall be in quantities of less than one case of any wine brand but not more than one such sale shall be made to the same retail alcohol licensee in a twenty-four-hour period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fB\u8221\'3f retail alcohol license may sell beer to class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, and class \u8220\'3fF\u8221\'3f retail alcohol licensees, and to special class \u8220\'3fC\u8221\'3f retail native wine licensees, for resale for consumption on the premises. Such beer sales shall be in quantities of not more than five cases of beer, high alcoholic content beer, and canned cocktails, but not more than one such sale shall be made to the same retail alcohol licensee in a twenty-four-hour period. A class \u8220\'3fA\u8221\'3f beer permittee shall be held harmless concerning any beer resold as authorized by this subparagraph division.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special class \u8220\'3fB\u8221\'3f retail native wine license shall authorize the holder to purchase wine from a native winery holding a class \u8220\'3fA\u8221\'3f wine permit and to sell native wine only at retail for consumption off the licensed premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class \u8220\'3fC\u8221\'3f.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fC\u8221\'3f retail alcohol license may be issued to a commercial establishment but must be issued in the name of the individuals who actually own the entire business.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fC\u8221\'3f retail alcohol license shall be authorized to purchase alcoholic beverages as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alcoholic liquors in original unopened containers from class \u8220\'3fE\u8221\'3f retail alcohol licensees only.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wine from class \u8220\'3fA\u8221\'3f wine permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wine from class \u8220\'3fB\u8221\'3f retail alcohol licensees or class \u8220\'3fE\u8221\'3f retail alcohol licensees in quantities of less than one case of any wine brand in a twenty-four-hour period, but not more than one such purchase shall be made by the licensee in a twenty-four-hour period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beer from class \u8220\'3fA\u8221\'3f beer permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(v)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beer from class \u8220\'3fB\u8221\'3f retail alcohol licensees or class \u8220\'3fE\u8221\'3f retail alcohol licensees in quantities of not more than five cases of beer, high alcoholic content beer, and canned cocktails, but not more than one such purchase shall be made by the licensee in a twenty-four-hour period. A class \u8220\'3fA\u8221\'3f beer permittee shall be held harmless concerning any beer resold as authorized by this subparagraph subdivision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fC\u8221\'3f retail alcohol license shall be authorized to sell alcoholic beverages to patrons by the individual drink for consumption on the premises only. However, alcoholic liquor, wine, and beer in original unopened containers may also be sold for consumption off the premises. In addition, mixed drinks or cocktails may also be sold for consumption off the premises subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fC\u8221\'3f retail alcohol license may also hold a special class \u8220\'3fA\u8221\'3f beer permit for the premises licensed under a class \u8220\'3fC\u8221\'3f retail alcohol license for the purpose of operating a brewpub pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special class \u8220\'3fC\u8221\'3f retail alcohol license may be issued to a commercial establishment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a special class \u8220\'3fC\u8221\'3f retail alcohol license shall be authorized to purchase alcoholic beverages as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wine from class \u8220\'3fA\u8221\'3f wine permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wine from class \u8220\'3fB\u8221\'3f retail alcohol licensees or class \u8220\'3fE\u8221\'3f retail alcohol licensees in quantities of less than one case of any wine brand in a twenty-four-hour period, but not more than one such purchase shall be made by the licensee in a twenty-four-hour period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beer from class \u8220\'3fA\u8221\'3f beer permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beer from class \u8220\'3fB\u8221\'3f retail alcohol licensees or class \u8220\'3fE\u8221\'3f retail alcohol licensees in quantities of not more than five cases of beer, high alcoholic content beer, and canned cocktails, but not more than one such purchase shall be made by the licensee in a twenty-four-hour period. A class \u8220\'3fA\u8221\'3f beer permittee shall be held harmless concerning any beer resold as authorized by this subparagraph subdivision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a special class \u8220\'3fC\u8221\'3f retail alcohol license shall be authorized to sell wine and beer to patrons by the individual drink for consumption on the premises only. However, wine and beer in original unopened containers may also be sold for consumption off the premises. In addition, a mixed drink or cocktail that does not contain alcoholic liquor may be sold for consumption off the premises subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a special class \u8220\'3fC\u8221\'3f retail alcohol license may also hold a special class \u8220\'3fA\u8221\'3f beer permit for the premises licensed under a special class \u8220\'3fC\u8221\'3f retail alcohol license for the purpose of operating a brewpub pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The license issued to holders of a special class \u8220\'3fC\u8221\'3f retail alcohol license shall clearly state on its face that the license is limited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special class \u8220\'3fC\u8221\'3f retail native wine license shall authorize the holder to sell beer and native wine as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.31C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class \u8220\'3fD\u8221\'3f.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fD\u8221\'3f retail alcohol license may be issued to a railway corporation, to an air common carrier, and to passenger-carrying boats or ships for hire with a capacity of twenty-five persons or more operating in inland or boundary waters, and shall authorize the holder to sell or furnish alcoholic beverages to passengers for consumption only on trains, watercraft as described in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or aircraft, respectively. Each license is valid throughout the state. Only one license is required for all trains, watercraft, or aircraft operated in the state by the licensee. However, if a watercraft is an excursion gambling boat licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{, the owner shall obtain a separate class \u8220\'3fD\u8221\'3f retail alcohol license for each excursion gambling boat operating in the waters of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fD\u8221\'3f retail alcohol licensee who operates a train or a watercraft intrastate only, or an excursion gambling boat licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{, shall be authorized to purchase alcoholic beverages as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alcoholic liquors in original unopened containers from class \u8220\'3fE\u8221\'3f retail alcohol licensees only.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wine from class \u8220\'3fA\u8221\'3f wine permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wine from class \u8220\'3fB\u8221\'3f retail alcohol licensees or class \u8220\'3fE\u8221\'3f retail alcohol licensees in quantities of less than one case of any wine brand in a twenty-four-hour period, but not more than one such purchase shall be made by the licensee in a twenty-four-hour period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beer from class \u8220\'3fA\u8221\'3f beer permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beer from class \u8220\'3fB\u8221\'3f retail alcohol licensees or class \u8220\'3fE\u8221\'3f retail alcohol licensees in quantities of not more than five cases of beer, high alcoholic content beer, and canned cocktails, but not more than one such purchase shall be made by the licensee in a twenty-four-hour period. A class \u8220\'3fA\u8221\'3f beer permittee shall be held harmless concerning any beer resold as authorized by this subparagraph division.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class \u8220\'3fE\u8221\'3f.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fE\u8221\'3f retail alcohol license may be issued and shall authorize the holder to purchase alcoholic liquor in original unopened containers from the department only, wine from a class \u8220\'3fA\u8221\'3f wine permittee only, and beer from a class \u8220\'3fA\u8221\'3f beer permittee only; to sell alcoholic liquor, wine, and beer in original unopened containers at retail to patrons for consumption off the licensed premises; and to sell alcoholic liquor and high alcoholic content beer at wholesale to other retail alcohol licensees, provided the holder has filed with the department a basic permit issued by the alcohol and tobacco tax and trade bureau of the United States department of the treasury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A holder of a class \u8220\'3fE\u8221\'3f retail alcohol license may hold other retail alcohol licenses, but the premises licensed under a class \u8220\'3fE\u8221\'3f retail alcohol license shall be separate from other licensed premises, though the separate premises may have a common entrance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fE\u8221\'3f retail alcohol license may sell wine to class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, and class \u8220\'3fF\u8221\'3f retail alcohol licensees for resale for consumption on the premises. Such wine sales shall be in quantities of less than one case of any wine brand but not more than one such sale shall be made to the same retail alcohol licensee in a twenty-four-hour period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fE\u8221\'3f retail alcohol license may sell beer to class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, and class \u8220\'3fF\u8221\'3f retail alcohol licensees, and to special class \u8220\'3fC\u8221\'3f retail native wine licensees, for resale for consumption on the premises. Such beer sales shall be in quantities of not more than five cases of beer, high alcoholic content beer, and canned cocktails, but not more than one such sale shall be made to the same retail alcohol licensee in a twenty-four-hour period. A class \u8220\'3fA\u8221\'3f beer permittee shall be held harmless concerning any beer resold as authorized by this subparagraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may issue a class \u8220\'3fE\u8221\'3f retail alcohol license for premises covered by a retail alcohol license for on-premises consumption under any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the premises are in a county having a population under nine thousand five hundred in which no other class \u8220\'3fE\u8221\'3f retail alcohol license has been issued by the department, and no other application for a class \u8220\'3fE\u8221\'3f retail alcohol license has been made within the previous twelve consecutive months.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the premises covered by a retail alcohol license is a grocery store that is at least five thousand square feet.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class \u8220\'3fF\u8221\'3f.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fF\u8221\'3f retail alcohol license may be issued to a club and shall authorize the holder to sell alcoholic beverages to bona fide members and their guests by the individual drink for consumption on the premises only.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fF\u8221\'3f retail alcohol license shall be authorized to purchase alcoholic beverages as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alcoholic liquors in original unopened containers from class \u8220\'3fE\u8221\'3f retail alcohol licensees only.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wine from class \u8220\'3fA\u8221\'3f wine permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wine from class \u8220\'3fB\u8221\'3f retail alcohol licensees or class \u8220\'3fE\u8221\'3f retail alcohol licensees in quantities of less than one case of any wine brand in a twenty-four-hour period, but not more than one such purchase shall be made by the licensee in a twenty-four-hour period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beer from class \u8220\'3fA\u8221\'3f beer permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beer from class \u8220\'3fB\u8221\'3f retail alcohol licensees or class \u8220\'3fE\u8221\'3f retail alcohol licensees in quantities of not more than five cases of beer, high alcoholic content beer, and canned cocktails, but not more than one such purchase shall be made by the licensee in a twenty-four-hour period. A class \u8220\'3fA\u8221\'3f beer permittee shall be held harmless concerning any beer resold as authorized by this subparagraph division.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, a person holding a retail alcohol license to sell alcoholic beverages for consumption on the licensed premises may permit a customer to remove one unsealed bottle of wine for consumption off the premises if the customer has purchased and consumed a portion of the bottle of wine on the licensed premises. The licensee or the licensee\u8217\'3fs agent shall securely reseal such bottle in a bag designed so that it is visibly apparent that the resealed bottle of wine has not been tampered with and provide a dated receipt for the resealed bottle of wine to the customer. A wine bottle resealed pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 321.284}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.284A}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, a person holding a retail alcohol license to sell alcoholic beverages for consumption on the licensed premises may permit a customer to carry an alcoholic beverage in an open container from the licensed premises to any of the following immediately adjacent locations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensed premises authorized to sell the same type of alcoholic beverage for consumption on the licensed premises.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A temporarily closed public right-of-way.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A private place.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee of the immediately adjacent licensed premises, or owner of the immediately adjacent private place, may refuse to allow the customer to enter the licensed premises or private place with an alcoholic beverage in an open container.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f27; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.027;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.27; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.30}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7741, 742}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 22, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1088, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1175, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 203, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 74, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a7111, 140}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 17, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1008, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a738, 39}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a75, 19, 40}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a754 \u8211\'3f 60}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a711 \u8211\'3f 13}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1114, \'a710, 11, 16}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 155, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a71, 6}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71875, 2380, 2381}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 48, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 157, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 31, \'a72 \u8211\'3f 5, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712.43}}}{{\f5\fs12\hyphpar0\qj{, 123.31}}}{{\f5\fs12\hyphpar0\qj{, 123.33}}}{{\f5\fs12\hyphpar0\qj{, 123.36}}}{{\f5\fs12\hyphpar0\qj{, 123.43}}}{{\f5\fs12\hyphpar0\qj{, 123.43A}}}{{\f5\fs12\hyphpar0\qj{, 123.45}}}{{\f5\fs12\hyphpar0\qj{, 123.95}}}{{\f5\fs12\hyphpar0\qj{, 123.127}}}{{\f5\fs12\hyphpar0\qj{, 123.138}}}{{\f5\fs12\hyphpar0\qj{, 123.173C}}}{{\f5\fs12\hyphpar0\qj{, 123.175}}}{{\f5\fs12\hyphpar0\qj{, 123.176}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph a amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph a, subparagraph (1), subparagraph division (c) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph b, subparagraph (2), subparagraph division (c) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph d, subparagraph (4) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 5}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.31}}}{\*\bkmkstart stylerid1_2E5_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Retail alcohol licenses }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person applying for a retail alcohol license shall submit a completed application electronically, or in a manner prescribed by the director, which shall set forth under oath the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and place of residence of the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names and addresses of all persons or, in the case of a corporation, limited liability company, or any other similar legal entity, the officers, directors, and persons owning or controlling ten percent or more of the capital stock thereof, having a financial interest, by way of loan, ownership, or otherwise, in the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location of the premises where the applicant intends to operate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the owner of the premises and if the owner of the premises is not the applicant, whether the applicant is the actual lessee of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When required by the director, and in such form and containing such information as the director may require, a description of the premises where the applicant intends to use the license, to include a sketch or drawing of the premises and, if applicable, the number of square feet of interior floor space which comprises the retail sales area of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether any person specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ has ever been convicted of any offense against the laws of the United States, or any state or territory thereof, or any political subdivision of any such state or territory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information as required by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The retail alcohol license shall only be issued to an applicant who establishes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant has submitted a completed application as required by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant is a person of good moral character as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.3, subsection 40}}}{{\f5\fs18\hyphpar0\qj{. This paragraph does not apply if the applicant is the state of Iowa or a state agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 669.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant is a citizen of the state of Iowa or, if a corporation, that the applicant is authorized to do business in the state. This paragraph does not apply if the applicant is the state of Iowa or a state agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 669.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the premises where the applicant intends to use the license conforms to all applicable laws, health regulations, and fire regulations, and constitutes a safe and proper place or building and that the applicant shall not have or maintain any interior access to residential or sleeping quarters unless permission is granted by the director in the form of a living quarters permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant gives consent to a person, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.30, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, to enter upon the premises without a warrant during the business hours of the applicant to inspect for violations of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or ordinances and regulations that local authorities may adopt.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f27; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.027;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.27; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.31}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 91, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1201, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 17, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a72, 6}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72382 \u8211\'3f 2384}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 31, \'a76, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}{{\f5\fs12\hyphpar0\qj{, 123.35}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraphs b and c amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.31A}}}{\*\bkmkstart stylerid1_2E5_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under class \u8220\'3fB\u8221\'3f, class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, and class \u8220\'3fE\u8221\'3f retail alcohol license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fB\u8221\'3f, class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, or class \u8220\'3fE\u8221\'3f retail alcohol license shall be allowed to sell beer and wine to consumers at retail for consumption off the premises. The sales made pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be made in original containers except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every person holding a class \u8220\'3fB\u8221\'3f, class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, or class \u8220\'3fE\u8221\'3f retail alcohol license having more than one place of business where beer and wine is sold which places do not constitute a single premises within the meaning of }}}{{\f5\fs18\hyphpar0\qj{section 123.3, subsection 29}}}{{\f5\fs18\hyphpar0\qj{, shall be required to have a separate license for each separate place of business, except as otherwise provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the rules of the department, sales made pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be made in a container other than the original container only if all of the following requirements are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The beer or wine is transferred from the original container to the container to be sold on the licensed premises at the time of sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person transferring the beer or wine from the original container to the container to be sold shall be eighteen years of age or older.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The container to be sold shall be no larger than seventy-two ounces.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The container to be sold shall be securely sealed by a method authorized by the department that is designed so that if the sealed container is reopened or the seal tampered with, it is visibly apparent that the seal on the container of beer or wine has been tampered with or the sealed container has otherwise been reopened.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A container of beer or wine other than the original container that is sold and sealed in compliance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ and the department\u8217\'3fs rules shall not be deemed an open container subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 321.284}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.284A}}}{{\f5\fs18\hyphpar0\qj{ if the sealed container is unopened and the seal has not been tampered with, and the contents of the container have not been partially removed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a class \u8220\'3fC\u8221\'3f or special class \u8220\'3fC\u8221\'3f retail alcohol license, or the licensee\u8217\'3fs agents or employees, shall not sell beer or wine to other retail alcohol license holders knowing or having reasonable cause to believe that the beer will be resold in another licensed establishment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A holder of any retail alcohol permit shall not sell wine except wine which is purchased from a person holding a class \u8220\'3fA\u8221\'3f wine permit and on which the tax imposed by }}}{{\f5\fs18\hyphpar0\qj{section 123.183}}}{{\f5\fs18\hyphpar0\qj{ has been paid.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a73, 6}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72385 \u8211\'3f 2387}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.31B}}}{\*\bkmkstart stylerid1_2E5_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under special class \u8220\'3fB\u8221\'3f retail native wine license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a special class \u8220\'3fB\u8221\'3f retail native wine license may sell native wine only at retail for consumption off the premises. Native wine shall be sold for consumption off the premises in original containers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special class \u8220\'3fB\u8221\'3f retail native wine licensee having more than one place of business where wine is sold shall obtain a separate license for each place of business.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a74, 6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.31C}}}{\*\bkmkstart stylerid1_2E5_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under special class \u8220\'3fC\u8221\'3f retail native wine license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a special class \u8220\'3fC\u8221\'3f retail native wine license may sell beer and native wine only at retail for consumption on or off the premises. Sales of beer and native wine for consumption off the premises made pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be made in original containers except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{. A sale of a mixed drink or cocktail that does not contain alcoholic liquor may be sold for consumption off the premises subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A special class \u8220\'3fC\u8221\'3f retail native wine licensee having more than one place of business where wine is sold and served shall obtain a separate permit for each place of business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a special class \u8220\'3fC\u8221\'3f retail native wine license may purchase wine for resale only from a native winery holding a class \u8220\'3fA\u8221\'3f wine permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a special class \u8220\'3fC\u8221\'3f retail native wine license may purchase beer as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From class \u8220\'3fA\u8221\'3f beer permittees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From class \u8220\'3fB\u8221\'3f retail alcohol licensees or class \u8220\'3fE\u8221\'3f retail alcohol licensees in quantities of not more than five cases of beer, high alcoholic content beer, and canned cocktails, but not more than one such purchase shall be made by the licensee in a twenty-four-hour period. A class \u8220\'3fA\u8221\'3f beer permittee shall be held harmless concerning any beer resold as authorized by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the rules of the department, sales made pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be made in a container other than the original container only if all of the following requirements are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The beer or native wine is transferred from the original container to the container to be sold on the licensed premises at the time of sale or when sold by telephonic or other electronic means.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person transferring the beer or native wine from the original container to the container to be sold shall be eighteen years of age or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The container to be sold shall be no larger than seventy-two ounces.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The container to be sold shall be securely sealed by a method authorized by the department that is designed so that if the sealed container is reopened or the seal tampered with, it is visibly apparent that the seal on the container of beer or native wine has been tampered with or the sealed container has otherwise been reopened.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A container of beer or native wine other than the original container that is sold and sealed in compliance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ and the rules of the department shall not be deemed an open container subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 321.284}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.284A}}}{{\f5\fs18\hyphpar0\qj{ if the sealed container is unopened and the seal has not been tampered with, and the contents of the container have not been partially removed.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 157, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 31, \'a77, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.30}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.32}}}{\*\bkmkstart stylerid1_2E5_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Action by local authorities and department on applications for retail alcohol licenses, native distilled spirits licenses, and wine and beer permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Filing of application.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A completed application for a retail alcohol license as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.31}}}{{\f5\fs18\hyphpar0\qj{, except a class \u8220\'3fD\u8221\'3f retail alcohol license, shall be filed with the appropriate city council if the premises for which the license is sought are located within the corporate limits of a city, or with the board of supervisors if the premises for which the license is sought are located outside the corporate limits of a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A completed application for a class \u8220\'3fD\u8221\'3f retail alcohol license and for any of the following certificates, licenses, or permits shall be submitted to the department electronically, or in a manner prescribed by the director, which shall proceed in the same manner as in the case of an application approved by local authorities:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate of compliance as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 123.23}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{123.135}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{123.180}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fD\u8221\'3f retail alcohol license as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.31}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer\u8217\'3fs license as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.41}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A broker\u8217\'3fs permit as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.42}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f native distilled spirits license as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.43}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.127}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A charity beer, spirits, and wine special event license as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.173A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f wine permit as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.175}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A wine direct shipper\u8217\'3fs permit as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.187}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A wine carrier permit as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.188}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A wine auction permit as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.173C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Action by local authorities.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local authority shall either approve or disapprove the issuance of a retail alcohol license, shall endorse its approval or disapproval on the application, and shall forward the application with the necessary fee and bond, if required, to the department. There is no limit upon the number of retail alcohol licenses which may be approved for issuance by local authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Licensed premises for local events.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local authority may define, by motion of the local authority, licensed premises which shall be used by holders of retail alcohol licenses at festivals, fairs, or celebrations which are sponsored or authorized by the local authority. The licensed premises defined by motion of the local authority shall be used by the holders of five-day or fourteen-day class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, or class \u8220\'3fF\u8221\'3f retail alcohol licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Security employee training.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local authority, as a condition of obtaining and holding a license for on-premises consumption, may require a designated security employee as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.3}}}{{\f5\fs18\hyphpar0\qj{ to be trained and certified in security methods. The training shall include but is not limited to de-escalation techniques, anger management techniques, civil rights or unfair practices awareness as provided in }}}{{\f5\fs18\hyphpar0\qj{section 216.7}}}{{\f5\fs18\hyphpar0\qj{, recognition of fake or altered identification, information on laws applicable to the serving of alcohol at a licensed premises, use of force and techniques for safely removing patrons, and instruction on the proper physical restraint methods used against a person who has become combative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Occupancy rates.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local authority located in a county with a population that exceeds three hundred thousand persons, as a condition of obtaining and holding a license for on-premises consumption, shall require the applicant or licensee to provide, and update if necessary, the occupancy rate of the licensed premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Action by director.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of an application having been disapproved by the local authority, the director shall notify the applicant that the applicant may appeal the disapproval of the application to the director. The applicant shall be notified by certified mail or personal service, and the application, the fee, and any bond shall be returned to the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of an application having been approved by the local authority, the department shall make an investigation as the director deems necessary to determine that the applicant complies with all requirements for holding a license, and may require the applicant to appear to be examined under oath to demonstrate that the applicant complies with all of the requirements to hold a license. If the director requires the applicant to appear and to testify under oath, a record shall be made of all testimony or evidence and the record shall become a part of the application. The director may appoint a member of the department or may request an administrative law judge of the department of inspections, appeals, and licensing to receive the testimony under oath and evidence, and to issue a proposed decision to approve or disapprove the application for a license. The director may affirm, reverse, or modify the proposed decision to approve or disapprove the application for the license. If the application is approved by the director, the license shall be issued. If the application is disapproved by the director, the applicant shall be so notified by certified mail or personal service and the appropriate local authority shall be notified electronically, or in a manner prescribed by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Appeal to director.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a retail alcohol license may appeal from the local authority\u8217\'3fs disapproval of an application for a license to the director. In the appeal the applicant shall be allowed the opportunity to demonstrate in an evidentiary hearing conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ that the applicant complies with all of the requirements for holding the license. The director may appoint a member of the department or may request an administrative law judge from the department of inspections, appeals, and licensing to conduct the evidentiary hearing and to render a proposed decision to approve or disapprove the issuance of the license. The director may affirm, reverse, or modify the proposed decision. If the director determines that the applicant complies with all of the requirements for holding a license, the director shall order the issuance of the license. If the director determines that the applicant does not comply with the requirements for holding a license, the director shall disapprove the issuance of the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Judicial review.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant or the local authority may seek judicial review of the action of the director in accordance with the terms of the Iowa administrative procedure Act, }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding the terms of the Iowa administrative procedure Act, }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, petitions for judicial review may be filed in the district court of the county where the premises covered by the application are situated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Suspension by local authority.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retail alcohol licensee whose license has been suspended or revoked or a civil penalty imposed by a local authority for a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or suspended by a local authority for violation of a local ordinance may appeal the suspension, revocation, or civil penalty to the director. The director may appoint a member of the department or may request an administrative law judge from the department of inspections, appeals, and licensing to hear the appeal which shall be conducted in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ and to issue a proposed decision. The director may review the proposed decision upon the motion of a party to the appeal or upon the director\u8217\'3fs own motion in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. Upon review of the proposed decision, the director may affirm, reverse, or modify the proposed decision. A retail alcohol licensee or a local authority aggrieved by a decision of the director may seek judicial review of the decision pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f27; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.027;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.27; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.32}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7743}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1088, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 161, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1177, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a710 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1201, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 143, \'a73, 17}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 13, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1166, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 137, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1008, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a77, 41}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1114, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a728, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71876, 1877, 2388, 2389}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1088, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.39}}}{{\f5\fs12\hyphpar0\qj{, 331.303}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.33}}}{\*\bkmkstart stylerid1_2E5_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every holder of a license or permit under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall maintain records, in printed or electronic format, which include income statements, balance sheets, purchase and sales invoices, purchase and sales ledgers, and any other records as the director may require. The records required and the premises of the licensee or permittee shall be accessible and open to inspection pursuant to }{{\f5\fs18\hyphpar0\qj{section 123.30, subsection 1}}}{, during normal business hours of the licensee or permittee.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f22; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.022;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.22; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.33}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 196, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72390}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.49}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.34}}}{\*\bkmkstart stylerid1_2E5_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Seasonal, fourteen-day, and five-day licenses }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may issue eight-month seasonal class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, and class \u8220\'3fF\u8221\'3f retail alcohol licenses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for an eight-month seasonal license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be fifty percent of the license fee for that class of license. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may issue fourteen-day class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, and class \u8220\'3fF\u8221\'3f retail alcohol licenses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fourteen-day retail alcohol license, if granted, is valid for fourteen consecutive days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for a fourteen-day retail alcohol license is one-quarter of the annual fee for that class of retail alcohol license. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may issue five-day class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fD\u8221\'3f, and class \u8220\'3fF\u8221\'3f retail alcohol licenses, and five-day special class \u8220\'3fC\u8221\'3f retail native wine licenses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A five-day retail alcohol license is valid for five consecutive days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for the five-day retail alcohol license is one-eighth of the annual fee for that class of license, except that the fee for a five-day special class \u8220\'3fC\u8221\'3f retail native wine license is fifty dollars. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A refund of fees paid shall not be made for seasonal licenses, or for fourteen-day or five-day retail alcohol licenses. In addition, a seasonal, fourteen-day, or five-day license shall not be renewed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f27, 1921-f100; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.027, 1921.100;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.27, 124.6; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.34}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 55, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1237, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1177, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1008, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a729, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72391 \u8211\'3f 2393}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1087, \'a71}}}