yphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For premises located outside the corporate limits of any city, a fee equal to that charged for a premises of the same square footage in the nearest incorporated city, as determined by the address assigned by the United States postal service. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Class \u8220\'3fF\u8221\'3f retail alcohol license fees shall be six hundred dollars, except that for class \u8220\'3fF\u8221\'3f licenses in cities of less than two thousand population, and for clubs of less than two hundred fifty members, the license fee shall be four hundred dollars; however, the fee shall be two hundred dollars for any club which is a post, branch, or chapter of a veterans organization chartered by the Congress of the United States, if the club does not sell or permit the consumption of alcoholic beverages on the premises more than one day in any week or more than a total of fifty-two days in a year, and if the application for a license states that the club does not and will not sell or permit the consumption of alcoholic beverages on the premises more than one day in any week or more than a total of fifty-two days in a year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall credit all fees to the beer and liquor control fund. The department shall remit to the appropriate local authority a sum equal to sixty-five percent of the fees collected for each class \u8220\'3fB\u8221\'3f, class \u8220\'3fC\u8221\'3f, or class \u8220\'3fF\u8221\'3f license except special class \u8220\'3fC\u8221\'3f licenses or class \u8220\'3fE\u8221\'3f licenses, covering premises located within the local authority\u8217\'3fs jurisdiction. The department shall remit to the appropriate local authority a sum equal to seventy-five percent of the fees collected for each special class \u8220\'3fC\u8221\'3f license covering premises located within the local authority\u8217\'3fs jurisdiction. Those fees collected for each class \u8220\'3fE\u8221\'3f retail alcohol license shall be credited to the beer and liquor control fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is imposed a surcharge on the fee for each class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, or class \u8220\'3fF\u8221\'3f retail alcohol license equal to thirty percent of the scheduled license fee. The surcharges collected under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited in the beer and liquor control fund, and notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, no portion of the surcharges collected under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be remitted to the local authority.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f28; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.028;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.38; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.36}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a759, 209}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1275, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1312, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 32, \'a726 \u8211\'3f 29}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7744}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 22, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a79 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1089, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1175, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 245, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a785}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 17, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a742, 43}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a717 \u8211\'3f 19}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 155, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a78, 15}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72400, 2401}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 157, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 31, \'a716 \u8211\'3f 20}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.427}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendments to subsection 1 apply to licenses issued or renewed on or after November 10, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 31, \'a720}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph a, subparagraph (4) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph c, subparagraph (4) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph d, subparagraph (4) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph g, subparagraph (4) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.37}}}{\*\bkmkstart stylerid1_2E5_2E41_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E41_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exclusive power to license and levy taxes \u8212\'3f disputed taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The power to establish licenses and permits and levy taxes as imposed in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is vested exclusively with the state. Unless specifically provided, a local authority shall not require the obtaining of a special license or permit for the sale of alcoholic beverages at any establishment, or require the obtaining of a license by any person as a condition precedent to the person\u8217\'3fs employment in the sale, serving, or handling of alcoholic beverages within an establishment operating under a license or permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may compromise and settle doubtful and disputed claims for taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or for taxes of doubtful collectibility, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 7D.9}}}{{\f5\fs18\hyphpar0\qj{. The director may enter into informal settlements pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.10}}}{{\f5\fs18\hyphpar0\qj{ to compromise and settle doubtful and disputed claims for taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The director may make a claim under a licensee\u8217\'3fs or permittee\u8217\'3fs penal bond for taxes of doubtful collectibility. Whenever a compromise or settlement is made, the director shall make a complete record of the case showing the tax assessed, reports and audits, if any, the licensee\u8217\'3fs or permittee\u8217\'3fs grounds for dispute or contest, together with all evidence of the dispute or contest, and the amounts, conditions, and settlement or compromise of the dispute or contest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee or permittee who disputes the amount of tax imposed must pay all tax and penalty pertaining to the disputed tax liability prior to appealing the disputed tax liability to the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall adopt rules establishing procedures for payment of disputed taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If it is determined that the tax is not due in whole or in part, the department shall promptly refund the part of the tax payment which is determined not to be due.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.37}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1153, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 252, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 22, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72402}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.38}}}{\*\bkmkstart stylerid1_2E5_2E42_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E42_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nature of permit or license \u8212\'3f surrender \u8212\'3f transfer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retail alcohol license, wine permit, or beer permit is a personal privilege and is revocable for cause. It is not property nor is it subject to attachment and execution nor alienable nor assignable, and it shall cease upon the death of the permittee or licensee. However, the director may in the director\u8217\'3fs discretion allow the executor or administrator of the estate of a permittee or licensee to operate the business of the decedent for a reasonable time not to exceed the expiration date of the permit or license. Every permit or license shall be issued in the name of the applicant and no person holding a permit or license shall allow any other person to use it.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any licensee or permittee, or the executor or administrator of the estate of a licensee or permittee, or any person duly appointed by the court to take charge of and administer the property or assets of the licensee or permittee for the benefit of the licensee\u8217\'3fs or permittee\u8217\'3fs creditors, may voluntarily surrender a license or permit to the department. When a license or permit is surrendered, the department shall notify the local authority, and the department or the local authority shall refund to the person surrendering the license or permit, a proportionate amount of the fee received by the department or the local authority for the license or permit as follows:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a license or permit is surrendered during the first three months of the period for which it was issued, the refund shall be three-fourths of the amount of the fee.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If surrendered more than three months but not more than six months after issuance, the refund shall be one-half of the amount of the fee.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If surrendered more than six months but not more than nine months after issuance, the refund shall be one-fourth of the amount of the fee.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No refund shall be made for any retail alcohol license, wine permit, or beer permit surrendered more than nine months after issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, any portion of license or permit fees used for the purposes authorized in }}}{{\f5\fs18\hyphpar0\qj{section 331.424, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) and (2), shall not be deemed received either by the department or by a local authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No refund shall be made to any licensee or permittee upon the surrender of the license or permit if there is at the time of surrender a complaint filed with the department or local authority charging the licensee or permittee with a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If upon a hearing on a complaint the license or permit is not revoked or suspended, then the licensee or permittee is eligible, upon surrender of the license or permit, to receive a refund as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. However, if the license or permit is revoked or suspended upon hearing, the licensee or permittee is not eligible for the refund of any portion of the license or permit fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local authority may in its discretion authorize a licensee or permittee to transfer the license or permit from one location to another within the same incorporated city, or within a county outside the corporate limits of a city, provided that the premises to which the transfer is to be made would have been eligible for a license or permit in the first instance and such transfer will not result in the violation of any law. All transfers authorized, and the particulars of same, shall be reported to the director by the local authority. The director may by rule establish a uniform transfer fee to be assessed by all local authorities upon licensees or permittees to cover the administrative costs of such transfers, such fee to be retained by the local authority involved.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f29, -f100; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.029, 1921.100;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.29, 124.6; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.38}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 206, \'a75, 12}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7162}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1008, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a742, 43}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a779, 108}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a731, 32, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72403 \u8211\'3f 2406}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.38A}}}{\*\bkmkstart stylerid1_2E5_2E43_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E43_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidential investigative records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In order to assure a free flow of information for accomplishing the purposes of }{{\f5\fs18\hyphpar0\qj{section 123.4}}}{ and }{{\f5\fs18\hyphpar0\qj{section 123.9, subsection 6}}}{, all complaint information, investigation files, audit files, and inspection files, other investigation reports, and other investigative information in the possession of the department or employees acting under the authority of the director under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are privileged and confidential, and are not subject to discovery, subpoena, or other means of legal compulsion for their release before administrative or criminal charges are filed. However, investigative information in the possession of department employees under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may be disclosed to the licensing authorities of a city or county within this state, in another state, the District of Columbia, or territory or county in which the licensee or permittee is licensed or permitted or has applied for a license or permit. In addition, the investigative information can be shared with any law enforcement agency or other state agency that also has investigative, regulatory, or enforcement jurisdiction authorized by law. Records received by the department for purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ from other agencies which would be confidential if created by the department are considered confidential.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 113, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72407}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.39}}}{\*\bkmkstart stylerid1_2E5_2E44_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E44_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspension or revocation of license or permit \u8212\'3f civil penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director or the local authority may suspend a class \u8220\'3fB\u8221\'3f, special class \u8220\'3fB\u8221\'3f native wine, class \u8220\'3fC\u8221\'3f, special class \u8220\'3fC\u8221\'3f, class \u8220\'3fE\u8221\'3f, or class \u8220\'3fF\u8221\'3f retail alcohol license, or charity beer, spirits, and wine special event license for a period not to exceed one year, revoke the license, or impose a civil penalty not to exceed one thousand dollars per violation. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may suspend a certificate of compliance, a class \u8220\'3fD\u8221\'3f retail alcohol license, a manufacturer\u8217\'3fs license, a broker\u8217\'3fs permit, a class \u8220\'3fA\u8221\'3f native distilled spirits license, a class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit, a class \u8220\'3fA\u8221\'3f wine permit, a wine direct shipper\u8217\'3fs permit, or a wine carrier permit for a period not to exceed one year, revoke the license, permit, or certificate, or impose a civil penalty not to exceed one thousand dollars per violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A license, permit, or certificate of compliance issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may be suspended or revoked, or a civil penalty may be imposed for any of the following causes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Misrepresentation of any material fact in the application for the license, permit, or certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violation of any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any change in the ownership or interest in the business operated under a retail alcohol license which change was not previously reported in a manner prescribed by the director within thirty days of the change and subsequently approved by the local authority, when applicable, and the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An event which would have resulted in disqualification from receiving the license, permit, or certificate when originally issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any sale, hypothecation, or transfer of the license, permit, or certificate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The failure or refusal on the part of any license, permit, or certificate holder to render any report or remit any taxes to the department under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ when due.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A criminal conviction is not a prerequisite to suspension, revocation, or imposition of a civil penalty pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local authority which acts pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 123.32}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 123.50}}}{{\f5\fs18\hyphpar0\qj{ shall notify the department in writing of the action taken, and shall notify the license or permit holder of the right to appeal a suspension, revocation, or imposition of a civil penalty to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before suspension, revocation, or imposition of a civil penalty by the director, the license, permit, or certificate holder shall be given written notice and an opportunity for a hearing. The director may appoint a member of the department or may request an administrative law judge from the department of inspections, appeals, and licensing to conduct the hearing and issue a proposed decision. Upon the motion of a party to the hearing or upon the director\u8217\'3fs own motion, the director may review the proposed decision in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. Upon review of the proposed decision, the director may affirm, reverse, or modify the proposed decision. A license, permit, or certificate holder aggrieved by a decision of the director may seek judicial review of the director\u8217\'3fs decision in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Civil penalties imposed and collected by the local authority under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be retained by the local authority. Civil penalties imposed and collected by the department under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be credited to the general fund of the state pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.17, subsection 9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Local authorities may suspend any retail alcohol license for a violation of any ordinance or regulation adopted by the local authority. Local authorities may adopt ordinances or regulations for the location of the premises of retail alcohol licensed establishments and local authorities may adopt ordinances, not in conflict with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and that do not diminish the hours during which alcoholic beverages may be sold or consumed at retail, governing any other activities or matters which may affect the retail sale and consumption of alcoholic beverages and the health, welfare and morals of the community involved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a retail alcohol license is suspended after a hearing as a result of violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ by the licensee or the licensee\u8217\'3fs agents or employees, the premises which were licensed by the license shall not be relicensed for a new applicant until the suspension has terminated or time of suspension has elapsed, or ninety days have elapsed since the commencement of the suspension, whichever occurs first. However, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit the premises from being relicensed to a new applicant before the suspension has terminated or before the time of suspension has elapsed or before ninety days have elapsed from the commencement of the suspension, if the premises prior to the time of the suspension had been purchased under contract, and the vendor under that contract had exercised the person\u8217\'3fs rights under }}}{{\f5\fs18\hyphpar0\qj{chapter 656}}}{{\f5\fs18\hyphpar0\qj{ and sold the property to a different person who is not related to the previous licensee by marriage or within the third degree of consanguinity or affinity and if the previous licensee does not have a financial interest in the business of the new applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the cause for suspension is a first offense violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the director or local authority shall impose a civil penalty in the amount of five hundred dollars in lieu of suspension of the license or permit. }}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f32, 1921-f126; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.032, 1921.129;}}}{ C46, 50, 54, 58, 62, \'a7123.32, 124.34; C66, 71, \'a7123.32, 123.102, 124.34; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.39}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1017, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1154, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7128}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a719 \u8211\'3f 21}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a721, 22}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a733 \u8211\'3f 35, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71878, 2408}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a726}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.23}}}{{\f5\fs12\hyphpar0\qj{, 123.24}}}{{\f5\fs12\hyphpar0\qj{, 123.41}}}{{\f5\fs12\hyphpar0\qj{, 123.42}}}{{\f5\fs12\hyphpar0\qj{, 123.43}}}{{\f5\fs12\hyphpar0\qj{, 123.46A}}}{{\f5\fs12\hyphpar0\qj{, 123.50}}}{{\f5\fs12\hyphpar0\qj{, 123.135}}}{{\f5\fs12\hyphpar0\qj{, 123.173A}}}{{\f5\fs12\hyphpar0\qj{, 123.173C}}}{{\f5\fs12\hyphpar0\qj{, 123.180}}}{{\f5\fs12\hyphpar0\qj{, 123.186}}}{{\f5\fs12\hyphpar0\qj{, 123.187}}}{{\f5\fs12\hyphpar0\qj{, 123.188}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; internal reference change applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.40}}}{\*\bkmkstart stylerid1_2E5_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Effect of revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any retail alcohol licensee, wine permittee, or beer permittee whose license or permit is revoked under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not thereafter be permitted to hold a retail alcohol license, wine permit, or beer permit in the state of Iowa for a period of two years from the date of revocation. A spouse or business associate holding ten percent or more of the capital stock or ownership interest in the business of a person whose license or permit has been revoked shall not be issued a retail alcohol license, wine permit, or beer permit, and no retail alcohol license, wine permit, or beer permit shall be issued which covers any business in which such person has a financial interest for a period of two years from the date of revocation. If a license or permit is revoked, the premises which had been covered by the license or permit shall not be relicensed for one year.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f32, 1921-f123; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.032, 1921.125;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.32, 124.30; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.40}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a736, 88}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.3}}}{{\f5\fs12\hyphpar0\qj{, 123.50}}}{{\f5\fs12\hyphpar0\qj{, 123.56}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.41}}}{\*\bkmkstart stylerid1_2E5_2E46_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E46_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Manufacturer\u8217\'3fs license \u8212\'3f alcoholic liquor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each completed application to obtain or renew a manufacturer\u8217\'3fs license shall be submitted to the department electronically, or in a manner prescribed by the director, and shall be accompanied by a fee of three hundred dollars payable to the department. The director may in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ grant and issue to a manufacturer a manufacturer\u8217\'3fs license, valid for a one-year period after date of issuance, which shall allow the manufacture, storage, and wholesale disposition and sale of alcoholic liquors to the department and to customers outside of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As a condition precedent to the approval and granting of a manufacturer\u8217\'3fs license, an applicant shall file with the department a basic permit issued by the alcohol and tobacco tax and trade bureau of the United States department of the treasury, and a statement under oath that the applicant will faithfully observe and comply with all laws, rules, and regulations governing the manufacture and sale of alcoholic liquor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who holds an experimental distilled spirits plant permit or its equivalent issued by the alcohol and tobacco tax and trade bureau of the United States department of the treasury may produce alcohol for use as fuel without obtaining a manufacturer\u8217\'3fs license from the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who holds a manufacturer\u8217\'3fs license shall file with the department, on or before the fifteenth day of each calendar month, all documents filed by the manufacturer with the alcohol and tobacco tax and trade bureau of the United States department of the treasury, including all production, storage, and processing reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall subject the license holder to the general penalties provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall constitute grounds for imposition of a civil penalty, suspension of the license, or revocation of the license after notice and opportunity for a hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f36; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.036;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.36; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.41}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 30, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a723 \u8211\'3f 25}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a79, 15}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72409}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.42}}}{\*\bkmkstart stylerid1_2E5_2E47_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E47_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Broker\u8217\'3fs permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to representing or promoting alcoholic liquor products in the state, the broker shall submit a completed application to the department electronically, or in a manner prescribed by the director, for a broker\u8217\'3fs permit. The director may in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ issue a broker\u8217\'3fs permit which shall be valid for one year from the date of issuance unless it is sooner suspended or revoked for a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of applying for a broker\u8217\'3fs permit, each applicant shall submit to the department a list of names and addresses of all manufacturers, distillers, and importers whom the applicant has been appointed to represent in the state of Iowa for any purpose. The listing shall be amended by the broker as necessary to keep the listing current with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A broker\u8217\'3fs permit is valid throughout the state, and a broker who represents more than one certificate or license holder is required to obtain only one broker\u8217\'3fs permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual fee for a broker\u8217\'3fs permit is twenty-five dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee of a broker is not required to apply for or hold a broker\u8217\'3fs permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a distiller\u8217\'3fs certificate of compliance, a manufacturer\u8217\'3fs license, or a class \u8220\'3fA\u8221\'3f native distilled spirits license is not required to appoint a broker to represent its alcoholic liquor products in the state. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall subject the permit holder to the general penalties provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall constitute grounds for imposition of a civil penalty, suspension of the permit, or revocation of the permit after notice and opportunity for a hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f37; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.037;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.37; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.42}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1017, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a723 \u8211\'3f 25}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a726, 27}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72410}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.43}}}{\*\bkmkstart stylerid1_2E5_2E48_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E48_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Class \u8220\'3fA\u8221\'3f native distilled spirits license }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ application and issuance }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person applying for a class \u8220\'3fA\u8221\'3f native distilled spirits license shall submit an application electronically, or in a manner prescribed by the director, which shall set forth under oath the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and place of residence of the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names and addresses of all persons or, in the case of a corporation, limited liability company, or any other similar legal entity, the officers, directors, and persons owning or controlling ten percent or more of the capital stock thereof, having a financial interest, by way of loan, ownership, or otherwise, in the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location of the premises where the applicant intends to operate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the owner of the premises and if the owner of the premises is not the applicant, whether the applicant is the actual lessee of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When required by the director, and in such form and containing such information as the director may require, a description of the premises where the applicant intends to use the license, to include a sketch or drawing of the premises and, if applicable, the number of square feet of interior floor space which comprises the retail sales area of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether any person specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ has ever been convicted of any offense against the laws of the United States, or any state or territory thereof, or any political subdivision of any such state or territory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information as required by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the director shall issue a class \u8220\'3fA\u8221\'3f native distilled spirits license to any applicant who establishes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant has submitted a completed application as required by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant is a person of good moral character as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.3, subsection 40}}}{{\f5\fs18\hyphpar0\qj{. This paragraph does not apply if the applicant is the state of Iowa or a state agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 669.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant is a citizen of the state of Iowa or, if a corporation, that the applicant is authorized to do business in the state. This paragraph does not apply if the applicant is the state of Iowa or a state agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 669.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant has filed with the department a basic permit issued by the alcohol and tobacco tax and trade bureau of the United States department of the treasury, and that the applicant will faithfully observe and comply with all laws, rules, and regulations governing the manufacture and sale of alcoholic liquor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the premises where the applicant intends to use the license conforms to all applicable laws, health regulations, and fire regulations, and constitutes a safe and proper place or building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant gives consent to a person, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.30, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, to enter upon the premises without a warrant during the business hours of the applicant to inspect for violations of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or ordinances and regulations that local authorities may adopt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f native distilled spirits license for a native distillery shall be issued and renewed annually upon payment of a fee of three hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall subject the licensee to the general penalties provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall constitute grounds for imposition of a civil penalty or suspension or revocation of the license after notice and opportunity for a hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpremises\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in addition to premises as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.3}}}{{\f5\fs18\hyphpar0\qj{, may include any of the following noncontiguous locations, provided that such noncontiguous locations are approved by the alcohol and tobacco tax and trade bureau of the United States department of the treasury:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any number of locations which are only separated from the premises as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.3}}}{{\f5\fs18\hyphpar0\qj{ by public waterways, roads, or carrier rights-of-way.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any number of locations in the same general location as the premises as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An additional warehouse or warehouses, located somewhere other than on the premises as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.3}}}{{\f5\fs18\hyphpar0\qj{ or a location described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 119, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a710, 15}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72411 \u8211\'3f 2414}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 31, \'a78, 9, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}{{\f5\fs12\hyphpar0\qj{, 123.43A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraphs b and c amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 5}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.43A}}}{\*\bkmkstart stylerid1_2E5_2E49_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E49_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Native distilleries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to rules of the department, a native distillery holding a class \u8220\'3fA\u8221\'3f native distilled spirits license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.43}}}{{\f5\fs18\hyphpar0\qj{ may sell or offer for sale native distilled spirits. As provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, sales of native distilled spirits manufactured on the premises may be made at retail for off-premises consumption when sold on the premises of the native distillery that manufactures native distilled spirits. All sales intended for resale in this state shall be made through the state\u8217\'3fs wholesale distribution system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A native distillery shall not sell more than nine liters per person per day, of native distilled spirits on the premises of the native distillery. However, a native distillery shall not directly ship native distilled spirits for sale at retail. The native distillery shall maintain records of individual purchases of native distilled spirits at the native distillery for three years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A native distillery shall not sell native distilled spirits other than as permitted in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall not allow native distilled spirits sold for consumption off the premises to be consumed upon the premises of the native distillery. However, native distilled spirits may be tasted pursuant to the rules of the department on the premises where fermented, distilled, or matured, when no charge is made for the tasting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sale of native distilled spirits to the department for wholesale disposition and sale by the department shall be subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ regarding such disposition and sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A native distillery issued a class \u8220\'3fA\u8221\'3f native distilled spirits license shall file with the department, on or before the fifteenth day of each calendar month, all documents filed by the native distillery with the alcohol and tobacco tax and trade bureau of the United States department of the treasury, including all production, storage, and processing reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary or the fact that a person is the holder of a class \u8220\'3fA\u8221\'3f native distilled spirits license, a native distillery may be granted a class \u8220\'3fC\u8221\'3f retail alcohol license as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.30}}}{{\f5\fs18\hyphpar0\qj{ for the same premises licensed under a class \u8220\'3fA\u8221\'3f native distilled spirits license where the manufacturing of native distilled spirits occurs. A native distillery may be granted not more than two class \u8220\'3fC\u8221\'3f retail alcohol licenses. A native distillery may be issued a class \u8220\'3fC\u8221\'3f retail alcohol license regardless of whether the native distillery is also a manufacturer of beer pursuant to a class \u8220\'3fA\u8221\'3f beer permit or a manufacturer of native wine pursuant to a class \u8220\'3fA\u8221\'3f wine permit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary or the fact that a person is the holder of a class \u8220\'3fA\u8221\'3f native distilled spirits license, a native distillery may be granted a five-day class \u8220\'3fC\u8221\'3f retail alcohol license as described in }}}{{\f5\fs18\hyphpar0\qj{section 123.34}}}{{\f5\fs18\hyphpar0\qj{ for premises other than the premises licensed under a class \u8220\'3fA\u8221\'3f native distilled spirits license where the manufacturing of native distilled spirits occurs. A native distillery may be granted not more than six five-day class \u8220\'3fC\u8221\'3f retail alcohol licenses during a calendar year. A native distillery may be issued a five-day class \u8220\'3fC\u8221\'3f retail alcohol license regardless of whether the native distillery is also a manufacturer of beer pursuant to a class \u8220\'3fA\u8221\'3f beer permit or a manufacturer of native wine pursuant to a class \u8220\'3fA\u8221\'3f wine permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A native distillery may sell the native distilled spirits it manufactures to customers outside the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer may use the space and equipment of another manufacturer for the purpose of manufacturing native distilled spirits, provided that such an alternating proprietorship arrangement is approved by the alcohol and tobacco tax and trade bureau of the United States department of the treasury. A separate class \u8220\'3fA\u8221\'3f native distilled spirits license shall be issued to each manufacturer, and each manufacturer shall be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the rules of the department. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{, not more than one class \u8220\'3fC\u8221\'3f retail alcohol license shall be issued to a premises with alternating proprietorships.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1031, \'a784}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 17, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 30, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1008, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 160, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1114, \'a712, 16}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 133, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a737, 38, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72415}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1087, \'a72, 3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.44}}}{\*\bkmkstart stylerid1_2E5_2E5_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E5_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gifts prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A manufacturer or broker shall not give away alcoholic liquor at any time in connection with the manufacturer\u8217\'3fs or broker\u8217\'3fs business except for testing or sampling purposes only. A manufacturer, distiller, vintner, brewer, broker, wholesaler, or importer, organized as a corporation pursuant to the laws of this state or any other state, who deals in alcoholic beverages subject to regulation under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not offer or give anything of value to a commission member or official or employee of the department under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or directly or indirectly contribute in any manner any money or thing of value to a person seeking a public or appointive office or a recognized political party or a group of persons seeking to become a recognized political party.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f39; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.039;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.39; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.44}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1017, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72416}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a719}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.45}}}{\*\bkmkstart stylerid1_2E5_2E51_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E51_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General limitations on business interests }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ licensing of native breweries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to such exceptions as otherwise authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a person engaged in the business of manufacturing, bottling, or wholesaling alcoholic beverages, excluding an institutional investor, or any broker, employee, or agent of such a person, shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Directly or indirectly supply, furnish, give, or pay for any furnishings, fixtures, or equipment used in the storage, handling, serving, or dispensing of alcoholic beverages or food within the place of business of a licensee or permittee authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to sell at retail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Directly or indirectly extend any credit for alcoholic beverages or beer or pay for any such license or permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Directly or indirectly be interested in the ownership, conduct, or operation of the business of another licensee or permittee authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to sell at retail, unless the licensee or permittee authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to sell at retail does not purchase or sell the alcoholic beverages of the person engaged in the business of manufacturing, bottling, or wholesaling alcoholic beverages. However, the licensee or permittee authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to sell at retail may purchase and sell the wine of the person engaged in the business of manufacturing wine that is not native wine provided the licensed premises is the principal office, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 490.140}}}{{\f5\fs18\hyphpar0\qj{, of the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hold a retail alcohol license unless the licensee holding a retail alcohol license does not purchase or sell the alcoholic beverages of the person engaged in the business of manufacturing, bottling, or wholesaling alcoholic beverages. However, a person engaged in the business of manufacturing wine that is not native wine may purchase and sell the person\u8217\'3fs wine under the authority of a special class \u8220\'3fC\u8221\'3f retail alcohol license and a class \u8220\'3fB\u8221\'3f retail alcohol license provided the licensed premises is the principal office, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 490.140}}}{{\f5\fs18\hyphpar0\qj{, of the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of law to the contrary, a broker, employee, or agent of a person engaged in the business of manufacturing, bottling, or wholesaling alcoholic beverages may be a broker, employee, or agent of another person engaged in the business of manufacturing, bottling, or wholesaling alcoholic beverages or a broker, employee, or agent of a business authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to sell alcoholic beverages at retail as long as the broker, employee, or agent is not an officer, owner, director, or employee in a position to exercise any control or influence over the types of sales or the purchasing of alcoholic beverages in either position of employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person engaged in the wholesaling of beer or wine may sell only disposable glassware, which is constructed of paper, paper laminated, or plastic materials and designed primarily for personal consumption on a one-time usage basis, to retailers for use within the premises of licensed establishments, for an amount which is greater than or equal to an amount which represents the greater of either the amount paid for the disposable glassware by the supplier or the amount paid for the disposable glassware by the wholesaler. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the fact that a person is the holder of a class \u8220\'3fA\u8221\'3f beer permit, a native brewery may be granted a class \u8220\'3fC\u8221\'3f retail alcohol license or a special class \u8220\'3fC\u8221\'3f retail alcohol license, both as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.30}}}{{\f5\fs18\hyphpar0\qj{, for the same premises licensed under a class \u8220\'3fA\u8221\'3f beer permit where the manufacturing of beer occurs. A native brewery may be granted not more than two class \u8220\'3fC\u8221\'3f retail alcohol licenses or two special class \u8220\'3fC\u8221\'3f retail alcohol licenses. A native brewery may be issued a class \u8220\'3fC\u8221\'3f retail alcohol license or a special class \u8220\'3fC\u8221\'3f retail alcohol license regardless of whether that person is also a manufacturer of native distilled spirits pursuant to a class \u8220\'3fA\u8221\'3f native distilled spirits license or a manufacturer of native wine pursuant to a class \u8220\'3fA\u8221\'3f wine permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the fact that a person is the holder of a class \u8220\'3fA\u8221\'3f beer permit, a native brewery may be granted a five-day class \u8220\'3fC\u8221\'3f or five-day special class \u8220\'3fC\u8221\'3f retail alcohol license as described in }}}{{\f5\fs18\hyphpar0\qj{section 123.34}}}{{\f5\fs18\hyphpar0\qj{ for premises other than the premises licensed under a class \u8220\'3fA\u8221\'3f beer permit where the manufacturing of beer occurs. A native brewery may be granted not more than six five-day class \u8220\'3fC\u8221\'3f or five-day special class \u8220\'3fC\u8221\'3f retail alcohol licenses during a calendar year. A native brewery may be issued a five-day class \u8220\'3fC\u8221\'3f or five-day special class \u8220\'3fC\u8221\'3f retail alcohol license regardless of whether the native brewery is also a manufacturer of native distilled spirits pursuant to a class \u8220\'3fA\u8221\'3f native distilled spirits license or a manufacturer of native wine pursuant to a class \u8220\'3fA\u8221\'3f wine permit. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee or permittee who permits or assents to or is a party in any way to a violation or infringement of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The exceptions established by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ to the general prohibition against tied interests shall be limited to their express terms so as not to undermine the general prohibition and shall therefore be construed accordingly, and shall not be construed to affect exceptions to the general prohibition against tied interests as otherwise authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f40, 1921-f115; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.040, 1921.117;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.40, 124.22; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.45}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 57, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1024, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 24, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 8, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 160, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a754, 55}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 133, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a739, 40, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 157, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1087, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.130}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.46}}}{\*\bkmkstart stylerid1_2E5_2E52_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E52_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consumption or intoxication in public places \u8212\'3f notifications \u8212\'3f chemical tests \u8212\'3f expungement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fArrest\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 804.5}}}{{\f5\fs18\hyphpar0\qj{ and includes taking into custody pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChemical test\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a test of a person\u8217\'3fs blood, breath, or urine to determine the percentage of alcohol present by a qualified person using devices and methods approved by the commissioner of public safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeace officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not use or consume alcoholic liquor, wine, or beer upon the public streets or highways. A person shall not use or consume alcoholic liquor in any public place except premises covered by a retail alcohol license. A person shall not possess or consume alcoholic liquors, wine, or beer on public school property or while attending a public or private school-related function. A person shall not be intoxicated in a public place. A person violating }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not simulate intoxication in a public place. A person violating }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a peace officer arrests a person on a charge of public intoxication under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the peace officer shall inform the person that the person may have a chemical test administered at the person\u8217\'3fs own expense. If a device approved by the commissioner of public safety for testing a sample of a person\u8217\'3fs breath to determine the person\u8217\'3fs blood alcohol concentration is available, that is the only test that need be offered the person arrested. In a prosecution for public intoxication, evidence of the results of a chemical test performed under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is admissible upon proof of a proper foundation. The percentage of alcohol present in a person\u8217\'3fs blood, breath, or urine established by the results of a chemical test performed within two hours after the person\u8217\'3fs arrest on a charge of public intoxication is presumed to be the percentage of alcohol present at the time of arrest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer shall make a reasonable effort to identify a person under the age of eighteen who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and refer the person to juvenile court.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ A juvenile court officer shall notify the person\u8217\'3fs custodial parent, legal guardian, or custodian of the violation. In addition, the juvenile court officer shall make a reasonable effort to identify the elementary or secondary school the person attends, if any, and to notify the superintendent of the school district or the superintendent\u8217\'3fs designee, or the authorities in charge of the nonpublic school, of the violation. A reasonable attempt to notify the person includes, but is not limited to, a telephone call or notice by first-class mail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the expiration of two years following conviction for a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or of a similar local ordinance, a person may petition the court to expunge the conviction, and if the person has had no other criminal convictions, other than local traffic violations or simple misdemeanor violations of }}}{{\f5\fs18\hyphpar0\qj{chapter 321}}}{{\f5\fs18\hyphpar0\qj{ during the two-year period, the conviction shall be expunged as a matter of law. The court shall enter an order that the record of the conviction be expunged by the clerk of the district court. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 692.2}}}{{\f5\fs18\hyphpar0\qj{, after receipt of notice from the clerk of the district court that a record of conviction has been expunged, the record of conviction shall be removed from the criminal history data files maintained by the department of public safety if such a record was maintained in the criminal history data files.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be charged or prosecuted for a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the person is immune from charge or prosecution pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 701.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f42, 1921-f127; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.042, 1921.132;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.42, 124.37; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.46}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1067, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 225, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1231, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1138, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1044, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1071, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1128, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 17, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1058, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 140, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1080, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a741, 88}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.91}}}{{\f5\fs12\hyphpar0\qj{, 232.22}}}{{\f5\fs12\hyphpar0\qj{, 232.52}}}{{\f5\fs12\hyphpar0\qj{, 701.12}}}{{\f5\fs12\hyphpar0\qj{, 901C.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.46A}}}{\*\bkmkstart stylerid1_2E5_2E53_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E53_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Delivery of alcoholic beverages by retailers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensees authorized to sell alcoholic liquor, wine, or beer in original unopened containers for consumption off the licensed premises may deliver alcoholic liquor, wine, or beer to a home, another licensed premises if there is identical ownership of the premises by the licensee, or other designated location in this state. Deliveries shall be limited to alcoholic beverages authorized by the licensee\u8217\'3fs license. Orders delivered to another licensed premises shall contain only those alcoholic beverages authorized for sale by the retail alcohol license covering the premises to which the alcoholic beverages will be delivered. Orders delivered to another licensed premises shall be fulfilled using the alcoholic beverages inventory owned by the licensee who will receive the order for delivery. If the recipient refuses or fails to pick up the delivery, or is ineligible to receive the delivery, the alcoholic beverages shall be returned to the licensee who fulfilled the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensees authorized to sell wine, beer, or mixed drinks or cocktails for consumption off the licensed premises in a container other than the original container may deliver the wine, beer, or mixed drinks or cocktails to a home or other designated location in this state only if the container other than the original container has been sold and securely sealed in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the rules of the department. Deliveries shall be limited to alcoholic beverages authorized by the licensee\u8217\'3fs license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All deliveries of alcoholic liquor, wine, beer, or mixed drinks or cocktails shall be subject to the following requirements and restrictions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Payment for the alcoholic liquor, wine, beer, or mixed drinks or cocktails shall be received by the licensee at the time of order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Orders for deliveries may be taken by the licensee between the hours of 2:00 a.m. and 6:00 a.m. on any day of the week, notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to the contrary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alcoholic liquor, wine, beer, or mixed drinks or cocktails delivered to a person shall be for personal use and not for resale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Deliveries shall only be made to persons in this state who are twenty-one years of age or older.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Deliveries shall not be made to a person who is intoxicated or is simulating intoxication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Deliveries shall occur between 6:00 a.m. and 10:00 p.m. Monday through Sunday on the same day the order for alcoholic liquor, wine, beer, or mixed drinks or cocktails is removed from the licensed premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Delivery of alcoholic liquor, wine, beer, or mixed drinks or cocktails shall be made by the licensee, the licensee\u8217\'3fs employee, or a third party, provided the licensee has entered into a written agreement with the third party that authorizes the third party to act as an agent of the licensee for the purpose of delivering alcoholic liquor, wine, beer, or mixed drinks or cocktails. Each licensee shall submit to the department electronically, or in a manner prescribed by the director, a list of names and addresses of all third parties it has authorized to act as its agent for the purpose of delivering alcoholic liquor, wine, beer, or mixed drinks or cocktails. The licensee shall provide the department with amendments to the list as necessary to ensure the department possesses an accurate, current list.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Delivery personnel shall be twenty-one years of age or older.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Valid proof of the recipient\u8217\'3fs identity and age shall be obtained at the time of delivery, and the signature of a person twenty-one years of age or older shall be obtained as a condition of delivery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensees shall maintain records of deliveries which include the quantity delivered, the recipient\u8217\'3fs name and address, and the signature of the recipient of the alcoholic liquor, wine, beer, or mixed drinks or cocktails. The records shall be maintained on the licensed premises for a period of three years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall subject the licensee to the penalty provisions of }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{. If the licensee, an employee of the licensee, or a person delivering alcoholic liquor, wine, beer, or mixed drinks or cocktails for a third party acting on behalf of the licensee pursuant to a written agreement violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the licensee shall not be assessed a penalty under }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ if the licensee establishes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The violation was committed off of the licensee\u8217\'3fs premises after the liquor, wine, beer, or mixed drinks or cocktails was removed from the licensee\u8217\'3fs premises in fulfillment of a delivery order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person who committed the violation is an employee of the licensee, that no other violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ was committed by any employee of the licensee within the two-year period immediately preceding the date of violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person who committed the violation is a person delivering for a third party acting on behalf of the licensee, that no other violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ was committed by any person delivering for the same third party while the third party was acting on behalf of the licensee within the two-year period immediately preceding the date of violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall impact the direct shipment of wine as regulated by }}}{{\f5\fs18\hyphpar0\qj{section 123.187}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 30, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a764 \u8211\'3f 66, 68}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 99, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 155, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 174, \'a711, 12, 36}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a742, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72417, 2418}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a727}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.49}}}{{\f5\fs12\hyphpar0\qj{, 123.187}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.47}}}{\*\bkmkstart stylerid1_2E5_2E54_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E54_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons under eighteen years of age, persons eighteen, nineteen, or twenty years of age, and persons twenty-one years of age and older.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell, give, or otherwise supply any alcoholic beverage to any person knowing or having reasonable cause to believe that person to be under legal age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except for the purposes described in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a person who is the owner or lessee of, or who otherwise has control over, property that is not a licensed premises, shall not knowingly permit any person, knowing or having reasonable cause to believe the person to be under the age of eighteen, to consume or possess on such property any alcoholic beverage.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ commits the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a first offense, a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8C, subsection 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a second or subsequent offense, a simple misdemeanor punishable by a fine of five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A landlord or manager of the property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under legal age who consumes or possesses any alcoholic beverage in connection with a religious observance, ceremony, or rite.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or persons under legal age shall not purchase or attempt to purchase, consume, or individually or jointly have alcoholic beverages in their possession or control; except in the case of any alcoholic beverage given or dispensed to a person under legal age within a private home and with the knowledge, presence, and consent of the parent or guardian, for beverage or medicinal purposes or as administered to the person by either a physician or dentist for medicinal purposes and except to the extent that a person under legal age may handle alcoholic beverages during the regular course of the person\u8217\'3fs employment by a retail alcohol licensee, or wine or beer permittee under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is eighteen, nineteen, or twenty years of age, other than a licensee or permittee, who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ regarding the purchase of, attempt to purchase, or consumption of any alcoholic beverage, or possessing or having control of any alcoholic beverage, commits the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8C, subsection 7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A second offense shall be a simple misdemeanor punishable by a fine of five hundred dollars. In addition to any other applicable penalty, the person in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall choose between either completing a substance use disorder evaluation or the suspension of the person\u8217\'3fs motor vehicle operating privileges for a period not to exceed one year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A third or subsequent offense shall be a simple misdemeanor punishable by a fine of five hundred dollars and the suspension of the person\u8217\'3fs motor vehicle operating privileges for a period not to exceed one year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may, in its discretion, order the person who is under legal age to perform community service work under }}}{{\f5\fs18\hyphpar0\qj{section 909.3A}}}{{\f5\fs18\hyphpar0\qj{, of an equivalent value to the fine imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person who commits a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is under the age of eighteen, the matter shall be disposed of in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsections 7 and 8}}}{{\f5\fs18\hyphpar0\qj{, a person who is of legal age, other than a licensee or permittee, who sells, gives, or otherwise supplies any alcoholic beverage to a person who is under legal age in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a serious misdemeanor punishable by a minimum fine of five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be charged or prosecuted for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 3 or 4}}}{{\f5\fs18\hyphpar0\qj{ if the person is immune from charge or prosecution pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 701.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is of legal age, other than a licensee or permittee, who sells, gives, or otherwise supplies any alcoholic beverage to a person who is under legal age in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ which results in serious injury to any person commits an aggravated misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is of legal age, other than a licensee or permittee, who sells, gives, or otherwise supplies any alcoholic beverage to a person who is under legal age in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ which results in the death of any person commits a class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the expiration of two years following conviction for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ or of a similar local ordinance, a person may petition the court to expunge the conviction, and if the person has had no other criminal convictions, other than local traffic violations or simple misdemeanor violations of }}}{{\f5\fs18\hyphpar0\qj{chapter 321}}}{{\f5\fs18\hyphpar0\qj{ during the two-year period, the conviction shall be expunged as a matter of law. The court shall enter an order that the record of the conviction be expunged by the clerk of the district court. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 692.2}}}{{\f5\fs18\hyphpar0\qj{, after receipt of notice from the clerk of the district court that a record of conviction has been expunged for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the record of conviction shall be removed from the criminal history data files maintained by the department of public safety. An expunged conviction shall not be considered a prior offense for purposes of enhancement under }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ or under a local ordinance unless the new violation occurred prior to entry of the order of expungement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f43; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.043;}}}{ C46, 50, 54, 58, 62, \'a7123.43; C66, 71, \'a7123.43, 125.33; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.47}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1231, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1105, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1172, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 191, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 153, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 105, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1071, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1128, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1096, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1141, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a728 \u8211\'3f 33}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1080, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a743, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a770}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.47B}}}{{\f5\fs12\hyphpar0\qj{, 135B.34}}}{{\f5\fs12\hyphpar0\qj{, 135C.33}}}{{\f5\fs12\hyphpar0\qj{, 137C.25C}}}{{\f5\fs12\hyphpar0\qj{, 232.2}}}{{\f5\fs12\hyphpar0\qj{, 232.19}}}{{\f5\fs12\hyphpar0\qj{, 232.22}}}{{\f5\fs12\hyphpar0\qj{, 232.52}}}{{\f5\fs12\hyphpar0\qj{, 321.216B}}}{{\f5\fs12\hyphpar0\qj{, 321.284}}}{{\f5\fs12\hyphpar0\qj{, 321.284A}}}{{\f5\fs12\hyphpar0\qj{, 701.12}}}{{\f5\fs12\hyphpar0\qj{, 805.8C(7)}}}{{\f5\fs12\hyphpar0\qj{, 805.8C(8)}}}{{\f5\fs12\hyphpar0\qj{, 901C.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.47A}}}{\*\bkmkstart stylerid1_2E5_2E55_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E55_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons age eighteen, nineteen, and twenty \u8212\'3f penalty.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1997/CH0126.pdf" }{\fldrslt \cf5 \f5 \fs18{{97 Acts, ch 126, \'a754}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.47B}}}{\*\bkmkstart stylerid1_2E5_2E56_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E56_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Parental and school notification }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ persons under eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer shall make a reasonable effort to identify a person under the age of eighteen discovered consuming or to be in possession of alcoholic liquor, wine, or beer in violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.47}}}{{\f5\fs18\hyphpar0\qj{ and refer the person to juvenile court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person under the age of eighteen is discovered consuming or to be in possession of alcoholic liquor, wine, or beer, but the person is immune from prosecution under }}}{{\f5\fs18\hyphpar0\qj{section 701.12}}}{{\f5\fs18\hyphpar0\qj{, a peace officer shall make a reasonable effort to identify the person and notify a juvenile court officer of such person\u8217\'3fs consumption or possession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The juvenile court officer shall notify the person\u8217\'3fs custodial parent, legal guardian, or custodian of the violation. In addition, the juvenile court shall also make a reasonable effort to identify the elementary or secondary school which the person attends if the person is enrolled in elementary or secondary school and to notify the superintendent or the superintendent\u8217\'3fs designee of the school which the person attends, or the authorities in charge of the nonpublic school which the person attends, of the consumption or possession. A reasonable attempt to notify the person includes but is not limited to a telephone call or notice by first-class mail.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1251, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 191, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1128, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1096, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1080, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.147}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.48}}}{\*\bkmkstart stylerid1_2E5_2E57_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E57_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Seizure of false or altered driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a retail alcohol licensee or an employee of the licensee has a reasonable belief based on factual evidence that a driver\u8217\'3fs license as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1, subsection 20A}}}{{\f5\fs18\hyphpar0\qj{, or nonoperator\u8217\'3fs identification card issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.190}}}{{\f5\fs18\hyphpar0\qj{ offered by a person who wishes to purchase an alcoholic beverage at the licensed premises is altered or falsified or belongs to another person, the licensee or employee may retain the driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card. Within twenty-four hours, the license or card shall be delivered to the appropriate city or county law enforcement agency of the jurisdiction in which the licensed premises is located. When the license or card is delivered to the appropriate law enforcement agency, the licensee shall file a written report of the circumstances under which the license or card was retained. The local law enforcement agency may investigate whether a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.216}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.216A}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.216B}}}{{\f5\fs18\hyphpar0\qj{ has occurred. If an investigation is not initiated or a probable cause is not established by the local law enforcement agency, the driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card shall be delivered to the person to whom it was issued. The local law enforcement agency may forward the license or card with the report to the department of transportation for investigation, in which case, the department may investigate whether a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.216}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.216A}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321.216B}}}{{\f5\fs18\hyphpar0\qj{ has occurred. The department of transportation shall return the license or card to the person to whom it was issued if an investigation is not initiated or a probable cause is not established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon taking possession of a driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a receipt for the license or card with the date and hour of seizure noted shall be provided to the person from whom the license or card was seized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retail alcohol licensee or an employee of the licensee is not subject to criminal prosecution for, or to civil liability for damages alleged to have resulted from, the retention and delivery of a driver\u8217\'3fs license or a nonoperator\u8217\'3fs identification card which is taken pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to relieve a licensee or employee of the licensee from civil liability for damages resulting from the use of unreasonable force in obtaining the altered or falsified driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card or the driver\u8217\'3fs license or nonoperator\u8217\'3fs identification card believed to belong to another person.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1105, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1090, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79, 12}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a744, 88}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.49}}}{\*\bkmkstart stylerid1_2E5_2E58_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E58_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Miscellaneous prohibitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not sell, dispense, or give to an intoxicated person, or one simulating intoxication, any alcoholic beverage.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person other than a person required to hold a license or permit under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ who dispenses or gives an alcoholic beverage in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is not civilly liable to an injured person or the estate of a person for injuries inflicted on that person as a result of intoxication by the consumer of the alcoholic beverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly declares that }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be interpreted so that the holding of }}}{{\i\f5\fs18\hyphpar0\qj{Clark v. Mincks}}}{{\f5\fs18\hyphpar0\qj{, 364 N.W.2d 226 (Iowa 1985) is abrogated in favor of prior judicial interpretation finding the consumption of alcoholic beverages rather than the serving of alcoholic beverages as the proximate cause of injury inflicted upon another by an intoxicated person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a retail alcohol license under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and the person\u8217\'3fs agents or employees, shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly permit any gambling, except in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 99B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{99D}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{99F}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{99G}}}{{\f5\fs18\hyphpar0\qj{, or knowingly permit solicitation for immoral purposes, or immoral or disorderly conduct on the premises covered by the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sell or dispense any alcoholic beverage on the premises covered by the license, or permit its consumption thereon between the hours of 2:00 a.m. and 6:00 a.m. on any day of the week.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sell alcoholic beverages to any person on credit, except with a bona fide credit card. This provision does not apply to sales by a club to its members, to sales by a hotel or motel to bona fide registered guests, nor to retail sales by the managing entity of a convention center, civic center, or events center.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Keep on premises covered by a retail alcohol license any alcoholic liquor in any container except the original package purchased from the department, and except mixed drinks or cocktails mixed on the premises for immediate consumption on the licensed premises or as otherwise provided by this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. This prohibition does not apply to holders of a class \u8220\'3fD\u8221\'3f retail alcohol license or to alcoholic liquor delivered in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 123.46A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Mixed drinks or cocktails mixed on the premises that are not for immediate consumption may be consumed on the licensed premises subject to the requirements of this subparagraph as follows: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The mixed drinks or cocktails shall be stored, for no longer than the shortest period outlined in the minimum standards of the specific ingredients of the mixed drink or cocktail in the rules established by the department of inspections, appeals, and licensing to protect consumers from foodborne illness as described in }}}{{\f5\fs18\hyphpar0\qj{section 137F.2}}}{{\f5\fs18\hyphpar0\qj{. A licensee who mixes, stores, and allows the consumption of mixed drinks or cocktails that are not for immediate consumption shall comply with all applicable state and federal food safety laws and regulations. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mixed drink or cocktail that is not for immediate consumption shall be mixed, stored, and dispensed on the licensed premises from a labeled container in a quantity that does not exceed three gallons. A mixed drink or cocktail, or portion thereof, not consumed within the time frame outlined in subparagraph division (a) is considered expired and must be destroyed. An expired mixed drink or cocktail shall not be added to an empty container and relabeled or added to another mixed drink or cocktail. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mixed drink or cocktail that is not for immediate consumption shall at all times be in a container compliant with applicable state and federal food safety laws and regulations. The mixed drink or cocktail shall be mixed and remain stored in the same container. The mixed drink or cocktail shall be removed from the stored container to compound and fulfill a mixed drink or cocktail order upon receipt of the order for the mixed drink or cocktail or for transfer into a pourable container. The pourable container shall have affixed a label compliant with subparagraph subdivision (ii) displaying label information identical to that on the container from which the contents were poured. The expiration date and time shall not be extended by the transfer of product to a pourable container. The mixed drink or cocktail may be strained into another container when the mixed drink or cocktail is returned without delay to the labeled container from which it was strained and the container and process are compliant with applicable state and federal food safety laws and regulations. An original container of alcoholic liquor or an original container of wine shall not be used to mix, store, or dispense a mixed drink or cocktail. The mixed drink or cocktail shall not be mixed, stored, or dispensed from a container bearing an alcoholic beverage name brand. A dispensing machine which contains a mixed drink or cocktail is subject to the requirements and restrictions of this subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A label must be placed on a container when the contents of the mixed drink or cocktail are placed into the empty container. The label shall be affixed to the container in a conspicuous place. The label must legibly identify the month, day, year, and time the contents are placed into the empty container. The label must legibly identify the month, day, year, and time the contents expire. The label must legibly specify the title of the recipe used for the contents of the container. The label must legibly identify the person who prepared the contents of the container. The label must legibly identify the size of the batch within the container and be conspicuously marked with the words \u8220\'3fCONTAINS ALCOHOL\u8221\'3f. The label shall be removed from the container once the entire contents have been consumed, transferred to a pourable container, or destroyed and disposed of in accordance with applicable law. A label shall not be reused, and a removed label shall not be reapplied to a container. A new label shall be placed on the container for each prepared batch of mixed drinks or cocktails that is not for immediate consumption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mixed drink or cocktail that is not for immediate consumption shall not include added flavors and other nonbeverage ingredients containing hallucinogenic substances or added caffeine or other added stimulants including but not limited to guarana, ginseng, and taurine. A licensee is limited to utilizing alcoholic beverages in the mixed drink or cocktail that are authorized by the retail alcohol license and obtained as prescribed by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee shall keep records as to when the contents in each prepared batch of mixed drinks or cocktails are mixed in a particular container and the recipe used for that mixture. The records must include the month, day, year, and time the contents are placed into the empty container, each alcoholic beverage, including the brand and the amount utilizing the metric system, and each nonalcoholic ingredient placed in the container. The recipe must contain the title and directions for preparing the contents, the identity of the person who prepared the contents of the container, and the size of the batch. The records must include the month, day, year, and time the contents of the container are destroyed and disposed of, the identity of the person who destroyed and disposed of the contents, and the method of destruction and disposal, or a statement that the contents were entirely consumed. Records shall be maintained on the licensed premises for a period of three years and shall be open to inspection pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.33}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition, mixed drinks or cocktails mixed on the premises pursuant to this subparagraph (2) may be sold for consumption off the licensed premises as provided in and subject to the requirements of subparagraph (3).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Mixed drinks or cocktails mixed on premises covered by a class \u8220\'3fC\u8221\'3f or special class \u8220\'3fC\u8221\'3f retail alcohol license, or a special class \u8220\'3fC\u8221\'3f retail native wine license, for consumption off the licensed premises may be sold if the mixed drink or cocktail is immediately filled in a sealed container and is promptly taken from the licensed premises prior to consumption of the mixed drink or cocktail. A mixed drink or cocktail that is sold in a sealed container in compliance with the requirements of this subparagraph and rules adopted by the department shall not be deemed an open container subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 321.284}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321.284A}}}{{\f5\fs18\hyphpar0\qj{ if the sealed container is unopened and the seal has not been tampered with, and the contents of the container have not been partially removed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fImmediate consumption\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the compounding and fulfillment of a mixed drink or cocktail order upon receipt of the order for the mixed drink or cocktail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSealed container\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a vessel containing a mixed drink or cocktail that is designed to prevent consumption without removal of a tamper-evident lid, cap, or seal. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSealed container\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a container with a sipping hole or other opening for a straw, a cup made of plastic that is intended for one-time use, or a cup made of paper or polystyrene foam.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTamper-evident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a lid, cap, or seal that visibly demonstrates when a container has been opened.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reuse for packaging alcoholic liquor or wine any container or receptacle used originally for packaging alcoholic liquor or wine; or adulterate, by the addition of any substance, the contents or remaining contents of an original package of an alcoholic liquor or wine; or knowingly possess any original package which has been so reused or adulterated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employ a person under eighteen years of age in the sale or serving of alcoholic beverages for consumption on the premises where sold.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph shall not apply if the employer has on file written permission from the parent, guardian, or legal custodian of a person sixteen or seventeen years of age for the person to sell or serve alcoholic beverages for consumption on the premises where sold. However, a person sixteen or seventeen years of age shall not work in a bar as defined in }}}{{\f5\fs18\hyphpar0\qj{section 142D.2}}}{{\f5\fs18\hyphpar0\qj{. The employer shall keep a copy of the written permission on file until the person is either eighteen years of age or no longer engaged in the sale of or serving alcoholic beverages for consumption on the premises where sold. If written permission is on file in accordance with this paragraph, a person sixteen or seventeen years of age may sell or serve alcoholic beverages in a restaurant as defined in }}}{{\f5\fs18\hyphpar0\qj{section 142D.2}}}{{\f5\fs18\hyphpar0\qj{ during the hours in which the restaurant serves food.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person sixteen or seventeen years of age shall not sell or serve alcoholic beverages under this paragraph unless at least two employees eighteen years of age or older are physically present in the area where alcoholic beverages are sold or served.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person employed under this paragraph reports an incident of workplace harassment to the employer or if the employer otherwise becomes aware of such an incident, the employer shall report the incident to the employee\u8217\'3fs parent, guardian, or legal custodian and to the Iowa office of civil rights, which shall determine if any action is necessary or appropriate under }}}{{\f5\fs18\hyphpar0\qj{chapter 216}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer that employs a person under this paragraph shall require the person to attend training on prevention and response to sexual harassment upon commencing employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to a person commencing employment under this paragraph, the employer shall notify the employer\u8217\'3fs dramshop liability insurer, in a form and time period prescribed by the director, that the employer is employing a person under this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Allow any person other than the licensee or employees of the licensee to use or keep on the licensed premises any alcoholic liquor in any bottle or other container which is designed for the transporting of such beverages, except as permitted in }}}{{\f5\fs18\hyphpar0\qj{section 123.95}}}{{\f5\fs18\hyphpar0\qj{. This paragraph does not apply to the lodging quarters of a hotel or motel holding a retail alcohol license, or to holders of a class \u8220\'3fD\u8221\'3f retail alcohol license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sell, give, or otherwise supply any alcoholic beverage to any person, knowing or failing to exercise reasonable care to ascertain whether the person is under legal age, or permit any person, knowing or failing to exercise reasonable care to ascertain whether the person is under legal age, to consume any alcoholic beverage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a retail wine or beer permittee, knowingly allow the mixing or adding of alcohol or any alcoholic beverage to wine, beer, or any other beverage in or about the permittee\u8217\'3fs place of business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly permit or engage in any criminal activity on the premises covered by the license. However, the absence of security personnel on the licensed premises is insufficient, without additional evidence, to prove that criminal activity occurring on the licensed premises was knowingly permitted in violation of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. For purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpremises\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes parking lots and areas adjacent to the premises of a retail alcohol licensee authorized to sell alcoholic beverages for consumption on the licensed premises and used by patrons of the retail alcohol licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sell, give, possess, or otherwise supply a machine which is used to vaporize an alcoholic beverage for the purpose of being consumed in a vaporized form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sell, give, or otherwise supply any alcoholic beverage containing tetrahydrocannabinol, including any isomers, derivatives, or analogs of tetrahydrocannabinol, whether naturally occurring or synthesized, to any person on the licensed premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person under legal age shall not misrepresent the person\u8217\'3fs age for the purpose of purchasing or attempting to purchase any alcoholic beverage from any retail alcohol licensee. If any person under legal age misrepresents the person\u8217\'3fs age, and the licensee establishes that the licensee made reasonable inquiry to determine whether the prospective purchaser was over legal age, the licensee is not guilty of selling alcoholic beverages to a person under legal age.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f46, 1921-f114, 1921-g3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.046, 1921.115, 1921.116;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.46, 124.20, 124.21; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.49}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1275, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 32, \'a738 \u8211\'3f 42}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1002, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1211, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 67, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1175, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 245, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1172, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a7108, 121}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7142}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1155, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1033, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1128, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a734 \u8211\'3f 36}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a730, 31, 67, 68}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1114, \'a713, 16}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 155, \'a76 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a745 \u8211\'3f 50, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72419}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 44, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a7106}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 92, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7196}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1176, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 31, \'a710, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.3}}}{{\f5\fs12\hyphpar0\qj{, 123.30}}}{{\f5\fs12\hyphpar0\qj{, 123.31C}}}{{\f5\fs12\hyphpar0\qj{, 123.39}}}{{\f5\fs12\hyphpar0\qj{, 123.46A}}}{{\f5\fs12\hyphpar0\qj{, 123.50}}}{{\f5\fs12\hyphpar0\qj{, 123.50A}}}{{\f5\fs12\hyphpar0\qj{, 123.92}}}{{\f5\fs12\hyphpar0\qj{, 602.6405}}}{{\f5\fs12\hyphpar0\qj{, 805.8C(2)}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Civil liability for dispensing or sale and service to intoxicated persons; see }{{\f5\fs12\hyphpar0\qj{\'a7123.92}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For scheduled fines applicable to violations of subsection 2, paragraph h, see }{{\f5\fs12\hyphpar0\qj{\'a7805.8C(2)}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph d, subparagraphs (2), (3), and (4) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.49A}}}{\*\bkmkstart stylerid1_2E5_2E59_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E59_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Restriction on alcoholic beverages containing tetrahydrocannabinol.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A holder of a license, permit, or certificate of compliance issued by the department under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not manufacture, import, or sell at wholesale in this state an alcoholic beverage containing tetrahydrocannabinol, including any isomers, derivatives, or analogs of tetrahydrocannabinol, whether naturally occurring or synthesized.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1176, \'a719}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.50}}}{\*\bkmkstart stylerid1_2E5_2E6_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E6_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Criminal and civil penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who violates any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 123.49}}}{{\f5\fs18\hyphpar0\qj{, except}}}{{\f5\fs18\hyphpar0\qj{ section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or who fails to affix upon sale, defaces, or fails to record a keg identification label or produce a record of keg identification labels pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.138}}}{{\f5\fs18\hyphpar0\qj{, shall be guilty of a simple misdemeanor. A person who violates }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, commits a simple misdemeanor punishable as a scheduled violation under }}}{{\f5\fs18\hyphpar0\qj{section 805.8C, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The conviction of any retail alcohol licensee for a violation of any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 123.49}}}{{\f5\fs18\hyphpar0\qj{, subject to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, is grounds for the suspension or revocation of the license by the department or the local authority. However, if any retail alcohol licensee is convicted of any violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or any retail alcohol licensee, excluding a special class \u8220\'3fB\u8221\'3f or class \u8220\'3fD\u8221\'3f retail alcohol licensee, is convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the retail alcohol license shall be revoked and shall immediately be surrendered by the holder, and the bond, if any, of the license holder shall be forfeited to the department. However, the department shall retain only that portion of the bond equal to the amount the department determines the license holder owes the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any retail alcohol licensee or employee of a licensee is convicted or found in violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the director or local authority shall, in addition to criminal penalties fixed for violations by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, assess a civil penalty as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A first violation shall subject the licensee to a civil penalty in the amount of five hundred dollars. Failure to pay the civil penalty as ordered under }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ shall result in automatic suspension of the license for a period of fourteen days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A second violation within two years shall subject the licensee to a thirty-day suspension and a civil penalty in the amount of one thousand five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A third violation within three years shall subject the licensee to a sixty-day suspension and a civil penalty in the amount of one thousand five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fourth violation within three years shall result in revocation of the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date of any violation shall be used in determining the period between violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspension shall be limited to the specific license for the premises found in violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 123.40}}}{{\f5\fs18\hyphpar0\qj{, revocation shall be limited to the specific license found in violation and shall not disqualify a licensee from holding a license at a separate location.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other penalties imposed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the department shall assess a civil penalty up to the amount of five thousand dollars upon a class \u8220\'3fE\u8221\'3f retail alcohol licensee when the class \u8220\'3fE\u8221\'3f retail alcohol license is revoked for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.59}}}{{\f5\fs18\hyphpar0\qj{. Failure to pay the civil penalty as required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall result in forfeiture of the bond to the department. However, the department shall retain only that portion of the bond equal to the amount the department determines the license holder owes the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an employee of a retail alcohol licensee violates }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the licensee shall not be assessed a penalty under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and the violation shall be deemed not to be a violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for the purpose of determining the number of violations for which a penalty may be assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, if, at the time of the violation, the employee holds a valid certificate of completion of either the alcohol compliance employee training program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.50A}}}{{\f5\fs18\hyphpar0\qj{ or a third-party responsible alcohol service program approved by the director, and if the violation involves selling, giving, or otherwise supplying any alcoholic beverage to a person between the ages of eighteen and twenty years of age. A violation involving a person under the age of eighteen years of age shall not qualify for the bar against assessment of a penalty pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. A licensee may assert only once in a four-year period the bar under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ against assessment of a penalty pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, that takes place at the same place of business location.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f46, 1921-f127; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.046, 1921.132;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.46, 124.37; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.50}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1275, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1292, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 32, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7745}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1088, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 252, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1172, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1204, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 137, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1008, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 46, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 30, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a737 \u8211\'3f 39}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a751, 52, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72420 \u8211\'3f 2422}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a729 \u8211\'3f 32}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1114, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799B.3}}}{{\f5\fs12\hyphpar0\qj{, 99B.55}}}{{\f5\fs12\hyphpar0\qj{, 123.39}}}{{\f5\fs12\hyphpar0\qj{, 123.141}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{License suspension upon revocation of gambling license or amusement device registration; }{{\f5\fs12\hyphpar0\qj{\'a799B.3}}}{ and }{{\f5\fs12\hyphpar0\qj{\'a799B.55}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.50A}}}{\*\bkmkstart stylerid1_2E5_2E61_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E61_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alcohol compliance employee training program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If sufficient funding is appropriated, the department shall develop an alcohol compliance employee training program, not to exceed two hours in length for employees and prospective employees of licensees and permittees, to inform the employees about state laws and regulations regarding the sale of alcoholic beverages to persons under legal age, and compliance with and the importance of laws regarding the sale of alcoholic beverages to persons under legal age. In developing the alcohol compliance employee training program, the department may consult with stakeholders who have expertise in the laws and regulations regarding the sale of alcoholic beverages to persons under legal age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alcohol compliance employee training program shall be made available to employees and prospective employees of licensees and permittees at no cost to the employee, the prospective employee, or the licensee or permittee, and in a manner which is as convenient and accessible to the extent practicable throughout the state so as to encourage attendance. Contingent upon the availability of specified funds for provision of the program, the department shall schedule the program on at least a monthly basis and the program shall be available at a location in at least a majority of counties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon completion of the alcohol compliance employee training program, an employee or prospective employee shall receive a certificate of completion, which shall be valid for a period of two years, unless the employee or prospective employee is convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in which case the certificate shall be void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall also offer periodic continuing employee training and recertification for employees who have completed initial training and received an initial certificate of completion as part of the alcohol compliance employee training program.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 30, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72423}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.50}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.51}}}{\*\bkmkstart stylerid1_2E5_2E62_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E62_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Advertisements for alcoholic liquor, wine, or beer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No signs or other matter advertising any brand of alcoholic liquor, beer, or wine shall be erected or placed upon the outside of any premises occupied by a licensee or permittee authorized to sell alcoholic liquor, beer, or wine at retail. However, signs or other advertising matter may be erected or placed inside the premises, inside a fence or similar enclosure which wholly or partially surrounds the premises, or inside a window facing outward from the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f47; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.047;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.47; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.51}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7746}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 22, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.52}}}{\*\bkmkstart stylerid1_2E5_2E63_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E63_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person not expressly authorized by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to deal in alcoholic liquors shall within the state keep for sale or offer for sale anything which is capable of being mistaken for a package containing alcoholic liquor and is either labeled or branded with the name of any kind of alcoholic liquor, whether the same contains any alcoholic liquor or not.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f48; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.048;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.48; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.52}}}{]}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{123.53 through 123.55}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.56}}}{\*\bkmkstart stylerid1_2E5_2E65_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E65_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public safety nuisances }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public safety nuisance exists at a licensed premises for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ when it is established by clear and convincing evidence that an owner, manager, employee, contemporaneous patron, or guest of the licensed premises commits any of the following acts on the licensed premises or in any parking lots or areas, including but not limited to public rights of way, adjacent to the licensed premises:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unlawfully discharges a firearm or uses an offensive weapon, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 724.1}}}{{\f5\fs18\hyphpar0\qj{, regardless of whether it inflicts injury or death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assaults another person with a dangerous weapon as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.7}}}{{\f5\fs18\hyphpar0\qj{ resulting in injury or death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Engages in a riot as defined in }}}{{\f5\fs18\hyphpar0\qj{section 723.1}}}{{\f5\fs18\hyphpar0\qj{ on at least three separate days within any twelve-month period in which a peace officer responded for purposes of dispersing the participants in the riot. A person who willingly joins in or remains a part of a riot need not be the same person for each riot incident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the county attorney or city attorney for the county or city where the licensed premises is located has reason to believe a public safety nuisance that constitutes a serious threat to the public safety exists, the county attorney or city attorney, or an attorney acting at the direction of the county attorney or city attorney, may file a suit in equity in district court without bond seeking abatement of a public safety nuisance occurring at a premises licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ pursuant to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon filing a suit in equity in district court pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the county attorney or city attorney shall notify the director of the action. Upon receiving notice, the director shall issue an order reducing the hours during which alcoholic beverages may be sold or consumed at retail on the licensed premises to between 6:00 a.m. and 10:00 p.m. each day of the week during the pendency of the action in equity. The county attorney or city attorney shall notify the director of any final action or judgment entered resulting from the action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In an action seeking abatement of a public safety nuisance as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, evidence of other current violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may be received by the court and considered in determining the remedial provisions of any abatement order. In addition, evidence of prior sanctions, violations of law, nuisance behavior, or general reputation relating to the licensed premises may be admissible in determining the reasonableness of remedial provisions of an abatement order. However, evidence of a prior conviction of the licensee, managers, employees, or contemporaneous patrons and guests is not necessary for purposes of considering or issuing an abatement order under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. In an action under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the director may submit to the court a report as evidence on behalf of the department regarding the compliance history of the licensee or permittee for consideration by the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the district court finds that a public safety nuisance exists, the court may enter judgment declaring the existence of the nuisance and order such remedial action as the court determines reasonable to abate the nuisance. The abatement order may take the form of an injunction. The duration of an abatement order may be up to two years. Remedial action may include but is not limited to temporary closure of the licensed premises, revocation of the license for such period of time as is consistent with }}}{{\f5\fs18\hyphpar0\qj{section 123.40}}}{{\f5\fs18\hyphpar0\qj{, required change in business practice or operations, or posting of a bond. If a bond is ordered and posted, the bond shall be subject to forfeiture, in whole or in part, for any further actions contrary to the abatement order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flicensed premises\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a premises where alcoholic beverages are authorized to be sold for consumption on the licensed premises and where the serving of food is only incidental to the consumption of alcoholic beverages on the premises.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1100, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72424}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a733}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.57}}}{\*\bkmkstart stylerid1_2E5_2E66_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E66_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Examination of accounts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The financial condition and transactions of all offices, departments, warehouses, and depots concerning the alcohol beverage control activities of the department shall be examined at least once each year by the state auditor and at shorter periods if requested by the director, governor, commission, or the general assembly\u8217\'3fs standing committees on government oversight.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f57; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.057;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.57}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1246, \'a7749}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 30, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72425}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.58}}}{\*\bkmkstart stylerid1_2E5_2E67_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E67_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Auditing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All provisions of }{{\f5\fs18\hyphpar0\qj{sections 11.6}}}{, }{{\f5\fs18\hyphpar0\qj{11.11}}}{, }{{\f5\fs18\hyphpar0\qj{11.14}}}{, }{{\f5\fs18\hyphpar0\qj{11.21}}}{, }{{\f5\fs18\hyphpar0\qj{11.31}}}{, and }{{\f5\fs18\hyphpar0\qj{11.41}}}{, relating to auditing of financial records of governmental subdivisions which are not inconsistent with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are applicable to the department and its offices, warehouses, and depots under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f58; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.058;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.58}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1246, \'a7750}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 264, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 75, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72426}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.59}}}{\*\bkmkstart stylerid1_2E5_2E68_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E68_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bootlegging }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who, acting individually, or through another acting for the person, keeps or carries on the person, or in a vehicle, or leaves in a place for another to secure, any alcoholic liquor, wine, or beer, with intent to sell or dispense the liquor, wine, or beer, in violation of law, or who, within this state, in any manner, directly or indirectly, solicits, takes, or accepts an order for the purchase, sale, shipment, or delivery of alcoholic liquor, wine, or beer in violation of law, or aids in the delivery and distribution of alcoholic liquor, wine, or beer so ordered or shipped, or who in any manner procures for, sells, or gives alcoholic liquor, wine, or beer to a person under legal age, for any purpose except as authorized and permitted in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, is a bootlegger.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a first offense, a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a second or subsequent offense, a serious misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7924 \u8211\'3f 928; R60, \'a71559, 1562, 1563, 1583, 1587; C73, \'a71523, 1540 \u8211\'3f 1542, 1555; C97, \'a72382; SS15, \'a72382, 2461-a; C24, 27, 31, \'a71927; C35, \'a71921-f59, 1927; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.059, 1927;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.59, 125.7; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.59}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 67, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1096, \'a73, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.50}}}{{\f5\fs12\hyphpar0\qj{, 123.70}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.60}}}{\*\bkmkstart stylerid1_2E5_2E69_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E69_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nuisances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The premises where the unlawful manufacture or sale, or keeping with intent to sell, use or give away, of alcoholic liquors, wine, or beer is carried on, and any vehicle or other means of conveyance used in transporting liquor, wine, or beer in violation of law, and the furniture, fixtures, vessels and contents, kept or used in connection with such activities are nuisances and shall be abated as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7935; R60, \'a71564; C73, \'a71543; C97, \'a72384; C24, 27, 31, \'a71929; C35, \'a71921-f60, 1929; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.060, 1929;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.60, 125.9; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.60}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a751}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.61}}}{{\f5\fs12\hyphpar0\qj{, 123.88}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Nuisances in general, }{{\f5\fs12\hyphpar0\qj{chapter 657}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.61}}}{\*\bkmkstart stylerid1_2E5_2E7_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E7_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who erects, establishes, or uses any premises for any of the purposes prohibited in }{{\f5\fs18\hyphpar0\qj{section 123.60}}}{, is guilty of nuisance and shall be subject to the general penalties provided by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7935; R60, \'a71564; C73, \'a71543; C97, \'a72384; C24, 27, 31, \'a71930; C35, \'a71921-f61, 1930; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.061, 1930;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.61, 125.10; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.61}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.62}}}{\*\bkmkstart stylerid1_2E5_2E71_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E71_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Actions to enjoin nuisances shall be brought in equity in the name of the state by the county attorney who shall prosecute the same to judgment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71564; C73, \'a71543; C97, \'a72405, 2406; S13, \'a72406; SS15, \'a72405; C24, 27, 31, \'a72017; C35, \'a71921-f62, 2017; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.062, 2017;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.62, 128.1; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.62}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.756(24)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.63}}}{\*\bkmkstart stylerid1_2E5_2E72_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E72_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Temporary writ.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In an action to enjoin a nuisance, the court shall, upon the presentation of a petition, allow a temporary writ of injunction without bond, if the petitioner provides evidence to the satisfaction of the court, in the form of affidavits, depositions, oral testimony, or otherwise, that the nuisance complained of exists.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71564; C73, \'a71543; C97, \'a72405; SS15, \'a72405; C24, 27, 31, \'a72018; C35, \'a71921-f63, 2018; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.063, 2018;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.63, 128.2; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.63}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a758}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.64}}}{\*\bkmkstart stylerid1_2E5_2E73_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E73_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Three days\u8217\'3f notice in writing shall be given the defendant of the hearing of the application, and if then continued at the defendant\u8217\'3fs instance the writ as petitioned for shall be granted as a matter of course.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72405; SS15, \'a72405; C24, 27, 31, \'a72019; C35, \'a71921-f64, 2019; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.064, 2019;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.64, 128.3; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.64}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1168, \'a726}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.65}}}{\*\bkmkstart stylerid1_2E5_2E74_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E74_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope of injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When an injunction has been granted, it shall be binding upon the defendant throughout the state and any violation of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ anywhere within the state shall be punished as a contempt as provided in }{{\f5\fs18\hyphpar0\qj{section 123.68}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72405; SS15, \'a72405; C24, 27, 31, \'a72020; C35, \'a71921-f65, 2020; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.065, 2020;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.65, 128.4; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.65}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a759}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.66}}}{\*\bkmkstart stylerid1_2E5_2E75_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E75_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trial of action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any action brought to enjoin a nuisance or to establish a violation of the injunction shall be accorded priority over other business pending before the district court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72406; S13, \'a72406; C24, 27, 31, \'a72021; C35, \'a71921-f66, 2021; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.066, 2021;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.66, 128.5; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.66}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a760}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.67}}}{\*\bkmkstart stylerid1_2E5_2E76_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E76_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General reputation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In all actions to enjoin a nuisance or to establish a violation of the injunction, evidence of the general reputation of the premises described in the petition or information shall be admissible for the purpose of proving the existence of the nuisance or the violation of the injunction.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72406; S13, \'a72406; C24, 27, 31, \'a72022; C35, \'a71921-f67, 2022; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.067, 2022;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.67, 128.6; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.67}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.68}}}{\*\bkmkstart stylerid1_2E5_2E77_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E77_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contempt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In the case of a violation of any injunction granted under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the court may summarily try and punish the defendant pursuant to the general penalties provided by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The proceedings shall be commenced by filing with the clerk of the court an information under oath setting out the alleged facts constituting such violation, upon which the court shall cause a warrant to issue under which the defendant shall be arrested.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72407; SS15, \'a72407; C24, 27, 31, \'a72027; C35, \'a71921-f68, 2027; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.068, 2027;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.68, 128.13; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.68}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.65}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.69}}}{\*\bkmkstart stylerid1_2E5_2E78_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E78_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trial of contempt action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The trial shall be as in equity and may be had upon depositions, or either party may demand the production and oral examination of the witnesses.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, SS15, \'a72407; C24, 27, 31, \'a72028; C35, \'a71921-f69, 2028; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.069, 2028;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.69, 128.14; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.69}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.70}}}{\*\bkmkstart stylerid1_2E5_2E79_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E79_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Injunction against bootlegger.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A bootlegger as defined in }{{\f5\fs18\hyphpar0\qj{section 123.59}}}{ may be restrained by injunction from doing or continuing to do any of the acts prohibited herein, and all the proceedings for injunctions, temporary and permanent, and for punishments for violation of the same as prescribed herein, shall be applicable to such person, and the fact that an offender has no known or permanent place of business, or base of supplies, or quits the business after the commencement of an action, shall not prevent a temporary or permanent injunction, as the case may be, from issuing.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72461-b; C24, 27, 31, \'a72031; C35, \'a71921-f71, 2031; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.071, 2031;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.71, 128.17; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.70}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a743}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.71}}}{\*\bkmkstart stylerid1_2E5_2E8_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E8_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conditions on injunction proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A bootlegger injunction proceeding, as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, shall not be maintained unless it is shown to the court that efforts in good faith have been made to discover the base of supplies or place where the defendant charged as a bootlegger conducts an unlawful business or receives or manufactures the alcoholic liquor, wine, or beer, which the defendant is charged with bootlegging.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, \'a72031-a1; C35, \'a71921-f72, 2031-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.072, 2031.1;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.72, 128.18; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.71}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a752}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.72}}}{\*\bkmkstart stylerid1_2E5_2E81_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E81_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Order of abatement of nuisance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the existence of a nuisance is established in a civil or criminal action, an order of abatement shall be entered as a part of the judgment in the case. The order shall direct the confiscation of all alcoholic liquor, wine, or beer by the state; the removal from the premises involved of all fixtures, furniture, vessels, or movable property used in any way in conducting the unlawful business; the sale of all removed property as well as any vehicle or other means of conveyance which has been abated, the sale to be conducted in the manner provided for the sale of chattels under execution; and the effective closing of the premises against use for the purpose of manufacture, sale, or consumption of alcoholic liquor, wine, or beer for a period of one year, unless sooner released by the court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7935; R60, \'a71559; C73, \'a71523, 1543; C97, \'a72408; C24, 27, 31, \'a72032; C35, \'a71921-f73, 2032; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.073, 2032;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.73, 128.19; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.72}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a753}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.73}}}{\*\bkmkstart stylerid1_2E5_2E82_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E82_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of abated premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any person uses a premises closed pursuant to an abatement order in violation of such order the person shall be punished for contempt as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72408; C24, 27, 31, \'a72033; C35, \'a71921-f74, 2033; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.074, 2033;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.74, 128.20; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.74}}}{\*\bkmkstart stylerid1_2E5_2E83_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E83_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For removing and selling the movable property, the officer shall be entitled to charge and receive the same fees as the officer would for levying upon and selling like property on execution; and for closing the premises and keeping them closed a reasonable sum shall be allowed by the court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72408; C24, 27, 31, \'a72034; C35, \'a71921-f75, 2034; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.075, 2034;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.75, 128.21; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.74}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.75}}}{\*\bkmkstart stylerid1_2E5_2E84_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E84_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Proceeds of sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The proceeds of the sale of personal property in abatement proceedings shall be applied first in payment of the costs of the action and abatement, and second to the satisfaction of any fine and costs adjudged against the proprietor of the premises and keeper of said nuisance, and the balance, if any, shall be paid to the defendant.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72409; C24, 27, 31, \'a72035; C35, \'a71921-f76, 2035; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.076, 2035;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.76, 128.22; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.75}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.76}}}{\*\bkmkstart stylerid1_2E5_2E85_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E85_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abatement of nuisance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the owner of the abated premises appears and pays all costs of the proceeding and files a bond with sureties to be approved by the clerk in the full value of the property, to be ascertained by the court, conditioned that the owner will immediately abate the nuisance and prevent the same from being established or kept on such premises within a period of one year thereafter, the court may order such premises to be delivered to the owner and cancel the order of abatement so far as it may relate to the property.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72410; S13, \'a72410; C24, 27, 31, \'a72036; C35, \'a71921-f77, 2036; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.077, 2036;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.77, 128.23; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.76}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.78}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(30)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.77}}}{\*\bkmkstart stylerid1_2E5_2E86_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E86_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abatement before judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the action is in equity and the owner of the premises pays the costs of the action and files the bond prior to the entry of judgment and the abatement order, such action shall be abated as to the premises only.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72410; S13, \'a72410; C24, 27, 31, \'a72037; C35, \'a71921-f78, 2037; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.078, 2037;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.78, 128.24; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.77}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.78}}}{\*\bkmkstart stylerid1_2E5_2E87_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E87_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Existing liens.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The release of the property under the provisions of either }{{\f5\fs18\hyphpar0\qj{section 123.76}}}{ or }{{\f5\fs18\hyphpar0\qj{123.77}}}{ shall not release it from any judgment lien, penalty, or liability, to which it may be subject by law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72410; S13, \'a72410; C24, 27, 31, \'a72038; C35, \'a71921-f79, 2038; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.079, 2038;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.79, 128.25; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.78}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.79}}}{\*\bkmkstart stylerid1_2E5_2E88_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E88_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abatement bond a lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Undertakings of bonds for abatement shall immediately after filing by the clerk of the district court be docketed and entered upon the lien index as required for judgments in civil cases, and from the time of such entries shall be liens upon real estate of the persons executing the same, with like effect as judgments in civil actions.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72039; C35, \'a71921-f80, 2039; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.080, 2039;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.80, 128.26; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.79}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.84}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(30)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.80}}}{\*\bkmkstart stylerid1_2E5_2E89_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E89_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Attested copies filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Attested copies of such undertakings may be filed in the office of the clerk of the district court of the county in which the real estate is situated in the same manner and with like effect as attested copies of judgments, and shall be immediately docketed and indexed in the same manner.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72040; C35, \'a71921-f81, 2040; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.081, 2040;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.81, 128.27; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.80}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.8102(30)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.81}}}{\*\bkmkstart stylerid1_2E5_2E9_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E9_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Forfeiture of bond.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the owner of a property who has filed an abatement bond as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ fails to abate the alcoholic liquor, wine, or beer nuisance on the premises covered by the bond, or fails to prevent the maintenance of any alcoholic liquor, wine, or beer nuisance on the premises at any time within a period of one year after entry of the abatement order, the court shall, after a hearing in which such fact is established, direct an entry of the violation of the terms of the owner\u8217\'3fs bond to be made on the record and the undertaking of the owner\u8217\'3fs bond shall be forfeited.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72041; C35, \'a71921-f82, 2041; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.082, 2041;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.82, 128.28; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.81}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a742}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.82}}}{\*\bkmkstart stylerid1_2E5_2E91_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E91_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A proceeding to forfeit an abatement bond shall be commenced by filing with the clerk of the court, by the county attorney of the county where the bond is filed, an application under oath to forfeit such bond, setting out the alleged facts constituting the violation of the terms of the bond, upon which the court shall direct by order attached to such application that a notice be issued by the clerk of the district court directed to the principal and sureties on the bond to appear at a certain date fixed to show cause why such bond should not be forfeited and judgment entered for the penalty fixed therein.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72042; C35, \'a71921-f83, 2042; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.083, 2042;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.83, 128.29; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.82}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.83}}}{{\f5\fs12\hyphpar0\qj{, 123.84}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.83}}}{\*\bkmkstart stylerid1_2E5_2E92_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E92_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Method of trial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The trial of an action filed pursuant to }{{\f5\fs18\hyphpar0\qj{section 123.82}}}{ shall be to the court and as in equity, and be governed by the same rules of evidence as contempt proceedings.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72043; C35, \'a71921-f84, 2043; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.084, 2043;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.84, 128.30; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.83}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a744}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.84}}}{\*\bkmkstart stylerid1_2E5_2E93_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E93_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judgment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the court after a hearing in an action filed pursuant to }{{\f5\fs18\hyphpar0\qj{section 123.82}}}{ finds an alcoholic liquor, wine, or beer nuisance has been maintained on the premises covered by the abatement bond and that alcoholic liquor, wine, or beer has been sold or kept for sale on the premises contrary to law within one year from the date of the giving of the bond, then the court shall order the forfeiture of the bond and enter judgment for the full amount of the bond against the principal and sureties on the bond. The lien on the real estate created pursuant to }{{\f5\fs18\hyphpar0\qj{section 123.79}}}{ shall be decreed foreclosed and the court shall provide for a special and general execution for the enforcement of the decree and judgment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72044; C35, \'a71921-f85, 2044; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.085, 2044;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.85, 128.31; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.84}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.85}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.85}}}{\*\bkmkstart stylerid1_2E5_2E94_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E94_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Appeal from a judgment and decree entered pursuant to }{{\f5\fs18\hyphpar0\qj{section 123.84}}}{ may be taken as in equity cases and the cause be triable de novo except that if the state appeals it need not file an appeal or supersedeas bond.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72045; C35, \'a71921-f86, 2045; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.086, 2045;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.86, 128.32; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.85}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a746}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.86}}}{\*\bkmkstart stylerid1_2E5_2E95_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E95_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County attorney to prosecute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be the duty of the county attorney to prosecute in the name of the state all forfeitures of abatement bonds and the foreclosures of same.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72047; C35, \'a71921-f87, 2047; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.087, 2047;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.87, 128.34; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.86}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.756(24)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.87}}}{\*\bkmkstart stylerid1_2E5_2E96_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E96_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prompt service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be a simple misdemeanor for any peace officer to delay service of original notices, writs of injunction, writs of abatement, or warrants for contempt in any equity case filed for injunction or abatement by the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72049; C35, \'a71921-f88, 2049; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.088, 2049;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.88, 128.36; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.87}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.88}}}{\*\bkmkstart stylerid1_2E5_2E97_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E97_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{On the issue whether a party knew or ought to have known of a nuisance described under }{{\f5\fs18\hyphpar0\qj{section 123.60}}}{, evidence of the general reputation of the place shall be admissible.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, \'a72053; C35, \'a71921-f89, 2053; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.089, 2053;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.89, 128.40; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.88}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 30, \'a747}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.89}}}{\*\bkmkstart stylerid1_2E5_2E98_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E98_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Counts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Informations or indictments under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may allege any number of violations of its provisions by the same party, but the several charges must be set out in separate counts, and the accused may be convicted and punished upon each one as on separate informations or indictments, and a separate judgment shall be rendered on each count under which there is a finding of guilty.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7931; R60, \'a71562; C73, \'a71540; C97, \'a72425; C24, 27, 31, \'a71953; C35, \'a71921-f90, 1953; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.090, 1953;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.90, 126.8; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.89}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.90}}}{\*\bkmkstart stylerid1_2E5_2E99_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E99_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalties generally.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless other penalties are provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, any person, except a person under legal age, who violates any of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or who makes a false statement concerning any material fact in submitting an application for a permit or license, shall be guilty of a serious misdemeanor. Any person under legal age who violates any of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall upon conviction be guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f91, 1921-f127; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.091, 1921.132;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7123.91, 124.37; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.90}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a756}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.91}}}{\*\bkmkstart stylerid1_2E5_2E1_30_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Second and subsequent conviction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless otherwise provided by law, a person who has been convicted in a criminal action in any court of record of a violation of a provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, except for a violation of }{{\f5\fs18\hyphpar0\qj{section 123.46}}}{, or a provision of the laws of the United States or of any other state relating to alcoholic liquors, wine, or beer, and who is thereafter convicted of a subsequent criminal offense against any provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is guilty of the following offenses:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the second conviction, a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the third and each subsequent conviction, an aggravated misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71561, 1563, 1577; C73, \'a71525, 1538, 1540, 1542, 1559; SS15, \'a72461-m; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1964;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.19; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.91}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 140, \'a742}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.92}}}{\*\bkmkstart stylerid1_2E5_2E1_301_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_301_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil liability for dispensing or sale and service of any alcoholic beverage (Dramshop Act) \u8212\'3f liability insurance \u8212\'3f underage persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the limitation amount specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if applicable, any third party who is not the intoxicated person who caused the injury at issue and who is injured in person or property or means of support by an intoxicated person or resulting from the intoxication of a person, has a right of action for damages actually sustained, severally or jointly against any licensee or permittee, whether or not the license or permit was issued by the department or by the licensing authority of any other state, who sold and served any alcoholic beverage directly to the intoxicated person, provided that the person was visibly intoxicated at the time of the sale or service.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the injury was proximately caused by an intoxicated person, a permittee or licensee may establish as an affirmative defense that the intoxication did not contribute to the injurious action of the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total amount recoverable by each plaintiff in any civil action for noneconomic damages for personal injury, whether in tort, contract, or otherwise, against a licensee or permittee, shall be limited to two hundred fifty thousand dollars for any injury or death of a person, unless the jury determines that there is a substantial or permanent loss or impairment of a bodily function, substantial disfigurement, or death, which warrants a finding that imposition of such a limitation would deprive the plaintiff of just compensation for the injuries sustained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every retail alcohol licensee, except a class \u8220\'3fB\u8221\'3f, special class \u8220\'3fB\u8221\'3f, or class \u8220\'3fE\u8221\'3f retail alcohol licensee, shall furnish proof of financial responsibility by the existence of a liability insurance policy in an amount determined by the department. If an insurer provides dramshop liability insurance at a new location to a licensee or permittee who has a positive loss experience at other locations for which such insurance is provided by the insurer, and the insurer bases premium rates at the new location on the negative loss history of the previous licensee at that location, the insurer shall examine and consider adjusting the premium for the new location not less than thirty months after the insurance is issued, based on the loss experience of the licensee at that location during that thirty-month period of time.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A dramshop liability insurance policy may be written on an aggregate limit basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of dramshop liability insurance is to provide protection for members of the public who experience damages as a result of licensees serving patrons any alcoholic beverage to a point that reaches or exceeds the standard set forth in law for liability. Minimum coverage requirements for such insurance are not for the purpose of making the insurance affordable for all licensees regardless of claims experience. A dramshop liability insurance policy obtained by a licensee shall meet the minimum insurance coverage requirements as determined by the department and is a mandatory condition for holding a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 123.49, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, any person who is injured in person or property or means of support by an intoxicated person who is under legal age or resulting from the intoxication of a person who is under legal age, has a right of action for all damages actually sustained, severally or jointly, against a person who is not a licensee and who dispensed or gave any alcoholic beverage to the intoxicated underage person when the nonlicensee who dispensed or gave the alcoholic beverage to the underage person knew or should have known the underage person was intoxicated, or who dispensed or gave any alcoholic beverage to the underage person to a point where the nonlicensee knew or should have known that the underage person would become intoxicated.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the injury was caused by an intoxicated person who is under legal age, a person who is not a licensee and who dispensed or gave the alcoholic beverage to the underage person may establish as an affirmative defense that the intoxication did not contribute to the injurious action of the underage person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdispensed\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fgave\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the act of physically presenting a receptacle containing any alcoholic beverage to the underage person whose actions or intoxication results in the sustaining of damages by another person. However, a person who dispenses or gives any alcoholic beverage to an underage person shall only be liable for any damages if the person knew or should have known that the underage person was under legal age.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a71557; C97, \'a72418; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2055;}}}{ C46, 50, 54, 58, 62, \'a7129.2; C66, 71, \'a7123.95, 129.2; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.92}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a757}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1211, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1158, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1136, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 126, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 128, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 124, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1008, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a745 \u8211\'3f 47}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1090, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a718, 51}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a753, 54, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72427, 2428}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.3}}}{{\f5\fs12\hyphpar0\qj{, 123.10}}}{{\f5\fs12\hyphpar0\qj{, 123.95}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Minimum coverage requirements evaluation, see }{{\f5\fs12\hyphpar0\qj{\'a7505.33}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.93}}}{\*\bkmkstart stylerid1_2E5_2E1_302_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_302_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitation of action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Within six months of the occurrence of an injury, the injured person shall give written notice to the licensee or permittee or such licensee\u8217\'3fs or permittee\u8217\'3fs insurance carrier of the person\u8217\'3fs intention to bring an action under }{{\f5\fs18\hyphpar0\qj{this section}}}{, indicating the time, place and circumstances causing the injury. Such six months\u8217\'3f period shall be extended if the injured party is incapacitated at the expiration thereof or unable, through reasonable diligence, to discover the name of the licensee, permittee, or person causing the injury or until such time as such incapacity is removed or such person has had a reasonable time to discover the name of the licensee, permittee or person causing the injury.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.93}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.94}}}{\*\bkmkstart stylerid1_2E5_2E1_303_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_303_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inurement of action prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No right of action for contribution or indemnity shall accrue to any insurer, guarantor or indemnitor of any intoxicated person for any act of such intoxicated person against any licensee or permittee as defined in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.94}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.95}}}{\*\bkmkstart stylerid1_2E5_2E1_304_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_304_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Premises must be licensed \u8212\'3f exception as to conventions and social gatherings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not allow the dispensing or consumption of alcoholic liquor, except wines and beer, in any establishment unless the establishment is licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of an annual class \u8220\'3fC\u8221\'3f retail alcohol license may act as the agent of a private social host for the purpose of providing and serving alcoholic beverages as part of a food catering service for a private social gathering in a private place, provided the licensee has applied for and been granted a catering privilege by the department. The holder of an annual special class \u8220\'3fC\u8221\'3f retail alcohol license shall not act as the agent of a private social host for the purpose of providing and serving wine and beer as part of a food catering service for a private social gathering in a private place. An applicant for a class \u8220\'3fC\u8221\'3f retail alcohol license shall state on the application for the license that the licensee intends to engage in catering food and alcoholic beverages for private social gatherings and the catering privilege shall be noted on the license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The private social host or the licensee shall not solicit payment of any kind, including donations, for the food or alcoholic beverages from the guests, and the alcoholic beverages and food shall be served without cost to the guests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 123.92}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a retail alcohol licensee who acts in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ when the retail alcohol licensee is providing and serving food and alcoholic beverages as an agent of a private social host at a private social gathering in a private place which is not on the licensed premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee who engages in catering food and alcoholic beverages for private social gatherings shall maintain a record on the licensed premises which includes the name and address of the host of the private social gathering, and the date for which catering was provided. The record maintained pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be open to inspection pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.30, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, during normal business hours of the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, bona fide conventions or meetings may bring their own legal liquor onto the licensed premises if the liquor is served to delegates or guests without cost. All other provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be applicable to such premises. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall have no application to private social gatherings of friends or relatives in a private home or private place which is not of a commercial nature nor where goods or services may be purchased or sold nor any charge or rent or other thing of value is exchanged for the use of such premises for any purpose other than for sleeping quarters.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, \'a7123.96; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.95}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a755, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72429}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a77D.16}}}{{\f5\fs12\hyphpar0\qj{, 123.49}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.96}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.97}}}{\*\bkmkstart stylerid1_2E5_2E1_306_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_306_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Covered into general fund.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a787, 88}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.98}}}{\*\bkmkstart stylerid1_2E5_2E1_307_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_307_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Labeling shipments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any common carrier or for any person to transport or convey by any means, whether for compensation or not, within this state, any alcoholic liquor, wine, or beer, unless the vessel or other package containing such alcoholic liquor, wine, or beer shall be plainly and correctly identified, showing the quantity and kind of alcoholic liquor, wine, or beer contained therein, the name of the party to whom they are to be delivered, and the name of the shipper, or unless such information is shown on a bill of lading or other document accompanying the shipment. No person shall be authorized to receive or keep such alcoholic liquor, wine, or beer unless the same be marked or labeled as required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The violation of any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by any common carrier, or any agent or employee of any carrier, or by any person, shall be punished under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any alcoholic liquor, wine, or beer conveyed, carried, transported, or delivered in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, whether in the hands of the carrier or someone to whom they shall have been delivered, shall be subject to seizure and condemnation, as alcoholic liquor, wine, or beer kept for illegal sale.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72421; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1936, 1938;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.16, 125.18; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.98}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1060, \'a748}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.99}}}{\*\bkmkstart stylerid1_2E5_2E1_308_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_308_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{False statements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person commits a simple misdemeanor if the person, for the purpose of procuring the shipment, transportation, or conveyance of any alcoholic liquor, wine, or beer within this state in violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, does any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Makes to any person, company, corporation, or common carrier, or to any agent thereof, any false statements as to the character or contents of any box, barrel, or other vessel or package containing such alcoholic liquor, wine, or beer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refuses to give correct and truthful information as to the contents of any such box, barrel, or other vessel or package so sought to be transported or conveyed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Falsely labels, brands, or marks a box, barrel, or other vessel or package in order to conceal the fact that the same contains alcoholic liquor, wine, or beer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By any device or concealment procures or attempts to procure the conveyance or transportation of alcoholic liquor, wine, or beer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72420; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1934;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.14; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.99}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a745}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.100}}}{\*\bkmkstart stylerid1_2E5_2E1_309_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E1_309_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Packages in transit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any peace officer of the county under process or warrant to the peace officer directed shall have the right to open any box, barrel, or other vessel or package for examination, if the peace officer has reasonable ground for believing that it contains alcoholic liquor, wine, or beer, either before or while the same is being so transported or conveyed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72420; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1935;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.15; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.100}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a750}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.101}}}{\*\bkmkstart stylerid1_2E5_2E11_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E11_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record of shipments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be the duty of all common carriers, or corporations, or persons who shall for hire carry any alcoholic liquor, wine, or beer into the state, or from one point to another within the state, for the purpose of delivery, and who shall deliver such alcoholic liquor, wine, or beer to any person, company, or corporation, to maintain a proper record of the name of the consignor of each shipment of alcoholic liquor, wine, or beer from where shipped, the date of arrival, the quantity and kind of alcoholic liquor, wine, or beer, so far as disclosed by lettering on the package or by the carrier\u8217\'3fs records, and to whom and where consigned, and the date delivered.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72421-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1940;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.20; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.101}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a751}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.102}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.102}}}{\*\bkmkstart stylerid1_2E5_2E111_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E111_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspection of shipping records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The records required by }{{\f5\fs18\hyphpar0\qj{section 123.101}}}{ shall, during business hours, be open to inspection by any peace or law enforcing officer. It is a simple misdemeanor to refuse such inspection.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72421-c, -d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1941;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.21; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.102}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a728}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.103}}}{\*\bkmkstart stylerid1_2E5_2E112_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E112_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record and certification upon delivery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The full name and residence or place of business of the consignee of a shipment billed in whole or in part as alcoholic liquor, wine, or beer, shall be properly recorded at the time of delivery and the consignee shall certify that the alcoholic liquor, wine, or beer is for the consignee\u8217\'3fs own lawful purposes.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72421-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1942;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.22; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.103}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a752}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.104}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.104}}}{\*\bkmkstart stylerid1_2E5_2E113_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E113_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unlawful delivery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is a simple misdemeanor for any corporation, common carrier, person, or any agent or employee thereof:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To deliver any alcoholic liquor, wine, or beer to any person other than to the consignee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To deliver any alcoholic liquor, wine, or beer without having the same properly recorded as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.103}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To deliver any alcoholic liquor, wine, or beer where there is reasonable ground to believe that such alcoholic liquor, wine, or beer is intended for unlawful use.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72421-c1; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1943;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.23; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.104}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a753}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.105}}}{\*\bkmkstart stylerid1_2E5_2E114_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E114_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Immunity from damage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In no case shall any corporation, common carrier, person, or the agent thereof, be liable in damages for complying with any requirements of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72421-c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1944;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.24; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.105}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.106}}}{\*\bkmkstart stylerid1_2E5_2E115_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E115_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Federal statutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The requirements of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ relative to the shipment and delivery of alcoholic liquor, wine, or beer and the records to be kept thereof shall be construed in harmony with federal statutes relating to interstate commerce in such liquor, wine, or beer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72421-e; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1945;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.25; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.106}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a754}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.107}}}{\*\bkmkstart stylerid1_2E5_2E116_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E116_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unnecessary allegations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any indictment or information under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, it shall not be necessary:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To set out exactly the kind or quantity of alcoholic liquor, wine, or beer manufactured, sold, given in evasion of the statute, or kept for sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To set out the exact time of manufacture, sale, gift, or keeping for sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To negative any exceptions contained in the statute creating or defining the offense, which may be proper ground of defense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proof of the violation by the accused of any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the substance of which violation is briefly set forth, within the time mentioned in the indictment or information, shall be sufficient to convict such person.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71569; C73, \'a71549; C97, \'a72424; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1952;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.7; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.107}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a746}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.108}}}{\*\bkmkstart stylerid1_2E5_2E117_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E117_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Second conviction defined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The second or subsequent convictions provided for in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be convictions on separate informations or indictments, and, unless shown in the information or indictment, the charge shall be held to be for a first offense.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71562; C73, \'a71540; C97, \'a72425; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1955;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.10; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.108}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.109}}}{\*\bkmkstart stylerid1_2E5_2E118_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E118_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record of conviction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{On the trial of any cause in which the accused is charged with a second or subsequent offense, a duly authenticated copy of the former judgment in any court in which such conviction was had shall be competent evidence of such former conviction.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72461-n; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1956;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.11; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.109}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.110}}}{\*\bkmkstart stylerid1_2E5_2E119_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E119_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Proof of sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall not be necessary in every case to prove payment in order to prove a sale within the meaning and intent of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71569; C73, \'a71549; C97, \'a72424; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1957;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.12; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.110}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.111}}}{\*\bkmkstart stylerid1_2E5_2E12_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E12_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Purchaser as witness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The person purchasing any alcoholic liquor, wine, or beer sold in violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall in all cases be a competent witness to prove such sale.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71569; C73, \'a71549; C97, \'a72424; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1958;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.13; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.111}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a756}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.112}}}{\*\bkmkstart stylerid1_2E5_2E121_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E121_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Peace officer as witness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every peace officer shall give evidence, when called upon, of any facts within the peace officer\u8217\'3fs knowledge tending to prove a violation of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71578; C73, \'a71551; C97, \'a72428; S13, \'a72428; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1959;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.14; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.112}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.113}}}{\*\bkmkstart stylerid1_2E5_2E122_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E122_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judgment lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For all fines and costs assessed or judgments rendered of any kind against any person for a violation of any provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or costs paid by the county on account of such violation, the personal and real property of the violator, whether exempt or not, except the homestead, as well as the premises and property, personal and real, occupied and used for the unlawful purpose, with the knowledge of the owner or the owner\u8217\'3fs agent, by the violator, shall be liable, and the same shall be a lien on such real estate until paid.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71579; C73, \'a71552, 1558; C97, \'a72422; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1960;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.15; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.113}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.114}}}{\*\bkmkstart stylerid1_2E5_2E123_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E123_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement of lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Costs paid by the county for the prosecution of actions or proceedings, civil or criminal, under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, as well as the fines inflicted or judgments rendered, may be enforced against the property upon which the lien attaches by execution, or by action against the owner of the property to subject it to the payment thereof.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a71558; C97, \'a72422; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1961;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.16; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.114}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.115}}}{\*\bkmkstart stylerid1_2E5_2E124_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E124_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Defense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In any prosecution under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ for the unlawful transportation of alcoholic liquor, wine, or beer it shall be a defense that the character and contents of the shipment or thing transported were not known to the accused or to the accused\u8217\'3fs agent or employee.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72419; C24, \'a72059; C27, 31, 35, \'a71945-a2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1945.3;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.28; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.115}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a757}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.116}}}{\*\bkmkstart stylerid1_2E5_2E125_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E125_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Right to receive alcoholic liquor, wine, or beer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The consignee of alcoholic liquor, wine, or beer shall, on demand of the carrier transporting such alcoholic liquor, wine, or beer, furnish the carrier, at the place of delivery, with legal proof of the consignee\u8217\'3fs legal right to receive such alcoholic liquor, wine, or beer at the time of delivery, and until such proof is furnished the carrier shall be under no legal obligation to make delivery nor be liable for failure to deliver.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, \'a72061; C27, 31, 35, \'a71945-a4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1945.5;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.30; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.116}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a758}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.117}}}{\*\bkmkstart stylerid1_2E5_2E126_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E126_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Delivery to sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If such proof is not furnished the carrier within ten days after demand, the carrier may deliver such liquor, wine, or beer to the sheriff of the county embracing the place of delivery, and such delivery shall absolve the carrier from all liability pertaining to such liquor, wine, or beer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, \'a72062; C27, 31, 35, \'a71945-a5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1945.6;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.31; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.117}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a736}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.118}}}{\*\bkmkstart stylerid1_2E5_2E127_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E127_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Destruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The sheriff shall, on receipt of such liquor, wine, or beer from the carrier, report the receipt to the district court of the sheriff\u8217\'3fs county, and the court shall proceed to summarily enter an order for the destruction or forfeiture to the state of such liquor, wine, or beer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, \'a72063; C27, 31, 35, \'a71945-a6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1945.7;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.32; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.118}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a737}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.119}}}{\*\bkmkstart stylerid1_2E5_2E128_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E128_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In all actions, civil or criminal, under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the finding of alcoholic liquors or of instruments or utensils used in the manufacture of alcoholic liquors, or materials which are being used, or are intended to be used in the manufacture of alcoholic liquors, in the possession of or under the control of any person, under and by authority of a search warrant or other process of law, and which shall have been finally adjudicated and declared forfeited by the court, shall be competent evidence of maintaining a nuisance or bootlegging, or of illegal transportation of alcoholic liquors, as the case may be, by such person.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a71966-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1966.1;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.23; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.119}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1060, \'a759}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.120}}}{\*\bkmkstart stylerid1_2E5_2E129_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E129_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Attempt to destroy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The destruction of or attempt to destroy any liquid by any person while in the presence of peace officers or while a property is being searched by a peace officer, shall be competent evidence that such liquid is alcoholic liquor, wine, or beer and intended for unlawful purposes.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a71966-a3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1966.3;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7126.25; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.120}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 35, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a760}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.121}}}{\*\bkmkstart stylerid1_2E5_2E13_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E13_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Venue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any prosecution under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the unlawful sale of alcoholic liquor, wine, or beer, including a sale which requires a shipment or delivery of the alcoholic liquor, wine, or beer, shall be deemed to be made in the county in which the delivery is made by the carrier to the consignee, or the consignee\u8217\'3fs agent or employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any prosecution under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the unlawful transportation of alcoholic liquor, wine, or beer, the offense shall be held to have been committed in any county in which such alcoholic liquor, wine, or beer is received for transportation, through which it is transported, or in which it is delivered.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72419; C24, \'a71928, 2060; C27, 31, 35, \'a71928, 1945-a3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1928, 1945.4;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7125.8, 125.29; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.121}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a761}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E2_2E2}{BEER PROVISIONS}{\*\bkmkend stylerid1_2E6_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.122}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Beer certificate, permit, or license required }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exception for personal use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not cause the manufacture, importation, or sale of beer in this state unless a certificate or permit as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, or a retail alcohol license as provided in }}}{{\f5\fs18\hyphpar0\qj{subchapter I of this chapter}}}{{\f5\fs18\hyphpar0\qj{, is first obtained which authorizes that manufacture, importation, or sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person of legal age may manufacture beer for personal use without a class \u8220\'3fA\u8221\'3f beer permit, subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Such beer may be consumed on the premises or removed from the premises where it was manufactured only if the beer is not sold, exchanged, bartered, dispensed, or given in consideration of purchase for any property or services or in evasion of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a person shall not import beer. However, an individual of legal age may import beer into the state without a certificate, permit, or license an amount of beer not to exceed four and one-half gallons per calendar month that the individual personally obtained outside the state or, in the case of beer personally obtained outside the United States, a quantity which does not exceed the amount allowed by federal law governing the importation of alcoholic beverages into the United States for personal consumption. Beer imported pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be for personal consumption in a private home or other private accommodation and only if the beer is not sold, exchanged, bartered, dispensed, or given in consideration of purchase for any property or services or in evasion of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f96; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.095;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.1; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.122}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1088, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 138, \'a726, 161, 162}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a756, 88}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.10}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Charity beer, spirits, and wine special event license, see }{{\f5\fs12\hyphpar0\qj{\'a7123.173A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.123}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Effect on liquor control licensees.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a787, 88}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.124}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Beer permits }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ classes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Permits for the manufacture and sale, or sale, of beer shall be known as class \u8220\'3fA\u8221\'3f and special class \u8220\'3fA\u8221\'3f. A holder of a class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit shall have the authority as provided in }{{\f5\fs18\hyphpar0\qj{section 123.130}}}{. }\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f98; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.097;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.3; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.124}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1241, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 221, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1003, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1017, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a789, 96}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a757, 88}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.125}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of beer permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall issue class \u8220\'3fA\u8221\'3f and special class \u8220\'3fA\u8221\'3f beer permits and may suspend or revoke permits for cause as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f98; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.097;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.3; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.125}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 221, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a790, 96}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a758, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72430}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.126}}}{\*\bkmkstart stylerid1_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{High alcoholic content beer }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ applicability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless otherwise provided by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ applicable to beer shall also apply to high alcoholic content beer.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1189, \'a742, 43}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.126A}}}{\*\bkmkstart stylerid1_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Canned cocktails }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ applicability }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ manufacture.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ applicable to beer shall also apply to canned cocktails.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, a manufacturer of beer may obtain and possess alcoholic liquor from the department for the purpose of manufacturing canned cocktails.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 107, \'a73, 6}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1010, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72431}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.127}}}{\*\bkmkstart stylerid1_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Class \u8220\'3fA\u8221\'3f and special class \u8220\'3fA\u8221\'3f beer permit application and issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person applying for a class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit shall submit a completed application electronically, or in a manner prescribed by the director, which shall set forth under oath the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and place of residence of the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names and addresses of all persons or, in the case of a corporation, limited liability company, or any other similar legal entity, the officers, directors, and persons owning or controlling ten percent or more of the capital stock thereof, having a financial interest, by way of loan, ownership, or otherwise, in the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location of the premises where the applicant intends to operate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the owner of the premises and if the owner of the premises is not the applicant, whether the applicant is the actual lessee of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When required by the director, and in such form and containing such information as the director may require, a description of the premises where the applicant intends to use the permit, to include a sketch or drawing of the premises and, if applicable, the number of square feet of interior floor space which comprises the retail sales area of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether any person specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ has ever been convicted of any offense against the laws of the United States, or any state or territory thereof, or any political subdivision of any such state or territory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information as required by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall issue a class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit to any applicant who establishes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant has submitted a completed application as required by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant is a person of good moral character as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.3, subsection 40}}}{{\f5\fs18\hyphpar0\qj{. This paragraph does not apply if the applicant is the state of Iowa or a state agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 669.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant is a citizen of the state of Iowa or, if a corporation, that the applicant is authorized to do business in the state. This paragraph does not apply if the applicant is the state of Iowa or a state agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 669.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant has filed with the department a basic permit issued by the alcohol and tobacco tax and trade bureau of the United States department of the treasury, and that the applicant will faithfully observe and comply with all laws, rules, and regulations governing the manufacture and sale of beer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the premises where the applicant intends to use the permit conforms to all applicable laws, health regulations, and fire regulations, and constitutes a safe and proper place or building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant gives consent to a person, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.30, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, to enter upon the premises without a warrant during the business hours of the applicant to inspect for violations of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or ordinances and regulations that local authorities may adopt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is applying for a special class \u8220\'3fA\u8221\'3f beer permit, that the applicant holds or has applied for a class \u8220\'3fC\u8221\'3f or special class \u8220\'3fC\u8221\'3f retail alcohol license.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f102; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.103;}}}{ C46, 50, 54, 58, 62, 66, \'a7124.8; C71, \'a7124.8, 124.41; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.127}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1241, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 221, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 143, \'a76, 17}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7177}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a791, 92, 96}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a734, 35}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a738, 39}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a759, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72432 \u8211\'3f 2435}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 31, \'a711, 12, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraphs b and c amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph g stricken and former paragraph h redesignated as g}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.128}}}{\*\bkmkstart stylerid1_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Class \u8220\'3fB\u8221\'3f beer permit application.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.129}}}{\*\bkmkstart stylerid1_2E6_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Class \u8220\'3fC\u8221\'3f beer permit application.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.130}}}{\*\bkmkstart stylerid1_2E6_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under class \u8220\'3fA\u8221\'3f and special class \u8220\'3fA\u8221\'3f beer permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person holding a class \u8220\'3fA\u8221\'3f beer permit issued by the department shall be authorized to manufacture and sell, or sell at wholesale, beer for consumption off the premises, such sales within the state to be made only to persons holding a subsisting class \u8220\'3fA\u8221\'3f beer permit, or retail alcohol licenses, excluding a special class \u8220\'3fB\u8221\'3f retail native wine license, issued in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, a person holding a class \u8220\'3fA\u8221\'3f beer permit issued by the department who also holds a brewer\u8217\'3fs notice issued by the alcohol and tobacco tax and trade bureau of the United States department of the treasury shall be authorized to sell, at wholesale, no more than thirty thousand barrels of beer on an annual basis for consumption off the premises to a licensee authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to sell beer at retail.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a class \u8220\'3fA\u8221\'3f beer permit may sell beer to distributors outside of the state that are authorized by the laws of that jurisdiction to sell beer at wholesale. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit does not grant authority to manufacture wine as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.3, subsection 53}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.45, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a native brewery may be granted not more than two class \u8220\'3fC\u8221\'3f retail alcohol licenses or not more than two special class \u8220\'3fC\u8221\'3f retail alcohol licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All class \u8220\'3fA\u8221\'3f premises shall be located within the state. All beer received by the holder of a class \u8220\'3fA\u8221\'3f beer permit from the holder of a certificate of compliance before being resold must first come to rest on the licensed premises of the permit holder, must be inventoried, and is subject to the barrel tax when resold as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.136}}}{{\f5\fs18\hyphpar0\qj{. A class \u8220\'3fA\u8221\'3f beer permittee shall not store beer overnight except on premises licensed under a class \u8220\'3fA\u8221\'3f beer permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All special class \u8220\'3fA\u8221\'3f premises shall be located within the state. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a person who holds a special class \u8220\'3fA\u8221\'3f beer permit for the same location at which the person holds a class \u8220\'3fC\u8221\'3f or special class \u8220\'3fC\u8221\'3f retail alcohol license for the purpose of operating as a brewpub may manufacture and sell beer to be consumed on the premises, may sell beer at retail at the manufacturing premises for consumption off the premises, may sell beer to a class \u8220\'3fA\u8221\'3f beer permittee for resale purposes, and may sell beer to distributors outside of the state that are authorized by the laws of that jurisdiction to sell beer at wholesale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who holds a special class \u8220\'3fA\u8221\'3f beer permit for the same location at which the person holds a class \u8220\'3fC\u8221\'3f or special class \u8220\'3fC\u8221\'3f retail alcohol license for the purpose of operating as a brewpub may manufacture beer under an alternating proprietorship arrangement as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{. However, the person may not sell beer to be consumed on the premises where manufactured or sell beer at retail for consumption off the premises where manufactured unless the person is also the holder of a class \u8220\'3fC\u8221\'3f or special class \u8220\'3fC\u8221\'3f retail alcohol license issued for the premises of the alternating proprietorship whose space and equipment is being used for the purpose of manufacturing beer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The permit issued to holders of a special class \u8220\'3fA\u8221\'3f beer permit shall clearly state on its face that the permit is limited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmanufacturer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes only those persons who hold a class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit and manufacture beer in Iowa.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of law to the contrary, a manufacturer may use the space and equipment of another manufacturer for the purpose of manufacturing beer, provided that such an alternating proprietorship arrangement has been approved by the alcohol and tobacco tax and trade bureau of the United States department of the treasury. A separate class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit shall be issued to each manufacturer, and each manufacturer shall be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the rules of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of law to the contrary, not more than one class \u8220\'3fC\u8221\'3f retail alcohol license or special class \u8220\'3fC\u8221\'3f retail license shall be issued to a premises with alternating proprietorships as authorized by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer of beer issued a class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit shall file with the department, on or before the fifteenth day of each calendar month, all documents filed with the alcohol and tobacco tax and trade bureau of the United States department of the treasury, including all brewer\u8217\'3fs operation and excise tax return reports.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f105; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.106;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.11; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.130}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1241, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 221, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1003, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a793, 96}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 8, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a740 \u8211\'3f 42}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 133, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a760, 61, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72436, 2437}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 48, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 157, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.124}}}{{\f5\fs12\hyphpar0\qj{, 123.136}}}{{\f5\fs12\hyphpar0\qj{, 123.143}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.131}}}{\*\bkmkstart stylerid1_2E6_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under class \u8220\'3fB\u8221\'3f beer permit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.132}}}{\*\bkmkstart stylerid1_2E6_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under class \u8220\'3fC\u8221\'3f beer permit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.133}}}{\*\bkmkstart stylerid1_2E6_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale on trains \u8212\'3f bond.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 17, \'a716}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.134}}}{\*\bkmkstart stylerid1_2E6_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Beer permit fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual permit fee for a class \u8220\'3fA\u8221\'3f beer permit is seven hundred fifty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual permit fee for a class \u8220\'3fA\u8221\'3f beer permit for a native brewery is three hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual permit fee for a special class \u8220\'3fA\u8221\'3f beer permit is three hundred dollars.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f117; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.119;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.24; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.134}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1275, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 22, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 221, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 245, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a794, 96}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 17, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a742 \u8211\'3f 44}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a729, 30}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 155, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a711, 15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.135}}}{\*\bkmkstart stylerid1_2E6_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Brewer\u8217\'3fs certificate of compliance }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer, brewer, bottler, importer, or vendor of beer, or any agent thereof, desiring to ship or sell beer, or have beer brought into this state for resale by a class \u8220\'3fA\u8221\'3f beer permittee, shall first make application for and be issued a brewer\u8217\'3fs certificate of compliance by the director for that purpose. The certificate of compliance expires at the end of one year from the date of issuance and shall be renewed for a like period upon application to the director unless otherwise revoked for cause. Each completed application for a certificate of compliance or renewal of a certificate shall be submitted electronically, or in a manner prescribed by the director, and shall be accompanied by a fee of two hundred dollars payable to the department. Each holder of a certificate of compliance shall furnish the information in a manner the director requires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of applying for a certificate of compliance, each applicant shall file with the department a list of all class \u8220\'3fA\u8221\'3f beer permittees with whom it intends to do business and shall designate the geographic area in which its products are to be distributed by such permittee. The listing of class \u8220\'3fA\u8221\'3f beer permittees and geographic area as filed with the department shall be amended by the holder of a certificate of compliance as necessary to keep the listing current with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All class \u8220\'3fA\u8221\'3f beer permit holders shall sell only those brands of beer which are manufactured, brewed, bottled, shipped, or imported by a person holding a current certificate of compliance. Any employee or agent working for or representing the holder of a certificate of compliance within this state shall submit electronically, or in a manner prescribed by the director, the employee\u8217\'3fs or agent\u8217\'3fs name and address with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any holder of a certificate of compliance or the holder\u8217\'3fs agent, or any class \u8220\'3fA\u8221\'3f beer permit holder or the beer permit holder\u8217\'3fs agent, to grant to any retail alcohol license holder, directly or indirectly, any rebates, free goods, or quantity discounts on beer which are not uniformly offered to all retail alcohol licensees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall subject the holder of a brewer\u8217\'3fs certificate of compliance or a class \u8220\'3fA\u8221\'3f beer permit holder to the general penalties provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall constitute grounds for imposition of a civil penalty, suspension of the certificate or permit, or revocation of the certificate or permit after notice and opportunity for a hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.135}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 221, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 252, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a795, 96}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a744, 45}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a712, 15, 62, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72438}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}{{\f5\fs12\hyphpar0\qj{, 123.35}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.136}}}{\*\bkmkstart stylerid1_2E6_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Barrel tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the annual permit fee to be paid by all class \u8220\'3fA\u8221\'3f beer permittees under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ there shall be levied and collected from the permittees on all beer manufactured for sale or sold in this state at wholesale and on all beer imported into this state for sale at wholesale and sold in this state at wholesale, and from special class \u8220\'3fA\u8221\'3f beer permittees on all beer manufactured for consumption on the premises and on all beer sold at retail at the manufacturing premises for consumption off the premises pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.130, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, a tax of five and eighty-nine hundredths dollars for every barrel containing thirty-one gallons, and at a like rate for any other quantity or for the fractional part of a barrel. However, no tax shall be levied or collected on beer shipped outside this state by a class \u8220\'3fA\u8221\'3f beer permittee or special class \u8220\'3fA\u8221\'3f beer permittee or on beer sold to a class \u8220\'3fA\u8221\'3f beer permittee by a special class \u8220\'3fA\u8221\'3f beer permittee or another class \u8220\'3fA\u8221\'3f beer permittee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All revenue derived from the barrel tax shall accrue to the state general fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ relating to the administration of the barrel tax on beer shall apply to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f118; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.120;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.25; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.136}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1246, \'a7751}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 221, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a746}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.130}}}{{\f5\fs12\hyphpar0\qj{, 123.137}}}{{\f5\fs12\hyphpar0\qj{, 123.142}}}{{\f5\fs12\hyphpar0\qj{, 455C.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.137}}}{\*\bkmkstart stylerid1_2E6_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Report of barrel sales \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a person holding a class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit shall, on or before the tenth day of each calendar month commencing on the tenth day of the calendar month following the month in which the person is issued a beer permit, make a report under oath to the department electronically, or in a manner prescribed by the director, showing the exact number of barrels of beer, or fractional parts of barrels, sold by the beer permit holder during the preceding calendar month. The report shall also state information the director requires, and beer permit holders shall at the time of filing a report pay to the department the amount of tax due at the rate fixed in }}}{{\f5\fs18\hyphpar0\qj{section 123.136}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit holder who reasonably expects to be liable for not more than two thousand five hundred dollars in barrel tax for the twelve-month period beginning July 1 and ending June 30, and who was liable for not more than two thousand five hundred dollars in barrel tax in the immediately preceding twelve-month period beginning July 1 and ending June 30, may file reports and pay taxes due as described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ on a quarterly basis according to the following schedule:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before October 10 for the months of July, August, and September.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before January 10 for the months of October, November, and December.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before April 10 for the months of January, February, and March.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before July 10 for the months of April, May, and June.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A penalty of ten percent of the amount of the tax shall be added thereto if the report is not filed and the tax paid within the time required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f119; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.121;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.26; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.137}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 221, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72439}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 76, \'a71, 3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 1 effective January 1, 2026; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 76, \'a73}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.138}}}{\*\bkmkstart stylerid1_2E6_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records required }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ keg identification label.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permittee shall keep proper records showing the amount of beer sold by the permittee, and these records shall be at all times open to inspection by the director and to other persons pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.30, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. Each retail alcohol licensee as described in }}}{{\f5\fs18\hyphpar0\qj{section 123.30}}}{{\f5\fs18\hyphpar0\qj{ shall keep proper records showing each purchase of beer made by the licensee, and the date and the amount of each purchase and the name of the person from whom each purchase was made, which records shall be open to inspection pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.30, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, during normal business hours of the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each retail alcohol licensee who sells beer for off-premises consumption shall affix to each keg of beer an identification label provided by the director. The label provided shall allow for its full removal when common external keg cleaning procedures are performed. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fkeg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all durable and disposable containers with a liquid capacity of five gallons or more. Each retail alcohol licensee shall also keep a record of the identification label number of each keg of beer sold by the licensee with the name and address of the purchaser and the number of the purchaser\u8217\'3fs driver\u8217\'3fs license, nonoperator\u8217\'3fs identification card, or military identification card, if the military identification card contains a picture and signature. This information shall be retained by the licensee for a minimum of ninety days. The records kept pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be available for inspection by any law enforcement officer during normal business hours.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall provide the keg identification labels described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and shall, prior to utilizing a label, notify licensed brewers and licensed beer importers of the type of label to be utilized. Each label shall contain a number and the following statement:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is unlawful to sell, give, or otherwise supply any alcoholic beverage, wine, or beer to any person under legal age. Any person who defaces this label shall be guilty of criminal mischief punishable pursuant to }{{\f5\fs18\hyphpar0\qj{section 716.6}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The identification label shall be placed on the keg at the time of retail sale. The licensee shall obtain the labels referred to in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ from the department. The cost of the labels to licensees shall not exceed the department\u8217\'3fs cost of producing and distributing the labels. The moneys collected by the department relating to the sale of labels shall be credited to the beer and liquor control fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be implemented uniformly throughout the state. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall preempt any local county or municipal ordinance regarding keg registration or the sale of beer in kegs. In addition, a county or municipality shall not adopt or continue in effect an ordinance regarding keg registration or the sale of beer in kegs.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f120; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.122;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.27; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.138}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1241, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 221, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 46, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a763 \u8211\'3f 66, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72440}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.50}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.139}}}{\*\bkmkstart stylerid1_2E6_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Separate locations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A class \u8220\'3fA\u8221\'3f or special class \u8220\'3fA\u8221\'3f beer permittee having more than one place of business is required to have a separate beer permit for each separate place of business maintained by the permittee where beer is manufactured, stored, warehoused, or sold.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f121; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.123;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.28; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.139}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 221, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a765}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.140}}}{\*\bkmkstart stylerid1_2E6_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Separate locations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ class \u8220\'3fB\u8221\'3f or \u8220\'3fC\u8221\'3f beer permit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.141}}}{\*\bkmkstart stylerid1_2E6_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Keeping liquor where beer is sold.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No alcoholic liquor for beverage purposes shall be used, or kept for any purpose in the place of business of a special class \u8220\'3fC\u8221\'3f retail alcohol licensee, or on the premises of such special class \u8220\'3fC\u8221\'3f retail alcohol licensee, at any time. A violation of any provision of }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be grounds for suspension or revocation of the beer permit pursuant to }{{\f5\fs18\hyphpar0\qj{section 123.50, subsection 3}}}{. }{{\f5\fs18\hyphpar0\qj{This section}}}{ shall not apply in any manner or in any way to the premises of any hotel or motel for which a special class \u8220\'3fC\u8221\'3f retail alcohol license has been issued, other than that part of such premises regularly used by the hotel or motel for the principal purpose of selling beer or food to the general public, or to keep a pharmacy from having alcohol in stock for medicinal and compounding purposes.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-g4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.126;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.31; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.141}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 17, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 160, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a767, 88}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.142}}}{\*\bkmkstart stylerid1_2E6_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Unlawful sale and importation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for the holder of a retail alcohol license issued under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to sell beer, except beer brewed on the premises covered by a special class \u8220\'3fA\u8221\'3f beer permit or beer purchased from a person holding a class \u8220\'3fA\u8221\'3f beer permit issued in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and on which the tax provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.136}}}{{\f5\fs18\hyphpar0\qj{ has been paid. However, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to class \u8220\'3fD\u8221\'3f retail alcohol licensees as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any person not holding a class \u8220\'3fA\u8221\'3f beer permit to import beer into this state for the purpose of sale or resale.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f124; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.127;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.32; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.142}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 221, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 17, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a768, 88}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.143}}}{\*\bkmkstart stylerid1_2E6_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Distribution of funds }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ barrel tax fund created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The revenues obtained from permit fees and the barrel tax collected under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be distributed as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All permit fees collected by the department under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall accrue to the beer and liquor control fund, except as otherwise provided. All taxes collected by the department under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall accrue to the state general fund, except as otherwise provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Barrel tax revenues collected on beer manufactured in this state from a class \u8220\'3fA\u8221\'3f beer permittee which owns and operates a native brewery shall be credited to the barrel tax fund hereby created in the office of the treasurer of state. In addition, barrel tax revenues collected on beer manufactured in this state from a special class \u8220\'3fA\u8221\'3f beer permittee which owns and operates a brewpub that is sold at retail at the manufacturing premises pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.130, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, shall be credited to the barrel tax fund. Moneys deposited in the barrel tax fund shall not revert to the general fund of the state without a specific appropriation by the general assembly. Moneys in the barrel tax fund are appropriated to the economic development authority for purposes of }}}{{\f5\fs18\hyphpar0\qj{section 15E.117}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f125; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.128;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.33; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.143}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a760, 209}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1312, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 198, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 95, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1188, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a769, 70, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 13, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72441}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715E.117}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.144}}}{\*\bkmkstart stylerid1_2E6_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bottling beer.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 113, \'a763}}}{{\f5\fs18\hyphpar0\qj{. See }}}{{\f5\fs18\hyphpar0\qj{\'a7123.122}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.145}}}{\*\bkmkstart stylerid1_2E6_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Labels on bottles, barrels, etc. }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ conclusive evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The label on any bottle, keg, barrel, or other container in which beer is offered for sale in this state, representing the alcoholic content of such beer as being in excess of five percent by weight shall be conclusive evidence as to the alcoholic content of the beer contained therein.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f128; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.133;}}}{ C46, 50, 54, 58, 62, 66, 71, \'a7124.38; C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.145}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 30, \'a724}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.146}}}{\*\bkmkstart stylerid1_2E6_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Importation of beer for personal use.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 113, \'a763}}}{{\f5\fs18\hyphpar0\qj{. See }}}{{\f5\fs18\hyphpar0\qj{\'a7123.122}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{123.147 through 123.149}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER III}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E2_2E2}{SPECIAL PROVISIONS}{\*\bkmkend stylerid1_2E7_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.150}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sunday sales before New Year\u8217\'3fs Day.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a787, 88}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{123.151 and 123.152}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E2_2E2}{WAREHOUSE PROJECT}{\*\bkmkend stylerid1_2E8_2E2_2E2}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{123.153 through 123.162}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2011/CH0017.pdf" }{\fldrslt \f5 \fs18{{2011 Acts, ch 17, \'a716}}}}}}{{\f5\fs18\qj{2011 Acts, ch 17, \'a716}}}{.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{123.163 through 123.170}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER V}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E2_2E2}{WINE PROVISIONS \u8212\'3f CHARITY BEER, SPIRITS, AND WINE SPECIAL EVENTS}{\*\bkmkend stylerid1_2E9_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.171}}}{\*\bkmkstart stylerid1_2E9_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wine certificate, permit, or license required }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exceptions for personal use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not cause the manufacture, importation, or sale of wine in this state unless a certificate or permit as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, or a retail alcohol license as provided in }}}{{\f5\fs18\hyphpar0\qj{ subchapter I of this chapter}}}{{\f5\fs18\hyphpar0\qj{, is first obtained which authorizes that manufacture, importation, or sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person of legal age may manufacture wine for personal use without a class \u8220\'3fA\u8221\'3f wine permit, subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Such wine may be consumed on the premises or removed from the premises where it was manufactured only if the wine is not sold, exchanged, bartered, dispensed, or given in consideration of purchase for any property or services or in evasion of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, an individual of legal age may import into the state without a certificate, permit, or license an amount of wine not to exceed nine liters per calendar month that the individual personally obtained outside the state or, in the case of wine personally obtained outside the United States, a quantity which does not exceed the amount allowed by federal law governing the importation of alcoholic beverages into the United States for personal consumption. Wine imported pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be for personal consumption in a private home or other private accommodation and only if the wine is not sold other than as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, exchanged, bartered, dispensed, or given in consideration of purchase for any property or services or in evasion of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a person of legal age may conduct private wine sales without a certificate, permit, or license, subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Except for wine manufactured pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a person may sell wine from the person\u8217\'3fs private collection in an original, unopened container to either a class \u8220\'3fA\u8221\'3f wine permittee for purposes of resale or a wine auction permittee under }}}{{\f5\fs18\hyphpar0\qj{section 123.173C}}}{{\f5\fs18\hyphpar0\qj{ for resale by means of an auction. A class \u8220\'3fA\u8221\'3f wine permittee or wine auction permittee involved in the sale of wine by a person under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall ensure that each bottle of wine purchased has a permanently affixed label stating that the wine was acquired from a private collection.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1008, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1096, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a771, 88}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1088, \'a72, 3}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.10}}}{{\f5\fs12\hyphpar0\qj{, 123.180}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.172}}}{\*\bkmkstart stylerid1_2E9_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Effect on liquor control licensees.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a787, 88}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.173}}}{\*\bkmkstart stylerid1_2E9_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wine permit }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ class \u8220\'3fA\u8221\'3f }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.187}}}{{\f5\fs18\hyphpar0\qj{, a permit exclusively for the manufacture and sale of wine shall be known as a class \u8220\'3fA\u8221\'3f wine permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f wine permit allows the holder to manufacture and sell, or sell at wholesale, in this state, wine. The holder of a class \u8220\'3fA\u8221\'3f wine permit may manufacture in this state wine having an alcoholic content greater than seventeen percent by weight or twenty-one and twenty-five hundredths percent of alcohol by volume for shipment outside this state. All class \u8220\'3fA\u8221\'3f premises shall be located within the state. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f wine permittee shall be required to deliver wine to a retail alcohol licensee, and a retail alcohol licensee shall be required to accept delivery of wine from a class \u8220\'3fA\u8221\'3f wine permittee, only at the licensed premises of the retail alcohol licensee. Except as specifically permitted by the department upon good cause shown, delivery or transfer of wine from an unlicensed premises to a licensed retail alcohol licensee\u8217\'3fs premises, or from one licensed retail alcohol licensee\u8217\'3fs premises to another licensed retail alcohol licensee\u8217\'3fs premises, even if there is common ownership of all of the premises by one retail alcohol licensee, is prohibited. }}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 203, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 143, \'a77, 17}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1032, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1008, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a772, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72442}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a734}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.173A}}}{\*\bkmkstart stylerid1_2E9_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Charity beer, spirits, and wine special event license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthorized nonprofit entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a nonprofit entity which has a principal office in the state, a nonprofit corporation organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 504}}}{{\f5\fs18\hyphpar0\qj{, or a foreign corporation as defined in }}}{{\f5\fs18\hyphpar0\qj{section 504.141}}}{{\f5\fs18\hyphpar0\qj{, whose income is exempt from federal taxation under }}}{{\f5\fs18\hyphpar0\qj{section 501(c) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCharity auction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an auction conducted by an authorized nonprofit entity which includes beer, spirits, and wine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCharity event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an event at which an authorized nonprofit entity may serve the event\u8217\'3fs attendees beer, spirits, and wine for consumption on the premises of the event, regardless of whether the entity charges an admission fee to the event or otherwise collects the cost of the beer, spirits, and wine served from the event\u8217\'3fs attendees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCharity special event\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a charity auction, charity event, or a combined charity auction and charity event.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application to the department and receipt of a charity beer, spirits, and wine special event license, an authorized nonprofit entity may conduct a charity special event subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A charity auction conducted by a charity beer, spirits, and wine special event licensee shall comply with the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The authorized nonprofit entity conducting the charity auction shall obtain the beer, spirits, and wine to be auctioned at the charity auction from an Iowa retail alcohol licensee, or may receive donations of beer, spirits, or wine to be auctioned at the charity auction from persons who purchased the donated beer, spirits, or wine from an Iowa retail alcohol licensee or an Iowa class \u8220\'3fA\u8221\'3f native distilled spirits licensee and who present a receipt documenting the purchase at the time the beer, spirits, or wine is donated. The authorized nonprofit entity conducting the charity auction shall retain a copy of the receipt for a period of one year from the date of the charity beer, spirits, and wine auction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The beer, spirits, and wine sold at the charity auction shall be in original containers for consumption off of the premises where the charity auction is conducted. No other alcoholic beverage may be sold by the charity beer, spirits, and wine special event licensee at the charity auction. A purchaser of beer, spirits, or wine at a charity auction shall not take possession of the beer, spirits, or wine until the person is leaving the event. A purchaser of beer, spirits, or wine at a charity auction shall not open the container or consume or permit the consumption of the beer, spirits, or wine purchased on the premises where the charity auction is conducted. A purchaser of beer, spirits, or wine at a charity auction shall not resell the beer, spirits, or wine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retail alcohol licensee or class \u8220\'3fA\u8221\'3f native distilled spirits licensee shall not purchase beer, spirits, or wine at a charity auction. The charity auction may be conducted on a premises for which a class \u8220\'3fB\u8221\'3f or class \u8220\'3fC\u8221\'3f retail alcohol license has been issued, provided that the retail alcohol licensee does not participate in the charity auction, supply beer, spirits, or wine to be auctioned at the charity auction, or receive any of the proceeds of the charity auction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A charity event conducted by a charity beer, spirits, and wine special event licensee shall comply with the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The charity event shall be conducted on a premises covered by a valid retail alcohol license issued by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The authorized nonprofit entity conducting a charity event shall have a written agreement with the retail alcohol licensee covering the premises where the charity event is to be conducted specifying that that licensee shall act as the agent of the authorized nonprofit entity for the purpose of providing and serving alcoholic beverages to the attendees of the charity event.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The retail alcohol licensee covering the premises where the charity event is to be conducted shall supply all alcoholic beverages served to the attendees of the charity event.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only those types of alcoholic beverages as are authorized to be sold by the retail alcohol license covering the premises where the charity event is to be conducted are to be served to the attendees of the charity event.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for a charity beer, spirits, and wine special event license to conduct a charity special event shall include all of the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date and time when the charity special event is to be conducted and the location of the premises in this state where the charity special event is to be physically conducted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The retail alcohol license number issued by the department for the premises where a charity event is to be conducted, if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certification that the objective of the charity special event is to raise funds solely to be used for educational, religious, or charitable purposes and that the entire proceeds from the charity special event are to be expended for any of the purposes described in }}}{{\f5\fs18\hyphpar0\qj{section 423.3, subsection 78}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An authorized nonprofit entity shall be eligible to receive no more than two charity beer, spirits, and wine special event licenses during a calendar year and each charity beer, spirits, and wine special event license shall be valid for a period not to exceed thirty-six consecutive hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall subject the charity beer, spirits, and wine special event license holder to the general penalties provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall constitute grounds for imposition of a civil penalty, suspension of the license, or revocation of the permit after notice and opportunity for a hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1031, \'a785}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 51, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a748, 49}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a773, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72443 \u8211\'3f 2445}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.173B}}}{\*\bkmkstart stylerid1_2E9_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Charity beer, spirits, and wine event permit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a787, 88}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.173C}}}{\*\bkmkstart stylerid1_2E9_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wine auction permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon application to the department and receipt of a wine auction permit, an authorized person may conduct a wine auction subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall not issue a wine auction permit to an applicant unless the applicant complies with the application requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and unless all of the following requirements are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is a person of good moral character.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant is a citizen of the state of Iowa or, if the applicant is a corporation, the applicant is authorized to do business in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant does not hold a retail alcohol license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The premises where the applicant intends to use the permit constitutes a safe and proper place or building and conforms to all applicable laws, ordinances, resolutions, and health and fire regulations. A permittee shall not have or maintain any interior access to residential or sleeping quarters unless the director grants permission in the form of a living quarters permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicant gives consent, as required by }}}{{\f5\fs18\hyphpar0\qj{section 123.30, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, for a person to enter upon the premises of the wine auction without a warrant during normal business hours to inspect for violations of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or ordinances and regulations that local authorities may adopt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for a wine auction permit must include all of the following information and shall be submitted electronically, or in a manner prescribed by the director:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and address of the applicant or, if the applicant is a corporation, limited liability company, or other legal entity, the names and addresses of all officers, directors, and persons owning or controlling ten percent or more of the capital stock of the entity and who have a financial interest, by way of loan, ownership, or otherwise, in the entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location and name of the owner of the premises where the applicant intends to conduct wine auctions and, if the applicant is not the owner of the premises, whether the applicant is the lessee of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As required by the director, and in such form and containing such information as the director may require, a description of the premises where the applicant intends to conduct wine auctions, including a depiction of the premises, and, if applicable, the number of square feet of interior floor space of the retail sales area of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether any person specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ has ever been convicted of any offense against the laws of the United States, or any state, territory, or political subdivision thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information as required by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A wine auction conducted by a wine auction permittee must comply with the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A permittee shall not offer wines owned by the permittee at auction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, within or outside of the state, who desires to ship wine from a private collection to a wine auction permittee to be sold at auction shall do so through a holder of a wine carrier permit. The wine auction permittee shall ensure that each bottle of wine so acquired is permanently affixed with a label stating that the wine was acquired from a private collection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A permittee shall ensure that each container of wine to be sold at a wine auction is in the original, unopened container.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A permittee is responsible for the storage of all wines that are to be offered at auction at the licensed premises, and for the subsequent shipment and delivery of all wines sold at auction to the purchasers of the wines. Shipment of wine pursuant to this paragraph shall only be done by a holder of a wine carrier permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A permittee is responsible for the payment of all applicable taxes for wines sold at auction pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.183}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a class \u8220\'3fA\u8221\'3f wine permittee or a retail alcohol licensee, not including a native wine manufacturer, may purchase wine offered at an auction pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and may resell wine purchased at auction in accordance with the requirements of the licensee\u8217\'3fs or permittee\u8217\'3fs license or permit. The licensee or permittee shall ensure that each wine resold is in the original, unopened container, and, if applicable, permanently affixed with a label stating that the wine was acquired from a private collection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A wine auction permit is valid for a period of one year pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.35, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. A wine auction permit shall allow the permittee to conduct no more than twenty-four wine auctions during the one-year period of the wine auction permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall subject the wine auction permit holder to the general penalties provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall constitute grounds for imposition of a civil penalty, suspension of the permit, or revocation of the permit after notice and opportunity for a hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1088, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}{{\f5\fs12\hyphpar0\qj{, 123.171}}}{{\f5\fs12\hyphpar0\qj{, 123.183}}}{{\f5\fs12\hyphpar0\qj{, 123.184}}}{{\f5\fs12\hyphpar0\qj{, 123.188}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.174}}}{\*\bkmkstart stylerid1_2E9_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of wine permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall issue wine permits as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and may suspend or revoke a wine permit for cause as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a765}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 143, \'a78, 17}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72446}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.175}}}{\*\bkmkstart stylerid1_2E9_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Class \u8220\'3fA\u8221\'3f wine permit application and issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person applying for a class \u8220\'3fA\u8221\'3f wine permit shall submit a completed application electronically, or in a manner prescribed by the director, which shall set forth under oath the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and place of residence of the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names and addresses of all persons or, in the case of a corporation, limited liability company, or any other similar legal entity, the officers, directors, and persons owning or controlling ten percent or more of the capital stock thereof, having a financial interest, by way of loan, ownership, or otherwise, in the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location of the premises where the applicant intends to operate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the owner of the premises and if the owner of the premises is not the applicant, whether the applicant is the actual lessee of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When required by the director, and in such form and containing such information as the director may require, a description of the premises where the applicant intends to use the permit, to include a sketch or drawing of the premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether any person specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ has ever been convicted of any offense against the laws of the United States, or any state or territory thereof, or any political subdivision of any such state or territory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other information as required by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall issue a class \u8220\'3fA\u8221\'3f wine permit to any applicant who establishes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant has submitted a completed application as required by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant is a person of good moral character as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.3, subsection 40}}}{{\f5\fs18\hyphpar0\qj{. This paragraph does not apply if the applicant is the state of Iowa or a state agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 669.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant is a citizen of the state of Iowa or, if a corporation, that the applicant is authorized to do business in the state. This paragraph does not apply if the applicant is the state of Iowa or a state agency as defined in }}}{{\f5\fs18\hyphpar0\qj{section 669.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant has filed with the department a basic permit issued by the alcohol and tobacco tax and trade bureau of the United States department of the treasury, and that the applicant will faithfully observe and comply with all the laws, rules, and regulations governing the manufacture and sale of wine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the premises where the applicant intends to use the permit conforms to all applicable laws, health regulations, and fire regulations, and constitutes a safe and proper place or building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the applicant gives consent to a person, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.30, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, to enter upon the premises without a warrant during the business hours of the applicant to inspect for violations of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or ordinances and regulations that local authorities may adopt.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 143, \'a79, 17}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a750, 51}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a774 \u8211\'3f 77, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72447 \u8211\'3f 2450}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 31, \'a713 \u8211\'3f 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraphs b and c amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph g stricken}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.176}}}{\*\bkmkstart stylerid1_2E9_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Native wines.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to rules of the department, manufacturers of native wines from grapes, cherries, other fruits or other fruit juices, vegetables, vegetable juices, dandelions, clover, honey, or any combination of these ingredients, holding a class \u8220\'3fA\u8221\'3f wine permit as required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, may sell, keep, or offer for sale and deliver the wine. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 123.24, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, manufacturers of native wine may obtain and possess grape brandy from the department for the sole purpose of manufacturing wine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Native wine may be sold at retail for off-premises consumption when sold on the premises of the manufacturer, or in a retail establishment operated by the manufacturer. Sales may also be made to class \u8220\'3fA\u8221\'3f or retail alcohol licensees as authorized by }}}{{\f5\fs18\hyphpar0\qj{sections 123.30}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{123.177}}}{{\f5\fs18\hyphpar0\qj{. A manufacturer of native wines shall not sell the wines other than as permitted in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall not allow wine sold to be consumed upon the premises of the manufacturer. However, prior to sale, native wines may be tasted pursuant to the rules of the department on the premises where made, when no charge is made for the tasting. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer of native wines may ship wine in closed containers to individual purchasers inside this state by obtaining a wine direct shipper permit pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.187}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f wine permit issued for a native wine manufacturer shall only allow the native wine manufacturer to sell, keep, or offer for sale and deliver the manufacturer\u8217\'3fs native wines as provided under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the fact that a person is the holder of a class \u8220\'3fA\u8221\'3f wine permit, a person engaged in the business of manufacturing native wine may be granted a class \u8220\'3fC\u8221\'3f retail alcohol license or special class \u8220\'3fC\u8221\'3f retail native wine license as defined in }}}{{\f5\fs18\hyphpar0\qj{section 123.30}}}{{\f5\fs18\hyphpar0\qj{ for the same premises licensed under a class \u8220\'3fA\u8221\'3f wine permit where the manufacturing of native wine occurs. A manufacturer of native wine may be granted not more than two class \u8220\'3fC\u8221\'3f retail alcohol licenses or special class \u8220\'3fC\u8221\'3f retail native wine licenses. A manufacturer of native wine may be issued a class \u8220\'3fC\u8221\'3f retail alcohol license or special class \u8220\'3fC\u8221\'3f retail native wine license regardless of whether the manufacturer is also a manufacturer of beer pursuant to a class \u8220\'3fA\u8221\'3f beer permit or a manufacturer of native distilled spirits pursuant to a class \u8220\'3fA\u8221\'3f native distilled spirits license.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the fact that a person is the holder of a class \u8220\'3fA\u8221\'3f wine permit, a person engaged in the business of manufacturing native wine may be granted a five-day class \u8220\'3fC\u8221\'3f retail alcohol license or five-day special class \u8220\'3fC\u8221\'3f retail native wine license as described in }}}{{\f5\fs18\hyphpar0\qj{section 123.34}}}{{\f5\fs18\hyphpar0\qj{ for premises other than the premises licensed under a class \u8220\'3fA\u8221\'3f wine permit where the manufacturing of native wine occurs. A manufacturer of native wine may be granted not more than six five-day class \u8220\'3fC\u8221\'3f retail alcohol licenses or five-day special class \u8220\'3fC\u8221\'3f retail native wine licenses during a calendar year. A manufacturer of native wine may be issued a five-day class \u8220\'3fC\u8221\'3f retail alcohol license or five-day special class \u8220\'3fC\u8221\'3f retail native wine license regardless of whether the manufacturer is also a manufacturer of beer pursuant to a class \u8220\'3fA\u8221\'3f beer permit or a manufacturer of native distilled spirits pursuant to a class \u8220\'3fA\u8221\'3f native distilled spirits license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a person employed by a manufacturer of native wine holding a class \u8220\'3fA\u8221\'3f wine permit may be employed by a brewery with a class \u8220\'3fA\u8221\'3f beer permit provided the person has no ownership interest in either licensed premises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer may use the space and equipment of another manufacturer for the purpose of manufacturing native wine, provided that such an alternating proprietorship arrangement is approved by the alcohol and tobacco tax and trade bureau of the United States department of the treasury. A separate class \u8220\'3fA\u8221\'3f wine permit shall be issued to each manufacturer, and each manufacturer shall be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the rules of the department. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, not more than one class \u8220\'3fC\u8221\'3f retail alcohol license shall be issued to a premises with alternating proprietorships.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer of native wines shall file with the department, on or before the fifteenth day of each calendar month, all documents filed with the alcohol and tobacco tax and trade bureau of the United States department of the treasury, including all wine premises operations and excise tax return reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmanufacturer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes only those persons who process in Iowa the fruit, vegetables, dandelions, clover, honey, or any combination of these ingredients, by fermentation into wines.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a71921-f56; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1921.056;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7123.56}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 198, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 143, \'a74, 5, 17}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 73, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 17, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 30, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1008, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a733 \u8211\'3f 35, 62}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 160, \'a73}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2020, \'a7123.176}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 133, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a778, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72451}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 157, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1087, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.177}}}{\*\bkmkstart stylerid1_2E9_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under class \u8220\'3fA\u8221\'3f wine permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a class \u8220\'3fA\u8221\'3f wine permit may manufacture and sell, or sell at wholesale, wine for consumption off the premises. Sales within the state may be made only to persons holding a class \u8220\'3fA\u8221\'3f wine permit and to persons holding a retail alcohol license. However, if the person holding the class \u8220\'3fA\u8221\'3f permit is a manufacturer of native wine, the person may sell only native wine to a person holding a retail alcohol license. A person holding a class \u8220\'3fA\u8221\'3f wine permit may sell wine to distributors outside of the state that are authorized by the laws of that jurisdiction to sell wine at wholesale. A class \u8220\'3fA\u8221\'3f wine permittee having more than one place of business shall obtain a separate permit for each place of business where wine is to be manufactured, stored, warehoused, or sold.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f wine permit holder may purchase and resell only those brands of wine which are manufactured, fermented, bottled, shipped, or imported by a person holding a certificate of compliance issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.180}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1241, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 91, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 143, \'a710, 17}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a779, 80, 88}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.176}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.178}}}{\*\bkmkstart stylerid1_2E9_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under class \u8220\'3fB\u8221\'3f wine permit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.178A}}}{\*\bkmkstart stylerid1_2E9_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under class \u8220\'3fB\u8221\'3f native wine permit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.178B}}}{\*\bkmkstart stylerid1_2E9_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Authority under class \u8220\'3fC\u8221\'3f native wine permit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1099, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.179}}}{\*\bkmkstart stylerid1_2E9_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wine permit and license fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual permit fee for a class \u8220\'3fA\u8221\'3f wine permit that is not issued to a native wine manufacturer is seven hundred fifty dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual permit fee for a class \u8220\'3fA\u8221\'3f wine permit issued to a native wine manufacturer is one hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for a charity beer, spirits, and wine special event license is one hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fee for a wine auction permit is one hundred dollars.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 143, \'a713, 17}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 51, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a753, 54}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1114, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a713, 15}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1088, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.180}}}{\*\bkmkstart stylerid1_2E9_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vintner\u8217\'3fs certificate of compliance \u8212\'3f wholesale and retail restrictions \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer, vintner, bottler, importer, or vendor of wine, or an agent thereof, desiring to ship, sell, or have wine brought into this state for sale at wholesale by a class \u8220\'3fA\u8221\'3f permittee shall first make application for and shall be issued a vintner\u8217\'3fs certificate of compliance by the director for that purpose. The vintner\u8217\'3fs certificate of compliance shall expire at the end of one year from the date of issuance and shall be renewed for a like period upon application to the director unless otherwise revoked for cause. Each completed application for a vintner\u8217\'3fs certificate of compliance or renewal of a certificate shall be submitted electronically, or in a manner prescribed by the director, and shall be accompanied by a fee of two hundred dollars payable to the department. Each holder of a vintner\u8217\'3fs certificate of compliance shall furnish the information required by the director in the form the director requires. A vintner or wine bottler whose plant is located in Iowa and who otherwise holds a class \u8220\'3fA\u8221\'3f wine permit to sell wine at wholesale is exempt from the fee, but not the other terms and conditions. The holder of a vintner\u8217\'3fs certificate of compliance may also hold a class \u8220\'3fA\u8221\'3f wine permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the time of applying for a vintner\u8217\'3fs certificate of compliance, each applicant shall file with the department a list of all class \u8220\'3fA\u8221\'3f wine permittees with whom it intends to do business. The listing of class \u8220\'3fA\u8221\'3f wine permittees as filed with the department shall be amended by the holder of the certificate of compliance as necessary to keep the listing current with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, all class \u8220\'3fA\u8221\'3f wine permit holders shall sell only those brands of wine which are manufactured, bottled, fermented, shipped, or imported by a person holding a current vintner\u8217\'3fs certificate of compliance. An employee or agent working for or representing the holder of a vintner\u8217\'3fs certificate of compliance within this state shall register the employee\u8217\'3fs or agent\u8217\'3fs name and address with the department. These names and addresses shall be filed with the department\u8217\'3fs copy of the certificate of compliance issued except that this provision does not require the listing of those persons who are employed on the premises of a bottling plant, or winery where wine is manufactured, fermented, or bottled in Iowa or the listing of those persons who are thereafter engaged in the transporting of the wine.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fA\u8221\'3f wine permit holder may sell brands of wine which are not manufactured, bottled, fermented, shipped, or imported by a person holding a current vintner\u8217\'3fs certificate of compliance if the brands of wine were purchased from a private sale pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.171, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, or if authorized by the laws of another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for a holder of a vintner\u8217\'3fs certificate of compliance or the holder\u8217\'3fs agent, or any class \u8220\'3fA\u8221\'3f wine permittee or the permittee\u8217\'3fs agent, to discriminate between class \u8220\'3fB\u8221\'3f, special class \u8220\'3fB\u8221\'3f, and class \u8220\'3fE\u8221\'3f retail alcohol licensees authorized to sell wine at retail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for a holder of a vintner\u8217\'3fs certificate of compliance or the vintner\u8217\'3fs agent who is engaged in the business of selling wine to class \u8220\'3fA\u8221\'3f wine permittees to discriminate between class \u8220\'3fA\u8221\'3f wine permittees authorized to sell wine at wholesale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall subject the holder of a vintner\u8217\'3fs certificate of compliance or a class \u8220\'3fA\u8221\'3f wine permit holder to the general penalties provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall constitute grounds for imposition of a civil penalty, suspension of the certificate or permit, or revocation of the certificate or permit after notice and opportunity for a hearing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.39}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 161, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 252, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 35, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 53, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a755, 56}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a714, 15, 81, 88}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72452}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1088, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7123.32}}}{{\f5\fs12\hyphpar0\qj{, 123.35}}}{{\f5\fs12\hyphpar0\qj{, 123.177}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.181}}}{\*\bkmkstart stylerid1_2E9_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited credit sales.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A class \u8220\'3fA\u8221\'3f wine permittee shall not sell wine on credit to a retail alcohol licensee for a period exceeding thirty days from date of delivery.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 252, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1060, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1099, \'a782, 83, 88}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.182}}}{\*\bkmkstart stylerid1_2E9_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Labels \u8212\'3f point of origin \u8212\'3f conclusive evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All imported bulk wines to be bottled and distributed in the state shall have the point of origin stated on the label. The print size for the point of origin shall be at least half the print size of the brand name on the label.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The label on a bottle or other container in which wine is offered for sale in this state, which label represents the alcoholic content of the wine as being in excess of seventeen percent by weight or twenty-one and twenty-five hundredths percent of alcohol by volume, is conclusive evidence of the alcoholic content of that wine.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a773}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1032, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{123.183}}}{\*\bkmkstart stylerid1_2E9_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wine gallonage tax and related funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the annual permit fee to be paid by each class \u8220\'3fA\u8221\'3f wine permittee, a wine gallonage tax shall be levied and collected from each class \u8220\'3fA\u8221\'3f wine permittee on all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All wine manufactured for sale and sold in this state at wholesale.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All wine imported into this state for sale at wholesale and sold in this state at wholesale. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The direct shipment of wine pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.187}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sale of wine at auction pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 123.173C}}}{{\f5\fs18\hyphpar0\qj{ to a retail alcohol license holder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rate of the wine gallonage tax is one dollar and seventy-five cents for each wine gallon. The same rate shall apply for the fractional parts of a wine gallon. The wine gallonage tax shall not be levied or collected on wine sold by one class \u8220\'3fA\u8221\'3f wine permittee to another class \u8220\'3fA\u8221\'3f wine permittee or on wine that is sold by a class \u8220\'3fA\u8221\'3f wine permittee to a distributor outside of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revenue collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be deposited in the wine gallonage tax fund as created in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A wine gallonage tax fund is created in the office of the treasurer of state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys deposited in the fund are appropriated as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the midwest grape and wine industry institute at Iowa state university of science and technology, two hundred fifty thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the economic development authority for purposes of}}}{{\f5\fs18\hyphpar0\qj{ section 15E.117}}}{{\f5\fs18\hyphpar0\qj{, the balance of moneys in the fund after the appropriation in subparagraph division (a).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund and moneys appropriated from the fund pursuant to subparagraph (2) are not subject to reversion under }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The revenue collected from the wine gallonage tax on wine imported into this state for sale at wholesale and sold in this state at wholesale, and on wine subject to direct shipment as provided in }}}{{\f5\fs18\hyphpar0\qj{section 123.187}}}{{\f5\fs18\hyphpar0\qj{ by a wine manufacturer licensed or permitted pursuant to laws regulating alcoholic beverages in another state, shall be deposited in the beer and liquor control fund created in }}}{{\f5\fs18\hyphpar0\qj{section 123.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a774}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 198, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7753}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 95, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 162, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 143, \'a714, 17}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 113, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 211, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a7164}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 130, \'a729, 71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1136, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 119, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 113, \'a757}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1088, \'a77, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715E.117}}}{{\f5\fs12\hyphpar0\qj{,