\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F233}{\*\bkmkend codeChapter_5F233}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 233}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{NEWBORN INFANT CUSTODY RELEASE PROCEDURES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\f5\fs18\qc\fi0\ri0\li0{ (NEWBORN SAFE HAVEN ACT)}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7232.78}}}{{\f5\fs12\qc{, 232.95}}}{{\f5\fs12\qc{, 232.96A}}}{{\f5\fs12\qc{, 232.102}}}{{\f5\fs12\qc{, 232.104}}}{{\f5\fs12\qc{, 232.111}}}{{\f5\fs12\qc{, 232.116}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{233.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Newborn safe haven Act }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ may be cited as the }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNewborn Safe Haven Act\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdoption service provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a state-licensed private agency which is recognized as exempt under section 501(c)(3) of the Internal Revenue Code and which represents itself as placing children permanently or temporarily in private family homes, receiving children for placement in private family homes, and actually engaging in placement of children in private family homes for adoption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCertified adoption investigator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 600A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmergency medical care provider location\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the physical business location of an emergency medical care provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFire department\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a paid or volunteer fire protection service provided by a benefited fire district under }}}{{\f5\fs18\hyphpar0\qj{chapter 357B}}}{{\f5\fs18\hyphpar0\qj{ or by a county, municipality or township, or a private corporate organization that has a valid contract to provide fire protection service for a benefited fire district, county, municipality, township, or governmental agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFire station\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the physical business location of a fire department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFirst responder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an emergency medical care provider as defined in }}}{{\f5\fs18\hyphpar0\qj{section 147A.1}}}{{\f5\fs18\hyphpar0\qj{, a registered nurse staffing an authorized service program under }}}{{\f5\fs18\hyphpar0\qj{section 147A.12}}}{{\f5\fs18\hyphpar0\qj{, a physician assistant staffing an authorized service program under }}}{{\f5\fs18\hyphpar0\qj{section 147A.13}}}{{\f5\fs18\hyphpar0\qj{, a physician staffing an authorized service program under }}}{{\f5\fs18\hyphpar0\qj{section 147A.13A}}}{{\f5\fs18\hyphpar0\qj{, a fire fighter, or a peace officer as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInstitutional health facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a hospital as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135B.1}}}{{\f5\fs18\hyphpar0\qj{, a facility providing medical or health services that is open twenty-four hours per day, seven days per week, and including a hospital emergency room or a health care facility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNewborn infant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a child who is, or who appears to be, ninety days of age or younger.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNewborn safety device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a padded and climate-controlled receptacle that meets one of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the receptacle is located at a hospital, the receptacle is conspicuous and visible to hospital staff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the receptacle is located at a fire station or an emergency medical care provider location:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fire station or emergency medical care provider location is staffed by a first responder twenty-four hours per day, seven days per week, notwithstanding the time staff is dispatched for an emergency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The receptacle is located in an area that is conspicuous and visible to staff, or the receptacle is located in an area that is not visible to staff but is equipped with a motion sensor and a dual alarm system. The dual alarm system shall be programmed to sound first when the receptacle is opened, immediately placing a telephone call to a 911 service and dispatching an emergency medical care provider or a fire fighter to the location of the receptacle, and to sound a second time, immediately placing a telephone call to a 911 service after movement is detected inside the receptacle.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 67, \'a71, 13}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1050, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1115, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 46, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 136, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1044, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.2}}}{{\f5\fs12\hyphpar0\qj{, 232.78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{233.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Required training and certification in cardiopulmonary resuscitation and first aid }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ adoption service provider employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An adoption service provider shall require and verify that all employees of the adoption service provider responding to the relinquishment of physical custody of a newborn infant in accordance with }{{\f5\fs18\hyphpar0\qj{section 233.2}}}{ are trained and maintain certification in cardiopulmonary resuscitation and first aid for infants and adults.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 46, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{233.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Newborn infant custody release procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A parent of a newborn infant may voluntarily release custody of the newborn infant as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By relinquishing physical custody of the newborn infant, without expressing an intent to again assume physical custody, at an institutional health facility or a fire station, to an adoption service provider, or by authorizing another person to relinquish physical custody on the parent\u8217\'3fs behalf. If physical custody of the newborn infant is not relinquished directly to an individual on duty at an institutional health facility or a fire station, or to an adoption service provider, the parent may take other actions to be reasonably sure that the individual on duty or the adoption service provider is aware that the newborn infant has been left at the institutional health facility, the fire station, or the location of the adoption service provider. The actions may include but are not limited to making telephone contact with the institutional health facility, the fire station, or the adoption service provider, or a 911 service.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By relinquishing physical custody of the newborn infant to medical staff at a hospital or other facility following delivery of the newborn infant in the hospital or other facility when the parent notifies the medical staff that the parent is voluntarily relinquishing physical custody of the newborn infant without expressing an intent to again assume physical custody.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By relinquishing physical custody of the newborn infant at a hospital, a fire station, or an emergency medical care provider location, through a newborn safety device, without expressing an intent to again assume physical custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the procedure described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a parent of a newborn infant may make telephone contact with a 911 service and relinquish physical custody of the newborn infant, without expressing an intent to again assume physical custody, to a first responder who responds to the 911 telephone call.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and for any judicial proceedings associated with the newborn infant, a rebuttable presumption arises that the person who relinquishes physical custody in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is the newborn infant\u8217\'3fs parent or has relinquished physical custody with the parent\u8217\'3fs authorization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the parent or other person relinquishing physical custody of a newborn infant clearly expresses an intent to return to again assume physical custody of the newborn infant, the individual on duty or the medical staff at the institutional health facility, the emergency medical care provider location, or the fire station at which physical custody of the newborn infant was relinquished, the adoption service provider to whom physical custody of the newborn infant was relinquished, or the first responder to whom physical custody of the newborn infant was relinquished, pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall take physical custody of the newborn infant. The individual on duty or the medical staff, the adoption service provider, or the first responder who takes physical custody of the newborn infant may request the parent or other person to provide the name of the parent or parents and information on the medical history of the newborn infant and the newborn infant\u8217\'3fs parent or parents. However, the parent or other person is not required to provide the names or medical history information to comply with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The individual on duty or the medical staff, the adoption service provider, or the first responder who takes physical custody of the newborn infant may perform reasonable acts necessary to protect the physical health or safety of the newborn infant. The individual on duty or the medical staff, the adoption service provider, and the first responder to whom physical custody of the newborn infant was relinquished, and the institutional health facility, the emergency medical care provider location, and the fire station at which physical custody of the newborn infant was relinquished are immune from criminal or civil liability for any acts or omissions made in good faith to comply with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the physical custody of a newborn infant is relinquished at an emergency medical care provider location or a fire station, to an adoption service provider, or to a first responder, the individual on duty at the emergency medical care provider location or the fire station, the adoption service provider, or the first responder who responded to the 911 telephone call shall transport the newborn infant to the nearest institutional health facility. The individual on duty at the emergency medical care provider location or the fire station, the adoption service provider, or the first responder who took physical custody of the newborn infant shall provide any parental identification or medical history information to the institutional health facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the physical custody of the newborn infant is relinquished at an institutional health facility, the state shall reimburse the institutional health facility for the institutional health facility\u8217\'3fs actual expenses in providing care to the newborn infant and in performing acts necessary to protect the physical health or safety of the newborn infant. The reimbursement shall be paid from moneys appropriated for this purpose to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the name of the parent is unknown to the institutional health facility, the individual on duty at the institutional health facility or other person designated by the institutional health facility at which physical custody of the newborn infant was relinquished shall submit the certificate of birth report as required pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 144.14}}}{{\f5\fs18\hyphpar0\qj{. If the name of the parent is disclosed to the institutional health facility, the facility shall submit the certificate of birth report as required pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 144.13}}}{{\f5\fs18\hyphpar0\qj{. The department shall not file the certificate of birth with the county of birth and shall otherwise maintain the confidentiality of the birth certificate in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 144.43}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As soon as possible after the individual on duty or the medical staff, the adoption service provider, or the first responder assumes physical custody of a newborn infant released under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and, if applicable, the individual on duty at the emergency medical care provider location or the fire station, the adoption service provider, or the first responder transports the newborn infant to the nearest institutional health facility under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the individual on duty or the medical staff shall notify either the department or an adoption service provider and the first responder shall notify the department. The department or the adoption service provider shall take the actions necessary to assume the care, control, and custody of the newborn infant as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If physical custody of the newborn infant was not initially relinquished to an adoption service provider, the department shall immediately notify the juvenile court and the county attorney of the department\u8217\'3fs action and the circumstances surrounding the action and request an ex parte order from the juvenile court ordering, in accordance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 232.78, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, the department to take custody of the newborn infant. Upon receiving the order, the department shall take custody of the newborn infant. After the department takes custody of the newborn infant, notwithstanding any provision to the contrary relating to priority placement of the child under }}}{{\f5\fs18\hyphpar0\qj{section 232.78}}}{{\f5\fs18\hyphpar0\qj{, the department shall, if feasible, place the newborn infant in a prospective adoptive home. The department shall maintain a list of prospective adoptive homes that have completed placement investigations and have been preapproved by the department or a certified adoption investigator.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If physical custody of the newborn infant was initially relinquished to an adoption service provider, the adoption service provider shall immediately notify the juvenile court and the county attorney of the adoption service provider\u8217\'3fs action and the circumstances surrounding the action and request an ex parte order from the juvenile court ordering, in accordance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 232.78, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, the adoption service provider to take custody of the newborn infant. Upon receiving the order, the adoption service provider shall take custody of the newborn infant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within twenty-four hours of the department or the adoption service provider taking custody of the newborn infant, the department or the adoption service provider shall notify the juvenile court and the county attorney in writing of the department\u8217\'3fs or adoption service provider\u8217\'3fs action and the circumstances surrounding the action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within twenty-four hours of the adoption service provider taking custody of the newborn infant, the adoption service provider shall notify the department in writing that the adoption service provider has taken custody of the newborn infant and will comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 233}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon being notified in writing by the department or the adoption service provider under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the county attorney shall file a petition alleging the newborn infant to be a child in need of assistance in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 232.87}}}{{\f5\fs18\hyphpar0\qj{ and a petition for termination of parental rights with respect to the newborn infant in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 232.111, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. A hearing on a child in need of assistance petition filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be held at the earliest practicable time. A hearing on a termination of parental rights petition filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be held no later than thirty days after the day the physical custody of the newborn child was relinquished in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ unless the juvenile court continues the hearing beyond the thirty days for good cause shown.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of a petition filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ by either the department or the adoption service provider shall be provided to any known parent and others in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ and shall be served upon any putative father registered with the state registrar of vital statistics pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 144.12A}}}{{\f5\fs18\hyphpar0\qj{. In addition, prior to holding a termination of parental rights hearing with respect to the newborn infant, notice by publication shall be provided as described in }}}{{\f5\fs18\hyphpar0\qj{section 600A.6, subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reasonable efforts, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.102A}}}{{\f5\fs18\hyphpar0\qj{, that are made in regard to the newborn infant shall be limited to the efforts made in a timely manner to finalize a permanency plan for the newborn infant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual on duty or the medical staff at an institutional health facility, emergency medical care provider location, or fire station, the adoption service provider, or the first responder who assumes physical custody of a newborn infant upon the release of the newborn infant under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be provided notice of any hearing held concerning the newborn infant at the same time notice is provided to other parties to the hearing and the individual on duty or the medical staff, the adoption service provider, or the first responder may provide testimony at the hearing.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 67, \'a72, 13}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 89, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1050, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7654, 655}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 112, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a763}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.78}}}{{\f5\fs12\hyphpar0\qj{, 232.95}}}{{\f5\fs12\hyphpar0\qj{, 232.102}}}{{\f5\fs12\hyphpar0\qj{, 232.104}}}{{\f5\fs12\hyphpar0\qj{, 233.1A}}}{{\f5\fs12\hyphpar0\qj{, 233.3}}}{{\f5\fs12\hyphpar0\qj{, 233.4}}}{{\f5\fs12\hyphpar0\qj{, 233.6}}}{{\f5\fs12\hyphpar0\qj{, 726.3}}}{{\f5\fs12\hyphpar0\qj{, 726.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{233.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Immunity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person authorized by the parent to assist with release of custody in accordance with }{{\f5\fs18\hyphpar0\qj{section 233.2}}}{ by relinquishing physical custody of the newborn infant or to otherwise act on the parent\u8217\'3fs behalf is immune from criminal prosecution for abandonment or neglect of the newborn infant under }{{\f5\fs18\hyphpar0\qj{section 726.3}}}{ or }{{\f5\fs18\hyphpar0\qj{726.6}}}{ and civil liability for any reasonable acts or omissions made in good faith in assisting with the release.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 67, \'a73, 13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{233.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rights of parents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Either parent of a newborn infant whose custody was released in accordance with }{{\f5\fs18\hyphpar0\qj{section 233.2}}}{ may intervene in the child in need of assistance or termination of parental rights proceedings held regarding the newborn infant and request that the juvenile court grant custody of the newborn infant to the parent. The requester must show by clear and convincing evidence including but not limited to by the use of DNA profiling as defined in }{{\f5\fs18\hyphpar0\qj{section 81.1}}}{ that the requester is the parent of the newborn infant. If the court determines that the requester is the parent of the newborn infant and that granting custody of the newborn infant to the parent is in the newborn infant\u8217\'3fs best interest, the court shall issue an order granting custody of the newborn infant to the parent. In addition to such order, the court may order services for the newborn infant and the parent as are in the best interest of the newborn infant.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 67, \'a74, 13}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 136, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7233.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{233.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidentiality protections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other privacy protection established in law, a record that is developed, acquired, or held in connection with an individual\u8217\'3fs good faith effort to voluntarily release a newborn infant in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and any identifying information concerning the individual shall be kept confidential. Such record shall not be inspected or the contents disclosed except as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any transcripts or recording of a 911 service telephone call that is made for the purpose of an individual\u8217\'3fs good faith effort to voluntarily release custody of a newborn infant in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and any identifying information concerning the individual shall be kept confidential. Such transcripts or recording of a 911 service telephone call shall not be inspected or the contents disclosed except as provided in this section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A record described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ may be inspected and the contents disclosed without court order to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court and professional court staff, including juvenile court officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The newborn infant and the newborn infant\u8217\'3fs counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The newborn infant\u8217\'3fs parent, guardian, custodian, and those persons\u8217\'3f counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The newborn infant\u8217\'3fs court appointed special advocate and guardian ad litem.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney and the county attorney\u8217\'3fs assistants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency, adoption service provider, association, facility, or institution which has custody of the newborn infant, or is legally responsible for the care, treatment, or supervision of the newborn infant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The newborn infant\u8217\'3fs foster parent or an individual providing a prospective adoptive home or preadoptive care to the newborn infant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to court order a record described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ may be inspected by and the contents may be disclosed to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person conducting bona fide research for research purposes under whatever conditions the court may deem proper, provided that no personal identifying data shall be disclosed to such a person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons who have a direct interest in a proceeding or in the work of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who knowingly discloses, receives, or makes use or permits the use of information derived directly or indirectly from such a record or discloses identifying information concerning such individual, except as provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, commits a serious misdemeanor.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 67, \'a75, 13}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1050, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 46, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{233.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Educational and public information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department and the department of justice shall develop and distribute the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An information card or other publication for distribution by an institutional health facility, an emergency medical care provider location, a fire station, an adoption service provider, or a first responder to a parent who releases custody of a newborn infant in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The publication shall inform the parent of a parent\u8217\'3fs rights under }}}{{\f5\fs18\hyphpar0\qj{section 233.4}}}{{\f5\fs18\hyphpar0\qj{, explain the request for medical history information under }}}{{\f5\fs18\hyphpar0\qj{section 233.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and provide other information deemed pertinent by the departments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Educational materials, public information announcements, and other resources to develop awareness of the availability of the newborn safe haven Act and the involvement of adoption service providers among adolescents, young parents, and others who might avail themselves of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Signage that may be used to identify the institutional health facilities, emergency medical care provider locations, fire stations, and adoption service provider locations at which physical custody of a newborn infant may be relinquished in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 67, \'a76, 13}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 112, \'a771}}}\par}}