li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The following definitions shall apply to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the context otherwise requires, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbook\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecord\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschedule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ kept by a county auditor, assessor, treasurer, recorder, sheriff, or other county officer means the county system as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHome\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a mobile home or a manufactured home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufactured home\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a factory-built structure built under authority of 42 U.S.C. \'a75403, that is required by federal law to display a seal from the United States department of housing and urban development, and was constructed on or after June 15, 1976.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufactured home community\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as land-leased community defined in }}}{{\f5\fs18\hyphpar0\qj{sections 335.30A}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{414.28A}}}{{\f5\fs18\hyphpar0\qj{. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmanufactured home community\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to include manufactured or mobile homes, buildings, tents, or other structures temporarily maintained by any individual, educational institution, or company on their own premises and used exclusively to house their own labor or students.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMobile home\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any vehicle without motive power used or so manufactured or constructed as to permit its being used as a conveyance upon the public streets and highways and so designed, constructed, or reconstructed as will permit the vehicle to be used as a place for human habitation by one or more persons; but shall also include any such vehicle with motive power not registered as a motor vehicle in Iowa. A }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmobile home\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is not built to a mandatory building code, contains no state or federal seals, and was built before June 15, 1976.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMobile home park\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a site, lot, field, or tract of land upon which three or more mobile homes or manufactured homes, or a combination of any of these homes, are placed on developed spaces and operated as a for-profit enterprise with water, sewer or septic, and electrical services available. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmobile home park\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to include manufactured or mobile homes, buildings, tents, or other structures temporarily maintained by any individual, educational institution, or company on their own premises and used exclusively to house their own labor or students.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fModular home\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a factory-built structure which is manufactured to be used as a place of human habitation, is constructed to comply with the Iowa state building code for modular factory-built structures, as adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 103A.7}}}{{\f5\fs18\hyphpar0\qj{, and must display the seal issued by the state building code commissioner.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135D.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71114}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a73 \u8211\'3f 6, 24}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 57, \'a710, 26}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 121, \'a715, 16}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1107, \'a717, 18, 33}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1148, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 153, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1119, \'a7200, 201}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1086, \'a771}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 3, \'a772}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a7145}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a716.45}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 358C.13}}}{{\f5\fs12\hyphpar0\qj{, 364.3}}}{{\f5\fs12\hyphpar0\qj{, 384.84}}}{{\f5\fs12\hyphpar0\qj{, 403.22}}}{{\f5\fs12\hyphpar0\qj{, 423.3}}}{{\f5\fs12\hyphpar0\qj{, 426A.11}}}{{\f5\fs12\hyphpar0\qj{, 427.1(30)}}}{{\f5\fs12\hyphpar0\qj{, 435.24}}}{{\f5\fs12\hyphpar0\qj{, 441.21}}}{{\f5\fs12\hyphpar0\qj{, 555B.1}}}{{\f5\fs12\hyphpar0\qj{, 555C.1}}}{{\f5\fs12\hyphpar0\qj{, 557B.1}}}{{\f5\fs12\hyphpar0\qj{, 562B.7}}}{{\f5\fs12\hyphpar0\qj{, 657A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Placement and taxation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a mobile home is placed outside a mobile home park, the home is to be assessed and taxed as real estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a manufactured home is placed in a manufactured home community or a mobile home park, the home must be titled and is subject to the manufactured or mobile home square foot tax. If a manufactured home is placed outside a manufactured home community or a mobile home park, the home must be titled and is to be assessed and taxed as real estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a modular home shall not be construed to be a mobile home or manufactured home. If a modular home is placed inside or outside a manufactured home community or a mobile home park, the home shall be considered real property and is to be assessed and taxed as real estate. However, if a modular home is placed in a manufactured home community or mobile home park which was in existence on or before January 1, 1998, that modular home shall be subject to property tax pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 435.22}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit the location of a modular home within a manufactured home community or mobile home park.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a7146}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a753, 147}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{435.3 through 435.17}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.18}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person violating any provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135D.18}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.18}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7435.24}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{435.19 through 435.21}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.22}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual tax }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of each mobile home or manufactured home located within a manufactured home community or mobile home park shall pay to the county treasurer an annual tax. However, when the owner is any educational institution and the home is used solely for student housing or when the owner is the state of Iowa or a subdivision of the state, the owner shall be exempt from the tax. The annual tax shall be computed as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Multiply the number of square feet of floor space each home contains when parked and in use by twenty cents. In computing floor space, the exterior measurements of the home shall be used as shown on the certificate of title, but not including any area occupied by a hitching device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the owner of the home is an Iowa resident, has attained the age of twenty-three years on or before December 31 of the base year, and has an income when included with that of a spouse which is less than eight thousand five hundred dollars per year, the annual tax shall not be imposed on the home. If the income is eight thousand five hundred dollars or more but less than sixteen thousand five hundred dollars, the annual tax shall be computed as follows:}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{If the Household}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Annual Tax Per}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Income is:}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Square Foot:}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{$}{{\f5\fs18\hyphpar0\qj{\~\~}}}{8,500 }{{\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{9,499.99}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{3.0 cents}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{9,500 }{{\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{ 10,499.99}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{6.0}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{10,500 }{{\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{ 12,499.99}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{10.0}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{12,500 }{{\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{ 14,499.99}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{13.0}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{14,500 }{{\f5\fs18\hyphpar0\qj{\u8212\'3f}}}{ 16,499.99}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{15.0}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fincome\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means income as defined in }}}{{\f5\fs18\hyphpar0\qj{section 425.17, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbase year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the calendar year preceding the year in which the claim for a reduced rate of tax is filed. The home reduced rate of tax shall only be allowed on the home in which the claimant is residing at the time the claim for a reduced rate of tax is filed or was residing at the time of the claimant\u8217\'3fs death in the case of a claim filed on behalf of a deceased claimant by the claimant\u8217\'3fs legal guardian, spouse, or attorney, or by the executor or administrator of the claimant\u8217\'3fs estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning with the 1998 base year, the income dollar amounts set forth in this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be multiplied by the cumulative adjustment factor for that base year as determined in }}}{{\f5\fs18\hyphpar0\qj{section 425.23, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount thus computed shall be the annual tax for all homes, except as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the sixth through ninth years after the year of manufacture the annual tax is ninety percent of the tax computed according to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For all homes ten or more years after the year of manufacture the annual tax is eighty percent of the tax computed according to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax shall be figured to the nearest even whole dollar.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A claim for credit for manufactured or mobile home tax due shall not be paid or allowed unless the claim is actually filed with the county treasurer between January 1 and June 1, both dates inclusive, immediately preceding the fiscal year during which the home taxes are due. However, in case of sickness, absence, or other disability of the claimant, or if in the judgment of the county treasurer good cause exists, the county treasurer may extend the time for filing a claim for credit through March 31 of the fiscal year during which the home taxes are due. The county treasurer shall certify to the director of revenue on or before May 1 each year the total dollar amount due for claims allowed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The forms for filing the claim shall be provided by the department of revenue. The forms shall require information as determined by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In case of sickness, absence, or other disability of the claimant or if, in the judgment of the director of revenue, good cause exists and the claimant requests an extension, the director may extend the time for filing a claim for credit or reimbursement. However, any further time granted shall not extend beyond June 30 of the fiscal year in which the home taxes are due. Claims filed as a result of this paragraph shall be filed with the director who shall provide for the reimbursement of the claim to the claimant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of revenue shall certify the amount due to each county, which amount shall be the dollar amount which will not be collected due to the granting of the reduced tax rate under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amounts due each county shall be paid by the department of revenue on June 15 of each year, drawn upon warrants payable to the respective county treasurers. The county treasurer in each county shall apportion the payment in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 435.25}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is appropriated annually from the general fund of the state to the department of revenue an amount sufficient to carry out }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, \'a7135D.22; C71, 73, 75, \'a7135D.22, 135D.28; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135D.22}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 172, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 189, \'a71, 2, 4, 6}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1244, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 198, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 210, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1139, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 190, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1250, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 267, \'a7513}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 2nd Ex, ch 1001, \'a7215, 216, 225}}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.22}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a77 \u8211\'3f 9, 24}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1165, \'a730, 50}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1167, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1107, \'a719, 33}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1177, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 152, \'a719, 20, 40}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a790}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 94, \'a72 \u8211\'3f 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.429}}}{{\f5\fs12\hyphpar0\qj{, 331.559}}}{{\f5\fs12\hyphpar0\qj{, 335.30A}}}{{\f5\fs12\hyphpar0\qj{, 414.28A}}}{{\f5\fs12\hyphpar0\qj{, 435.2}}}{{\f5\fs12\hyphpar0\qj{, 435.26A}}}{{\f5\fs12\hyphpar0\qj{, 435.27}}}{{\f5\fs12\hyphpar0\qj{, 435.33}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 4, paragraphs a, c, and e applies to taxes due and payable in fiscal years beginning on or after July 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 94, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.23}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemptions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ prorating tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufacturer\u8217\'3fs and retailer\u8217\'3fs inventory of mobile homes, manufactured homes, or modular homes not in use as a place of human habitation shall be exempt from the annual tax. All travel trailers, fifth-wheel travel trailers, and towable recreational vehicles shall be exempt from this tax. The homes, travel trailers, fifth-wheel travel trailers, and towable recreational vehicles in the inventory of manufacturers and retailers shall be exempt from personal property tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The homes coming into Iowa from out of state and located in a manufactured home community or mobile home park shall be liable for the tax computed pro rata to the nearest whole month, for the time the home is actually situated in Iowa.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135D.23}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 210, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a710, 24}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1108, \'a711, 15}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 67, \'a719, 20}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.559}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.24}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Collection of tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual tax is due and payable to the county treasurer on or after July 1 in each fiscal year and is collectible in the same manner and at the same time as ordinary taxes as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 445.36}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{445.37}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{445.39}}}{{\f5\fs18\hyphpar0\qj{. Interest at the rate prescribed by law shall accrue on unpaid taxes. Both installments of taxes may be paid at one time. The September installment represents a tax period beginning July 1 and ending December 31. The March installment represents a tax period beginning January 1 and ending June 30. A mobile home, manufactured home, or modular home coming into this state from outside the state, put in use from a retailer\u8217\'3fs inventory, or put in use at any time after July 1 or January 1, and located in a manufactured home community or mobile home park, is subject to the taxes prorated for the remaining unexpired months of the tax period, but the purchaser is not required to pay the tax at the time of purchase. Interest attaches the following April 1 for taxes prorated on or after October 1. Interest attaches the following October 1 for taxes prorated on or after April 1. If the taxes are not paid, the county treasurer shall send a statement of delinquent taxes as part of the notice of tax sale as provided in }}}{{\f5\fs18\hyphpar0\qj{section 446.9}}}{{\f5\fs18\hyphpar0\qj{. The owner of a home who sells the home between July 1 and December 31 and obtains a tax clearance statement is responsible only for the September tax payment and is not required to pay taxes for subsequent tax periods. If the owner of a home located in a manufactured home community or mobile home park sells the home, obtains a tax clearance statement, and obtains a replacement home to be located in a manufactured home community or mobile home park, the owner shall not pay taxes under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the newly acquired home for the same tax period that the owner has paid taxes on the home sold. Interest for delinquent taxes shall be calculated to the nearest whole dollar. In calculating interest each fraction of a month shall be counted as an entire month.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The home owners upon issuance of a certificate of title or upon transporting to a new site shall file the address, township, and school district, of the location where the home is parked with the county treasurer\u8217\'3fs office. Failure to comply is punishable as set out in }}}{{\f5\fs18\hyphpar0\qj{section 435.18}}}{{\f5\fs18\hyphpar0\qj{. When the new location is outside of a manufactured home community or mobile home park, the county treasurer shall provide to the assessor a copy of the tax clearance statement for purposes of assessment as real estate on the following January 1.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each manufactured home community or mobile home park owner shall notify monthly the county treasurer concerning any home arriving in or departing from the manufactured home community or park without a tax clearance statement. The records of the owner shall be open to inspection by a duly authorized representative of any law enforcement agency. The manufactured home community or mobile home park owner or manager shall make an annual report to the county treasurer due June 1 of the homes sited in the manufactured home community or mobile home park, listing the owner and mailing address of each home located in the manufactured home community or mobile home park. The report is delinquent if not filed with the county treasurer by June 30. In addition to the annual report, the owner or manager shall also report any changes of homes or owners in a report due December 1, which is delinquent if not filed by December 31. However, if no changes have occurred since the June annual report, the December report is not required to be filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax is a lien on the vehicle senior to any other lien upon it except a judgment obtained in an action to dispose of an abandoned home under }}}{{\f5\fs18\hyphpar0\qj{section 555B.8}}}{{\f5\fs18\hyphpar0\qj{. The home bearing a current registration issued by any other state and remaining within this state for an accumulated period not to exceed ninety days in any twelve-month period is not subject to Iowa tax. However, when one or more persons occupying a home bearing a foreign registration are employed in this state, there is no exemption from the Iowa tax. This tax is in lieu of all other taxes general or local on a home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before a home may be moved from its present site by any person, a tax clearance statement in the name of the owner must be obtained from the county treasurer of the county where the present site is located certifying that taxes are not owing under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for previous years and that the taxes have been paid for the current tax period. When a person moves a home from real property to a retailer\u8217\'3fs stock or to a manufactured home community or mobile home park, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 435.1}}}{{\f5\fs18\hyphpar0\qj{, a tax clearance statement shall be applied for, and issued, from the county treasurer of the county where the present site is located. When the home is moved to another county in this state, the county treasurer shall forward a copy of the tax clearance statement to the county treasurer of the county in which the home is being relocated. However, a tax clearance statement is not required for a home in a manufacturer\u8217\'3fs or retailer\u8217\'3fs stock which has not been used as a place for human habitation. A tax clearance form is not required to move an abandoned home. A tax clearance form is not required in eviction cases provided the manufactured home community or mobile home park owner or manager advises the county treasurer that the tenant is being evicted. If a retailer acquires a home from a person other than a manufacturer, the person shall provide a tax clearance statement in the name of the owner of record to the retailer. The tax clearance statement shall be provided by the county treasurer in a method prescribed by the department of transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As an alternative to the semiannual or annual payment of taxes, the county treasurer may accept partial payments of current year home taxes. The treasurer shall transfer amounts from each taxpayer\u8217\'3fs account to be applied to each semiannual tax installment prior to the delinquency dates specified in }}}{{\f5\fs18\hyphpar0\qj{section 445.37}}}{{\f5\fs18\hyphpar0\qj{ and the amounts collected shall be apportioned by the tenth of the month following transfer. If, prior to the due date of each semiannual installment, the account balance is insufficient to fully satisfy the installment, the treasurer shall transfer and apply the entire account balance, leaving an unpaid balance of the installment. Interest shall attach on the unpaid balance in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 445.39}}}{{\f5\fs18\hyphpar0\qj{. Unless funds sufficient to fully satisfy the delinquency are received, the treasurer shall collect the unpaid balance as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 445.3}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{445.4}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 446}}}{{\f5\fs18\hyphpar0\qj{. Any remaining balance in a taxpayer\u8217\'3fs account in excess of the amount needed to fully satisfy an installment shall remain in the account to be applied toward the next semiannual installment. Any interest income derived from the account shall be deposited in the county\u8217\'3fs general fund to cover administrative costs. The treasurer shall send a notice with the tax statement or by separate mail to each taxpayer stating that, upon request to the treasurer, the taxpayer may make partial payments of current year home taxes.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Partial payment of taxes which are delinquent may be made to the county treasurer. For the installment being paid, payment shall first be applied toward any interest, fees, and costs accrued and the remainder applied to the tax due. A partial payment must equal or exceed the interest, fees, and costs of the installment being paid. A partial payment made under this paragraph shall be apportioned in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 445.57}}}{{\f5\fs18\hyphpar0\qj{, however, such partial payment may, at the discretion of the county treasurer, be apportioned either on or before the tenth day of the month following the receipt of the partial payment or on or before the tenth day of the month following the due date of the next semiannual tax installment. If the payment does not include the whole of any installment of the delinquent tax, the unpaid tax shall continue to accrue interest pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 445.39}}}{{\f5\fs18\hyphpar0\qj{. Partial payment shall not be permitted in lieu of redemption if the property has been sold for taxes under }}}{{\f5\fs18\hyphpar0\qj{chapter 446}}}{{\f5\fs18\hyphpar0\qj{ and under any circumstances shall not constitute an extension of the time period for a sale under }}}{{\f5\fs18\hyphpar0\qj{chapter 446}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Current year taxes may be paid at any time regardless of any outstanding prior year delinquent taxes.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135D.24}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 5, \'a71, 2, 4, 5}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 70, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1139, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71115}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 210, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1138, \'a711, 18}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1080, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1016, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a711, 12, 24}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 83, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1085, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 34, \'a711, 26}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1108, \'a712, 15}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1138, \'a7103}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.559}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}{{\f5\fs12\hyphpar0\qj{, 435.25}}}{{\f5\fs12\hyphpar0\qj{, 435.27}}}{{\f5\fs12\hyphpar0\qj{, 435.29}}}{{\f5\fs12\hyphpar0\qj{, 445.5}}}{{\f5\fs12\hyphpar0\qj{, 445.57}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.25}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Apportionment and collection of taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax and interest for delinquent taxes collected under }}}{{\f5\fs18\hyphpar0\qj{section 435.24}}}{{\f5\fs18\hyphpar0\qj{ shall be apportioned in the same manner as though they were the proceeds of taxes levied on real property at the same location as the home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Chapters 446}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{447}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{448}}}{{\f5\fs18\hyphpar0\qj{ apply to the sale of a home for the collection of delinquent taxes and interest, the redemption of a home sold for the collection of delinquent taxes and interest, and the execution of a tax sale certificate of title for the purchase of a home sold for the collection of delinquent taxes and interest in the same manner as though a home were real property within the meaning of these chapters to the extent consistent with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The certificate of title shall be issued by the county treasurer. The treasurer shall charge ten dollars for each certificate of title, except that the treasurer shall issue a tax sale certificate of title to the county at no charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a home is removed from the county where delinquent taxes, regular or special, are owing, or when it is administratively impractical to pursue tax collection through the remedies of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, all taxes, regular and special, interest, and costs shall be abated by resolution of the county board of supervisors. The resolution shall direct the treasurer to strike from the tax books the reference to that home.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135D.25}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1251, \'a73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 210, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1134, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1016, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a713, 24}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.559}}}{{\f5\fs12\hyphpar0\qj{, 435.22}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Apportionment of property taxes, see }{{\f5\fs12\hyphpar0\qj{\'a7445.38}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.26}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conversion to real property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mobile home or manufactured home which is located outside a manufactured home community or mobile home park shall be converted to real estate by being placed on a permanent foundation and shall be assessed for real estate taxes. A home, after conversion to real estate, is eligible for the homestead tax exemption and credit and the military service tax exemption as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 425, subchapter I}}}{{\f5\fs18\hyphpar0\qj{, and section }}}{{\f5\fs18\hyphpar0\qj{426A.11}}}{{\f5\fs18\hyphpar0\qj{. A taxable mobile home or manufactured home which is located outside of a manufactured home community or mobile home park as of January 1, 1995, is also exempt from the permanent foundation requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ until the home is relocated.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a security interest is noted on the certificate of title, the home owner shall tender to the secured party a mortgage on the real estate upon which the home is to be located in the unpaid amount of the secured debt, and with the same priority as or a higher priority than the secured party\u8217\'3fs security interest, or shall obtain the written consent of the secured party to the conversion, in which latter case the lien notation on the certificate of title shall suffice to preserve the lienholder\u8217\'3fs security in the home separate from any interest in the land.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After complying with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the owner shall notify the assessor who shall inspect the new premises for compliance. If a security interest is noted on the certificate of title, the assessor shall require an affidavit, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 622.85}}}{{\f5\fs18\hyphpar0\qj{, from the home owner, declaring that the owner has complied with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and setting forth the method of compliance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If compliance with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, has been accomplished by the secured party accepting the tender of a mortgage, the assessor shall collect the home vehicle title and enter the property upon the tax rolls.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If compliance with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, has been accomplished by the secured party consenting to the conversion without accepting a mortgage, the secured party shall retain the home vehicle title and the assessor shall note the conversion on the assessor\u8217\'3fs records and enter the property upon the tax rolls. So long as a security interest is noted on the certificate of title, the title to the home will not be merged with title to the land, and the sale or foreclosure of an interest in the land shall not affect title to the home or any security interest in the home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the property is entered on the tax rolls, the assessor shall also enter on the tax rolls the title number last assigned to the mobile home or manufactured home and the manufacturer\u8217\'3fs identification number.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135D.26}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 64, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 98, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 260, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a74, 5}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.26}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a714, 24}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1107, \'a720, 21, 33}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 114, \'a726}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 153, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 108, \'a774}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a7147}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a744, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.301}}}{{\f5\fs12\hyphpar0\qj{, 331.559}}}{{\f5\fs12\hyphpar0\qj{, 364.3}}}{{\f5\fs12\hyphpar0\qj{, 435.27}}}{{\f5\fs12\hyphpar0\qj{, 657A.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 1, paragraph a applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.26A}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Surrender of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who owns a manufactured home that is located in a manufactured home community and is installed on a permanent foundation may surrender the manufactured home\u8217\'3fs certificate of title to the county treasurer for the purpose of assuring eligibility for funds available from mortgage lending programs sponsored by the federal national mortgage association, the federal home loan mortgage corporation, the United States department of agriculture, or any other federal governmental agency or instrumentality that has similar requirements for mortgage lending programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a certificate of title from a manufactured home owner, a county treasurer shall notify the state department of transportation that the certificate of title has been surrendered, remove the registration of title from the county treasurer\u8217\'3fs records, and destroy the certificate of title.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufactured home owner or the owner\u8217\'3fs representative shall provide to the county recorder the identifying data of the manufactured home, including the owner\u8217\'3fs name, the name of the manufacturer, the model name, the year of manufacture, and the serial number of the home, along with the legal description of the real estate on which the manufactured home is located. In addition, evidence shall be provided of the surrender of the certificate of title. After the surrender of the certificate of title of a manufactured home under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, conveyance of an interest in the manufactured home shall not require transfer of title so long as the manufactured home remains on the same real estate site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the surrender of a manufactured home\u8217\'3fs certificate of title under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the manufactured home shall continue to be taxed under }}}{{\f5\fs18\hyphpar0\qj{section 435.22}}}{{\f5\fs18\hyphpar0\qj{ and is not eligible for the homestead tax exemption and credit or the military service tax exemption and credit. A foreclosure action on a manufactured home whose title has been surrendered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be conducted as a real estate foreclosure. A tax lien and its priority shall remain the same on a manufactured home after its certificate of title has been surrendered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate of title of a manufactured home shall not be surrendered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if an unreleased security interest is noted on the certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner of a manufactured home who has surrendered a certificate of title under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and requires another certificate of title for the manufactured home is required to apply for a certificate of title under }}}{{\f5\fs18\hyphpar0\qj{chapter 321}}}{{\f5\fs18\hyphpar0\qj{. If supporting documents for the reissuance of a title are not available or sufficient, the procedure for the reissuance of a title specified in the rules of the state department of transportation shall be used.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 24, \'a77, 10}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7128, 159}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2003 Acts, 1st Ex, ch 2, \'a726, 209}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a745, 48, 49}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 3 applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.26B}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Affidavit in lieu of surrender of certificate of title }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ manufactured and mobile homes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If there is no record that a certificate of title has been issued or surrendered for a manufactured home or mobile home that is located outside a manufactured home community or mobile home park, that has been converted to real estate by being placed on a permanent foundation, and that is entered on the tax rolls, the owner may effectuate a surrender of the certificate of title by recording with the county recorder an affidavit that includes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The full legal name, Iowa driver\u8217\'3fs license number or Iowa nonoperator\u8217\'3fs identification card number, bona fide residence, and mailing address of the owner, and any other identification information required by the state department of transportation. If the owner is a firm, association, or corporation, the affidavit shall contain the bona fide business address and federal employer identification number of the owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of the manufactured or mobile home including, insofar as the specified data may exist with respect to a manufactured or mobile home, the manufacturer, model, year of manufacture, and identification number or other assigned number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement of the affiant\u8217\'3fs title or ownership interest and a statement of all liens, encumbrances, or security interests upon the manufactured or mobile home, including the names and mailing addresses of all persons having any such liens, encumbrances, or security interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement of any facts or information known to the affiant that could affect the validity of title or the existence or validity of any lien, encumbrance, or security interest on the manufactured or mobile home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and address of the person from whom the owner purchased or acquired the manufactured or mobile home, including information related to the location and date of purchase or acquisition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The affidavit shall also include an attached written opinion by an attorney licensed to practice law in this state who has examined the abstract of title of the land upon which the manufactured or mobile home is situated. The opinion shall state the names of the owners and holders of mortgages, liens, or other encumbrances on the land upon which the manufactured or mobile home is situated and shall note the encumbrances, along with any bonds securing the encumbrances. Utility easements shall not be construed to be encumbrances for the purpose of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the manufactured or mobile home is located outside a manufactured home community or mobile home park, has been converted to real estate by being placed on a permanent foundation, and has been entered on the tax rolls. This statement shall be endorsed by the city or county assessor, as applicable, and include the legal description of the real property upon which the manufactured or mobile home is situated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that the owner has made a diligent search and inquiry but has been unable to locate and produce a manufacturer\u8217\'3fs certificate of origin or a certificate of title for the manufactured or mobile home and that the owner has no knowledge that a certificate of title has previously been issued or surrendered for the manufactured or mobile home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An endorsement by the state department of transportation that the department has searched its records and has no record of a certificate of title or a surrender of a certificate of title for the manufactured or mobile home and that the department has no record of any ownership interest contrary to the ownership interest asserted by the affiant. The endorsement shall also specify that the state department of transportation is unable to identify any lien, encumbrance, or security interest contrary to those specified by the affiant. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state department of transportation shall not conduct any search of records or provide any endorsement until the affidavit has been completed, executed, and endorsed pursuant to paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and the affiant has paid a fee not to exceed two hundred dollars. The state department of transportation shall set the amount of the fee by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following endorsement of the affidavit, the state department of transportation shall return the affidavit to the owner for recording. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the state department of transportation has endorsed an affidavit, the department shall not issue a certificate of title for the manufactured or mobile home unless the manufactured or mobile home is reconverted under }}}{{\f5\fs18\hyphpar0\qj{section 435.27}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recording the affidavit with all necessary endorsements and attachments shall establish the surrender of the certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the surrender of the certificate of title under this section, a conveyance of an interest in the manufactured or mobile home shall not require a transfer of title if the manufactured or mobile home remains located on the same real property that is identified in the affidavit under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A foreclosure action on a manufactured or mobile home for which the certificate of title was surrendered under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be conducted as a real estate foreclosure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax lien and its priority shall not be modified as a result of a surrender of title under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state department of transportation shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The rules adopted by the state department of transportation shall include a standardized form for an affidavit required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1108, \'a713, 15}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a753, 80}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.27}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reconversion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mobile home or manufactured home converted to real estate under }}}{{\f5\fs18\hyphpar0\qj{section 435.26}}}{{\f5\fs18\hyphpar0\qj{ may be reconverted to a home as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ when it is moved to a manufactured home community or mobile home park or a manufactured or mobile home retailer\u8217\'3fs inventory. When the home is located within a manufactured home community or mobile home park, the home shall be taxed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 435.22, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicular frame of the home can be modified to return it to the status of a mobile home or manufactured home, the owner or a secured party holding a mortgage or certificate of title pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 435.26}}}{{\f5\fs18\hyphpar0\qj{ who has obtained possession of the home may apply to the county treasurer as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.20}}}{{\f5\fs18\hyphpar0\qj{ for a certificate of title for the home. If a mortgage exists on the real estate, a security interest in the home shall be given to a secured party not applying for reconversion and noted on the certificate of title with the same priority or a higher priority than the secured party\u8217\'3fs mortgage interest. A reconversion shall not occur without the written consent of every secured party holding a mortgage or certificate of title.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the secured party has elected to retain the home vehicle title pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 435.26, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, an owner applying for reconversion shall present to the county treasurer written consent to the reconversion from all secured parties and an affirmation from the secured party holding the title that the title is in its possession and is intact. Upon receipt of the affirmation, the county treasurer shall notify the assessor of the reconversion, which notification constitutes compliance by the owner with }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After compliance with }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ and receipt of the title, the owner shall notify the assessor of the reconversion. The assessor shall remove the assessed valuation of the home from assessment rolls as of the succeeding January 1 when the home becomes subject to taxation as provided under }}}{{\f5\fs18\hyphpar0\qj{section 435.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 98, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7135D.27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 260, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a715, 24}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1107, \'a722, 33}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a716, 18}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a757}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7135, 143}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7435.26B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.28}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County treasurer to notify assessor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon issuance of a certificate of title to a mobile home or manufactured home which is not located in a manufactured home community or mobile home park or retailer\u8217\'3fs inventory, the county treasurer shall notify the assessor of the existence of the home for tax assessment purposes.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a716, 24}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1108, \'a714, 15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.29}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The person who moves the mobile home or manufactured home without having obtained a tax clearance statement as provided in }{{\f5\fs18\hyphpar0\qj{section 435.24}}}{ shall pay a civil penalty of one hundred dollars. The penalty money shall be credited to the general fund of the county.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 70, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS85, \'a7135D.29}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.29}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a717, 24}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1107, \'a723, 33}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{435.30 through 435.32}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.33}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rent reimbursement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A home owner who qualifies for a reduced tax rate provided in }{{\f5\fs18\hyphpar0\qj{section 435.22}}}{ and who rents a space upon which to set the home shall be entitled to the protections provided in }{{\f5\fs18\hyphpar0\qj{sections 425.33 through 425.36}}}{ and if the home owner who qualifies for a reduced tax rate believes that a landlord has increased the home owner\u8217\'3fs rent because the home owner is eligible for a reduced tax rate, the provisions of }{{\f5\fs18\hyphpar0\qj{sections 425.33}}}{ and }{{\f5\fs18\hyphpar0\qj{425.36}}}{ shall be applicable.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7135D.33}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7435.33}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1110, \'a718, 24}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a7131}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.34}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Modular home exemption.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0133.pdf" }{\fldrslt \cf5 \f5 \fs18{{2009 Acts, ch 133, \'a7191}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{\'a7435.2(3)}}}{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{435.35}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Existing home outside of