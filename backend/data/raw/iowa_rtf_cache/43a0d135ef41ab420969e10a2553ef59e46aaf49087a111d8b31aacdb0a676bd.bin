}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ modifies, limits, or supersedes the }{{\f5\fs18\hyphpar0\qj{Electronic Signatures in Global and National Commerce Act}}}{, }{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a77001 et seq.}}}{, but does not modify, limit, or supersede }{{\f5\fs18\hyphpar0\qj{section 101(c) of that Act}}}{, }{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a77001(c)}}}{, or authorize electronic delivery of any of the notices described in }{{\f5\fs18\hyphpar0\qj{section 103(b) of that Act}}}{, }{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a77003(b)}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1040, \'a712, 14, 15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies to a transfer made or an obligation incurred, as provided in }{{\f5\fs12\hyphpar0\qj{\'a7684.6}}}{, on or after July 1, 2016; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2016/CH1040.pdf" }{\fldrslt \cf5 \f5 \fs12{{2016 Acts, ch 1040, \'a715}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{684.15}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{, which was formerly cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUniform Fraudulent Transfer Act\u8221\'3f}}}{, may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa Uniform Voidable Transactions Act\u8221\'3f}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1121, \'a716}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C95, \'a7684.12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1040, \'a713 \u8211\'3f 15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2017, \'a7684.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2016 amendment applies to a transfer made or an obligation incurred, as provided in }{{\f5\fs12\hyphpar0\qj{\'a7684.6}}}{, on or after July 1, 2016; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2016/CH1040.pdf" }{\fldrslt \cf5 \f5 \fs12{{2016 Acts, ch 1040, \'a715}}}}}}\par}}