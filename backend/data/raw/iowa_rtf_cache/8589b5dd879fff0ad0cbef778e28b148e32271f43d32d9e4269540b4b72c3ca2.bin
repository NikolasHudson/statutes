\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F8_301}{\*\bkmkend codeChapter_5F8_301}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 801}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CRIMINAL PROCEDURE SCOPE AND DEFINITIONS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{801.1}}}{\*\bkmkstart stylerid1_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Chapters 801 through 819}}}{ shall be known and may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa Code of Criminal Procedure\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7801.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7378}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{801.2}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of the Iowa code of criminal procedure shall govern procedure in the courts of Iowa in all criminal proceedings except where a different procedure is specifically provided by law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7801.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{801.3}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of the Iowa code of criminal procedure shall be liberally construed to give effect to the general purposes thereof, which shall be to provide for:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Simplicity in criminal procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fairness in administration of the criminal laws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Elimination of unjustifiable delay in pretrial, trial, and post-trial proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Just determination of every criminal proceeding by a fair and impartial trial and review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The effective apprehension and trial of persons suspected of committing public offenses without violation of fundamental human rights.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7801.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{801.4}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purposes of }{{\f5\fs18\hyphpar0\qj{Title XVI}}}{,* unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3faccused person\u8221\'3f, \u8220\'3faccused\u8221\'3f, \u8220\'3fdefendant\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ and similar words mean an individual, a public or private corporation, a partnership, or an unincorporated or voluntary association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAttorney general\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes an authorized assistant of the attorney general.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCharge\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a written statement presented to a court accusing a person of the commission of a public offense, including but not limited to a complaint, information, or indictment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fComplaint\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a statement in writing, under oath or affirmation, made before a magistrate or district court clerk or clerk\u8217\'3fs designee as the case may be, of the commission of a public offense, and accusing someone of committing the public offense. A complaint shall be substantially in the form provided in the Iowa rules of criminal procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty attorney\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes an authorized assistant of the county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCourt\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a place where justice is administered by a magistrate and includes such magistrate while acting in a judicial capacity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCriminal proceeding\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is a proceeding in which a person is accused of a public offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndictable offense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an offense other than a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndigent person\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is indigent as determined in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 815.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMagistrate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all judges of the district court, including district associate judges and judicial magistrates throughout the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeace officers\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, sometimes designated \u8220\'3flaw enforcement officers\u8221\'3f, include:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sheriffs and their regular deputies who are subject to mandated law enforcement training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Marshals and police officers of cities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Peace officer members of the department of public safety as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 80}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Parole officers acting pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 906.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Probation officers acting pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 602.7202, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 907.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Special security officers employed by board of regents institutions as set forth in }}}{{\f5\fs18\hyphpar0\qj{section 262.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conservation officers as authorized by }}}{{\f5\fs18\hyphpar0\qj{section 456A.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such employees of the department of transportation as are designated }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpeace officers\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ by resolution of the department under }}}{{\f5\fs18\hyphpar0\qj{section 321.477}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employees of an aviation authority designated as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpeace officers\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ by the authority under }}}{{\f5\fs18\hyphpar0\qj{section 330A.8, subsection 16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such persons as may be otherwise so designated by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProsecuting attorney\u8221\'3f,}}}{{\f5\fs18\hyphpar0\qj{ sometimes designated }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fprosecutor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, means any attorney who is authorized by law to appear on the behalf of the state in a criminal case, and includes the attorney general, an assistant attorney general, the county attorney, an assistant county attorney, or a special or substitute prosecutor whose appearance is approved by a court having jurisdiction to try the defendant for the offense with which the defendant is charged. In the case of prosecution for a municipal ordinance violation, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fprosecuting attorney\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a city attorney or an assistant city attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProsecution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the commencement, including the filing of a complaint, and continuance of a criminal proceeding, and pursuit of that proceeding to final judgment on behalf of the state or other political subdivision.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a72778, 2822, 2823, 2830; R60, \'a74439, 4440, 4447, 4530; C73, \'a74108, 4109, 4111; C97, \'a75097, 5099, 5101; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13403, 13405, 13458;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7748.1, 748.3, 754.1; C79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7801.4}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71240}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710129, 10130, 10201}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1019, \'a71, 2}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 182, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1233, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a77.10}}}{{\f5\fs12\hyphpar0\qj{, 8A.363}}}{{\f5\fs12\hyphpar0\qj{, 9E.2}}}{{\f5\fs12\hyphpar0\qj{, 70A.9}}}{{\f5\fs12\hyphpar0\qj{, 80F.2}}}{{\f5\fs12\hyphpar0\qj{, 80G.1}}}{{\f5\fs12\hyphpar0\qj{, 80H.1}}}{{\f5\fs12\hyphpar0\qj{, 123.46}}}{{\f5\fs12\hyphpar0\qj{, 125.2}}}{{\f5\fs12\hyphpar0\qj{, 135.190A}}}{{\f5\fs12\hyphpar0\qj{, 147A.1}}}{{\f5\fs12\hyphpar0\qj{, 169.4}}}{{\f5\fs12\hyphpar0\qj{, 229.1}}}{{\f5\fs12\hyphpar0\qj{, 233.1}}}{{\f5\fs12\hyphpar0\qj{, 235F.1}}}{{\f5\fs12\hyphpar0\qj{, 279.84}}}{{\f5\fs12\hyphpar0\qj{, 321.1}}}{{\f5\fs12\hyphpar0\qj{, 321.176A}}}{{\f5\fs12\hyphpar0\qj{, 321.178}}}{{\f5\fs12\hyphpar0\qj{, 321.224}}}{{\f5\fs12\hyphpar0\qj{, 321.231B}}}{{\f5\fs12\hyphpar0\qj{, 321.279}}}{{\f5\fs12\hyphpar0\qj{, 321.484}}}{{\f5\fs12\hyphpar0\qj{, 321.492}}}{{\f5\fs12\hyphpar0\qj{, 321.513}}}{{\f5\fs12\hyphpar0\qj{, 321L.4}}}{{\f5\fs12\hyphpar0\qj{, 330A.8}}}{{\f5\fs12\hyphpar0\qj{, 331.604}}}{{\f5\fs12\hyphpar0\qj{, 331.756(76)(d)}}}{{\f5\fs12\hyphpar0\qj{, 351.45}}}{{\f5\fs12\hyphpar0\qj{, 351.46}}}{{\f5\fs12\hyphpar0\qj{, 422.12P}}}{{\f5\fs12\hyphpar0\qj{, 453A.2}}}{{\f5\fs12\hyphpar0\qj{, 453A.52C}}}{{\f5\fs12\hyphpar0\qj{, 509A.13C}}}{{\f5\fs12\hyphpar0\qj{, 707.11}}}{{\f5\fs12\hyphpar0\qj{, 721.12}}}{{\f5\fs12\hyphpar0\qj{, 804.7}}}{{\f5\fs12\hyphpar0\qj{, 804.7A}}}{{\f5\fs12\hyphpar0\qj{, 804.7B}}}{{\f5\fs12\hyphpar0\qj{, 811.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{*This provision does not include }{{\f5\fs12\hyphpar0\qj{chapters 709A}}}{, }{{\f5\fs12\hyphpar0\qj{718A}}}{, }{{\f5\fs12\hyphpar0\qj{822}}}{, }{{\f5\fs12\hyphpar0\qj{904}}}{, }{{\f5\fs12\hyphpar0\qj{913}}}{, and }{{\f5\fs12\hyphpar0\qj{914}}}{, which were moved into Title XVI by the Code editor. }{{\f5\fs12\hyphpar0\qj{Chapters 709A}}}{, }{{\f5\fs12\hyphpar0\qj{718A}}}{, }{{\f5\fs12\hyphpar0\qj{822}}}{, }{{\f5\fs12\hyphpar0\qj{904}}}{, }{{\f5\fs12\hyphpar0\qj{913}}}{, and }{{\f5\fs12\hyphpar0\qj{914}}}{ contain the applicable provisions pertaining to those chapters. }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{801.5}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applicability to offenses committed before the effective date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Title XVI}}}{{\f5\fs18\hyphpar0\qj{* does not apply to offenses committed before January 1, 1978. Prosecutions for offenses committed before that date are governed by the prior law, which is continued in effect for that purpose, as if this title* were not in force. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, an offense is committed before said date if any of the elements of the offense occurred before that date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any case pending on or commenced after said date, involving an offense committed before that date:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the request of the defendant a defense or mitigation under this title,* whether specifically provided for herein or based upon the failure of said statutes to define an applicable offense, shall apply; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the request of the defendant and the approval of the court:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Procedural provisions of this title* shall apply insofar as they are justly applicable; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may impose a sentence or suspended imposition of a sentence under the provisions of this title* applicable to the offense and the offender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions of this title* governing the release or discharge of prisoners, probationers, and parolees shall apply to persons under sentence for offenses committed before January 1, 1978, except that the minimum or maximum period of their detention or supervision shall in no case be increased, nor shall the provisions of this title* affect the substantive or procedural validity of any judgment of conviction entered before said date, regardless of the fact that appeal time has not run or that an appeal is pending.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7801.5}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{*This provision does not include }{{\f5\fs12\hyphpar0\qj{chapters 709A}}}{, }{{\f5\fs12\hyphpar0\qj{718A}}}{, }{{\f5\fs12\hyphpar0\qj{822}}}{, }{{\f5\fs12\hyphpar0\qj{904}}}{, }{{\f5\fs12\hyphpar0\qj{913}}}{, and }{{\f5\fs12\hyphpar0\qj{914}}}{, which were moved into Title XVI by the Code editor. }{{\f5\fs12\hyphpar0\qj{Chapters 709A}}}{, }{{\f5\fs12\hyphpar0\qj{718A}}}{, }{{\f5\fs12\hyphpar0\qj{822}}}{, }{{\f5\fs12\hyphpar0\qj{904}}}{, }{{\f5\fs12\hyphpar0\qj{913}}}{, and }{{\f5\fs12\hyphpar0\qj{914}}}{ contain the applicable provisions pertaining to those chapters. }\par}}