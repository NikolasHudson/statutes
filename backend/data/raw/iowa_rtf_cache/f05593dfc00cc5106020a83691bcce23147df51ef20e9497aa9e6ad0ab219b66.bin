\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F89A}{\*\bkmkend codeChapter_5F89A}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 89A}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{ELEVATORS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a710A.202}}}{{\f5\fs12\qc{, 10A.204}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, except as otherwise expressly provided:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAlteration\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any change made to an existing conveyance, other than the repair or replacement of damaged, worn, or broken parts necessary for normal maintenance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConveyance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an elevator, dumbwaiter, escalator, moving walk, lift, or inclined or vertical wheelchair lift subject to regulation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and includes hoistways, rails, guides, and all other related mechanical and electrical equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDormant conveyance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a conveyance whose power feed lines have been disconnected from the mainline disconnect switch and is one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An electric elevator, material lift, or dumbwaiter whose suspension ropes have been removed, whose car and counterweight rest at the bottom of the hoistway, and whose hoistway doors have been permanently barricaded or sealed in the closed position on the hoistway side.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hydraulic elevator, material lift, or dumbwaiter whose car rests at the bottom of the hoistway, whose pressure piping has been disassembled and a section removed from the premises; whose hoistway doors have been permanently barricaded or sealed in the closed position on the hoistway side; and, if provided, whose suspension ropes have been removed and the counterweights landed at the bottom of the hoistway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An escalator or moving walk whose entrances have been permanently barricaded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A rack and pinion or screw column elevator, whose motor has been removed, platform lowered to the bottom, and entrances barricaded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDumbwaiter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a hoisting and lowering mechanism equipped with a car which moves in guides in a substantially vertical direction, when the floor area does not exceed nine square feet, the total compartment height does not exceed four feet, the capacity does not exceed five hundred pounds, and which is used exclusively for carrying materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElevator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a hoisting and lowering mechanism equipped with a car or platform which moves in guides in a substantially vertical direction, and which serves two or more floors of a building or structure. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElevator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a dumbwaiter, endless belt, conveyor, chain or bucket hoist, construction hoist, or other device used for the primary purpose of elevating or lowering building or other materials and not used as a means of conveyance for individuals, and does not include tiering, piling, feeding, or other machines or devices giving service within only one story.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEscalator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a power-driven, inclined, continuous stairway used for raising or lowering passengers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFreight elevator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an elevator used for carrying freight and on which only the operator and persons necessary for unloading and loading the freight are permitted to ride.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInclined or vertical wheelchair lift\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a lift used to transport a wheelchair as specified in the American society of mechanical engineers safety standard for platform lifts and stairway chairlifts, A18.1.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInspector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an inspector employed by the department for the purpose of administering }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLift\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a device consisting of a power-driven endless belt, provided with steps or platforms and handholds attached to it for the transportation of persons from floor to floor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMaterial lift elevator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an elevator limited in use to the movement of materials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMoving walk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a type of passenger-carrying device on which passengers stand or walk, and in which the passenger-carrying surface remains parallel to its direction in motion and is uninterrupted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNew installation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a conveyance the construction or relocation of which is begun, or for which an application for a new installation permit is filed, on or after the effective date of rules relating to those permits adopted by the director under authority of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. All other installations are existing installations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOwner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the owner of a conveyance, unless the conveyance is a new installation or is undergoing major alterations, in which case the owner shall be considered the person responsible for the installation or alteration of the conveyance until the conveyance has passed final inspection by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPassenger elevator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an elevator that is used to carry persons other than the operator and persons necessary for loading and unloading.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSafety board\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the elevator safety board created in }}}{{\f5\fs18\hyphpar0\qj{section 89A.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSpecial inspector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an inspector commissioned by the director, and not employed by the department.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1094, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1157, \'a71, 2}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7937}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.1}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1025, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1186, \'a723}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 68, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1097, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a711, 12, 30}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 16, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1029, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71804 \u8211\'3f 1806}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall be known as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa State Elevator Code\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.18}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C83, \'a7104.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 64, \'a7110}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a789A.1A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope of chapter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any conveyance installed in any single private dwelling residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Material hoists subject to regulation under }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/rule/875.26.1.pdf" }{\fldrslt \cf5 \f5 \fs18{{875 IAC 26.1}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj\cf1{29 C.F.R. \'a71926.552}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lifts subject to regulation under }}}{{\f5\fs18\hyphpar0\qj{chapter 88}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Material lift elevators existing in the same location since prior to January 1, 1975.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conveyances over which an agency of the federal government is asserting similar enforcement jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An elevator installed in a building in a federally designated national historic district as long as each of the following conditions is met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of the building owns a commercial enterprise that occupies the first story of the building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The building has no more than two stories above the first story of the building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of the building lives in the upper stories of the building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The building has sufficient physical barriers or safety protocols to ensure that only the owner, the owner\u8217\'3fs guests, or a government official acting in an official capacity can access the elevator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ supersede conflicting provisions contained in building codes of this state or any subdivision of this state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 16, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1029, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1043, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a743, 44}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{State building code, see }{{\f5\fs12\hyphpar0\qj{chapter 103A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The safety board may adopt rules governing maintenance, construction, alteration, and installation of conveyances, and the inspection and testing of new and existing installations as necessary to provide for the public safety, and to protect the public welfare.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The safety board shall adopt, amend, or repeal rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ as it deems necessary for the administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, which shall include but not be limited to rules providing for:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Classifications of types of conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintenance, inspection, testing, and operation of the various classes of conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Construction of new conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alteration of existing conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Minimum safety requirements for all existing conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Control or prevention of access to conveyances or dormant conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reporting of accidents and injuries arising from the use of conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The adoption of procedures for the issuance of variances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of fees charged and collected for inspection, permits, and commissions. Fees shall be set at an amount sufficient to cover costs as determined from consideration of the reasonable time required to conduct an inspection, reasonable hourly wages paid to inspectors, and reasonable transportation and similar expenses. The safety board shall also be authorized to consider setting reduced fees for nonprofit associations and nonprofit corporations, as described in }}}{{\f5\fs18\hyphpar0\qj{chapters 501B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{504}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submission of information such as plans, drawings, and measurements concerning new installations and alterations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The safety board shall adopt rules for conveyances according to the applicable provisions of the American society of mechanical engineers safety codes for elevators and escalators, A17.1 and A17.3, as the safety board deems necessary. In adopting rules the safety board may adopt the American society of mechanical engineers safety codes, or any part of the codes, by reference.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The safety board may adopt rules permitting existing passenger and freight elevators to be modified into material lift elevators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall furnish copies of the rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to any person who requests them, without charge, or upon payment of a charge not to exceed the actual cost of printing of the rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The safety board may adopt rules permitting inclined or vertical wheelchair lifts in churches and houses of worship to service more than one floor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ relating to the denial, issuance, revocation, and suspension of special inspector commissions.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1678;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7104.1; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1094, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1157, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1042, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 68, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1107, \'a713 \u8211\'3f 17, 30}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 16, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 85, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1103, \'a735, 51}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71807}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1169, \'a714}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Director\u8217\'3fs duties and personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall enforce the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The director shall employ personnel for the administration of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 8A, subchapter IV}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7162}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71808}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Registration of conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The owner of every existing conveyance, whether or not dormant, shall register the conveyance with the director, giving type, contract load and speed, name of manufacturer, its location, and the purpose for which it is used, and other information the director may require. Registration shall be made in a format required by the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.5}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 68, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 16, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71809}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspections \u8212\'3f reports \u8212\'3f nonliability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All new and existing conveyances, except dormant conveyances, shall be tested and inspected in accordance with the following schedule:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every new or altered conveyance shall be inspected and tested before the operating permit is issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every existing conveyance registered with the director shall be inspected within one year after the effective date of the registration, except that the safety board may extend by rule the time specified for making inspections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every conveyance shall be inspected not less frequently than annually, except that the safety board may adopt rules providing for inspections of conveyances at intervals other than annually.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The inspections required by }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 3}}}{{\f5\fs18\hyphpar0\qj{ shall be made only by inspectors or special inspectors. An inspection by a special inspector may be accepted by the director in lieu of a required inspection by an inspector.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A report of every inspection shall be filed with the director by the inspector or special inspector, in a format required by the director, after the inspection has been completed and within the time provided by rule, but not to exceed thirty days. The report shall include all information required by the director to determine whether the conveyance is in compliance with applicable rules. For the inspection required by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the report shall indicate whether the conveyance has been installed in accordance with the detailed plans and specifications approved by the director, and meets the requirements of the applicable rules. The failure of a special inspector to inform the director of violations shall not subject the director to liability for any damages incurred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the inspections required by }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 3}}}{{\f5\fs18\hyphpar0\qj{, the safety board may provide by rule for additional inspections as the safety board deems necessary to enforce the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.6}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1077, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1098, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 68, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1107, \'a718, 30}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 16, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71810}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a789A.9}}}{{\f5\fs12\hyphpar0\qj{, 89A.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Alteration permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The owner shall submit to the director detailed plans, specifications, and other information the director may require for each conveyance to be altered, together with an application for an alteration permit, in a format required by the director. Repairs or replacements necessary for normal maintenance are not alterations, and may be made on existing installations with parts equivalent in material, strength, and design to those replaced and no plans or specifications or application need be filed for the repairs or replacements. However, }{{\f5\fs18\hyphpar0\qj{this section}}}{ does not authorize the use of any conveyance contrary to an order issued pursuant to }{{\f5\fs18\hyphpar0\qj{section 89A.10, subsections 2 and 3}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.7}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 68, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 16, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71811}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{New installation permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The installation or relocation of a conveyance shall not begin until an installation permit has been issued by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for an installation permit shall be submitted in a format determined by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the application or any accompanying materials indicates a failure to comply with applicable rules, the director shall give notice of the compliance failures to the person filing the application.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the application indicates compliance with applicable rules or after compliance failures have been remedied, the director shall issue an installation permit for relocation or installation, as applicable.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.8}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 68, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 85, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71812}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operating permits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating permits shall be issued by the director to the owner of every conveyance when the inspection report indicates compliance with the applicable provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, a permit shall not be issued if the fees required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ have not been paid. Permits shall be issued within thirty days after filing of the inspection report required by }}}{{\f5\fs18\hyphpar0\qj{section 89A.6}}}{{\f5\fs18\hyphpar0\qj{, unless the time is extended for cause by the department. A conveyance shall not be operated after the thirty days or after an extension granted by the director has expired, unless an operating permit has been issued.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operating permit shall indicate the type of equipment for which it is issued, and in the case of elevators shall state whether passenger or freight, and also shall state the contract load and speed for each conveyance. The permit shall be posted conspicuously in the car of an elevator, or on or near a dumbwaiter, escalator, moving walk, or inclined or vertical wheelchair lift.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1067, \'a720}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a719, 30}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 16, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1029, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71813}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement orders by director }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an inspection report indicates a failure to comply with applicable rules, or with the detailed plans and specifications approved by the director, the director may, upon giving notice, order the owner of a conveyance to make the changes necessary for compliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the owner does not make the changes necessary for compliance as required in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ within the period specified by the director, the director, upon notice, may suspend or revoke the operating permit, or may refuse to issue the operating permit for the conveyance. The director shall notify the owner of any action to suspend, revoke, or refuse to issue an operating permit and the reason for the action by service in the same manner as an original notice or by certified mail. An owner may appeal the director\u8217\'3fs initial decision to the safety board. The decision of the safety board shall be considered final agency action pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director has reason to believe that the continued operation of a conveyance constitutes an imminent danger which could reasonably be expected to seriously injure or cause death to any person, in addition to any other remedies, the director may apply to the district court in the county in which such imminently dangerous condition exists for a temporary order for the purpose of enjoining such imminently dangerous conveyance. Upon hearing, if deemed appropriate by the court, a permanent injunction may be issued to ensure that such imminently dangerous conveyance be prevented or controlled. Upon the elimination or rectification of such imminently dangerous condition, the temporary or permanent injunction shall be vacated.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7526}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1109, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 68, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1107, \'a720, 21, 30}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 16, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71814}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a789A.7}}}{{\f5\fs12\hyphpar0\qj{, 89A.11}}}{{\f5\fs12\hyphpar0\qj{, 89A.18}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(25)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonconforming conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The safety board, pursuant to rule, may grant exceptions and variances from the requirements of rules adopted for any conveyance. Exceptions or variations shall be reasonably related to the age of the conveyance, and may be conditioned upon a repair or modification of the conveyance deemed necessary by the safety board to assure reasonable safety. However, an exception or variance shall not be granted except to prevent undue hardship. Such conveyances shall be subject to orders issued pursuant to }{{\f5\fs18\hyphpar0\qj{section 89A.10}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.11}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 50, \'a71}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a722, 30}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 16, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Access to conveyances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every owner of a conveyance subject to regulation by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall grant access to that conveyance to the director and personnel of the department. Inspections shall be permitted at reasonable times, with or without prior notice.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.12}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.12}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 68, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 16, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71815}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.13}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Elevator safety board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An elevator safety board is created within the department to formulate definitions and rules for the safe and proper installation, repair, maintenance, alteration, use, and operation of conveyances in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The safety board is composed of nine members, one of whom shall be the director or the director\u8217\'3fs designee. The governor shall appoint the remaining eight members of the board, subject to senate confirmation, to staggered four-year terms which shall begin and end as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{. The members shall be as follows:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{two representatives from an elevator manufacturing company or its authorized representative; two representatives from elevator servicing companies; one building owner or manager; one representative employed by a local government in this state who is knowledgeable about building codes in this state; one representative of workers actively involved in the installation, maintenance, and repair of elevators; and one licensed mechanical engineer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy in membership shall be filled in the same manner as the original appointment. The members shall serve without salary, but shall be reimbursed for actual and necessary expenses incurred in the performance of official duties as a member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the safety board shall select a chairperson, vice chairperson, and a secretary from their membership. However, neither the director nor the director\u8217\'3fs designee shall serve as chairperson. The safety board shall meet at least quarterly but may meet as often as necessary. Meetings shall be set by a majority of the safety board or upon the call of the chairperson, or in the chairperson\u8217\'3fs absence, upon the call of the vice chairperson. A majority of the safety board members shall constitute a quorum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner or user of equipment regulated under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may appeal a notice of defect or an inspection report to the safety board within thirty days after the issuance of the notice or report. Safety board action constitutes final agency action for purposes of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The safety board shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ necessary to administer the duties of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than July 1, 2005, and every three years thereafter, the safety board shall conduct a comprehensive review of existing conveyance rules, regulations, and standards.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.13}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1042, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a723, 30}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 16, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71816}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a789A.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Continuing duty of owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every conveyance shall be maintained by the owner in a safe operating condition and in conformity with the rules adopted by the safety board.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a724, 30}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 16, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.15}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspections by local authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city or other governmental subdivision shall not make or maintain any ordinance, bylaw, or resolution providing for the licensing of special inspectors. An ordinance or resolution relating to the inspection, construction, installation, alteration, maintenance, or operation of conveyances within the limits of the city or governmental subdivision which conflicts with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or with rules adopted pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is void. The director, in the director\u8217\'3fs discretion, may accept inspections by local authorities in lieu of inspections required by }{{\f5\fs18\hyphpar0\qj{section 89A.6}}}{, but only upon a showing by the local authority that applicable laws and rules will be consistently and literally enforced and that inspections will be performed by special inspectors.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.15}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a725, 30}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 16, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71817}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.304}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.16}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prosecution of offenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall cause prosecution for the violation of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to be instituted by the attorney general in the county in which the violation occurred.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.16}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a71818}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.17}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any owner who violates any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be guilty of a simple misdemeanor, unless otherwise specifically provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who bribes or attempts to bribe an inspector shall be subject to criminal proceedings under }}}{{\f5\fs18\hyphpar0\qj{section 722.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7104.17}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.18}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If upon notice and hearing the director determines that an owner has operated a conveyance after an order of the director that suspends, revokes, or refuses to issue an operating permit for the conveyance has become final under }{{\f5\fs18\hyphpar0\qj{section 89A.10, subsection 2}}}{, the director may assess a civil penalty against the owner in an amount not exceeding five hundred dollars, as determined by the director. An order assessing a civil penalty is subject to appeal under }{{\f5\fs18\hyphpar0\qj{section 89A.10, subsection 2}}}{, in the same manner and to the same extent as decisions referred to in that subsection. The director may commence an action in the district court to enforce payment of the civil penalty. A record of assessment against or payment of a civil penalty by any person for a violation of }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall not be admissible as evidence in any court in any civil action. Revenue from the penalty provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be remitted to the treasurer of state for deposit in the state general fund.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1077, \'a72}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a789A.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a726, 30}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 16, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71819}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.19}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All fees collected by the director pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be remitted to the treasurer of state, to be deposited in the licensing and regulation fund created in }{{\f5\fs18\hyphpar0\qj{section 10A.507}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1107, \'a727, 30}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1023, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71820}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 108, \'a734}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{89A.20 through 89A.24}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{89A.25}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transferred to }}}{{\f5\fs18\hyphpar0\qj{\'a789A.1A}}}{{\f5\fs18\hyphpar0\qj{; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH0064.pdf" }{\fldrslt \cf5 \f5 \fs18{{2023 Acts, ch 64, \'a7110}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}}