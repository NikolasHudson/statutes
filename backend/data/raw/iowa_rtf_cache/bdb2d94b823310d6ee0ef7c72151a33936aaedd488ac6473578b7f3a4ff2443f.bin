\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F495}{\*\bkmkend codeChapter_5F495}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 495}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{FOREIGN PUBLIC UTILITY CORPORATIONS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7490.1801}}}{{\f5\fs12\qc{, 669.14}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{495.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Capital stock and permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sections 492.5 through 492.9}}}{ are applicable to any foreign corporation which directly or indirectly owns, uses, operates, controls, or is concerned in the operation of any public gasworks, electric light plant, heating plant, waterworks, interurban or street railway located within the state, or the carrying on of any gas, electric light, electric power, heating business, waterworks, interurban or street railway business within the state, or that owns or controls, directly or indirectly, any of the capital stock of any corporation which owns, uses, operates or is concerned in the operation of any public gasworks, electric light plant, electric power plant, heating plant, waterworks, interurban or street railway located within the state, or any foreign corporation that exercises any control in any way or in any manner over any of such works, plants, interurban or street railways or the business carried on by such works, plants, interurban or street railways by or through the ownership of the capital stock of any corporation or corporations or in any other manner whatsoever. The ownership, operation, or control of any such works, plants, interurban or street railways or the business carried on by any of such works or plants or the ownership or control of the capital stock in any corporation owning or operating any of such works, plants, interurban or street railways by any foreign corporation in violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is unlawful.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71641-1; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8433;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7495.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 126, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7319}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{495.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Holding companies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are hereby made applicable to all corporations, including so-called \u8220\'3fholding companies\u8221\'3f which by or through the ownership of the capital stock in any other corporation or corporations or a series of corporations owning or controlling the capital stock of each other can or may exercise control over the capital stock of any corporation which owns, uses, operates, or is concerned in the operation of any public gasworks, electric light plant, electric power plant, heating plant, waterworks, interurban or street railway located in the state, or the business carried on by such works or plants.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71641-m; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8434;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7495.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{495.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Biennial report \u8212\'3f fee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All corporations subject to the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are hereby required to pay the fee and to make the biennial report in the form and manner and at the time as specified in }{{\f5\fs18\hyphpar0\qj{chapter 490}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71641-n; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8435;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7495.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1022, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{495.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale of capital stock.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are hereby made applicable to the sale of its own capital stock by any corporation subject to the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, whether said capital stock has been heretofore issued by said corporation or not, including the sale of so-called \u8220\'3ftreasury stock\u8221\'3f or stock of the corporation in the hands of a trustee or where the corporation participates in any way or manner in the benefits of said sales, and also to the sale of any of the obligations of any corporation subject to the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the payment of which is secured by the deposit or pledge of any of the capital stock of said corporation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71641-o; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8436;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7495.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{495.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations \u8212\'3f stock void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shares of capital stock of any corporation owned or controlled in violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be void and the holder of such shares shall not be entitled to exercise the powers of a shareholder of the corporation or permitted to participate in or be entitled to any of the benefits accruing to shareholders of the corporation. }{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall be construed so as to prevent evasion and to accomplish the intents and purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71641-p; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8437;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7495.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 126, \'a714}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{495.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dissolution \u8212\'3f receiver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Courts of equity shall have full power to dissolve, close up, or dispose of any business or property owned, operated, or controlled in violation of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{; to dissolve any corporation owning or controlling the capital stock of any other corporation in violation of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and to close up or dispose of the business or property of said corporation; and if the court finds that, in order to carry out the purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, it is necessary so to do, it may dissolve the corporation issuing the stock which is owned in violation of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, close up the business of said corporation and dispose of its property, and the court may also appoint a receiver who shall be a resident of Iowa for any business or for any corporation which has violated the provisions thereof or of the corporation issuing the stock which is held in violation thereof. Any action to enforce the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may be instituted by the attorney general in the name of the state of Iowa or by a citizen in the name of the state of Iowa at the citizen\u8217\'3fs own proper cost and expense, reserving, however, to the stockholders owning capital stock not held in violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ all rights possessed by them.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71641-q; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{8438;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7495.6}}}{]}\par}}