\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F427B}{\*\bkmkend codeChapter_5F427B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 427B}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{SPECIAL TAX PROVISIONS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7331.303}}}{{\f5\fs12\qc{, 331.402}}}{{\f5\fs12\qc{, 437A.16A}}}{{\f5\fs12\qc{, 441.47}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E2_2E2}{INDUSTRIAL PROPERTY AND CATTLE FACILITIES ACTUAL VALUE ADDED EXEMPTION}{\*\bkmkend stylerid1_2E5_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.1}}}{\*\bkmkstart stylerid1_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Actual value added exemption from tax }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ public hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDistribution center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a building or structure used primarily for the storage of goods which are intended for subsequent shipment to retail outlets. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDistribution center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean a building or structure used primarily to store raw agricultural products, used primarily by a manufacturer to store goods to be used in the manufacturing process, used primarily for the storage of petroleum products, or used for the retail sale of goods.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNew construction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means new buildings and structures and includes new buildings and structures which are constructed as additions to existing buildings and structures. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNew construction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include reconstruction of an existing building or structure which does not constitute complete replacement of an existing building or structure or refitting of an existing building or structure, unless the reconstruction of an existing building or structure is required due to economic obsolescence and the reconstruction is necessary to implement recognized industry standards for the manufacturing and processing of specific products and the reconstruction is required for the owner of the building or structure to continue to competitively manufacture or process those products which determination shall receive prior approval from the city council of the city or the board of supervisors of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResearch-service facilities\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a building or group of buildings devoted primarily to research and development activities, including but not limited to the design and production or manufacture of prototype products for experimental use, and corporate-research services which do not have a primary purpose of providing on-site services to the public. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWarehouse\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a building or structure used as a public warehouse for the storage of goods pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 554, article 7}}}{{\f5\fs18\hyphpar0\qj{, except that it does not mean a building or structure used primarily to store raw agricultural products or from which goods are sold at retail.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city council, or a county board of supervisors as authorized by }}}{{\f5\fs18\hyphpar0\qj{section 427B.2}}}{{\f5\fs18\hyphpar0\qj{, may provide by ordinance for a partial exemption from property taxation of the actual value added to industrial real estate by the new construction of industrial real estate, research-service facilities, warehouses, distribution centers and the acquisition of or improvement to machinery and equipment assessed as real estate pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 427A.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The exemption shall also apply to new machinery and equipment assessed as real estate pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 427A.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, unless the machinery or equipment is part of the normal replacement or operating process to maintain or expand the existing operational status. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ordinance may be enacted not less than thirty days after a public hearing is held in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 335.6}}}{{\f5\fs18\hyphpar0\qj{ in the case of a county, or }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{ in the case of a city. The ordinance shall designate the length of time the partial exemption shall be available and may provide for an exemption schedule in lieu of that provided in }}}{{\f5\fs18\hyphpar0\qj{section 427B.3}}}{{\f5\fs18\hyphpar0\qj{. However, an alternative exemption schedule adopted shall not provide for a larger tax exemption in a particular year than is provided for that year in the schedule contained in }}}{{\f5\fs18\hyphpar0\qj{section 427B.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7427B.1}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a720}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1232, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 232, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 34, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a7123}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.19}}}{{\f5\fs12\hyphpar0\qj{, 427.1(27)(c)}}}{{\f5\fs12\hyphpar0\qj{, 427.1(27)(d)}}}{{\f5\fs12\hyphpar0\qj{, 427B.2}}}{{\f5\fs12\hyphpar0\qj{, 427B.3}}}{{\f5\fs12\hyphpar0\qj{, 427B.4}}}{{\f5\fs12\hyphpar0\qj{, 427B.5}}}{{\f5\fs12\hyphpar0\qj{, 427B.7}}}{{\f5\fs12\hyphpar0\qj{, 427B.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.2}}}{\*\bkmkstart stylerid1_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Zoning under }}}{{\f5\b\fs18\hyphpar0\qj{chapter 335}}}{{\f5\b\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors of a county which has appointed a county zoning commission and provided for county zoning under }}}{{\f5\fs18\hyphpar0\qj{chapter 335}}}{{\f5\fs18\hyphpar0\qj{ may provide for a partial exemption from property taxation of the actual value added to industrial real estate as provided under }}}{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors of a county which has not appointed a zoning commission may provide for a partial exemption from property taxation of the actual value added to industrial real estate as provided under }}}{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{{\f5\fs18\hyphpar0\qj{ in the following areas:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Outside the incorporated limits of a city to which a city has extended its zoning ordinance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 414.23}}}{{\f5\fs18\hyphpar0\qj{ which complies with the city\u8217\'3fs zoning ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Outside the incorporated limits of a city which has adopted a zoning ordinance but which has not extended the ordinance to the area permitted under }}}{{\f5\fs18\hyphpar0\qj{section 414.23}}}{{\f5\fs18\hyphpar0\qj{ if the property would be within the area to which a city may extend a zoning ordinance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 414.23}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Outside the incorporated limits of a city which has not adopted a zoning ordinance but which would be within the area to which a city may extend a zoning ordinance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 414.23}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors of a county which has not appointed a zoning commission may provide for a partial exemption from property taxation of the actual value added to industrial real estate as provided under }}}{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{{\f5\fs18\hyphpar0\qj{ in an area where the partial exemption could not otherwise be granted under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ where the actual value added is to industrial real estate existing on July 1, 1979.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To grant an exemption under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the county board of supervisors shall comply with all of the requirements imposed by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ upon the city council of a city.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7427B.2}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a721 \u8211\'3f 23}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a7255}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7427B.1}}}{{\f5\fs12\hyphpar0\qj{, 427B.7}}}{{\f5\fs12\hyphpar0\qj{, 427B.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.3}}}{\*\bkmkstart stylerid1_2E5_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Period of partial exemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fActual value added\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, as used in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, means the actual value added as of the first year for which the exemption is received, except that actual value added by improvements to machinery and equipment means the actual value as determined by the assessor as of January 1 of each year for which the exemption is received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The actual value added to industrial real estate for the reasons specified in }}}{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{{\f5\fs18\hyphpar0\qj{ is eligible to receive a partial exemption from taxation for a period of five years. However, if property ceases to be classified as industrial real estate or ceases to be used as a warehouse or distribution center, the partial exemption for the value added shall not be allowed for subsequent assessment years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of actual value added which is eligible to be exempt from taxation shall be as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the first year, seventy-five percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the second year, sixty percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the third year, forty-five percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fourth year, thirty percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fifth year, fifteen percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This schedule shall be followed unless an alternative schedule is adopted by the city council of a city or the board of supervisors of a county in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, the granting of the exemption under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for new construction constituting complete replacement of an existing building or structure shall not result in the assessed value of the industrial real estate being reduced below the assessed value of the industrial real estate before the start of the new construction added.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7427B.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1232, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a7167}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7427B.1}}}{{\f5\fs12\hyphpar0\qj{, 427B.7}}}{{\f5\fs12\hyphpar0\qj{, 427B.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.4}}}{\*\bkmkstart stylerid1_2E5_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application for exemption by property owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application shall be filed for each project resulting in actual value added for which an exemption is claimed. The application for exemption shall be filed by the owner of the property with the local assessor by February 1 of the assessment year in which the value added is first assessed for taxation. Applications for exemption shall be made on forms prescribed by the director of revenue and shall contain information pertaining to the nature of the improvement, its cost, and other information deemed necessary by the director of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person may submit a proposal to the city council of the city or the board of supervisors of a county to receive prior approval for eligibility for a tax exemption on new construction. The city council or the board of supervisors, by ordinance, may give its prior approval of a tax exemption for new construction if the new construction is in conformance with the zoning plans for the city or county. The prior approval shall also be subject to the hearing requirements of }}}{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{{\f5\fs18\hyphpar0\qj{. Prior approval does not entitle the owner to exemption from taxation until the new construction has been completed and found to be qualified real estate. However, if the tax exemption for new construction is not approved, the person may submit an amended proposal to the city council or board of supervisors to approve or reject.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7427B.4}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1104, \'a724}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1058, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7427.1(27)(d)}}}{{\f5\fs12\hyphpar0\qj{, 427B.7}}}{{\f5\fs12\hyphpar0\qj{, 427B.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.5}}}{\*\bkmkstart stylerid1_2E5_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemption may be repealed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When in the opinion of the city council or the county board of supervisors continuation of the exemption granted by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ ceases to be of benefit to the city or county, the city council or the county board of supervisors may repeal the ordinance authorized by }{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{, but all existing exemptions shall continue until their expiration.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7427B.5}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7427B.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.6}}}{\*\bkmkstart stylerid1_2E5_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dual exemptions prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A property tax exemption under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not be granted if the property for which the exemption is claimed has received any other property tax exemption authorized by law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7427B.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.7}}}{\*\bkmkstart stylerid1_2E5_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Actual value added exemption from tax \u8212\'3f cattle facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city council, or a county board of supervisors as authorized by }{{\f5\fs18\hyphpar0\qj{section 427B.2}}}{, may, by ordinance as provided in }{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{, establish a partial exemption from property taxation of the actual value added to owner-operated cattle facilities, including small or medium sized feedlots but not including slaughter facilities, either by new construction or by the retrofitting of existing facilities. The application for the exemption shall be filed pursuant to }{{\f5\fs18\hyphpar0\qj{section 427B.4}}}{. The actual value added to owner-operated cattle facilities, as specified in }{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{, is eligible to receive a partial exemption from taxation for a period of five years. The amount of actual value added which is eligible to be exempt from taxation is the same as provided in the exemption schedule in }{{\f5\fs18\hyphpar0\qj{section 427B.3}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 169, \'a710}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{427B.8 and 427B.9}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E2_2E2}{RESERVED}{\*\bkmkend stylerid1_2E6_2E2_2E2}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{427B.10 through 427B.16}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER III}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E2_2E2}{SPECIAL VALUATION FOR MACHINERY, EQUIPMENT, AND COMPUTERS \u8212\'3f STATE REPLACEMENT FUNDS}{\*\bkmkend stylerid1_2E7_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.17}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Property subject to special valuation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric power generating plant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any nameplate rated electric power generating plant, in which electric energy is produced from other forms of energy, including all taxable land, buildings, and equipment used in the production of such energy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNet acquisition cost\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the acquired cost of the property including all foundations and installation cost less any excess cost adjustment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNet actual generation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means net electrical megawatt hours produced by the unit during the preceding assessment year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNet capacity factor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means net actual generation divided by the product of net maximum capacity times the number of hours the unit was in the active state during the assessment year. Upon commissioning, a unit is in the active state until it is decommissioned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNet maximum capacity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the capacity the unit can sustain over a specified period when not restricted by ambient conditions or equipment deratings, minus the losses associated with station service or auxiliary loads.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For property defined in }}}{{\f5\fs18\hyphpar0\qj{section 427A.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the taxpayer\u8217\'3fs valuation shall be limited to thirty percent of the net acquisition cost of the property, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsections 3 and 4}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Property defined in }}}{{\f5\fs18\hyphpar0\qj{section 427A.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, which is first assessed for taxation in this state on or after January 1, 1995, shall be exempt from taxation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Property defined in }}}{{\f5\fs18\hyphpar0\qj{section 427A.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and assessed under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall be valued by the local assessor as follows for the following assessment years:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the assessment year beginning January 1, 1999, at twenty-two percent of the net acquisition cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the assessment year beginning January 1, 2000, at fourteen percent of the net acquisition cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the assessment year beginning January 1, 2001, at six percent of the net acquisition cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the assessment year beginning January 1, 2002, and succeeding assessment years, at zero percent of the net acquisition cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Property assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be eligible to receive a partial exemption under }}}{{\f5\fs18\hyphpar0\qj{sections 427B.1 through 427B.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of dividing taxes under }}}{{\f5\fs18\hyphpar0\qj{section 260E.4}}}{{\f5\fs18\hyphpar0\qj{, the employer\u8217\'3fs or business\u8217\'3fs valuation of property defined in }}}{{\f5\fs18\hyphpar0\qj{section 427A.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and used to fund a new jobs training project which project\u8217\'3fs first written agreement providing for a division of taxes as provided in }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ is approved on or before June 30, 1995, shall be limited to thirty percent of the net acquisition cost of the property. The community college shall notify the assessor by February 15 of each assessment year if taxes levied against such property of an employer or business will be used to finance a project in the following fiscal year. In any fiscal year in which the community college does rely on taxes levied against an employer\u8217\'3fs or business\u8217\'3fs property defined in }}}{{\f5\fs18\hyphpar0\qj{section 427A.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to finance a project, such property shall not be valued pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3 or 4}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable, for that fiscal year. An employer\u8217\'3fs or business\u8217\'3fs taxable property used to fund a new jobs training project shall not be valued pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 3 or 4}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable, until the assessment year following the calendar year in which the certificates or other funding obligations have been retired or escrowed. If the certificates issued, or other funding obligations incurred, between January 1, 1982, and June 30, 1995, are refinanced or refunded after June 30, 1995, the valuation of such property shall then be the valuation specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 3 or 4}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable, for the applicable assessment year beginning with the assessment year following the calendar year in which those certificates or other funding obligations are refinanced or refunded after June 30, 1995.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{ or any other provision to the contrary, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be applicable to a new cogeneration facility subject to the assessed value provisions of }}}{{\f5\fs18\hyphpar0\qj{section 437A.16A}}}{{\f5\fs18\hyphpar0\qj{, but the exemptions provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by an amount bearing the same ratio to the value of the property that is exempt pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ as the allowable credit under }}}{{\f5\fs18\hyphpar0\qj{section 437A.16A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, bears to the assessable value of the entire new cogeneration facility before the application of any abatements, credits, or exemptions against that value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to property assessed by the department of revenue pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 428.24 through 428.29}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{chapters 434}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{437}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{437A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{437B}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{438}}}{{\f5\fs18\hyphpar0\qj{, and such property shall not receive the benefits of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any electric power generating plant which operated during the preceding assessment year at a net capacity factor of more than twenty percent, shall not receive the benefits of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 32, \'a7109}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 180, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 206, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1049, \'a72, 3, 9}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1180, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 66, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1150, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 150, \'a764, 69}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 104, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7105}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 94, \'a75, 35, 36}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7139}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1158, \'a712, 28}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 136, \'a752, 59}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7427B.19}}}{{\f5\fs12\hyphpar0\qj{, 427B.19A}}}{{\f5\fs12\hyphpar0\qj{, 427B.19C}}}{{\f5\fs12\hyphpar0\qj{, 427B.19D}}}{{\f5\fs12\hyphpar0\qj{, 437A.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 8, paragraph b effective December 31, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 136, \'a759}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 8, paragraph b amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.18}}}{\*\bkmkstart stylerid1_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Replacement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Beginning with the fiscal year beginning July 1, 1996, each county treasurer shall be paid from the industrial machinery, equipment and computers replacement fund an amount equal to the amount of the industrial machinery, equipment and computers tax replacement claim, as calculated in }{{\f5\fs18\hyphpar0\qj{section 427B.19}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 206, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.19}}}{\*\bkmkstart stylerid1_2E7_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Assessor and county auditor duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before July 1 of each fiscal year, the assessor shall determine the total assessed value of the property assessed under }}}{{\f5\fs18\hyphpar0\qj{section 427B.17}}}{{\f5\fs18\hyphpar0\qj{ for taxes payable in that fiscal year and the total assessed value of such property assessed as of January 1, 1994, and shall report the valuations to the county auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before July 1 of each fiscal year, the assessor shall determine the valuation of all commercial and industrial property assessed for taxes payable in that fiscal year and the valuation of such property assessed as of January 1, 1994, and shall report the valuations to the county auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before September 1 of each fiscal year through June 30, 2004, the county auditor shall prepare a statement, based upon the report received pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, listing for each taxing district in the county:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning with the assessment year beginning January 1, 1995, the difference between the assessed valuation of property assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 427B.17}}}{{\f5\fs18\hyphpar0\qj{ for that year and the total assessed value of such property assessed as of January 1, 1994. If the total assessed value of the property assessed as of January 1, 1994, is less, there is no tax replacement for the fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax levy rate for each taxing district for that fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The industrial machinery, equipment and computers tax replacement claim for each taxing district. For fiscal years beginning July 1, 1996, and ending June 30, 2001, the replacement claim is equal to the amount determined pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, multiplied by the tax rate specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. For fiscal years beginning July 1, 2001, and ending June 30, 2004, the replacement claim is equal to the product of the amount determined pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, less any increase in valuations determined in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and the tax rate specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. If the amount subtracted under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is more than the amount determined in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, there is no tax replacement for the fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning with the assessment year beginning January 1, 2000, the auditor shall reduce the amount listed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, by the increase, if any, in assessed valuations of commercial and industrial property in the assessment year beginning January 1, 1994, and the assessment year for which taxes are due and payable in that fiscal year. If the calculation under this paragraph indicates a net decrease in aggregate valuation of such property, the industrial machinery, equipment and computers tax replacement claim for each taxing district is equal to the amount determined pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, multiplied by the tax rate specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county auditor shall certify and forward one copy of the statement to the department of revenue not later than September 1 of each year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fassessed value of the property assessed under }}}{{\i\f5\fs18\hyphpar0\qj{section 427B.17}}}{{\i\f5\fs18\hyphpar0\qj{\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include the value of property defined in }}}{{\f5\fs18\hyphpar0\qj{section 427A.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, which is obligated to secure payment of certificates or other indebtedness incurred pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 260E}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{260F}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of computing replacement amounts under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, that portion of an urban renewal area defined as the sum of the assessed valuations defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, shall be considered a taxing district.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 206, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1049, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 158, \'a732, 33}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 178, \'a75, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.3}}}{{\f5\fs12\hyphpar0\qj{, 427B.18}}}{{\f5\fs12\hyphpar0\qj{, 427B.19A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.19A}}}{\*\bkmkstart stylerid1_2E7_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fund created.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The industrial machinery, equipment and computers property tax replacement fund is created. For the fiscal year beginning July 1, 1996, through the fiscal year ending June 30, 2004, there is appropriated annually from the general fund of the state to the department of revenue to be credited to the industrial machinery, equipment and computers property tax replacement fund, an amount sufficient to implement }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. However, for the fiscal year beginning July 1, 2003, the amount appropriated to the department of revenue to be credited to the industrial machinery, equipment and computers tax replacement fund is eleven million two hundred eighty-one thousand six hundred eighty-five dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an amount appropriated for a fiscal year is insufficient to pay all claims as a result of action by the general assembly limiting the amount appropriated to the fund, the director shall prorate the disbursements from the fund to the county treasurers and shall notify the county auditors of the pro rata percentage on or before September 30.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The replacement claims shall be paid to each county treasurer in equal installments in September and March of each year. The county treasurer shall apportion the replacement claim payments among the eligible taxing districts in the county. If the taxing district is an urban renewal area, the amount of the replacement claim shall be apportioned as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ unless the municipality elects to proceed under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the total assessed value of property located in an urban renewal area taxing district is equal to or more than that portion of such valuation defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the total tax replacement amount computed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 427B.19}}}{{\f5\fs18\hyphpar0\qj{ shall be credited to that portion of the assessed value defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the total assessed value of the property is less than that portion of such valuation defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the replacement amount shall be credited to those portions of the assessed value defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To that portion defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, an amount equal to the amount that would be produced by multiplying the applicable consolidated levy times the difference between the assessed value of the taxable property defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and the total assessed value in the budget year for which the replacement claim is computed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To that portion defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the remaining amount, if any.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the allocation provisions of paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the amount of the tax replacement amount that shall be allocated to that portion of the assessed value defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall not exceed the amount equal to the amount certified to the county auditor under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ for the budget year in which the claim is paid, after deduction of the amount of other revenues committed for payment on that amount for the budget year. The amount not allocated to that portion of the assessed value defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, as a result of the operation of this paragraph, shall be allocated to that portion of assessed value defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality may elect to reduce the amount of assessed value of property defined in }}}{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, by an amount equal to that portion of the amount of such assessed value which was phased out for the fiscal year by operation of }}}{{\f5\fs18\hyphpar0\qj{section 427B.17, subsection 4}}}{{\f5\fs18\hyphpar0\qj{. The applicable assessment roll and ordinance providing for the division of taxes under }}}{{\f5\fs18\hyphpar0\qj{section 403.19}}}{{\f5\fs18\hyphpar0\qj{ in the urban renewal taxing district shall be deemed to be modified for that fiscal year only to the extent of such adjustment without further action on the part of the city or county implementing the urban renewal taxing district.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 206, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1049, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 158, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 116, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7246}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.3}}}{{\f5\fs12\hyphpar0\qj{, 298.18A}}}{{\f5\fs12\hyphpar0\qj{, 427B.19C}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.19B}}}{\*\bkmkstart stylerid1_2E7_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Guarantee of state replacement funds.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0178.pdf" }{\fldrslt \cf5 \f5 \fs18{{2003 Acts, ch 178, \'a711}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.19C}}}{\*\bkmkstart stylerid1_2E7_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adjustment of certain assessments required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In the assessment year beginning January 1, 2003, the amount of assessed value of property defined in }{{\f5\fs18\hyphpar0\qj{section 403.19, subsection 1}}}{, for an urban renewal taxing district which received replacement moneys under }{{\f5\fs18\hyphpar0\qj{section 427B.19A, subsection 4}}}{, shall be reduced by an amount equal to that portion of the amount of assessed value of such property which was assessed pursuant to }{{\f5\fs18\hyphpar0\qj{section 427B.17, subsection 4}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1049, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7247}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.19D}}}{\*\bkmkstart stylerid1_2E7_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal for state assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For fiscal years beginning on or after July 1, 1996, a municipality in which is located an urban renewal district for which debt was incurred prior to June 30, 1996, may appeal to the state appeal board for state assistance to meet such debt obligations for the fiscal year if such debt is not secured by an assessment agreement pursuant to }{{\f5\fs18\hyphpar0\qj{section 403.6, subsection 19}}}{, and if the urban renewal area contains property assessed pursuant to }{{\f5\fs18\hyphpar0\qj{section 427B.17}}}{. The appeal shall be made by May 15 preceding the fiscal year on forms approved by the department of management.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1049, \'a78}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E2_2E2}{UNDERGROUND STORAGE TANKS REMEDIAL ACTION CREDIT}{\*\bkmkend stylerid1_2E8_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.20}}}{\*\bkmkstart stylerid1_2E8_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local option remedial action property tax credit \u8212\'3f public hearing.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1054, \'a720}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Property tax credits provided under this subchapter IV, existing on July 1, 2024, shall continue until their expiration; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1054.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1054, \'a721}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.21}}}{\*\bkmkstart stylerid1_2E8_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application for credit by underground storage tank owner or operator \u8212\'3f approval by county board of supervisors or city council.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1054, \'a720}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Property tax credits provided under this subchapter IV, existing on July 1, 2024, shall continue until their expiration; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1054.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1054, \'a721}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.22}}}{\*\bkmkstart stylerid1_2E8_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Credit may be repealed.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1054, \'a720}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Property tax credits provided under this subchapter IV, existing on July 1, 2024, shall continue until their expiration; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1054.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1054, \'a721}}}}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{427B.23 through 427B.25}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER V}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E2_2E2}{SPECIAL VALUATION FOR WIND ENERGY CONVERSION PROPERTY}{\*\bkmkend stylerid1_2E9_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427B.26}}}{\*\bkmkstart stylerid1_2E9_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special valuation of wind energy conversion property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city council or county board of supervisors may provide by ordinance for the special valuation of wind energy conversion property as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. The ordinance may be enacted not less than thirty days after a public hearing on the ordinance is held. Notice of the hearing shall be published in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 331.305}}}{{\f5\fs18\hyphpar0\qj{ in the case of a county, or }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{ in the case of a city. The ordinance shall only apply to property first assessed on or after the effective date of the ordinance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If in the opinion of the city council or the county board of supervisors continuation of the special valuation provided under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ ceases to be of benefit to the city or county, the city council or the county board of supervisors may repeal the ordinance authorized by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Property specially valued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ prior to repeal of the ordinance shall continue to be valued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ until the end of the nineteenth assessment year following the assessment year in which the property was first assessed. Following repeal of the ordinance and conclusion of the applicable nineteen-year period, the wind energy conversion property shall be subject to assessment and taxation under }}}{{\f5\fs18\hyphpar0\qj{chapter 437A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 441.21, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{sections 428.24 through 428.26}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{428.28}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{428.29}}}{{\f5\fs18\hyphpar0\qj{, as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the valuation and assessment provisions in }}}{{\f5\fs18\hyphpar0\qj{chapter 437A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 441.21, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{sections 428.24 through 428.26}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{428.28}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{428.29}}}{{\f5\fs18\hyphpar0\qj{, as applicable, wind energy conversion property which is first assessed for property taxation on or after January 1, 1994, and on or after the effective date of the ordinance enacted pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall be valued by the local assessor for property tax purposes as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the first assessment year, at zero percent of the net acquisition cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the second through sixth assessment years, at a percent of the net acquisition cost which rate increases by five percentage points each assessment year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the seventh and succeeding assessment years, at thirty percent of the net acquisition cost.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxpayer shall file with the local assessor by February 1 of the assessment year in which the wind energy conversion property is first assessed for property tax purposes, a declaration of intent to have the property assessed at the value determined under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in lieu of the valuation and assessment provisions in }}}{{\f5\fs18\hyphpar0\qj{chapter 437A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 441.21, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{sections 428.24 through 428.26}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{428.28}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{428.29}}}{{\f5\fs18\hyphpar0\qj{, as applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintaining, refurbishing, or repowering wind energy conversion property shall not cause the wind energy conversion property to receive a new assessment schedule under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCollector substation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an electrical substation designed to collect energy from multiple electricity-generating sources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNet acquisition cost\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the acquired cost of the property including all foundations and installation cost less any excess cost adjustment. However, except in the case of a clerical error, an adjustment shall not be made after the third year the wind energy conversion property is assessed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRepowering\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the removal and replacement of components of wind energy conversion property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWind energy conversion property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the entire wind plant including but not limited to a wind charger, windmill, wind turbine, tower and electrical equipment, pad mount transformers, power lines, and collector substation.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 161, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7269, 270}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1075, \'a71 \u8211\'3f 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7437A.6}}}{{\f5\fs12\hyphpar0\qj{, 441.21}}}{{\f5\fs12\hyphpar0\qj{, 476B.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 1, paragraph b applies retroactively to assessment years beginning on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1075, \'a75}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 2, unnumbered paragraph 1 applies retroactively to assessment years beginning on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1075, \'a75}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 3, paragraph a applies retroactively to assessment years beginning on or after January 1, 2022; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1075.pdf" }{\fldrslt \cf5 \f5 \fs12{{2022 Acts, ch 1075, \'a75}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph b applies to assessment schedules commenced under subsection 2 on or after May 23, 2022; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1075.pdf" }{\fldrslt \cf5 \f5 \fs12{{2022 Acts, ch 1075, \'a76}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 4 applies retroactively to assessment years beginning on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1075, \'a75}}}\par}}