\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F73_30}{\*\bkmkend codeChapter_5F73_30}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 730}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{EMPLOYER-EMPLOYEE OFFENSES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7331.307}}}{{\f5\fs12\qc{, 364.22}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{730.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statements regarding discharge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any person, agent, company, or corporation, after having discharged any employee from service, shall prevent or attempt to prevent, by word or writing of any kind, such discharged employee from obtaining employment with any other person, company, or corporation, except by furnishing in writing on request a truthful statement as to the cause of the person\u8217\'3fs discharge, such person, agent, company, or corporation shall be guilty of a serious misdemeanor and shall be liable for all damages sustained by any such person.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a75027; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13253;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7736.1; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7730.1}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7730.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{730.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Blacklisting employees \u8212\'3f treble damages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any railway company or other company, partnership, or corporation shall authorize or allow any of its or their agents to blacklist any discharged employee, or attempt by word or writing or any other means whatever to prevent such discharged employee, or any employee who may have voluntarily left said company\u8217\'3fs service, from obtaining employment with any other person or company, except as provided for in }{{\f5\fs18\hyphpar0\qj{section 730.1}}}{, such company or partnership shall be liable in treble damages to such employee so prevented from obtaining employment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a75028; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13254;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7736.2; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7730.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7106}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{730.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{False charges concerning honesty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every person who shall by any letter, mark, sign, or designation whatever, or by any verbal statement, falsely and without probable cause, report to any railroad or any other company or corporation, or to any person or firm, or to any of the officers, servants, agents, or employees of any such corporation, person, or firm, that any conductor, crew member, engineer, stoker, station agent, or any employee of such railroad company, corporation, person, or firm has received any money or thing of value for the transportation of persons or property or for other service for which the person has not accounted to such corporation, person, or firm, or shall falsely and without probable cause report that any conductor, crew member, engineer, stoker, station agent, or other employee of any railroad company, corporation, firm, or person, neglected, failed, or refused to collect any money or ticket for transportation of persons or property or other service when it was their duty so to do, shall, on conviction, be guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a75028-w1; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{13255;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7736.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7730.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{730.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Polygraph examination prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpolygraph examination\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any procedure which involves the use of instrumentation or a mechanical or electrical device to enable or assist the detection of deception, the verification of truthfulness, or the rendering of a diagnostic opinion regarding either of these, and includes a lie detector or similar test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer shall not as a condition of employment, promotion, or change in status of employment, or as an express or implied condition of a benefit or privilege of employment, knowingly do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Request or require that an employee or applicant for employment take or submit to a polygraph examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer, cause to be administered, threaten to administer, or attempt to administer a polygraph examination to an employee or applicant for employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Request or require that an employee or applicant for employment give an express or implied waiver of a practice prohibited by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsection 2}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the state or a political subdivision of the state when in the process of selecting any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A candidate for employment as a peace officer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A candidate for employment as a corrections officer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant for a position with a law enforcement agency of a political subdivision of the state when the applicant is being considered for a position in which the employee filling the position has direct access to prisoner funds, any other cash assets, and confidential information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Polygraph examinations under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall adhere to the published antidiscrimination policy of the state or political subdivision conducting the examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee who acted in good faith shall not be discharged, disciplined, or discriminated against in any manner for filing a complaint or testifying in any proceeding or action involving violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. An employee discharged, disciplined, or otherwise discriminated against in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be compensated by the employer in the amount of any loss of wages and benefits arising out of the discrimination and shall be restored to the employee\u8217\'3fs previous position of employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ may be enforced through a civil action.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or who aids in the violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is liable to an aggrieved employee or applicant for employment for affirmative relief including reinstatement or hiring, with or without back pay, or any other equitable relief as the court deems appropriate including attorney fees and court costs.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a person commits, is committing, or proposes to commit, an act in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, an injunction may be granted through an action in district court to prohibit the person from continuing such acts. The action for injunctive relief may be brought by an aggrieved employee or applicant for employment, the county attorney, or the attorney general.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who in good faith brings an action under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ alleging that an employer has required or requested a polygraph examination in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall establish that sufficient evidence exists upon which a reasonable person could find that a violation has occurred. Upon proof that sufficient evidence exists upon which a finding could be made that a violation has occurred as required under this paragraph, the employer has the burden of proving that the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ were met.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ commits a simple misdemeanor. In addition to any other penalties, the punishment imposed for a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall include assessment of a fine of not less than two hundred fifty dollars.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 86, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1227, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 153, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1059, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7214}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a780F.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{730.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Private sector drug-free workplaces.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E9_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAlcohol\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means ethanol, isopropanol, or methanol.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConfirmed positive test result\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, except for alcohol testing conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), the results of a hair, blood, urine, or oral fluid test in which the level of controlled substances or metabolites in the sample analyzed meets or exceeds nationally accepted standards for determining detectable levels of controlled substances as adopted by the United States department of health and human services\u8217\'3f substance abuse and mental health services administration. If nationally accepted standards for tests on a particular specimen have not been adopted by the United States department of health and human services\u8217\'3f substance abuse and mental health services administration, the standards for determining detectable levels of controlled substances for purposes of determining a confirmed positive test result shall be the same standard that has been cleared or approved by the United States department of health and human services\u8217\'3f food and drug administration for the particular specimen testing utilized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDrug\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a substance considered a controlled substance and included in schedule I, II, III, IV, or V under the federal Controlled Substances Act, 21 U.S.C. \'a7801 et seq.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmployee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person in the service of an employer in this state and includes the employer, and any chief executive officer, president, vice president, supervisor, manager, and officer of the employer who is actively involved in the day-to-day operations of the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmployer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person, firm, company, corporation, labor organization, or employment agency, which has one or more full-time employees employed in the same business, or in or about the same establishment, under any contract of hire, express or implied, oral or written, in this state. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmployer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include the state, a political subdivision of the state, including a city, county, or school district, the United States, the United States postal service, or a Native American tribe.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGood faith\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means reasonable reliance on facts, or that which is held out to be factual, without the intent to be deceived, and without reckless, malicious, or negligent disregard for the truth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedical review officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a licensed physician, osteopathic physician, chiropractor, nurse practitioner, or physician assistant authorized to practice in any state of the United States, who is responsible for receiving laboratory results generated by an employer\u8217\'3fs drug or alcohol testing program, and who has knowledge of substance use disorders and has appropriate medical training to interpret and evaluate an individual\u8217\'3fs confirmed positive test result together with the individual\u8217\'3fs medical history and any other relevant biomedical information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProspective employee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who has made application, whether written or oral, to an employer to become an employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReasonable suspicion drug or alcohol testing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means drug or alcohol testing based upon evidence that an employee is using or has used alcohol or other drugs in violation of the employer\u8217\'3fs written policy drawn from specific objective and articulable facts and reasonable inferences drawn from those facts in light of experience. For purposes of this paragraph, facts and inferences may be based upon, but not limited to, any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Observable phenomena while at work such as direct observation of alcohol or drug use or abuse or of the physical symptoms or manifestations of being impaired due to alcohol or other drug use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Abnormal conduct or erratic behavior while at work or a significant deterioration in work performance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A report of alcohol or other drug use provided by a reliable and credible source.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Evidence that an individual has tampered with any drug or alcohol test during the individual\u8217\'3fs employment with the current employer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Evidence that an employee has caused an accident while at work which resulted in an injury to a person for which injury, if suffered by an employee, a record or report could be required under }}}{{\f5\fs18\hyphpar0\qj{chapter 88}}}{{\f5\fs18\hyphpar0\qj{, or resulted in damage to property, including to equipment, in an amount reasonably estimated at the time of the accident to exceed one thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Evidence that an employee has manufactured, sold, distributed, solicited, possessed, used, or transferred drugs while working or while on the employer\u8217\'3fs premises or while operating the employer\u8217\'3fs vehicle, machinery, or equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSafety-sensitive position\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a position designated by the employer as one wherein an accident could cause loss of human life, serious bodily injury, or significant property or environmental damage, including a job with duties that include immediate supervision of a person in a job that meets the requirement of this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSample\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means such sample from the human body capable of revealing the presence of alcohol or other drugs, or their metabolites, which shall include only hair, urine, saliva, breath, and blood. However, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsample\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean blood except as authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnannounced drug or alcohol testing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means testing for the purposes of detecting drugs or alcohol which is conducted on a periodic basis, without advance notice of the test to employees, other than employees whose duties include responsibility for administration of the employer\u8217\'3fs drug or alcohol testing program, subject to testing prior to the day of testing, and without individualized suspicion. The selection of employees to be tested from the pool of employees subject to testing shall be done based on a neutral and objective selection process by an entity independent from the employer and shall be made by a computer-based random number generator that is matched with employees\u8217\'3f social security numbers, payroll identification numbers, or other comparable identifying numbers in which each member of the employee population subject to testing has an equal chance of selection for initial testing, regardless of whether the employee has been selected or tested previously. The random selection process shall be conducted through a computer program that records each selection attempt by date, time, and employee number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E9_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Applicability.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to drug or alcohol tests conducted on employees required to be tested pursuant to federal statutes, federal regulations, or orders issued pursuant to federal law. In addition, an employer, through its written policy, may exclude from the pools of employees subject to unannounced drug or alcohol testing pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, employee populations required to be tested as described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E9_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Testing optional.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not require or create a legal duty on an employer to conduct drug or alcohol testing and the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to encourage, discourage, restrict, limit, prohibit, or require such testing. In addition, an employer may implement and require drug or alcohol testing at some but not all of the work sites of the employer and the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall only apply to the employer and employees who are at the work sites where drug or alcohol testing pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ has been implemented. A cause of action shall not arise in favor of any person against an employer or agent of an employer based on the failure of the employer to establish a program or policy on substance use disorder prevention or to implement any component of testing as permitted by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E9_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Testing as condition of employment \u8212\'3f requirements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the extent provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{, an employer may test employees and prospective employees for the presence of drugs or alcohol as a condition of continued employment or hiring. An employer shall adhere to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ concerning the conduct of such testing and the use and disposition of the results of such testing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E9_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Collection of samples.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In conducting drug or alcohol testing, an employer may require the collection of samples from its employees and prospective employees, and may require presentation of reliable individual identification from the person being tested to the person collecting the samples. Collection of a sample shall be in conformance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The employer may designate the type of sample to be used for this testing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E9_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Scheduling of tests.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Drug or alcohol testing of employees conducted by an employer shall normally occur during, or immediately before or after, a regular work period. The time required for such testing by an employer shall be deemed work time for the purposes of compensation and benefits for employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer shall pay all actual costs for drug or alcohol testing of employees and prospective employees required by the employer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer shall provide transportation or pay reasonable transportation costs to employees if drug or alcohol sample collection is conducted at a location other than the employee\u8217\'3fs normal work site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E9_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Testing procedures.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All sample collection and testing for drugs or alcohol under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be performed in accordance with the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The collection of samples shall be performed under sanitary conditions and with regard for the privacy of the individual from whom the sample is being obtained and in a manner reasonably calculated to preclude contamination or substitution of the sample. If the sample collected is hair which would entail removal of an article of clothing or urine, procedures shall be established to provide for individual privacy in the collection of the sample unless there is a reasonable suspicion that a particular individual subject to testing may alter or substitute the hair or urine sample to be provided, or has previously altered or substituted a hair or urine sample provided pursuant to a drug or alcohol test. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3findividual privacy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a location at the collection site where hair collection or urination can occur in private, which has been secured by visual inspection to ensure that other persons are not present, which provides that undetected access to the location is not possible during hair collection or urination, and which provides for the ability to effectively restrict access to the location during the time the sample is provided. If an individual is providing a hair or urine sample and collection of the hair or urine sample is directly monitored or observed by another individual, the individual who is directly monitoring or observing the collection shall be of the same gender as the individual from whom the hair or urine sample is being collected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Collection of a sample for testing of current employees shall be performed so that the sample is split into two components at the time of collection in the presence of the individual from whom the sample is collected. The second portion of the sample shall be of sufficient quantity to permit a second, independent confirmatory test as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. If the sample is urine, the sample shall be split such that the primary sample contains at least thirty milliliters and the secondary sample contains at least fifteen milliliters. Both portions of the sample shall be forwarded to the laboratory conducting the initial confirmatory testing. In addition to any requirements for storage of the initial sample that may be imposed upon the laboratory as a condition for certification or approval, the laboratory shall store the second portion of any sample until receipt of a confirmed negative test result or for a period of at least forty-five calendar days following the completion of the initial confirmatory testing, if the first portion yielded a confirmed positive test result.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sample collections shall be documented, and the procedure for documentation shall include the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Samples, except for samples collected for alcohol testing conducted pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), shall be labeled so as to reasonably preclude the possibility of misidentification of the person tested in relation to the test result provided, and samples shall be handled and tracked in a manner such that control and accountability are maintained from initial collection to each stage in handling, testing, and storage, through final disposition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or prospective employee shall be provided an opportunity to provide any information which may be considered relevant to the test, including identification of prescription or nonprescription drugs currently or recently used, or other relevant medical information. To assist an employee or prospective employee in providing the information described in this subparagraph, the employer shall provide an employee or prospective employee with a list of the drugs to be tested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sample collection, storage, and transportation to the place of testing shall be performed so as to reasonably preclude the possibility of sample contamination, adulteration, or misidentification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Testing of a hair sample shall be limited to samples not longer than one and one-half inches. Testing of a hair sample shall be limited to the portion of the hair that was closest to the skin.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All confirmatory drug testing shall be conducted at a laboratory certified by the United States department of health and human services\u8217\'3f substance abuse and mental health services administration or approved under rules adopted by the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Drug or alcohol testing shall include confirmation of any initial positive test results. An employer may take adverse employment action, including refusal to hire a prospective employee, based on a confirmed positive test result for drugs or alcohol.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For drug or alcohol testing, except for alcohol testing conducted pursuant to subparagraph (2), confirmation shall be by use of a different chemical process than was used in the initial screen for drugs or alcohol. The confirmatory drug or alcohol test shall be a chromatographic technique such as gas chromatography/mass spectrometry, or another comparably reliable analytical method.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, alcohol testing, including initial and confirmatory testing, may be conducted pursuant to requirements established by the employer\u8217\'3fs written policy. The written policy shall include requirements governing evidential breath testing devices, alcohol screening devices, and the qualifications for personnel administering initial and confirmatory testing, which shall be consistent with regulations adopted as of July 1, 2017, by the United States department of transportation governing alcohol testing required to be conducted pursuant to the federal }}}{{\f5\fs18\hyphpar0\qj{Omnibus Transportation Employee Testing Act of 1991}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, collection of an oral fluid sample for testing shall be performed in the presence of the individual from whom the sample is collected. The sample shall be of sufficient quantity to permit a second, independent, confirmatory test as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. In addition to any requirement for storage of the initial sample that may be imposed upon the laboratory as a condition for certification or approval, the laboratory shall store the unused portion of any sample until receipt of a confirmed negative test result or for a period of at least forty-five calendar days following the completion of the initial confirmatory testing, if the portion yielded a confirmed positive test result.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A medical review officer shall, prior to the results being reported to an employer, review and interpret any confirmed positive test results, including both quantitative and qualitative test results, to ensure that the chain of custody is complete and sufficient on its face and that any information provided by the individual pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), is considered. However, this paragraph shall not apply to alcohol testing conducted pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In conducting drug or alcohol testing pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the laboratory, the medical review officer, and the employer shall ensure, to the extent feasible, that the testing only measures, and the records concerning the testing only show or make use of information regarding, alcohol or drugs in the body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a confirmed positive test result for drugs or alcohol for a current employee is reported to the employer by the medical review officer, the employer shall notify the employee in writing by certified mail, return receipt requested, of the results of the test, the employee\u8217\'3fs right to request and obtain a confirmatory test of the second sample collected pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ at an approved laboratory of the employee\u8217\'3fs choice, and the fee payable by the employee to the employer for reimbursement of expenses concerning the test. The fee charged an employee shall be an amount that represents the costs associated with conducting the second confirmatory test, which shall be consistent with the employer\u8217\'3fs cost for conducting the initial confirmatory test on an employee\u8217\'3fs sample. If the employee, by certified mail, return receipt requested, requests a second confirmatory test, identifies an approved laboratory to conduct the test, and pays the employer the fee for the test within seven days from the date the employer mails by certified mail, return receipt requested, the written notice to the employee of the employee\u8217\'3fs right to request a test, a second confirmatory test shall be conducted at the laboratory chosen by the employee. The results of the second confirmatory test shall be reported to the medical review officer who reviewed the initial confirmatory test results and the medical review officer shall review the results and issue a report to the employer on whether the results of the second confirmatory test confirmed the initial confirmatory test as to the presence of a specific drug or alcohol. If the results of the second test do not confirm the results of the initial confirmatory test, the employer shall reimburse the employee for the fee paid by the employee for the second test and the initial confirmatory test shall not be considered a confirmed positive test result for drugs or alcohol for purposes of taking disciplinary action pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{. In lieu of certified mail, return receipt requested, an employer may offer an employee the option to receive notifications and make requests as provided in this subparagraph by in-person exchange of written materials or by electronic notification. The employee may choose to receive notifications and make requests by one of these methods or by certified mail, return receipt requested.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a confirmed positive test result for drugs or alcohol for a prospective employee is reported to the employer by the medical review officer, the employer shall notify the prospective employee in writing of the results of the test, of the name and address of the medical review officer who made the report, and of the prospective employee\u8217\'3fs right to request records under }}}{{\f5\fs18\hyphpar0\qj{subsection 13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A laboratory conducting testing under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall dispose of all samples for which a negative test result was reported to an employer within five working days after issuance of the negative test result report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as necessary to conduct drug or alcohol testing pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and to submit the report required by }}}{{\f5\fs18\hyphpar0\qj{subsection 16}}}{{\f5\fs18\hyphpar0\qj{, a laboratory or other medical facility shall only report to an employer or outside entity information relating to the results of a drug or alcohol test conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ concerning the determination of whether the tested individual has engaged in conduct prohibited by the employer\u8217\'3fs written policy with regard to alcohol or drug use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, an employer may rely and take action upon the results of any blood test for drugs or alcohol made on any employee involved in an accident at work if the test is administered by or at the direction of the person providing treatment or care to the employee without request or suggestion by the employer that a test be conducted, and the employer has lawfully obtained the results of the test. For purposes of this paragraph, an employer shall not be deemed to have requested or required a test in conjunction with the provision of medical treatment following a workplace accident by providing information concerning the circumstance of the accident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E9_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Drug or alcohol testing.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employers may conduct drug or alcohol testing as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employers may conduct unannounced drug or alcohol testing of employees who are selected from any of the following pools of employees:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The entire employee population at a particular work site of the employer except for employees not subject to testing pursuant to a collective bargaining agreement, or employees who are not scheduled to be at work at the time the testing is conducted because of the status of the employees or who have been excused from work pursuant to the employer\u8217\'3fs work policy prior to the time the testing is announced to employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The entire full-time active employee population at a particular work site except for employees not subject to testing pursuant to a collective bargaining agreement, or employees who are not scheduled to be at work at the time the testing is to be conducted because of the status of the employee or who have been excused from work pursuant to the employer\u8217\'3fs working policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All employees at a particular work site who are in a pool of employees in a safety-sensitive position and who are scheduled to be at work at the time testing is conducted, other than employees not subject to testing pursuant to a collective bargaining agreement, or employees who are not scheduled to be at work at the time the testing is to be conducted or who have been excused from work pursuant to the employer\u8217\'3fs work policy prior to the time the testing is announced to employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employers may conduct drug or alcohol testing of employees during, and after completion of, drug or alcohol rehabilitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employers may conduct reasonable suspicion drug or alcohol testing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employers may conduct drug or alcohol testing of prospective employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employers may conduct drug or alcohol testing as required by federal law or regulation or by law enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employers may conduct drug or alcohol testing in investigating accidents in the workplace in which the accident resulted in an injury to a person for which injury, if suffered by an employee, a record or report could be required under }}}{{\f5\fs18\hyphpar0\qj{chapter 88}}}{{\f5\fs18\hyphpar0\qj{, or resulted in damage to property, including to equipment, in an amount reasonably estimated at the time of the accident to exceed one thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employers may conduct hair testing of prospective employees only.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E9_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Written policy and other testing requirements.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Drug or alcohol testing or retesting by an employer shall be carried out within the terms of a written policy which has been provided to every employee subject to testing, and is available for review by employees and prospective employees. If an employee or prospective employee is a minor, the employer shall provide a copy of the written policy to a parent of the employee or prospective employee and shall obtain a receipt or acknowledgment from the parent that a copy of the policy has been received. Providing a copy of the written policy to a parent of a minor by certified mail, return receipt requested, shall satisfy the requirements of this subparagraph.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition, the written policy shall provide that any notice required by }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to be provided to an individual pursuant to a drug or alcohol test conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall also be provided to the parent of the individual by certified mail, return receipt requested, if the individual tested is a minor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In providing information or notice to a parent as required by this paragraph, an employer shall rely on the information regarding the identity of a parent as provided by the minor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fminor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who is under eighteen years of age and is not considered by law to be an adult, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fparent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one biological or adoptive parent, a stepparent, or a legal guardian or custodian of the minor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of certified mail, return receipt requested, an employer may offer an employee, prospective employee, or parent of a minor who is an employee or prospective employee the option to receive copies and notices as provided in subparagraph (1) or (2) by in-person exchange of written materials or by electronic notification. The employee, prospective employee, or parent of a minor who is an employee or prospective employee may choose to receive copies and notices by one of these methods or by certified mail, return receipt requested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer\u8217\'3fs written policy shall provide uniform requirements for what disciplinary or rehabilitative actions an employer shall take against an employee or prospective employee upon receipt of a confirmed positive test result for drugs or alcohol or upon the refusal of the employee or prospective employee to provide a testing sample. The policy shall provide that any action taken against an employee or prospective employee shall be based only on the results of the drug or alcohol test. The written policy shall also provide that if rehabilitation is required pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the employer shall not take adverse employment action against the employee so long as the employee complies with the requirements of rehabilitation and successfully completes rehabilitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employers shall establish an awareness program to inform employees of the dangers of drug and alcohol use in the workplace and comply with the following requirements in order to conduct drug or alcohol testing under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an employer has an employee assistance program, the employer must inform the employee of the benefits and services of the employee assistance program. An employer shall post notice of the employee assistance program in conspicuous places and explore alternative routine and reinforcing means of publicizing such services. In addition, the employer must provide the employee with notice of the policies and procedures regarding access to and utilization of the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an employer does not have an employee assistance program, the employer must maintain a resource file of alcohol and other substance use disorder programs certified by the department of health and human services, mental health providers, and other persons, entities, or organizations available to assist employees with personal or behavioral problems. The employer shall provide all employees information about the existence of the resource file and a summary of the information contained within the resource file. The summary should contain, but need not be limited to, all information necessary to access the services listed in the resource file.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee or prospective employee whose drug or alcohol test results are confirmed as positive in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not, by virtue of those results alone, be considered as a person with a disability for purposes of any state or local law or regulation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the written policy provides for alcohol testing, the employer shall establish in the written policy a standard for alcohol concentration which shall be deemed to violate the policy. The standard for alcohol concentration shall not be less than .02, expressed in terms of grams of alcohol per two hundred ten liters of breath, or its equivalent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee of an employer who is designated by the employer as being in a safety-sensitive position shall be placed in only one pool of safety-sensitive employees subject to drug or alcohol testing pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3). An employer may have more than one pool of safety-sensitive employees subject to drug or alcohol testing pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), but shall not include an employee in more than one safety-sensitive pool.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a confirmed positive alcohol test which indicates an alcohol concentration greater than the concentration level established by the employer pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and if the employer has at least fifty employees, and if the employee has been employed by the employer for at least twelve of the preceding eighteen months, and if rehabilitation is agreed upon by the employee, and if the employee has not previously violated the employer\u8217\'3fs substance use disorder prevention policy pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the written policy shall provide for the rehabilitation of the employee pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), and the apportionment of the costs of rehabilitation as provided by this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the employer has an employee benefit plan, the costs of rehabilitation shall be apportioned as provided under the employee benefit plan.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If no employee benefit plan exists and the employee has coverage for any portion of the costs of rehabilitation under any health care plan of the employee, the costs of rehabilitation shall be apportioned as provided by the health care plan with any costs not covered by the plan apportioned equally between the employee and the employer. However, the employer shall not be required to pay more than two thousand dollars toward the costs not covered by the employee\u8217\'3fs health care plan.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If no employee benefit plan exists and the employee does not have coverage for any portion of the costs of rehabilitation under any health care plan of the employee, the costs of rehabilitation shall be apportioned equally between the employee and the employer. However, the employer shall not be required to pay more than two thousand dollars towards the cost of rehabilitation under this subparagraph division.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rehabilitation required pursuant to this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg}}}{{\f5\fs18\hyphpar0\qj{\u8221\'3f shall not preclude an employer from taking any adverse employment action against the employee during the rehabilitation based on the employee\u8217\'3fs failure to comply with any requirements of the rehabilitation, including any action by the employee to invalidate a test sample provided by the employee pursuant to the rehabilitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to conduct drug or alcohol testing under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, an employer shall require supervisory personnel of the employer involved with drug or alcohol testing under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to attend a minimum of two hours of initial training and to attend, on an annual basis thereafter, a minimum of one hour of subsequent training. The training shall include but is not limited to information concerning the recognition of evidence of employee alcohol and other substance use disorder, the documentation and corroboration of employee alcohol and other substance use disorder, and the referral of employees with a substance use disorder to the employee assistance program or to the resource file maintained by the employer pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E9_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Disciplinary procedures.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a confirmed positive test result for drugs or alcohol which indicates a violation of the employer\u8217\'3fs written policy, or upon the refusal of an employee or prospective employee to provide a testing sample, an employer may use that test result or test refusal as a valid basis for disciplinary or rehabilitative actions pursuant to the requirements of the employer\u8217\'3fs written policy and the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, which may include, among other actions, the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A requirement that the employee enroll in an employer-provided or approved rehabilitation, treatment, or counseling program, which may include additional drug or alcohol testing, participation in and successful completion of which may be a condition of continued employment, and the costs of which may or may not be covered by the employer\u8217\'3fs health plan or policies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Suspension of the employee, with or without pay, for a designated period of time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Termination of employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refusal to hire a prospective employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other adverse employment action in conformance with the employer\u8217\'3fs written policy and procedures, including any relevant collective bargaining agreement provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following a drug or alcohol test, but prior to receipt of the final results of the drug or alcohol test, an employer may suspend a current employee, with or without pay, pending the outcome of the test. An employee who has been suspended shall be reinstated by the employer, with back pay, and interest on such amount at eighteen percent per annum compounded annually, if applicable, if the result of the test is not a confirmed positive test result for drugs or alcohol which indicates a violation of the employer\u8217\'3fs written policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E9_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Employer immunity.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cause of action shall not arise against an employer who has established a policy and initiated a testing program in accordance with the testing and policy safeguards provided for under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, for any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Testing or taking action based on the results of a positive drug or alcohol test result, indicating the presence of drugs or alcohol, in good faith, or on the refusal of an employee or prospective employee to submit to a drug or alcohol test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure to test for drugs or alcohol, or failure to test for a specific drug or controlled substance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure to test for, or if tested for, failure to detect, any specific drug or other controlled substance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Termination or suspension of any substance use disorder prevention or testing program or policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any action taken related to a false negative drug or alcohol test result.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Testing or taking action against an employee or prospective employee with a confirmed positive test result due to the employee\u8217\'3fs or prospective employee\u8217\'3fs use of medical cannabidiol as authorized under }}}{{\f5\fs18\hyphpar0\qj{chapter 124E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{\*\bkmkstart stylerid1_2E9_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Employer liability \u8212\'3f false positive test results.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a cause of action shall not arise against an employer who has established a program of drug or alcohol testing in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless all of the following conditions exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer\u8217\'3fs action was based on a false positive test result.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer knew or clearly should have known that the test result was in error and ignored the correct test result because of reckless, malicious, or negligent disregard for the truth, or the willful intent to deceive or to be deceived.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cause of action for defamation, libel, slander, or damage to reputation shall not arise against an employer establishing a program of drug or alcohol testing in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ unless all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer discloses the test results to a person other than the employer, an authorized employee, agent, or representative of the employer, the tested employee or the tested applicant for employment, an authorized substance use disorder treatment program or employee assistance program, or an authorized agent or representative of the tested employee or applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The test results disclosed incorrectly indicate the presence of alcohol or drugs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employer negligently discloses the results.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any cause of action based upon a false positive test result, all of the following conditions apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The results of a drug or alcohol test conducted in compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are presumed to be valid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer shall not be liable for monetary damages if the employer\u8217\'3fs reliance on the false positive test result was reasonable and in good faith.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{\*\bkmkstart stylerid1_2E9_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Confidentiality of results \u8212\'3f exception.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All communications received by an employer relevant to employee or prospective employee drug or alcohol test results, or otherwise received through the employer\u8217\'3fs drug or alcohol testing program, are confidential communications and shall not be used or received in evidence, obtained in discovery, or disclosed in any public or private proceeding, except as otherwise provided or authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee, or a prospective employee, who is the subject of a drug or alcohol test conducted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ pursuant to an employer\u8217\'3fs written policy and for whom a confirmed positive test result is reported shall, upon written request, have access to any records relating to the employee\u8217\'3fs drug or alcohol test, including records of the laboratory where the testing was conducted and any records relating to the results of any relevant certification or review by a medical review officer. However, a prospective employee shall be entitled to records under this paragraph only if the prospective employee requests the records within fifteen calendar days from the date the employer provided the prospective employee written notice of the results of a drug or alcohol test as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and as necessary to conduct drug or alcohol testing under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and to file a report pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 16}}}{{\f5\fs18\hyphpar0\qj{, a laboratory and a medical review officer conducting drug or alcohol testing under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not use or disclose to any person any personally identifiable information regarding such testing, including the names of individuals tested, even if unaccompanied by the results of the test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer may use and disclose information concerning the results of a drug or alcohol test conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ under any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In an arbitration proceeding pursuant to a collective bargaining agreement, or an administrative agency proceeding or judicial proceeding under workers\u8217\'3f compensation laws or unemployment compensation laws or under common or statutory laws where action taken by the employer based on the test is relevant or is challenged.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any federal agency or other unit of the federal government as required under federal law, regulation or order, or in accordance with compliance requirements of a federal government contract.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To any agency of this state authorized to license individuals if the employee tested is licensed by that agency and the rules of that agency require such disclosure.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a union representing the employee if such disclosure would be required by federal labor laws.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a substance use disorder evaluation or treatment facility or professional for the purpose of evaluation or treatment of the employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, positive test results from an employer drug or alcohol testing program shall not be used as evidence in any criminal action against the employee or prospective employee tested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{\*\bkmkstart stylerid1_2E9_2E16_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E16_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Civil penalties \u8212\'3f jurisdiction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any laboratory or medical review officer which discloses information in violation of the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 7}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fi\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fl\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or any employer who, through the selection process described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fl\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, improperly targets or exempts employees subject to unannounced drug or alcohol testing, shall be subject to a civil penalty of one thousand dollars for each violation. The attorney general or the attorney general\u8217\'3fs designee may maintain a civil action to enforce }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Any civil penalty recovered shall be deposited in the general fund of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A laboratory or medical review officer involved in the conducting of a drug or alcohol test pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be deemed to have the necessary contact with this state for the purpose of subjecting the laboratory or medical review officer to the jurisdiction of the courts of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{\*\bkmkstart stylerid1_2E9_2E17_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E17_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Civil remedies.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ may be enforced through a civil action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or who aids in the violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is liable to an aggrieved employee or prospective employee for affirmative relief including reinstatement or hiring, with or without back pay, or any other equitable relief as the court deems appropriate including reasonable attorney fees and court costs. An aggrieved employee or prospective employee has the burden of proving by a preponderance of the evidence that a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ directly caused any damages for which affirmative relief is sought.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When an employer commits, is committing, or proposes to commit, an act in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, an injunction may be granted through an action in district court to prohibit the person from continuing such acts. The action for injunctive relief may be brought by an aggrieved employee or prospective employee, the county attorney, or the attorney general.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{\*\bkmkstart stylerid1_2E9_2E18_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E18_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Reports.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A laboratory doing business for an employer who conducts drug or alcohol tests pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall file an annual report with the department of health and human services by March 1 of each year concerning the number of drug or alcohol tests conducted on employees who work in this state pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and the number of positive and negative results of the tests, during the previous calendar year. In addition, the laboratory shall include in its annual report the specific basis for each test as authorized in }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{, the type of drug or drugs which were found in the positive drug tests, and all significant available demographic factors relating to the positive test pool.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 208, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1188, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1011, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1100, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a732, 33, 35}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 60, \'a71 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 114, \'a756, 59}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1081, \'a71 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a7112}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 50, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a7215 \u8211\'3f 217}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 111, \'a71 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 162, \'a722, 25}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7178}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1046, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71308 \u8211\'3f 1317}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 141, \'a71 \u8211\'3f 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a796.5}}}{{\f5\fs12\hyphpar0\qj{, 99F.4}}}{{\f5\fs12\hyphpar0\qj{, 124E.21}}}{{\f5\fs12\hyphpar0\qj{, 715A.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph j amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 7, paragraph j, subparagraph (1) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 9, paragraph a, NEW subparagraph (5)}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 15 amended}\par}}