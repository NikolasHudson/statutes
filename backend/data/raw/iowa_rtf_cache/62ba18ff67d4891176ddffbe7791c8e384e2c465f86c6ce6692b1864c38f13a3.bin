\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F421}{\*\bkmkend codeChapter_5F421}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 421}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{DEPARTMENT OF REVENUE}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a763A.2}}}{{\f5\fs12\qc{, 441.49}}}{{\f5\fs12\qc{, 533.329}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State board of tax review.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by its own terms; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2015/CH0109.pdf" }{\fldrslt \cf5 \f5 \fs18{{2015 Acts, ch 109, \'a72, 3}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.1A}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Property assessment appeal board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statewide property assessment appeal board is created for the purpose of establishing a consistent, fair, and equitable property assessment appeal process. The statewide property assessment appeal board is established within the department of revenue for administrative and budgetary purposes. The board\u8217\'3fs principal office shall be in the office of the department of revenue in the capital of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The property assessment appeal board shall consist of three members appointed to staggered six-year terms, beginning and ending as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{, by the governor and subject to confirmation by the senate. Subject to confirmation by the senate, the governor shall appoint from the members a chairperson of the board to a two-year term. Vacancies on the board shall be filled for the unexpired portion of the term in the same manner as regular appointments are made. The term of office for the initial board shall begin January 1, 2007.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each member of the property assessment appeal board shall be qualified by virtue of at least two years\u8217\'3f experience in the area of government, corporate, or private practice relating to property appraisal and property tax administration. Two members of the board shall be certified real property appraisers and one member shall be an attorney practicing in the area of state and local taxation or property tax appraisals. No more than two members of the board may be from the same political party as that term is defined in }}}{{\f5\fs18\hyphpar0\qj{section 43.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The property assessment appeal board shall organize by appointing a secretary who shall take the same oath of office as the members of the board. The board may employ additional personnel as it finds necessary. All personnel employed by the board shall be considered state employees and are subject to the merit system provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 8A, subchapter IV}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the election of a property owner or aggrieved taxpayer or an appellant described in }}}{{\f5\fs18\hyphpar0\qj{section 441.42}}}{{\f5\fs18\hyphpar0\qj{, the property assessment appeal board shall review any final decision, finding, ruling, determination, or order of a local board of review relating to protests of an assessment, valuation, or application of an equalization order, or any final decision of the county board of supervisors relating to denial of an application for, or the revocation of, a property tax exemption pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 427.1, subsection 40}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The property assessment appeal board may do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Affirm, reverse, or modify a final decision, finding, ruling, determination, or order of a local board of review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Affirm or reverse a final decision of a county board of supervisors relating to denial of an application for, or the revocation of, a property tax exemption under }}}{{\f5\fs18\hyphpar0\qj{section 427.1, subsection 40}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Order the payment or refund of property taxes in a matter over which the board has jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Grant other relief or issue writs, orders, or directives that the board deems necessary or appropriate in the process of disposing of a matter over which the board has jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subpoena documents and witnesses and administer oaths.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt administrative rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ for the administration and implementation of its powers, including rules for practice and procedure for protests filed with the board, the manner in which hearings on appeals of assessments shall be conducted, filing fees to be imposed by the board, and for the determination of the correct assessment of property which is the subject of an appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt administrative rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ necessary for the preservation of order and the regulation of proceedings before the board, including forms or notice and the service thereof, which rules shall conform as nearly as possible to those in use in the courts of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The property assessment appeal board shall employ a competent attorney to serve as its general counsel, and assistants to the general counsel as it finds necessary for the full and efficient discharge of its duties. The general counsel is the attorney for, and legal advisor of, the board. The general counsel or an assistant to the general counsel shall provide the necessary legal advice to the board in all matters and shall represent the board in all actions instituted in a court challenging the validity of a rule or order of the board. The general counsel shall devote full time to the duties of the office. During employment as general counsel to the board, the counsel shall not be a member of a political committee, contribute to a political campaign, participate in a political campaign, or be a candidate for partisan political office. The general counsel and assistants to the general counsel shall be considered state employees and are subject to the merit system provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 8A, subchapter IV}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the property assessment appeal board shall receive a salary set by the governor and commensurate with the salary of an administrative law judge. The members of the board shall be considered state employees for purposes of salary and benefits. The members of the board and any employees of the board, when required to travel in the discharge of official duties, shall be paid their actual and necessary expenses incurred in the performance of duties.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 150, \'a7121}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1185, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 215, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 123, \'a747 \u8211\'3f 49, 64 \u8211\'3f 67}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 120, \'a739, 40, 45}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1130, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a758, 60}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7441.37A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 6 applies to fiscal years beginning on or after July 1, 2022, effective with the pay period beginning June 24, 2022, and subsequent pay periods; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a760}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.2}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A department of revenue is created. The department shall be administered by a director of revenue who shall be appointed by the governor subject to confirmation by the senate and shall serve at the pleasure of the governor. If the office of the director becomes vacant, the vacancy shall be filled in the same manner as provided for the original appointment. Except for the Iowa lottery division under }{{\f5\fs18\hyphpar0\qj{chapter 99G}}}{, the director may establish, abolish, and consolidate divisions within the department of revenue when necessary for the efficient performance of the various functions and duties of the department of revenue.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a76943-c11, -c12, -c15, -c17; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.010, 6943.011, 6943.014, 6943.016;}}}{ C46, 50, 54, 58, 62, 66, \'a7421.1, 421.2, 421.5, 421.7; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7421.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7419}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7111}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a77E.5}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.3}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Director to have no conflicting interests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director of revenue shall not hold any other office under the laws of the United States or of this or any other state or hold any other position of profit. The director shall not engage in any occupation, business, or profession interfering with or inconsistent with the director\u8217\'3fs duties, serve on or under any committee of any political party, or contribute to the campaign fund of any person or political party. The director shall be of high moral character, shall be recognized for executive and administrative capacity, and shall possess expert knowledge and skills in the fields of taxation and property tax assessment. The director shall devote full time to the duties of the office.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a76943-c14; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.013;}}}{ C46, 50, 54, 58, 62, 66, \'a7421.4; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7421.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.4}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deputies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director may appoint deputy directors and may designate one or more of the deputies as acting director. A deputy designated to serve in the absence of the director has all of the powers possessed by the director. The director may employ certified public accountants, engineering and technical assistants, and other employees, or independent contractors necessary to protect the interests of the state and any political subdivision.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7421.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7420}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1165, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 158, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.5}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Settling claims for taxes, penalties, and interest }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ abatement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSettle\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsettlement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any compromise or abatement of any taxes, penalties, or interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the authority granted to the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.10}}}{{\f5\fs18\hyphpar0\qj{ and notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 7D.9}}}{{\f5\fs18\hyphpar0\qj{, the department may, in its sole discretion, settle any taxes, penalties, or interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may enter into a settlement in the case of doubtful liability, doubtful collectability, severe economic hardship, or to promote effective tax administration, regardless of whether the amount was the subject of a timely filed appeal or return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever a settlement is made, the department shall make a complete record of the case showing the tax assessed or claimed due, tax refund claimed, recommendations, reports, and audits of departmental personnel if any, the taxpayer\u8217\'3fs grounds for dispute or contest together with all of the evidence, and the amounts, conditions, and settlement of the same.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A taxpayer shall not have the right to a settlement of any tax, penalty, or interest liability under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Any determination by the department regarding the settlement shall be discretionary and shall be final and conclusive except in the case of fraud, mutual mistake of material fact, or as otherwise stated in a written settlement agreement between the taxpayer and the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may require an application for relief under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7421.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1165, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a722, 40}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.25}}}{{\f5\fs12\hyphpar0\qj{, 423.37}}}{{\f5\fs12\hyphpar0\qj{, 453B.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.6}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definition of return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For purposes of }{{\f5\fs18\hyphpar0\qj{this Title}}}{, unless the context otherwise requires, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freturn\u8221\'3f}}}{ means any tax or information return, amended return, declaration of estimated tax, or claim for refund that is required by, provided for, or permitted under, the provisions of }{{\f5\fs18\hyphpar0\qj{this Title}}}{ or }{{\f5\fs18\hyphpar0\qj{section 533.329}}}{, and which is filed with the department by, on behalf of, or with respect to any person. }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReturn\u8221\'3f}}}{ includes any amendment or supplement to these items, including supporting schedules, attachments, or lists which are supplemental to or part of the filed return.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1161, \'a72, 15, 16}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.20}}}{{\f5\fs12\hyphpar0\qj{, 422.72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.7}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interest rate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except where a different rate of interest is stated in a provision of this Title,* the rate of interest on interest-bearing obligations arising under this Title shall be the rate of interest in effect under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rate of interest that shall be in effect during a calendar year shall be the rate which is two percentage points greater than the numerical average, rounded to the nearest one percent, of the respective prime rates for each of the months in the twelve-month period that ends September 30 of the previous calendar year. The rate of interest established by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ takes effect January 1, and applies to any amount which is due or becomes payable on or after that date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding contrary provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the rate of interest that is in effect during a calendar year shall also be the rate of interest to be in effect for the following calendar year, unless the rate of interest as calculated under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ is at least one percentage point higher or lower than the rate then in effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event interest accrues or is calculated on a monthly basis, the rate of interest for each month shall be one-twelfth, rounded to the nearest one-tenth of one percent, of the rate specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fprime rate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the prime rate charged by banks on short-term business loans, as determined by the board of governors of the federal reserve system and published in the federal reserve bulletin.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In November of each year the director shall cause an advisory notice to be published in the Iowa administrative bulletin and on the internet site of the department, stating the rate of interest to be in effect on or after January 1 of the following year, as established by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The calculation and publication of the rate of interest by the director is exempt from }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71481-a23; C24, 27, 31, \'a77310, 7368; C35, \'a76943-f20, -f21, -f24, 7310, 7368; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.056, 6943.057, 6943.060, 7310, 7368;}}}{ C46, 50, 54, \'a7422.24, 422.25, 422.28, 450.6, 450.63; C58, 62, \'a7324.64, 422.24, 422.25, 422.28, 450.6, 450.63; C66, \'a7324.64, 422.16(9)(10, b), 422.24, 422.25, 422.28, 422.58, 423.18, 450.6, 450.63; C71, 73, 75, \'a7324.65, 422.16(9)(10, b), 422.24, 422.25, 422.28, 422.58, 423.18, 450.6, 450.63; C77, \'a7324.65, 422.16(9)(10, b)(11, e), 422.24, 422.25, 422.28, 422.58, 423.18, 450.6, 450.63, 450.94; C79, \'a7324.65, 422.16(9)(10, b)(11, e), 422.24, 422.25, 422.28, 422.58, 422.88, 423.18, 435.4, 435.6, 450.6, 450.63, 450.94, 450A.9; }{{\f5\fs18\hyphpar0\qj{C81, \'a7324.65}}}{, }{{\f5\fs18\hyphpar0\qj{422.16(9)(10, b)(11, e)}}}{, }{{\f5\fs18\hyphpar0\qj{422.24}}}{, }{{\f5\fs18\hyphpar0\qj{422.25}}}{, }{{\f5\fs18\hyphpar0\qj{422.28}}}{, }{{\f5\fs18\hyphpar0\qj{422.58}}}{, }{{\f5\fs18\hyphpar0\qj{422.88}}}{, }{{\f5\fs18\hyphpar0\qj{422.91}}}{, }{{\f5\fs18\hyphpar0\qj{423.18}}}{, }{{\f5\fs18\hyphpar0\qj{435.4}}}{, }{{\f5\fs18\hyphpar0\qj{435.6}}}{, }{{\f5\fs18\hyphpar0\qj{450.6}}}{, }{{\f5\fs18\hyphpar0\qj{450.63}}}{, }{{\f5\fs18\hyphpar0\qj{450.94}}}{, }{{\f5\fs18\hyphpar0\qj{450A.9}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 131, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1007, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1172, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 70, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 86, \'a774}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a757}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7184.3}}}{{\f5\fs12\hyphpar0\qj{, 421.27}}}{{\f5\fs12\hyphpar0\qj{, 421.60}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.24}}}{{\f5\fs12\hyphpar0\qj{, 422.25}}}{{\f5\fs12\hyphpar0\qj{, 422.88}}}{{\f5\fs12\hyphpar0\qj{, 423.4}}}{{\f5\fs12\hyphpar0\qj{, 423.40}}}{{\f5\fs12\hyphpar0\qj{, 423B.8}}}{{\f5\fs12\hyphpar0\qj{, 425.7}}}{{\f5\fs12\hyphpar0\qj{, 425A.8}}}{{\f5\fs12\hyphpar0\qj{, 437A.13}}}{{\f5\fs12\hyphpar0\qj{, 437B.9}}}{{\f5\fs12\hyphpar0\qj{, 450.6}}}{{\f5\fs12\hyphpar0\qj{, 450.63}}}{{\f5\fs12\hyphpar0\qj{, 452A.65}}}{{\f5\fs12\hyphpar0\qj{, 452A.74A}}}{{\f5\fs12\hyphpar0\qj{, 453A.28}}}{{\f5\fs12\hyphpar0\qj{, 453A.46}}}{{\f5\fs12\hyphpar0\qj{, 453B.12}}}{{\f5\fs12\hyphpar0\qj{, 459.402}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{*This provision does not include }{{\f5\fs12\hyphpar0\qj{chapters 421B}}}{, }{{\f5\fs12\hyphpar0\qj{427C}}}{, }{{\f5\fs12\hyphpar0\qj{435}}}{, }{{\f5\fs12\hyphpar0\qj{452A}}}{, and }{{\f5\fs12\hyphpar0\qj{453A}}}{, which were moved into this Title by the Code editor. }{{\f5\fs12\hyphpar0\qj{Chapters 421B}}}{, }{{\f5\fs12\hyphpar0\qj{427C}}}{, }{{\f5\fs12\hyphpar0\qj{435}}}{, }{{\f5\fs12\hyphpar0\qj{452A}}}{, and }{{\f5\fs12\hyphpar0\qj{453A}}}{ contain the applicable provisions pertaining to those chapters. }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.8}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty for defective return under certain circumstances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a person files a purported return of tax which does not contain information on which the substantial correctness of the self-assessment may be judged or which contains information that on its face indicates that the self-assessment is substantially incorrect and the conduct previously referred to in }{{\f5\fs18\hyphpar0\qj{this section}}}{ is due to a position which is frivolous or a desire which appears on the purported return to delay or impede the administration of the tax laws of this state, then the person shall pay a penalty of five hundred dollars. This penalty shall be in addition to any other penalty provided by law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1007, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.9}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties and powers \u8212\'3f office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of revenue or a department employee designated by the director shall sign on behalf of the department all orders, subpoenas, warrants, and other documents of like character issued by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The office of the department shall be maintained at the seat of government in this state. The department shall be deemed to be in continuous session and open for the transaction of business except Saturday, Sunday, and a holiday. The director of revenue may hold sessions in conducting investigations any place within the state when necessary to facilitate and render more thorough the performance of the director\u8217\'3fs duties. As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fholiday\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 421.9A, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or a date when the office is otherwise closed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 4.1, subsection 34}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may make application to the district court or judicial magistrate in the county where the books, records, or assets are located for an administrative search warrant as authorized by }}}{{\f5\fs18\hyphpar0\qj{section 808.14}}}{{\f5\fs18\hyphpar0\qj{, to ensure equitable administration of state tax law, if any of the following occurs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person refuses to allow the director or the director\u8217\'3fs authorized representative to audit the person\u8217\'3fs books or records or to inspect or value the person\u8217\'3fs assets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director has good and sufficient reason to believe that a person will not allow the department to audit books or records or inspect or value assets or to believe that the person will destroy books or records or secrete or transfer assets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Immediately upon issuance of a distress warrant authorized by }}}{{\f5\fs18\hyphpar0\qj{section 422.26}}}{{\f5\fs18\hyphpar0\qj{, the director may make application to the district court or judicial magistrate for an administrative search warrant as authorized by }}}{{\f5\fs18\hyphpar0\qj{section 808.14}}}{{\f5\fs18\hyphpar0\qj{ to execute the distress warrant.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a76943-c20, -c21, -c22, -c23; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.019, 6943.020, 6943.021, 6943.022;}}}{ C46, 50, 54, 58, 62, 66, \'a7421.10, 421.11, 421.12, 421.13; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7421.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7421}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1232, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1165, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 126, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7112}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.9A}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Due dates and holidays.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fholiday\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A legal public holiday as described in }}}{{\f5\fs18\hyphpar0\qj{section 1C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A paid holiday as described in }}}{{\f5\fs18\hyphpar0\qj{section 1C.2, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A federal holiday observed by the United States postal service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A banking holiday observed by the federal reserve.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A date when the office of the department is otherwise closed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 4.1, subsection 34}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the due date for filing a return or other document with the department or the due date for the department to take any action falls on a Saturday, Sunday, or any holiday, the act is considered to be performed timely if the act is performed on or before the first business day following the Saturday, Sunday, or holiday.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1061, \'a762}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7421.9}}}{{\f5\fs12\hyphpar0\qj{, 421.17A}}}{{\f5\fs12\hyphpar0\qj{, 452A.61}}}{{\f5\fs12\hyphpar0\qj{, 453A.10}}}{{\f5\fs12\hyphpar0\qj{, 453A.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.10}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal period }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ applicability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The appeal period for revision of assessment of tax, interest, and penalties set out under }{{\f5\fs18\hyphpar0\qj{section 422.28}}}{, }{{\f5\fs18\hyphpar0\qj{423.37}}}{, }{{\f5\fs18\hyphpar0\qj{437A.9}}}{, }{{\f5\fs18\hyphpar0\qj{437A.22}}}{, }{{\f5\fs18\hyphpar0\qj{437B.5}}}{, }{{\f5\fs18\hyphpar0\qj{437B.18}}}{, }{{\f5\fs18\hyphpar0\qj{452A.64}}}{, }{{\f5\fs18\hyphpar0\qj{453A.29}}}{, or }{{\f5\fs18\hyphpar0\qj{453A.46}}}{ applies to appeals to notices from the department denying changes in filing methods, denying refund claims, and denying portions of refund claims for the tax covered by that section, and notices of any adverse department action directed to a specific taxpayer, other than licensing, which involves a calculation.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 251, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 83, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1114, \'a71, 18}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0002.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2003 Acts, 1st Ex, ch 2, \'a7177, 205}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 94, \'a73, 35, 36}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a723, 40}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7437A.14}}}{{\f5\fs12\hyphpar0\qj{, 437B.10}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{421.11 through 421.13}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules \u8212\'3f director\u8217\'3fs duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall have power to establish all needful rules not inconsistent with law for the orderly and methodical performance of the director\u8217\'3fs duties, and to require the observance of such rules by those having business with or appearing before the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a76943-c24; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.023;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7421.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.15}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Seal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall have an official seal, and orders or other papers executed by the director may, under the director\u8217\'3fs direction, be attested, with the seal affixed, by the secretary.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a76943-c25; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.024;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7421.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.16}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director and department employees are entitled to receive from the state their actual necessary expenses while traveling on the business of the department. The expenditures shall be sworn to by the party who incurred the expense, and approved and allowed by the director. However, such expenses shall not be allowed residents of Polk county while in the city of Des Moines or traveling between their homes and the city of Des Moines.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a76943-c26; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.025;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7421.16}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1158, \'a772}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 284, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 23, \'a741}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 151, \'a72, 89}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{421.17}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and duties of director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to the powers and duties transferred to the director of revenue, the director shall have and assume the following powers and duties:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To have and exercise general supervision over the administration of the assessment and tax laws of the state, over boards of supervisors and all other officers or boards in the performance of their official duties in all matters relating to assessments and taxation, to the end that all assessments of property and taxes levied on the property be made relatively just and uniform in substantial compliance with the law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To supervise the activity of all assessors and boards of review in the state of Iowa; to cooperate with them in bringing about a uniform and legal assessment of property as prescribed by law.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may order the reassessment of all or part of the property in any assessing jurisdiction in any year. Such reassessment shall be made by the local assessor according to law under the direction of the director and the cost of making the assessment shall be paid in the same manner as the cost of making an original assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall determine the degree of uniformity of valuation as between the various assessing jurisdictions of the state and shall have the authority to employ competent personnel for the purpose of performing this duty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of bringing about uniformity and equalization of assessments throughout the state of Iowa, the director shall prescribe rules relating to the standards of value to be used by assessing authorities in the determination, assessment and equalization of actual value for assessment purposes of all property subject to taxation in the state, and such rules shall be adhered to and followed by all assessing authorities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To facilitate uniformity and equalization of assessments throughout the state of Iowa and to facilitate transfers of funds to local governments, the director of revenue may use geographic information system technology and may require assessing authorities and local governments that have adopted compatible technology to provide information to the department of revenue electronically using electronic geographic information system file formats. The department of revenue shall act on behalf of political subdivisions and the state to deliver a consolidated response to the boundary and annexation survey and provide legal boundary geography data to the United States census bureau. The department of revenue shall coordinate with political subdivisions and the state to ensure that consistent, accurate, and integrated geography is provided to the United States census bureau. The department of management shall provide geographic information system and technical support to the department of revenue to facilitate the exchange.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To prescribe and promulgate all forms of books and forms to be used in the listing and assessment of property, and on or before November 1 of each year shall furnish to the county auditor of each county such prescribed forms of assessment rolls and other forms to properly list and assess all property subject to taxation in each county. The department of revenue shall also from time to time prepare and furnish in like manner forms for any and all other blanks, memoranda or instructions which the director deems necessary or expedient for the use or guidance of any of the officers over which the director is authorized by law to exercise supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To confer with, advise, and direct boards of supervisors, boards of review, and others obligated by law to make levies and assessments, as to their duties under the laws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To direct proceedings, actions, and prosecutions to be instituted for the enforcement of the laws relating to the penalties, liabilities, and punishment of public officers, and officers or agents of corporations, and other persons or corporations, for failure or neglect to comply with the provisions of the statutes governing the return, assessment and taxation of property; to make or cause to be made complaints against members of boards of review, boards of supervisors or other assessing, reviewing, or taxing officers for official misconduct or neglect of duty. Employees of the department of revenue shall not during their regular hours of employment engage in the preparation of tax returns, except in connection with a regular audit of a tax return or in connection with assistance requested by the taxpayer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require city, township, school districts, county, state, or other public officers to report information as to the assessment of property and collection of taxes and such other information as may be needful or desirable in the work of the department in such form and upon such blanks as the director may prescribe.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall require all city and county assessors to prepare a quarterly report in the manner and form to be prescribed by the director showing for each warranty deed or contract of sale of real estate, divided between rural and urban, during the last completed quarter the amount of real property transfer tax, the sale price or consideration, and the equalized value at which that property was assessed that year. This report with further information required by the director shall be submitted to the department within sixty days after the end of each quarter. The department shall prepare annual summaries of the records of the ratio of assessments to actual sales prices for all counties, and for cities having city assessors, and the information for the preceding year shall be available for public inspection by May 1.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To hold public hearings either at the seat of government or elsewhere in the state, and tax the costs thereof; to summon and compel witnesses to appear and give testimony, to administer oaths to said witnesses, and to compel said witnesses to produce for examination records, books, papers, and documents relating to any matter which the director shall have the authority to investigate or determine. Provided, however, that no bank or trust company or its officers or employees shall be required to divulge knowledge concerning the property of any person when such knowledge was obtained through information imparted as a part of a business transaction with or for such person and in the usual and ordinary course of business of said bank or trust company, and was necessary and proper to the discharge of the duty of said bank or trust company in relation to such business transaction. This proviso shall be additional to other provisions of the law relating to confidential and privileged communications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To cause the depositions of witnesses residing within or without the state, or absent therefrom, to be taken either on written or oral interrogatories, and the clerk of the district court of any county shall upon the order of the director issue a commission for the taking of such depositions. The proceedings therefor shall be the same as the proceedings for the taking of depositions in the district court so far as applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To investigate the work and methods of boards of review, boards of supervisors, or other public officers, in the assessment, equalization, and taxation of all kinds of property, and for that purpose the director or employees of the department may visit the counties or localities when deemed necessary so to do.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To require any board of review at any time after its adjournment to reconvene and to make such orders as the director shall determine are just and necessary; to direct and order any board of review to raise or lower the valuation of the property, real or personal, in any township, city, or taxing district, to order and direct any board of review to raise or lower the valuation of any class or classes of property in any township, city, or taxing district, and generally to make any order or direction to any board of review as to the valuation of any property, or any class of property, in any township, city, county, or taxing district, which in the judgment of the director may seem just and necessary, to the end that all property shall be valued and assessed in the manner and according to the real intent of the law. For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ the words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftaxing district\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ include drainage districts and levee districts.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may correct obvious errors or obvious injustices in the assessment of any individual property, but the director shall not reduce the valuation of any individual property except upon the recommendation of the local board of review and an order of the director affecting any valuation shall not be retroactive as to any reduction or increase in taxes payable prior to January 1 of the year in which that order is issued, or prior to September 1 of the preceding year in cities under special charter which collect their own municipal levies. The director shall not correct errors or injustices under the authority of this paragraph if that correction would involve the exercise of judgment. Judicial review of the actions of the director may be sought in accordance with the terms of the Iowa administrative procedure Act, }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may order made effective reassessments or revaluations in any taxing district for any taxing year or years and the director may in any year order uniform increases or decreases in valuation of all property or upon any class of property within any taxing district or any area within such taxing district, such orders to be effective in the year specified by the director. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To carefully examine into all cases where evasion or violation of the law for assessment and taxation of property is alleged, complained of, or discovered, and to ascertain wherein existing laws are defective or are improperly or negligently administered, and cause to be instituted such proceedings as will remedy improper or negligent administration of the laws relating to the assessment or taxation of property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To make a summary of the tax situation in the state, setting out the amount of moneys raised by both direct and indirect taxation; and also to formulate and recommend legislation for the better administration of the fiscal laws so as to secure just and equal taxation. To recommend such additions to and changes in the present system of taxation that in the director\u8217\'3fs judgment are for the best interest of the state and will eliminate the necessity of any levy for state purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may establish criteria allowing for the use of electronic filing or the use of alternative filing methods of any return, deposit, or document required to be filed for taxes administered by the department. The director may also establish criteria allowing for payment of taxes, penalty, interest, and fees by electronic funds transfer or other alternative methods. The director shall adopt rules setting forth procedures for use in electronic filing and electronic funds transfer or other alternative methods and standards that provide for acceptance of a signature in a form other than the handwriting of a person. The rules shall also take into consideration any undue hardship electronic filing or electronic funds transfer or other alternative methods create for filers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To call upon a state agency or institution for technical advice and data which may be of value in connection with the work of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To prepare and issue a state appraisal manual which each county and city assessor shall use in assessing and valuing all classes of property in the state. The appraisal manual shall be continuously revised and the manual and revisions shall be issued to the county and city assessors in such form and manner as prescribed by the director. Each county and city assessor shall use the most recently issued manual in assessing and valuing all classes of property in the state within two years of the publication date of the most recently issued manual. The department may grant an extension of up to two years to a county or city assessor upon request and demonstration of substantial hardship by an assessor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To issue rules as are necessary, subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, to provide for the uniform application of the exemptions provided in }}}{{\f5\fs18\hyphpar0\qj{section 427.1}}}{{\f5\fs18\hyphpar0\qj{ in all assessor jurisdictions in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To subpoena from property owners and taxpayers any and all records and documents necessary to assist the department in the determination of the fair market value of industrial real estate.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The burden of showing reasonable cause to believe that the documents or records sought by the subpoena are necessary to assist the department under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be upon the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 17A.10 through 17A.18A}}}{{\f5\fs18\hyphpar0\qj{ relating to contested cases shall not apply to any matters involving the equalization of valuations of classes of property as authorized by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 441}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This exemption from the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 17A.10 through 17A.18A}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a hearing before the director as provided in }}}{{\f5\fs18\hyphpar0\qj{section 441.49, subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To cooperate with child support services created in }}}{{\f5\fs18\hyphpar0\qj{chapter 252B}}}{{\f5\fs18\hyphpar0\qj{ to establish and maintain a process to implement the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 252B.5, subsection 9}}}{{\f5\fs18\hyphpar0\qj{. The department of revenue shall forward to individuals meeting the criteria under }}}{{\f5\fs18\hyphpar0\qj{section 252B.5, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a notice by first class mail that the individual is obligated to file a state estimated tax form and to remit a separate child support payment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals notified shall submit a state estimated tax form on a quarterly basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual shall pay monthly, the lesser of the total delinquency or one hundred fifty percent of the current or most recent monthly obligation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual shall remit the payment to the department of revenue separate from any tax liability payments, identify the payment as a support payment, and make the payment payable to the collection services center. The department shall forward all payments received pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the collection services center established pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 252B}}}{{\f5\fs18\hyphpar0\qj{, for processing and disbursement. The department of revenue may establish a process for child support services or the collection services center to directly receive the payments. For purposes of crediting the support payments pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 252B.14}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{598.22}}}{{\f5\fs18\hyphpar0\qj{, payments received by the department of revenue and forwarded to the collection services center shall be credited as if received directly by the collection services center.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The notice shall provide that, as an alternative to the provisions of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the individual may contact child support services to formalize a repayment plan and obtain an exemption from the quarterly filing requirement when payments are made pursuant to the repayment plan or to contest the balance due listed in the notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of revenue, in cooperation with child support services, may adopt rules, if necessary, to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide information contained in state individual tax returns to child support services for the purposes of establishment or enforcement of support obligations. The department of revenue and child support services may exchange information in a manual or automated fashion. The department of revenue, in cooperation with child support services, may adopt rules, if necessary, to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To employ collection agencies, within or without the state, to collect delinquent taxes, including penalties and interest, administered by the department or delinquent accounts, charges, loans, fees, or other indebtedness due the state or any state agency, that have formal agreements with the department for central debt collection where the director finds that departmental personnel are unable to collect the delinquent accounts, charges, loans, fees, or other indebtedness because of a debtor\u8217\'3fs location outside the state or for any other reason. Fees for services, reimbursement, or other remuneration, including attorney fees, paid to collection agencies shall be based upon the amount of tax, penalty, and interest or debt actually collected and shall be paid only after the amount of tax, penalty, and interest or debt is collected. All funds collected must be remitted in full to the department within thirty days from the date of collection from a debtor or in a lesser time as the director prescribes. The funds shall be applied toward the debtor\u8217\'3fs account and handled as are funds received by other means. An amount is appropriated from the amount of tax, penalty, and interest, delinquent accounts, charges, loans, fees, or other indebtedness actually collected by the collection agency sufficient to pay all fees for services, reimbursement, or other remuneration pursuant to a contract with a collection agency under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A collection agency entering into a contract with the department for the collection of delinquent taxes, penalties, and interests, delinquent accounts, charges, loans, fees, or other indebtedness pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is subject to the requirements and penalties of the confidentiality laws of this state regarding tax or indebtedness information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To develop, modify, or contract with vendors to create or administer systems or programs which identify nonfilers of returns or nonpayers of taxes administered by the department and to identify and prevent the issuance of fraudulent or erroneous refunds. Fees for services, reimbursements, costs incurred by the department, or other remuneration may be funded from the amount of tax, penalty, or interest actually collected and shall be paid only after the amount is collected. An amount is appropriated from the amount of tax, penalty, and interest actually collected, not to exceed the amount collected, which is sufficient to pay for services, reimbursement, costs incurred by the department, or other remuneration pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Vendors entering into a contract with the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are subject to the requirements and penalties of the confidentiality laws of this state regarding tax information. The director shall report annually to the legislative services agency and the chairpersons and ranking members of the ways and means committees on the amount of costs incurred and paid during the previous fiscal year pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and the incidence of refund fraud and the costs incurred and amounts prevented from issuance during the previous fiscal year pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To enter into agreements or compacts with remote sellers, retailers, or third-party providers for the voluntary collection of Iowa sales or use taxes attributable to sales into Iowa. The director has the authority to enter into and perform all duties required of the office of director by multistate agreements or compacts that provide for the collection of sales and use taxes, including joint audits with other states or audits on behalf of other states. The agreements or compacts shall generally conform to the provisions of Iowa sales and use tax statutes. All fees for services, reimbursements, remuneration, incentives, and costs incurred by the department associated with these agreements or compacts may be paid or reimbursed from the additional revenue generated. An amount is appropriated from amounts generated to pay or reimburse all costs associated with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Persons entering into an agreement or compact with the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are subject to the requirements and penalties of the confidentiality laws of this state regarding tax information. Notwithstanding any other provisions of law, the contract, agreement, or compact shall provide for the registration, collection, report, and verification of amounts subject to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the director\u8217\'3fs discretion, accept payment of taxes, penalties, interest, and fees, or any portion thereof, by credit card. The director may adjust the payable amount to reflect the costs of processing the payment as determined by the treasurer of state and the payment by credit card shall include, in addition to all other charges, any discount charged by the credit card issuer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To ensure that persons employed under contract, other than officers or employees of the state, who provide assistance in administration of tax laws and who are directly under contract or who are involved in any way with work under the contract and who have access to confidential information are subject to applicable requirements and penalties of tax information confidentiality laws of the state regarding all tax return, return information, or investigative or audit information that may be required to be divulged in order to carry out the duties specified under the contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish, administer, and make available a centralized debt collection capability and procedure for the use by any state agency or local government entity including, but not limited to, the department of revenue, along with other boards, commissions, departments, and any other entity reported in the Iowa annual comprehensive financial report, to collect delinquent accounts, charges, fees, loans, taxes, or other indebtedness owed to or being collected by the state. The department\u8217\'3fs collection facilities shall only be available for use by other state agencies or local government entities for their discretionary use when resources are available to the director and subject to the director\u8217\'3fs determination that use of the procedure is feasible. The director shall prescribe the appropriate form and manner in which this information is to be submitted to the office of the department. The obligations or indebtedness must be delinquent and not subject to litigation, claim, appeal, or review pursuant to the appropriate remedies of each state agency or local government entity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall establish, as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a centralized computer data bank to compile the information provided and shall establish in the centralized data bank all information provided from all sources within the state concerning addresses, financial records, and other information useful in assisting the department in collection services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall establish a formal debt collection policy for use by state agencies and local government entities which have not established their own policy. Other state agencies and local government entities may use the collection facilities of the department pursuant to formal agreement with the department. The agreement shall provide that the information provided to the department shall be sufficient to establish the obligation in a court of law and to render it as a legal judgment on behalf of the state or the local government agency. After transferring the file to the department for collection, an individual state agency or the local government agency shall terminate all collection procedures and be available to provide assistance to the department. Upon receipt of the file, the department shall assume all liability for its actions without recourse to the agency or the local government agency, and shall comply with all applicable state and federal laws governing collection of the debt. The department may use a participating agency\u8217\'3fs or local government agency\u8217\'3fs statutory collection authority to collect the participating agency\u8217\'3fs delinquent accounts, charges, fees, loans, taxes, or other indebtedness owed to or being collected by the state. The department has the powers granted in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ regarding setoff from income tax refunds or other accounts payable by the state for any of the obligations transferred by state agencies or local government agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department\u8217\'3fs existing right to credit against tax due shall not be impaired by any right granted to, or duty imposed upon, the department or other state agency or local government agency by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All state agencies and local government agencies shall be given access, at the discretion of the director, to the centralized computer data bank and, notwithstanding any other provision of law to the contrary, may deny, revoke, or suspend any license or deny any renewal authorized by the laws of this state to any person who has defaulted on an obligation owed to or collected by the state. The confidentiality provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 422.20}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{422.72}}}{{\f5\fs18\hyphpar0\qj{ do not apply to tax information contained in the centralized computer data bank. State agencies and local government agencies shall endeavor to obtain from all applicants the applicant\u8217\'3fs social security or federal tax identification number, or, if the applicant has neither, the applicant\u8217\'3fs state driver\u8217\'3fs license number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the director\u8217\'3fs discretion, the department may accept payment of debts, interest, and fees, or any portion by credit card. The director may adjust the payable amount to reflect the costs of processing the payment as determined by the treasurer of state and the payment by credit card shall include, in addition to all other charges, any discount charge by the credit card issuer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall adopt administrative rules to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, including, but not limited to, rules necessary to prevent conflict with federal laws and regulations or the loss of federal funds, to establish procedures necessary to guarantee due process of law, and to provide for reimbursement of the department by other state agencies and local government entities for the department\u8217\'3fs costs related to debt collection for state agencies and local government entities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall report quarterly to the legislative fiscal committee, the legislative services agency, and the chairpersons and ranking members of the joint appropriations subcommittee on administration and regulation concerning the implementation of the centralized debt collection program, the number of departmental collection programs initiated, the amount of debts collected, and an estimate of future costs and benefits which may be associated with the collection program. It is the intent of the general assembly that the centralized debt collection program will result in the collection of at least two dollars of indebtedness for every dollar expended in administering the collection program during a fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may distribute to credit reporting entities and for publication the names, addresses, and amounts of indebtedness owed to or being collected by the state if the indebtedness is subject to the centralized debt collection procedure established in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The director shall adopt rules to administer this paragraph, and the rules shall provide guidelines by which the director shall determine which names, addresses, and amounts of indebtedness may be distributed for publication. The director may distribute information for publication pursuant to this paragraph, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{sections 422.20}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.72}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{423.42}}}{{\f5\fs18\hyphpar0\qj{, or any other provision of state law to the contrary pertaining to confidentiality of information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Of the amount of debt actually collected pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ an amount, not to exceed the amount collected, which is sufficient to pay for salaries, support, maintenance, services, and other costs incurred by the department related to the administration of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be retained by the department. Revenues retained by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be considered appropriated receipts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{. The director shall, in the annual budget request pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 8.23}}}{{\f5\fs18\hyphpar0\qj{, make an estimate as to the amount of receipts to be retained and the estimated amount of additional receipts to be collected. The director shall report annually to the department of management, the legislative fiscal committee, and the legislative services agency on any additional positions added and the costs incurred during the previous fiscal year pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.40, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, and rules adopted pursuant to this paragraph, a county treasurer may collect delinquent taxes, including penalties and interest, and nontax liabilities being collected by the central collection unit of the department of revenue. County treasurers shall be given access to information as necessary to accomplish the purposes of }}}{{\f5\fs18\hyphpar0\qj{section 321.40, subsection 6}}}{{\f5\fs18\hyphpar0\qj{. The confidentiality provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 422.20}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{422.72}}}{{\f5\fs18\hyphpar0\qj{ do not apply to information provided by the department to a county treasurer pursuant to this paragraph. A county treasurer collecting taxes, penalties, and interest administered by the department is subject to the requirements and penalties of the confidentiality laws of this state regarding tax or indebtedness information. The director shall adopt rules to implement the collections authorized in }}}{{\f5\fs18\hyphpar0\qj{section 321.40}}}{{\f5\fs18\hyphpar0\qj{ and this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To place on the department\u8217\'3fs official internet site the official electronic state of Iowa voter registration form and a link to the Iowa secretary of state\u8217\'3fs official internet site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{29.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To administer the county endowment fund created in }}}{{\f5\fs18\hyphpar0\qj{section 15E.311}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{30.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a natural disaster is declared by the governor in any area of the state, the director may extend for a period of up to one year the due date for the filing of any tax return and may suspend any associated penalty or interest that would accrue during that period of time for any affected taxpayer whose principal residence or business is located in the covered area if the director determines it necessary for the efficient administration of the tax laws of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{31.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director has reason to believe, as a result of an investigation or audit, that a taxpayer may have misclassified workers, then to assist the department of workforce development, the director is authorized to provide to the department of workforce development the following confidential information with respect to such a taxpayer:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Withholding and payroll tax information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxpayer\u8217\'3fs identity, including taxpayer identification number and date of birth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The results or most recent status of the audit or investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{32.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the extent permissible by federal law, to subpoena certain records held by a public or private utility company with respect to an individual who has a debt or obligation placed with the centralized collection unit of the department. The subpoena authority granted in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may be used only after reasonable efforts have been made by the centralized collection unit to identify and locate the individual.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may subpoena customer records in order to obtain a telephone number and last known address, but shall not request or require the disclosure of transaction information, account activity, or proprietary information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public or private utility company shall respond to the subpoenas. The subpoenas shall not be served more frequently than quarterly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The burden of showing reasonable cause to believe that the documents or records sought by the subpoena are necessary to assist the department under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be upon the director. In administering }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the director and the department shall comply with all applicable state and federal laws pertaining to the confidentiality or privacy of individuals or public or private utility companies. The information and customer records obtained by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are confidential records and are not subject to requests for examination pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public or private utility company shall not be held liable for any action arising as a result of providing the records described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or for any other action taken reasonably and in good faith to comply with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpublic or private utility company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a public utility, cable, video, or satellite television company, cellular telephone company, or internet service provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{33.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To adopt rules ensuring that the total amount of transfers and disbursements in a fiscal year by the department to a local government or other entity with respect to projects under }}}{{\f5\fs18\hyphpar0\qj{chapter 15J}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 418}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 423B.10}}}{{\f5\fs18\hyphpar0\qj{ does not exceed the amount of applicable taxes collected during the same fiscal year within the geographic boundaries of the reinvestment districts, governmental entities, or urban renewal areas in which such projects are located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{34.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the director\u8217\'3fs discretion, to retain in an electronic format any record, application, tax return, deposit, report, or any other information or document required to be submitted to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{35.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To audit and examine all taxes collected or administered by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{36.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To enter into an agreement pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ with the state fair organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 173}}}{{\f5\fs18\hyphpar0\qj{ or with a fair defined in }}}{{\f5\fs18\hyphpar0\qj{section 174.1}}}{{\f5\fs18\hyphpar0\qj{, to collect and remit taxes and fees from sellers making sales at retail on property owned, controlled, or operated by a fair or through events conducted by a fair.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{37.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish a fee, by rule, and charge a person for a copy of a return. The fee shall be retained by the department of revenue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{38.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law to the contrary, to cancel the following permits upon verification by the department of revenue the permits are no longer in use: income tax withholding, sales or use tax, or motor fuel tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{39.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Administer }}}{{\f5\fs18\hyphpar0\qj{chapters 99G}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{123}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a71010, 1011; C24, 27, \'a76868, 6869; C31, 35, \'a76868, 6869, 6943-c27; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6868, 6869, 6943.026;}}}{ C46, \'a7420.209, 420.210, 421.17; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7421.17}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1057, \'a72 \u8211\'3f 4}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1216, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159, 160}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 153, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 197, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1091, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1237, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a7422}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 199, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1109, \'a725, 26}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 250, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1232, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 90 A