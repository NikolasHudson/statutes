\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F4_30_30}{\*\bkmkend codeChapter_5F4_30_30}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 400}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CIVIL SERVICE}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a78.80}}}{{\f5\fs12\qc{, 8A.122}}}{{\f5\fs12\qc{, 10A.515}}}{{\f5\fs12\qc{, 20.8}}}{{\f5\fs12\qc{, 20.18}}}{{\f5\fs12\qc{, 28D.6}}}{{\f5\fs12\qc{, 28E.26}}}{{\f5\fs12\qc{, 28J.7}}}{{\f5\fs12\qc{, 80B.11}}}{{\f5\fs12\qc{, 97B.49B}}}{{\f5\fs12\qc{, 97B.49G}}}{{\f5\fs12\qc{, 137.104}}}{{\f5\fs12\qc{, 321J.1}}}{{\f5\fs12\qc{, 364.3}}}{{\f5\fs12\qc{, 411.5}}}{{\f5\fs12\qc{, 462A.2}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In cities having a population of eight thousand or over and having a paid fire department or a paid police department, the mayor, one year after a regular city election, with the approval of the council, shall appoint three civil service commissioners. The city shall publish notice of the names of persons selected for appointment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{. Commissioners shall hold office, one until the first Monday in April of the second year, one until the first Monday in April of the third year, and one until the first Monday in April of the fourth year after such appointment, whose successors shall be appointed for a term of four years. In cities having a population of more than fifty thousand, the city council shall establish, by ordinance, the number of civil service commissioners at not less than five but not more than seven.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of determining the population of a city under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the federal census conducted in 1980 shall be used.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5689;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.1; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1118, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 114, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 162, \'a71, 9}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1100, \'a755}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1134, \'a7108, 115}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 127, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 111, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 82, \'a72, 12}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 130, \'a710}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 1 by 2025 Acts, ch 82, \'a72, effective August 16, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 82, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See Code editor\u8217\'3fs note on simple harmonization at the beginning of this Code volume}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Qualifications \u8212\'3f prohibited contracts }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioners must be citizens of Iowa, eligible electors as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 39}}}{{\f5\fs18\hyphpar0\qj{, and residents of the city preceding their appointment, and shall serve without compensation. A person, while on the commission, shall not hold or be a candidate for any office of public trust. However, when a human rights commission has been established by a city, the director of the commission shall ex officio be a member, without vote, of the civil service commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Civil service commissioners, with respect to the city in which they are commissioners, shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sell, or in any manner become parties, directly or indirectly, to any contract to furnish supplies, material, or labor to the city unless the sale is made or the contract is awarded by competitive bid in writing, publicly invited and opened.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Have an interest, direct or indirect, in any contract or job of work or material or the profits thereof or services to be furnished or performed for the city unless the contract or job is awarded by competitive bid in writing, publicly invited and opened.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract entered into in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ is void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of the provisions contained in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ is a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5690;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.2; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 21, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 111, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1019, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a736}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Optional appointment of commission \u8212\'3f abolishing commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In cities having a population of less than eight thousand, the city council may, by ordinance, adopt the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ in which case it shall either appoint such commission or provide, by ordinance, for the exercise of the powers and performance of the duties of the commission by the council. Where the city council exercises the powers of the commission the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as used in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall mean the city council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the city council appoints a commission, the city council may, by ordinance, abolish the commission, and the commission shall stand abolished sixty days from the date of the ordinance and the powers and duties of the commission shall revert to the city council except whenever a city having a population of less than eight thousand provides for the appointment of a civil service commission, the city council may by ordinance abolish such office, but the ordinance shall not take effect until the ordinance has been submitted to the voters at a regular city election and approved by a majority of the voters at such election. The ordinance shall be published once each week for two consecutive weeks preceding the date of the election in a newspaper published in and having a general circulation in the city. If a newspaper is not published in such city, publication may be made in any newspaper having general circulation in the county.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5691;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.3; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1134, \'a7109, 115}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Chairperson \u8212\'3f clerk \u8212\'3f records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall elect a chairperson from among its members. In cities having a population of more than seventy-five thousand, the commission shall appoint a clerk of the commission. In all other cities the city clerk or a designee of the city clerk shall be clerk of the commission. If an employee is appointed clerk of the commission who is employed in a civil service status at the time of appointment as clerk of the commission, the appointee shall retain the civil service rights held before the appointment. However, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not grant civil service status or rights to the employee in the capacity of clerk of the commission nor extend any civil service right upon which the appointee may retain the position of clerk of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The civil service commission shall keep a record of all its meetings and also a complete individual service record of each civil service employee which record shall be permanent and kept up-to-date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When duly certified by the clerk of the commission copies of all records and entries or papers pertaining to said record shall be admissible in evidence with the same force and effect as the originals.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5692;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.4; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 55, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 162, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rooms and supplies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The council shall provide suitable rooms in which the commission may hold its meetings and supply the commission with all necessary equipment and a qualified shorthand reporter or an electronic voice recording device to enable it to properly perform its duties.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5693;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.5; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 147, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applicability \u8212\'3f exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ applies to permanent full-time police officers and fire fighters in cities having a population of more than eight thousand, and to all appointive permanent full-time employees in cities having a population of more than fifteen thousand except:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons appointed to fill vacancies in elective offices and members of boards and commissions and the clerk to the civil service commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city clerk, chief deputy city clerk, city attorneys, city treasurer, city assessor, city auditor, professional city engineers licensed in this state, and city health officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city manager or city administrator and assistant city managers or assistant city administrators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The head and principal assistant of each department and the head of each division. This exclusion does not apply to assistant fire chiefs and to assistant police chiefs in cities with police departments of two hundred fifty or fewer members. However, }}}{{\f5\fs18\hyphpar0\qj{sections 400.13}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{400.14}}}{{\f5\fs18\hyphpar0\qj{ apply to police and fire chiefs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The principal secretary to the city manager or city administrator, the principal secretary to the mayor, and the principal secretary to each of the department heads.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employees of boards of trustees or commissions established pursuant to state law or city ordinances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employees whose positions are funded by state or federal grants or other temporary revenues. However, a city may use state or federal grants or other temporary revenue to fund a position under civil service if the position is a permanent position which will be maintained for at least one year after expiration of the grants or temporary revenues.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5694;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.6; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710103, 10201}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1058, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 162, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Preference by service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee regularly serving in or holding a position when the position becomes subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or when the position is reclassified by the city shall retain the position and have full civil service rights in the position under any of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employee meets the minimum qualifications established for the position and has completed the required probationary period for the position.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employee has served satisfactorily in the position for a period equal to the probationary period of the position, and passes a qualifying noncompetitive examination for the position but does not meet the minimum qualifications established for the position.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee who has not completed the required probationary period but who otherwise meets the minimum qualifications established for the position or who passes a qualifying noncompetitive examination for the position shall receive full civil service rights in the position upon the completion of the probationary period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appointments made after the time }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ becomes applicable in a city are subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5695;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.7; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 162, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728D.6}}}{{\f5\fs12\hyphpar0\qj{, 400.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Original entrance examination \u8212\'3f appointments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission, when necessary under the rules, including minimum and maximum age limits, which shall be prescribed and published in advance by the commission and posted in the city hall, shall hold examinations for the purpose of determining the qualifications of applicants for positions under civil service, other than promotions, which examinations shall be practical in character and shall relate to matters which will fairly test the mental and physical ability of the applicant to discharge the duties of the position to which the applicant seeks appointment. The physical examination and mental health evaluation of applicants for appointment to the positions of police officer or fire fighter shall be held in accordance with medical protocols established by the board of trustees of the fire and police retirement system established by }}}{{\f5\fs18\hyphpar0\qj{section 411.5}}}{{\f5\fs18\hyphpar0\qj{ and shall be conducted in accordance with the directives of the board of trustees. However, the prohibitions of }}}{{\f5\fs18\hyphpar0\qj{section 216.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, regarding tests for the presence of the antibody to the human immunodeficiency virus shall not apply to such examinations. The board of trustees may change the medical protocols at any time the board so determines. In the event of a conflict between the medical protocols established under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the minimum entrance requirements of the Iowa law enforcement academy under }}}{{\f5\fs18\hyphpar0\qj{section 80B.11}}}{{\f5\fs18\hyphpar0\qj{, the medical protocols established under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall control. The physical examination and mental health evaluation of an applicant for the position of police officer or fire fighter shall be conducted after a conditional offer of employment has been made to the applicant. An applicant shall not be discriminated against on the basis of height, weight, sex, or race in determining physical or mental ability of the applicant. Reasonable rules relating to strength, agility, and general health of applicants shall be prescribed. The costs of the physical examination and the mental health evaluation required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid from the trust and agency fund of the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall establish the guidelines for conducting the examinations under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The commission shall hire persons with expertise to prepare and administer the examinations approved by the commission. It may also hire persons with expertise to consult in the preparation of such examinations if the persons so hired are employed to aid personnel of the commission in assuring that a fair examination is conducted. A fair examination shall explore the competence of the applicant in the particular field of examination.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An applicant who has successfully completed training at the Iowa law enforcement academy or another training facility certified by the director of the Iowa law enforcement academy does not need to retake a civil service examination upon changing employment from one Iowa law enforcement agency to another Iowa law enforcement agency, or upon becoming employed by more than one Iowa law enforcement agency simultaneously, if the applicant has previously passed a civil service examination when the applicant was initially hired as a certified peace officer and if, without a break of not more than one hundred eighty days from prior law enforcement service, the applicant is hired by another Iowa law enforcement agency. However, the applicant shall complete and pass the applicable physical examination provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ prior to beginning the new employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All appointments to such positions shall be conditional upon a probation period of not to exceed six months, and in the case of police dispatchers and fire fighters a probation period not to exceed twelve months. In the case of police patrol officers, if the employee has successfully completed training at the Iowa law enforcement academy or another training facility certified by the director of the Iowa law enforcement academy before the initial appointment as a police patrol officer, the probationary period shall be for a period of up to nine months and shall commence with the date of initial appointment as a police patrol officer. If the employee has not successfully completed training at the Iowa law enforcement academy or another training facility certified by the director of the law enforcement academy before initial appointment as a police patrol officer, the probationary period shall commence with the date of initial employment as a police patrol officer and shall continue for a period of up to nine months following the date of successful completion of training at the Iowa law enforcement academy or another training facility certified by the director of the Iowa law enforcement academy. A police patrol officer transferring employment from one jurisdiction to another shall be employed subject to a probationary period of up to nine months. However, in cities with a population over one hundred seventy-five thousand, appointments to the position of fire fighter shall be conditional upon a probation period of not to exceed twenty-four months. During the probation period, the appointee may be removed or discharged from such position by the appointing person or body without the right of appeal to the commission. A person removed or discharged during a probationary period shall, at the time of discharge, be given a notice in writing stating the reason or reasons for the dismissal. A copy of such notice shall be promptly filed with the commission. Continuance in the position after the expiration of such probationary period shall constitute a permanent appointment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5696;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.8; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 187, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 147, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1071, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1187, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1124, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1077, \'a784}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 176, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1103, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 20, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 183, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1014, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1138, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7400.10}}}{{\f5\fs12\hyphpar0\qj{, 400.11}}}{{\f5\fs12\hyphpar0\qj{, 411.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.8A}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Guidelines for ongoing fitness for police officers and fire fighters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board of trustees of the fire and police retirement system established by }{{\f5\fs18\hyphpar0\qj{section 411.5}}}{, in consultation with the medical board established in }{{\f5\fs18\hyphpar0\qj{section 411.5}}}{, shall establish and maintain protocols and guidelines for ongoing wellness and fitness for police officers and fire fighters while in service. The board of trustees may change the protocols and guidelines at any time the board so determines. The protocols and guidelines shall be established by the board of trustees for the consideration of cities covered by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and may be applied by a city for the purpose of determining continued wellness and fitness for members of the city\u8217\'3fs police and fire departments. However, the protocols and guidelines shall not be applied to members of a police or fire department of a city who are covered by }{{\f5\fs18\hyphpar0\qj{chapter 20}}}{ except through the collective bargaining process as provided under }{{\f5\fs18\hyphpar0\qj{chapter 20}}}{. The medical board established in }{{\f5\fs18\hyphpar0\qj{section 411.5}}}{ shall provide to cities and fire and police departments assistance regarding the possible implementation and operation of the protocols and guidelines for ongoing wellness and fitness provided by }{{\f5\fs18\hyphpar0\qj{this section}}}{. For purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwellness and fitness\u8221\'3f}}}{ means the process by which police officers and fire fighters maintain fitness for duty.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1077, \'a785}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7400.18}}}{{\f5\fs12\hyphpar0\qj{, 400.19}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Promotional examinations and procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall, at such times as shall be found necessary, under such rules as shall be prescribed and published in advance by the commission, and posted in the city hall, hold competitive promotional examinations for the purpose of determining the qualifications of applicants for promotion to a higher grade under civil service, which examinations shall be practical in character, and shall relate to such matters as will fairly test the ability of the applicant to discharge the duties of the position to which the applicant seeks promotion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall establish guidelines for conducting the examinations under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The commission shall hire persons with expertise to prepare and administer the examinations approved by the commission for the position in the city for which the applicant is taking the examination. It may also hire persons with expertise to consult in the preparation of such examinations if the persons so hired are employed to aid personnel of the commission in assuring that a fair examination is conducted. A fair examination shall explore the competence of the applicant in the particular field of examination. The names of persons approved to administer any examination under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be posted in the city hall at least twenty-four hours prior to the examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vacancies in civil service promotional grades shall be filled by lateral transfer, voluntary demotion, or promotion of employees of the city to the extent that the city employees qualify for the positions. When laterally transferred, voluntarily demoted, or promoted, an employee shall hold full civil service rights in the position. If an employee of the city does not pass the promotional examination and otherwise qualify for a vacated position, or if an employee of the city does not apply for a vacated position, an entrance examination may be used to fill the vacancy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If there is a certified list of qualified candidates for a promotional appointment, the following procedures shall be followed:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A publication stating that interviews are being scheduled to make a new certified list to fill a vacancy in a civil service promotional grade classification shall be posted for at least five working days before the closing date for the interviews in the same locations where examination notices are posted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee who wishes to voluntarily demote or to laterally transfer into a vacancy and has previously been or is currently in the classification where the vacancy exists shall notify the civil service commission of the employee\u8217\'3fs interest in the vacant position. The employee shall be added to the list of candidates to be interviewed and considered for the vacancy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If there is no certified list of qualified candidates for a promotional appointment, the following procedures shall be followed:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When an examination announcement is posted to make a certified list of qualified candidates, the announcement shall also state that an employee who has been or is currently employed in the classification where the vacancy exists may notify the civil service commission of the employee\u8217\'3fs interest in the vacant position. Upon notification, the employee shall be added to the list of candidates for an interview and consideration for the vacant position.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All civil service employees of a city who meet the minimum qualifications for a classification shall have the right to compete in the civil service examination process to establish a certified list of qualified candidates.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a75696-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5696.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.9; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1085, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 162, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 111, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 183, \'a756}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Veterans preferences.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In all examinations and appointments under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, other than promotions and appointments of chief of the police department and chief of the fire department, veterans who are citizens and residents of the United States, shall have five percentage points added to the veteran\u8217\'3fs grade or score attained in qualifying examinations for appointment to positions and five additional percentage points added to the grade or score if the veteran has a service-connected disability or is receiving compensation, disability benefits, or pension under laws administered by the United States department of veterans affairs. An honorably discharged veteran who has been awarded the Purple Heart incurred in action shall be considered to have a service-connected disability. However, the percentage points shall be given only upon passing the exam and shall not be the determining factor in passing. Veteran\u8217\'3fs preference percentage points shall be applied once to the final scores used to rank applicants for selection for an interview. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fveteran\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 35.1}}}{{\f5\fs18\hyphpar0\qj{ except that the requirement that the person be a resident of this state shall not apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a veteran entitled to preference pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ has been honorably discharged between forty-five days before and sixty days after an examination is administered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 400.8}}}{{\f5\fs18\hyphpar0\qj{, the commission may allow the veteran to be subject to examination up to ninety days following the date the original examination was administered and if appropriate shall add the veteran\u8217\'3fs name to the list for original appointment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 400.11, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5697;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.10; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 50, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1238, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 180, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 26, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 150, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7128}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1116, \'a758}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a735C.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Veterans preference law, }{{\f5\fs12\hyphpar0\qj{chapter 35C}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Names certified \u8212\'3f temporary appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission, within one hundred eighty days after the beginning of each competitive examination for original appointment, shall certify to the city council a list of the names of forty persons, or a lesser number as determined by the commission, who qualify with the highest standing as a result of each examination for the position they seek to fill, or the number which have qualified if less than forty, in the order of their standing, and all newly created offices or other vacancies in positions under civil service which occur before the beginning of the next examination for the positions shall be filled from the lists, or from the preferred list existing if provided for in case of diminution of employees, within thirty days. If a tie occurs in the examination scores which would qualify persons for the last position on the list, the list of the names of the persons who qualify with the highest standing as a result of each examination shall include all persons who qualify for the last position. Preference for temporary service in civil service positions shall be given those on the lists. However, the commission may certify a list of names eligible for appointment subject to successfully completing a medical examination. The medical examination shall be provided pursuant to commission rules adopted under }}}{{\f5\fs18\hyphpar0\qj{section 400.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may hold in reserve, for original appointments, additional lists of forty persons, each next highest in standing, in order of their grade, or such number as may qualify if less than forty. If the list of up to forty persons provided in the first paragraph is exhausted within one year, the commission may certify such additional lists of up to forty persons each, in order of their standing, to the council as eligible for appointment to fill such vacancies as may exist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission, within ninety days after the beginning of each competitive examination for promotion, shall certify to the city council a list of names of the ten persons who qualify with the highest standing as a result of each examination for the position the persons seek to fill, or the number which have qualified if less than ten, in the order of their standing and all newly created offices or other vacancies in positions under civil service which occur before the beginning of the next examination for the positions shall be filled from the lists, or from the preferred list existing if provided for in the case of diminution of employees, within thirty days. If a tie occurs in the examination scores which would qualify persons for the tenth position on the list, the list of names of the persons who qualify with the highest standing as a result of each examination shall include all persons who qualify for the tenth position.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except where the preferred list exists, persons on the certified eligible list for promotion shall hold preference for promotion for two years following the date of certification, except for certified eligible lists of fire fighters as defined in }}}{{\f5\fs18\hyphpar0\qj{section 411.1, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, which lists shall hold preference for three years upon approval of the commission, after which the lists shall be canceled and promotion to the grade shall not be made until a new list has been certified eligible for promotion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When there is no such preferred list or certified eligible list, or when the eligible list shall be exhausted, the person or body having the appointing power may temporarily fill a newly created office or other vacancy only until an examination can be held and the names of qualified persons be certified by the commission, and such temporary appointments are hereby limited to ninety days for any one person in the same vacancy, but such limitation shall not apply to persons temporarily acting in positions regularly held by another. A temporary appointment to a position regularly held by another shall, whenever possible, be made according to the certified eligible list. Any person temporarily filling a vacancy in a position of higher grade for twenty days or more, shall receive the salary paid in such higher grade.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5698;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.11; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 62, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 187, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 147, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1071, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 162, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 111, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a7116, 117}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7400.10}}}{{\f5\fs12\hyphpar0\qj{, 400.12A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Seniority }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ extinguishment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ reestablishment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of determining the seniority rights of civil service employees, seniority shall be computed, beginning with the date of appointment to or employment in any positions for which they were certified or otherwise qualified and established as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, but shall not include any period of time exceeding sixty days in any one year during which they were absent from the service except for disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event that a civil service employee has more than one classification or grade, the length of the employee\u8217\'3fs seniority rights shall date in the respective classifications or grades from and after the time the employee was appointed to or began employment in each classification or grade. In the event that an employee has been promoted from one classification or grade to another, the employee\u8217\'3fs civil service seniority rights shall be continuous in any department grade or classification that the employee formerly held.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list of all civil service employees shall be prepared and posted in the city hall by the civil service commission on or before July 1 of each year, indicating the civil service standing of each employee as to the employee\u8217\'3fs seniority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided in a collective bargaining agreement, a city council may extinguish the seniority rights, including but not limited to seniority accrued, provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to all civil service employees who are not employed or appointed as a fire fighter or police officer, fire chief or police chief, or assistant fire chief or assistant police chief. A city council may subsequently reestablish seniority rights extinguished pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for all employees who are not employed or appointed as a fire fighter or police officer, fire chief or police chief, or assistant fire chief or assistant police chief. Seniority rights reestablished in this way may include, but are not required to include, accrual of seniority for employment prior to the reestablishment of such rights.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5698.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.12; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 2, \'a755, 64}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7400.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.12A}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hiring practices }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ suspension }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ reinstatement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city council, by majority vote, may suspend the practices specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ that are generally required pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the hiring of an employee of a department governed by civil service. A suspension shall not be in effect for more than one year, but a city council may immediately vote to implement a new suspension of the required practices upon the expiration of the prior suspension. Upon the expiration of a suspension, hiring practices required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be immediately reinstated for the applicable positions. A city council, by majority vote, may reinstate hiring practices suspended pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ prior to the expiration of the suspension. A subsequent vote to suspend required hiring practices, even if the vote occurs prior to the original expiration date of the prior suspension, shall be considered a vote for a new suspension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{section 400.11, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, may be suspended as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not relieve an employee of a department governed by civil service from the requirements to complete all examinations and tests applicable to those persons for positions subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to preclude an employee of a department governed by civil service from accessing rights, benefits, or privileges provided outside of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to change the maximum number of persons on the hiring list referenced in }}}{{\f5\fs18\hyphpar0\qj{section 400.11, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for a position to be filled to be greater than forty.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1014, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 82, \'a73, 12}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph c effective August 16, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 82, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, NEW paragraph c}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.13}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Chief of police and chief of fire department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief of the fire department and the chief of the police department shall be appointed from the chiefs\u8217\'3f civil service eligible lists. Such lists shall be determined by original examination open to all persons applying, whether or not members of the employing city. The chief of a fire department shall have had a minimum of five years\u8217\'3f experience in a fire department, or three years\u8217\'3f experience in a fire department and two years of comparable experience or educational training. The chief of a police department shall have had a minimum of five years\u8217\'3f experience in a public law enforcement agency, or three years\u8217\'3f experience in a public law enforcement agency and two years of comparable experience or educational training. A chief of a police department or fire department shall maintain civil service rights as determined by }}}{{\f5\fs18\hyphpar0\qj{section 400.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who becomes chief of police or chief of the fire department shall be allowed to transfer all rights the person may have acquired under }}}{{\f5\fs18\hyphpar0\qj{chapter 410}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{411}}}{{\f5\fs18\hyphpar0\qj{, including employer contributions during the person\u8217\'3fs years of service in a city, employee contributions, and interest, to the retirement system of the city that hires the person as chief. Such person shall also transfer the number of years served as seniority toward other benefits provided by the city which hires the person. If a chief of a police or fire department is relieved of that position, the person shall be entitled to remain in the department for which the person was chief at a position commensurate with the person\u8217\'3fs civil service status, even if this means that the city must create a position for the person to fill until a regular position becomes vacant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In cities under the commission plan of government the superintendent of public safety, with the approval of the city council, shall appoint the chief of the fire department and the chief of the police department. In cities under a council-manager form of government the city manager shall make the appointments with the approval of the city council, and in all other cities the appointments shall be made as provided by city ordinance or city charter.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5699;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.13; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1171, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7372.4}}}{{\f5\fs12\hyphpar0\qj{, 400.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.14}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil service status of chiefs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A police officer under civil service may be appointed chief of police and a fire fighter under civil service may be appointed chief of the fire department without losing civil service status, and shall retain, while holding the office of chief, the same civil service rights that the officer or fire fighter may have had immediately previous to appointment as chief, but nothing in }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be deemed to extend to such individual any civil service right upon which the individual may retain the position of chief.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C27, 31, 35, \'a75699-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5699.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.14; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7208}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7400.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.15}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointing powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All appointments or promotions to positions within the scope of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ other than those of chief of police and chief of fire department shall be made:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In cities under the commission form of government, by the superintendents of the respective departments, with the approval of the city council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In cities under the city manager plan, by the city manager.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In all other cities, with the approval of the city council. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the police and fire departments, by the chiefs of the respective departments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All such appointments or promotions shall promptly be reported to the clerk of the commission by the appointing officer. An appointing authority may transfer an employee, other than police officers and fire fighters, from one department to the same civil service classification in another department, and such employee shall retain the same civil service status.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, \'a75698; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5699.2;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.15; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 162, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a751}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.16}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Qualifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All appointive officers and employees of cities shall be selected with reference to their qualifications and fitness and for the good of the public service, and without reference to their political faith or party allegiance.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5700;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.16; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.16}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.17}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employees under civil service \u8212\'3f qualifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{section 400.7}}}{{\f5\fs18\hyphpar0\qj{, a person shall not be appointed, promoted, or employed in any capacity, including a new classification, in the fire or police department, or any department which is governed by the civil service, until the person has passed a civil service examination as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and has been certified to the city council as being eligible for the appointment. However, in an emergency in which the peace and order of the city is threatened by reason of fire, flood, storm, or mob violence, making additional protection of life and property necessary, the person having the appointing power may deputize additional persons, without examination, to act as peace officers until the emergency has passed. A person may be appointed to a position subject to successfully completing a civil service medical examination. A person shall not be appointed or employed in any capacity in the fire or police department if the person is unable to meet reasonable physical condition training requirements and reasonable level of experience requirements necessary for the performance of the position; if the person is a habitual criminal; if the person is addicted to narcotics or alcohol and has not been rehabilitated for a period of one year or more, or is not presently undergoing treatment; or if the person has attempted a deception or fraud in connection with a civil service examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 400.7}}}{{\f5\fs18\hyphpar0\qj{, a person shall not be appointed or employed in any capacity in any department which is governed by civil service if the person is unable to meet reasonable physical condition training requirements and reasonable level of experience requirements necessary for the performance of the position; if the person is addicted to narcotics or alcohol and has not been rehabilitated for a period of one year or more, or is not presently undergoing treatment; or if the person has attempted a deception or fraud in connection with a civil service examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employees shall not be required to be a resident of the city in which they are employed, but they shall become a resident of the state within two years of such appointment or the date employment begins and shall remain a resident of the state during the remainder of employment. The state residency requirement under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to employees of a city that has adopted an ordinance to allow its employees to reside in another state and shall not apply to an employee of a city that later repeals such an ordinance if the employee resides in another state at the time of the repeal. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cities may set a reasonable maximum distance outside of the corporate limits of the city, or a reasonable maximum travel time, that police officers, fire fighters, and other critical city employees may live from their place of employment. An employee subject to a residency requirement based on distance or travel time who does not meet that residency requirement on the date of appointment or on the date employment begins shall take reasonable steps to meet the requirement as soon as practicable, and a city may provide the employee up to one year from the date of appointment or the date employment begins to meet the residency requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be appointed, denied appointment, promoted, removed, discharged, suspended, or demoted to or from a civil service position or in any other way favored or discriminated against in that position because of political or religious opinions or affiliations, race, national origin, sex, or age, or in retaliation for the exercise of any right enumerated in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, the maximum age for a police officer or fire fighter covered by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and employed for police duty or the duty of fighting fires is sixty-five years of age.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5701;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.17; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 187, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 147, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 111, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1017, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 2, \'a756, 64}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.18}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Removal, discharge, demotion, or suspension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding civil service rights as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall only be removed, discharged, demoted, or suspended with just cause and upon a finding by a preponderance of the evidence that an act or failure to act by the employee is in violation of law, city policies, or rules, or that the employee is physically or mentally unfit as determined under guidelines established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 400.8A}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to modify the rights, requirements, or procedures provided in }}}{{\f5\fs18\hyphpar0\qj{section 400.8A}}}{{\f5\fs18\hyphpar0\qj{ or other rights, requirements, or procedures provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee who is removed, discharged, demoted, or suspended may request a hearing before the civil service commission to review the appointing authority\u8217\'3fs, police chief\u8217\'3fs, or fire chief\u8217\'3fs decision to remove, discharge, demote, or suspend the employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city shall have the burden to prove that the act or failure to act by the employee was in violation of law, city policies, or department rules not in conflict with any collective bargaining agreement or law. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the city shall establish each element of the charges specified under }}}{{\f5\fs18\hyphpar0\qj{section 400.22}}}{{\f5\fs18\hyphpar0\qj{ by a preponderance of the evidence. The city shall have the burden to prove that the punishment imposed upon the employee is proportionate, reasonable, and just in the totality of the circumstances under the factors provided in }}}{{\f5\fs18\hyphpar0\qj{section 400.27, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person subject to a hearing has the right to be represented by counsel at the person\u8217\'3fs expense or by the person\u8217\'3fs authorized collective bargaining representative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A collective bargaining agreement to which a bargaining unit that has at least thirty percent of members who are public safety employees as defined in }}}{{\f5\fs18\hyphpar0\qj{section 20.3}}}{{\f5\fs18\hyphpar0\qj{ is a party shall provide additional procedures not inconsistent with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for the implementation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5702;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.18; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.18}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 111, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 2, \'a757, 64}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 82, \'a74, 12}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7411.1}}}{{\f5\fs12\hyphpar0\qj{, 411.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsections 1 and 3 effective August 16, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 82, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 1 and 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.19}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Peremptory removal, discharge, demotion, or suspension of subordinates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The person having the appointing power as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or the chief of police or chief of the fire department, may, upon presentation of reasonable and just grounds for such action to the subordinate in writing, peremptorily remove, discharge, demote, or suspend a subordinate then under the person\u8217\'3fs or chief\u8217\'3fs direction due to any act or failure to act by the employee that is in violation of law, city policies, or department rules, and is deemed reasonably anticipated to be detrimental to the public. }{{\f5\fs18\hyphpar0\qj{This section}}}{ shall not be construed to modify the rights, requirements, or procedures provided in }{{\f5\fs18\hyphpar0\qj{section 400.8A}}}{ or other rights, requirements, or procedures provided by law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5703;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.19; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 2, \'a758, 64}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 82, \'a75, 12}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7411.1}}}{{\f5\fs12\hyphpar0\qj{, 411.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment effective August 16, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 82, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.20}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The removal, discharge, demotion, or suspension of a person holding civil service rights may be appealed to the civil service commission within fourteen calendar days after the removal, discharge, demotion, or suspension.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5704;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.20; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 2, \'a759, 64}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a780F.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Internal investigations and rights of peace officers and public safety and emergency personnel, see }{{\f5\fs12\hyphpar0\qj{\'a780F.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.21}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice of appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the appeal be taken by the person removed, discharged, demoted, or suspended, notice of the appeal, signed by the appellant and specifying the ruling appealed from, shall be filed with the clerk of the commission. If the appeal is taken by the person making such removal, discharge, demotion, or suspension, such notice shall also be served upon the person removed, discharged, demoted, or suspended.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5705;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.21; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.21}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 2, \'a760, 64}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7125}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7400.27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.22}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Charges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Within fourteen calendar days from the service of the notice of appeal, the person or body making the ruling appealed from shall file with the body to which the appeal is taken a written specification of the charges and grounds upon which the ruling was based. If the charges are not filed, the person removed, discharged, demoted, or suspended may present the matter to the body to whom the appeal is to be taken by affidavit, setting forth the facts, and the body to whom the appeal is to be taken shall immediately enter an order reinstating the person removed, discharged, demoted, or suspended for want of prosecution.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5706;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.22; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.22}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 2, \'a761, 64}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7400.18}}}{{\f5\fs12\hyphpar0\qj{, 400.22A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.22A}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exculpatory evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person shall not knowingly withhold exculpatory evidence from an employee subject to a written specification of charges filed under }{{\f5\fs18\hyphpar0\qj{section 400.22}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 82, \'a76, 12}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section effective August 16, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 82, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.23}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Time and place of hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Within ten days after such specifications are filed, the commission shall fix the time for a hearing, which shall be not less than five nor more than twenty days thereafter, and the place for hearing the appeal. The commission shall notify the parties in writing of the time and place so fixed, and the notice shall contain a copy of the specifications so filed. Hearings under }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be held during normal city business hours unless otherwise agreed to by the parties and the commission. The commission in its discretion may grant a continuance or stay of a hearing upon request.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5707;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.23; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.23}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 82, \'a77, 12}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment effective August 16, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 82, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.24}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Oaths }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ books and papers }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The presiding officer of the commission or the council, as the case may be, shall have power to administer oaths in the same manner and with like effect and under the same penalties as in the case of magistrates exercising criminal or civil jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The council or commission shall cause subpoenas to be issued for such witnesses and the production of such books and papers as either party may designate. Issuance of subpoenas shall be consistent with the Iowa rules of civil procedure. The subpoenas shall be signed by the chairperson of the commission or mayor, as the case may be, or by an attorney representing a party before the commission. The council or commission shall provide a copy of each subpoena to both parties upon issuance. A party, or an attorney representing a party, shall provide copies of any material produced in response to a subpoena to the opposing party upon receipt of such material.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Those employees who are defined as an }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fofficer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ under }}}{{\f5\fs18\hyphpar0\qj{section 80F.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall have the right to request documents, records, and any other evidence in the possession of the appointing authority relevant to the determination of cause and proportionality of discipline not otherwise in violation of }}}{{\f5\fs18\hyphpar0\qj{chapter 80F}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5708;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.24; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.24}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 82, \'a78, 12}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment effective August 16, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 82, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.25}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contempt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In case a witness is duly subpoenaed and refuses to attend, or in case a witness appears and refuses to testify or to produce required books or papers, the official body hearing the appeal shall, in writing, report such refusal to the district court of the county, and said court shall proceed with said person or witness as though said refusal had occurred in a proceeding legally pending before said court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5709;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.25; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.25}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Contempts, }{{\f5\fs12\hyphpar0\qj{chapter 665}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.26}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public trial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The trial of all appeals shall be public, and the parties may be represented by counsel or by the parties\u8217\'3f authorized collective bargaining representative. However, upon the request of the employee, the deliberations of the commission in a city with a population of less than two hundred thousand shall be held in closed session.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5710;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.26; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.26}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 111, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 82, \'a79, 12}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment effective August 16, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 82, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.27}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Jurisdiction \u8212\'3f attorney \u8212\'3f appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The civil service commission has jurisdiction to hear and determine matters involving the rights of civil service employees under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and may affirm, modify, or reverse any case on its merits.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commission determines that the city proved the employee committed the charge as specified, the commission shall determine whether the removal, discharge, demotion, or suspension of the employee was with just cause based upon the totality of the circumstances. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the commission shall consider factors including the nature of the conduct at issue in the circumstances, the proportionality of the punishment to the conduct at issue, the employee\u8217\'3fs work history, whether the employee reasonably could comply with the policy or rule in the circumstances and whether the employee\u8217\'3fs conduct was objectively reasonable in the circumstances, the employee\u8217\'3fs defenses or justifications, any mitigating or aggravating factors, whether the punishment is reasonably calculated to correct the employee\u8217\'3fs behavior or conduct, if the punishment is necessary to protect the public interest, whether the city, its employees, or the appointing authority acted in accordance with the law, city policies, department rules, or standard operating procedures, or if the policy failed in the circumstances. The commission shall only consider, order, or impose discipline upon the employee for charges proven by the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall reverse the city\u8217\'3fs decision and dismiss a specific charge with prejudice if the city fails to meet its burden of proof as to that charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The final decision of the commission shall be based upon a majority vote of the commission, shall be made in writing, and shall include findings of fact and conclusions relied upon, and reasoning or rationale for the decision, separately stated. The commission shall render and serve its final decision upon the parties by certified mail within thirty days of the close of the record or trial unless the parties consent to a later date in writing or on the record. The final decision may be served upon an employee by electronic mail with the consent of the employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the city attorney or solicitor shall be the attorney for the commission or when requested by the commission shall present matters concerning civil service employees to the commission, except the commission may hire a counselor or an attorney on a per diem basis to represent it when in the opinion of the commission there is a conflict of interest between the commission and the city council. The counselor or attorney hired by the commission shall not be the city attorney or solicitor. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of a notice of appeal pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 400.21}}}{{\f5\fs18\hyphpar0\qj{, a city attorney, assistant city attorney, or solicitor who represents or has represented the commission shall not represent the city or its officers or employees in an appeal pending before the commission unless the employee waives the conflict of interest in writing or on the record. If the commission is required to hire a counselor or attorney that is not a city attorney, assistant city attorney, or solicitor as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the city shall pay the costs incurred by the commission in employing a counselor or attorney under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and the commission shall independently seek and retain such an attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A counselor or attorney who represents the commission in an appeal before the commission shall be fair and impartial toward the parties. The counselor or attorney representing the commission may provide advice and counsel to the commission on matters before it and assist the commission with its proceedings and trial as may be necessary or requested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall provide for the production of evidence and exchange of exhibits in advance of trial. The city shall mark its exhibits with numbers. The employee shall mark its exhibits with letters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city or any civil service employee shall have a right to appeal to the district court from the final ruling or decision of the civil service commission. The appeal shall be taken within thirty days from the service of the formal decision of the commission. The district court of the county in which the city is located shall have full jurisdiction of the appeal. The scope of review for the appeal shall be a trial de novo.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The appeal to the district court shall be perfected by filing a notice of appeal with the clerk of the district court within the time prescribed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and by serving notice of appeal on the clerk of the civil service commission, from whose ruling or decision the appeal is taken.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event the ruling or decision appealed from is reversed by the district court, the appellant, if it be an employee, shall then be reinstated as of the date of the said suspension, demotion, or discharge and shall be entitled to compensation from the date of such suspension, demotion, or discharge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other remedies and relief, upon application, the district court may award reasonable attorney fees, expert fees, and costs to those employees who are defined as an \u8220\'3fofficer\u8221\'3f under }}}{{\f5\fs18\hyphpar0\qj{section 80F.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and only when such employee meets any of the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employee is fully reinstated from a termination without discipline imposed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employee\u8217\'3fs suspension has been reduced by over fifty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employee\u8217\'3fs demotion was reversed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5711;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.27; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.27}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 55, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 2, \'a762, 64}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7126}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 82, \'a710 \u8211\'3f 12}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7400.18}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendments effective August 16, 2025; 2025 Acts, ch 82, \'a712}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended and editorially internally renumbered}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.28}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Employees }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ number diminished.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city council may implement a diminution of employees in a classification or grade under civil service. Such a diminution shall be carried out in accordance with any procedures provided in a collective bargaining agreement to which a bargaining unit that has at least thirty percent of members who are public safety employees as defined in }{{\f5\fs18\hyphpar0\qj{section 20.3}}}{ is a party, if applicable.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7679-h; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5712;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.28; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.28}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1138, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7131}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 2, \'a763, 64}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.29}}}{\*\bkmkstart stylerid1_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Political activity limited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a civil service position shall not, while performing official duties or while using city equipment at the person\u8217\'3fs disposal by reason of the position, solicit in any manner contribution for any political party or candidate or engage in any political activity during working hours that impairs the efficiency of the position or presence during the working hours. A person shall not seek or attempt to use any political endorsement in connection with any appointment to a civil service position.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a civil service position shall not, by the authority of the position, secure or attempt to secure in any manner for any other person an appointment or advantage in appointment to a civil service position or an increase in pay or other advantage of employment in any such position for the purpose of influencing the vote or political action of that person or for any other consideration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who in any manner supervises a person holding a civil service position shall not directly or indirectly solicit the person supervised to contribute money, anything of value, or service to a candidate seeking election, or a political party or candidate\u8217\'3fs political committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit any employee or group of employees, individually or collectively, from expressing honest opinions and convictions, or making statements and comments concerning their wages or other conditions of their employment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71056-a32; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5713;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.29; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.29}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1021, \'a73}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Public employee candidates for elective public office; see }{{\f5\fs12\hyphpar0\qj{\'a755.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.30}}}{\*\bkmkstart stylerid1_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be strictly carried out by each person or body having powers or duties thereunder, and any act or failure to act tending to avoid or defeat the purposes of such provisions is hereby prohibited and shall be a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5713.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7365.30; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.30}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{400.31}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Waterworks employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In cities where the board of waterworks trustees has adopted a resolution placing its employees under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ as to civil service, the civil service commission acting under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ has charge of the civil service procedure as to those employees and }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ applies.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C50, 54, 58, 62, 66, 71, 73, \'a7365.31; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7400.31}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a783}}}\par}}