\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(25)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a free clinic as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135.24A}}}{{\f5\fs18\hyphpar0\qj{ for purposes of record checks of potential volunteers and existing volunteers at the free clinic. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only with respect to disposition data for cases of founded child abuse subject to placement in the central registry pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.71D}}}{{\f5\fs18\hyphpar0\qj{, to a person who submits written authorization from an individual allowing the person access to data pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ on behalf of the individual in order to verify whether the individual is named in a founded child abuse report as having abused a child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Access to report data and disposition data for a case of child abuse determined to meet the definition of child abuse, which data is not subject to placement in the central registry pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.71D}}}{{\f5\fs18\hyphpar0\qj{, is authorized only to the following persons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subjects of a report identified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons involved in an assessment of child abuse identified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (2), (3), (4), (6), and (7).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Others identified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (2), (3), (6), and (18).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of justice for purposes of review by the prosecutor\u8217\'3fs review committee or the commitment of sexually violent predators as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 229A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Access to report data for a case of child abuse determined to not meet the definition of child abuse, which data is not subject to placement in the central registry pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.71D}}}{{\f5\fs18\hyphpar0\qj{, is authorized only to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subjects of a report identified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons involved in an assessment of child abuse identified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (2), (6), and (7).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Others identified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (2) and (18).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of justice for purposes of review by the prosecutor\u8217\'3fs review committee or the commitment of sexually violent predators as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 229A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Access to disposition data subject to placement in the central registry pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.71D}}}{{\f5\fs18\hyphpar0\qj{ is authorized to the department of administrative services or to the personnel office of a public employer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 20.3}}}{{\f5\fs18\hyphpar0\qj{, as necessary for presentation in grievance or arbitration procedures provided for in }}}{{\f5\fs18\hyphpar0\qj{sections 8A.415}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{20.18}}}{{\f5\fs18\hyphpar0\qj{. Disposition data introduced into a grievance or arbitration proceeding shall not be considered a part of the public record of a case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a child who is a legal resident of another state is present in this state and a report of child abuse is made concerning the child, the department shall act to ensure the safety of the child. The department shall contact the child\u8217\'3fs state of legal residency to coordinate the assessment of the report. If the child\u8217\'3fs state of residency refuses to conduct an assessment, the department shall commence an appropriate assessment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a report of child abuse is made concerning an alleged perpetrator who resides in this state and a child who resides in another state, the department shall assist the child\u8217\'3fs state of residency in conducting an assessment of the report. The assistance shall include but is not limited to an offer to interview the alleged perpetrator and any other relevant source. If the child\u8217\'3fs state of residency refuses to conduct an assessment of the report, the department shall commence an appropriate assessment. The department shall seek to develop protocols with states contiguous to this state for coordination in the assessment of a report of child abuse when a person involved with the report is a resident of another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director receives a written request for information regarding a specific case of child abuse involving a fatality or near fatality to a child from the majority or minority leader of the senate or the speaker or the minority leader of the house of representatives, the director or the director\u8217\'3fs designee shall arrange for a confidential meeting with the requestor or the requestor\u8217\'3fs designee. In the confidential meeting the director or the director\u8217\'3fs designee shall share all pertinent information concerning the case, including but not limited to child abuse information. Any written document distributed by the director or the director\u8217\'3fs designee at the confidential meeting shall not be removed from the meeting and a participant in the meeting shall be subject to the restriction on redissemination of confidential information applicable to a person under }}}{{\f5\fs18\hyphpar0\qj{section 235A.17, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, for confidential information disclosed to the participant at the meeting. A participant in the meeting may issue a report to the governor or make general public statements concerning the department\u8217\'3fs handling of the case of child abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the request of the governor, the department shall disclose child abuse information to the governor or the governor\u8217\'3fs designee relating to a specific case of child abuse reported to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, apart from a request made pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 7 or 8}}}{{\f5\fs18\hyphpar0\qj{, the department receives from a member of the public a request for information relating to a case of founded child abuse involving a fatality or near fatality to a child, the response to the request shall be made in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{subsections 10 and 11}}}{{\f5\fs18\hyphpar0\qj{. If the request is received before or during performance of an assessment of the case in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{, the director or the director\u8217\'3fs designee shall initially disclose whether or not the assessment will be or is being performed. Otherwise, within five business days of receiving the request or completing the assessment, whichever is later, the director or the director\u8217\'3fs designee shall consult with the county attorney responsible for prosecution of any alleged perpetrator of the fatality or near fatality and shall disclose information, including but not limited to child abuse information, relating to the case, except for the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The substance or content of any mental health or psychological information that is confidential under }}}{{\f5\fs18\hyphpar0\qj{chapter 228}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information that constitutes the substance or contains the content of an attorney work product or is a privileged communication under }}}{{\f5\fs18\hyphpar0\qj{section 622.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information that would reveal the identity of any individual who provided information relating to a report of child abuse or an assessment of such a report involving the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information that the director or the director\u8217\'3fs designee reasonably believes is likely to cause mental or physical harm to a sibling of the child or to another child residing in the child\u8217\'3fs household.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information that the director or the director\u8217\'3fs designee reasonably believes is likely to jeopardize the prosecution of any alleged perpetrator of the fatality or near fatality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information that the director or the director\u8217\'3fs designee reasonably believes is likely to jeopardize the rights of any alleged perpetrator of the fatality or near fatality to a fair trial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information that the director or the director\u8217\'3fs designee reasonably believes is likely to undermine an ongoing or future criminal investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information, the release of which is a violation of federal law or regulation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information released by the director or the director\u8217\'3fs designee pursuant to a request made under }}}{{\f5\fs18\hyphpar0\qj{subsection 9}}}{{\f5\fs18\hyphpar0\qj{ relating to a case of founded child abuse involving a fatality or near fatality to a child shall include all of the following, unless such information is excepted from disclosure under }}}{{\f5\fs18\hyphpar0\qj{subsection 9}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any relevant child abuse information concerning the cause of and circumstances surrounding the child fatality or near fatality, including the age and gender of the child and the department\u8217\'3fs response and findings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information describing any previous child abuse or neglect investigations of the caregivers responsible for the child abuse or neglect that are pertinent to the child abuse or neglect that led to the child fatality or near fatality, and the results of any such investigations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A summary of information, that would otherwise be confidential under }}}{{\f5\fs18\hyphpar0\qj{section 217.30}}}{{\f5\fs18\hyphpar0\qj{, as to whether or not the child or a member of the child\u8217\'3fs family was utilizing social services provided by the department at the time of the child fatality or near fatality or within the five-year period preceding the fatality or near fatality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any recommendations made by the department to the county attorney or the juvenile court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The services provided by and actions of the state on behalf of the child that are pertinent to the child abuse or neglect that led to the child fatality or near fatality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person who made a request for information under }}}{{\f5\fs18\hyphpar0\qj{subsection 9}}}{{\f5\fs18\hyphpar0\qj{ does not believe the department has substantially complied with the request, the person may apply to the juvenile court under }}}{{\f5\fs18\hyphpar0\qj{section 235A.24}}}{{\f5\fs18\hyphpar0\qj{ for an order for disclosure of additional information.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If release of social services information in addition to that released under }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, is believed to be in the public\u8217\'3fs interest and right to know, the director or the director\u8217\'3fs designee may apply to the court under }}}{{\f5\fs18\hyphpar0\qj{section 235A.24}}}{{\f5\fs18\hyphpar0\qj{ requesting a review of the information proposed for release and an order authorizing release of the information. A release of information that would otherwise be confidential under }}}{{\f5\fs18\hyphpar0\qj{section 217.30}}}{{\f5\fs18\hyphpar0\qj{ concerning social services provided to the child or the child\u8217\'3fs family shall not include information concerning financial or medical assistance provided to the child or the child\u8217\'3fs family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an individual who is the subject of a child abuse report listed in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or another party involved in an assessment under }}}{{\f5\fs18\hyphpar0\qj{section 232.71B}}}{{\f5\fs18\hyphpar0\qj{ releases in a public forum or to the media information concerning a case of child abuse including but not limited to child abuse information which would otherwise be confidential, the director or the director\u8217\'3fs designee may respond with relevant information concerning the case of child abuse that was the subject of the release. Prior to releasing the response, the director or the director\u8217\'3fs designee shall consult with the child\u8217\'3fs parent or guardian, or the child\u8217\'3fs guardian ad litem, and apply to the court under }}}{{\f5\fs18\hyphpar0\qj{section 235A.24}}}{{\f5\fs18\hyphpar0\qj{ requesting a review of the information proposed for release and an order authorizing release of the information.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7235A.15}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1066, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 173, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 174, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1177, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 153, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1158, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 65, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 283, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1221, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1248, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1249, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 138, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1141, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1143, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 76, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1156, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 93, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 