\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F282}{\*\bkmkend codeChapter_5F282}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 282}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{SCHOOL ATTENDANCE AND TUITION}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7274.3}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{School age \u8212\'3f nonresidents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons between five and twenty-one years of age are of school age. Nonresident children shall be charged the maximum tuition rate as determined in }}}{{\f5\fs18\hyphpar0\qj{section 282.24}}}{{\f5\fs18\hyphpar0\qj{, with the exception that those residing temporarily in a school corporation may attend school in the corporation upon terms prescribed by the board. A school district discontinuing grades under }}}{{\f5\fs18\hyphpar0\qj{section 282.7, subsection 1 or 3}}}{{\f5\fs18\hyphpar0\qj{, shall be charged tuition as provided in }}}{{\f5\fs18\hyphpar0\qj{section 282.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fresident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a child who meets either of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is physically present in a district, whose residence has not been established in another district by operation of law, and who meets any of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is in the district for the purpose of making a home and not solely for school purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Meets the definitional requirements of the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhomeless individual\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ under }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a711302(a) and (c)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lives in a juvenile detention center or residential facility in the district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is domiciled with the child\u8217\'3fs parent or guardian who is on active duty in the military service of the United States and is stationed at and resides or is domiciled within a federal military installation located contiguous to a county in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parent or guardian of a child who meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, may enroll the child in a school district in a county in this state that is located contiguous to the out-of-state federal military installation. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 285.1}}}{{\f5\fs18\hyphpar0\qj{ relating to transportation of resident pupils, the parent or guardian is responsible for transporting the child without reimbursement to and from a point on a regular school bus route of the district of enrollment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 282.6}}}{{\f5\fs18\hyphpar0\qj{, if a parent or guardian enrolls a child in a school district in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the school district shall be free of tuition for such child.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a71795; C97, \'a72804; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4268;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 31, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1263, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 210, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1130, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 120, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a788, 89}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a7237, 239}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256E.8}}}{{\f5\fs12\hyphpar0\qj{, 257.6}}}{{\f5\fs12\hyphpar0\qj{, 257.11B}}}{{\f5\fs12\hyphpar0\qj{, 282.8}}}{{\f5\fs12\hyphpar0\qj{, 282.18}}}{{\f5\fs12\hyphpar0\qj{, 282.35}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Extended school programs.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2006/CH1152.pdf" }{\fldrslt \cf5 \f5 \fs18{{2006 Acts, ch 1152, \'a756}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Offsetting tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The parent or guardian whose child or protected person attends school in a district of which the parent or guardian is not a resident shall be allowed to deduct the amount of school tax paid by the parent or guardian in said district from the amount of tuition required to be paid.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72804; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4269;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1158, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1009, \'a747}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Admission and exclusion of pupils.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may exclude from school children under the age of six years when in its judgment such children are not sufficiently mature to be benefited by regular instruction, or any child who is found to be physically or mentally unable to attend school under }}}{{\f5\fs18\hyphpar0\qj{section 299.5}}}{{\f5\fs18\hyphpar0\qj{, or whose presence in school has been found to be injurious to the health of other pupils, or is efficiently taught for the scholastic year at a state institution. However, the board shall provide special education programs and services under }}}{{\f5\fs18\hyphpar0\qj{chapters 256B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{257}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{273}}}{{\f5\fs18\hyphpar0\qj{ for all children requiring special education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The conditions of admission to public schools for work in the year immediately preceding the first grade and in the first grade shall be as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child under the age of six years on the fifteenth of September of the current school year shall not be admitted to a public school unless the board of directors of the school has adopted and put into effect courses of study for the school year immediately preceding the first grade, approved by the department of education, and has employed a practitioner or practitioners for this work with standards of training approved by the board of educational examiners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No child shall be admitted to school work for the year immediately preceding the first grade unless the child is five years of age on or before the fifteenth of September of the current school year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No child shall be admitted to the first grade unless the child is six years of age on or before the fifteenth of September of the current school year; except that a child under six years of age who has been admitted to school work for the year immediately preceding the first grade under conditions approved by the department of education, or who has demonstrated the possession of sufficient ability to profit by first-grade work on the basis of tests or other means of evaluation recommended or approved by the department of education, may be admitted to first grade at any time before December 31.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a school board from requiring the attainment of a greater age than the age requirements set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72782; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4270;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 135, \'a785}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 210, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 265, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7128}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7279.9A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspension \u8212\'3f expulsion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board may, by a majority vote, expel any student from school for a violation of the regulations or rules established by the board, or when the presence of the student is detrimental to the best interests of the school. The board may confer upon any teacher, principal, or superintendent the power temporarily to suspend a student, notice of the suspension being at once given in writing to the president of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A student who commits an assault, as defined under }}}{{\f5\fs18\hyphpar0\qj{section 708.1}}}{{\f5\fs18\hyphpar0\qj{, against a school employee in a school building, on school grounds, or at a school-sponsored function shall be suspended for a time to be determined by the principal. Notice of the suspension shall be immediately sent to the president of the board. By special meeting or at the next regularly scheduled board meeting, the board shall review the suspension and decide whether to hold a disciplinary hearing to determine whether or not to order further sanctions against the student, which may include expelling the student. In making its decision, the board shall consider the best interests of the school district, which shall include what is best to protect and ensure the safety of the school employees and students from the student committing the assault.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A student shall not be suspended or expelled pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the suspension or expulsion would violate the }}}{{\f5\fs18\hyphpar0\qj{federal Individuals with Disabilities Education Act}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 282.6}}}{{\f5\fs18\hyphpar0\qj{, if a student has been expelled or suspended from school and has not met the conditions of the expulsion or suspension, the student shall not be permitted to enroll in a school district until the board of directors of the school district approves, by a majority vote, the enrollment of the student.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a71735, 1756; C97, \'a72782; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4271;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 210, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1131, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1199, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 218, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1215, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a771}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7279.9A}}}{{\f5\fs12\hyphpar0\qj{, 280.21B}}}{{\f5\fs12\hyphpar0\qj{, 282.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Readmission of student.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a student is suspended by a teacher, principal, or superintendent, pursuant to }{{\f5\fs18\hyphpar0\qj{section 282.4}}}{, the student may be readmitted by the teacher, principal, or superintendent when the conditions of the suspension have been met, but when expelled by the board the student may be readmitted only by the board or in the manner prescribed by the board.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a72054; C73, \'a71735, 1756; C97, \'a72782; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4272;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1091, \'a723}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 218, \'a728}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1215, \'a752}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7279.9A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tuition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fresident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is physically present in a district, whose residence has not been established in another district by operation of law, and who meets any of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is in the district for the purpose of making a home and not solely for school purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Meets the definitional requirements of the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhomeless individual\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ under }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a711302(a)}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lives in a residential correctional facility in the district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every school shall be free of tuition to all actual residents between the ages of five and twenty-one years and to resident veterans as defined in }}}{{\f5\fs18\hyphpar0\qj{section 35.1}}}{{\f5\fs18\hyphpar0\qj{, as many months after becoming twenty-one years of age as they have spent in the armed forces of the United States before they became twenty-one, provided, however, fees may be charged covering instructional costs for a summer school or driver education program. The board of education may, in a hardship case, exempt a student from payment of the above fees. Every person, however, who shall attend any school after graduation from a four-year course in an approved high school or its equivalent shall be charged a sufficient tuition fee to cover the cost of the instruction received by the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to tuition authorized by }}}{{\f5\fs18\hyphpar0\qj{chapter 260C}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a71724, 1727; C97, \'a72773; S13, \'a72773; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4273;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 210, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1135, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 180, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a780}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a723}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7282.1}}}{{\f5\fs12\hyphpar0\qj{, 282.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Attending in another corporation \u8212\'3f payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a school district by record action may discontinue any or all of grades seven through twelve and negotiate an agreement for attendance of the pupils enrolled in those grades in the schools of one or more contiguous school districts having accredited school systems. If the board designates more than one contiguous district for attendance of its pupils, the board shall draw boundary lines within the school district for determining the school districts of attendance of the pupils. The portion of a district so designated shall be contiguous to the accredited school district designated for attendance. Only entire grades may be discontinued under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and if a grade is discontinued, all higher grades in that district shall also be discontinued. A school district that has discontinued one or more grades under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ has complied with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 275.1}}}{{\f5\fs18\hyphpar0\qj{ relating to the maintenance of kindergarten and twelve grades. A pupil who graduates from another school district under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall receive a diploma from the receiving district. The boards of directors entering into an agreement under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall provide for sharing the costs and expenses as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 282.10 through 282.12}}}{{\f5\fs18\hyphpar0\qj{. The agreement shall provide for transportation and authority and liability of the affected boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the career and technical education program offered by a school district does not meet standards for program approval adopted by the state board for career and technical education, the district shall be granted one year to meet the standards for approval. If a district chooses to waive the one-year grace period, or the district fails to meet the approval standards after one year, the director of the department of education shall delegate the authority to the regional career and technical education planning partnership established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.136}}}{{\f5\fs18\hyphpar0\qj{ to direct the district to contract with another school district or a community college which has an approved program, for the provision of career and technical education for students of the district. The district that has waived the one-year grace period or has failed to meet the approval standards shall pay to the district or community college that has an approved program an amount equal to the percent of the school day in which a pupil is receiving career and technical education in the approved program times the district cost per pupil of the district of residence of the pupil. The regional career and technical education planning partnership established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.136}}}{{\f5\fs18\hyphpar0\qj{ shall contract with an approved program for delivery of career and technical education in the district which has failed to meet the approval standards or has waived the one-year grace period. Transportation to and from the approved program shall be provided by the school district that has waived the one-year grace period or has failed to meet approval standards. Reasonable effort shall be made to conduct the approved program at an attendance center in the district that has failed to meet the approval standards or has waived the one-year grace period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{sections 28E.9}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{282.8}}}{{\f5\fs18\hyphpar0\qj{, a school district may negotiate an agreement under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ for attendance of its pupils in a school district located in a contiguous state subject to a reciprocal agreement by the two state boards in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Prior to negotiating an agreement with the school district in the contiguous state, the board of directors shall file a written request with the state board of education for a determination whether the school district in the contiguous state meets requirements substantially similar to those required for accredited or approved school districts in this state and the school district receives or has available services equivalent to those that would be provided in this state by an area education agency. The school district shall also obtain approval by the department of education of the sharing proposal, before the agreement becomes effective. Six months before making the request for approval, the district shall request a feasibility study from the department of education. If the state board of this state and the corresponding state board in the contiguous state agree that the school districts of their respective states meet substantially similar requirements and have substantially similar services available to the school district, and if the Iowa department of education approves the proposed contract, the two state boards may sign a reciprocal agreement for attendance of their pupils in the school district of the other state, subject to the agreement signed between the boards of directors of the two districts. A school district that negotiates an agreement with a school district in a contiguous state under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is not eligible for supplementary weighting under }}}{{\f5\fs18\hyphpar0\qj{section 257.11}}}{{\f5\fs18\hyphpar0\qj{ as a result of that agreement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a71143; R60, \'a72024; C73, \'a71793; C97, \'a72803; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4274;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 31, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 212, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71484}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 224, \'a759}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1263, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 135, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 278, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7108}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1108, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a783}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.9}}}{{\f5\fs12\hyphpar0\qj{, 275.1}}}{{\f5\fs12\hyphpar0\qj{, 275.2}}}{{\f5\fs12\hyphpar0\qj{, 282.1}}}{{\f5\fs12\hyphpar0\qj{, 282.10}}}{{\f5\fs12\hyphpar0\qj{, 282.24}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Attending school outside state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The boards of directors of school districts located near the state boundaries may designate schools of equivalent standing across the state line for attendance of both elementary and secondary school pupils when the public school in the adjoining state is nearer than any appropriate public school in a pupil\u8217\'3fs district of residence or in Iowa. Distance shall be measured by the nearest traveled public road. Arrangements shall be subject to reciprocal agreements made between the chief state school officers of the respective states. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 282.1}}}{{\f5\fs18\hyphpar0\qj{, arrangements between districts pursuant to the reciprocal agreements made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall establish tuition and transportation fees in an amount acceptable to the affected boards, but the tuition fee established shall not be less than the lower of the tuition fee established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 282.24}}}{{\f5\fs18\hyphpar0\qj{ for the school district or the equivalent tuition rate for the non-Iowa school district for the previous school year, and the transportation fee established shall not be less than the lower average transportation cost per mile for yellow school buses as described in }}}{{\f5\fs18\hyphpar0\qj{section 321.373}}}{{\f5\fs18\hyphpar0\qj{ for the previous school year of the two affected school districts. The agreement shall provide that if the tuition fee for the school district in the adjoining state is a variable rate, the test of which tuition fee is lower shall be determined for each student by the affected boards. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person attending school in another state pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall continue to be treated as a pupil of the district of residence for state school foundation aid purposes under }}}{{\f5\fs18\hyphpar0\qj{section 257.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the tuition provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the tuition fee established for a child requiring special education under }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ shall be equal to the actual cost of the special education instructional program provided to that child under the child\u8217\'3fs individualized education program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the chief state school officers of the respective states have not entered into a reciprocal agreement under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or the agreement has expired or been terminated, or the distance to the public school in the adjoining state is not nearer than an appropriate public school in the pupil\u8217\'3fs district of residence or an appropriate public school in Iowa, the pupil attending school outside the state shall be considered a nonresident child for purposes of tuition payments to the receiving district and shall not be treated as a pupil of the district of residence for state school foundation aid purposes under }}}{{\f5\fs18\hyphpar0\qj{section 257.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The whole grade sharing provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 282.10 through 282.12}}}{{\f5\fs18\hyphpar0\qj{ and the open enrollment provisions of }}}{{\f5\fs18\hyphpar0\qj{section 282.18}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to agreements made between districts under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a74274-c1, -c2, 4275; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4274.01, 4274.02, 4275;}}}{ C46, \'a7282.8, 282.9, 282.17; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.8}}}{, }{{\f5\fs18\hyphpar0\qj{282.17}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 89, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 4, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1036, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7275.1}}}{{\f5\fs12\hyphpar0\qj{, 282.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enrollment of person listed on sex offender registry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding sections }}}{{\f5\fs18\hyphpar0\qj{256E.7}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{256F.4}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{275.55A}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{282.18}}}{{\f5\fs18\hyphpar0\qj{, or any other provision to the contrary, prior to knowingly enrolling an individual who is required to register as a sex offender under }}}{{\f5\fs18\hyphpar0\qj{chapter 692A}}}{{\f5\fs18\hyphpar0\qj{, but who is otherwise eligible to enroll in a public school, the board of directors of a school district shall determine the educational placement of the individual. Upon receipt of notice that a student who is enrolled in the district is required to register as a sex offender under }}}{{\f5\fs18\hyphpar0\qj{chapter 692A}}}{{\f5\fs18\hyphpar0\qj{, the board shall determine the educational placement of the student. The tentative agenda for the meeting of the board of directors at which the board will consider such enrollment or educational placement shall specifically state that the board is considering the enrollment or educational placement of an individual who is required to register as a sex offender under }}}{{\f5\fs18\hyphpar0\qj{chapter 692A}}}{{\f5\fs18\hyphpar0\qj{. If the individual is denied enrollment in a school district under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the school district of residence shall provide the individual with educational services in an alternative setting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 692A.121}}}{{\f5\fs18\hyphpar0\qj{, or any other provision of law to the contrary, the county sheriff shall provide to the boards of directors of the school districts located within the county the name of any individual under the age of twenty-one who is required to register as a sex offender under }}}{{\f5\fs18\hyphpar0\qj{chapter 692A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1140, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 119, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 112, \'a717}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7692A.120}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Whole grade sharing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whole grade sharing is a procedure used by school districts whereby all or a substantial portion of the pupils in any grade in two or more school districts share an educational program for all or a substantial portion of a school day under a written agreement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.13}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{280.15}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{282.7, subsection 1 or 3}}}{{\f5\fs18\hyphpar0\qj{. Whole grade sharing may either be one-way or two-way sharing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One-way whole grade sharing occurs when a school district sends pupils to one or more other school districts for instruction and does not receive a substantial number of pupils from those districts in return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two-way whole grade sharing occurs when a school district sends pupils to one or more other school districts for instruction and receives a substantial number of pupils from those school districts in return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A whole grade sharing agreement shall be signed by the boards of the districts involved in the agreement not later than February 1 of the school year preceding the school year for which the agreement is to take effect. The boards of the districts shall negotiate as part of the new or existing agreement the disposition of funding provided under }}}{{\f5\fs18\hyphpar0\qj{chapter 284}}}{{\f5\fs18\hyphpar0\qj{, including the teacher leadership supplement state cost per pupil as provided in }}}{{\f5\fs18\hyphpar0\qj{section 257.9}}}{{\f5\fs18\hyphpar0\qj{, unless all of the districts subject to the agreement are receiving such funding.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 224, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1263, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1181, \'a775}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 88, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1036, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 172, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a738}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.9}}}{{\f5\fs12\hyphpar0\qj{, 256.13}}}{{\f5\fs12\hyphpar0\qj{, 257.11}}}{{\f5\fs12\hyphpar0\qj{, 275.2}}}{{\f5\fs12\hyphpar0\qj{, 280.15}}}{{\f5\fs12\hyphpar0\qj{, 282.7}}}{{\f5\fs12\hyphpar0\qj{, 282.8}}}{{\f5\fs12\hyphpar0\qj{, 285.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Procedure for whole grade sharing agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3faffected pupils\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are those who under the whole grade sharing agreement are attending or scheduled to attend the school district specified in the agreement, other than the district of residence, during the term of the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not less than ninety days prior to signing a whole grade sharing agreement whereby all or a substantial portion of the pupils in a grade in the district will attend school in another district, the board of directors of each school district that is negotiating, extending, or renewing a sharing agreement, shall publicly announce its intent to negotiate a sharing agreement under }}}{{\f5\fs18\hyphpar0\qj{section 21.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. Within thirty days of the board\u8217\'3fs public notice, a petition may be filed with the department of education requesting that a feasibility study be completed. The petition shall be signed by twenty percent of the eligible electors in the district. The director of the department of education may determine that a feasibility study conducted by the board satisfies the request, provided that the study conforms with the criteria contained in }}}{{\f5\fs18\hyphpar0\qj{section 256.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not less than thirty days prior to signing a whole grade sharing agreement whereby all or a substantial portion of the pupils in a grade in the district will attend school in another district, the board of directors of each school district that is a party to a proposed sharing agreement shall hold a public hearing at which the proposed agreement is described, and at which the parent or guardian of an affected pupil and certificated employees of the school district shall have an opportunity to comment on the proposed agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within the thirty-day period prior to the signing of the agreement, the parent or guardian of an affected pupil may request the board of directors to send the pupil to another contiguous school district. The request shall be based upon one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the agreement will not meet the educational program needs of the pupil.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That adequate consideration was not given to geographical factors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall allow or disallow the request prior to the signing of the agreement, or the request shall be deemed granted. If the board disallows the request, the board shall indicate the reasons why the request is disallowed and shall notify the parent or guardian that the decision of the board may be appealed as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board disallows the request of a parent or guardian of an affected pupil, the parent or guardian, not later than March 1, may appeal the sending of that pupil to the school district specified in the agreement, to the state board of education. The basis for the appeal shall be the same as the basis for the request to the board. An appeal shall specify a contiguous school district to which the parent or guardian wishes to send the affected pupil.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the parent or guardian appeals, the standard of review of the appeal is a preponderance of evidence that the parent\u8217\'3fs or guardian\u8217\'3fs hardship outweighs the benefits and integrity of the sharing agreement. The state board may require the district of residence to pay tuition to the contiguous school district specified by the parent or guardian, or may deny the appeal by the parent or guardian. If the state board requires the district of residence to pay tuition to the contiguous school district specified by the parent or guardian, the tuition shall be equal to the tuition established in the sharing agreement. The decision of the state board is binding on the boards of directors of the school districts affected, except that the decision of the state board may be appealed by either party to the district court.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 224, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1263, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 160, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a781}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.9}}}{{\f5\fs12\hyphpar0\qj{, 256.13}}}{{\f5\fs12\hyphpar0\qj{, 257.11}}}{{\f5\fs12\hyphpar0\qj{, 280.15}}}{{\f5\fs12\hyphpar0\qj{, 282.7}}}{{\f5\fs12\hyphpar0\qj{, 282.8}}}{{\f5\fs12\hyphpar0\qj{, 291.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funding of whole grade sharing agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agreement for whole grade sharing shall establish a method for determination of costs, if any, associated with the sharing agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For one-way sharing, the sending district shall pay no less than one-half of the district cost per pupil of the sending district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For two-way sharing, the costs shall be determined by mutual agreement of the boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of pupils participating in a whole grade sharing agreement shall be determined on the date specified in }}}{{\f5\fs18\hyphpar0\qj{section 257.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and on the second Friday of January of each year.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 224, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1036, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.13}}}{{\f5\fs12\hyphpar0\qj{, 257.11}}}{{\f5\fs12\hyphpar0\qj{, 280.15}}}{{\f5\fs12\hyphpar0\qj{, 282.7}}}{{\f5\fs12\hyphpar0\qj{, 282.8}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{282.13 through 282.17}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.18}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Open enrollment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the goal of the general assembly to permit a wide range of educational choices for children enrolled in schools in this state and to maximize ability to use those choices. It is therefore the intent that }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ be construed broadly to maximize parental choice and access to educational opportunities which are not available to children because of where they live.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the school year commencing July 1, 1989, and each succeeding school year, a parent or guardian residing in a school district may enroll the parent\u8217\'3fs or guardian\u8217\'3fs child in a public school in another school district in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By March 1 of the preceding school year for students entering grades one through twelve, or by September 1 of the current school year for students entering kindergarten or for prekindergarten students enrolled in special education programs and included in the school district\u8217\'3fs basic enrollment under }}}{{\f5\fs18\hyphpar0\qj{section 257.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), a parent or guardian shall send notification to the district of residence and the receiving district, on forms prescribed by the department of education, that the parent or guardian intends to enroll the parent\u8217\'3fs or guardian\u8217\'3fs child in a public school in another school district. If a parent or guardian fails to file a notification that the parent or guardian intends to enroll the parent\u8217\'3fs or guardian\u8217\'3fs child in a public school in another district by the deadline specified in this paragraph, the procedures of }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ apply.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of the receiving district shall enroll the pupil in a school in the receiving district for the following school year unless the receiving district has insufficient classroom space for the pupil or unless the receiving district has prohibited the pupil from enrolling pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 14}}}{{\f5\fs18\hyphpar0\qj{. The board of directors of a receiving district may adopt a policy granting the superintendent of the school district authority to approve open enrollment applications. If the request is granted, the board shall transmit a copy of the form to the parent or guardian and the school district of residence within five days after board action, but not later than June 1 of the preceding school year. The parent or guardian may withdraw the request at any time prior to the start of the school year. A denial of a request by the board of a receiving district is not subject to appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every school district shall adopt a policy which defines the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3finsufficient classroom space\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for that district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent of a district subject to court-ordered desegregation may deny a request for transfer under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the superintendent finds that enrollment or release of a pupil will adversely affect the district\u8217\'3fs implementation of the desegregation order, unless the transfer is requested by a pupil whose sibling is already participating in open enrollment to another district, or unless the request for transfer is submitted to the district in a timely manner as required under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ prior to implementation of the desegregation order by the district. If a transfer request would facilitate implementation of a desegregation order, the district shall give priority to granting the request over other requests.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A parent or guardian whose request has been denied because of the district\u8217\'3fs implementation of the desegregation order may appeal the decision of the superintendent to the board of the district in which the request was denied. The board may either uphold or overturn the superintendent\u8217\'3fs decision. A decision of the board to uphold the denial of the request is subject to appeal to the district court in the county in which the primary business office of the district is located. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of a school district subject to court-ordered desegregation shall develop a policy for implementation of open enrollment in the district. The policy shall contain objective criteria for determining when a request would adversely impact the desegregation order and criteria for prioritizing requests that do not have an adverse impact on the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After March 1 of the preceding school year and until the date specified in }}}{{\f5\fs18\hyphpar0\qj{section 257.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the parent or guardian shall send notification to the district of residence and the receiving district, on forms prescribed by the department of education, that good cause exists for failure to meet the March 1 deadline. The board of directors of a receiving school district may adopt a policy granting the superintendent of the school district authority to approve open enrollment applications submitted after the March 1 deadline. The board of the receiving district shall take action to approve the request if good cause exists. If the request is granted, the board shall transmit a copy of the form to the parent or guardian and the school district of residence within five days after board action. A denial of a request by the board of a receiving district is not subject to appeal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a resident district believes that a receiving district is violating }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the resident district may, within fifteen days after board action by the receiving district, submit an appeal to the director of the department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of education, or the director\u8217\'3fs designee, shall attempt to mediate the dispute to reach approval by both boards as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 16}}}{{\f5\fs18\hyphpar0\qj{. If approval is not reached under mediation, the director or the director\u8217\'3fs designee shall conduct a hearing and shall hear testimony from both boards. Within ten days following the hearing, the director shall render a decision upholding or reversing the decision by the board of the receiving district. Within five days of the director\u8217\'3fs decision, the board may appeal the decision of the director to the state board of education under the procedures set forth in }}}{{\f5\fs18\hyphpar0\qj{chapter 290}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Open enrollment applications filed after March 1 of the preceding school year that do not qualify for good cause as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to the approval of the board of the resident district and the board of the receiving district. The parent or guardian shall send notification to the district of residence and the receiving district that the parent or guardian seeks to enroll the parent\u8217\'3fs or guardian\u8217\'3fs child in the receiving district. A decision of either board to deny an application filed under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ involving repeated acts of harassment of the student or serious health condition of the student that the resident district cannot adequately address is subject to appeal under }}}{{\f5\fs18\hyphpar0\qj{section 290.1}}}{{\f5\fs18\hyphpar0\qj{. The state board shall exercise broad discretion to achieve just and equitable results that are in the best interest of the affected child or children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A request under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is for a period of not less than one year. If the request is for more than one year and the parent or guardian desires to have the pupil enroll in a different district, the parent or guardian may petition the current receiving district by March 1 of the previous school year for permission to enroll the pupil in a different district for a period of not less than one year. Upon receipt of such a request, the current receiving district board may act on the request to transfer to the other school district at the next regularly scheduled board meeting after the receipt of the request. The new receiving district shall enroll the pupil in the district unless there is insufficient classroom space in the district or the district is subject to court-ordered desegregation and enrollment of the pupil would adversely affect implementation of the desegregation order. A denial of a request to change district enrollment within the approval period is not subject to appeal. However, a pupil who has been in attendance in another district under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may return to the district of residence and enroll at any time, once the parent or guardian has notified the district of residence and the receiving district in writing of the decision to enroll the pupil in the district of residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pupil participating in open enrollment shall be counted, for state school foundation aid purposes, in the pupil\u8217\'3fs district of residence. A pupil\u8217\'3fs residence, for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, means a residence under }}}{{\f5\fs18\hyphpar0\qj{section 282.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of the district of residence shall pay to the receiving district the sum of the state cost per pupil for the budget year plus the teacher leadership supplement state cost per pupil, the professional development supplement state cost per pupil, and the early intervention supplement state cost per pupil for the budget year as provided in }}}{{\f5\fs18\hyphpar0\qj{section 257.9}}}{{\f5\fs18\hyphpar0\qj{, plus any moneys that would be due to the school district of residence for the pupil as a result of the non-English speaking weighting under }}}{{\f5\fs18\hyphpar0\qj{section 280.4, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, for the budget year multiplied by the state cost per pupil for the budget year. If the pupil participating in open enrollment is also an eligible pupil under }}}{{\f5\fs18\hyphpar0\qj{section 261E.6}}}{{\f5\fs18\hyphpar0\qj{, the receiving district shall pay the tuition reimbursement amount to an eligible postsecondary institution as provided in }}}{{\f5\fs18\hyphpar0\qj{section 261E.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a pupil participates in cocurricular or extracurricular activities in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, the district of residence may deduct up to two hundred dollars per activity, for up to two activities, from the amount calculated in subparagraph (1). For a cocurricular activity, one semester shall equal one activity. Extracurricular activities for which such a resident district may charge up to two hundred dollars per activity for up to two activities under this subparagraph include interscholastic athletics, music, drama, and any other activity with a general fund expenditure exceeding five thousand dollars annually. A pupil may participate in additional extracurricular activities at the discretion of the resident district. The school district of residence may charge the pupil a fee for participation in such cocurricular or extracurricular activities equivalent to the fee charged to and paid in the same manner by other resident pupils.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a pupil participating in open enrollment attends school in the receiving district for less than a full school year, payment from the district of residence to the receiving district shall be prorated on a per diem basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a request filed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is for a child requiring special education under }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{, the request to transfer to the other district shall only be granted if the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The receiving district maintains a special education instructional program which is appropriate to meet the child\u8217\'3fs educational needs and the enrollment of the child in the receiving district\u8217\'3fs program would not cause the size of the class or caseload in that special education instructional program in the receiving district to exceed the maximum class size or caseload established pursuant to rules adopted by the state board of education.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the child would be assigned to a general education class, there is sufficient classroom space for the general education class to which the child would be assigned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For children requiring special education, the board of directors of the district of residence shall pay to the receiving district the actual costs incurred in providing the appropriate special education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For children requiring special education, the receiving district shall complete and provide to the district of residence the documentation necessary to seek Medicaid reimbursement for eligible services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a parent or guardian of a child, who is participating in open enrollment under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, moves to a different school district during the course of either district\u8217\'3fs academic year, the child\u8217\'3fs first district of residence as determined on the date specified in }}}{{\f5\fs18\hyphpar0\qj{section 257.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall be responsible for payment of the cost per pupil plus weightings or special education costs to the receiving school district for the balance of the school year in which the move took place. The new district of residence shall be responsible for the payments during succeeding years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a request to transfer is due to a change in family residence, a change in a child\u8217\'3fs residence from the residence of one parent or guardian to the residence of a different parent or guardian, a change in the state in which the family residence is located, a change in a child\u8217\'3fs parents\u8217\'3f marital status, a guardianship proceeding, placement in foster care, adoption, participation in a foreign exchange program, or participation in a substance use disorder or mental health treatment program, and the child who is the subject of the request is enrolled in any grade from kindergarten through grade twelve or who is a prekindergarten student enrolled in a special education program at the time of the request and is not currently using any provision of open enrollment, the parent or guardian of the child shall have the option to have the child remain in the child\u8217\'3fs original district of residence under open enrollment with no interruption in the child\u8217\'3fs educational program. If a parent or guardian exercises this option, the child\u8217\'3fs new district of residence is not required to pay the amount calculated in }}}{{\f5\fs18\hyphpar0\qj{subsection 7 or 8}}}{{\f5\fs18\hyphpar0\qj{, as applicable, until the start of the first full year of enrollment of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The receiving district shall bill the resident district determined under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ according to the timeline in }}}{{\f5\fs18\hyphpar0\qj{section 282.20, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. Payments shall be made to the receiving district in a timely manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the transfer of a pupil from one district to another results in a transfer from one area education agency to another, the sending district shall forward a copy of the request to the sending district\u8217\'3fs area education agency. The receiving district shall forward a copy of the request to the receiving district\u8217\'3fs area education agency. Any moneys received by the area education agency of the sending district for the pupil who is the subject of the request shall be forwarded to the receiving district\u8217\'3fs area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A district of residence may apply to the school budget review committee if a student was not included in the resident district\u8217\'3fs enrollment count during the fall of the year preceding the student\u8217\'3fs transfer under open enrollment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 285.1}}}{{\f5\fs18\hyphpar0\qj{ relating to transportation of nonresident pupils, the parent or guardian is responsible for transporting the pupil without reimbursement to and from a point on a regular school bus route of the receiving district. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa point on a regular school bus route of the receiving district\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any school bus stop on the regular school bus route of the receiving district that existed prior to road construction that necessitates a change in the regular school bus route, whether or not the change in the regular school bus route resulting from the road construction necessitates sending school vehicles from the receiving district into the district of residence in order to safely, economically, or efficiently transport students to or from the preexisting point.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A receiving district with a total enrollment of less than two thousand students may send school vehicles not more than two miles into the district of residence of the pupil using the open enrollment option under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, for the purpose of transporting the pupil to and from school in the receiving district, if the pupil\u8217\'3fs primary residence is closer to the attendance center the pupil attends in the receiving district than the residence is to the attendance center the pupil would be assigned in the sending district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding subparagraph (1), a receiving district with a total enrollment of greater than or equal to two thousand students may send school vehicles two miles or more into the district of residence of the pupil using the open enrollment option under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, for the purpose of transporting the pupil to and from school in the receiving district, regardless of the distance between the pupil\u8217\'3fs primary residence and the attendance center the pupil attends in the receiving district or the attendance center the pupil would be assigned in the sending district, if all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total enrollment of the pupil\u8217\'3fs district of residence is less than two thousand students.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pupil\u8217\'3fs district of residence is contiguous to the receiving district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pupil\u8217\'3fs district of residence has sent school vehicles into the receiving district pursuant to subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding subparagraph (1) or (2), a receiving district may send school vehicles into the district of residence of the pupil using the open enrollment option under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, for the purpose of transporting the pupil to and from school in the receiving district, if the boards of both the sending and receiving districts agree to this arrangement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the pupil meets the economic eligibility requirements established by the department and state board of education, the sending district is responsible for providing transportation or paying the pro rata cost of the transportation to a parent or guardian for transporting the pupil to and from a point on a regular school bus route of a contiguous receiving district unless the cost of providing transportation or the pro rata cost of the transportation to a parent or guardian exceeds the average transportation cost per pupil transported for the previous school year in the district. The economic eligibility requirements established by the department of education and state board of education shall minimally include those pupils with household incomes of two hundred percent or less of the federal poverty level as defined by the most recently revised poverty income guidelines published by the United States department of health and human services. If the cost exceeds the average transportation cost per pupil transported for the previous school year, the sending district shall only be responsible for that average per pupil amount. A sending district which provides transportation for a pupil to a contiguous receiving district under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may withhold, from the district cost per pupil amount that is to be paid to the receiving district, an amount which represents the average or pro rata cost per pupil for transportation, whichever is less.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sending district shall not be responsible for paying a parent or guardian pursuant to subparagraph (1) if the pupil is transported by the receiving district to and from school in the receiving district pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pupil who participates in open enrollment for purposes of attending a grade in grades nine through twelve in a school district other than the district of residence is ineligible to participate in varsity interscholastic athletic contests and athletic competitions during the pupil\u8217\'3fs first ninety school days of enrollment in the district. However, a pupil may participate immediately in a varsity interscholastic sport under any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the pupil is entering grade nine for the first time and did not participate in an interscholastic athletic competition for another school or school district during the summer immediately following eighth grade.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the district of residence and the other school district jointly participate in the sport.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the sport in which the pupil wishes to participate is not offered in the district of residence.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the pupil chooses to use open enrollment to attend school in another school district because the district in which the student previously attended school was dissolved and merged with one or more contiguous school districts under }}}{{\f5\fs18\hyphpar0\qj{section 256.11, subsection 12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the pupil participates in open enrollment because the pupil\u8217\'3fs district of residence has entered into a whole grade sharing agreement with another district for the pupil\u8217\'3fs grade.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the parent or guardian of the pupil participating in open enrollment is an active member of the armed forces and resides in permanent housing on government property provided by a branch of the armed services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the district of residence determines that the pupil was previously subject to a founded incident of harassment or bullying as defined in }}}{{\f5\fs18\hyphpar0\qj{section 280.28}}}{{\f5\fs18\hyphpar0\qj{ while attending school in the district of residence.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the pupil participates in open enrollment because of circumstances that meet the definition of good cause. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fgood cause\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a change in a child\u8217\'3fs residence due to a change in family residence, a change in a child\u8217\'3fs residence from the residence of one parent or guardian to the residence of a different parent or guardian, a change in the state in which the family residence is located, a change in a child\u8217\'3fs parents\u8217\'3f marital status, a guardianship or custody proceeding, placement in foster care, adoption, participation in a foreign exchange program, initial placement of a prekindergarten student in a special education program requiring specially designed instruction, or participation in a substance use disorder or mental health treatment program, a change in the status of a child\u8217\'3fs resident district such as removal of accreditation by the state board, surrender of accreditation, or permanent closure of a nonpublic school, revocation of a charter school contract as provided in }}}{{\f5\fs18\hyphpar0\qj{section 256E.10}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{256F.8}}}{{\f5\fs18\hyphpar0\qj{, the failure of negotiations for a whole grade sharing, reorganization, dissolution agreement, or the rejection of a current whole grade sharing agreement, or reorganization plan.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board of directors or superintendent of the district of residence issues or implements a decision that results in the discontinuance or suspension of varsity interscholastic sports activities in the district of residence.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board of directors of the district of residence and the board of directors of the receiving district both agree to waive the ineligibility period.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For open enrollment applications approved for the school year beginning July 1, 2021, if the pupil\u8217\'3fs district of residence had a voluntary diversity plan in effect on January 1, 2021, and applicable to the school year beginning July 1, 2021.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pupil who has paid tuition and attended school, or has attended school pursuant to a mutual agreement between the two districts, in a district other than the pupil\u8217\'3fs district of residence for at least one school year is also eligible to participate immediately in interscholastic athletic contests and athletic competitions under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, but only as a member of a team from the district that pupil had attended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a pupil is declared ineligible for interscholastic athletic contests and athletic competitions in the pupil\u8217\'3fs district of residence due to the pupil\u8217\'3fs academic performance, upon participating in open enrollment, in addition to any other period of ineligibility under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the pupil shall be ineligible in the receiving district for the remaining period of ineligibility declared by the district of residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool days of enrollment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include enrollment in summer school. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fvarsity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 256.46, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pupil participating in open enrollment for purposes of receiving educational instruction and course content primarily over the internet in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 256.7, subsection 32}}}{{\f5\fs18\hyphpar0\qj{, may participate in any cocurricular or extracurricular activities offered to children in the pupil\u8217\'3fs grade or group and sponsored by the district of residence under the same conditions and requirements as the pupils enrolled in the district of residence. The pupil may participate in not more than two cocurricular or extracurricular activities during a school year unless the resident district approves the student\u8217\'3fs participation in additional activities. The student shall comply with the eligibility, conduct, and other requirements relating to the activity that are established by the district of residence for any student who applies to participate or who is participating in the activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a pupil, for whom a request to transfer has been filed with a district, has been suspended or expelled in the district, the pupil shall not be permitted to transfer until the pupil has been reinstated in the sending district. Once the pupil has been reinstated, however, the pupil shall be permitted to transfer in the same manner as if the pupil had not been suspended or expelled by the sending district. If a pupil, for whom a request to transfer has been filed with a district, is expelled in the district, the pupil shall be permitted to transfer to a receiving district under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the pupil applies for and is reinstated in the sending district. However, if the pupil applies for reinstatement but is not reinstated in the sending district, the receiving district may deny the request to transfer. The decision of the receiving district is not subject to appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a pupil participating in open enrollment is truant as defined in }}}{{\f5\fs18\hyphpar0\qj{section 299.8}}}{{\f5\fs18\hyphpar0\qj{, the board of directors of the receiving district may prohibit the pupil from remaining enrolled in the receiving district, and from enrolling in the receiving district in the future, after providing notice and an opportunity to be heard to the pupil\u8217\'3fs parent or guardian. A receiving district shall send notification of the receiving district\u8217\'3fs decision to prohibit the pupil from remaining enrolled in the receiving district pursuant to this paragraph to the pupil\u8217\'3fs parent or guardian and to the pupil\u8217\'3fs sending district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sending district shall enroll the pupil who is prohibited from remaining enrolled in the receiving district pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit the pupil\u8217\'3fs parent or guardian from filing a request to transfer pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subsequent to the receiving district\u8217\'3fs decision to prohibit the pupil from remaining enrolled in the receiving district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a request under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is for transfer to a laboratory school, as described in }}}{{\f5\fs18\hyphpar0\qj{chapter 265}}}{{\f5\fs18\hyphpar0\qj{, the student, who is the subject of the request, shall not be included in the basic enrollment of the student\u8217\'3fs district of residence, and the laboratory school shall report the enrollment of the student directly to the department of education, unless the number of students from the district attending the laboratory school during the current school year, as a result of open enrollment under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, exceeds the number of students enrolled in the laboratory school from that district during the 1989-1990 school year. If the number of students enrolled in the laboratory school from a district during the current year exceeds the number of students enrolled from that district during the 1989-1990 school year, those students who represent the difference between the current and the 1988-1989 school year enrollment figures shall be included in the basic enrollment of the students\u8217\'3f districts of residence and the districts shall retain any moneys received as a result of the inclusion of the student in the district enrollment. The total number of students enrolled at a laboratory school during a school year shall not exceed six hundred seventy students. The regents institution operating the laboratory school and the board of directors of the school district in the community in which the regents institution is located shall develop a student transfer policy designed to protect and promote the quality and integrity of the teacher education program at the laboratory school, the viability of the education program of the local school district in which the regents institution is located, and to indicate the order in which and reasons why requests to transfer to a laboratory school shall be considered. A laboratory school may deny a request for transfer under the policy. A denial of a request to transfer under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is not subject to appeal under }}}{{\f5\fs18\hyphpar0\qj{section 290.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An application for open enrollment may be granted at any time with approval of the resident and receiving districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The deadlines specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not apply to a child whose parent or guardian is filing a notification that the parent or guardian intends to open enroll the child in a public school in another school district for purposes of receiving full-time instruction under }}}{{\f5\fs18\hyphpar0\qj{section 256.43}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of education shall recommend rules to the state board of education for the orderly implementation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The state board shall adopt rules as needed for the implementation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1113, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 12, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 319, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1182, \'a71, 5}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 202, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1135, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 149, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1091, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1131, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1175, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1157, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 23, \'a731, 32}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1124, \'a713, 16}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1129, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1140, \'a717 \u8211\'3f 23}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 79, \'a75, 7, 8}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 180, \'a735, 36, 72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 79, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 179, \'a793 \u8211\'3f 95}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a741 \u8211\'3f 43}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1071, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1181, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 18, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a7104}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 177, \'a754, 57}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a739, 40}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 121, \'a757, 75}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1036, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1079, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1119, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a7103}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1022, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1045, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 50, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 90, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 112, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 139, \'a713 \u8211\'3f 19, 21, 22}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1153, \'a733 \u8211\'3f 38, 41}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71045, 1046}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a7109}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1107, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1152, \'a723 \u8211\'3f 28, 30}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1168, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a785.20}}}{{\f5\fs12\hyphpar0\qj{, 85.61}}}{{\f5\fs12\hyphpar0\qj{, 256.43}}}{{\f5\fs12\hyphpar0\qj{, 256.46}}}{{\f5\fs12\hyphpar0\qj{, 256F.4}}}{{\f5\fs12\hyphpar0\qj{, 256F.9}}}{{\f5\fs12\hyphpar0\qj{, 257.6}}}{{\f5\fs12\hyphpar0\qj{, 257.31}}}{{\f5\fs12\hyphpar0\qj{, 261E.7}}}{{\f5\fs12\hyphpar0\qj{, 275.15}}}{{\f5\fs12\hyphpar0\qj{, 282.8}}}{{\f5\fs12\hyphpar0\qj{, 282.9}}}{{\f5\fs12\hyphpar0\qj{, 284.13}}}{{\f5\fs12\hyphpar0\qj{, 290.1}}}{{\f5\fs12\hyphpar0\qj{, 321.178}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Extracurricular eligibility; see also }{{\f5\fs12\hyphpar0\qj{\'a7256.46}}}{ and }{{\f5\fs12\hyphpar0\qj{chapter 261I}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendments to section by }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 11522024 Acts, ch 1152}}}{, apply to applications and notifications related to open enrollment submitted on or after July 1, 2024; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1152.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1152, \'a730}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.19}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child living in substance use disorder or foster care placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who is living in a facility that provides residential treatment as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffacility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is defined in }}}{{\f5\fs18\hyphpar0\qj{section 125.2}}}{{\f5\fs18\hyphpar0\qj{, which is located in a school district other than the school district in which the child resided before entering the facility may enroll in and attend an accredited school in the school district in which the child is living.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who is living in a facility, or with an approved kinship caregiver, as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 237.1}}}{{\f5\fs18\hyphpar0\qj{, or in an unlicensed relative foster care placement, shall remain enrolled in and attend an accredited school in the school district in which the child resided and is enrolled at the time of placement, unless it is determined by the juvenile court or the public or private agency of this state that has responsibility for the child\u8217\'3fs placement that remaining in such school is not in the best interests of the child. If such a determination is made, the child may attend an accredited school located in the school district in which the child is living and not in the school district in which the child resided prior to receiving foster care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The instructional costs for students who do not require special education shall be paid as provided in }}}{{\f5\fs18\hyphpar0\qj{section 282.31, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or for students who require special education shall be paid as provided in }}}{{\f5\fs18\hyphpar0\qj{section 282.31, subsection 2 or 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, \'a74283; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4275.1, 4283, 4283.01;}}}{ C46, 50, 54, 58, 62, \'a7282.18, 282.22, 282.23; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.18}}}{, }{{\f5\fs18\hyphpar0\qj{282.22}}}{, }{{\f5\fs18\hyphpar0\qj{282.23}}}{, }{{\f5\fs18\hyphpar0\qj{282.25}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 90, \'a71}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1244, \'a734}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71485}}}{; }{{\f5\fs18\hyphpar0\qj{87 Acts, ch 233, \'a7480}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 319, \'a774}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 120, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71047}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 135, \'a732}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7282.31}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.20}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tuition fees \u8212\'3f payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The school corporation in which the student resides shall pay from the general fund to the secretary of the corporation in which the student is permitted to enroll, a tuition fee as prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 282.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any school district to rebate to any pupils or their parents, directly or indirectly, any portion of the tuition collected or to be collected or to authorize or permit such pupils to receive at the expense of the district, directly or indirectly, any special compensation, benefit, privilege, or other thing of value that is not and cannot legally be made available to all other pupils enrolled in its schools. Any superintendent or board members responsible for this unlawful act shall each be personally liable for payment of a fine in an amount not to exceed one hundred dollars. Action to recover the penalty or action to enjoin the unlawful act may be instituted by the board of any school district or by a taxpayer in any school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before February 15 and July 15 of each year the secretary of the creditor district shall deliver to the secretary of the debtor district an itemized statement of such tuition fees.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72733-1a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4277;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 31, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 88, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a755}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256E.8}}}{{\f5\fs12\hyphpar0\qj{, 282.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.21}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Collection of tuition fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If payment is not made, the board of the creditor corporation shall file with the auditor of the county of the pupil\u8217\'3fs residence a statement certified by its president specifying the amount due for tuition, and the time for which the same is claimed. The auditor shall transmit to the county treasurer an order directing the county treasurer to transfer the amount of such account from the funds of the debtor corporation to the creditor corporation, and the county treasurer shall pay the same accordingly.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72733-1a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4278;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.21}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7275.26}}}{{\f5\fs12\hyphpar0\qj{, 331.502}}}{{\f5\fs12\hyphpar0\qj{, 331.552}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{282.22 and 282.23}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.24}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tuition fees established }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ itemized statement of appraised value of school buildings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum tuition fee that may be charged for elementary and secondary school students residing within another school district or corporation except students attending school in another district under }}}{{\f5\fs18\hyphpar0\qj{section 282.7, subsection 1 or 3}}}{{\f5\fs18\hyphpar0\qj{, is the district cost per pupil of the receiving district as computed in }}}{{\f5\fs18\hyphpar0\qj{section 257.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A school corporation which owns facilities used as attendance centers for students shall maintain an itemized statement of the appraised value of all buildings owned by the school corporation. The appraisal shall be updated at least once every five years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prevent the corporation or district in which the student resides from paying a tuition in excess of the maximum computed tuition rates, if the actual per pupil cost of the preceding year so warrants, but the receiving district or corporation shall not demand more than the maximum rate.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a74233-e3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4233.3;}}}{ C46, \'a7279.18; C50, 54, 58, 62, 66, 71, 73, 75, \'a7279.18, 282.24; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.24}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 31, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 212, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 224, \'a763}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1263, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 135, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 54, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a782}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1036, \'a711, 12}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.11}}}{{\f5\fs12\hyphpar0\qj{, 257.41}}}{{\f5\fs12\hyphpar0\qj{, 275.55A}}}{{\f5\fs12\hyphpar0\qj{, 282.1}}}{{\f5\fs12\hyphpar0\qj{, 282.8}}}{{\f5\fs12\hyphpar0\qj{, 282.20}}}{{\f5\fs12\hyphpar0\qj{, 282.27}}}{{\f5\fs12\hyphpar0\qj{, 291.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.25}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.26}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{High school students attending advanced courses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of any community college may, by mutual agreement with any college or university, permit any specially qualified high school student to attend advanced courses of academic instruction at the college or university.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board of regents and the state board of education may by rule permit such students to attend any institution of higher learning under their jurisdiction. Credit earned in any such course at a college or university may be applied toward credit for high school graduation. Public school funds shall not be expended for payment of tuition or other costs for such attendance at a college or university, unless the payment is expressly permitted or required by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{ shall also apply to colleges and universities in adjacent states when the institutions are located nearer to the homes or schools of the school district than the closest college or university within the state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7282.26}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1233, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1253, \'a789}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a7105}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.27}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Children living in psychiatric hospitals or institutions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The public school district in which a psychiatric unit of a hospital licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{{\f5\fs18\hyphpar0\qj{ or a psychiatric medical institution for children licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 135H}}}{{\f5\fs18\hyphpar0\qj{, which is not operated by the state, is located shall be responsible for the provision of educational services to children residing in the unit or institution. Children residing in the unit or institution shall be included in the basic enrollment of their districts of residence, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 282.31, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of each district of residence shall pay to the school district in which such psychiatric unit or institution is located, for the provision of educational services to the child, a portion of the tuition rate prescribed by }}}{{\f5\fs18\hyphpar0\qj{section 282.24}}}{{\f5\fs18\hyphpar0\qj{ for students residing within another school district for each of such children who does not require special education, based upon the proportion that the time each child is provided educational services while in such unit or institution is to the total time for which the child is provided educational services during a normal school year. The actual special education instructional costs incurred for a child who resides in the unit or institution shall be paid by the district of residence of the child to the district in which the unit or institution is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 282.24}}}{{\f5\fs18\hyphpar0\qj{, if a child for whom all of the following applies is placed in the psychiatric unit or institution, the district of residence may use amounts received as supplementary weighting pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 257.11, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, to pay the instructional costs necessary to address the child\u8217\'3fs behavior during instructional time when those services are not otherwise provided to students who do not require special education and the costs exceed the costs of instruction of pupils in a regular curriculum and the costs exceed the maximum tuition rate prescribed by }}}{{\f5\fs18\hyphpar0\qj{section 282.24}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child does not require special education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is not placed by the department of health and human services or a court in a day program treatment program in such psychiatric unit or institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of the district of residence has determined that the child is likely to inflict self-harm or likely to harm another student.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 282.24}}}{{\f5\fs18\hyphpar0\qj{, if a child for whom all of the following applies is placed in the psychiatric unit or institution, the district of residence may use the funding for programs for returning dropouts and dropout prevention calculated pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 257.41}}}{{\f5\fs18\hyphpar0\qj{, to pay the instructional costs necessary to address the child\u8217\'3fs behavior during instructional time when those services are not otherwise provided to students who do not require special education and the costs exceed the costs of instruction of pupils in a regular curriculum, the costs exceed the maximum tuition rate prescribed by }}}{{\f5\fs18\hyphpar0\qj{section 282.24}}}{{\f5\fs18\hyphpar0\qj{, and the child meets the definition of a returning dropout or potential dropout in }}}{{\f5\fs18\hyphpar0\qj{section 257.39}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child does not require special education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The child is not placed by the department of health and human services or a court in a day program treatment program in such psychiatric unit or institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of the district of residence has determined that the child is likely to inflict self-harm or likely to harm another student.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 282.31, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), if a child placed in the psychiatric unit or institution was not enrolled in the educational program of the district of residence of the child on October 1 of the current school year, the district of residence may include that student in a claim submitted to the department of education pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 282.31, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1230, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 22, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71048, 1049}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.28}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Children at Eldora and Toledo.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0178.pdf" }{\fldrslt \cf5 \f5 \fs18{{2003 Acts, ch 178, \'a759}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.29}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Children placed by district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding }{{\f5\fs18\hyphpar0\qj{section 282.31, subsection 1}}}{, a child who has been identified as requiring special education, who has been placed in a facility, home, or other placement by the district court, and for whom parental rights have been terminated by the district court, shall be provided special education programs and services on the same basis as the programs and services are provided for children requiring special education who are residents of the school district in which the child has been placed. The special education instructional costs shall be paid as provided in }{{\f5\fs18\hyphpar0\qj{section 282.31, subsection 2 or 3}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 233, \'a7482}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 120, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.7}}}{{\f5\fs12\hyphpar0\qj{, 282.31}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.30}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An area education agency shall provide or make provision for an appropriate educational program for each child living in the following types of facilities located within its boundaries:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An approved or licensed shelter care home, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.2, subsection 40}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An approved juvenile detention home, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 232.2, subsection 37}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency shall provide the educational program by any one of, but not limited to, the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing for the enrollment of the child in the district of residence of the child, subject to the approval of the district in which the child is living.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cooperating with the district of residence of the child and obtaining the course of study and textbooks of the child for use in the special facility into which the child has been placed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing for the enrollment of the child in the district in which the child is living, subject to the approval of the district in which the child is living.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An area education agency shall not provide educational services to a facility specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ unless the facility makes a request for educational services to the area education agency by either of the following dates:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{December 1 of the school year prior to the beginning of the school year for which the services are being requested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ninety days prior to the beginning of the time for which the services are being requested if the facility is a newly established facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The area education agency where the child is living, the school district of residence, the other appropriate area education agency or agencies, and other appropriate agencies involved with the care or placement of the child shall cooperate with the school district where the child is living in sharing educational information, textbooks, curriculum, assignments, and materials in order to plan and to provide for the appropriate education of the child living in such facility specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 233, \'a7483}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1121, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.7}}}{{\f5\fs12\hyphpar0\qj{, 282.31}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; internal reference changes applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.31}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funding for special programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who lives in a facility pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 282.30, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and who is not enrolled in the educational program of the district of residence of the child, shall receive appropriate educational services. The area education agency shall submit a proposed program and budget to the department of education by January 1 for the next succeeding school year. The department of education shall review and approve or modify the program and proposed budget and shall notify the department of administrative services and the area education agency of its action by February 1. The department of administrative services shall pay the approved budget amount for an area education agency in monthly installments beginning September 15 and ending June 15 of the next succeeding school year. The installments shall be as nearly equal as possible as determined by the department of management, taking into consideration the relative budget and cash position of the state\u8217\'3fs resources. The department of administrative services shall transfer the approved budget amount for an area education agency from the moneys appropriated under }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{ and make the payment to the area education agency. The area education agency shall submit an accounting for the actual cost of the program to the department of education by August 1 of the following school year. The department shall review and approve or modify all expenditures incurred in compliance with the guidelines pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.7, subsection 10}}}{{\f5\fs18\hyphpar0\qj{, and shall notify the department of administrative services of the approved accounting amount. The approved accounting amount shall be compared with any amounts paid by the department of administrative services to the area education agency and any differences added to or subtracted from the October payment made under this paragraph for the next school year. Any amount paid by the department of administrative services shall be deducted monthly from the state foundation aid paid under }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{ to all school districts in the state during the subsequent fiscal year. The portion of the total amount of the approved budget that shall be deducted from the state aid of a school district shall be the same as the ratio that the budget enrollment for the budget year of the school district bears to the total budget enrollment in the state for that budget year in which the deduction is made.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who lives in a facility or other placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 282.19}}}{{\f5\fs18\hyphpar0\qj{, and who does not require special education and who is enrolled in the educational program of the district of residence at the time the child is placed, shall be included in the basic enrollment of the school district in which the child is enrolled. A child who lives in a facility or other placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 282.19}}}{{\f5\fs18\hyphpar0\qj{, and who does not require special education and who is not enrolled in the educational program of the district of residence of the child, shall be included in the basic enrollment of the school district in which the facility or other placement is located.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, on June 30 of a school year, if the board of directors of a school district determines that the number of days for which a school district generated funding for children under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ who were counted in the basic enrollment of the school district in that school year in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 257.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, is less than the sum of the number of days enrolled for all children enrolled in the school district under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ during the school year, the secretary of the school district may submit a claim to the department of education by August 1 following the school year for an amount equal to the district cost per pupil of the district for the previous school year multiplied by the quotient of the excess number of enrolled days for children under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ divided by the number of days in the district\u8217\'3fs board-approved calendar for the previous year. The amount of the claim shall be paid by the department of administrative services to the school district by October 1. The department of administrative services shall transfer the total amount of the approved claim of a school district from the moneys appropriated under }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{ and the amount paid shall be deducted monthly from the state foundation aid paid to all school districts in the state during the remainder of the subsequent fiscal year in the manner provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The actual special education instructional costs incurred for a child who lives in a facility or other placement pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 282.19}}}{{\f5\fs18\hyphpar0\qj{ or for a child who is placed in a facility or home pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 282.29}}}{{\f5\fs18\hyphpar0\qj{, who requires special education and who is not enrolled in the educational program of the district of residence of the child but who receives an educational program from the district in which the facility, home, or other placement is located, shall be paid by the district of residence of the child to the district in which the facility, home, or other placement is located, and the costs shall include the cost of transportation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child shall not be denied special education programs and services because of a dispute over the determination of district of residence of the child. The director of the department of education shall determine the district of residence when a dispute arises regarding the determination of the district of residence for a child who requires special education pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The actual special education instructional costs, including transportation, for a child who requires special education shall be paid by the department of administrative services to the school district in which the facility or home is located, only when a district of residence cannot be determined, and the child was not included in the weighted enrollment of any district pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256B.9}}}{{\f5\fs18\hyphpar0\qj{, and the payment pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, was not made by any district. The district shall submit a proposed program and budget to the department of education by January 1 for the next succeeding school year. The department of education shall review and approve or modify the program and proposed budget and shall notify the district by February 1. The district shall submit a claim by August 1 following the school year for the actual cost of the program. The department shall review and approve or modify the claim and shall notify the department of administrative services of the approved claim amount by September 1. The total amount of the approved claim shall be paid by the department of administrative services to the school district by October 1. The total amount paid by the department of administrative services shall be deducted monthly from the state foundation aid paid under }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{ to all school districts in the state during the subsequent fiscal year. The portion of the total amount of the approved claims that shall be deducted from the state aid of a school district shall be the same as the ratio that the budget enrollment for the budget year of the school district bears to the total budget enrollment in the state for the budget year in which the deduction is made. The department of administrative services shall transfer the total amount of the approved claims from moneys appropriated under }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{ for payment to the school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdistrict of residence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the school district in which the parent or legal guardian of the child resides or the district in which the district court is located if the district court is the guardian of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Programs may be provided during the summer and funded under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the school district or area education agency determines a valid educational reason to do so.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 233, \'a7484}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1284, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1272, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 214, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1152, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 22, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 120, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 60, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.7}}}{{\f5\fs12\hyphpar0\qj{, 282.19}}}{{\f5\fs12\hyphpar0\qj{, 282.27}}}{{\f5\fs12\hyphpar0\qj{, 282.29}}}{{\f5\fs12\hyphpar0\qj{, 282.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.32}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An area education agency or local school district may appeal a decision made pursuant to }{{\f5\fs18\hyphpar0\qj{section 282.31}}}{ to the state board of education. The decision of the state board is final.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 233, \'a7485}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 178, \'a757}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.33}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funding for children residing in state mental health institutes or institutions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child who resides in an institution for children under the jurisdiction of the director of health and human services referred to in }}}{{\f5\fs18\hyphpar0\qj{section 218.1, subsection 3, 4, or 5}}}{{\f5\fs18\hyphpar0\qj{, and who is not enrolled in the educational program of the district of residence of the child, shall receive appropriate educational services. The institution in which the child resides shall submit a proposed program and budget based on the average daily attendance of the children residing in the institution to the department of education and the department of health and human services by January 1 for the next succeeding school year. The department of education shall review and approve or modify the proposed program and budget and shall notify the department of administrative services of its action by February 1. The department of administrative services shall pay the approved budget amount to the department of health and human services in monthly installments beginning September 15 and ending June 15 of the next succeeding school year. The installments shall be as nearly equal as possible as determined by the department of administrative services, taking into consideration the relative budget and cash position of the state\u8217\'3fs resources. The department of administrative services shall pay the approved budget amount for the department of health and human services from the moneys appropriated under }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{ and the department of health and human services shall distribute the payment to the institution. The institution shall submit an accounting for the actual cost of the program to the department of education by August 1 of the following school year. The department shall review and approve or modify all expenditures incurred in compliance with the guidelines adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 256.7, subsection 10}}}{{\f5\fs18\hyphpar0\qj{, and shall notify the department of administrative services of the approved accounting amount. The approved accounting amount shall be compared with any amounts paid by the department of administrative services to the department of health and human services and any differences added to or subtracted from the October payment made under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for the next school year. Any amount paid by the department of administrative services shall be deducted monthly from the state foundation aid paid under }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{ to all school districts in the state during the subsequent fiscal year. The portion of the total amount of the approved budget that shall be deducted from the state aid of a school district shall be the same as the ratio that the budget enrollment for the budget year of the school district bears to the total budget enrollment in the state for that budget year in which the deduction is made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Programs may be provided during the summer and funded under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the institution determines a valid educational reason to do so and the department of education approves the program in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71050}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7256.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.34}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Educational programs for children\u8217\'3fs residential facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A children\u8217\'3fs residential facility operating under a certificate of approval issued under }}}{{\f5\fs18\hyphpar0\qj{chapter 237C}}}{{\f5\fs18\hyphpar0\qj{ shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide an educational program and appropriate education services to children residing in the children\u8217\'3fs residential facility by contracting with the school district in which the children\u8217\'3fs residential facility is located, contracting with an accredited nonpublic school, or becoming accredited as a nonpublic school through the standards and accreditation process described in }}}{{\f5\fs18\hyphpar0\qj{section 256.11}}}{{\f5\fs18\hyphpar0\qj{ and adopted by rule by the state board of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Display prominently in all of its major publications and on its internet site a notice accurately describing the educational program and educational services provided by the children\u8217\'3fs residential facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Include in any promotional, advertising, or marketing materials regarding the children\u8217\'3fs residential facility available in print, broadcast, or via the internet or by any other means all fees charged by the children\u8217\'3fs residential facility for the services offered or provided by the children\u8217\'3fs residential facility and its refund policy for the return of refundable portions of any fees. This paragraph shall not apply to sponsorship by a children\u8217\'3fs residential facility of public radio or public television broadcasts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state board of education shall adopt by rule pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ standards for the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Educational programs and appropriate educational services provided under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts between children\u8217\'3fs residential facilities and school districts or accredited nonpublic schools.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notices displayed in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education shall comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 237C.4, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, regarding standards, rules, and modifications, and the responsibilities set forth for publication, notification, and receipt and maintenance of information filed with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract that fails to comply with any of the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or with standards adopted by the state board of education under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, is void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules adopted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not regulate religious education curricula at children\u8217\'3fs residential facilities.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1114, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7237C.4}}}{{\f5\fs12\hyphpar0\qj{, 237C.6}}}{{\f5\fs12\hyphpar0\qj{, 237C.9}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; internal reference change applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{282.35}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Children requiring special education }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ out-of-state placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who is under the age of eighteen years, or an individual who is under the age of twenty-one and is a full-time student, to whom all of the following criteria apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual is eligible for health care benefits under }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual\u8217\'3fs health care coordination and intervention team determines, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 249A.4A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), that the placement of the individual in an out-of-state facility, or placement of the individual with an out-of-state provider, is necessary for the individual to realize the full benefits of }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of health and human services certifies that the placement of the individual in an out-of-state facility, or placement of the individual with an out-of-state provider, is necessary to prevent the filing of a petition under }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{ related to the individual.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of education determines that the placement of the individual in an out-of-state facility, or placement of the individual with an out-of-state provider, would provide to the individual the education required under }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ and the rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual is and remains a resident of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDistrict of residence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the school district in which the parent or legal guardian of the child resides or the district in which the district court is located if the district court is the guardian of the child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 282.1, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child\u8217\'3fs district of residence may place the child in an out-of-state facility or with an out-of-state provider for purposes of providing the child with the education required under }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{, subject to the terms of an agreement between the child\u8217\'3fs district of residence and the facility or provider. The agreement shall satisfy all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The agreement must require the facility or provider to provide periodic invoices to the child\u8217\'3fs district of residence that describes the services provided to the child and the cost associated with such services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The agreement must condition the child\u8217\'3fs district of residence\u8217\'3fs payment of the invoice described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ upon the facility or provider providing to the child the education required under }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{ and the rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 256B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A child\u8217\'3fs district of residence is not financially responsible for the services provided by an out-of-state facility or an out-of-state provider to a child unless the out-of-state facility or out-of-state provider provides notice to the child\u8217\'3fs district of residence that the child may be subject to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the child\u8217\'3fs district of residence enters into an agreement with the out-of-state facility or out-of-state provider that satisfies the requirements established in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By August 1 following the school year in which the out-of-state facility or out-of-state provider provided services to a child pursuant to an agreement entered into under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the child\u8217\'3fs district of residence may submit an accounting to the department of education that describes the cost of the services provided by the facility or provider during such school year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By August 15 following the school year in which the out-of-state facility or out-of-state provider provided services to a child pursuant to an agreement entered into under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the department of education shall review and either approve or modify the accounting submitted pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and make payment to the child\u8217\'3fs district of residence toward the school year in which the cost of the services was incurred. The payment amount is the difference between the amount of the actual costs as reflected in the district of residence\u8217\'3fs accounting less the amount generated by the weighting for the provision of services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any amounts paid by the department of education to school districts in this state pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be deducted on a monthly basis from the state foundation aid paid under }}}{{\f5\fs18\hyphpar0\qj{section 257.16}}}{{\f5\fs18\hyphpar0\qj{ to all school districts in the state in the school year following the school year in which the services were provided. The portion of the total amount paid by the department of education to a district that shall be deducted from the state foundation aid paid to the district shall be the same as the ratio that the budget enrollment for the budget year of the district bears to the total budget enrollment in the state for that budget year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education shall promptly and summarily resolve any disputes between school districts related to the financial responsibility of such school districts under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 142, \'a77}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}}