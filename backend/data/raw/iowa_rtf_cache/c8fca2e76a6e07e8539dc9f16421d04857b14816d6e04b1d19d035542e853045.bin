18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fprior conviction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a plea of guilty, deferred judgment, deferred or suspended sentence, or adjudication of delinquency, regardless of whether a prior conviction occurred before, on, or after March 31, 2000.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsexually violent offense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 229A.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1082, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 23, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1030, \'a71, 2, 4}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 17, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1139, \'a723, 27}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a768, 78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{901A.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enhanced sentencing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a sexually predatory offense which is a serious or aggravated misdemeanor, who has a prior conviction for a sexually predatory offense, shall be sentenced to and shall serve twice the maximum period of incarceration for the offense, notwithstanding any other provision of the Code to the contrary, prior to being eligible for parole or work release. A person sentenced under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not have the person\u8217\'3fs sentence reduced under }}}{{\f5\fs18\hyphpar0\qj{chapter 903A}}}{{\f5\fs18\hyphpar0\qj{ or otherwise by more than fifteen percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of a sexually predatory offense which is a serious or aggravated misdemeanor, who has two or more prior convictions for sexually predatory offenses, shall be sentenced to and shall serve a period of incarceration of ten years, notwithstanding any other provision of the Code to the contrary. A person sentenced under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not have the person\u8217\'3fs sentence reduced under }}}{{\f5\fs18\hyphpar0\qj{chapter 903A}}}{{\f5\fs18\hyphpar0\qj{ or otherwise by more than fifteen percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, a person convicted of a sexually predatory offense which is a felony, who has a prior conviction for a sexually predatory offense, shall be sentenced to and shall serve twice the maximum period of incarceration for the offense, or twenty-five years, whichever is greater, notwithstanding any other provision of the Code to the contrary. A person sentenced under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not have the person\u8217\'3fs sentence reduced under }}}{{\f5\fs18\hyphpar0\qj{chapter 903A}}}{{\f5\fs18\hyphpar0\qj{ or otherwise by more than fifteen percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, a person convicted of a sexually predatory offense which is a felony who has previously been sentenced under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall be sentenced to life in prison on the same terms as a class \u8220\'3fA\u8221\'3f felon under }}}{{\f5\fs18\hyphpar0\qj{section 902.1}}}{{\f5\fs18\hyphpar0\qj{, notwithstanding any other provision of the Code to the contrary. In order for a person to be sentenced under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the prosecuting attorney shall allege and prove that }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is applicable to the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has been convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall, upon a second conviction for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, be committed to the custody of the director of the Iowa department of corrections for the rest of the person\u8217\'3fs life. In determining whether a conviction is a first or second conviction under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a prior conviction for a criminal offense committed in another jurisdiction which would constitute a violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if committed in this state, shall be considered a conviction under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The terms and conditions applicable to sentences for class \u8220\'3fA\u8221\'3f felons under }}}{{\f5\fs18\hyphpar0\qj{chapters 901 through 909}}}{{\f5\fs18\hyphpar0\qj{ shall apply to persons sentenced under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has been placed in a transitional release program, released with supervision, or discharged pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 229A}}}{{\f5\fs18\hyphpar0\qj{, and who is subsequently convicted of a sexually predatory offense or a sexually violent offense, shall be sentenced to life in prison on the same terms as a class \u8220\'3fA\u8221\'3f felon under }}}{{\f5\fs18\hyphpar0\qj{section 902.1}}}{{\f5\fs18\hyphpar0\qj{, notwithstanding any other provision of the Code to the contrary. The terms and conditions applicable to sentences for class \u8220\'3fA\u8221\'3f felons under }}}{{\f5\fs18\hyphpar0\qj{chapters 901 through 909}}}{{\f5\fs18\hyphpar0\qj{ shall apply to persons sentenced under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. However, if the person commits a sexually violent offense which is a misdemeanor offense under }}}{{\f5\fs18\hyphpar0\qj{chapter 709}}}{{\f5\fs18\hyphpar0\qj{, the person shall be sentenced to life in prison, with eligibility for parole as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 906}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person sentenced under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be eligible for deferred judgment, deferred sentence, or suspended sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other sentence imposed on a person convicted of a sexually predatory offense pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1, 2, or 3}}}{{\f5\fs18\hyphpar0\qj{, the person shall be sentenced to an additional term of parole or work release not to exceed two years. The board of parole shall determine whether the person should be released on parole or placed in a work release program. The sentence of parole supervision shall commence immediately upon the person\u8217\'3fs release by the board of parole and shall be under the terms and conditions as set out in }}}{{\f5\fs18\hyphpar0\qj{chapter 906}}}{{\f5\fs18\hyphpar0\qj{. Violations of parole or work release shall be subject to the procedures set out in }}}{{\f5\fs18\hyphpar0\qj{chapter 904}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{908}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted under those chapters. For purposes of disposition of a parole violator upon revocation of parole or work release, the sentence of an additional term of parole or work release shall be considered part of the original term of commitment to the department of corrections.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1082, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1171, \'a719, 20}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1139, \'a724, 27}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7255}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1165, \'a7106}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a7231}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a753}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{901A.3 and 901A.4}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2000/CH1030.pdf" }{\fldrslt \f5 \fs18{{2000 Acts, ch 1030, \'a73, 4}}}}}}{{\f5\fs18\qj{2000 Acts, ch 1030, \'a73, 4}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}}