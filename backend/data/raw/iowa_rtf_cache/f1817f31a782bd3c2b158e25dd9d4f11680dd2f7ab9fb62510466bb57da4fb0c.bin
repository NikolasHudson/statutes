09A.18A}}}{{\f5\fs12\qc{, 904.602}}}{{\f5\fs12\qc{, 915.12}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{22.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGovernment body\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means this state, or any county, city, township, school corporation, political subdivision, tax-supported district, nonprofit corporation other than a fair conducting a fair event as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 174}}}{{\f5\fs18\hyphpar0\qj{, whose facilities or indebtedness are supported in whole or in part with property tax revenue and which is licensed to conduct pari-mutuel wagering pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{; the governing body of a drainage or levee district as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 468}}}{{\f5\fs18\hyphpar0\qj{, including a board as defined in }}}{{\f5\fs18\hyphpar0\qj{section 468.3}}}{{\f5\fs18\hyphpar0\qj{, regardless of how the district is organized; or other entity of this state, or any branch, department, board, bureau, commission, council, committee, official, or officer of any of the foregoing or any employee delegated the responsibility for implementing the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLawful custodian\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the government body currently in physical possession of the public record. The custodian of a public record in the physical possession of persons outside a government body is the government body owning that record. The records relating to the investment of public funds are the property of the public body responsible for the public funds. Each government body shall delegate to particular officials or employees of that government body the responsibility for implementing the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall publicly announce the particular officials or employees to whom responsibility for implementing the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ has been delegated. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLawful custodian\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean an automated data processing unit of a public body if the data processing unit holds the records solely as the agent of another public body, nor does it mean a unit which holds the records of other public bodies solely for storage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic records\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes all records, documents, tape, or other information, stored or preserved in any medium, of or belonging to this state or any county, city, township, school corporation, political subdivision, nonprofit corporation other than a fair conducting a fair event as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 174}}}{{\f5\fs18\hyphpar0\qj{, whose facilities or indebtedness are supported in whole or in part with property tax revenue and which is licensed to conduct pari-mutuel wagering pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{, or tax-supported district in this state, or any branch, department, board, bureau, commission, council, or committee of any of the foregoing.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic records\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also includes all records relating to the investment of public funds including but not limited to investment policies, instructions, trading orders, or contracts, whether in the custody of the public body responsible for the public funds or a fiduciary or other third party.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768A.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1145, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1185, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C85, \'a722.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1271, \'a7702}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 258, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1156, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1019, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a715, 126}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 132, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.101}}}{{\f5\fs12\hyphpar0\qj{, 23.2}}}{{\f5\fs12\hyphpar0\qj{, 204A.5}}}{{\f5\fs12\hyphpar0\qj{, 455B.117}}}{{\f5\fs12\hyphpar0\qj{, 521J.1}}}{{\f5\fs12\hyphpar0\qj{, 543E.5}}}{{\f5\fs12\hyphpar0\qj{, 618.8}}}{{\f5\fs12\hyphpar0\qj{, 618.11}}}{{\f5\fs12\hyphpar0\qj{, 618.18}}}{{\f5\fs12\hyphpar0\qj{, 618.19}}}{{\f5\fs12\hyphpar0\qj{, 721.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{22.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Right to examine public records \u8212\'3f exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every person shall have the right to examine and copy a public record and to publish or otherwise disseminate a public record or the information contained in a public record. Unless otherwise provided for by law, the right to examine a public record shall include the right to examine a public record without charge while the public record is in the physical possession of the custodian of the public record. The right to copy a public record shall include the right to make photographs or photographic copies while the public record is in the possession of the custodian of the public record. All rights under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are in addition to the right to obtain a certified copy of a public record under }}}{{\f5\fs18\hyphpar0\qj{section 622.46}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A government body shall not prevent the examination or copying of a public record by contracting with a nongovernment body to perform any of its duties or functions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If feasible, the custodian of a public record may provide for the electronic examination and copying of a public record in lieu of requiring in-person examination and copying of a public record. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to searches of all indexes, general and specific, of public records relating to documents, instruments, and muniments of title, for the purpose of performing title searches, real property searches, or creating real property abstracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, a government body is not required to permit access to or use of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A geographic computer database by any person except upon terms and conditions acceptable to the governing body. The governing body shall establish reasonable rates and procedures for the retrieval of specified records, which are not confidential records, stored in the database upon the request of any person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Data processing software developed by the government body or developed by a nongovernment body and used by a government body pursuant to a contractual relationship with the nongovernment body, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 22.3A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768A.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1185, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C85, \'a722.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 189, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1099, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1224, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 42, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1103, \'a732, 51}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.106}}}{{\f5\fs12\hyphpar0\qj{, 8A.341}}}{{\f5\fs12\hyphpar0\qj{, 22.14}}}{{\f5\fs12\hyphpar0\qj{, 68B.32A}}}{{\f5\fs12\hyphpar0\qj{, 331.608}}}{{\f5\fs12\hyphpar0\qj{, 357A.11A}}}{{\f5\fs12\hyphpar0\qj{, 388.9}}}{{\f5\fs12\hyphpar0\qj{, 388.9A}}}{{\f5\fs12\hyphpar0\qj{, 459.304}}}{{\f5\fs12\hyphpar0\qj{, 459A.208}}}{{\f5\fs12\hyphpar0\qj{, 502.809}}}{{\f5\fs12\hyphpar0\qj{, 904.602}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{22.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supervision }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The examination and copying of public records shall be done under the supervision of the lawful custodian of the records or the custodian\u8217\'3fs authorized designee. The lawful custodian shall not require the physical presence of a person requesting or receiving a copy of a public record and shall fulfill requests for a copy of a public record received in writing, by telephone, or by electronic means. Although fulfillment of a request for a copy of a public record may be contingent upon receipt of payment of reasonable expenses, the lawful custodian shall make every reasonable effort to provide the public record requested at no cost other than copying costs for a record which takes less than thirty minutes to produce. In the event expenses are necessary, such expenses shall be reasonable and communicated to the requester upon receipt of the request. A person may contest the reasonableness of the custodian\u8217\'3fs expenses as provided for in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The lawful custodian may adopt and enforce reasonable rules regarding the examination and copying of the records and the protection of the records against damage or disorganization. The lawful custodian shall provide a suitable place for the examination and copying of the records, but if it is impracticable to do the examination and copying of the records in the office of the lawful custodian, the person desiring to examine or copy shall pay any necessary expenses of providing a place for the examination and copying.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All reasonable expenses of the examination and copying shall be paid by the person desiring to examine or copy. The lawful custodian may charge a reasonable fee for the services of the lawful custodian or the custodian\u8217\'3fs authorized designee in supervising the examination and copying of the records. If copy equipment is available at the office of the lawful custodian of any public records, the lawful custodian shall provide any person a reasonable number of copies of any public record in the custody of the office upon the payment of a fee. The fee for the copying service as determined by the lawful custodian shall not exceed the actual cost of providing the service. Actual costs shall include only those reasonable expenses directly attributable to supervising the examination of and making and providing copies of public records. Actual costs shall not include charges for ordinary expenses or costs such as employment benefits, depreciation, maintenance, electricity, or insurance associated with the administration of the office of the lawful custodian. Costs for legal services should only be utilized for the redaction or review of legally protected confidential information. However, a county recorder shall not charge a fee for the examination and copying of public records necessary to complete and file claims for benefits with the Iowa department of veterans affairs or the United States department of veterans affairs.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768A.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C85, \'a722.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 44, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 103, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1052, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1039, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a72.42}}}{{\f5\fs12\hyphpar0\qj{, 8A.341}}}{{\f5\fs12\hyphpar0\qj{, 321.11}}}{{\f5\fs12\hyphpar0\qj{, 483A.22A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{22.3A}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Access to data processing software.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAccess\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the instruction of, communication with, storage of data in, or retrieval of data from a computer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fComputer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an electronic device which performs logical, arithmetical, and memory functions by manipulations of electronic or magnetic impulses, and includes all input, output, processing, storage, and communication facilities which are connected or related to the computer including a computer network. As used in this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcomputer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any central processing unit, front-end processing unit, miniprocessor, or microprocessor, and related peripheral equipment such as data storage devices, document scanners, data entry terminal controllers, and data terminal equipment and systems for computer networks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fComputer network\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a set of related, remotely connected devices and communication facilities including two or more computers with capability to transmit data among them through communication facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fData\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a representation of information, knowledge, facts, concepts, or instructions that has been prepared or is being prepared in a formalized manner and has been processed, or is intended to be processed, in a computer. Data may be stored in any form, including but not limited to a printout, magnetic storage media, disk, compact disc, punched card, or as memory of a computer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fData processing software\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an ordered set of instructions or statements that, when executed by a computer, causes the computer to process data, and includes any program or set of programs, procedures, or routines used to employ and control capabilities of computer hardware. As used in this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdata processing software\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to an operating system, compiler, assembler, utility, library resource, maintenance routine, application, computer networking program, or the associated documentation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A government body may provide, restrict, or prohibit access to data processing software developed by the government body or developed by a nongovernment body and used by a government body pursuant to a contractual relationship with the nongovernment body, regardless of whether the data processing software is separated or combined with a public record. A government body shall establish policies and procedures to provide access to public records which are combined with its data processing software. A public record shall not be withheld from the public because it is combined with data processing software.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A government body shall not acquire any electronic data processing system for the storage, manipulation, or retrieval of public records that would impair the government body\u8217\'3fs ability to permit the examination of a public record and the copying of a public record in either written or electronic form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a public record is only available as a part of or in combination with data processing software in order to permit the examination or copying of the public record, the government body shall bear the cost of separation of the public record from the data processing software.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ An electronic public record shall be made available in the format in which it is readily accessible to the government body if that format is useable with commonly available data processing or database management software. The government body may make a public record available in a specific format requested by a person that is different from that in which the public record is readily accessible to the government body and may charge the reasonable costs of any required processing, programming, or other work required to produce the public record in the specific format in addition to any other costs allowed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cost chargeable to a person receiving a public record separated from data processing software under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be in excess of the charge under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ unless the person receiving the public record requests that the public record be specially processed or produced in a format different from that in which the public record is readily accessible to the government body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A government body may establish payment rates and procedures required to provide access to data processing software, regardless of whether the data processing software is separated from or combined with a public record. Proceeds from payments may be considered appropriated receipts, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{. The payment amount shall be calculated as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount charged for access to a public record shall be not more than that required to recover direct publication costs, including but not limited to editing, compilation, and media production costs, incurred by the government body in developing the data processing software and preparing the data processing software for transfer to the person. The amount shall be in addition to any other fee required to be paid under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the examination and copying of a public record. If a person accesses a public record stored in an electronic format that does not require formatting, editing, or compiling to access the public record, the charge for providing the accessed public record shall not exceed the reasonable cost of accessing that public record. The government body shall, if requested, provide documentation which explains and justifies the amount charged. This subparagraph shall not apply to any publication for which a price has been established pursuant to another section, including }}}{{\f5\fs18\hyphpar0\qj{section 2A.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If access to the data processing software is provided to a person for a purpose other than provided in subparagraph (1), the amount may be established according to the discretion of the government body, and may be based upon competitive market considerations as determined by the government body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A government body is granted and may apply for and receive any legal protection necessary to secure a right to or an interest in data processing software developed by the government body, including but not limited to federal copyright, patent, and trademark protections, and any trade secret protection available under }}}{{\f5\fs18\hyphpar0\qj{chapter 550}}}{{\f5\fs18\hyphpar0\qj{. The government body may enter into agreements for the sale or distribution of its data processing software, including marketing and licensing agreements. The government body may impose conditions upon the use of the data processing software that is otherwise consistent with state and federal law.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1099, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1224, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 207, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 35, \'a738, 49}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 127, \'a745, 89}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 42, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7109}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.89}}}{{\f5\fs12\hyphpar0\qj{, 8A.341}}}{{\f5\fs12\hyphpar0\qj{, 22.2}}}{{\f5\fs12\hyphpar0\qj{, 22.7(33)}}}{{\f5\fs12\hyphpar0\qj{, 169A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{22.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Public records requests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The rights of persons under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may be exercised under any of the following circumstances: }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In person, at any time during the customary office hours of the lawful custodian of the records. However, if the lawful custodian does not have customary office hours of at least thirty hours per week, such right may be exercised at any time from 9:00 a.m. to noon and from 1:00 p.m. to 4:00 p.m. Monday through Friday, excluding legal holidays, unless the person exercising such right and the lawful custodian agree on a different time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In writing, by telephone, or by electronic means. The lawful custodian of the records shall post information for making such requests in a manner reasonably calculated to apprise the public of that information.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768A.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1185, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C85, \'a722.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1103, \'a733, 51}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.341}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{22.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement of rights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and all rights of persons under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may be enforced by mandamus or injunction, whether or not any other remedy is also available. In the alternative, rights under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ also may be enforced by an action for judicial review according to the provisions of the Iowa administrative procedure Act, }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{, if the records involved are records of an \u8220\'3fagency\u8221\'3f as defined in that Act.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768A.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1185, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C85, \'a722.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 44, \'a7114}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78A.341}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{22.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2011 Acts, ch 106, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{22.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidential records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The following public records shall be kept confidential, unless otherwise ordered by a court, by the lawful custodian of the records, or by another person duly authorized to release such information:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personal information in records regarding a student, prospective student, or former student maintained, created, collected or assembled by or for a school corporation or educational institution maintaining such records. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit a postsecondary education institution from disclosing to a parent or guardian information regarding a violation of a federal, state, or local law, or institutional rule or policy governing the use or possession of alcohol or a controlled substance if the child is under the age of twenty-one years and the institution determines that the student committed a disciplinary violation with respect to the use or possession of alcohol or a controlled substance regardless of whether that information is contained in the student\u8217\'3fs education records. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit a school corporation or educational institution from transferring student records electronically to the department of education, an accredited nonpublic school, an attendance center, a school district, or an accredited postsecondary institution in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 256.9, subsection 44}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hospital records, medical records, and professional counselor records of the condition, diagnosis, care, or treatment of a patient or former patient or a counselee or former counselee, including outpatient. However, confidential communications between a crime victim and the victim\u8217\'3fs counselor are not subject to disclosure except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 915.20A}}}{{\f5\fs18\hyphpar0\qj{. However, the department of health and human services shall adopt rules which provide for the sharing of information among agencies and providers concerning the maternal and child health program including but not limited to the statewide child immunization information system, while maintaining an individual\u8217\'3fs confidentiality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Trade secrets which are recognized and protected as such by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records which represent and constitute the work product of an attorney, which are related to litigation or claim made by or against a public body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Peace officers\u8217\'3f investigative reports, privileged records or information specified in }}}{{\f5\fs18\hyphpar0\qj{section 80G.2}}}{{\f5\fs18\hyphpar0\qj{, and specific portions of electronic mail and telephone billing records of law enforcement agencies if that information is part of an ongoing investigation, except where disclosure is authorized elsewhere in this Code. However, the date, time, specific location, and immediate facts and circumstances surrounding a crime or incident shall not be kept confidential under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, except in those unusual circumstances where disclosure would plainly and seriously jeopardize an investigation or pose a clear and present danger to the safety of an individual. Specific portions of electronic mail and telephone billing records may only be kept confidential under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if the length of time prescribed for commencement of prosecution or the finding of an indictment or information under the statute of limitations applicable to the crime that is under investigation has not expired.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5A.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A crisis intervention report generated by a law enforcement agency regarding a person experiencing a mental health crisis, substance use disorder crisis, or housing crisis, when the report is generated for the specific purpose of providing crisis intervention information to assist peace officers under any of the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{De-escalating conflicts.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Referring a person experiencing a mental health crisis, substance use disorder crisis, or housing crisis to a mental health treatment provider, substance use disorder treatment provider, homeless service provider, or any other appropriate service provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A crisis intervention report generated for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be made available to the person who is the subject of the report upon the request of the person who is the subject of the report, and may be provided to a mental health treatment provider, substance use disorder treatment provider, homeless service provider, or any other appropriate service provider in connection with a referral for services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Crisis intervention reports generated for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ are not peace officers\u8217\'3f investigative reports under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the date, time, specific location, and immediate facts and circumstances surrounding a crime or incident shall not be kept confidential under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, except where disclosure would pose a clear and present danger to the safety of the person subject to the crisis intervention report or the safety of others.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCrisis intervention report\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freport\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a report generated by a law enforcement agency using a prescribed form created by the department of justice to record the following information relevant to assess the nature of a crisis:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any biological or chemical causes of the crisis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any observed demeanors and behaviors of the person experiencing the crisis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons notified in relation to the crisis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether suicide or injuries occurred in relation to the crisis and the extent of those injuries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether weapons were involved in the crisis and a description of the weapon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The disposition of the crisis intervention and any crime committed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHousing crisis\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a situation where a person is experiencing homelessness, a lack of adequate or safe housing, or is in imminent danger of homelessness or lack of adequate or safe housing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reports to governmental agencies which, if released, would give advantage to competitors and serve no public purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appraisals or appraisal information concerning the sale or purchase of real or personal property for public purposes, prior to the execution of any contract for such sale or the submission of the appraisal to the property owner or other interest holders as provided in }}}{{\f5\fs18\hyphpar0\qj{section 6B.45}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Economic development authority information on an industrial prospect with which the authority is currently negotiating.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Criminal identification files of law enforcement agencies. However, records of current and prior arrests and criminal history data shall be public records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A claim for compensation and reimbursement for legal assistance and supporting documents submitted to the state public defender for payment from the indigent defense fund established in }}}{{\f5\fs18\hyphpar0\qj{section 815.11}}}{{\f5\fs18\hyphpar0\qj{, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 13B.4A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personal information in confidential personnel records of government bodies relating to identified or identifiable individuals who are officials, officers, or employees of the government bodies. However, the following information relating to such individuals contained in personnel records shall be public records, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{section 80G.3}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and compensation of the individual including any written agreement establishing compensation or any other terms of employment excluding any information otherwise excludable from public information pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or any other applicable provision of law. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcompensation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means payment of, or agreement to pay, any money, thing of value, or financial benefit conferred in return for labor or services rendered by an official, officer, or employee plus the value of benefits conferred including but not limited to casualty, disability, life, or health insurance, other health or wellness benefits, vacation, holiday, and sick leave, severance payments, retirement benefits, and deferred compensation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The dates the individual was employed by the government body.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The positions the individual holds or has held with the government body.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The educational institutions attended by the individual, including any diplomas and degrees earned, and the names of the individual\u8217\'3fs previous employers, positions previously held, and dates of previous employment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fact that the individual resigned in lieu of termination, was discharged, or was demoted as the result of a disciplinary action, and the documented reasons and rationale for the resignation in lieu of termination, the discharge, or the demotion. For purposes of this subparagraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdemoted\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdemotion\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean a change of an employee from a position in a given classification to a position in a classification having a lower pay grade.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Personal information in confidential personnel records of government bodies relating to student employees shall only be released pursuant to }}}{{\f5\fs18\hyphpar0\qj{20 U.S.C. \'a71232g}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Financial statements submitted to the department of agriculture and land stewardship pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 203}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 203C}}}{{\f5\fs18\hyphpar0\qj{, by or on behalf of a licensed grain dealer or warehouse operator or by an applicant for a grain dealer license or warehouse license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The records of a library which, by themselves or when examined with other public records, would reveal the identity of the library patron checking out or requesting an item or information from the library. The records shall be released to a criminal or juvenile justice agency only pursuant to an investigation of a particular person or organization suspected of committing a known crime. The records shall be released only upon a judicial determination that a rational connection exists between the requested release of information and a legitimate end and that the need for the information is cogent and compelling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The material of a library, museum or archive which has been contributed by a private person to the extent of any limitation that is a condition of the contribution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information concerning the procedures to be used to control disturbances at adult correctional institutions. Such information shall also be exempt from public inspection under }}}{{\f5\fs18\hyphpar0\qj{section 17A.3}}}{{\f5\fs18\hyphpar0\qj{. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ disturbance means a riot or a condition that can reasonably be expected to cause a riot.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information in a report to the department of health and human services, to a local board of health, or to a local health department, which identifies a person infected with a reportable disease.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records of identity of owners of public bonds or obligations maintained as provided in }}}{{\f5\fs18\hyphpar0\qj{section 76.10}}}{{\f5\fs18\hyphpar0\qj{ or by the issuer of the public bonds or obligations. However, the issuer of the public bonds or obligations and a state or federal agency shall have the right of access to the records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Communications not required by law, rule, procedure, or contract that are made to a government body or to any of its employees by identified persons outside of government, to the extent that the government body receiving those communications from such persons outside of government could reasonably believe that those persons would be discouraged from making them to that government body if they were available for general public examination. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpersons outside of government\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include persons or employees of persons who are communicating with respect to a consulting or contractual relationship with a government body or who are communicating with a government body with whom an arrangement for compensation exists. Notwithstanding this provision:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The communication is a public record to the extent that the person outside of government making that communication consents to its treatment as a public record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information contained in the communication is a public record to the extent that it can be disclosed without directly or indirectly indicating the identity of the person outside of government making it or enabling others to ascertain the identity of that person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information contained in the communication is a public record to the extent that it indicates the date, time, specific location, and immediate facts and circumstances surrounding the occurrence of a crime or other illegal act, except to the extent that its disclosure would plainly and seriously jeopardize a continuing investigation or pose a clear and present danger to the safety of any person. In any action challenging the failure of the lawful custodian to disclose any particular information of the kind enumerated in this paragraph, the burden of proof is on the lawful custodian to demonstrate that the disclosure of that information would jeopardize such an investigation or would pose such a clear and present danger.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Examinations, including but not limited to cognitive and psychological examinations for law enforcement officer candidates administered by or on behalf of a governmental body, to the extent that their disclosure could reasonably be believed by the custodian to interfere with the accomplishment of the objectives for which they are administered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information concerning the nature and location of any archaeological resource or site if, in the opinion of the state archaeologist, disclosure of the information will result in unreasonable risk of damage to or loss of the resource or site where the resource is located. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to interfere with the responsibilities of the federal government or the state historic preservation officer pertaining to access, disclosure, and use of archaeological site records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information concerning the nature and location of any ecologically sensitive resource or site if, in the opinion of the director of the department of natural resources after consultation with the state ecologist, disclosure of the information will result in unreasonable risk of damage to or loss of the resource or site where the resource is located. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to interfere with the responsibilities of the federal government or the director of the department of natural resources and the state ecologist pertaining to access, disclosure, and use of the ecologically sensitive site records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reports or recommendations of the Iowa insurance guaranty association filed or made pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 515B.10, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information or reports collected or submitted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 508C.12, subsections 3 and 5}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 508C.13, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, except to the extent that release is permitted under those sections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Financial information, which if released would give advantage to competitors and serve no public purpose, relating to commercial operations conducted or intended to be conducted by a person submitting records containing the information to the department of agriculture and land stewardship for the purpose of obtaining assistance in business planning.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Applications, investigation reports, and case records of persons applying for county general assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 252.25}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Marketing and advertising budget and strategy of a nonprofit corporation which is subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, this exemption does not apply to salaries or benefits of employees who are employed by the nonprofit corporation to handle the marketing and advertising responsibilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information contained in records of the centralized employee registry created in }}}{{\f5\fs18\hyphpar0\qj{chapter 252G}}}{{\f5\fs18\hyphpar0\qj{, except to the extent that disclosure is authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 252G}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{29.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Records and information obtained or held by independent special counsel during the course of an investigation conducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 68B.31A}}}{{\f5\fs18\hyphpar0\qj{. Information that is disclosed to a legislative ethics committee subsequent to a determination of probable cause by independent special counsel and made pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 68B.31}}}{{\f5\fs18\hyphpar0\qj{ is not a confidential record unless otherwise provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{30.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information contained in a declaration of paternity completed and filed with the state registrar of vital statistics pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 144.12A}}}{{\f5\fs18\hyphpar0\qj{, except to the extent that the information may be provided to persons in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 144.12A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{31.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Memoranda, work products, and case files of a mediator and all other confidential communications in the possession of a mediator, as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 10A, subchapter III,}}}{{\f5\fs18\hyphpar0\qj{ and}}}{{\f5\fs18\hyphpar0\qj{ chapter 216}}}{{\f5\fs18\hyphpar0\qj{. Information in these confidential communications is subject to disclosure only as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 10A.332}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{216.15B}}}{{\f5\fs18\hyphpar0\qj{, notwithstanding any other contrary provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{32.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Social security numbers of the owners of unclaimed property reported to the treasurer of state pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 556.11, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, included on claim forms filed with the treasurer of state pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 556.19}}}{{\f5\fs18\hyphpar0\qj{, included in outdated warrant reports received by the treasurer of state pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 556.2C}}}{{\f5\fs18\hyphpar0\qj{, or stored i