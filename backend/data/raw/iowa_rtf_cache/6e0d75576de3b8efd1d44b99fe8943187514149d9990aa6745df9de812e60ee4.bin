\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F176A}{\*\bkmkend codeChapter_5F176A}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 176A}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{COUNTY AGRICULTURAL EXTENSION}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7159.6}}}{{\f5\fs12\qc{, 173.3}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ may be known and cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty Agricultural Extension Law\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Declaration of policy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is the policy of the legislature to provide for aid in disseminating among the people of Iowa useful and practical information on subjects relating to agriculture, home economics, and community and economic development, and to encourage the application of the information in the counties of the state through extension work to be carried on in cooperation with Iowa state university of science and technology and the United States department of agriculture as provided in the Act of Congress known as the Smith-Lever Act, adopted May 8, 1914, as amended, 38 Stat. 372 \u8211\'3f 374, codified at 7 U.S.C. \'a7341 \u8211\'3f 349.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7838}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1010, \'a757}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definition of terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever used or referred to in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless a different meaning clearly appears from the context:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty agricultural extension council\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, hereinafter referred to as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fextension council\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, means the agency created and constituted as provided in }}}{{\f5\fs18\hyphpar0\qj{section 176A.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCounty agricultural extension district\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, hereinafter referred to as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fextension district\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, means a governmental subdivision of this state, and a public body corporate organized in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the purposes, with the powers, and subject to the restrictions set forth in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector of extension\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the \u8220\'3fdirector of Iowa state university of science and technology extension service\u8221\'3f, and shall hereinafter be referred to as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdirector of extension\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fExtension service\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the \u8220\'3fcooperative extension service in agriculture and home economics of Iowa state university\u8221\'3f, and shall hereinafter be referred to as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fextension service\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa state university\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the \u8220\'3fIowa state university of science and technology\u8221\'3f, and shall hereinafter be referred to as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa state university\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a769}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Establishment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ body corporate }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ county agricultural extension districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each county, except Pottawattamie, is constituted and established as a \u8220\'3fcounty agricultural extension district\u8221\'3f and shall be a public body corporate organized in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the purposes, with the powers and subject to the restrictions set forth in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pottawattamie county shall be divided into and constitute two districts as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A district to be known as \u8220\'3fEast Pottawattamie\u8221\'3f which shall include the following townships:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pleasant, Layton, Knox, James, Valley, Lincoln, Washington, Belknap, Center, Wright, Carson, Macedonia, Grove, Waveland.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A district to be known as \u8220\'3fWest Pottawattamie\u8221\'3f which shall include the following townships:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rockford, Boomer, Neola, Minden, Hazel Dell, York, Crescent, Norwalk, Lake, Garner, Hardin, Kane, Lewis, Keg Creek, Silver Creek.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2930;}}}{ C46, 50, 54, \'a7176.8; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a768}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County agricultural extension council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{There shall be elected in each extension district an extension council consisting of nine members. Each member of the extension council shall be a resident registered voter of the extension district.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1149, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1169, \'a764}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7176A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Elections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An election shall be held biennially at the time of the general election in each extension district for the election of members of the extension council. All registered voters of the extension district are entitled to vote in the election.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1149, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 67, \'a753}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a739.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Terms \u8212\'3f meetings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided pursuant to law for members elected in 1990, the term of office of an extension council member is four years. The term shall commence on the first day of January following the date of the member\u8217\'3fs election which is not a Sunday or legal holiday.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each extension council shall meet at least two times during a calendar year and at other times during the year as the council determines. The date, time, and place of each meeting shall be fixed by the council.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1149, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 133, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and duties of county agricultural extension council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The extension councils of each extension district of the state shall have, exercise, and perform the following powers and duties:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To elect from their own number annually a chairperson, vice chairperson, secretary and a treasurer who shall serve and be the officers of the extension council for a term of one year, and perform the functions and duties as herein in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To serve as an agency of the state and to manage and transact all of the business and affairs of its district and have control of all of the property acquired by it and necessary for the conduct of the business of the district for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To, at least ninety days prior to the date fixed for the election of council members, appoint a nominating committee consisting of four persons who are not council members and designate the chairperson. The nominating committee shall consider the geographic distribution of potential nominees in nominating one or more resident registered voters of the extension district as candidates for election to each office to be filled at the election. To qualify for the election ballot, each nominee shall file a nominating petition signed by at least twenty-five eligible electors of the district with the county commissioner of elections at least sixty-nine days before the date of election.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide for the nomination by petition of candidates for election to membership on the extension council. A nominating petition shall be signed by at least twenty-five eligible electors of the extension district and shall be filed with the county commissioner of elections at least sixty-nine days before the date of the election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To enter into a memorandum of understanding with the extension service setting forth the cooperative relationship between the extension service and the extension district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To employ all necessary extension professional personnel from qualified nominees furnished to it and recommended by the director of extension and not to terminate the employment of any such without first conferring with the director of extension, and to employ such other personnel as it shall determine necessary for the conduct of the business of the extension district, and to fix the compensation for all such personnel in cooperation with the extension service and in accordance with the memorandum of understanding entered into with such extension service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To prepare annually before April 30 a budget for the fiscal year beginning July 1 and ending the following June 30, in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 24}}}{{\f5\fs18\hyphpar0\qj{ and certify the budget to the board of supervisors of the county of their extension district as required by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be responsible for the preparation and adoption of the educational program on extension work in agriculture, home economics, and 4-H club work, and periodically review the program, and for the carrying out of the program in cooperation with the extension service in accordance with the memorandum of understanding with the extension service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To make and adopt such rules not inconsistent with the law as it may deem necessary for its own government and the transaction of the business of the extension district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To fill all vacancies in its membership to serve for the unexpired term of the member creating the vacancy by appointing a resident registered voter of the extension district. However, if an unexpired term in which the vacancy occurs has more than seventy days to run after the date of the next general election and the vacancy occurs seventy-four or more days before the election, the vacancy shall be filled at the next general election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To, as soon as possible following the meeting at which the officers are elected, file in the office of the board of supervisors and of the county treasurer a certificate signed by the chairperson and secretary of the extension council certifying the names, addresses, and terms of office of each member, and the names and addresses of the officers of the extension council with the signatures of the officers affixed to the certificate. The certificate shall be conclusive as to the organization of the extension district, its extension council, and as to its members and officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To deposit all funds received from the \u8220\'3fcounty agricultural extension education fund\u8221\'3f in a bank or banks approved by the extension council in the name of the extension district. These receipts shall constitute a fund known as the \u8220\'3fcounty agricultural extension education fund\u8221\'3f which shall be disbursed by the treasurer of the extension council on vouchers signed by its chairperson and secretary and approved by the extension council and recorded in its minutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To expend the \u8220\'3fcounty agricultural extension education fund\u8221\'3f for salaries and travel, expense of personnel, rental, office supplies, equipment, communications, office facilities and services, and in payment of such other items as shall be necessary to carry out the extension district program; provided, however, it shall be unlawful for the county agricultural extension council to lease any office space which is occupied or used by any other farm organization or farm cooperative, and provided further, that it shall be lawful for the county agricultural extension council to lease space in a building owned or occupied by a farm organization or farm cooperative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To carry over unexpended county agricultural extension education funds into the next year so that funds will be available to carry on the program until such time as moneys received from taxes are collected by the county treasurer. However, the unencumbered funds in the county agricultural extension education fund in excess of one-half the amount expended from the fund in the previous year shall be paid over to the county treasurer. The treasurer of the extension council with the approval of the council may invest agricultural extension education funds retained by the council and not needed for current expenses in the manner authorized for treasurers of political subdivisions under }}}{{\f5\fs18\hyphpar0\qj{section 12C.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To file with the county auditor and to publish in two newspapers of general circulation in the district before September 1 full and detailed reports under oath of all receipts, from whatever source derived, and expenditures of such county agricultural extension education fund showing from whom received, to whom paid and for what purpose for the last fiscal year.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71683-j, -m; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2930, 2933, 2938;}}}{ C46, 50, 54, \'a7176.8, 176.11, 176.16; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a777, 209}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 43, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1149, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 129, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1169, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 133, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 56, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 64, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1004, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a733, 47, 48}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7176A.9}}}{{\f5\fs12\hyphpar0\qj{, 331.427}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 6 applies retroactively to January 1, 2024; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a748}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitation on powers and activities of extension council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The extension council has for its sole purpose the dissemination of information, the giving of instruction and practical demonstrations on subjects relating to agriculture, home economics, and community and economic development, and the encouragement of the application of the information, instruction, and demonstrations to and by all persons in the extension district, and the imparting to the persons of information on those subjects through field demonstrations, publications, or other media.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The extension district, its council, or a member or an employee as a representative of either one or the other shall not engage in commercial or other private enterprises, legislative programs, nor attempt in any manner by the adoption of resolutions or otherwise to influence legislation, either state or national, or other activities not authorized by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The extension council or a member or employee thereof as a representative of either the extension district or the extension council shall not give preferred services to any individual, group or organization or sponsor the programs of any group, organization or private agency other than as herein provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The extension council may collect reasonable fees and may seek and receive grants, donations, gifts, bequests, or other moneys from public and private sources to be used for the purposes set forth in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and may enter into contracts to provide educational services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The extension council and its employed personnel may cooperate with and give information and advice to organized and unorganized groups, but shall not promote, sponsor, or engage in the organization of any group for any purpose except the promoting, organization, and the development of the programs of 4-H clubs. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall prevent the county extension council or extension agents employed by it from using or seeking opportunities to reach an audience of persons interested in agricultural extension work through the help of interested farm organizations, civic organizations, or any other group. However, in using or seeking such opportunities, the county extension council or agents employed by the extension council shall make available to all groups and organizations in the county equal opportunity to cooperate in the educational extension program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the council shall serve without compensation, but may receive actual and necessary expenses, including in-state travel expenses at not more than the state rate, incurred in the performance of official duties other than attendance at regular local county extension council meetings. Payment shall be made from funds available pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 176A.8, subsection 12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a71683-e; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2929, 2931;}}}{ C46, 50, 54, \'a7176.7, 176.9; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7839}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1166, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a770}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County agricultural extension education tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The extension council of each extension district shall, at a meeting held before April 30, estimate the amount of money required to be raised by taxation for financing the county agricultural extension education program authorized in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The annual tax levy and the amount of money to be raised from the levy for the county agricultural extension education fund shall not exceed the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in subparagraph (2), for an extension district having a population of less than thirty thousand, an annual levy of twenty and one-fourth cents per thousand dollars of the assessed valuation of the taxable property in the district up to a maximum of seventy thousand dollars for the fiscal year commencing July 1, 1985, and seventy-five thousand dollars for each subsequent fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an extension district having a population of less than thirty thousand and as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, an annual levy of thirty cents per thousand dollars of the assessed valuation of the taxable property in the district up to a maximum of eighty-seven thousand dollars payable during the fiscal year commencing July 1, 1992, and an increase of six thousand dollars in the amount payable during each subsequent fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in subparagraph (2), for an extension district having a population of thirty thousand or more but less than fifty thousand, an annual levy of twenty and one-fourth cents per thousand dollars of the assessed valuation of the taxable property in the district up to a maximum of eighty-four thousand dollars for the fiscal year commencing July 1, 1985, and ninety thousand dollars for each subsequent fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an extension district having a population of thirty thousand or more but less than fifty thousand and as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, an annual levy of twenty and one-fourth cents per thousand dollars of the assessed valuation of the taxable property in the district up to a maximum of one hundred four thousand dollars payable during the fiscal year commencing July 1, 1992, and an increase of seven thousand dollars in the amount payable during each subsequent fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in subparagraph (2), for an extension district having a population of fifty thousand or more but less than ninety-five thousand, an annual levy of thirteen and one-half cents per thousand dollars of the assessed valuation of the taxable property in the district up to a maximum of one hundred five thousand dollars for the fiscal year commencing July 1, 1985, and one hundred twelve thousand five hundred dollars for each subsequent fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an extension district having a population of fifty thousand or more but less than ninety thousand and as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, an annual levy of thirteen and one-half cents per thousand dollars of the assessed valuation of the taxable property in the district up to a maximum of one hundred thirty thousand five hundred dollars payable during the fiscal year commencing July 1, 1992, and an increase of nine thousand dollars in the amount payable during each subsequent fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in subparagraph (2), for an extension district having a population of ninety-five thousand or more, an annual levy of thirteen and one-half cents per thousand dollars of the assessed valuation of the taxable property in the district up to a maximum of one hundred forty thousand dollars for the fiscal year commencing July 1, 1985, and one hundred fifty thousand dollars for each subsequent fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an extension district having a population of ninety thousand or more but less than two hundred thousand and as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, an annual levy of thirteen and one-half cents per thousand dollars of the assessed valuation of the taxable property in the district up to a maximum of one hundred eighty thousand dollars payable during the fiscal year commencing July 1, 1992, and an increase of fifteen thousand dollars in the amount payable during each subsequent fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an extension district having a population of two hundred thousand or more and as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, an annual levy of five cents per thousand dollars of the assessed valuation of the taxable property in the district up to a maximum of two hundred thousand dollars payable during the fiscal year commencing July 1, 1992, and an increase of twenty-five thousand dollars in the amount payable during each subsequent fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An extension council of an extension district may choose to be subject to the levy and revenue limits specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), and paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), and }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for the purpose of the annual levy for the fiscal year commencing July 1, 1991, which levy is payable in the fiscal year beginning July 1, 1992. Before an extension district may be subject to the levy and revenue limits specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), and paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), and }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for fiscal years beginning on or after July 1, 1992, which levy is payable in fiscal years beginning on or after July 1, 1993, the question of whether the district shall be subject to the levy and revenue limits as specified in such paragraphs must be submitted to the registered voters of the district. The question shall be submitted at the time of a general election. If the question is approved by a majority of those voting on the question the levy and revenue limits specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), and paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), and }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall thereafter apply to the extension district. The question need only be approved at one general election. If a majority of those voting on the question vote against the question, the district may continue to submit the question at subsequent general elections until approved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The extension council in each extension district shall comply with }}}{{\f5\fs18\hyphpar0\qj{chapter 24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2930;}}}{ C46, 50, 54, \'a7176.8; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7176A.10}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 69, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 156, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1212, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1246, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 133, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7205}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a734, 47, 48}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1, unnumbered paragraph 1 applies retroactively to January 1, 2024; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a748}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual levy by board of supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board of supervisors of each county shall annually, at the time of levying taxes for county purposes, levy the taxes necessary to raise the county agricultural extension education fund and certified to it by the extension council as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, but if the amount certified for such fund is in excess of the amount authorized by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ it shall levy only so much thereof as is authorized by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2930;}}}{ C46, 50, 54, \'a7176.8; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.12}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County agricultural extension fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A county agricultural extension education fund shall be established in each county and the county treasurer of each county shall keep the amount of tax levied under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ in that fund. Before the fifteenth day of each month, the treasurer shall notify the chairperson of the county extension council of the amount collected for this fund to the first day of that month and shall pay that amount to the treasurer of the extension council as provided in }{{\f5\fs18\hyphpar0\qj{section 331.552, subsection 29}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a778, 209}}}{; }{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1003, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.559}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.13}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cooperation extension council \u8212\'3f extension service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The extension council is specifically authorized to cooperate with the extension service and the United States department of agriculture in the accomplishment of the county agricultural extension education program contemplated by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, to the end that the federal funds allocated to the extension service and the county agricultural extension education fund of each district may be more efficiently used by the extension service and the extension council. The director of extension shall coordinate the county agricultural extension education program in the several extension districts.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71683-p; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2931, 2932;}}}{ C46, 50, 54, \'a7176.9, 176.10; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.14}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Extension council officers \u8212\'3f duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chairperson of the extension council shall preside at all meetings of the extension council, have authority to call special meetings of said council upon such notice as shall be fixed and determined by the extension council, and shall call special meetings of the extension council upon the written request of a majority of the members of said council, and in addition to the duties imposed in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ perform and exercise the usual duties performed and exercised by a chairperson or president of a board of directors of a corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The vice chairperson, in the absence or disability of the chairperson, or the chairperson\u8217\'3fs refusal to act, shall perform the duties imposed upon the chairperson and act in the chairperson\u8217\'3fs stead.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary shall perform the duties usually incident to this office. The secretary shall keep the minutes of all meetings of the extension council. The secretary shall sign such instruments and papers as are required to be signed by the secretary as such in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and by the extension council from time to time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treasurer shall receive, deposit and have charge of all of the funds of the extension council and pay and disburse the same as in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ required, and as may be from time to time required by the extension council. The treasurer shall keep an accurate record of receipts and disbursements and submit a report thereof at such times as may be required by the extension council.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each of the officers of the extension council shall perform and carry out the officer\u8217\'3fs duties as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and shall perform and carry out any other duties as required by rules adopted by the extension council as authorized in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. A member of the extension council, within fifteen days after the member\u8217\'3fs election, shall take and sign the usual oath of public officers which shall be filed in the office of the county auditor of the county of the extension district. The treasurer of the extension council, within ten days after being elected and before entering upon the duties of the office, shall execute to the extension council a corporate surety bond for an amount not less than twenty thousand dollars. The bond shall be continued until the treasurer faithfully discharges the duties of the office. The bond shall be filed with the county auditor of the county of the extension district. The county auditor shall notify the chairperson of the extension council of the bond\u8217\'3fs filing in the auditor\u8217\'3fs office. The cost of the surety bond shall be paid for by the extension council.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71683-i, -j, -m; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2933, 2934, 2938;}}}{ C46, 50, 54, \'a7176.11, 176.12, 176.16; C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 73, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1107, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.502}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.15}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consolidation of extension districts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any two or more extension districts may be consolidated to form a single extension district, by resolution duly adopted by the extension council of each such extension district. Upon adoption of such resolutions providing for such consolidation, the extension councils shall do all things which may be necessary or convenient to carry into effect such consolidation. The initial extension council for such new extension district shall consist of the members of the extension councils of the consolidated extension districts. The extension council of such new extension district shall promptly elect officers as provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and upon such election the terms of the officers of the extension councils of the consolidated extension districts shall terminate. The extension council of the new extension district shall select a name for such district and shall file the name, together with copies of the resolution providing for such consolidation, with the recorder of each county affected thereby. The new extension district shall be regarded for all purposes as an extension district, the same as if such extension district consisted of a single county, and its extension council and officers thereof shall have all the powers and duties which now or hereafter may pertain to extension councils and officers thereof. All assets and liabilities of the consolidated extension districts shall become the assets and liabilities of the new extension district. The tax rate for the \u8220\'3fcounty agricultural extension education fund\u8221\'3f shall be the same in each county included in an extension district formed by consolidation. For the purposes of any law requiring extension districts to file any document with or certify any information to any county officer or board, an extension district formed by consolidation shall file or certify the same with or to the appropriate officer or board of each county included in the extension district. An extension district formed by consolidation may be dissolved and the original extension districts as they existed prior to such consolidation may be reestablished, by resolution duly adopted by the extension council of such extension district; and upon adoption of such resolution, the extension council shall do all things which may be necessary or convenient to carry into effect such dissolution and the reestablishment of the original extension districts.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{176A.16}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General election law applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{chapter 49}}}{ apply to the elections held pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, and the county commissioner of elections has responsibility for the conducting of those elections.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7176A.16}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1149, \'a77}}}\par}}