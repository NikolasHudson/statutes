phpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAlcohol concentration\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the number of grams of alcohol per any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One hundred milliliters of blood.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two hundred ten liters of breath.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sixty-seven milliliters of urine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAlcoholic beverage\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes alcohol, wine, spirits, beer, or any other beverage which contains ethyl alcohol and is fit for human consumption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fArrest\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to taking into custody pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 232.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fControlled substance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any drug, substance, or compound that is listed in }}}{{\f5\fs18\hyphpar0\qj{section 124.204}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{124.206}}}{{\f5\fs18\hyphpar0\qj{, or any metabolite or derivative of the drug, substance, or compound.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state department of transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of transportation or the director\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDriver\u8217\'3fs license\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any license or permit issued to a person to operate a motor vehicle on the highways of this state, including but not limited to a driver\u8217\'3fs, commercial driver\u8217\'3fs, temporary restricted, or temporary license and an instruction, chauffeur\u8217\'3fs instruction, commercial learner\u8217\'3fs, or temporary permit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeace officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the state patrol.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A police officer under civil service as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 400}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sheriff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A regular deputy sheriff who has had formal police training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other law enforcement officer who has satisfactorily completed an approved course relating to motor vehicle operators under the influence of alcoholic beverages at the Iowa law enforcement academy or a law enforcement training program approved by the department of public safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSerious injury\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.18}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1074, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 132, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 35, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1073, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a770}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.208}}}{{\f5\fs12\hyphpar0\qj{, 321J.2A}}}{{\f5\fs12\hyphpar0\qj{, 668.15A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.1A}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Drunk driving public education campaign \u8212\'3f pamphlets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of public safety, the governor\u8217\'3fs traffic safety bureau, the state department of transportation, the governor, and the attorney general shall cooperate in an ongoing public education campaign to inform the citizens of this state of the dangers and the specific legal consequences of driving drunk in this state. The entities shall use their best efforts to utilize all available opportunities for making public service announcements on television and radio broadcasts, and to obtain and utilize federal funds for highway safety and other grants in conducting the public education campaign.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall publish pamphlets containing the criminal and administrative penalties for drunk driving, and related laws, rules, instructions, and explanatory matter. This information may be included in publications containing information related to other motor vehicle laws, issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.15}}}{{\f5\fs18\hyphpar0\qj{. Copies of the pamphlets shall be given wide distribution, and a supply shall be made available to each county treasurer.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 177, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1013, \'a730, 35}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.2}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Operating while under the influence of alcohol or a drug or while having an alcohol concentration of .08 or more (OWI).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person commits the offense of operating while intoxicated if the person operates a motor vehicle in this state in any of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While under the influence of an alcoholic beverage or other drug or a combination of such substances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While having an alcohol concentration of .08 or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{While any amount of a controlled substance is present in the person, as measured in the person\u8217\'3fs blood or urine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ commits:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A serious misdemeanor for the first offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An aggravated misdemeanor for a second offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A class \u8220\'3fD\u8221\'3f felony for a third offense and each subsequent offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A first offense is punishable by all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A minimum period of imprisonment in the county jail of forty-eight hours, but not to exceed one year, to be served as ordered by the court, less credit for any time the person was confined in a jail or detention facility following arrest or for any time the person spent in a court-ordered operating-while-intoxicated program that provides law enforcement security. However, the court, in ordering service of the sentence and in its discretion, may accommodate the defendant\u8217\'3fs work schedule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With the consent of the defendant, the court may defer judgment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{ and may place the defendant on probation upon conditions as it may require. Upon a showing that the defendant is not fulfilling the conditions of probation, the court may revoke probation and impose any sentence authorized by law. Before taking such action, the court shall give the defendant an opportunity to be heard on any matter relevant to the proposed action. Upon violation of the conditions of probation, the court may proceed as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 908}}}{{\f5\fs18\hyphpar0\qj{. Upon fulfillment of the conditions of probation and the payment of fees imposed and not waived by the judicial district department of correctional services under }}}{{\f5\fs18\hyphpar0\qj{section 904.912}}}{{\f5\fs18\hyphpar0\qj{, the defendant shall be discharged without entry of judgment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person is not eligible for a deferred judgment under }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{ if the person has been convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or the person\u8217\'3fs driver\u8217\'3fs license has been revoked under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant\u8217\'3fs alcohol concentration established by the results of an analysis of a specimen of the defendant\u8217\'3fs blood, breath, or urine withdrawn in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ exceeds .15, regardless of whether or not the alcohol concentration indicated by the chemical test minus the established margin of error inherent in the device or method used to conduct the test equals an alcohol concentration of .15 or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant has previously been convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ or a statute in another state substantially corresponding to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant has previously received a deferred judgment or sentence for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ or for a violation of a statute in another state substantially corresponding to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant refused to consent to testing requested in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321J.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the offense under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ results in bodily injury to a person other than the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the offense was committed while also in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.279, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assessment of a fine of one thousand two hundred fifty dollars. However, in the discretion of the court, if no personal or property injury has resulted from the defendant\u8217\'3fs actions, the court may waive up to six hundred twenty-five dollars of the fine when the defendant presents to the court a temporary restricted license issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the entry of a deferred judgment, a civil penalty shall be assessed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 907.14}}}{{\f5\fs18\hyphpar0\qj{ in an amount not less than the amount of the criminal fine authorized pursuant to this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As an alternative to a portion or all of the fine, the court may order the person to perform unpaid community service. However, the court shall not order the person to perform unpaid community service in lieu of a civil penalty or victim restitution. Surcharges and fees shall also be assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 911}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revocation of the person\u8217\'3fs driver\u8217\'3fs license for a minimum period of one hundred eighty days up to a maximum revocation period of one year, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{section 321J.12}}}{{\f5\fs18\hyphpar0\qj{. The department shall require the defendant to install an ignition interlock device of a type approved by the commissioner of public safety on all vehicles operated by the defendant if the defendant seeks a temporary restricted license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assignment to substance use disorder evaluation and treatment, a course for drinking drivers, and, if available and appropriate, a reality education substance use disorder prevention program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A second offense is punishable by all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A minimum period of imprisonment in the county jail or community-based correctional facility of seven days but not to exceed two years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assessment of a minimum fine of one thousand eight hundred seventy-five dollars and a maximum fine of six thousand two hundred fifty dollars. Surcharges and fees shall be assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 911}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revocation of the defendant\u8217\'3fs driver\u8217\'3fs license for a period of one year, if a revocation occurs pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.12, subsection 1}}}{{\f5\fs18\hyphpar0\qj{. If a revocation occurs due to test refusal under }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{, or pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.4, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the defendant\u8217\'3fs license shall be revoked for a period of two years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assignment to substance use disorder evaluation and treatment, a course for drinking drivers, and, if available and appropriate, a reality education substance use disorder prevention program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A third or subsequent offense is punishable by all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Commitment to the custody of the director of the department of corrections for an indeterminate term not to exceed five years, with a mandatory minimum term of thirty days.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court does not suspend a person\u8217\'3fs sentence of commitment to the custody of the director of the department of corrections under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the person shall be assigned to a facility pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 904.513}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court suspends a person\u8217\'3fs sentence of commitment to the custody of the director of the department of corrections under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the court shall order the person to serve not less than thirty days nor more than one year in the county jail, and the person may be committed to treatment in the community under }}}{{\f5\fs18\hyphpar0\qj{section 907.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assessment of a minimum fine of three thousand one hundred twenty-five dollars and a maximum fine of nine thousand three hundred seventy-five dollars. Surcharges and fees shall be assessed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 911}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Revocation of the person\u8217\'3fs driver\u8217\'3fs license for a period of six years pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.4, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assignment to substance use disorder evaluation and treatment, a course for drinking drivers, and, if available and appropriate, a reality education substance use disorder prevention program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the maximum sentence set forth in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a person convicted of a third or subsequent offense may be sentenced as an habitual offender pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 902.8}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{902.9}}}{{\f5\fs18\hyphpar0\qj{ if the person qualifies as an habitual offender as described in }}}{{\f5\fs18\hyphpar0\qj{section 902.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the extent that }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{ allows, the court may impose additional sentencing terms and conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All persons convicted of an offense under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall be ordered, at the person\u8217\'3fs expense, to undergo, prior to sentencing, a substance use disorder evaluation. The court shall order the person to follow the recommendations proposed in the substance use disorder evaluation as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321J.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where the program is available and is appropriate for the convicted person, a person convicted of an offense under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall be ordered to participate in a reality education substance use disorder prevention program as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321J.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A minimum term of imprisonment in a county jail or community-based correctional facility imposed on a person convicted of a second or subsequent offense under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be served on consecutive days. However, if the sentencing court finds that service of the full minimum term on consecutive days would work an undue hardship on the person, or finds that sufficient jail space is not available and is not reasonably expected to become available within four months after sentencing to incarcerate the person serving the minimum sentence on consecutive days, the court may order the person to serve the minimum term in segments of at least forty-eight hours and to perform a specified number of hours of unpaid community service as deemed appropriate by the sentencing court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In determining if a violation charged is a second or subsequent offense for purposes of criminal sentencing or license revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any conviction or revocation deleted from motor vehicle operating records pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.12}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered as a previous offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Deferred judgments entered pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{ for violations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be counted as previous offenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Convictions or the equivalent of deferred judgments for violations in any other states under statutes substantially corresponding to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be counted as previous offenses. The courts shall judicially notice the statutes of other states which define offenses substantially equivalent to the one defined in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and can therefore be considered corresponding statutes. Each previous violation on which conviction or deferral of judgment was entered prior to the date of the violation charged shall be considered and counted as a separate previous offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be convicted and sentenced for more than one violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for actions arising out of the same event or occurrence, even if the event or occurrence involves more than one of the conditions specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court shall immediately certify to the department a true copy of each order entered with respect to deferral of judgment, deferral of sentence, or pronouncement of judgment and sentence for a defendant under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a person operating a motor vehicle while under the influence of a drug if the substance was prescribed for the person and was taken under the prescription and in accordance with the directions of a medical practitioner as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 155A}}}{{\f5\fs18\hyphpar0\qj{ or if the substance was dispensed by a pharmacist without a prescription pursuant to the rules of the board of pharmacy, if there is no evidence of the consumption of alcohol and the medical practitioner or pharmacist had not directed the person to refrain from operating a motor vehicle.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When charged with a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a person may assert, as an affirmative defense, that the controlled substance present in the person\u8217\'3fs blood or urine was prescribed or dispensed for the person and was taken in accordance with the directions of a practitioner and the labeling directions of the pharmacy, as that person and place of business are defined in }}}{{\f5\fs18\hyphpar0\qj{section 155A.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any prosecution under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, evidence of the results of analysis of a specimen of the defendant\u8217\'3fs blood, breath, or urine is admissible upon proof of a proper foundation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The alcohol concentration established by the results of an analysis of a specimen of the defendant\u8217\'3fs blood, breath, or urine withdrawn within two hours after the defendant was driving or in physical control of a motor vehicle is presumed to be the alcohol concentration at the time of driving or being in physical control of the motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The presence of a controlled substance or other drug established by the results of analysis of a specimen of the defendant\u8217\'3fs blood or urine withdrawn within two hours after the defendant was driving or in physical control of a motor vehicle is presumed to show the presence of such controlled substance or other drug in the defendant at the time of driving or being in physical control of the motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of public safety shall adopt nationally accepted standards for determining detectable levels of controlled substances in the division of criminal investigation\u8217\'3fs initial laboratory screening test for controlled substances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any fine or penalty imposed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the court shall order a defendant convicted of or receiving a deferred judgment for a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to make restitution for damages resulting directly from the violation, to the victim, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 910}}}{{\f5\fs18\hyphpar0\qj{. An amount paid pursuant to this restitution order shall be credited toward any adverse judgment in a subsequent civil proceeding arising from the same occurrence. However, other than establishing a credit, a restitution proceeding pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be given evidentiary or preclusive effect in a subsequent civil proceeding arising from the same occurrence.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may order restitution paid to any public agency for the costs of the emergency response resulting from the actions constituting a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, not exceeding five hundred dollars per public agency for each such response. For the purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femergency response\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any incident requiring response by fire fighting, law enforcement, ambulance, medical, or other emergency services. A public agency seeking such restitution shall consult with the county attorney regarding the expenses incurred by the public agency, and the county attorney may include the expenses in the statement of pecuniary damages pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 910.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any prosecution under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the results of a chemical test shall not be used to prove a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if the alcohol, controlled substance, or other drug concentration indicated by the chemical test minus the established margin of error inherent in the device or method used to conduct the chemical test does not equal or exceed the level prohibited by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 118, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 215, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1100, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a72, 3, 11 \u8211\'3f 13, 37}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 96, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1118, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1135, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1042, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 60, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7120}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2003 Acts, 1st Ex, ch 2, \'a748, 209}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a790}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1166, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a7174}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1124, \'a71, 9}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a750, 81}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 131, \'a793, 158}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1110, \'a72, 3, 9}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 5, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1028, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 98, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71067 \u8211\'3f 1070}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 42, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a750}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a781.1}}}{{\f5\fs12\hyphpar0\qj{, 135B.34}}}{{\f5\fs12\hyphpar0\qj{, 135C.33}}}{{\f5\fs12\hyphpar0\qj{, 232.22}}}{{\f5\fs12\hyphpar0\qj{, 232.150}}}{{\f5\fs12\hyphpar0\qj{, 321.12}}}{{\f5\fs12\hyphpar0\qj{, 321.208}}}{{\f5\fs12\hyphpar0\qj{, 321.213}}}{{\f5\fs12\hyphpar0\qj{, 321.241}}}{{\f5\fs12\hyphpar0\qj{, 321.555}}}{{\f5\fs12\hyphpar0\qj{, 321J.2A}}}{{\f5\fs12\hyphpar0\qj{, 321J.2B}}}{{\f5\fs12\hyphpar0\qj{, 321J.3}}}{{\f5\fs12\hyphpar0\qj{, 321J.4}}}{{\f5\fs12\hyphpar0\qj{, 321J.4B}}}{{\f5\fs12\hyphpar0\qj{, 321J.5}}}{{\f5\fs12\hyphpar0\qj{, 321J.6}}}{{\f5\fs12\hyphpar0\qj{, 321J.8}}}{{\f5\fs12\hyphpar0\qj{, 321J.9}}}{{\f5\fs12\hyphpar0\qj{, 321J.10}}}{{\f5\fs12\hyphpar0\qj{, 321J.10A}}}{{\f5\fs12\hyphpar0\qj{, 321J.12}}}{{\f5\fs12\hyphpar0\qj{, 321J.13}}}{{\f5\fs12\hyphpar0\qj{, 321J.15}}}{{\f5\fs12\hyphpar0\qj{, 321J.16}}}{{\f5\fs12\hyphpar0\qj{, 321J.20}}}{{\f5\fs12\hyphpar0\qj{, 321J.22}}}{{\f5\fs12\hyphpar0\qj{, 321J.24}}}{{\f5\fs12\hyphpar0\qj{, 321J.25}}}{{\f5\fs12\hyphpar0\qj{, 321N.3}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(51)}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}{{\f5\fs12\hyphpar0\qj{, 724.4C}}}{{\f5\fs12\hyphpar0\qj{, 724.15}}}{{\f5\fs12\hyphpar0\qj{, 724.16}}}{{\f5\fs12\hyphpar0\qj{, 724.22}}}{{\f5\fs12\hyphpar0\qj{, 726.6}}}{{\f5\fs12\hyphpar0\qj{, 804.31}}}{{\f5\fs12\hyphpar0\qj{, 901C.3}}}{{\f5\fs12\hyphpar0\qj{, 902.3}}}{{\f5\fs12\hyphpar0\qj{, 907.3}}}{{\f5\fs12\hyphpar0\qj{, 910.1}}}{{\f5\fs12\hyphpar0\qj{, 910.3}}}{{\f5\fs12\hyphpar0\qj{, 915.80}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For provisions relating to third offense OWI driver\u8217\'3fs license revocations and restoration of driving privileges, see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/99/CH0153.pdf" }{\fldrslt \cf5 \f5 \fs12{{99 Acts, ch 153, \'a725}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.2A}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons under the age of twenty-one.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is under the age of twenty-one shall not operate a motor vehicle while having an alcohol concentration, as defined under }}}{{\f5\fs18\hyphpar0\qj{section 321J.1}}}{{\f5\fs18\hyphpar0\qj{, of .02 or more. The driver\u8217\'3fs license or nonresident operating privilege of a person who is under the age of twenty-one and who operates a motor vehicle while having an alcohol concentration of .02 or more shall be revoked by the department for the period of time specified under }}}{{\f5\fs18\hyphpar0\qj{section 321J.12}}}{{\f5\fs18\hyphpar0\qj{. A revocation under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not preclude a prosecution or conviction under any applicable criminal provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. However, if the person is convicted of a criminal offense under }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, the revocation imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be superseded by any revocation imposed as a result of the conviction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any proceeding regarding a revocation under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, evidence of the results of analysis of a specimen of the defendant\u8217\'3fs blood, breath, or urine is admissible upon proof of a proper foundation. The alcohol concentration established by the results of an analysis of a specimen of the defendant\u8217\'3fs blood, breath, or urine withdrawn within two hours after the defendant was driving or in physical control of a motor vehicle is presumed to be the alcohol concentration at the time of driving or being in physical control of the motor vehicle.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 48, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.12}}}{{\f5\fs12\hyphpar0\qj{, 321.241}}}{{\f5\fs12\hyphpar0\qj{, 321A.17}}}{{\f5\fs12\hyphpar0\qj{, 321J.2B}}}{{\f5\fs12\hyphpar0\qj{, 321J.5}}}{{\f5\fs12\hyphpar0\qj{, 321J.6}}}{{\f5\fs12\hyphpar0\qj{, 321J.8}}}{{\f5\fs12\hyphpar0\qj{, 321J.9}}}{{\f5\fs12\hyphpar0\qj{, 321J.10A}}}{{\f5\fs12\hyphpar0\qj{, 321J.12}}}{{\f5\fs12\hyphpar0\qj{, 321J.13}}}{{\f5\fs12\hyphpar0\qj{, 321J.15}}}{{\f5\fs12\hyphpar0\qj{, 321J.16}}}{{\f5\fs12\hyphpar0\qj{, 321J.20}}}{{\f5\fs12\hyphpar0\qj{, 321J.25}}}{{\f5\fs12\hyphpar0\qj{, 321N.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.2B}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Parental and school notification \u8212\'3f persons under eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer shall make a reasonable effort to identify a person under the age of eighteen who violates }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{ and, if the person is not referred to juvenile court, the law enforcement agency of which the peace officer is an employee shall make a reasonable attempt to notify the person\u8217\'3fs custodial parent or legal guardian of the violation, whether or not the person is taken into custody, unless the officer has reasonable grounds to believe that notification is not in the best interests of the person or will endanger that person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The peace officer shall also make a reasonable effort to identify the elementary or secondary school which the person attends if the person is enrolled in elementary or secondary school and to notify the superintendent or the superintendent\u8217\'3fs designee of the school which the person attends, or the authorities in charge of the nonpublic school which the person attends, of the violation. If the person is taken into custody, the peace officer shall notify a juvenile court officer who shall make a reasonable effort to identify the elementary or secondary school the person attends, if any, and to notify the superintendent of the school district or the superintendent\u8217\'3fs designee, or the authorities in charge of the nonpublic school, of the violation. A reasonable attempt to notify the person includes, but is not limited to, a telephone call or notice by first-class mail.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1138, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7232.147}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.3}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Substance use disorder evaluation or treatment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to orders issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.2, subsections 3, 4, and 5}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 321J.17}}}{{\f5\fs18\hyphpar0\qj{, the court shall order any defendant convicted under }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ to follow the recommendations proposed in the substance use disorder evaluation for appropriate substance use disorder treatment for the defendant. Court-ordered substance use disorder treatment is subject to the periodic reporting requirements of }}}{{\f5\fs18\hyphpar0\qj{section 125.86}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a defendant is committed by the court to a substance use disorder treatment facility, the administrator of the facility shall report to the court when it is determined that the defendant has received the maximum benefit of treatment at the facility and the defendant shall be released from the facility. The time for which the defendant is committed for treatment shall be credited against the defendant\u8217\'3fs sentence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may prescribe the length of time for the evaluation and treatment or it may request that the community college or other approved provider conducting the course for drinking drivers which the person is ordered to attend or the treatment program to which the person is committed immediately report to the court when the person has received maximum benefit from the course for drinking drivers or treatment program or has recovered from the person\u8217\'3fs addiction, dependency, or tendency to chronically use alcohol or drugs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon successfully completing a course for drinking drivers or an ordered substance use disorder treatment program, a court may place the person on probation for six months and as a condition of probation, the person shall attend a program providing posttreatment services relating to substance use disorder as approved by the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person committed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ who does not possess sufficient income or estate to make payment of the costs of the treatment in whole or in part shall be considered a state patient and the costs of treatment shall be paid as provided in }}}{{\f5\fs18\hyphpar0\qj{section 125.44}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant who fails to carry out the order of the court shall be confined in the county jail for twenty days in addition to any other imprisonment ordered by the court or may be ordered to perform unpaid community service work, and shall be placed on probation for one year with a violation of this probation punishable as contempt of court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other condition of probation, the person shall attend a program providing substance use disorder prevention services or posttreatment services related to substance use disorder as ordered by the court. The person shall report to the person\u8217\'3fs probation officer as ordered concerning proof of attendance at the treatment program or posttreatment program ordered by the court. Failure to attend or complete the program shall be considered a violation of probation and is punishable as contempt of court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a second or subsequent offense in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, the court upon hearing may commit the defendant for inpatient treatment of alcoholism or drug addiction or dependency to any hospital, institution, or community correctional facility in Iowa providing such treatment. The time for which the defendant is committed for treatment shall be credited against the defendant\u8217\'3fs sentence.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court may prescribe the length of time for the evaluation and treatment or it may request that the hospital to which the person is committed immediately report to the court when the person has received maximum benefit from the program of the hospital or institution or has recovered from the person\u8217\'3fs addiction, dependency, or tendency to chronically use alcohol or drugs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person committed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ who does not possess sufficient income or estate to make payment of the costs of the treatment in whole or in part shall be considered a state patient and the costs of treatment shall be paid as provided in }}}{{\f5\fs18\hyphpar0\qj{section 125.44}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state department of transportation, in cooperation with the judicial branch, shall adopt rules, pursuant to the procedure in }}}{{\f5\fs18\hyphpar0\qj{section 125.33}}}{{\f5\fs18\hyphpar0\qj{, regarding the assignment of persons ordered under }}}{{\f5\fs18\hyphpar0\qj{section 321J.17}}}{{\f5\fs18\hyphpar0\qj{ to submit to substance use disorder evaluation and treatment. The rules shall be applicable only to persons other than those committed to the custody of the director of the department of corrections under }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{. The rules shall be consistent with the practices and procedures of the judicial branch in sentencing persons to substance use disorder evaluation and treatment under }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{. The rules shall include the requirement that the treatment programs utilized by a person pursuant to an order of the department of transportation meet the licensure standards of the department of health and human services for substance use disorder treatment programs under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{. The rules shall also include provisions for payment of costs by the offenders, including insurance reimbursement on behalf of offenders, or other forms of funding, and shall also address reporting requirements of the facility, consistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 125.84}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{125.86}}}{{\f5\fs18\hyphpar0\qj{. The department of transportation shall be entitled to treatment information contained in reports to the department of transportation, notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{ that would restrict department access to treatment information and records.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 118, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1047, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a791}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1124, \'a72, 9}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 20, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71071}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.44}}}{{\f5\fs12\hyphpar0\qj{, 321.213}}}{{\f5\fs12\hyphpar0\qj{, 321J.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.4}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revocation of license \u8212\'3f ignition interlock devices \u8212\'3f temporary restricted license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a defendant is convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ and the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege has not been revoked under }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.12}}}{{\f5\fs18\hyphpar0\qj{ for the occurrence from which the arrest arose, the department shall revoke the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege for one hundred eighty days if the defendant submitted to chemical testing and has had no previous conviction or revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall revoke the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege for one year if the defendant refused to submit to chemical testing and has had no previous conviction or revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The department shall require the defendant to install an ignition interlock device of a type approved by the commissioner of public safety on all vehicles operated by the defendant if the defendant seeks a temporary restricted license. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a defendant is convicted of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, and the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege has not already been revoked under }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.12}}}{{\f5\fs18\hyphpar0\qj{ for the occurrence from which the arrest arose, the department shall revoke the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege for one year if the defendant submitted to chemical testing and has had a previous conviction or revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall revoke the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege for two years if the defendant refused to submit to chemical testing and has had a previous revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The department shall require the defendant to install an ignition interlock device of a type approved by the commissioner of public safety on all vehicles operated by the defendant if the defendant seeks a temporary restricted license. A temporary restricted license shall not be granted by the department until the defendant installs the ignition interlock device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court defers judgment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 907.3}}}{{\f5\fs18\hyphpar0\qj{ for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, and if the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege has not been revoked under }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.12}}}{{\f5\fs18\hyphpar0\qj{, or has not otherwise been revoked for the occurrence from which the arrest arose, the department shall revoke the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege for a period of not less than thirty days nor more than ninety days. The department shall require the defendant to install an ignition interlock device of a type approved by the commissioner of public safety on all vehicles operated by the defendant if the defendant seeks a temporary restricted license. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a plea or verdict of guilty of a third or subsequent violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, the department shall revoke the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege for a period of six years. The department shall require the defendant to install an ignition interlock device of a type approved by the commissioner of public safety on all vehicles operated by the defendant if the defendant seeks a temporary restricted license. A temporary restricted license shall not be granted by the department until the defendant installs the ignition interlock device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a plea or verdict of guilty of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ which involved a personal injury, the court shall determine in open court, from consideration of the information in the file and any other evidence the parties may submit, whether a serious injury was sustained by any person other than the defendant and, if so, whether the defendant\u8217\'3fs conduct in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ caused the serious injury. If the court so determines, the court shall order the department to revoke the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege for a period of one year in addition to any other period of suspension or revocation. The defendant shall surrender to the court any Iowa license or permit and the court shall forward it to the department with a copy of the order for revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a plea or verdict of guilty of a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ which involved a death, the court shall determine in open court, from consideration of the information in the file and any other evidence the parties may submit, whether a death occurred and, if so, whether the defendant\u8217\'3fs conduct in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ caused the death. If the court so determines, the court shall order the department to revoke the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege for a period of six years. The defendant shall not be eligible for any temporary restricted license for at least two years after the revocation. The defendant shall surrender to the court any Iowa license or permit and the court shall forward it to the department with a copy of the order for revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a license or permit to operate a motor vehicle is revoked or denied under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.12}}}{{\f5\fs18\hyphpar0\qj{, the period of revocation or denial shall be the period provided for such a revocation or until the defendant reaches the age of eighteen whichever period is longer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On a conviction for or as a condition of a deferred judgment for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, the court may order the defendant to install ignition interlock devices of a type approved by the commissioner of public safety on all motor vehicles operated by the defendant which, without tampering or the intervention of another person, would prevent the defendant from operating the motor vehicle with an alcohol concentration greater than a level set by rule of the commissioner of public safety. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner of public safety shall adopt rules to approve certain ignition interlock devices and the means of installation of the devices, and shall establish the level of alcohol concentration beyond which an ignition interlock device will not allow operation of the motor vehicle in which it is installed, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321J.17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The order to install ignition interlock devices shall remain in effect for a period of time as determined by the court which shall not exceed the maximum term of imprisonment which the court could have imposed according to the nature of the violation, unless otherwise extended under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. While the order is in effect, the defendant shall not operate a motor vehicle which does not have an approved ignition interlock device installed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege has been revoked, the department shall not issue a temporary permit or a driver\u8217\'3fs license to the person without certification that approved ignition interlock devices have been installed on all motor vehicles operated by the defendant while the order is in effect. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A defendant who fails within a reasonable time to comply with an order to install an approved ignition interlock device may be declared in contempt of court and punished accordingly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who tampers with or circumvents an ignition interlock device installed under a court order while an order is in effect commits a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ignition interlock device provider shall not impose an early termination fee if the defendant is no longer required to have a device installed and presents an unrestricted driver\u8217\'3fs license to the provider prior to the end of the term for which the provider agreed to provide the defendant with a device.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1168, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a784}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1212, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a78 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 55, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1090, \'a79 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1152, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a78 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79, 12}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a74, 36, 37}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1138, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 60, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7121, 122}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 143, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1097, \'a74 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1110, \'a74, 9}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 98, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1050, \'a71 \u8211\'3f 3, 10, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.213}}}{{\f5\fs12\hyphpar0\qj{, 321J.2}}}{{\f5\fs12\hyphpar0\qj{, 321J.17}}}{{\f5\fs12\hyphpar0\qj{, 321J.20}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For provisions relating to third offense OWI driver\u8217\'3fs license revocations and restoration of driving privileges, see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/99/CH0153.pdf" }{\fldrslt \cf5 \f5 \fs12{{99 Acts, ch 153, \'a725}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendments to section effective January 1, 2025, and apply to driver\u8217\'3fs license revocations under }{{\f5\fs12\hyphpar0\qj{chapter 321J}}}{ for which the underlying offense occurred on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1050.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1050, \'a710, 11}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.4A}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.4B}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motor vehicle impoundment or immobilization \u8212\'3f penalty \u8212\'3f liability of vehicle owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fImmobilized\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the installation of a device in a motor vehicle that completely prevents a motor vehicle from being operated, or the installation of an ignition interlock device of a type approved by the commissioner of public safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fImpoundment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the process of seizure and confinement within an enclosed area of a motor vehicle, for the purpose of restricting access to the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOwner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the registered titleholder of a motor vehicle; except in the case where a rental or leasing agency is the registered titleholder, in which case the lessee of the vehicle shall be treated as the owner of the vehicle for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle is subject to impoundment in the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person operates a vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, and if convicted for that conduct, the conviction would be a second or subsequent offense under }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person operates a vehicle while that person\u8217\'3fs driver\u8217\'3fs license or operating privilege has been suspended, denied, revoked, or barred due to a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of court shall send notice of a conviction of an offense for which the vehicle was impounded to the impounding authority upon conviction of the defendant for such offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Impoundment of the vehicle under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may occur in addition to any criminal penalty imposed under }}}{{\f5\fs18\hyphpar0\qj{chapter 321}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the underlying criminal offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motor vehicle operated by the person in the commission of any offense included in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ may be immediately impounded or immobilized in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or agency taking possession of an impounded or immobilized motor vehicle shall do the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make an inventory of any property contained in the vehicle, according to the agency\u8217\'3fs inventory procedure. The agency responsible for the motor vehicle shall also deliver a copy of the inventory to the county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contact all rental or leasing agencies registered as owners of the vehicle, as well as any parties registered as holders of a secured interest in the vehicle, in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county attorney shall file a copy of the inventory with the district court as part of each file related to criminal charges filed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner of a motor vehicle impounded or immobilized under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, who knows of, should have known of, or gives consent to the operation of, the motor vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), shall be:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Guilty of a simple misdemeanor, and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Jointly and severally liable for any damages caused by the person who operated the motor vehicle, subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 668}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following persons shall be entitled to immediate return of the motor vehicle without payment of costs associated with the impoundment or immobilization of the vehicle:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner of the motor vehicle, if the person who operated the motor vehicle is not a co-owner of the motor vehicle.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle rental or leasing agency that owns the vehicle.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who owns the motor vehicle and who is charged but is not convicted of the violation of }}}{{\f5\fs18\hyphpar0\qj{section 321.218}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321.561}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321A.32}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{321J.2}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{321J.21}}}{{\f5\fs18\hyphpar0\qj{, which resulted in the impoundment or immobilization of the motor vehicle under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon conviction of the defendant for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), the court may order continued impoundment, or the immobilization, of the motor vehicle used in the commission of the offense, if the convicted person is the owner of the motor vehicle, and shall specify all of the following in the order:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The motor vehicle that is subject to the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The period of impoundment or immobilization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person or agency responsible for carrying out the order requiring continued impoundment, or the immobilization, of the motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle subject to the order is in the custody of a law enforcement agency, the court shall designate that agency as the responsible agency. If the vehicle is not in the custody of a law enforcement agency, the person or agency responsible for carrying out the order shall be any person deemed appropriate by the court, including but not limited to a law enforcement agency with jurisdiction over the area in which the residence of the vehicle owner is located. The person or agency responsible for carrying out the order shall determine whether the motor vehicle shall be impounded or immobilized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The period of impoundment or immobilization of a motor vehicle under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be the period of license revocation imposed upon the person convicted of the offense or one hundred eighty days, whichever period is longer. The impoundment or immobilization period shall commence on the day that the vehicle is first impounded or immobilized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court shall send a copy of the order to the department, the person convicted of the offense, the person or agency responsible for executing the order for impoundment or immobilization, and any holders of any security interests in the vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle subject to the court order is not in the custody of a law enforcement agency, the person or agency designated in the order as the person or agency responsible for executing the order shall, upon receipt of the order, promptly locate the vehicle specified in the order, seize the motor vehicle and the license plates, and send or deliver the vehicle\u8217\'3fs license plates to the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the vehicle is located at a place other than the place at which the court order is to be carried out, the person or agency responsible for executing the order shall arrange for the vehicle to be moved to the place of impoundment or immobilization. When the vehicle is found, is impounded or immobilized, and is at the place of impoundment or immobilization, the person or agency responsible for executing the order shall notify the clerk of the date on which the order was executed. The clerk shall notify the department of the date on which the order was executed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a court order for continued impoundment or immobilization of the motor vehicle, the agency shall review the value of the vehicle in relation to the costs associated with the period of impoundment of the motor vehicle specified in the order. If the agency determines that the costs of impoundment of the motor vehicle exceed the actual wholesale value of the motor vehicle, the agency may treat the vehicle as an abandoned vehicle pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.89}}}{{\f5\fs18\hyphpar0\qj{. If the agency elects to treat the motor vehicle as abandoned, the agency shall notify the registered owner of the motor vehicle that the vehicle shall be deemed abandoned and shall be sold in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.89}}}{{\f5\fs18\hyphpar0\qj{ if payment of the total cost of impoundment is not received within twenty-one days of the mailing of the notice. The agency shall provide documentation regarding the valuation of the vehicle and the costs of impoundment. This paragraph shall not apply to vehicles that are immobilized pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or if }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1) or (2), applies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon conviction of the defendant for a second or subsequent violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), the court shall order, if the convicted person is the owner of the motor vehicle used in the commission of the offense, that that motor vehicle be seized and forfeited to the state pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapters 809}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{809A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a notice of conviction of the defendant for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the impounding authority shall seize the motor vehicle\u8217\'3fs license plates and registration, and shall send or deliver them to the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall destroy license plates received under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and shall not authorize the release of the vehicle or the issuance of new license plates for the vehicle until the period of impoundment or immobilization has expired, and the fee and costs assessed under }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{ have been paid. The fee for issuance of new license plates and certificates of registration shall be the same as for the replacement of lost, mutilated, or destroyed license plates and certificates of registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon conviction for a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the court shall assess the defendant, in addition to any other penalty, a fee of one hundred dollars plus the cost of any expenses for towing, storage, and any other costs of impounding or immobilizing the motor vehicle, to be paid to the clerk of the district court.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person or agency responsible for impoundment or immobilization under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall inform the court of the costs of towing, storage, and any other costs of impounding or immobilizing the motor vehicle. Upon payment of the fee and costs, the clerk shall forward a copy of the receipt to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a law enforcement agency impounds or immobilizes a motor vehicle, the amount of the fee and expenses deposited with the clerk shall be paid by the clerk to the law enforcement agency responsible for executing the order to reimburse the agency for costs incurred for impoundment or immobilization equipment and, if required, in sending officers to search for and locate the vehicle specified in the impoundment or immobilization order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operating a motor vehicle on a street or highway in this state in violation of an order of impoundment or immobilization is a serious misdemeanor. A motor vehicle which is subject to an order of impoundment or immobilization that is operated on a street or highway in this state in violation of the order shall be seized and forfeited to the state under }}}{{\f5\fs18\hyphpar0\qj{chapters 809}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{809A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once the period of impoundment or immobilization has expired, the owner of the motor vehicle shall have thirty days to claim the motor vehicle and pay all fees and charges imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. If the owner or the owner\u8217\'3fs designee has not claimed the vehicle and paid all fees and charges imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ within seven days from the date of expiration of the period, the clerk shall send written notification to the motor vehicle owner, at the owner\u8217\'3fs last known address, notifying the owner of the date of expiration of the period of impoundment or immobilization and of the period in which the motor vehicle must be claimed. If the motor vehicle owner fails to claim the motor vehicle and pay all fees and charges imposed within the thirty-day period, the motor vehicle shall be forfeited to the state under }}}{{\f5\fs18\hyphpar0\qj{chapters 809}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{809A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{During the period of impoundment or immobilization the owner of an impounded or immobilized vehicle shall not sell or transfer the title of the motor vehicle which is subject to the order of impoundment or immobilization.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person convicted of an offense under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall not purchase or register any motor vehicle during the period of impoundment, immobilization, or license revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, during the period of impoundment or immobilization, the title to the motor vehicle which is the subject of the order is transferred by the foreclosure of a chattel mortgage, a sale upon execution, the cancellation of a conditional sales contract, or an order of a court, the court which enters the order that permits transfer of the title shall notify the department of the transfer of the title. The department shall enter notice of the transfer of the title to the motor vehicle in the previous owner\u8217\'3fs vehicle registration record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violation of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding other requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon learning the address or phone number of a rental or leasing company which owns a motor vehicle impounded or immobilized under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the peace officer, county attorney, or attorney general shall immediately contact the company to inform the company that the vehicle is available for return to the company.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The holder of a security interest in a vehicle which is impounded or immobilized pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or forfeited in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{chapters 809}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{809A}}}{{\f5\fs18\hyphpar0\qj{ shall be notified of the impoundment, immobilization, or forfeiture within seventy-two hours of the seizure of the vehicle and shall have the right to claim the motor vehicle without payment of any fees or surcharges unless the value of the vehicle exceeds the value of the security interest held by the creditor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of the following persons may make application to the court for permission to operate a motor vehicle, which is impounded or immobilized pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, during the period of impoundment or immobilization, if the applicant\u8217\'3fs driver\u8217\'3fs license or operating privilege has not been suspended, denied, revoked, or barred, and an ignition interlock device of a type approved by the commissioner of public safety is installed in the motor vehicle prior to operation:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, other than the person who committed the offense which resulted in the impoundment or immobilization, who is not a member of the immediate family of the person who committed the offense but is a joint owner of the motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the immediate family of the person who committed the offense which resulted in the impoundment or immobilization, if the member demonstrates that the motor vehicle that is subject to the order for impoundment or immobilization is the only motor vehicle possessed by the family.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa member of the immediate family\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a spouse, child, or parent of the person who committed the offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The impoundment, immobilization, or forfeiture of a motor vehicle under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ does not constitute loss of use of a motor vehicle for purposes of any contract of insurance.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 48, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 143, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1133, \'a742, 43}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a7103 \u8211\'3f 106}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.89}}}{{\f5\fs12\hyphpar0\qj{, 809A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.5}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Preliminary screening test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a peace officer has reasonable grounds to believe that either of the following have occurred, the peace officer may request that the operator provide a sample of the operator\u8217\'3fs breath for a preliminary screening test using a device approved by the commissioner of public safety for that purpose:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A motor vehicle operator may be violating or has violated }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operator has been involved in a motor vehicle collision resulting in injury or death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The results of this preliminary screening test may be used for the purpose of deciding whether an arrest should be made or whether to request a chemical test authorized in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, but shall not be used in any court action except to prove that a chemical test was properly requested of a person pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 48, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.6}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Implied consent to test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who operates a motor vehicle in this state under circumstances which give reasonable grounds to believe that the person has been operating a motor vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{ is deemed to have given consent to the withdrawal of specimens of the person\u8217\'3fs blood, breath, or urine and to a chemical test or tests of the specimens for the purpose of determining the alcohol concentration or presence of a controlled substance or other drugs, subject to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The withdrawal of the body substances and the test or tests shall be administered at the written request of a peace officer having reasonable grounds to believe that the person was operating a motor vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{, and if any of the following conditions exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer has lawfully placed the person under arrest for violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has been involved in a motor vehicle accident or collision resulting in personal injury or death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person has refused to take a preliminary breath screening test provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The preliminary breath screening test was administered and it indicated an alcohol concentration equal to or in excess of the level prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The preliminary breath screening test was administered to a person operating a commercial motor vehicle as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1}}}{{\f5\fs18\hyphpar0\qj{ and it indicated an alcohol concentration of 0.04 or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The preliminary breath screening test was administered and it indicated an alcohol concentration less than the level prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, and the peace officer has reasonable grounds to believe that the person was under the influence of a controlled substance, a drug other than alcohol, or a combination of alcohol and another drug.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The preliminary breath screening test was administered and it indicated an alcohol concentration of .02 or more but less than .08 and the person is under the age of twenty-one.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The peace officer shall determine which of the three substances, breath, blood, or urine, shall be tested. Refusal to submit to a chemical test of urine or breath is deemed a refusal to submit, and }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{ applies. A refusal to submit to a chemical test of blood is not deemed a refusal to submit, but in that case, the peace officer shall then determine which one of the other two substances shall be tested and shall offer the test. If the peace officer fails to offer a test within two hours after the preliminary screening test is administered or refused or the arrest is made, whichever occurs first, a test is not required, and there shall be no revocation under }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if the peace officer has reasonable grounds to believe that the person was under the influence of a controlled substance, a drug other than alcohol, or a combination of alcohol and another drug, a blood or urine test shall be required even after another type of test has been administered. }}}{{\f5\fs18\hyphpar0\qj{Section 321J.9}}}{{\f5\fs18\hyphpar0\qj{ applies to a refusal to submit to a chemical test of urine or blood requested under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a785}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 48, \'a713, 14}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1138, \'a714 \u8211\'3f 16}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 60, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.2}}}{{\f5\fs12\hyphpar0\qj{, 321J.7}}}{{\f5\fs12\hyphpar0\qj{, 321J.9}}}{{\f5\fs12\hyphpar0\qj{, 321J.10}}}{{\f5\fs12\hyphpar0\qj{, 321J.12}}}{{\f5\fs12\hyphpar0\qj{, 907.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.7}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dead or unconscious persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person who is dead, unconscious, or otherwise in a condition rendering the person incapable of consent or refusal is deemed not to have withdrawn the consent provided by }{{\f5\fs18\hyphpar0\qj{section 321J.6}}}{, and the test may be given if a licensed physician, physician assistant, or advanced registered nurse practitioner certifies in advance of the test that the person is unconscious or otherwise in a condition rendering that person incapable of consent or refusal. If the certification is oral, a written certification shall be completed by the physician, physician assistant, or advanced registered nurse practitioner within a reasonable time of the test.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 147, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 177, \'a713}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 49, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.8}}}{{\f5\fs12\hyphpar0\qj{, 321J.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.8}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statement of officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has been requested to submit to a chemical test shall be advised by a peace officer of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person refuses to submit to the test, the person\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege will be revoked by the department as required by and for the applicable period specified under }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person submits to the test and the results indicate the presence of a controlled substance or other drug, or an alcohol concentration equal to or in excess of the level prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{, the person\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege will be revoked by the department as required by and for the applicable period specified under }}}{{\f5\fs18\hyphpar0\qj{section 321J.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is operating a commercial motor vehicle as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1}}}{{\f5\fs18\hyphpar0\qj{ and either refuses to submit to the test or submits to the test and the results indicate an alcohol concentration of 0.04 or more, the person is disqualified from operating a commercial motor vehicle for the applicable period under }}}{{\f5\fs18\hyphpar0\qj{section 321.208}}}{{\f5\fs18\hyphpar0\qj{ in addition to any revocation of the person\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege which may be applicable under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is operating a noncommercial motor vehicle and holding a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit as defined in }}}{{\f5\fs18\hyphpar0\qj{section 321.1}}}{{\f5\fs18\hyphpar0\qj{ and either refuses to submit to the test or submits to the test and the results indicate the presence of a controlled substance or other drug or an alcohol concentration equal to or in excess of the level prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, the person is disqualified from operating a commercial motor vehicle for the applicable period under }}}{{\f5\fs18\hyphpar0\qj{section 321.208}}}{{\f5\fs18\hyphpar0\qj{ in addition to any revocation of the person\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege which may be applicable under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply in any case involving a person described in }}}{{\f5\fs18\hyphpar0\qj{section 321J.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 69, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a771}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.9}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Refusal to submit \u8212\'3f revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person refuses to submit to the chemical testing, a test shall not be given, but the department, upon the receipt of the peace officer\u8217\'3fs certification, subject to penalty for perjury, that the officer had reasonable grounds to believe the person to have been operating a motor vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{, that specified conditions existed for chemical testing pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.6}}}{{\f5\fs18\hyphpar0\qj{, and that the person refused to submit to the chemical testing, shall revoke the person\u8217\'3fs driver\u8217\'3fs license and any nonresident operating privilege for the following periods of time:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One year if the person has no previous revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two years if the person has had a previous revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall require the defendant to install an ignition interlock device of a type approved by the commissioner of public safety on all vehicles operated by the defendant if the defendant seeks a temporary restricted license. A temporary restricted license shall not be granted by the department until the defendant installs the ignition interlock device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is a resident without a license or permit to operate a motor vehicle in this state, the department shall deny to the person the issuance of a license or permit for the same period a license or permit would be revoked, subject to review as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The effective date of revocation shall be ten days after the department has mailed notice of revocation to the person by first class mail, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. The peace officer who requested or directed the administration of a chemical test may, on behalf of the department, serve immediate notice of intention to revoke and of revocation on a person who refuses to permit chemical testing. If the peace officer serves immediate notice, the peace officer shall take the Iowa license or permit of the driver, if any, and issue a temporary license effective for ten days. The peace officer shall immediately send the person\u8217\'3fs license to the department along with the officer\u8217\'3fs certificate indicating the person\u8217\'3fs refusal to submit to chemical testing.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1097, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1110, \'a75, 9}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 98, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1050, \'a74, 10, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.211A}}}{{\f5\fs12\hyphpar0\qj{, 321J.2}}}{{\f5\fs12\hyphpar0\qj{, 321J.4}}}{{\f5\fs12\hyphpar0\qj{, 321J.6}}}{{\f5\fs12\hyphpar0\qj{, 321J.8}}}{{\f5\fs12\hyphpar0\qj{, 321J.10}}}{{\f5\fs12\hyphpar0\qj{, 321J.13}}}{{\f5\fs12\hyphpar0\qj{, 915.80}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 2 effective January 1, 2025, and applies to driver\u8217\'3fs license revocations under chapter 321J for which the underlying offense occurred on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1050.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1050, \'a710, 11}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.10}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tests pursuant to warrants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refusal to consent to a test under }}}{{\f5\fs18\hyphpar0\qj{section 321J.6}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit the withdrawal of a specimen for chemical testing pursuant to a search warrant issued in the investigation of a suspected violation of }}}{{\f5\fs18\hyphpar0\qj{section 707.5}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{707.6A}}}{{\f5\fs18\hyphpar0\qj{ if all of the following grounds exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A traffic accident has resulted in a death or personal injury reasonably likely to cause death.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There are reasonable grounds to believe that one or more of the persons whose driving may have been the proximate cause of the accident was violating }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ at the time of the accident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Search warrants may be issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in full compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 808}}}{{\f5\fs18\hyphpar0\qj{ or they may be issued under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 808.3}}}{{\f5\fs18\hyphpar0\qj{, the issuance of a search warrant under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be based upon sworn oral testimony communicated by telephone if the magistrate who is asked to issue the warrant is satisfied that the circumstances make it reasonable to dispense with a written affidavit. The following shall then apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a caller applies for the issuance of a warrant under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the magistrate becomes aware of the purpose of the call, the magistrate shall place under oath the person applying for the warrant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person applying for the warrant shall prepare a duplicate warrant and read the duplicate warrant, verbatim, to the magistrate who shall enter, verbatim, what is read to the magistrate on a form that will be considered the original warrant. The magistrate may direct that the warrant be modified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The oral application testimony shall set forth facts and information tending to establish the existence of the grounds for the warrant and shall describe with a reasonable degree of specificity the person or persons whose driving is believed to have been the proximate cause of the accident and from whom a specimen is to be withdrawn and the location where the withdrawal of the specimen or specimens is to take place.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a voice recording device is available, the magistrate may record by means of that device all of the call after the magistrate becomes aware of the purpose of the call. Otherwise, the magistrate shall cause a stenographic or longhand memorandum to be made of the oral testimony of the person applying for the warrant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the magistrate is satisfied from the oral testimony that the grounds for the warrant exist or that there is probable cause to believe that they exist, the magistrate shall order the issuance of the warrant by directing the person applying for the warrant to sign the magistrate\u8217\'3fs name on the duplicate warrant. The magistrate shall immediately sign the original warrant and enter on its face the exact time when the issuance was ordered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person who executes the warrant shall enter the time of execution on the face of the duplicate warrant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The magistrate shall cause any record of the call made by means of a voice recording device to be transcribed, shall certify the accuracy of the transcript, and shall file the transcript and the original record with the clerk. If a stenographic or longhand memorandum was made of the oral testimony of the person who applied for the warrant, the magistrate shall file a signed copy with the clerk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of court shall maintain the original and duplicate warrants along with the record of the telephone call and any transcript or memorandum made of the call in a confidential file until a charge, if any, is filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Search warrants issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall authorize and direct peace officers to secure the withdrawal of blood specimens by medical personnel under }}}{{\f5\fs18\hyphpar0\qj{section 321J.11}}}{{\f5\fs18\hyphpar0\qj{. Reasonable care shall be exercised to ensure the health and safety of the persons from whom specimens are withdrawn in execution of the warrants.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person from whom a specimen is to be withdrawn objects to the withdrawal of blood, the warrant may be executed as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is capable of giving a specimen of breath, and a direct breath testing instrument is readily available, the warrant may be executed by the withdrawal of a specimen of breath for chemical testing, unless the peace officer has reasonable grounds to believe that the person was under the influence of a controlled substance, a drug other than alcohol, or a combination of alcohol and another drug.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the testimony in support of the warrant sets forth facts and information that the peace officer has reasonable grounds to believe that the person was under the influence of a controlled substance, a drug other than alcohol, or a combination of alcohol and another drug, a urine sample shall be collected in lieu of a blood sample, if the person is capable of giving a urine sample and the sample can be collected without the need to physically compel the execution of the warrant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The act of any person knowingly resisting or obstructing the withdrawal of a specimen pursuant to a search warrant issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ constitutes a contempt punishable by a fine not exceeding one thousand dollars or imprisonment in a county jail not exceeding one year or by both such fine and imprisonment. Also, if the withdrawal of a specimen is so resisted or obstructed, }}}{{\f5\fs18\hyphpar0\qj{sections 321J.9}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321J.16}}}{{\f5\fs18\hyphpar0\qj{ apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonsubstantive variances between the contents of the original and duplicate warrants shall not cause a warrant issued under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to be considered invalid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Specimens obtained pursuant to warrants issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are not subject to disposition under }}}{{\f5\fs18\hyphpar0\qj{section 808.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 809}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{809A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subsections 1 through 7}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ do not apply where a test may be administered under }}}{{\f5\fs18\hyphpar0\qj{section 321J.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Medical personnel who use reasonable care and accepted medical practices in withdrawing blood specimens are immune from liability for their actions in complying with requests made of them pursuant to search warrants or pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1233, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1133, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7184}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.10A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.10A}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Blood, breath, or urine specimen withdrawal without a warrant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 321J.10}}}{{\f5\fs18\hyphpar0\qj{, if a person is under arrest for an offense arising out of acts alleged to have been committed while the person was operating a motor vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{, and that arrest results from an accident that causes a death or personal injury reasonably likely to cause death, a chemical test of blood may be administered without the consent of the person arrested to determine the amount of alcohol or a controlled substance in that person\u8217\'3fs blood if all of the following circumstances exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The peace officer reasonably believes the blood drawn will produce evidence of intoxication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The method used to take the blood sample is reasonable and performed in a reasonable manner by medical personnel under }}}{{\f5\fs18\hyphpar0\qj{section 321J.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The peace officer reasonably believes the officer is confronted with an emergency situation in which the delay necessary to obtain a warrant under }}}{{\f5\fs18\hyphpar0\qj{section 321J.10}}}{{\f5\fs18\hyphpar0\qj{ threatens the destruction of the evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person from whom a specimen of blood is to be withdrawn objects to the withdrawal, a breath or urine sample may be taken under the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is capable of giving a specimen of breath, and a direct breath testing instrument is readily available, the withdrawal of a specimen of the person\u8217\'3fs breath may be taken for chemical testing, unless the peace officer has reasonable grounds to believe that the person was under the influence of a controlled substance, a drug other than alcohol, or a combination of alcohol and another drug.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the peace officer has reasonable grounds to believe that the person was under the influence of a controlled substance, a drug other than alcohol, or a combination of alcohol and another drug, a urine sample shall be collected in lieu of a blood sample, if the person is capable of giving a urine sample and the sample can be collected.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1098, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.11}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Taking sample for test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Only a licensed physician, licensed physician assistant as defined in }}}{{\f5\fs18\hyphpar0\qj{section 148C.1}}}{{\f5\fs18\hyphpar0\qj{, medical technologist, or registered nurse, acting at the request of a peace officer, may withdraw a specimen of blood for the purpose of determining the alcohol concentration or the presence of a controlled substance or other drugs. However, any peace officer, using devices and methods approved by the commissioner of public safety, may take a specimen of a person\u8217\'3fs breath or urine for the purpose of determining the alcohol concentration, or may take a specimen of a person\u8217\'3fs urine for the purpose of determining the presence of a controlled substance or other drugs. Only new equipment kept under strictly sanitary and sterile conditions shall be used for drawing blood.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person may have an independent chemical test or tests administered at the person\u8217\'3fs own expense in addition to any administered at the direction of a peace officer. The failure or inability of the person to obtain an independent chemical test or tests does not preclude the admission of evidence of the results of the test or tests administered at the direction of the peace officer. Upon the request of the person who is tested, the results of the test or tests administered at the direction of the peace officer shall be made available to the person.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1225, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.10}}}{{\f5\fs12\hyphpar0\qj{, 321J.10A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.12}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Test result revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon certification, subject to penalty for perjury, by the peace officer that there existed reasonable grounds to believe that the person had been operating a motor vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, that there existed one or more of the necessary conditions for chemical testing described in }}}{{\f5\fs18\hyphpar0\qj{section 321J.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and that the person submitted to chemical testing and the test results indicated the presence of a controlled substance or other drug, or an alcohol concentration equal to or in excess of the level prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, or a combination of alcohol and another drug in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, the department shall revoke the person\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege for the following periods of time:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One hundred eighty days if the person has had no revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One year if the person has had a previous revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall require the defendant to install an ignition interlock device of a type approved by the commissioner of public safety on all vehicles operated by the defendant if the defendant seeks a temporary restricted license. A temporary restricted license shall not be granted by the department until the defendant installs the ignition interlock device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The effective date of the revocation shall be ten days after the department has mailed notice of revocation to the person by first class mail, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. The peace officer who requested or directed the administration of the chemical test may, on behalf of the department, serve immediate notice of revocation on a person whose test results indicated the presence of a controlled substance or other drug, or an alcohol concentration equal to or in excess of the level prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, or a combination of alcohol and another controlled substance or drug in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the peace officer serves that immediate notice, the peace officer shall take the person\u8217\'3fs Iowa license or permit, if any, and issue a temporary license valid only for ten days. The peace officer shall immediately send the person\u8217\'3fs driver\u8217\'3fs license to the department along with the officer\u8217\'3fs certificate indicating that the test results indicated the presence of a controlled substance or other drug, or an alcohol concentration equal to or in excess of the level prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon certification, subject to penalty of perjury, by the peace officer that there existed reasonable grounds to believe that the person had been operating a motor vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2A}}}{{\f5\fs18\hyphpar0\qj{, that there existed one or more of the necessary conditions for chemical testing described in }}}{{\f5\fs18\hyphpar0\qj{section 321J.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and that the person submitted to chemical testing and the test results indicated an alcohol concentration of .02 or more but less than .08, the department shall revoke the person\u8217\'3fs driver\u8217\'3fs license or operating privilege for a period of sixty days if the person has had no previous revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and for a period of ninety days if the person has had a previous revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The results of a chemical test may not be used as the basis for a revocation of a person\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege if the alcohol or drug concentration indicated by the chemical test minus the established margin of error inherent in the device or method used to conduct the chemical test is not equal to or in excess of the level prohibited by }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 143, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1090, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 32, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 60, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7123}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1097, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1110, \'a76, 9}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7185}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 98, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1050, \'a75, 10, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.211A}}}{{\f5\fs12\hyphpar0\qj{, 321J.2}}}{{\f5\fs12\hyphpar0\qj{, 321J.2A}}}{{\f5\fs12\hyphpar0\qj{, 321J.4}}}{{\f5\fs12\hyphpar0\qj{, 321J.8}}}{{\f5\fs12\hyphpar0\qj{, 321J.13}}}{{\f5\fs12\hyphpar0\qj{, 915.80}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 2 effective January 1, 2025, and applies to driver\u8217\'3fs license revocations under }{{\f5\fs12\hyphpar0\qj{chapter 321J}}}{ for which the underlying offense occurred on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1050.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1050, \'a710, 11}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.13}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hearing on revocation \u8212\'3f appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of revocation of a person\u8217\'3fs noncommercial driver\u8217\'3fs license or operating privilege served pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.12}}}{{\f5\fs18\hyphpar0\qj{ shall include a form accompanied by a preaddressed envelope on which the person served may indicate by a checkmark if the person only wishes to request a temporary restricted license, or if the person wishes a hearing to contest the revocation. The form shall clearly state on its face that the form must be completed and returned within ten days of receipt or the person\u8217\'3fs right to a hearing to contest the revocation is foreclosed. The form shall also be accompanied by a statement of the operation of and the person\u8217\'3fs rights under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall grant the person an opportunity to be heard within forty-five days of receipt of a request for a hearing if the request is made not later than ten days after receipt of notice of revocation served pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.12}}}{{\f5\fs18\hyphpar0\qj{. The hearing shall be before the department in the county where the alleged events occurred, unless the director and the person agree that the hearing may be held in some other county, or the hearing may be held by telephone conference at the discretion of the agency conducting the hearing. The hearing may be recorded and its scope shall be limited to the issues of whether a peace officer had reasonable grounds to believe that the person was operating a motor vehicle in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{ and one or more of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the person refused to submit to the test or tests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether a test was administered and the test results indicated an alcohol concentration equal to or in excess of the level prohibited under }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether a test was administered and the test results indicated the presence of alcohol, a controlled substance or other drug, or a combination of alcohol and another drug, in violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the hearing the department shall order that the revocation be either rescinded or sustained. Upon receipt of the decision of the department to sustain a revocation, the person contesting the revocation has ten days to file a request for review of the decision by the director. The director or the director\u8217\'3fs designee shall review the decision within thirty days and shall either rescind or sustain the revocation or order a new hearing. If the director orders a new hearing, the department shall grant the person a new hearing within twenty days of the director\u8217\'3fs order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall stay the revocation of a person\u8217\'3fs driver\u8217\'3fs license or operating privilege for the period that the person is contesting the revocation under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 321J.14}}}{{\f5\fs18\hyphpar0\qj{ if it is shown to the satisfaction of the department that the new evidence is material and that there were valid reasons for failure to present it in the contested case proceeding before the department. However, a stay shall not be granted for violations of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department fails to comply with the time limitations of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ regarding granting a hearing, review by the director or the director\u8217\'3fs designee, or granting a new hearing, and if the request for a hearing or review by the director was properly made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the revocation of the driver\u8217\'3fs license or operating privilege of the person who made the request for a hearing or review shall be rescinded. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not apply in those cases in which a continuance to the hearing has been granted at the request of either the person who requested the hearing or the peace officer who requested or administered the chemical test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall grant a request for a hearing to rescind the revocation if the person whose motor vehicle license or operating privilege has been or is being revoked under }}}{{\f5\fs18\hyphpar0\qj{section 321J.9}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.12}}}{{\f5\fs18\hyphpar0\qj{ submits a petition containing information relating to the discovery of new evidence that provides grounds for rescission of the revocation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person shall prevail at the hearing if, in the criminal action on the charge of violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{ resulting from the same circumstances that resulted in the administrative revocation being challenged, the court held one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the peace officer did not have reasonable grounds to believe that a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.2A}}}{{\f5\fs18\hyphpar0\qj{ had occurred to support a request for or to administer a chemical test.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the chemical test was otherwise inadmissible or invalid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such a holding by the court in the criminal action is binding on the department, and the department shall rescind the revocation. If the offense for which the revocation was imposed was committed while the person was operating a noncommercial motor vehicle and holding a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit and the department disqualified the person from operating a commercial motor vehicle under }}}{{\f5\fs18\hyphpar0\qj{section 321.208, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, as a result of the revocation, the department shall also rescind the disqualification.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 148, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1109, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1214, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 83, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 104, \'a730, 31}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 13, \'a722, 29}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 130, \'a715, 18}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1110, \'a77, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321A.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.14}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judicial review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Judicial review of an action of the department may be sought in accordance with the terms of the Iowa administrative procedure Act, }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{. Notwithstanding the terms of that chapter, a petition for judicial review may be filed in the district court in the county where the alleged events occurred or in the county in which the administrative hearing was held.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.15}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Evidence in any action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the trial of a civil or criminal action or proceeding arising out of acts alleged to have been committed by a person while operating a motor vehicle in violation of }{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{ or }{{\f5\fs18\hyphpar0\qj{321J.2A}}}{, evidence of the alcohol concentration or the presence of a controlled substance or other drugs in the person\u8217\'3fs body at the time of the act alleged as shown by a chemical analysis of the person\u8217\'3fs blood, breath, or urine is admissible. If it is established at trial that an analysis of a breath specimen was performed by a certified operator using a device intended to determine alcohol concentration and methods approved by the commissioner of public safety, no further foundation is necessary for introduction of the evidence.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 48, \'a719}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1138, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.16}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Proof of refusal admissible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a person refuses to submit to a chemical test, proof of refusal is admissible in any civil or criminal action or proceeding arising out of acts alleged to have been committed while the person was operating a motor vehicle in violation of }{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{ or }{{\f5\fs18\hyphpar0\qj{321J.2A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 48, \'a720}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.17}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil penalty \u8212\'3f disposition \u8212\'3f conditions for license reinstatement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department revokes a person\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the department shall assess the person a civil penalty of two hundred dollars. The money collected by the department under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be transmitted to the treasurer of state who shall deposit one-half of the money in the separate fund established in }}}{{\f5\fs18\hyphpar0\qj{section 915.94}}}{{\f5\fs18\hyphpar0\qj{ and one-half of the money in the general fund of the state. A temporary restricted license shall not be issued unless an ignition interlock device has been installed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321J.4}}}{{\f5\fs18\hyphpar0\qj{. Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321.210B}}}{{\f5\fs18\hyphpar0\qj{, a temporary restricted license shall not be issued or a driver\u8217\'3fs license or nonresident operating privilege reinstated until the civil penalty has been paid. A person assessed a penalty under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may remit the civil penalty along with a processing fee of five dollars to a county treasurer authorized to issue driver\u8217\'3fs licenses under }}}{{\f5\fs18\hyphpar0\qj{chapter 321M}}}{{\f5\fs18\hyphpar0\qj{, or the civil penalty may be paid directly to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department or a court orders the revocation of a person\u8217\'3fs driver\u8217\'3fs license or nonresident operating privilege under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the department or court shall also order the person, at the person\u8217\'3fs own expense, to do the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enroll, attend, and satisfactorily complete a course for drinking drivers, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 321J.22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit to evaluation and treatment or rehabilitation services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court or department may request that the community college or substance use disorder treatment providers licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{ or other approved provider conducting the course for drinking drivers that the person is ordered to attend immediately report to the court or department that the person has successfully completed the course for drinking drivers. The court or department may request that the treatment program which the person attends periodically report on the defendant\u8217\'3fs attendance and participation in the program, as well as the status of treatment or rehabilitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A driver\u8217\'3fs license or nonresident operating privilege shall not be reinstated until proof of completion of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is presented to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall also require certification of installation of an ignition interlock device of a type approved by the commissioner of public safety on all motor vehicles operated by a person seeking reinstatement following a second or subsequent revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or following a conviction for violating }}}{{\f5\fs18\hyphpar0\qj{section 321J.21}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise extended under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the requirement for the installation of an approved ignition interlock device shall be for one year from the date of reinstatement unless a longer time period is required by statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The period of time a person is required to maintain an ignition interlock device under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by any period of time the person held a valid temporary restricted license during the period of the revocation for the occurrence from which the arrest arose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The period of time a person is required to maintain an ignition interlock device under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be increased if required in accordance with the compliance-based removal procedures provided in }}}{{\f5\fs18\hyphpar0\qj{section 321J.17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not operate any motor vehicle which is not equipped with an approved ignition interlock device during the period in which an ignition interlock device must be maintained, and the department shall not grant reinstatement unless the person certifies installation of an ignition interlock device as required in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. In addition to other penalties provided by law, the department shall revoke the driver\u8217\'3fs license of a person who is required to maintain an ignition interlock device if the person operates a motor vehicle which does not have an approved ignition interlock device or removes the ignition interlock device without authorization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 232, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 234, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 317, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 258, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 110, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 143, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1075, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1090, \'a767, 84}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1118, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7155}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1018, \'a725, 31}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1097, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 20, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 103, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a785}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71072}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1050, \'a76, 10, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.210B}}}{{\f5\fs12\hyphpar0\qj{, 321J.3}}}{{\f5\fs12\hyphpar0\qj{, 321J.17A}}}{{\f5\fs12\hyphpar0\qj{, 321J.20}}}{{\f5\fs12\hyphpar0\qj{, 321J.22}}}{{\f5\fs12\hyphpar0\qj{, 321M.9}}}{{\f5\fs12\hyphpar0\qj{, 331.557A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 3 effective January 1, 2025, and applies to driver\u8217\'3fs license revocations under }{{\f5\fs12\hyphpar0\qj{chapter 321J}}}{ for which the underlying offense occurred on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1050.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1050, \'a710, 11}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.17A}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Compliance-based removal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The period of time a person is required to maintain an ignition interlock device under }}}{{\f5\fs18\hyphpar0\qj{section 321J.17}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.20}}}{{\f5\fs18\hyphpar0\qj{ shall be extended by an additional sixty days per occurrence for any of the following occurrences detected by an ignition interlock device:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ten or more violations within a thirty-day period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Five or more violations within a twenty-four-hour period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tampering with or attempting to circumvent the ignition interlock device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Removing the ignition interlock device without authorization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ limits the number of subsequent extensions a person may receive following an occurrence detected by an ignition interlock device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall develop an electronic process in which an approved ignition interlock device provider is able to identify the start date of a driver\u8217\'3fs license revocation and to provide notice of any violations and a final compliance report to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a violation includes any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failing to provide a detectable breath sample to the ignition interlock device when prompted by the device.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing a breath sample to an ignition interlock device with an alcohol concentration of .04 or more.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, it is not a violation under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if a person provides a detectable breath sample and successfully passes a test immediately following the first failed test or in response to a bypass or circumvention attempt as described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and a violation shall not be reported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ prescribing the form and manner of communication pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and may otherwise adopt rules as necessary to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1050, \'a77, 10, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.4}}}{{\f5\fs12\hyphpar0\qj{, 321J.17}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section effective January 1, 2025, and applies to driver\u8217\'3fs license revocations under }{{\f5\fs12\hyphpar0\qj{chapter 321J}}}{ for which the underlying offense occurred on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1050.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1050, \'a710, 11}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.18}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Other evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ does not limit the introduction of any competent evidence bearing on the question of whether a person was under the influence of an alcoholic beverage or a controlled substance or other drug, including the results of chemical tests of specimens of blood, breath, or urine obtained more than two hours after the person was operating a motor vehicle.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1138, \'a723}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.19}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Information relayed to other states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When it has been finally determined under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ that a nonresident\u8217\'3fs privilege to operate a motor vehicle in this state has been revoked or denied, the department shall give information in writing of the action taken to the official in charge of traffic control or public safety of the state of the person\u8217\'3fs residence and of any state in which the person has a license.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a719}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.20}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Temporary restricted license }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ ignition interlock devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may, on application, issue a temporary restricted license to a person whose noncommercial driver\u8217\'3fs license is revoked under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or revoked or suspended under }}}{{\f5\fs18\hyphpar0\qj{chapter 321}}}{{\f5\fs18\hyphpar0\qj{ solely for violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or who has been determined to be a habitual offender under }}}{{\f5\fs18\hyphpar0\qj{chapter 321}}}{{\f5\fs18\hyphpar0\qj{ based solely on violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or on violations listed in }}}{{\f5\fs18\hyphpar0\qj{section 321.560, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, allowing the person to operate a motor vehicle in any manner allowed for a person issued a valid class C driver\u8217\'3fs license, unless otherwise prohibited by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a person under the age of eighteen whose license was revoked under }}}{{\f5\fs18\hyphpar0\qj{section 321J.2A}}}{{\f5\fs18\hyphpar0\qj{, to a person whose license was revoked under }}}{{\f5\fs18\hyphpar0\qj{section 321J.4, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, for the period during which the person is ineligible for a temporary restricted license, or to a person whose license is suspended or revoked for another reason.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A temporary restricted license issued under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be issued until the applicant installs an approved ignition interlock device on all motor vehicles operated by the applicant. Installation of an ignition interlock device under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be required for the period of time for which the temporary restricted license is issued, and for such additional period of time following reinstatement as is required under }}}{{\f5\fs18\hyphpar0\qj{section 321J.17, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. However, a person whose driver\u8217\'3fs license or nonresident operating privilege has been revoked under }}}{{\f5\fs18\hyphpar0\qj{section 321J.21}}}{{\f5\fs18\hyphpar0\qj{ may apply to the department for a temporary restricted license without the requirement of an ignition interlock device if at least twelve years have elapsed since the end of the underlying revocation period for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to other penalties provided by law, a person\u8217\'3fs temporary restricted license shall be revoked if the person is required to install an ignition interlock device and the person operates a motor vehicle which does not have an approved ignition interlock device or removes the ignition interlock device without authorization. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a temporary restricted license issued by the department under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not operate a commercial motor vehicle on a highway if a commercial driver\u8217\'3fs license or commercial learner\u8217\'3fs permit is required for the person\u8217\'3fs operation of the commercial motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person holding a temporary restricted license issued by the department under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be prohibited from operating a school bus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the department may issue a temporary restricted license to a person otherwise eligible for a temporary restricted license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, whose period of revocation under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ has expired, but who has not met all requirements for reinstatement of the person\u8217\'3fs driver\u8217\'3fs license or nonresident operating privileges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who tampers with, removes without authorization, or circumvents an ignition interlock device installed as required in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ while the requirement for the ignition interlock device is in effect commits a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, the department may issue a temporary restricted license to a person eligible for a temporary restricted license under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the person is also eligible for a temporary restricted license under }}}{{\f5\fs18\hyphpar0\qj{section 321.215}}}{{\f5\fs18\hyphpar0\qj{, provided the requirements of }}}{{\f5\fs18\hyphpar0\qj{ this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 321.215}}}{{\f5\fs18\hyphpar0\qj{ are satisfied.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1230, \'a787, 88}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 48, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 143, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a718 \u8211\'3f 20}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79, 12}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1138, \'a75, 36, 37}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1133, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 60, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 196, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1097, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 103, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 123, \'a736, 73}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 76, \'a713 \u8211\'3f 16}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7117}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1110, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 66, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1059, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7186}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 98, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1050, \'a78, 10, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.215}}}{{\f5\fs12\hyphpar0\qj{, 321.560}}}{{\f5\fs12\hyphpar0\qj{, 321J.2}}}{{\f5\fs12\hyphpar0\qj{, 321J.17A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendments to section effective January 1, 2025, and apply to driver\u8217\'3fs license revocations under }{{\f5\fs12\hyphpar0\qj{chapter 321J}}}{ for which the underlying offense occurred on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1050.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1050, \'a710, 11}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.20A}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Ignition interlock device }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ medical waiver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing criteria to waive the requirement to install an ignition interlock device under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ if a person has a verifiable medical condition, as determined in accordance with the rules, that makes the person incapable of properly operating an ignition interlock device. The rules must align with the special exception provisions under }}}{{\f5\fs18\hyphpar0\qj{23 U.S.C. \'a7164(a)(6)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, if the department waives the requirement to install an ignition interlock device, the person is not required to install an ignition interlock device to receive a temporary restricted license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A temporary restricted license issued to a person who received a medical waiver pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall only authorize the person to operate a motor vehicle as described in }}}{{\f5\fs18\hyphpar0\qj{section 321.215, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1050, \'a79 \u8211\'3f 11}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section effective January 1, 2025, and applies to driver\u8217\'3fs license revocations under }{{\f5\fs12\hyphpar0\qj{chapter 321J}}}{ for which the underlying offense occurred on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1050.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1050, \'a710, 11}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.21}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Driving while license suspended, denied, revoked, or barred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person whose driver\u8217\'3fs license or nonresident operating privilege has been suspended, denied, revoked, or barred due to a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and who drives a motor vehicle while the license or privilege is suspended, denied, revoked, or barred commits a serious misdemeanor. In addition to any other penalties, the punishment imposed for a violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall include assessment of a fine of one thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the fine, the department, upon receiving the record of the conviction of a person under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ upon a charge of driving a motor vehicle while the license of the person was suspended, denied, revoked, or barred shall extend the period of suspension, denial, revocation, or bar for an additional like period.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 153, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 98, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.211A}}}{{\f5\fs12\hyphpar0\qj{, 321.241}}}{{\f5\fs12\hyphpar0\qj{, 321J.4B}}}{{\f5\fs12\hyphpar0\qj{, 321J.17}}}{{\f5\fs12\hyphpar0\qj{, 321J.20}}}{{\f5\fs12\hyphpar0\qj{, 321N.3}}}{{\f5\fs12\hyphpar0\qj{, 901C.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See }{{\f5\fs12\hyphpar0\qj{\'a7321.555 \u8211\'3f 321.562}}}{ for penalties applicable to habitual offenders }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.22}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Drinking drivers course.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fApproved provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a provider of a course for drinking drivers offered outside this state which has been approved by the department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCourse for drinking drivers\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an approved course designed to inform the offender about drinking and driving and encourage the offender to assess the offender\u8217\'3fs own drinking and driving behavior in order to select practical alternatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSatisfactory completion of a course\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means receiving at the completion of a course a grade from the course instructor of \u8220\'3fC\u8221\'3f or \u8220\'3f2.0\u8221\'3f or better.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The course provided according to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be offered on a regular basis at each community college as defined in }}}{{\f5\fs18\hyphpar0\qj{section 260C.2}}}{{\f5\fs18\hyphpar0\qj{, or by substance use disorder treatment programs licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, or may be offered at a state correctional facility listed in }}}{{\f5\fs18\hyphpar0\qj{section 904.102}}}{{\f5\fs18\hyphpar0\qj{. However, a community college shall not be required to offer the course if a substance use disorder treatment program licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{ offers the course within the merged area served by the community college.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enrollment in the courses is not limited to persons ordered to enroll, attend, and successfully complete the course required under }}}{{\f5\fs18\hyphpar0\qj{sections 321J.2}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{321J.17, subsection 2}}}{{\f5\fs18\hyphpar0\qj{. However, any person under age eighteen who is required to attend the courses for violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{321J.17}}}{{\f5\fs18\hyphpar0\qj{ must attend a course offered by a substance use disorder treatment program licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The course required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Taught by a community college under the supervision of the department of education or by a substance use disorder treatment program licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, and may be offered at a state correctional facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approved by the department of education, in consultation with the community colleges, substance use disorder treatment programs licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, the department of health and human services, and the department of corrections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education may approve a provider of a course for drinking drivers offered outside this state upon proof to the department\u8217\'3fs satisfaction that the course is comparable to those offered by community colleges, substance use disorder treatment programs licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, and state correctional facilities as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The department shall comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ regarding such approved providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education shall establish reasonable fees to defray the expense of obtaining classroom space, instructor salaries, and class materials for courses offered both by community colleges and by substance use disorder treatment programs licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, or for classes offered at a state correctional facility, and for administrative expenses incurred by the department of education in implementing }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ on behalf of in-state and out-of-state offenders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be denied enrollment in a course by reason of the person\u8217\'3fs indigency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer shall not discharge a person from employment solely for the reason of work absence to attend a course required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Any employer who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is liable for damages which include but are not limited to actual damages, court costs, and reasonable attorney fees. The person may also petition the court for imposition of a cease and desist order against the person\u8217\'3fs employer and for reinstatement to the person\u8217\'3fs previous position of employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education, substance use disorder treatment programs licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, and state correctional facilities shall prepare for their respective courses a list of the locations of the courses taught under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the dates and times taught, the procedure for enrollment, and the schedule of course fees. The list shall be kept current and a copy of the list shall be sent to each court having jurisdiction over offenses provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education, substance use disorder treatment programs licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, and state correctional facilities shall maintain enrollment, attendance, and successful and nonsuccessful completion data for their respective courses on the persons ordered to enroll, attend, and successfully complete a course for drinking drivers. This data shall be forwarded to the court by the department of education, substance use disorder treatment programs licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, and the department of corrections.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1220, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1138, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1140, \'a737}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2002 Acts, 2nd Ex, ch 1003, \'a7240, 262}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 180, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1124, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 20, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71073}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a786}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.17}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.23}}}{\*\bkmkstart stylerid1_2E36_2E2_2E2}{\*\bkmkend stylerid1_2E36_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legislative findings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The general assembly finds and declares as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Drivers often do not realize the consequences of drinking alcohol or using other drugs, and driving a motor vehicle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prompt intervention is needed to protect society, including drivers, from death or serious long-term injury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The conviction of a driver for operating while intoxicated identifies that person as a risk to the health and safety of others, as well as to the intoxicated driver.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Close observation of the effects on others of alcohol and drug use by an intoxicated driver convicted of operating while intoxicated may have a marked effect on recidivism and should therefore be encouraged by the courts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reality education substance use disorder prevention program provides guidelines for the operation of an intensive program to discourage recidivism.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1231, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71074}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.24}}}{\*\bkmkstart stylerid1_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Court-ordered visitation for offenders \u8212\'3f immunity from liability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAppropriate victim\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a victim whose condition demonstrates the results of a motor vehicle accident involving intoxicated drivers without being excessively traumatic to the participant, as determined by the tour supervisor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fParticipant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is ordered by the court to participate in the reality education substance use disorder prevention program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProgram\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the reality education substance use disorder prevention program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProgram coordinator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person appointed by the court to coordinate the person\u8217\'3fs participation in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTour supervisor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person selected by a participant\u8217\'3fs program coordinator to supervise a tour.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A reality education substance use disorder prevention program is established in those judicial districts where the chief judge of the judicial district authorizes participation in the program. Upon a conviction or adjudication for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, or the entry of a deferred judgment concerning a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{, the court or juvenile court may order participation in the reality education substance use disorder prevention program as a term and condition of probation or disposition in addition to any other term or condition of probation or disposition required or authorized by law. The court or juvenile court shall require the defendant or delinquent child to abstain from consuming any controlled substance, alcoholic liquor, wine, or beer while participating in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court or juvenile court shall consult with the defendant or delinquent child and the defendant\u8217\'3fs or delinquent child\u8217\'3fs attorney, if any, and may consult with any other person, including but not limited to the defendant\u8217\'3fs or delinquent child\u8217\'3fs parents or other family members, to determine if the defendant or delinquent child is suitable for participation in the program, if the program will be educational and meaningful to the defendant or delinquent child, and if any physical, emotional, mental, or other reasons exist which indicate that the program would be inappropriate or would cause any injury to the defendant or delinquent child.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court or juvenile court may appoint a program coordinator, to coordinate all tours and select appropriate tour supervisors for each tour. The program coordinator shall monitor compliance by contacting each tour supervisor following the completion of a tour.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court or juvenile court may include a requirement for a supervised educational tour by the defendant or delinquent child to any or all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hospital or other emergency medical care facility which regularly receives victims of motor vehicle accidents, to observe treatment of appropriate victims of motor vehicle accidents involving intoxicated drivers, under the supervision of a registered nurse, physician, paramedic, or emergency medical technician.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A facility for the treatment of persons with a substance use disorder as defined in }}}{{\f5\fs18\hyphpar0\qj{section 125.2}}}{{\f5\fs18\hyphpar0\qj{, under the supervision of appropriately licensed medical personnel.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If approved by the state or county medical examiner, a morgue or a similar facility to receive appropriate educational material and instruction concerning damage caused by the consumption of alcohol or other drugs, under the supervision of the county medical examiner or deputy medical examiner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{However, the court or juvenile court shall not order the defendant or delinquent child to participate in a supervised education tour of a hospital or other facility specified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, unless the hospital or facility agrees to participate in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to a tour, the program coordinator shall explain and discuss the experiences which may be encountered during the tour to the participant. If the program coordinator determines at any time before or during a tour that the tour may be traumatic or otherwise inappropriate for the participant, the program coordinator shall terminate the tour without prejudice to the participant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court or juvenile court may order a personal conference after the tours with the participant, the participant\u8217\'3fs attorney, if any, and any other persons if available and deemed necessary by the court or juvenile court, to discuss the experiences of the participant in the program and how those experiences may impact the participant\u8217\'3fs conduct. The court or juvenile court may order the participant to write a report or letter concerning the participant\u8217\'3fs experiences in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tour supervisors and facilities toured during the program are not liable for any civil damages resulting from injury to the participant, or civil damages caused by the participant during or from any activities related to a tour, except for willful or grossly negligent acts intended to, or reasonably expected to result in, such injury or damage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief judge of the judicial district shall determine fees to be paid by participants in the program. The judicial branch shall use the fees to pay all costs associated with the program. The court shall either require the participant to pay the fee in order to participate in the program, or may waive the fee or collect a lesser amount upon a showing of cause.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1231, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a723, 24}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1047, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71075 \u8211\'3f 1077}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.2}}}{{\f5\fs12\hyphpar0\qj{, 707.6A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{321J.25}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Youthful offender substance use disorder awareness program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fParticipant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person whose driver\u8217\'3fs license or operating privilege has been revoked for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProgram\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a substance use disorder awareness program, licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 125}}}{{\f5\fs18\hyphpar0\qj{, and provided under a contract entered into between the provider and the department of health and human services or an administrative services organization as defined in }}}{{\f5\fs18\hyphpar0\qj{section 225A.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProgram coordinator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person assigned the duty to coordinate a participant\u8217\'3fs activities in a program by the program provider.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A substance use disorder awareness program is established in each behavioral health district designated pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 225A.4}}}{{\f5\fs18\hyphpar0\qj{. The program shall consist of an insight class and a substance use disorder evaluation, which shall be attended by the participant, to discuss issues related to the potential consequences of substance use disorder. The parent or parents of the participant shall also be encouraged to participate in the program. The program provider shall consult with the participant or the parents of the participant in the program to determine the timing and appropriate level of participation for the participant and any participation by the participant\u8217\'3fs parents. The program may also include a supervised educational tour by the participant to any or all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hospital or other emergency medical care facility which regularly receives victims of motor vehicle accidents, to observe treatment of appropriate victims of motor vehicle accidents involving intoxicated drivers, under the supervision of a registered nurse, physician, paramedic, or emergency medical technician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A facility for the treatment of persons with a substance use disorder as defined in }}}{{\f5\fs18\hyphpar0\qj{section 125.2}}}{{\f5\fs18\hyphpar0\qj{, under the supervision of appropriately licensed medical personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If approved by the state or county medical examiner, a morgue or a similar facility to receive appropriate educational material and instruction concerning damage caused by the consumption of alcohol or other drugs, under the supervision of the county medical examiner or deputy medical examiner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the program includes a tour, the program coordinator shall explain and discuss the experiences which may be encountered during the tour to the participant. If the program coordinator determines at any time before or during a tour that the tour may be traumatic or otherwise inappropriate for the participant, the program coordinator shall terminate the tour without prejudice to the participant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the revocation of the driver\u8217\'3fs license or operating privileges of a person who is fourteen years of age or older for a violation of }}}{{\f5\fs18\hyphpar0\qj{section 321J.2A}}}{{\f5\fs18\hyphpar0\qj{, if the person has had no previous revocations under either }}}{{\f5\fs18\hyphpar0\qj{section 321J.2}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 321J.2A}}}{{\f5\fs18\hyphpar0\qj{, a person may participate in the substance use disorder awareness program. The state department of transportation shall notify a potential program participant of the possibility and potential benefits of attending a program and shall notify a potential program participant of the availability of programs which exist in the area in which the person resides. The state department of transportation shall consult with the department of health and human services to determine what programs are available in various areas of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Program providers and facilities toured during the program are not liable for any civil damages resulting from injury to the participant, or civil damages caused by the participant during or from any activities related to a tour, except for willful or grossly negligent acts intended to, or reasonably expected to result in, such injury or damage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The program provider shall determine fees to be paid by participants in the program. The program fees shall be paid on a sliding scale, based upon the ability of a participant and a participant\u8217\'3fs family to pay the fees, and shall not exceed one hundred dollars per participant. The program provider shall use the fees to pay all costs associated with the program.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 143, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 177, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 175, \'a7121, 122}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71078}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7109, 110, 137}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1, paragraph b effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 2, unnumbered paragraph 1 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1, paragraph b amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, unnumbered paragraph 1 amended}\par}}