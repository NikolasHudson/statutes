\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F364}{\*\bkmkend codeChapter_5F364}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 364}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{POWERS AND DUTIES OF CITIES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a728J.9}}}{{\f5\fs12\qc{, 192.141}}}{{\f5\fs12\qc{, 214A.41}}}{{\f5\fs12\qc{, 331.248}}}{{\f5\fs12\qc{, 331.261}}}{{\f5\fs12\qc{, 354.1}}}{{\f5\fs12\qc{, 362.1}}}{{\f5\fs12\qc{, 362.9}}}{{\f5\fs12\qc{, 373.11}}}{{\f5\fs12\qc{, 376.1}}}{{\f5\fs12\qc{, 476.23}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city may, except as expressly limited by the Constitution of the State of Iowa, and if not inconsistent with the laws of the general assembly, exercise any power and perform any function it deems appropriate to protect and preserve the rights, privileges, and property of the city or of its residents, and to preserve and improve the peace, safety, health, welfare, comfort, and convenience of its residents. This grant of home rule powers does not include the power to enact private or civil law governing civil relationships, except as incident to an exercise of an independent city power, or to enact private or civil law which violates }{{\f5\fs18\hyphpar0\qj{section 675.4}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7664; R60, \'a71047, 1056, 1057, 1071 \u8211\'3f 1073, 1095; C73, \'a7454 \u8211\'3f 456, 482, 524; C97, \'a7680, 695, 947; C13, \'a7695; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5714, 5738, 6720;}}}{ C46, 50, \'a7366.1, 368.2, 420.31; C54, 58, 62, 66, 71, 73, \'a7366.1, 368.2, 420.31; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1010, \'a795}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1003, \'a72, 7, 8}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Municipal home rule, }{{\f5\fs12\hyphpar0\qj{Iowa Constitution, Art. III, \'a738A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vesting of power \u8212\'3f franchises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A power of a city is vested in the city council except as otherwise provided by a state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The enumeration of a specific power of a city does not limit or restrict the general grant of home rule power conferred by the Constitution of the State of Iowa. A city may exercise its general powers subject only to limitations expressly imposed by a state or city law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An exercise of a city power is not inconsistent with a state law unless it is irreconcilable with the state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may grant to any person a franchise to erect, maintain, and operate plants and systems for electric light and power, heating, telegraph, cable television, district telegraph and alarm, motor bus, trolley bus, street railway or other public transit, waterworks, sewer services, or gasworks, within the city for a term of not more than twenty-five years. When considering whether to grant, amend, extend, or renew a franchise, a city shall hold a public hearing on the question. Notice of the time and place of the hearing shall be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{. The franchise may be granted, amended, extended, or renewed only by an ordinance, but no exclusive franchise shall be granted, amended, extended, or renewed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such an ordinance shall not become effective unless approved at an election. The proposal may be submitted by the council on its own motion to the voters at any city election. Upon receipt of a petition meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 362.4}}}{{\f5\fs18\hyphpar0\qj{ requesting that a proposal be submitted to the voters, the council shall submit the proposal at the next regular city election or at a special election called for that purpose before the next regular city election. However, the city council may dispense with such election as to the grant, amendment, extension, or renewal of an electric light and power, heating, waterworks, sewer services under }}}{{\f5\fs18\hyphpar0\qj{section 357A.23}}}{{\f5\fs18\hyphpar0\qj{, or gasworks franchise unless there is a valid petition requesting submission of the proposal to the voters, or the party seeking such franchise, grant, amendment, extension, or renewal requests an election. If a majority of those voting approves the proposal, the city may proceed as proposed. The complete text of the ordinance shall be included on the ballot if conventional paper ballots are used. If an optical scan voting system is used, the proposal shall be stated on the optical scan ballot, and the full text of the ordinance posted for the voters pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 52.25}}}{{\f5\fs18\hyphpar0\qj{. All absentee voters shall receive the full text of the ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of the election shall be given by publication as prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 49.53}}}{{\f5\fs18\hyphpar0\qj{ in a newspaper of general circulation in the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person asking for the granting, amending, extension, or renewal of a franchise shall pay the costs incurred in holding the election, including the costs of the notice. A franchise shall not be finally effective until an acceptance in writing has been filed with the council and payment of the costs has been made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The franchise ordinance may regulate the conditions required and the manner of use of the streets and public grounds of the city, and it may, for the purpose of providing electrical, gas, heating, or water service, confer the power to appropriate and condemn private property upon the person franchised.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A franchise fee assessed by a city may be based upon a percentage of gross revenues generated from sales of the franchisee within the city not to exceed five percent except as provided in subparagraph division (b), without regard to the city\u8217\'3fs cost of inspecting, supervising, and otherwise regulating the franchise.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For franchise fees assessed and collected during fiscal years beginning on or after July 1, 2024, by a city with a population exceeding two hundred thousand, the rate of the franchise fee shall not exceed seven and one-half percent of gross revenues generated from sales of the franchisee in the city, and franchise fee amounts assessed and collected in excess of five percent of gross revenues generated from sales shall be used solely for the purpose specified in }}}{{\f5\fs18\hyphpar0\qj{section 384.3A, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Franchise fees collected pursuant to an ordinance in effect on May 26, 2009, shall be deposited in the city\u8217\'3fs general fund and such fees collected in excess of the amounts necessary to inspect, supervise, and otherwise regulate the franchise may be used by the city for any other purpose authorized by law. Franchise fees collected pursuant to an ordinance that is adopted or amended on or after May 26, 2009, to increase the percentage rate at which franchise fees are assessed shall be credited to the franchise fee account within the city\u8217\'3fs general fund and used pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 384.3A}}}{{\f5\fs18\hyphpar0\qj{. If a city franchise fee is assessed to customers of a franchise, the fee shall not be assessed to the city as a customer. Before a city adopts or amends a franchise fee rate ordinance or franchise ordinance to increase the percentage rate at which franchise fees are assessed, a revenue purpose statement shall be prepared specifying the purpose or purposes for which the revenue collected from the increased rate will be expended. If property tax relief is listed as a purpose, the revenue purpose statement shall also include information regarding the amount of the property tax relief to be provided with revenue collected from the increased rate. The revenue purpose statement shall be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When considering whether to amend an ordinance imposing a franchise fee to increase the rate of the fee, and after preparation of the revenue purpose statement under subparagraph (2), a city shall hold a public hearing on the question. Notice of the time and place of the hearing shall be published as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{. If a city adopts, amends, or repeals an ordinance imposing a franchise fee, the city shall promptly notify the director of revenue of such action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a city grants more than one cable television franchise, the material terms and conditions of any additional franchise shall not give undue preference or advantage to the new franchisee. A city shall not grant a new franchise that does not include the same territory as that of the existing franchise. A new franchisee shall be given a reasonable period of time to build the new system throughout the territory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If provided by ordinance, a city may enter into a }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ agreement for the collection of delinquent parking fines by a county treasurer pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.40}}}{{\f5\fs18\hyphpar0\qj{ at the time a person applies for renewal of a motor vehicle registration, for violations that have not been appealed or for which appeal has been denied. The city may pay the treasurer a reasonable fee for the collection of such fines, or may allow the county treasurer to retain a portion of the fines collected, as provided in the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city council may by ordinance or resolution prohibit or limit the use of consumer fireworks, display fireworks, or novelties, as described in }}}{{\f5\fs18\hyphpar0\qj{section 727.2}}}{{\f5\fs18\hyphpar0\qj{, on any day other than July 3, July 4, and December 31 in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 727.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7664; R60, \'a71047, 1056, 1057, 1090, 1094, 1095; C73, \'a7454 \u8211\'3f 456, 471, 473, 474, 517, 523, 524; C97, \'a7695, 720 \u8211\'3f 722, 775, 776; S13, \'a7695, 720 \u8211\'3f 722, 776; C24, 27, 31, 35, \'a75738, 5904, 5904-c1, 5905 \u8211\'3f 5909, 6128, 6131 \u8211\'3f 6134; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5738, 5904, 5904.1, 5905 \u8211\'3f 5909, 6128, 6131 \u8211\'3f 6134;}}}{ C46, 50, \'a7368.1, 386.1 \u8211\'3f 386.7, 397.2, 397.5 \u8211\'3f 397.8; C54, 58, 62, 66, \'a7368.2, 386.1 \u8211\'3f 386.7, 388.5 \u8211\'3f 388.9, 397.2, 397.5 \u8211\'3f 397.8; C71, 73, \'a7368.2, 386.1 \u8211\'3f 386.7, 397.2, 397.5 \u8211\'3f 397.8; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 127, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 143, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1123, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1148, \'a71, 9}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 82, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 98, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 54, \'a711, 12}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 190, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 57, \'a789}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7228, 231}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1110, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7148, 150}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 118, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a7104}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 50, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 115, \'a78, 12}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a760, 62}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1108, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 81, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7306.46}}}{{\f5\fs12\hyphpar0\qj{, 357A.23}}}{{\f5\fs12\hyphpar0\qj{, 358C.13}}}{{\f5\fs12\hyphpar0\qj{, 364.3}}}{{\f5\fs12\hyphpar0\qj{, 364.4}}}{{\f5\fs12\hyphpar0\qj{, 384.3A}}}{{\f5\fs12\hyphpar0\qj{, 403.7}}}{{\f5\fs12\hyphpar0\qj{, 476.84}}}{{\f5\fs12\hyphpar0\qj{, 477A.2}}}{{\f5\fs12\hyphpar0\qj{, 477A.5}}}{{\f5\fs12\hyphpar0\qj{, 480A.6}}}{{\f5\fs12\hyphpar0\qj{, 714H.4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See Code editor\u8217\'3fs note at the beginning of this Code volume}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4, paragraph h repealed by its own terms effective January 1, 2026; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1108.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1108, \'a71}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 6 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitation of powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The following are limitations upon the powers of a city:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city council shall exercise a power only by the passage of a motion, a resolution, an amendment, or an ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a violation of an ordinance a city shall not provide a penalty in excess of the maximum fine and term of imprisonment for a simple misdemeanor under }}}{{\f5\fs18\hyphpar0\qj{section 903.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. An amount equal to twenty percent of all fines collected by cities shall be deposited in the account established in }}}{{\f5\fs18\hyphpar0\qj{section 602.8108}}}{{\f5\fs18\hyphpar0\qj{. However, one hundred percent of all fines collected by a city pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.236, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall be retained by the city. The crime services surcharge required by }}}{{\f5\fs18\hyphpar0\qj{section 911.1}}}{{\f5\fs18\hyphpar0\qj{ shall be added to a city fine and is not a part of the city\u8217\'3fs penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may not set standards and requirements which are lower or less stringent than those imposed by state law, but may set standards and requirements which are higher or more stringent than those imposed by state law, unless a state law provides otherwise.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not impose any fee or charge on any individual or business licensed by the plumbing and mechanical systems board for the right to perform plumbing, mechanical, HVAC, refrigeration, sheet metal, or hydronic systems work within the scope of the license. This paragraph does not prohibit a city from charging fees for the issuance of permits for, and inspections of, work performed in its jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt an ordinance, motion, resolution, or amendment that sets standards or requirements regarding the sale or marketing of consumer merchandise that are different from, or in addition to, any state law. For purposes of this paragraph:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConsumer merchandise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means merchandise offered for sale or lease, or provided with a sale or lease, primarily but not exclusively for personal, family, or household purposes, and includes any container used for consuming, carrying, or transporting such merchandise.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fContainer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a bag, cup, package, container, bottle, or other packaging that is all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designed to be either reusable or single-use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Made of cloth, paper, plastic, including foamed or expanded plastic, cardboard, corrugated material, aluminum, glass, or postconsumer recycled or similar material or substrates, including coated, laminated, or multilayer substrates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designed for consuming, transporting, or protecting merchandise, food, or beverages from or at a food service or retail facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ordinance, motion, resolution, or amendment adopted prior to March 30, 2017, that violates this paragraph is void and unenforceable on and after March 30, 2017.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to city solid waste or recycling collection or city solid waste or recycling programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt an ordinance, motion, resolution, or amendment, or use any other means, that restricts an owner of real property from refinancing existing debt on, selling, or otherwise transferring title to the property by requiring the owner to take or show compliance with any action with respect to the property or pay any fee before, during, or after refinancing existing debt on, selling, or transferring title to the property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may not levy a tax unless specifically authorized by a state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt or enforce any ordinance imposing any registration or licensing system or registration or license fees for or relating to owner-occupied manufactured or mobile homes including the lots, lands, or manufactured home community or mobile home park upon or in which they are located. A city shall not adopt or enforce any ordinance imposing any registration or licensing system, or registration or license fees, or safety or sanitary standards for rental manufactured or mobile homes unless a similar registration or licensing system, or registration or license fees, or safety or sanitary standards are required for other rental properties intended for human habitation. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not preclude the investigation and abatement of a nuisance or the enforcement of a tiedown system, or the enforcement of any rules of the department of health and human services or local board of health if those rules apply to other rental properties or to owner-occupied housing intended for human habitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not provide a civil penalty in excess of seven hundred fifty dollars for the violation of an ordinance which is classified as a municipal infraction or if the infraction is a repeat offense, a civil penalty not to exceed one thousand dollars for each repeat offense. A municipal infraction is not punishable by imprisonment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city which operates a cable communications system shall manage the right-of-way on a competitively neutral and nondiscriminatory basis. Additionally, a city-operated cable communications system shall be required to pay the same fees and charges and comply with other requirements as may be imposed by the city by ordinance or by the terms of a franchise granted by the city, or as may otherwise be imposed by the city, upon any other cable provider. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a city from making an equitable apportionment of franchise requirements between or among cable television providers, in order to eliminate duplication. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit a city-operated cable communications system from making transfers of surplus as otherwise allowed or from making in-kind contributions as otherwise allowed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may adopt and enforce an ordinance requiring the construction of a storm shelter at a manufactured home community or mobile home park which is constructed after July 1, 1999. In lieu of requiring construction of a storm shelter, a city may require a community or park owner to provide a plan for the evacuation of community or park residents to a safe place of shelter in times of severe weather including tornadoes and high winds if the city determines that a safe place of shelter is available within a reasonable distance of the manufactured home community or mobile home park for use by community or park residents. Each evacuation plan prepared pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be filed with, and approved by, the local emergency management agency. If construction of a storm shelter is required, an ordinance adopted or enforced pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not include any of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the size of the storm shelter be larger than the equivalent of seven square feet for each manufactured or mobile home space in the manufactured home community or mobile home park.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the storm shelter include a restroom if the shelter is used exclusively as a storm shelter.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the storm shelter exceed the construction specifications approved by a licensed professional engineer and presented by the owner of the manufactured home community or mobile home park.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the shelter be located any closer than one thousand three hundred twenty feet from any manufactured or mobile home in the community. However, this restriction shall not prohibit the adoption or enforcement of an ordinance that requires a minimum of one shelter to be located in a manufactured home community or mobile home park.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufactured home community\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as land-leased community defined in }}}{{\f5\fs18\hyphpar0\qj{sections 335.30A}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{414.28A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMobile home park\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a mobile home park as defined in }}}{{\f5\fs18\hyphpar0\qj{section 562B.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fStorm shelter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a single structure or multiple structures designed to provide persons with temporary protection from a storm.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt or enforce any ordinance imposing any limitation on the amount of rent that can be charged for leasing private residential or commercial property. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prevent the right of a city to manage and control residential property in which the city has a property interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city which operates a utility that furnishes gas or electricity shall manage the right-of-way on a competitively neutral and nondiscriminatory basis. Such city utility shall be required to pay the fees and charges computed in the same manner as those fees and charges which are imposed by the city upon any other provider of a similar service within the corporate boundaries of the city. Such city utility shall also comply with the terms of the franchise granted by the city to the provider of a similar service. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit the city utility from making transfers of surplus as otherwise allowed or from making in-kind contributions as otherwise allowed. However, a city shall not require that transfers from the city utility be in excess of the franchise fee amount imposed upon the provider of a similar service unless otherwise agreed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt or enforce any ordinance or regulation in violation of }}}{{\f5\fs18\hyphpar0\qj{section 562A.27B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{562B.25B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt, enforce, or otherwise administer an ordinance, motion, resolution, or amendment providing for any terms or conditions of employment that exceed or conflict with the requirements of federal or state law relating to a minimum or living wage rate, any form of employment leave, hiring practices, employment benefits, scheduling practices, or other terms or conditions of employment. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An ordinance, motion, resolution, or amendment adopted prior to March 30, 2017, that violates }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is void and unenforceable on and after March 30, 2017.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt, enforce, or otherwise administer an ordinance, motion, resolution, or amendment, or use any other means, to restrict, impede, regulate, or prohibit, intentionally or effectively, any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provision of natural gas service by a public utility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 476.1}}}{{\f5\fs18\hyphpar0\qj{, a competitive natural gas provider as defined in }}}{{\f5\fs18\hyphpar0\qj{section 476.86}}}{{\f5\fs18\hyphpar0\qj{, or a retail propane marketer or retail propane dispenser as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 101C.2}}}{{\f5\fs18\hyphpar0\qj{ to a person, business, municipality, or other wholesale or retail customer within or outside the incorporated area of the city.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purchase of natural gas or propane from a competitive natural gas provider as defined in }}}{{\f5\fs18\hyphpar0\qj{section 476.86}}}{{\f5\fs18\hyphpar0\qj{ or a retail propane marketer or retail propane dispenser as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 101C.2}}}{{\f5\fs18\hyphpar0\qj{, or the receipt of natural gas or propane service from a public utility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 476.1}}}{{\f5\fs18\hyphpar0\qj{, by any person, business, municipality, or other wholesale or retail customer within or outside the incorporated area of the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply to an ordinance granting, extending, amending, or renewing a franchise pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 364.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, that does not restrict or impede the provision of natural gas service.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply to an ordinance, motion, resolution, or amendment relating to the rates, services, or governance of a public utility providing gas service to the public for compensation and subject to the jurisdiction of the utilities commission pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 476.1B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply to an ordinance, motion, resolution, or amendment that regulates a retail propane marketer or retail propane dispenser, as those terms are defined in }}}{{\f5\fs18\hyphpar0\qj{section 101C.2}}}{{\f5\fs18\hyphpar0\qj{, adopted before July 1, 2021.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt an ordinance, motion, resolution, or amendment, or use any other means, that requires the owner of real property to implement a policy relating to the use of facial coverings that is more stringent than a policy imposed by the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt or enforce an ordinance, motion, resolution, or amendment imposing any requirement to obtain a permit or license, or to pay a fee, for an eligible business operated on an occasional basis for no more than eighty-nine calendar days in a calendar year by a person or persons under the age of eighteen. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3feligible business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an on-site transactional business traditionally operated exclusively by a person under the age of eighteen, including a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstand operated by a minor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as defined in }}}{{\f5\fs18\hyphpar0\qj{section 137F.1}}}{{\f5\fs18\hyphpar0\qj{, that a person under the age of eighteen is not otherwise prohibited by law from operating.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt or enforce an ordinance or regulation that prohibits an owner, lessor, sublessor, managing agent, or other person having the right to lease, sublease, or rent out a dwelling unit from refusing to lease or rent out the dwelling unit to a person because of the person\u8217\'3fs use of a federal housing choice voucher issued by the United States department of housing and urban development. Such an ordinance or regulation in effect on January 1, 2021, is void and unenforceable on and after January 1, 2023. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdwelling unit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 562A.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city that operates and maintains parking meters or non-metered parking lots shall not enforce any ordinance related to fees at such parking meters against, and shall not charge a fee at any non-metered parking lot to, a person whose vehicle is lawfully displaying any of the following registration plates:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Medal of honor special registration plates issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34, subsection 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ex-prisoner of war special registration plates issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34, subsection 8A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Purple heart special registration plates issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.34, subsection 18}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration plates displaying the alphabetical characters \u8220\'3fDV\u8221\'3f preceding the registration plate number pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 321.166, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to limit a city\u8217\'3fs authority to enforce other parking-related ordinances, including but not limited to ordinances regulating the length of time parking is allowed, parking along snow and emergency routes, and the hours and locations where parking is prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless expressly authorized by state law, a city shall not adopt, enforce, or maintain an ordinance, order, or rule for the purpose of making payments to individuals under a guaranteed income program.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general shall send a cease and desist order to any city that adopts or enforces an ordinance, order, or rule in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the city fails to comply with the cease and desist order, the attorney general shall bring an action in the name of the state for injunctive relief against any city that has adopted an ordinance, order, or rule in violation of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fguaranteed income program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a program under which individuals are provided with regular periodic cash payments that are unearned and that may be used for any purpose, but does not include a program under which an individual is required to perform work or attend training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A guaranteed income program operating prior to or on May 1, 2024, may remain in effect until January 1, 2025, or until expiration of the program, whichever is earlier. A city shall not start a guaranteed income program or extend an existing guaranteed income program after May 1, 2024.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this subsection:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConstruction site\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as used in a storm water general permit adopted by rule pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 455B.103A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTopsoil\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as used in a storm water general permit adopted by rule pursuant to section }}}{{\f5\fs18\hyphpar0\qj{section 455B.103A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt or enforce an ordinance, motion, resolution, or amendment relating to the preservation, compaction, placement, or depth of topsoil at a construction site that is more restrictive than those requirements provided in the national pollutant discharge elimination system general permit no. 2 as issued by the department of natural resources. A city may develop standards to evaluate topsoil quantities before and after construction and ensure compliance with general permit no. 2. A city may request that the department of natural resources review the soil of a construction site to verify that the national pollutant discharge elimination system general permit no. 2 as issued by the department of natural resources is proper for the construction site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may adopt or enforce an ordinance, motion, resolution, or amendment that regulates storm water runoff at a construction site only to the extent that such regulation for rainfall events having a return frequency ranging from five through one hundred years does not require a post-construction storm water flow rate that is more restrictive than the existing flow rate of a rainfall event having a return frequency of five years, with all such runoff rates based on the actual existing condition of the site at the time the construction commences.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may adopt or enforce an ordinance, motion, resolution, or amendment that regulates storm water runoff from upstream properties adjacent to a construction site only to the extent that storm water runoff shall be allowed to pass through downstream storm water basins at the same flow rate as off-site storm water runoff entering the construction site.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may impose a storm water runoff requirement that is more restrictive than what is allowed or required by this paragraph at the construction site if the city meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city pays for all study, design, and engineering costs for implementing the storm water runoff requirement that includes an analysis by a licensed professional engineer of the difference in costs between the requirements of this paragraph and the more restrictive city storm water runoff requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city pays for the difference of costs between the requirements of this paragraph and the more restrictive requirement imposed by the city for installation of equipment or practices required for a property owner to comply with the storm water runoff requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the storm water runoff requirement results in the city using a person\u8217\'3fs private property, whether by easement or otherwise taking an interest in the property, the city pays the property owner the fair market value of the property taken for any additional land required beyond the requirements of this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not impose a special assessment or otherwise recover the costs from the property owner for the portion of the costs attributable to the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs attributable to the city shall only apply to the storm water management practices addressed in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt or enforce an ordinance, motion, resolution, or amendment that imposes restrictions, qualifications, or requirements on developers, contractors, or subcontractors related to a developer\u8217\'3fs or contractor\u8217\'3fs employee compensation or training beyond what is expressly authorized by state law. A city shall not make receipt of any incentives, or the eligibility for such incentives, contingent upon compliance with any such restrictions, qualifications, or requirements, except as required under federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not adopt or continue in effect any regulation, including in the form of an ordinance or resolution, that governs fuel-powered equipment as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 214A, subchapter IV}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city with a civil service commission established under }}}{{\f5\fs18\hyphpar0\qj{chapter 400}}}{{\f5\fs18\hyphpar0\qj{ shall not adopt, enforce, or otherwise administer an ordinance, motion, resolution, or amendment, or use any other means, to establish a board or other entity for the purpose of citizen review of the conduct of officers as defined under }}}{{\f5\fs18\hyphpar0\qj{section 80F.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall allow a minimum of one accessory dwelling unit on the same lot as a single family residence in accordance with the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accessory dwelling unit shall comply with all applicable building regulations as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 103A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accessory dwelling unit shall not exceed one thousand square feet or fifty percent of the size of the single family residence, whichever is larger.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accessory dwelling unit shall be prohibited or limited only to the extent that a state historic building code restriction, as adopted by a city in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 103A.43, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, a deed restriction, or a rule of a common interest community, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 499C.1}}}{{\f5\fs18\hyphpar0\qj{, limits or prohibits the construction or use of an accessory dwelling unit. The imposition of an ordinance, motion, resolution, or amendment regulating accessory dwelling units that is more restrictive when applied to a common interest community than when applied to a single family residence is prohibited.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a manufactured home as defined in }}}{{\f5\fs18\hyphpar0\qj{section 435.1, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, or a mobile home as defined in }}}{{\f5\fs18\hyphpar0\qj{section 435.1, subsection 5}}}{{\f5\fs18\hyphpar0\qj{, is used as an accessory dwelling unit, the manufactured home or mobile home shall be converted to real property by being placed on a permanent foundation and assessed for real estate taxes pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 435.26}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or by state law, a city shall not impose any of the following limitations or restrictions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requirements related to the placement or appearance of an accessory dwelling unit that are more restrictive than those imposed on a single family residence including but not limited to the following: maximum building heights; minimum setback requirements; minimum lot sizes; minimum building frontages; maximum lot coverages; density requirements; and aesthetic or architectural standards or requirements. Additionally, a city shall not require an accessory dwelling unit to match the exterior design, roof pitch, or finishing materials of the single family residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Regulations on the use of an accessory dwelling unit as a rental property that are more restrictive than those provided for in }}}{{\f5\fs18\hyphpar0\qj{subsections 9 and 16}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 414.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{chapter 562A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A requirement that the lot containing a single family residence and an accessory dwelling unit have additional parking beyond that required for a single family residence or payment of a fee in lieu of providing additional parking.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Restrictions on the occupancy of either the single family residence or the accessory dwelling unit by any of the following manners: requiring the property owner to be a resident; requiring a familial, marital, or employment relationship to exist between the occupants of the single family residence and the occupants of the accessory dwelling unit; or restricting the occupancy of an accessory dwelling unit based on income or age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A requirement of new or separate utility lines between the accessory dwelling unit and public utility service connections. However, if full utility access that includes a separate metering system for billing purposes cannot be provided to the accessory dwelling unit, then the city can require new or separate utility lines.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Imposition of a different city impact fee structure or development standard for an accessory dwelling unit than those used for the single family residence on the same lot.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement of improvements or repairs to public streets or sidewalks beyond those imposed on the single family residence on the same lot.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall approve an accessory dwelling unit permit application that meets the requirements set forth in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and by state law without discretionary review or hearing and consistent with the time frame assigned to the approval of a single family residence. An accessory dwelling unit permit application shall not have a review timeline or schedule in excess of a city\u8217\'3fs normal review schedule for a single family residence. If the city denies an accessory dwelling unit permit, the reason for denial shall be provided in writing to the applicant and include any remedy necessary to secure approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city ordinance, motion, resolution, or amendment regulating accessory dwelling units in a manner that conflicts with this subsection is void. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ prohibits a city from adopting an ordinance, motion, resolution, or amendment that is more permissive than the requirements provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAccessory dwelling unit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an additional residential dwelling unit located on the same lot as a single family residence that is either attached to or detached from the single family residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDetached\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes being part of an accessory structure such as a detached garage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDwelling unit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 562A.6, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSingle family residence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 562A.6, subsection 15}}}{{\f5\fs18\hyphpar0\qj{, except to the extent that a single family residence may share utility lines with the accessory dwelling unit if full utility access that includes a separate metering system for billing purposes can be provided to the accessory dwelling unit.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71071 \u8211\'3f 1073, 1095; C73, \'a7482, 524; C97, \'a7668, 680, 947; S13, \'a7668; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5663, 5714, 6720;}}}{ C46, 50, \'a7363.36, 366.1, 420.31; C54, 58, 62, \'a7366.1, 368A.1(10), 420.31; C66, 71, 73, \'a7366.1, 368.2, 368A.1(10), 420.31; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a7171, 209}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1219, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 195, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1202, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71118}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1074, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1144, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 33, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 153, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 186, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1083, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 153, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1111, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 21, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a7229, 231}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 100, \'a714, 15}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 77, \'a734, 36}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1120, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 20, \'a73 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1013, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a775}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1074, \'a74, 93}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 44, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 49, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 139, \'a730, 31}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 179, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1134, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71114, 2664}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1011, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1109, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369, 425}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 6, \'a722, 23}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 26, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 38, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 82, \'a71, 12}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 152, \'a719 \u8211\'3f 21}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713.2}}}{{\f5\fs12\hyphpar0\qj{, 331.427}}}{{\f5\fs12\hyphpar0\qj{, 364.22}}}{{\f5\fs12\hyphpar0\qj{, 388.10}}}{{\f5\fs12\hyphpar0\qj{, 455B.192}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See Code editor\u8217\'3fs note on simple harmonization at the beginning of this Code volume}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 22 effective August 16, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 82, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsections 20 \u8211\'3f 23}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Property and services outside of city \u8212\'3f lease-purchase \u8212\'3f insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city may:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Acquire, hold, and dispose of property outside the city in the same manner as within. However, the power of a city to acquire property outside the city does not include the power to acquire property outside the city by eminent domain, except for the following, subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapters 6A}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{6B}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a city utility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 362.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a city franchise conferred the authority to condemn private property under }}}{{\f5\fs18\hyphpar0\qj{section 364.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a combined utility system as defined in }}}{{\f5\fs18\hyphpar0\qj{section 384.80}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a municipal airport.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a landfill or other solid waste disposal or processing site.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The use of property for public streets and highways.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The operation of a multistate entity, of which the city is a participating member, created to provide drinking water that has received or is receiving federal funds, but only if such property is to be acquired for water transmission and service lines, pump stations, water storage tanks, meter houses and vaults, related appurtenances, or supporting utilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The exceptions provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) through (3), apply only to the extent the city had this power prior to July 1, 2006.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By contract, extend services to persons outside the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enact and enforce ordinances relating to city property and city-extended services outside the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter into leases or lease-purchase contracts for real or personal property in accordance with the following terms and procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall lease or lease-purchase property only for a term which does not exceed the economic life of the property, as determined by the governing body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lease or lease-purchase contract entered into by a city may contain provisions similar to those sometimes found in leases between private parties, including, but not limited to, the obligation of the lessee to pay any of the costs of operation or ownership of the leased property and the right to purchase the leased property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision of a lease or lease-purchase contract which stipulates that a portion of the rent payments be applied as interest is subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{{\f5\fs18\hyphpar0\qj{. Other laws relating to interest rates do not apply. }}}{{\f5\fs18\hyphpar0\qj{Chapter 75}}}{{\f5\fs18\hyphpar0\qj{ is not applicable. A city utility or city enterprise is a separate entity under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ whether it is governed by the governing body of the city or another governing body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body must follow substantially the same authorization procedure required for the issuance of general obligation bonds issued for the same purpose to authorize a lease or a lease-purchase contract made payable from the debt service fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body may authorize a lease or lease-purchase contract which is payable from the general fund if the contract would not cause the total of annual lease or lease-purchase payments due from the general fund of the city in any single future fiscal year for all lease or lease-purchase contracts in force on the date of the authorization, excluding payments to exercise purchase options or to pay the expenses of operation or ownership of the property, to exceed ten percent of the last certified general fund budget amount in accordance with the following procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body must follow substantially the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 384.25}}}{{\f5\fs18\hyphpar0\qj{ to authorize a lease or lease-purchase contract for personal property which is payable from the general fund. The governing body must follow substantially the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 384.25}}}{{\f5\fs18\hyphpar0\qj{ to authorize the lease or lease-purchase contract for real property which is payable from the general fund if the principal amount of the lease-purchase contract does not exceed the following limits:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Four hundred thousand dollars in a city having a population of five thousand or less.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seven hundred thousand dollars in a city having a population of more than five thousand but not more than seventy-five thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One million dollars in a city having a population of more than seventy-five thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body must follow the following procedures to authorize a lease or lease-purchase contract for real property which is payable from the general fund if the principal amount of the lease or lease-purchase contract exceeds the limits set forth in subparagraph (1):}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body must institute proceedings to enter into a lease or lease-purchase contract payable from the general fund by causing a notice of the meeting to discuss entering into the lease or lease-purchase contract, including a statement of the principal amount and purpose of the lease or lease-purchase contract and the right to petition for an election, to be published at least once in a newspaper of general circulation within the city at least ten days prior to the discussion meeting. No sooner than thirty days following the discussion meeting shall the governing body hold a meeting at which it is proposed to take action to enter into the lease or lease-purchase contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time before the end of the thirty-day period after which a meeting may be held to take action to enter into the lease or lease-purchase contract, a petition is filed with the clerk of the city in the manner provided by }}}{{\f5\fs18\hyphpar0\qj{section 362.4}}}{{\f5\fs18\hyphpar0\qj{, asking that the question of entering into the lease or lease-purchase contract be submitted to the registered voters of the city, the governing body shall either by resolution declare the proposal to enter into the lease or lease-purchase contract to have been abandoned or shall direct the county commissioner of elections to call a special election upon the question of entering into the lease or lease-purchase contract. However, for purposes of this subparagraph, the petition shall not require signatures in excess of one thousand persons.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The question to be placed on the ballot shall be stated affirmatively in substantially the following manner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the city of }{{\f5\fs18\hyphpar0\qj{................................}}}{ enter into a lease or lease-purchase contract in amount of $}{{\f5\fs18\hyphpar0\qj{................}}}{ for the purpose of }{{\f5\fs18\hyphpar0\qj{........................}}}{?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notice of the election and its conduct shall be in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{section 384.26, subsections 2 through 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a petition is not filed or if a petition is filed and the proposition of entering into the lease or lease-purchase contract is approved at an election, the governing body may proceed and enter into the lease or lease-purchase contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governing body may authorize a lease or lease-purchase contract payable from the net revenues of a city utility, combined utility system, city enterprise, or combined city enterprise by following the authorization procedures of }}}{{\f5\fs18\hyphpar0\qj{section 384.83}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lease or lease-purchase contract to which a city is a party or in which a city has a participatory interest is an obligation of a political subdivision of this state for the purposes of }}}{{\f5\fs18\hyphpar0\qj{chapters 502}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{636}}}{{\f5\fs18\hyphpar0\qj{, and is a lawful investment for banks, trust companies, savings associations, investment companies, insurance companies, insurance associations, executors, guardians, trustees, and any other fiduciaries responsible for the investment of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Property that is lease-purchased by a city is exempt under }}}{{\f5\fs18\hyphpar0\qj{section 427.1, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract for construction by a private party of property to be lease-purchased by a city is a contract for a public improvement under }}}{{\f5\fs18\hyphpar0\qj{section 26.2, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. If the estimated cost of the property to be lease-purchased that is renovated, repaired, or involves new construction exceeds the competitive bid threshold set in }}}{{\f5\fs18\hyphpar0\qj{section 26.3}}}{{\f5\fs18\hyphpar0\qj{, the city shall comply with the competitive bidding requirements of }}}{{\f5\fs18\hyphpar0\qj{section 26.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enter into insurance agreements obligating the city to make payments beyond its current budget year to procure or provide for a policy of insurance, a self-insurance program, or a local government risk pool to protect the city against tort liability, loss of property, or any other risk associated with the operation of the city. Such a self-insurance program or local government risk pool is not insurance and is not subject to regulation under }}}{{\f5\fs18\hyphpar0\qj{chapters 505 through 523C}}}{{\f5\fs18\hyphpar0\qj{. However, those self-insurance plans regulated pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 509A.14}}}{{\f5\fs18\hyphpar0\qj{ shall remain subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 509A.14}}}{{\f5\fs18\hyphpar0\qj{ and rules adopted pursuant to that section.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a7741-d, 741-g; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5773;}}}{ C46, \'a7368.41, 368.42; C50, \'a7368.42, 368.56; C54, 58, 62, 66, 71, 73, \'a7368.18; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 156, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1211, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1138, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 67, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1017, \'a735, 42, 43}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2006 Acts, 1st Ex, ch 1001, \'a732, 49}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 100, \'a712, 21}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a775}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1075, \'a711 \u8211\'3f 13}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a731, 71, 72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7346.27}}}{{\f5\fs12\hyphpar0\qj{, 384.110}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Joint action \u8212\'3f Iowa league of cities \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city or a board established to administer a city utility, in the exercise of any of its powers, may act jointly with any public or private agency as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financial condition and the transactions of the Iowa league of cities shall be audited as provided in }}}{{\f5\fs18\hyphpar0\qj{section 11.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for the Iowa league of cities to provide any form of aid to a political party or to the campaign of a candidate for political or public office. Any person violating or being an accessory to a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may enter into an agreement with the federal government acting through any of its authorized agencies, and may carry out provisions of the agreement as necessary to meet federal requirements to obtain the funds or cooperation of the federal government or its agencies for the planning, construction, rehabilitation, or extension of a public improvement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7694-c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5684;}}}{ C46, 50, \'a7363.62; C54, 58, 62, 66, 71, 73, \'a7363.43; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 264, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 3, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 75, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city shall substantially comply with a procedure established by a state law for exercising a city power. If a procedure is not established by state law, a city may determine its own procedure for exercising the power.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, \'a7368.2; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disposal of property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city may not dispose of an interest in real property by sale, lease for a term of more than three years, or gift, except in accordance with the following procedure:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The council shall set forth its proposal in a resolution and shall publish notice as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{, of the resolution and of a date, time and place of a public hearing on the proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After the public hearing, the council may make a final determination on the proposal by resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may not dispose of real property by gift except to a governmental body for a public purpose.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7470; C97, \'a7883, 1001; S13, \'a71056-a47; C24, 27, \'a76205, 6206, 6580, 6602, 6738, 6739; C31, 35, \'a76205, 6206, 6580, 6602, 6679-c1, 6738, 6739; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6205, 6206, 6580, 6602, 6679.1, 6738, 6739;}}}{ C46, 50, \'a7390.6, 403.11, 403.12, 416.108, 416.131, 419.66, 420.49, 420.50; C54, 58, 62, 66, 71, 73, \'a7368.35, 368.39, 390.6; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 54, \'a733}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7174.15}}}{{\f5\fs12\hyphpar0\qj{, 306.42}}}{{\f5\fs12\hyphpar0\qj{, 364.12A}}}{{\f5\fs12\hyphpar0\qj{, 446.19A}}}{{\f5\fs12\hyphpar0\qj{, 476.84}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Overpasses or underpasses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city may by ordinance require a railway company operating railway tracks on or across a city street to construct or reconstruct, and maintain, an overpass or underpass to permit the street to pass over or under the tracks, and may establish specifications for the construction or reconstruction of such an overpass or underpass, subject to the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement may not be enforced until the Iowa state department of transportation approves the specifications for a construction or reconstruction, after examination and a determination that the overpass or underpass is necessary for public safety and convenience.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The council shall hold a hearing on the matter and shall give not less than twenty days\u8217\'3f notice of the hearing to the railway companies involved, served in the same manner as an original notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may not require overpasses or underpasses of the same railway company to be constructed closer than on every fourth parallel street, nor require a company to construct or contribute to the construction of more than one overpass or underpass each year, nor require the construction of approaches longer than a total of eight hundred feet for a single overpass or underpass.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city which requires construction or reconstruction of an overpass or underpass shall provide for appraisal and assessment of resulting damage to private property, and shall pay the damages assessed, all as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 6B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall pay one half of all required maintenance costs, and may allocate costs between railway companies whose tracks are to be crossed by an overpass or underpass.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may enforce a requirement made as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by an action in mandamus, to be conducted and enforced as provided in }}}{{\f5\fs18\hyphpar0\qj{section 327C.16}}}{{\f5\fs18\hyphpar0\qj{ for actions brought by the state department of transportation. If the city prevails in the mandamus action, in addition to other remedies it may cause the required construction, reconstruction, or maintenance work to be done, and have judgment for the cost of the work against the companies.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7770 \u8211\'3f 774; S13, \'a7771, 773, 774; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5910 \u8211\'3f 5913, 5916 \u8211\'3f 5920, 5923 \u8211\'3f 5925;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7387.1 \u8211\'3f 387.4, 387.7 \u8211\'3f 387.11, 387.14 \u8211\'3f 387.16; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Flood control \u8212\'3f railway tracks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city may require a railway company to provide necessary structures, temporary and permanent, to carry its tracks during and after construction of a diverted channel for flood control purposes, subject to the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city shall give notice to the railway company, served in the same manner as an original notice, stating:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nature of the flood control project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The place where the diverted channel will cross the company\u8217\'3fs right-of-way.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The specifications for construction of the diverted channel across the company\u8217\'3fs right-of-way.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Details of the city\u8217\'3fs requirement for the company to provide the necessary structures where the diverted channel crosses the right-of-way, including a designated period of time for construction, and a requirement that the construction be in a manner which does not interfere with the construction of the diverted channel or the free flow of water.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the company does not comply with the requirement, the city may provide the necessary structures, and the railway is liable for the cost of the construction, in addition to its liability for assessment for special benefits as other property is assessed. The cost of the construction may be collected by the city from the company by court action.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6093 \u8211\'3f 6095;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7395.15 \u8211\'3f 395.17; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.10}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Street construction by railways.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All railway companies shall construct and repair all street improvements between the rails of their tracks, and one foot outside, at their own expense, unless by ordinance the railway is required to improve other portions of the street, and in that case the railway shall construct and repair the improvement of that part of the street specified by the ordinance, and the improvement or repair must be of the material and character ordered by the city, and must be done at the time the remainder of the improvement is constructed or repaired.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When an improvement is made, the company shall lay rail as required by the council, and shall then keep up to grade that part of the improvement they are required to construct or maintain.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a railway fails or refuses to comply with the order of the council to construct or repair an improvement, the work may be done by the city and the expense shall then be assessed upon the property of the railway company, for collection in the same manner as a property tax. A tax assessed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall also be a debt due from the railway, and may be collected in an action at law in the same manner as other debts.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71068; C73, \'a7478; C97, \'a7834, 840; C13, \'a7791-i; SS15, \'a7840-r; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6052 \u8211\'3f 6055;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7391.79 \u8211\'3f 391.82; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.13A}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.12}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Responsibility for public places.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fproperty owner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the contract purchaser if there is one of record, otherwise the record holder of legal title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall keep all public grounds, streets, sidewalks, alleys, bridges, culverts, overpasses, underpasses, grade crossing separations and approaches, public ways, squares, and commons open, in repair, and free from nuisance, with the following exceptions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Public ways and grounds may be temporarily closed by resolution. Following notice as provided in }}}{{\f5\fs18\hyphpar0\qj{section 362.3}}}{{\f5\fs18\hyphpar0\qj{, public ways and grounds may be vacated by ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The abutting property owner is responsible for the removal of the natural accumulations of snow and ice from the sidewalks within a reasonable amount of time and may be liable for damages caused by the failure of the abutting property owner to use reasonable care in the removal of the snow or ice. If damages are to be awarded under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ against the abutting property owner, the claimant has the burden of proving the amount of the damages. To authorize recovery of more than a nominal amount, facts must exist and be shown by the evidence which afford a reasonable basis for measuring the amount of the claimant\u8217\'3fs actual damages, and the amount of actual damages shall not be determined by speculation, conjecture, or surmise. All legal or equitable defenses are available to the abutting property owner in an action brought pursuant to this paragraph. The city\u8217\'3fs general duty under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not include a duty to remove natural accumulations of snow or ice from the sidewalks. However, when the city is the abutting property owner it has the specific duty of the abutting property owner set forth in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The abutting property owner may be required by ordinance to maintain all property outside the lot and property lines and inside the curb lines upon the public streets, except that the property owner shall not be required to remove diseased trees or dead wood on the publicly owned property or right-of-way.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may serve notice on the abutting property owner, by certified mail to the property owner as shown by the records of the county auditor, requiring the abutting property owner to repair, replace, or reconstruct sidewalks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the abutting property owner does not perform an action required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ within a reasonable time, a city may perform the required action and assess the costs against the abutting property for collection in the same manner as a property tax. This power does not relieve the abutting property owner of liability imposed under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city has no duty under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ with respect to property that is required by law to be maintained by a railway company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the abatement of a nuisance, public or private, in any reasonable manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the removal of diseased trees or dead wood, except as stated in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the removal, repair, or dismantling of a dangerous building or structure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the numbering of buildings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require connection to public drainage systems from abutting property when necessary for public health or safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require connection to public sewer systems from abutting property, and require installation of sanitary toilet facilities and removal of other toilet facilities on such property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require the cutting or destruction of weeds or other growth which constitutes a health, safety, or fire hazard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the property owner does not perform an action required under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ within a reasonable time after notice, a city may perform the required action and assess the costs against the property for collection in the same manner as a property tax. Notice may be in the form of an ordinance or by certified mail to the property owner as shown by the records of the county auditor, and shall state the time within which action is required. However, in an emergency a city may perform any action which may be required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ without prior notice, and assess the costs as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, after notice to the property owner and hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other remedy provided by law, a city may also seek reimbursement for costs incurred in performing any act authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by a civil action for damages against a property owner. However, a city shall not seek reimbursement for costs incurred in performing an act if the same act has not been performed by the city on adjoining city-owned property. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a county acquiring property for delinquent taxes shall not be considered a property owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may cause, without prior determination and notice, the repair or replacement of public improvements including, but not limited to, sidewalks, water stop boxes, and driveway approaches if the property owner does all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requests the repair and replacement of the public improvements specified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ abutting the property owner\u8217\'3fs property located outside the lot and property lines and inside the curb lines.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Waives the requirement of a prior finding by the city council that the condition of the public improvements constitutes a nuisance and the requirement of prior notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consents to the repair of the public improvements and the assessment of the cost of the repair to the abutting property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, in repairing and replacing improvements in the area between the lot or property lines and the curb lines pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, it becomes necessary for the city to repair or replace adjacent improvements in the area, the cost of repairing or replacing the adjacent public improvements may be assessed, with consent of the property owner, against the property which the public improvements abut.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may accumulate individual assessments for the repair and replacement of sidewalks, driveway approaches, water stop boxes, or similar improvements or for the abatement of nuisances, and may periodically certify the assessments to the county treasurer under one or more assessment schedules.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.12(1)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[R60, \'a71097; C73, \'a7467, 527; C97, \'a7753, 757, 780, 781; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5874, 5945, 5950, 5969;}}}{ C46, 50, \'a7381.1, 389.12, 389.19, 389.38; C54, 58, 62, 66, \'a7368.33, 381.1, 389.12, 389.38; C71, 73, \'a7368.33, 381.1, 381.2, 389.12, 389.38; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.12(2)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[R60, \'a71057, 1058, 1070, 1096; C73, \'a7456, 457, 480, 526; C97, \'a7696, 698, 699, 709 \u8211\'3f 712; S13, \'a7696, 711, 713-b, 737; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5739, 5751, 5752, 5755, 5759, 5784 \u8211\'3f 5786;}}}{ C46, \'a7368.2, 368.14, 368.15, 368.18, 368.22 \u8211\'3f 368.24, 368.44, 368.53 \u8211\'3f 368.55; C50, \'a7368.2, 368.14, 368.15, 368.18, 368.22 \u8211\'3f 368.24, 368.44, 368.53 \u8211\'3f 368.55, 368.62; C54, 58, 62, 66, 71, 73, \'a7368.3, 368.4, 368.9, 368.26, 368.31; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.12(3)}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1002, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 261, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 58, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.13}}}{{\f5\fs12\hyphpar0\qj{, 364.13A}}}{{\f5\fs12\hyphpar0\qj{, 384.11}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Nuisances in general, }{{\f5\fs12\hyphpar0\qj{chapter 657}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.12A}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Condemnation of residential buildings \u8212\'3f public purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purposes of }{{\f5\fs18\hyphpar0\qj{section 6A.4, subsection 6}}}{, a city may condemn a residential building found to be a public nuisance and take title to the property for the public purpose of disposing of the property under }{{\f5\fs18\hyphpar0\qj{section 364.7}}}{ by conveying the property to a private individual for rehabilitation or for demolition and construction of housing.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1204, \'a726}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.13}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Installments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any amount assessed against property under }{{\f5\fs18\hyphpar0\qj{section 364.12}}}{ will exceed five hundred dollars, a city may permit the assessment to be paid in up to ten annual installments, in the same manner and with the same interest rates provided for assessments against benefited property under }{{\f5\fs18\hyphpar0\qj{chapter 384, subchapter IV}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5784 \u8211\'3f 5786;}}}{ C46, 50, \'a7368.53 \u8211\'3f 368.55; C54, 58, \'a7368.26; C62, 66, \'a7368.26, 389.38; C71, 73, \'a7368.3, 368.26, 389.38; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1138, \'a7100}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.13A}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special assessments \u8212\'3f lien and precedence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A special assessment levied pursuant to }{{\f5\fs18\hyphpar0\qj{section 364.11}}}{ or }{{\f5\fs18\hyphpar0\qj{364.12}}}{, including all interest, is a lien against the benefited property from the date of filing the schedule of assessments until the assessment is paid. Special assessments have equal precedence with ordinary taxes and are not divested by judicial sale.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 90, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.13B}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special assessments \u8212\'3f procedures for levy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The procedures for making and levying a special assessment pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and for an appeal of the assessment are the same procedures as provided in }{{\f5\fs18\hyphpar0\qj{sections 384.59 through 384.67}}}{ and }{{\f5\fs18\hyphpar0\qj{sections 384.72 through 384.75}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 90, \'a720}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.14}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Personal injuries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When action is brought against a city for personal injuries alleged to have been caused by its negligence, the city may notify in writing any person by whose negligence it claims the injury was caused. The notice shall state the pendency of the action, the name of the plaintiff, the name and location of the court where the action is pending, a brief statement of the alleged facts from which the cause arose, that the city believes that the person notified is liable to it for any judgment rendered against the city, and asking the person to appear and defend. A judgment obtained in the suit is conclusive in any action by the city against any person so notified, as to the existence of the defect or other cause of the injury or damage, as to the liability of the city to the plaintiff in the first named action, and as to the amount of the damage or injury. A city may maintain an action against the person notified to recover the amount of the judgment together with all the expenses incurred by the city in the suit.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a71053; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6735;}}}{ C46, 50, \'a7420.46; C54, 58, 62, 66, 71, 73, \'a7368.34, 420.46; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.15}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Changing grade of streets.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a city has established the grade of a street or alley, and any person has made improvements on lots abutting the street or alley according to the established grade, and afterward the grade is altered in a manner to damage, injure, or diminish the value of the improved property, the city shall pay to the owner of the property the amount of such damage or injury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a city has opened a street or alley, and any person has made improvements on lots abutting the street or alley or uses such street or alley for ingress or egress, and afterward the street or alley is vacated causing damage or injury or loss of access, or diminishing the value of the improved property, the city shall pay to the owner of the property the amount of such damage or injury.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7469; C97, \'a7785, 786; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5953, 5954;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a7389.22, 389.23; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.16}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Municipal fire protection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each city shall provide for the protection of life and property against fire and may establish, house, equip, staff, uniform, and maintain a fire department. A city may establish fire limits and may, consistent with code standards promulgated by nationally recognized fire prevention agencies, regulate the storage, handling, use, and transportation of all flammables, combustibles, and explosives within the corporate limits and inspect for and abate fire hazards. A city may provide conditions upon which the fire department will answer calls outside the corporate limits or the territorial jurisdiction and boundary limits of this state. A city has the same governmental immunity outside its corporate limits when providing fire protection as when operating within the corporate limits. Fire fighters operating equipment on calls outside the corporate limits are entitled to the benefits of }{{\f5\fs18\hyphpar0\qj{chapter 410}}}{ or }{{\f5\fs18\hyphpar0\qj{411}}}{ when otherwise qualified.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71058, 1096; C73, \'a7457, 525; C97, \'a7711, 716; S13, \'a7711; C24, 27, \'a75760, 5766; C31, 35, \'a75760, 5766; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5760, 5766, 5766.1;}}}{ C46, 50, \'a7368.23, 368.29, 368.30; C54, 58, 62, 66, 71, 73, \'a7368.11; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7364.16}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1163, \'a784}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7357B.8}}}{{\f5\fs12\hyphpar0\qj{, 357J.15}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.17}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{City housing codes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city with a population of fifteen thousand or more may adopt by ordinance the latest version of one of the following housing codes before January 1, 1981:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The uniform housing code promulgated by the international conference of building officials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The housing code promulgated by the American public health association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The basic housing code promulgated by the building officials conference of America.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The standard housing code promulgated by the southern building code congress international.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Housing quality standards promulgated by the United States department of housing and urban development for use in assisted housing programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every city with a population of fifteen thousand or more which has not adopted another housing code under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by January 1, 1981, is subject to and shall be considered to have adopted the uniform housing code promulgated by the international conference of building officials, as amended to January 1, 1980. A city which reaches a population of fifteen thousand, as determined after July 1, 1980, has six months after such determination to comply with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city which adopts or is subject to a housing code under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall adopt enforcement procedures, which shall include a program for regular rental inspections, rental inspections upon receipt of complaints, and certification of inspected rental housing, and may include but are not limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A schedule of civil penalties or criminal fines for violations. A city may charge the owner of housing a late payment fee of twenty-five dollars and may add interest of up to one and one-half percent per month if a penalty or fine imposed under this subparagraph is not paid within thirty days of the date that the penalty or fine is due. The city shall send a notice of the late payment fee to such owner by first class mail to the owner\u8217\'3fs personal or business mailing address. The late payment fee and the interest shall not accrue if such owner files an appeal with either the city, if the city has established an appeals procedure, or the district court. Any unpaid penalty, fine, fee, or interest shall constitute a lien on the real property and may be collected in the same manner as a property tax. However, before a lien is filed, the city shall send a notice of intent to file a lien to the owner of the housing by first class mail to such owner\u8217\'3fs personal or business mailing address.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authority for the issuance of orders requiring violations to be corrected within a reasonable time.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authority for the issuance of citations pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 805.1 through 805.5}}}{{\f5\fs18\hyphpar0\qj{ upon a failure to satisfactorily remedy a violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authority, if other methods have failed, for an officer to contract to have work done as necessary to remedy a violation, the cost of which shall be assessed to the violator and constitute a lien on the property until paid.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An escrow system for the deposit of rent which will be applied to the costs of correcting violations.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Mediation of disputes based upon alleged violations.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Injunctive procedures.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authority by ordinance to provide that no rent shall be recoverable by the owner or lessee of any dwelling which does not comply with the housing code adopted by the city until such time as the dwelling does comply with the housing code adopted by the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The enforcement procedures shall be designed to improve housing conditions rather than to displace persons from their homes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city which is subject to the uniform housing code or which adopts another housing code under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may provide reasonable variances for existing structures which cannot practicably meet the standards in the code but are not unsafe for habitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cities may establish reasonable fees for inspection and enforcement procedures. A city may charge the owner of housing a late payment penalty of twenty-five dollars and may add interest of up to one and one-half percent per month if a fee imposed under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is not paid within thirty days of the date that the fee is due. The city shall send a notice of the late payment penalty to such owner by first class mail to the owner\u8217\'3fs personal or business mailing address. The late payment penalty and the interest shall not accrue if such owner files an appeal with either the city, if the city has established an appeals procedure, or the district court. Any unpaid fee, penalty, or interest shall constitute a lien on the real property and may be collected in the same manner as a property tax. However, before a lien is filed, the city shall send a notice of intent to file a lien to the owner of the housing by first class mail to such owner\u8217\'3fs personal or business mailing address.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cities with populations of less than fifteen thousand may comply with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may adopt housing code provisions which are more stringent than those in the model housing code it adopts or to which it is subject under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6327 \u8211\'3f 6451;}}}{ C46, 50, 54, 58, 62, 66, \'a7413.1 \u8211\'3f 413.125; C71, 73, 75, 77, 79, \'a7413.1 \u8211\'3f 413.11, 413.13 \u8211\'3f 413.125; }{{\f5\fs18\hyphpar0\qj{C81, \'a7364.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 179, \'a760, 61}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a7130}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7235}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.18}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Federal aid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Subject to applicable state or federal regulations in effect at the time of the city action, a city may accept contributions, grants, or other financial assistance from the state or federal government. Upon a finding of public purpose, the city may disburse the assistance to any person to be used for economic development projects, including but not limited to the purchase or improvement of land and buildings for residential, commercial, or industrial use.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 48, \'a71, 3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.19}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contracts to provide services to tax-exempt property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city council or county board of supervisors may enter into a contract with a person whose property is totally or partially exempt from taxation under }{{\f5\fs18\hyphpar0\qj{chapter 404}}}{, }{{\f5\fs18\hyphpar0\qj{chapter 404B}}}{, }{{\f5\fs18\hyphpar0\qj{section 427.1}}}{, or }{{\f5\fs18\hyphpar0\qj{section 427B.1}}}{, for the city or county to provide specified services to that person including but not limited to police protection, fire protection, street maintenance, and waste collection. The contract shall terminate as of the date previously exempt property becomes subject to taxation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1232, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 100, \'a722, 30}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.20}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motor vehicles required to operate on ethanol blended gasoline.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A motor vehicle purchased or used by a city to provide city services shall not operate on gasoline other than ethanol blended gasoline as defined in }{{\f5\fs18\hyphpar0\qj{section 214A.1}}}{. The motor vehicle shall also be affixed with a brightly visible sticker which notifies the traveling public that the motor vehicle is being operated on ethanol blended gasoline. However, the sticker is not required to be affixed to an unmarked vehicle used for purposes of providing law enforcement or security.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 254, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 26, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1142, \'a769}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.21}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of vacant school property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city shall not lease, purchase, or construct a building before considering the leasing of a vacant facility or building owned by a local public school corporation. The city may lease a facility or building owned by a local public school corporation with an option to purchase the facility or building in compliance with }{{\f5\fs18\hyphpar0\qj{section 297.22}}}{. The lease shall provide that the public school corporation may terminate the lease if the corporation needs to use the facility or building for school purposes. The public school corporation shall notify the city at least thirty days before the termination of the lease.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1148, \'a74}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 184, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.22}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Municipal infractions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipal infraction is a civil offense punishable by a civil penalty of not more than seven hundred fifty dollars for each violation or if the infraction is a repeat offense, a civil penalty not to exceed one thousand dollars for each repeat offense. However, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 364.3}}}{{\f5\fs18\hyphpar0\qj{, a municipal infraction arising from noncompliance with a pretreatment standard or requirement, referred to in }}}{{\f5\fs18\hyphpar0\qj\cf1{40 C.F.R. \'a7403.8}}}{{\f5\fs18\hyphpar0\qj{, by an industrial user may be punishable by a civil penalty of not more than one thousand dollars for each day a violation exists or continues.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may classify a municipal infraction, other than a violation arising from noncompliance with a pretreatment standard or requirement, as an environmental violation if the infraction is a violation of }}}{{\f5\fs18\hyphpar0\qj{chapter 455B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{459, subchapters II}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{III}}}{{\f5\fs18\hyphpar0\qj{, or a violation of a standard established by the city in consultation with the department of natural resources, or both. The discharge of airborne residue from grain, created by the handling, drying, or storing of grain by a person, shall not be subject to an ordinance, the violation of which is classified as an environmental violation, unless the person is engaged in industrial production or manufacturing of grain products. The discharge of airborne residue from grain, created by the handling, drying, or storing of grain by a person engaged in industrial production or manufacturing of grain products, shall not be subject to an ordinance, the violation of which is classified as an environmental violation, if the discharge occurs from September 15 to January 15. A municipal infraction which is classified an environmental violation is punishable by a civil penalty of not more than one thousand dollars for each occurrence. A person committing an environmental violation is not subject to a civil penalty, if all of the following conditions are satisfied:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The violation results solely from the person conducting an initial start-up, cleaning, repairing, performing scheduled maintenance, testing, or conducting a shutdown, of either equipment causing the violation or the equipment designed to reduce or eliminate the violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person notifies the city of the violation within twenty-four hours from the time that the violation begins.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The violation does not continue in existence for more than eight hours.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not enforce }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ against a person committing an environmental violation, until the city offers to participate in informal negotiations with the person. If the person accepts the offer, the city and the person shall participate in good faith negotiations to resolve issues alleged to be the basis for the violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city by ordinance may provide that a violation of an ordinance is a municipal infraction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not provide that a violation of an ordinance is a municipal infraction if the violation is a felony, an aggravated misdemeanor, or a serious misdemeanor under state law or if the violation is a simple misdemeanor under }}}{{\f5\fs18\hyphpar0\qj{chapters 687 through 747}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer authorized by a city to enforce a city code or regulation may issue a civil citation to a person who commits a municipal infraction. A copy of the citation may be served by personal service as provided in }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.305}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{, by certified mail addressed to the defendant at the defendant\u8217\'3fs last known mailing address, return receipt requested, or by publication in the manner as provided in }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.310}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{ and subject to the conditions of }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.311}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. A copy of the citation shall be retained by the issuing officer, and the original citation shall be sent to the clerk of the district court. The citation shall serve as notification that a civil offense has been committed and shall contain the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and address of the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name or description of the infraction attested to by the officer issuing the citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location and time of the infraction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of civil penalty to be assessed or the alternate relief sought, or both.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manner, location, and time in which the penalty may be paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The time and place of court appearance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The penalty for failure to appear in court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legal description of the affected real property, if applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receiving a citation under }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ that affects real property and that charges a violation relating to the condition of the property, including a building code violation, a local housing regulation violation, a housing code violation, or a public health or safety violation, the clerk of the district court shall index the citation pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 617.10}}}{{\f5\fs18\hyphpar0\qj{, if the legal description of the affected property is included in or attached to the citation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After filing the citation with the clerk of the district court, the city shall also file the citation in the office of the county treasurer. The county treasurer shall include a notation of the pendency of the action in the county system, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{, until the judgment of the court is satisfied or until the action is dismissed. Pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 446.7}}}{{\f5\fs18\hyphpar0\qj{, an affected property that is subject to a pending action shall not be offered for sale by the county treasurer at tax sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In municipal infraction proceedings:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The matter shall be tried before a magistrate, a district associate judge, or a district judge in the same manner as a small claim. The matter shall only be tried before a judge in district court if the total amount of civil penalties assessed exceeds the jurisdictional amount for small claims set forth in }}}{{\f5\fs18\hyphpar0\qj{section 631.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city has the burden of proof that the municipal infraction occurred and that the defendant committed the infraction. The proof shall be by clear, satisfactory, and convincing evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall ensure that the defendant has received a copy of the charges and that the defendant understands the charges. The defendant may question all witnesses who appear for the city and produce evidence or witnesses on the defendant\u8217\'3fs behalf.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant may be represented by counsel of the defendant\u8217\'3fs own selection and at the defendant\u8217\'3fs own expense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant may answer by admitting or denying the infraction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a municipal infraction is proven the court shall enter a judgment against the defendant. If the infraction is not proven, the court shall dismiss it.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All penalties or forfeitures collected by the court for municipal infractions shall be remitted to the city in the same manner as fines and forfeitures are remitted for criminal violations under }}}{{\f5\fs18\hyphpar0\qj{section 602.8106}}}{{\f5\fs18\hyphpar0\qj{. If the person named in the citation is served as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and fails without good cause to appear in response to the civil citation, judgment shall be entered against the person cited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person against whom judgment is entered, shall pay court costs and fees as in small claims under }}}{{\f5\fs18\hyphpar0\qj{chapter 631}}}{{\f5\fs18\hyphpar0\qj{. If the action is dismissed, the city is liable for the court costs and court fees. Where the action is disposed of without payment, or provision for assessment, of court costs, the clerk shall at once enter judgment for costs against the city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Seeking a civil penalty as authorized in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ does not preclude a city from seeking alternative relief from the court in the same action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When judgment has been entered against a defendant, the court may do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Impose a civil penalty by entry of a personal judgment against the defendant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Direct that payment of the civil penalty be suspended or deferred under conditions imposed by the court.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Grant appropriate alternative relief ordering the defendant to abate or cease the violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Authorize the city to abate or correct the violation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Order that the city\u8217\'3fs costs for abatement or correction of the violation be entered as a personal judgment against the defendant or assessed against the property where the violation occurred, or both.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a defendant willfully violates the terms of an order imposed by the court, the failure is contempt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A magistrate or district associate judge shall have jurisdiction to assess or enter judgment for costs of abatement or correction in an amount not to exceed the jurisdictional amount for a money judgment in a civil action pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 631.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, for magistrates and }}}{{\f5\fs18\hyphpar0\qj{section 602.6306, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for district associate judges. If the city seeks abatement or correction costs in excess of those amounts, and the matter is not before a judge in district court, the case shall be referred to the district court for hearing and entry of an appropriate order. The procedure for hearing in the district court shall be the same procedure as that for a small claims appeal pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 631.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The defendant or the city may file a motion for a new trial or may appeal the decision of a magistrate, district associate judge, or a district judge to the district court. The procedure on appeal shall be the same as for a small claim pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 631.13}}}{{\f5\fs18\hyphpar0\qj{. A factual determination made by the trial court, supported by substantial evidence as shown in the record, is binding for purposes of appeal relating to the violation at issue, but shall not be admissible or binding as to any future violation for the same or similar ordinance provision by the same defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not preclude a peace officer of a city from issuing a criminal citation for a violation of a city code or regulation if criminal penalties are also provided for the violation. Each day that a violation occurs or is permitted to exist by the defendant, constitutes a separate offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuance of a civil citation for a municipal infraction or the ensuing court proceedings do not provide an action for false arrest, false imprisonment, or malicious prosecution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action brought pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for a municipal infraction which is an environmental violation does not preclude, and is in addition to, any other enforcement action which may be brought pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 455B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455D}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{455E}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{459, subchapters II}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{III}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{VI}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A police department may dispose of personal property under }}}{{\f5\fs18\hyphpar0\qj{section 80.39}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1202, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 99, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 150, \'a75 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1210, \'a71 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1067, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1144, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1203, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 21, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1050, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.22B}}}{{\f5\fs12\hyphpar0\qj{, 380.10}}}{{\f5\fs12\hyphpar0\qj{, 446.7}}}{{\f5\fs12\hyphpar0\qj{, 455B.192}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.22A}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Neglected animals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city may rescue, provide maintenance, or dispose of neglected livestock or another animal, as provided in }{{\f5\fs18\hyphpar0\qj{chapters 717}}}{ and }{{\f5\fs18\hyphpar0\qj{717B}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1103, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.22B}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Collection of judgment debt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fjudgment debt\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any criminal penalty, any personal judgment for a civil penalty, or any personal or in rem judgment for the costs of abating a nuisance or other violation, owing to a city in any proceeding brought as a municipal infraction under }}}{{\f5\fs18\hyphpar0\qj{section 364.22}}}{{\f5\fs18\hyphpar0\qj{, or in a civil nuisance proceeding under }}}{{\f5\fs18\hyphpar0\qj{chapter 657}}}{{\f5\fs18\hyphpar0\qj{, or in a criminal proceeding for a misdemeanor violation under a city ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Judgment debt owing to a city is deemed delinquent if it is not paid within thirty days after the date it is assessed. An amount which was ordered by the court to be paid on a date fixed in the future is deemed delinquent if it is not received by the clerk of court within thirty days after the fixed date set out in the court order. If an amount was ordered to be paid in installments and an installment is not received within thirty days after the date it is due, the entire amount of the judgment debt is deemed delinquent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city may contract with a private collection designee for the collection of a judgment debt sixty days after the judgment debt in a case is deemed delinquent pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contract shall provide for a collection fee of up to twenty-five percent of the amount of the balance of the judgment debt in a case deemed delinquent. The collection fee shall be added to the amount of the judgment debt deemed delinquent. The amount of the judgment debt deemed delinquent and the collection fee shall be owed by and collected from the defendant. The collection fee shall be used to compensate the private collection designee.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1146, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.23}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Energy-efficient lighting required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All city-owned exterior flood lighting, including but not limited to street and security lighting but not including era or period lighting which has a minimum efficiency rating of fifty-eight lumens per watt and not including stadium or ball park lighting, shall be replaced, when worn-out, exclusively with high pressure sodium lighting or lighting with equivalent or better energy efficiency as approved in rules adopted by the utilities commission. In lieu of the requirements established for replacement lighting under }{{\f5\fs18\hyphpar0\qj{this section}}}{, stadium or ball park lighting shall be replaced, when worn-out, with the most energy-efficient lighting available at the time of replacement which may include metal halide, high-pressure sodium, or other light sources which may be developed.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 297, \'a76}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1991/CH0253.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{91 Acts, ch 253, \'a716}}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1992/CH1233.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, ch 1233, \'a73}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72665}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7369}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7474.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.24}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Traffic light synchronization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All cities with more than three traffic lights within the corporate limits shall establish a traffic light synchronization program for energy efficiency in accordance with rules adopted by the state department of transportation pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{. }\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 297, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 253, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a7111}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{364.25}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Retiree health care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A city may provide health or medical insurance coverage or supplemental health or medical insurance coverage to retired employees of the city. A city providing health or medical insurance coverage pursuant to }{{\f5\fs18\hyphpar0\qj{this section}}}{ may establish such requirements or restrictions concerning the coverage provided as the city may adopt. If coverage is provided, the cost of the health or medical insurance coverage may be paid from moneys held in a trust and agency fund established pursuant to }{{\f5\fs18\hyphpar0\qj{section 384.6}}}{, or out of an appropriation from the city general fund for this purpose.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1089, \'a71}}}\par}}