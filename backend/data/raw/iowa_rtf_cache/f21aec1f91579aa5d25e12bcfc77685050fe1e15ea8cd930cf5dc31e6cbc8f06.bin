\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F68B}{\*\bkmkend codeChapter_5F68B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 68B}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{GOVERNMENT ETHICS AND LOBBYING}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a728A.9}}}{{\f5\fs12\qc{, 99G.11}}}{{\f5\fs12\qc{, 261A.6}}}{{\f5\fs12\qc{, 602.1609}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_2E1_2E2}{TITLE AND DEFINITIONS}{\*\bkmkend stylerid1_2E5_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall be known as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGovernment Ethics and Lobbying Act\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768B.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 76, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.2}}}{\*\bkmkstart stylerid1_2E5_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a department, division, board, commission, bureau, authority, or office of the executive or legislative branch of state government, the office of attorney general, the state board of regents, community colleges, and the office of the governor, including a regulatory agency, or any department, division, board, commission, bureau, or office of a political subdivision of the state, but does not include any agricultural commodity promotional board, which is subject to a producer referendum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgency of state government\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstate agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a department, division, board, commission, bureau, authority, or office of the executive or legislative branch of state government, the office of attorney general, the state board of regents, community colleges, and the office of the governor, including a regulatory agency, but does not include any agricultural commodity promotional board, which is subject to a producer referendum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the Iowa ethics and campaign disclosure board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCandidate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a candidate under }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{ but does not include any judge standing for retention in a judicial election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCandidate\u8217\'3fs committee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the committee designated by a candidate for a state, county, city, or school office, as provided under }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, to receive contributions in excess of one thousand dollars in the aggregate, expend funds in excess of one thousand dollars in the aggregate, or incur indebtedness on behalf of the candidate in excess of one thousand dollars in the aggregate in any calendar year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClient\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a private person or a state, federal, or local government entity that pays compensation to or designates an individual to be a lobbyist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompensation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any money, thing of value, or financial benefit conferred in return for services rendered or to be rendered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fContribution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a loan, advance, deposit, rebate, refund, transfer of money, an in-kind transfer, or the payment of compensation for the personal services of another person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGift\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a rendering of anything of value in return for which legal consideration of equal or greater value is not given and received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHonorarium\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means anything of value that is accepted or given as consideration for an appearance, speech, or article.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fImmediate family members\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the spouse and dependent children of a public official or public employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLegislative employee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a permanent full-time employee of the general assembly but does not include members of the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLobbyist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who, by acting directly, does any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Receives compensation to encourage the passage, defeat, approval, veto, or modification of legislation, a rule, or an executive order by the members of the general assembly, a state agency, or any statewide elected official.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a designated representative of an organization which has as one of its purposes the encouragement of the passage, defeat, approval, veto, or modification of legislation, a rule, or an executive order before the general assembly, a state agency, or any statewide elected official.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Represents the position of a federal, state, or local government agency, in which the person serves or is employed as the designated representative, for purposes of encouraging the passage, defeat, approval, veto, or modification of legislation, a rule, or an executive order by members of the general assembly, a state agency, or any statewide elected official.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Makes expenditures of more than one thousand dollars in a calendar year, other than to pay compensation to an individual who provides the services specified under subparagraph (1) or to communicate with only the members of the general assembly who represent the district in which the individual resides, to communicate in person with members of the general assembly, a state agency, or any statewide elected official for purposes of encouraging the passage, defeat, approval, veto, or modification of legislation, a rule, or an executive order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLobbyist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Officials and employees of a political party organized in the state of Iowa representing more than two percent of the total votes cast for governor in the last three preceding general elections, but only when representing the political party in an official capacity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representatives of the news media only when engaged in the reporting and dissemination of news and editorials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All federal, state, and local elected officials, while performing the duties and responsibilities of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons whose activities are limited to appearances to give testimony or provide information or assistance at sessions of committees of the general assembly or at public hearings of state agencies or who are giving testimony or providing information or assistance at the request of public officials or employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the staff of the United States Congress or the Iowa general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Agency officials and employees while they are engaged in activities within the agency in which they serve or are employed or with another agency with which the official\u8217\'3fs or employee\u8217\'3fs agency is involved in a collaborative project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who is a member, director, trustee, officer, or committee member of a business, trade, labor, farm, professional, religious, education, or charitable association, foundation, or organization who is not paid compensation and is not specifically designated as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1) or (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons whose activities are limited to submitting data, views, or arguments in writing, or requesting an opportunity to make an oral presentation under }}}{{\f5\fs18\hyphpar0\qj{section 17A.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal employee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person employed by a political subdivision of this state and does not include an independent contractor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocal official\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an officeholder of a political subdivision of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMember of the general assembly\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual duly elected to the senate or the house of representatives of the state of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOfficial\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all statewide elected officials, the executive or administrative head or heads of an agency of state government, the deputy executive or administrative head or heads of an agency of state government, members of boards or commissions as defined under }}}{{\f5\fs18\hyphpar0\qj{section 7E.4}}}{{\f5\fs18\hyphpar0\qj{, and heads of the major subunits of departments or independent state agencies whose positions involve a substantial exercise of administrative discretion or the expenditure of public funds as defined under rules of the board adopted in consultation with the department or agency and pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOfficial\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include officers or employees of political subdivisions of the state, members of the general assembly, legislative employees, officers or employees of the judicial branch of government who are not members or employees of the office of attorney general, members of state government entities which are or exercise the same type of authority that is exercised by councils or committees as defined under }}}{{\f5\fs18\hyphpar0\qj{section 7E.4}}}{{\f5\fs18\hyphpar0\qj{, or members of any agricultural commodity promotional board, if such board is subject to a producer referendum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, without limitation, any individual, corporation, business trust, estate, trust, partnership or association, labor union, or any other legal entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic disclosure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a written report filed by a person as required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or required by rules adopted and issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic employee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means state employees, legislative employees, and local employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic office\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any state, county, city, or school office or any other office of a political subdivision of the state that is filled by election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic official\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means officials, local officials, and members of the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRegulatory agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of agriculture and land stewardship, department of workforce development, department of insurance and financial services, department of public safety, department of education, state board of regents, department of health and human services, department of revenue, department of inspections, appeals, and licensing, department of administrative services, employment appeal board, state department of transportation, office of civil rights, department of public defense, department of homeland security and emergency management, Iowa ethics and campaign disclosure board, utilities commission, and department of natural resources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRestricted donor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is in any of the following categories:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is or is seeking to be a party to any one or any combination of sales, purchases, leases, or contracts to, from, or with the agency in which the donee holds office or is employed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Will personally be, or is the agent of a person who will be, directly and substantially affected financially by the performance or nonperformance of the donee\u8217\'3fs official duty in a way that is greater than the effect on the public generally or on a substantial class of persons to which the person belongs as a member of a profession, occupation, industry, or region.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is personally, or is the agent of a person who is, the subject of or party to a matter which is pending before a subunit of a regulatory agency and over which the donee has discretionary authority as part of the donee\u8217\'3fs official duties or employment within the regulatory agency subunit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is a lobbyist or a client of a lobbyist with respect to matters within the donee\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState employee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is not an official and is a paid employee of the state of Iowa and does not include an independent contractor, an employee of the judicial branch who is not an employee of the office of attorney general, an employee of the general assembly, an employee of a political subdivision of the state, or an employee of any agricultural commodity promotional board, if such board is subject to a producer referendum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fStatewide elected official\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the governor, lieutenant governor, secretary of state, auditor of state, treasurer of state, secretary of agriculture, and attorney general of the state of Iowa.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768B.2}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1199, \'a735, 96}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1067, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 213, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1228, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 163, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1092, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1186, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1047, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1073, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1091, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 76, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 29, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 54, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1154, \'a71, 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a741, 1736, 2715}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7177, 369}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 123, \'a730}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.22}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 13, paragraph b, subparagraph (1) amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsections 17 and 25 amended}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E1_2E2}{CONFLICTS OF INTEREST}{\*\bkmkend stylerid1_2E6_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.2A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited outside employment and activities \u8212\'3f conflicts of interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who serves or is employed by the state or a political subdivision of the state shall not engage in any of the following conduct:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Outside employment or an activity that involves the use of the state\u8217\'3fs or the political subdivision\u8217\'3fs time, facilities, equipment, and supplies or the use of the state or political subdivision badge, uniform, business card, or other evidences of office or employment to give the person or member of the person\u8217\'3fs immediate family an advantage or pecuniary benefit that is not available to other similarly situated members or classes of members of the general public. This paragraph does not apply to off-duty peace officers who provide private duty security or fire fighters or emergency medical care providers certified under }}}{{\f5\fs18\hyphpar0\qj{chapter 147A}}}{{\f5\fs18\hyphpar0\qj{ who provide private duty fire safety or emergency medical services while carrying their badge or wearing their official uniform, provided that the person has secured the prior approval of the agency or political subdivision in which the person is regularly employed to engage in the activity. For purposes of this paragraph, a person is not }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsimilarly situated\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ merely by being or being related to a person who serves or is employed by the state or a political subdivision of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Outside employment or an activity that involves the receipt of, promise of, or acceptance of money or other consideration by the person, or a member of the person\u8217\'3fs immediate family, from anyone other than the state or the political subdivision for the performance of any act that the person would be required or expected to perform as a part of the person\u8217\'3fs regular duties or during the hours during which the person performs service or work for the state or political subdivision of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Outside employment or an activity that is subject to the official control, inspection, review, audit, or enforcement authority of the person, during the performance of the person\u8217\'3fs duties of office or employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the outside employment or activity is employment or activity described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the person shall immediately cease the employment or activity. If the outside employment or activity is employment or activity described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or constitutes outside employment or an activity prohibited under rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ or under the senate or house codes of ethics, unless otherwise provided by law, the person shall take one of the following courses of action:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cease the outside employment or activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Publicly disclose the existence of the conflict and refrain from taking any official action or performing any official duty that would detrimentally affect or create a benefit for the outside employment or activity. For purposes of this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fofficial action\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fofficial duty\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to participating in any vote, taking affirmative action to influence any vote, granting any license or permit, determining the facts or law in a contested case or rulemaking proceeding, conducting any inspection, or providing any other official service or thing that is not available generally to members of the public in order to further the interests of the outside employment or activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise specifically provided the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be in addition to, and shall not supersede, any other rights or remedies provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ further delineating particular situations where outside employment or activity of officials and state employees of the executive branch will be deemed to create an unacceptable conflict of interest.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 41, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1191, \'a738}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 9, \'a71, 2, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Incompatibility of offices, see }{{\f5\fs12\hyphpar0\qj{Iowa Constitution, Art. III, \'a721 and 22}}}{ and }{{\f5\fs12\hyphpar0\qj{\'a739.11}}}{ and }{{\f5\fs12\hyphpar0\qj{39.12}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Economic development and conflict disclosure, see }{{\f5\fs12\hyphpar0\qj{\'a715A.2}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.2B}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Executive branch compensation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Effective July 1, 2006, an official or state employee shall not receive compensation simultaneously from more than one executive branch agency, unless the official or state employee provides notice to the board within twenty business days of accepting employment with a second executive branch agency. Notice under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and contact information of the official or state employee and the name of the official\u8217\'3fs or employee\u8217\'3fs original executive branch agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the second executive branch agency from which compensation may be received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of compensation to be received and a brief explanation of what services are to be performed for the second executive branch agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ necessary for the administration of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to service in the Iowa national guard or service in the general assembly.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1149, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.2C}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited outside employment and activities }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ agents of foreign principals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Officials and state employees shall not engage in any outside employment or activity that requires the person to register under the federal }{{\f5\fs18\hyphpar0\qj{Foreign Agents Registration Act of 1938, as amended}}}{, }{{\f5\fs18\hyphpar0\qj{22 U.S.C. \'a7611 et seq}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1061, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.3}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When public bids required \u8212\'3f disclosure of income from other sales.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ Except as part of official state duties, an official, a state employee, a member of the general assembly, or a legislative employee shall not sell, in any one occurrence, any goods or services having a value in excess of two thousand dollars to any state agency unless the sale is made pursuant to an award or contract let after public notice and competitive bidding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to the publication of resolutions, advertisements, or other legal propositions or notices in newspapers designated pursuant to law for the publication of legal propositions or notices and for which rates are fixed pursuant to law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to sales of services by a member of a board or commission as defined under }}}{{\f5\fs18\hyphpar0\qj{section 7E.4}}}{{\f5\fs18\hyphpar0\qj{ to state executive branch agencies or subunits of departments or independent agencies as defined in }}}{{\f5\fs18\hyphpar0\qj{section 7E.4}}}{{\f5\fs18\hyphpar0\qj{ that are not the subunit of the department or independent agency in which the person serves or are not a subunit of a department or independent agency with which the person has substantial and regular contact as part of the person\u8217\'3fs duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to a contract for professional services that is exempt from competitive bidding requirements in the Code or in administrative rules adopted pursuant to the Code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An official or member of the general assembly who sells goods or services to a political subdivision of the state shall disclose whether income has been received from commissions from the sales in the manner provided under }}}{{\f5\fs18\hyphpar0\qj{section 68B.35}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fservices\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include instruction at an accredited education institution if the person providing the instruction meets the minimum education and licensing requirements established for instructors at the education institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except when performing official state duties, an official or a state employee making a permissible sale under this section shall file a report with the board within twenty days of making the sale. The report shall include but not be limited to the parties to the sale, the date of the sale, the total amount of the sale, and the type of goods or services being sold.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768B.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 163, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 5, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1054, \'a72, 3, 6}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1141, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 54, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.4}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sales or leases by regulatory agency officials and employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An official or employee of any regulatory agency shall not sell or lease, either directly or indirectly, any goods, real estate, or services to individuals, associations, or corporations subject to the regulatory authority of the agency of which the person is an official or employee, except when the official or employee has met all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consent of the regulatory agency for which the person is an official or employee is obtained and the person is not the official or employee with the authority to determine whether agency consent is to be given under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The duties or functions performed by the official or employee for the regulatory agency are not related to the regulatory authority of the agency over the individual, association, or corporation, or the selling or leasing of goods, real estate, or services by the official or employee to the individuals, associations, or corporations does not affect the official\u8217\'3fs or employee\u8217\'3fs duties or functions at the regulatory agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The selling or leasing of any goods, real estate, or services by the official or employee to an individual, association, or corporation does not include advocacy on behalf of the individual, association, or corporation to the regulatory agency in which the person is an official or employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The selling or leasing of any goods, real estate, or services by the official or employee to an individual, association, or corporation does not cause the official or employee to sell or lease goods, real estate, or services to the regulatory agency on behalf of the individual, association, or corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules specifying the method by which employees may obtain agency consent under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The board shall adopt rules specifying the method by which officials may obtain agency consent under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including situations when the person seeking to make the sale or lease is the executive or administrative head of the regulatory agency. A regulatory agency granting consent under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall file a copy of the consent with the board within twenty days of the consent being granted.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768B.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1209, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 79, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1091, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 76, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1149, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 67, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.4A}}}{\*\bkmkstart stylerid1_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sales by legislative employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A permanent legislative employee shall not sell, either directly or indirectly, any goods or services to individuals, associations, or corporations which employ persons who are registered lobbyists before the general assembly, except when the legislative employee has met all of the following conditions:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consent of the person or persons responsible for hiring or approving the hiring of the legislative employee is obtained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The duties and functions performed by the legislative employee for the general assembly are not related to the legislative authority of the general assembly over the individual, association, or corporation, or the selling of goods or services by the legislative employee to the individuals, associations, or corporations does not affect the employee\u8217\'3fs duties or functions at the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The selling of any goods or services by the legislative employee to an individual, association, or corporation does not include lobbying of the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The selling of any goods or services by the legislative employee does not cause the employee to sell goods or services to the general assembly on behalf of the individual, association, or corporation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1031, \'a724}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.4B}}}{\*\bkmkstart stylerid1_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sales or leases by members of the office of the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A permanent full-time member of the office of the governor shall not sell or lease, either directly or indirectly, any goods or services to a registered lobbyist before the general assembly or the executive branch or to an individual, association, or corporation which employs a person who is a registered lobbyist before the general assembly or the executive branch, except when the member of the office of the governor has met all of the following conditions:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consent of the person or persons responsible for hiring or approving the hiring of the member of the office of the governor is obtained. A copy of the consent shall be filed with the board within twenty days of the consent being granted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The duties and functions performed by the member for the office of the governor are not related to the authority of the office of the governor over the individual, association, or corporation, or the selling or leasing of goods or services by the member of the office of the governor to the individuals, associations, or corporations does not affect the member\u8217\'3fs duties or functions at the office of the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The selling or leasing of any goods or services by the member of the office of the governor to an individual, association, or corporation does not include lobbying of the office of the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The selling or leasing of any goods or services by the member of the office of the governor does not cause the member to sell or lease goods or services to the office of the governor on behalf of the individual, association, or corporation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1091, \'a76, 7}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 76, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1149, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.5}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.5A}}}{\*\bkmkstart stylerid1_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Ban on certain lobbying activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who serves as a statewide elected official, the executive or administrative head of an agency of state government, the deputy executive or administrative head of an agency of state government, or a member of the general assembly shall not act as a lobbyist during the time in which the person serves or is employed by the state unless the person is designated, by the agency in which the person serves or is employed, to represent the official position of the agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The head of a major subunit of a department or independent state agency whose position involves substantial exercise of administrative discretion or the expenditure of public funds, a full-time employee of an office of a statewide elected official whose position involves substantial exercise of administrative discretion or the expenditure of public funds, or a legislative employee whose position involves a substantial exercise of administrative discretion or the expenditure of public funds, shall not, during the time in which the person serves or is employed by the state, act as a lobbyist before the agency in which the person is employed or before state agencies, officials, or employees with whom the person has substantial or regular contact as part of the person\u8217\'3fs duties, unless the person is designated, by the agency in which the person serves or is employed, to represent the official position of the agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state or legislative employee who is not subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall not act as a lobbyist in relation to any particular case, proceeding, or application with respect to which the person is directly concerned and personally participates as part of the person\u8217\'3fs employment, unless the person is designated, by the agency in which the person is employed, to represent the official position of the agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall not within two years after the termination of service or employment become a lobbyist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The head of a major subunit of a department or independent state agency whose position involves substantial exercise of administrative discretion or the expenditure of public funds, a full-time employee of an office of a statewide elected official whose position involves substantial exercise of administrative discretion or the expenditure of public funds, or a legislative employee whose position involves a substantial exercise of administrative discretion or the expenditure of public funds, shall not, within two years after termination of employment, become a lobbyist before the agency in which the person was employed or before state agencies or officials or employees with whom the person had substantial and regular contact as part of the person\u8217\'3fs former duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state or legislative employee who is not subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall not, within two years after termination of employment, act as a lobbyist in relation to any particular case, proceeding, or application with respect to which the person was directly concerned and personally participated as part of the person\u8217\'3fs employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a person who, within two years of leaving service or employment with the state, is elected to, appointed to, or employed by another office of the state, an office of a political subdivision of the state, or the federal government and appears or communicates on behalf or as part of the duties of that office or employment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a75}}}{; }\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1992.1/CH1002.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 1st Ex, ch 1002, \'a71}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1191, \'a739}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.6}}}{\*\bkmkstart stylerid1_2E6_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Services against state prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Officials, except for members of boards or commissions as defined under }}}{{\f5\fs18\hyphpar0\qj{section 7E.4}}}{{\f5\fs18\hyphpar0\qj{, state employees, and legislative employees shall not receive, directly or indirectly, or enter into any express or implied agreement for, any compensation, in whatever form, for the appearance or rendition of services by that person or another against the interest of the state in relation to any case, proceeding, application, or other matter before any state agency, any court of the state of Iowa, any federal court, or any federal bureau, agency, commission, or department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is an official, but who is not subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall not receive, directly or indirectly, or enter into any agreement, express or implied, for any compensation, in whatever form, for the appearance or rendition of services by that person or another against the interest of the state in relation to any case, proceeding, application, or other matter before the subunit of a department or independent agency in which the person serves, is employed, or with which the person has substantial and regular contact as part of the person\u8217\'3fs duties.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768B.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1091, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a713.2}}}{{\f5\fs12\hyphpar0\qj{, 13B.4}}}{{\f5\fs12\hyphpar0\qj{, 68B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.7}}}{\*\bkmkstart stylerid1_2E6_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited use of influence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has served as an official, state employee of a state agency, member of the general assembly, or legislative employee shall not within a period of two years after the termination of such service or employment receive compensation for any services rendered on behalf of any person, firm, corporation, or association in relation to any case, proceeding, or application with respect to which the person was directly concerned and personally participated during the period of service or employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has served as the head of or on a commission or board of a regulatory agency or as a deputy thereof, shall not, within a period of two years after the termination of such service do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Accept employment with that commission, board, or agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Receive compensation for any services rendered on behalf of any person, firm, corporation, or association in any case, proceedings, or application before the department with which the person so served wherein the person\u8217\'3fs compensation is to be dependent or contingent upon any action by such agency with respect to any license, contract, certificate, ruling, decision, opinion, rate schedule, franchise, or other benefit, or in promoting or opposing, directly or indirectly, the passage of bills or resolutions before either house of the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a person who has served as the workers\u8217\'3f compensation commissioner, or any deputy thereof, may represent a claimant in a contested case before the division of workers\u8217\'3f compensation at any point subsequent to termination of such service, regardless of whether the person charges a contingent fee for such representation, provided such case was not pending before the division during the person\u8217\'3fs tenure as commissioner or deputy.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768B.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 321, \'a724}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1182, \'a757}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 9, \'a73, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.8}}}{\*\bkmkstart stylerid1_2E6_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lobbying activities by state agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state agency of the executive branch of state government shall not employ a person through the use of its public funds whose position with the agency is primarily representing the agency relative to the passage, defeat, approval, or modification of legislation that is being considered by the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state agency of the executive branch of state government shall not use or permit the use of its public funds for a paid advertisement or public service announcement thirty days prior to or during a legislative session for the purpose of encouraging the passage, defeat, approval, or modification of a bill that is being considered, or was considered during the previous legislative session, by the general assembly.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1116, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 122, \'a74, 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{68B.9 through 68B.20}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER III}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E1_2E2}{GIFTS AND OFFERS \u8212\'3f}{\*\bkmkend stylerid1_2E7_2E1_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{GENERAL PENALTIES}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.21}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legislative intent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is the goal of the general assembly that public officials and public employees of the state be extremely cautious and circumspect about accepting a gratuity or favor, especially from persons that have a substantial interest in the legislative, administrative, or political actions of the official or employee. Even where there is a genuine personal friendship, the acceptance of personal benefits from those who could gain advantage by influencing official actions raises suspicions that tend to undermine the public trust. It is therefore the intent of the general assembly that the provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ be construed to discourage all gratuities, but to prohibit only those that create unacceptable conflicts of interest or appearances of impropriety.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.22}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gifts accepted or received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a public official, public employee, or candidate, or that person\u8217\'3fs immediate family member shall not, directly or indirectly, accept or receive any gift or series of gifts from a restricted donor. A public official, public employee, candidate, or the person\u8217\'3fs immediate family member shall not solicit any gift or series of gifts from a restricted donor at any time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a restricted donor shall not, directly or indirectly, offer or make a gift or a series of gifts to a public official, public employee, or candidate. Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a restricted donor shall not, directly or indirectly, join with one or more other restricted donors to offer or make a gift or a series of gifts to a public official, public employee, or candidate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A restricted donor may give, and a public official, public employee, or candidate, or the person\u8217\'3fs immediate family member, may accept an otherwise prohibited nonmonetary gift or a series of otherwise prohibited nonmonetary gifts and not be in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the nonmonetary gift or series of nonmonetary gifts is donated within thirty days to a public body, the department of administrative services, or a bona fide educational or charitable organization, if no part of the net earnings of the educational or charitable organization inures to the benefit of any private stockholder or other individual. All such items donated to the department of administrative services shall be disposed of by assignment to state agencies for official use or by public sale. A person subject to }}}{{\f5\fs18\hyphpar0\qj{section 68B.22A}}}{{\f5\fs18\hyphpar0\qj{ that receives a gift pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall file a report pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 68B.22A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{, the following gifts may be received by public officials, public employees, candidates, or members of the immediate family of public officials, public employees, or candidates:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contributions to a candidate or a candidate\u8217\'3fs committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Informational material relevant to a public official\u8217\'3fs or public employee\u8217\'3fs official functions, such as books, pamphlets, reports, documents, periodicals, or other information that is recorded in a written, audio, or visual format.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Anything received from anyone related within the fourth degree by kinship or marriage, unless the donor is acting as an agent or intermediary for another person not so related.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An inheritance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Anything available or distributed free of charge to members of the general public without regard to the official status of the recipient. This paragraph shall not apply to functions described under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Items received from a bona fide charitable, professional, educational, or business organization to which the donee belongs as a dues-paying member, if the items are given to all members of the organization without regard to individual members\u8217\'3f status or positions held outside of the organization and if the dues paid are not inconsequential when compared to the items received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Actual expenses of a donee for food, beverages, registration, travel, and lodging for a meeting, which is given in return for participation in a panel or speaking engagement at the meeting when the expenses relate directly to the day or days on which the donee has participation or presentation responsibilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Plaques or items of negligible resale value which are given as recognition for the public services of the recipient.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Food and beverages provided at a meal that is part of a bona fide event or program at which the recipient is being honored for public service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonmonetary items with a value of three dollars or less that are received from any one donor during one calendar day.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Items or services solicited by or given to a state, national, or regional government organization in which the state of Iowa or a political subdivision of the state is a member for purposes of a business or educational conference, seminar, or other meeting; or solicited by or given to state, national, or regional government organizations, whose memberships and officers are primarily composed of state or local government officials or employees, for purposes of a business or educational conference, seminar, or other meeting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Items or services received by members or representatives of members at a regularly scheduled event that is part of a business or educational conference, seminar, or other meeting that is sponsored and directed by any state, national, or regional government organization in which the state of Iowa or a political subdivision of the state is a member, or received at such an event by members or representatives of members of state, national, or regional government organizations whose memberships and officers are primarily composed of state or local government officials or employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Funeral flowers or memorials to a church or nonprofit organization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Gifts which are given to a public official or public employee for the public official\u8217\'3fs or public employee\u8217\'3fs wedding or twenty-fifth or fiftieth wedding anniversary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Payment of salary or expenses by a person\u8217\'3fs employer or the firm in which the person is a member for the cost of attending a meeting of a subunit of an agency when the person whose expenses are being paid serves on a board, commission, committee, council, or other subunit of the agency and the person is not entitled to receive compensation or reimbursement of expenses from the state or a political subdivision of the state for attending the meeting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Food, beverages, travel, or lodging received by a public official or public employee if all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The public official or public employee is officially representing an agency in a delegation whose sole purpose is to attract a specific new business to locate in the state, encourage expansion or retention of an existing business already established in the state, or to develop markets for Iowa businesses or products.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The donor of the gift is not the business or businesses being contacted. However, food or beverages provided by the business or businesses being contacted which are consumed during the meeting are not a gift under }}}{{\f5\fs18\hyphpar0\qj{section 68B.2, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The public official or public employee plays a significant role in the presentation to the business or businesses on behalf of the public official\u8217\'3fs or public employee\u8217\'3fs agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Gifts other than food, beverages, travel, and lodging received by a public official or public employee which are received from a person who is a citizen of a country other than the United States and are given during a ceremonial presentation or as a result of a custom of the other country and are of personal value only to the donee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Actual registration costs for informational meetings or sessions which assist a public official or public employee in the performance of the person\u8217\'3fs official functions. The costs of food, drink, lodging, and travel are not \u8220\'3fregistration costs\u8221\'3f under this paragraph. Meetings or sessions which a public official or public employee attends for personal or professional licensing purposes are not \u8220\'3finformational meetings or sessions which assist a public official or public employee in the performance of the person\u8217\'3fs official functions\u8221\'3f under this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Food, beverage, and entertainment received at a function where every member of the general assembly has been invited to attend, when the function takes place during a regular session of the general assembly. A sponsor of a function under this paragraph shall file a registration prior to the function taking place identifying the sponsor and the date, time, and location of the function. The registration shall be filed with the person or persons designated by the secretary of the senate and the chief clerk of the house and with the board. After a function takes place, the sponsor of the function shall file a report disclosing the total amount expended, including in-kind expenditures, on food, beverage, and entertainment for the function. The report shall be filed with the person or persons designated by the secretary of the senate and the chief clerk of the house and with the board within twenty-eight calendar days following the date of the function. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of determining the value of an item given or received, an individual who gives an item on behalf of more than one person shall not divide the value of the item by the number of persons on whose behalf the item is given and the value of an item received shall be the value actually received by the donee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A gift shall not be considered to be received by a public official or public employee if the state is the donee of the gift and the public official or public employee is required to receive the gift on behalf of the state as part of the performance of the person\u8217\'3fs duties of office or employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not request, and a member of the general assembly shall not agree, that a member of the general assembly sell tickets for a community-related social event that is to be held for members of the general assembly in Polk county during the legislative session. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to Polk county or city of Des Moines events that are open to the public generally or are held only for Polk county or city of Des Moines legislators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, an organization or association which has as one of its purposes the encouragement of the passage, defeat, introduction, or modification of legislation shall not give and a member of the general assembly shall not receive food, beverages, registration, or scheduled entertainment with a per person value in excess of three dollars.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 163, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1092, \'a75 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 161, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 76, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 5, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1006, \'a71, 11}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1154, \'a72 \u8211\'3f 4}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.23}}}{{\f5\fs12\hyphpar0\qj{, 68B.34}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Solicitations for capitol complex projects, see }{{\f5\fs12\hyphpar0\qj{\'a78A.108}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.22A}}}{\*\bkmkstart stylerid1_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reporting of gifts and bequests received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All gifts and bequests with a value of fifty dollars or more received by a department or accepted by the governor on behalf of the state shall be reported within twenty days of receiving the gift or bequest to the board, using the board\u8217\'3fs internet reporting system. The board shall, by January 31 of each year, submit to the fiscal services division of the legislative services agency a written report listing all gifts and bequests received during the previous calendar year with a value over one thousand dollars and the purpose for each such gift or bequest. The submission shall also include a listing of all gifts and bequests received by a department from a person if the cumulative value of all gifts and bequests received by the department from the person during the previous calendar year exceeds one thousand dollars, and the board shall include, if available, the purpose for each such gift or bequest. However, the reports on gifts or bequests filed by the state board of regents and the Iowa state fair board pursuant to }{{\f5\fs18\hyphpar0\qj{section 8.44}}}{ shall be deemed sufficient to comply with the requirements of }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 173, \'a727}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS2005, \'a78.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1191, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 79, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 40, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a785}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2025, \'a768B.22A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 30, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a722.7(52)(d)}}}{{\f5\fs12\hyphpar0\qj{, 68B.22}}}{{\f5\fs12\hyphpar0\qj{, 68B.32}}}{{\f5\fs12\hyphpar0\qj{, 68B.32B}}}{{\f5\fs12\hyphpar0\qj{, 68B.34}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Gifts to state, see also }{{\f5\fs12\hyphpar0\qj{\'a7565.3}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.23}}}{\*\bkmkstart stylerid1_2E7_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Honoraria \u8212\'3f banned.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a public official or public employee shall not seek or accept an honorarium from a restricted donor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A public official or public employee may accept an honorarium from any person under the following circumstances:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The honorarium consists of payment of actual expenses of a donee for registration, food, beverages, travel, and lodging paid in return for participation in a panel or speaking engagement at a meeting when the expenses relate directly to the day or days on which the recipient has participation or presentation responsibilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The honorarium consists of a nonmonetary item or series of nonmonetary items that the public official or public employee donates within thirty days to a public body, a bona fide educational or charitable organization, or the department of administrative services as provided in }}}{{\f5\fs18\hyphpar0\qj{section 68B.22, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The honorarium consists of a payment made to a public official or public employee for services rendered as part of a bona fide private business, trade, or profession in which the public official or public employee is engaged if the payment is commensurate with the actual services rendered and is not being made because of the person\u8217\'3fs status as a public official or public employee, but, rather, because of some special expertise or other qualification.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.24}}}{\*\bkmkstart stylerid1_2E7_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Loans \u8212\'3f receipt from lobbyists prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An official, member of the general assembly, state employee, legislative employee, or candidate for state office shall not, directly or indirectly, seek or accept a loan or series of loans from a person who is a lobbyist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A lobbyist shall not, directly or indirectly, offer or make a loan or series of loans to an official, member of the general assembly, state employee, legislative employee, or candidate for state office. A lobbyist shall also not, directly or indirectly, join with one or more persons to offer or make a loan or series of loans to an official, member of the general assembly, state employee, legislative employee, or candidate for state office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to loans made in the ordinary course of business. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a loan is }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmade in the ordinary course of business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ when it is made by a person who is regularly engaged in a business that makes loans to members of the general public and the finance charges and other terms of the loan are the same or substantially similar to the finance charges and loan terms that are available to members of the general public.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{68B.25 through 68B.30}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E1_2E2}{ENFORCEMENT \u8212\'3f ENTITIES,}{\*\bkmkend stylerid1_2E8_2E1_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{PROCEDURE, AND JURISDICTION}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.31}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legislative ethics committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There shall be an ethics committee in the senate and an ethics committee in the house, each to consist of six members; three members to be appointed by the majority leader in each house, and three members by the minority leader in each house. A member of the ethics committee may disqualify himself or herself from participating in any proceeding upon submission of a written statement that the member cannot render an impartial and unbiased decision in a case. A member is ineligible to participate in committee meetings, as a member of the committee, in any proceeding relating to the member\u8217\'3fs own conduct. A member may be disqualified by a unanimous vote of the remaining eligible members of the committee. If a member of the ethics committee is disqualified from or is ineligible to participate in any committee proceedings, the authority responsible for the original appointment of the disqualified or ineligible member shall appoint a replacement member who shall serve during the period of the original member\u8217\'3fs disqualification or ineligibility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members shall receive a per diem and travel expenses at the same rate as paid members of interim committees for attending meetings held when the general assembly is not in session. The per diem and expenses shall be paid from funds appropriated by }}}{{\f5\fs18\hyphpar0\qj{section 2.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The majority leader of each house shall designate the chairperson and vice chairperson, and the minority leader of each house shall designate the ranking member, of each committee. The chairperson of each committee shall have the following powers, duties and functions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Preside over meetings of the committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Call meetings of the committee upon receipt of findings from the independent special counsel that there is probable cause to believe that a member of the general assembly or a lobbyist has committed a violation of a provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or of the rules relating to ethical conduct that are adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ethics committee of each house shall have the following powers, duties, and functions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare a code of ethics within thirty days after the commencement of each general assembly.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare rules relating to lobbyists and lobbying activities in the general assembly.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue advisory opinions interpreting the intent of constitutional and statutory provisions relating to legislators, lobbyists, and clients as well as interpreting the code of ethics and rules issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Opinions shall be issued when approved by a majority of the six members and may be issued upon the written request of a member of the general assembly or upon the committee\u8217\'3fs initiation. Opinions are not binding on the legislator, lobbyist, or client.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Receive and hear complaints and charges against members of its house, lobbyists, or clients of a lobbyist alleging a violation of the code of ethics, rules governing lobbyists, }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or other matters referred to it by its house or the independent special counsel. The committee shall recommend rules for the receipt and processing of findings of probable cause relating to ethical violations of members of the general assembly, lobbyists, or clients of lobbyists during the legislative session and those received after the general assembly adjourns.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recommend legislation relating to legislative ethics and lobbying activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ethics committee may employ independent legal counsel to assist the committee in carrying out the committee\u8217\'3fs duties under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. Payment of costs for the independent legal counsel shall be made from funds appropriated pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 2.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person may file a complaint with the ethics committee of either house alleging that a member of the general assembly, lobbyist, or client of a lobbyist before the general assembly has committed a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The ethics committee shall prescribe and provide forms for this purpose. The complaint shall include the name and address of the complainant and a statement of the facts believed to be true that form the basis of the complaint, including the sources of information and approximate dates of the acts alleged and a certification by the complainant under penalty of perjury that the facts stated to be true are true to the best of the complainant\u8217\'3fs knowledge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ethics committee shall promptly notify any party alleged to have committed a violation of the code of ethics, rules governing lobbyists, or }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ of the filing of a complaint by causing a copy of the complaint to be served or personally delivered to the party charged, unless service is waived by the party charged, and shall review the complaint to determine if the complaint meets the requirements for formal sufficiency. If the complaint is deficient as to form, the complaint shall be returned to the complainant with a statement of the nature of the deficiency and the party charged in the complaint shall be notified that the complaint has been returned. If a complaint, previously found to be deficient as to form, is refiled in different form, the party charged in the complaint shall be provided with a copy of the new document in the same manner as provided for service of the initial complaint. Any amendments to a complaint that are filed with the committee shall also be served or personally delivered, unless service is waived, to the party charged in the complaint. If the complaint is sufficient as to form, the ethics committee shall review the complaint to determine whether the complaint states a valid charge which may be investigated. A valid complaint must allege all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facts, that if true, establish a violation of a provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the rules governing lobbyists, or the code of ethics for which penalties or other remedies are provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the conduct providing the basis for the complaint occurred within three years of the filing of the complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the party charged with a violation is a party subject to the jurisdiction of the ethics committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the ethics committee determines that a complaint is not valid, the complaint shall be dismissed and returned to the complainant with a notice of dismissal stating the reason or reasons for the dismissal. If the ethics committee determines that a complaint is valid and the ethics committee does not take action under rules adopted pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the ethics committee shall request that the chief justice of the supreme court appoint an independent special counsel to investigate the allegations contained in the complaint to determine whether there is probable cause to believe that a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ has occurred and whether an evidentiary hearing on the complaint should be held. Payment of costs for the independent special counsel shall be made from }}}{{\f5\fs18\hyphpar0\qj{section 2.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ethics committee may adopt rules for purposes of taking action on valid complaints without requesting the appointment of an independent special counsel and without requiring action by the appropriate house pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 11}}}{{\f5\fs18\hyphpar0\qj{. Such action may only be taken if the committee determines that no dispute exists between the parties regarding material facts that establish a violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a hearing on the complaint is ordered, the ethics committee shall receive all admissible evidence, determine any factual or legal issues presented during the hearing, and make findings of fact based upon evidence received. Hearings shall be conducted in the manner prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 17A.12}}}{{\f5\fs18\hyphpar0\qj{. The rules of evidence applicable under }}}{{\f5\fs18\hyphpar0\qj{section 17A.14}}}{{\f5\fs18\hyphpar0\qj{ shall also apply in hearings before the ethics committee. Clear and convincing evidence shall be required to support a finding that the member of the general assembly, lobbyist, or client before the general assembly has committed a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. Parties to a complaint may, subject to the approval of the ethics committee, negotiate for settlement of disputes that are before the ethics committee. Terms of any negotiated settlements shall be publicly recorded. If a complaint is filed or initiated less than ninety days before the election for a state office, for which the person named in the complaint is the incumbent officeholder, the ethics committee shall, if possible, set the hearing at the earliest available date so as to allow the issue to be resolved before the election. An extension of time for a hearing may be granted when both parties mutually agree on an alternate date for the hearing. The ethics committee shall make every effort to hear all ethics complaints within three months of the date that the complaints are filed. However, after three months from the date of the filing of the complaint, extensions of time for purposes of preparing for hearing may only be granted by the ethics committee when the party charged in the complaint with the ethics violation consents to an extension. If the party charged does not consent to an extension, the ethics committee shall not grant any extensions of time for preparation prior to hearing. All complaints alleging a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the code of ethics shall be heard within nine months of the filing of the complaint. Final dispositions of violations, which the ethics committee has found to have been established by clear and convincing evidence, shall be made within thirty days of the conclusion of the hearing on the complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ethics committee of each house shall recommend rules for adoption by the respective house relating to the confidentiality of a complaint or information which has been filed or provided to the committee. Rules adopted shall provide for initial confidentiality of a complaint, unless the complaint has been publicly disclosed, and shall permit the ethics committee to treat some or all of the contents of a complaint or other information as confidential if the committee finds that the criteria established under }}}{{\f5\fs18\hyphpar0\qj{section 22.7, subsection 18}}}{{\f5\fs18\hyphpar0\qj{, for keeping certain information confidential, are met. If the existence of a complaint or a preliminary investigation is made public, the ethics committee shall publicly confirm the existence of the complaint or preliminary inquiry and, in the ethics committee\u8217\'3fs discretion, make public the complaint or investigation and any documents which were issued to any party to the complaint or investigation. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not prevent the committee from furnishing the complaint or other information to the appropriate law enforcement authorities at any time. Upon commencement of a hearing on a complaint, all investigative material shall be made available to the subject of the hearing and any material that is introduced at the hearing shall be public information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The code of ethics and rules relating to lobbyists and lobbying activities shall not become effective until approved by the members of the house to which the proposed code and rules apply. The code or rules may be amended either upon the recommendation of the ethics committee or by members of the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Violation of a provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted relating to ethical conduct may result in censure, reprimand, or other sanctions as determined by a majority of the member\u8217\'3fs house. However, a member may be suspended or expelled and the member\u8217\'3fs salary forfeited only if directed by a two-thirds vote of the member\u8217\'3fs house. A suspension, expulsion, or forfeiture of salary shall be for the duration specified in the directing resolution. Violation of a rule relating to lobbyists and lobbying activities may result in censure, reprimand, or other sanctions as determined by a majority of the members of the house in which the violation occurred. However, a lobbyist may be suspended from lobbying activities for the duration provided in the directing resolution only if directed by a two-thirds vote of the house in which the violation occurred.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768B.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 213, \'a74 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1223, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1256, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1228, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a768B.31}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a711 \u8211\'3f 13}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a7201}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1006, \'a72 \u8211\'3f 5, 11}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a711.41}}}{{\f5\fs12\hyphpar0\qj{, 22.7(29)}}}{{\f5\fs12\hyphpar0\qj{, 68B.31A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.31A}}}{\*\bkmkstart stylerid1_2E8_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Investigation by independent special counsel \u8212\'3f probable cause.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The purpose of an investigation by the independent special counsel is to determine whether there is probable cause to proceed with an adjudicatory hearing on the matter. In conducting investigations and holding hearings, the independent special counsel may require by subpoena the attendance and testimony of witnesses and may subpoena books, papers, records, and any other real evidence relating to the matter before the independent special counsel. The independent special counsel shall have the additional authority provided in }{{\f5\fs18\hyphpar0\qj{section 17A.13}}}{. If the independent special counsel determines at any stage in the proceedings that take place prior to hearing that the complaint is without merit, the independent special counsel shall report that determination to the appropriate ethics committee and the complaint shall be dismissed and the complainant and the party charged shall be notified. If, after investigation, the independent special counsel determines evidence exists which, if proven, would support a finding of a violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, a finding of probable cause shall be made and reported to the ethics committee, and a hearing shall be ordered by the ethics committee as provided in }{{\f5\fs18\hyphpar0\qj{section 68B.31}}}{. Independent special counsel investigations are not meetings of a governmental body within the meaning of }{{\f5\fs18\hyphpar0\qj{chapter 21}}}{, and records and information obtained by independent special counsel during investigations are confidential until disclosed to a legislative ethics committee under }{{\f5\fs18\hyphpar0\qj{section 68B.31}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1091, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a711.41}}}{{\f5\fs12\hyphpar0\qj{, 22.7(29)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.32}}}{\*\bkmkstart stylerid1_2E8_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Independent ethics and campaign disclosure board \u8212\'3f established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa ethics and campaign disclosure board is established as an independent agency. The board shall administer }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and set standards for, investigate complaints relating to, and monitor the ethics of officials, employees, lobbyists, and candidates for office in the executive branch of state government. The board shall administer and set standards for, investigate complaints relating to, and monitor the campaign finance practices of candidates for public office. The board shall administer and establish standards for, investigate complaints relating to, and monitor the reporting of gifts and bequests under }}}{{\f5\fs18\hyphpar0\qj{section 68B.22A}}}{{\f5\fs18\hyphpar0\qj{. The board shall consist of six members and shall be balanced as to political affiliation as provided in }}}{{\f5\fs18\hyphpar0\qj{section 4A.12}}}{{\f5\fs18\hyphpar0\qj{. The members shall be appointed by the governor, subject to confirmation by the senate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members shall serve staggered six-year terms beginning and ending as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{. Any vacancy on the board shall be filled by appointment for the unexpired portion of the term, within ninety days of the vacancy and in accordance with the procedures for regular appointments. A member of the board may be reappointed to serve additional terms on the board. Members may be removed in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 69}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall annually elect one member to serve as the chairperson of the board and one member to serve as vice chairperson. The vice chairperson shall act as the chairperson in the absence or disability of the chairperson or in the event of a vacancy in that office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the board shall receive a per diem as specified in }}}{{\f5\fs18\hyphpar0\qj{section 7E.6}}}{{\f5\fs18\hyphpar0\qj{ while conducting business of the board, and payment of actual and necessary expenses incurred in the performance of their duties. Members of the board shall file statements of financial interest under }}}{{\f5\fs18\hyphpar0\qj{section 68B.35}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall employ a full-time executive director who shall be the board\u8217\'3fs chief administrative officer. The board shall employ or contract for the employment of legal counsel notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 13.7}}}{{\f5\fs18\hyphpar0\qj{, and any other personnel as may be necessary to carry out the duties of the board. The board\u8217\'3fs legal counsel shall be the chief legal officer of the board and shall advise the board on all legal matters relating to the administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{. The state may be represented by the board\u8217\'3fs legal counsel in any civil action regarding the enforcement of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or at the board\u8217\'3fs request, the state may be represented by the office of the attorney general. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8A.412}}}{{\f5\fs18\hyphpar0\qj{, all of the board\u8217\'3fs employees, except for the executive director and legal counsel, shall be employed subject to the merit system provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 8A, subchapter IV}}}{{\f5\fs18\hyphpar0\qj{. The salary of the executive director shall be fixed by the board, within the range established by }}}{{\f5\fs18\hyphpar0\qj{section 8A.461}}}{{\f5\fs18\hyphpar0\qj{. The salary of the legal counsel shall be fixed by the board, within a salary range established by the department of administrative services for a position requiring similar qualifications and experience.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 198, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7155, 286}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1035, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1191, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7160, 168}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768A.101}}}{{\f5\fs12\hyphpar0\qj{, 68A.102}}}{{\f5\fs12\hyphpar0\qj{, 331.210A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.32A}}}{\*\bkmkstart stylerid1_2E8_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The duties of the board shall include but are not limited to all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ and conduct hearings under }}}{{\f5\fs18\hyphpar0\qj{sections 68B.32B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{68B.32C}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, as necessary to carry out the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop, prescribe, furnish, and distribute any forms necessary for the implementation of the procedures contained in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{ for the filing of reports and statements by persons required to file the reports and statements under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish a process to assign signature codes to a person or committee for purposes of facilitating an electronic filing procedure. The assignment of signature codes shall be kept confidential, notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 22.2}}}{{\f5\fs18\hyphpar0\qj{. The board and persons electronically filing reports and statements shall keep assigned signature codes or subsequently selected signature codes confidential. Signature codes shall not be subject to state security policies regarding frequency of change.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review the contents of all campaign finance disclosure reports and statements filed with the board and promptly advise each person or committee of errors found. The board may verify information contained in the reports with other parties to assure accurate disclosure. The board may also verify information by requesting that a candidate or committee produce copies of receipts, bills, logbooks, or other memoranda of reimbursements of expenses to a candidate for expenses incurred during a campaign. The board, upon its own motion, may initiate action and conduct a hearing relating to requirements under }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Receive all registrations and reports that are required to be filed with the board under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The board, upon its own motion, may initiate action, conduct hearings, impose sanctions, and order administrative resolutions relating to reporting requirements under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prepare and publish a manual setting forth examples of approved uniform systems of accounts and approved methods of disclosure for use by persons required to file statements and reports under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{. The board shall also prepare and publish other educational materials, and any other reports or materials deemed appropriate by the board. The board shall annually provide all officials and state employees with notification of the contents of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{ by distributing copies of educational materials to each agency of state government under the board\u8217\'3fs jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assure that the statements and reports which have been filed in accordance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{ are available for public inspection and copying during the regular office hours of the office in which they are filed and not later than by the end of the day during which a report or statement was received. Rules adopted relating to public inspection and copying of statements and reports may include a charge for any copying and mailing of the reports and statements, shall provide for the mailing of copies upon the request of any person and upon prior receipt of payment of the costs by the board, and shall prohibit the use of the information copied from reports and statements for any commercial purpose by any person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Require that the candidate of a candidate\u8217\'3fs committee, or the chairperson of a political committee, is responsible for filing disclosure reports under }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, and shall receive notice from the board if the committee has failed to file a disclosure report at the time required under }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{. A candidate of a candidate\u8217\'3fs committee, or the chairperson of a political committee, may be subject to a civil penalty for failure to file a disclosure report required under }}}{{\f5\fs18\hyphpar0\qj{section 68A.402, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish and impose penalties, and recommendations for punishment of persons who are subject to penalties of or punishment by the board or by other bodies, for the failure to comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine, in case of dispute, at what time a person has become a candidate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Preserve copies of reports and statements filed with the board for a period of five years from the date of receipt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish a procedure for requesting and issuing board advisory opinions to persons subject to the authority of the board under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{. Local officials and local employees may also seek an advisory opinion concerning the application of the applicable provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. Advice contained in board advisory opinions shall, if followed, constitute a defense to a complaint alleging a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or rules of the board that is based on the same facts and circumstances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish rules relating to ethical conduct for officials and state employees, including candidates for statewide office, and regulations governing the conduct of lobbyists of the executive branch of state government, including but not limited to conflicts of interest, abuse of office, misuse of public property, use of confidential information, participation in matters in which an official or state employee has a financial interest, and rejection of improper offers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Impose penalties upon, or refer matters relating to, persons who discharge any employee, or who otherwise discriminate in employment against any employee, for the filing of a complaint with, or the disclosure of information to, the board if the employee has filed the complaint or made the disclosure in good faith.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish fees, where necessary, to cover the costs associated with preparing, printing, and distributing materials to persons subject to the authority of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish an expedited procedure for reviewing complaints forwarded by the state commissioner of elections to the board for a determination as to whether a supervisor district plan adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 331.210A}}}{{\f5\fs18\hyphpar0\qj{ that differs from a supervisor district plan prepared by the legislative services agency was drawn for improper political reasons as described in }}}{{\f5\fs18\hyphpar0\qj{section 42.4, subsection 5}}}{{\f5\fs18\hyphpar0\qj{. The expedited procedure shall be substantially similar to the process used for other complaints filed with the board except that the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 68B.32D}}}{{\f5\fs18\hyphpar0\qj{ shall not apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the board\u8217\'3fs discretion, develop and operate a searchable internet site database that provides access to information on statements or reports filed with the board. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsearchable internet site database\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an internet site database that allows the public to search and aggregate information and is in a downloadable format.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the board\u8217\'3fs discretion, enter into an agreement with a political subdivision authorizing the board to enforce the provisions of a code of ethics adopted by that political subdivision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Impose penalties upon, or refer matters relating to, persons who provide false information to the board during a board investigation of a potential violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or rules of the board. The board shall adopt rules to administer }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 198, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1091, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 76, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1035, \'a72 \u8211\'3f 4, 9}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1185, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 5, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 126, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1031, \'a785}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1115, \'a7106}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1184, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 181, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1006, \'a76, 11}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1054, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1151, \'a73, 6}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768A.101}}}{{\f5\fs12\hyphpar0\qj{, 68A.405A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.32B}}}{\*\bkmkstart stylerid1_2E8_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Complaint procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person may file a complaint alleging that a candidate, committee, person holding a state office in the executive branch of state government, employee of the executive branch of state government, or other person has committed a violation of }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted by the board. Any person may file a complaint alleging that a person holding a state office in the executive branch of state government, an employee of the executive branch of state government, or a lobbyist or a client of a lobbyist of the executive branch of state government has committed a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted by the board. Any person may file a complaint alleging a violation of }}}{{\f5\fs18\hyphpar0\qj{section 68B.22A}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted by the board. The board shall prescribe and provide forms for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A complaint must include the name and address of the complainant, a statement of the facts believed to be true that form the basis of the complaint, including the sources of information and approximate dates of the acts alleged, and a certification by the complainant under penalty of perjury that the facts stated to be true are true to the best of the complainant\u8217\'3fs knowledge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board staff shall review the complaint to determine if the complaint is sufficient as to form. If the complaint is deficient as to form, the complaint shall be returned to the complainant with a statement of the deficiency and an explanation describing how the deficiency may be cured. If the complaint is sufficient as to form, the complaint shall be referred for legal review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the chairperson of the board concludes that immediate notification would prejudice a preliminary investigation or subject the complainant to an unreasonable risk, the board shall mail a copy of the complaint to the subject of the complaint within three working days of the acceptance of the complaint. If a determination is made by the chairperson not to mail a copy of the complaint to the subject of the complaint within the three working days time period, the board shall approve and establish the time and conditions under which the subject will be informed of the filing and contents of the complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon completion of legal review, the chairperson of the board shall be advised whether, in the opinion of the legal advisor, the complaint states an allegation which is legally sufficient. A legally sufficient allegation must allege all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facts that would establish a violation of a provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or rules adopted by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facts that would establish that the conduct providing the basis for the complaint occurred within three years of the complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facts that would establish that the subject of the complaint is a party subject to the jurisdiction of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After receiving an evaluation of the legal sufficiency of the complaint, the chairperson shall refer the complaint to the board for a formal determination by the board of the legal sufficiency of the allegations contained in the complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board determines that none of the allegations contained in the complaint are legally sufficient, the complaint shall be dismissed. The complainant shall be sent a notice of dismissal stating the reason or reasons for the dismissal. If a copy of the complaint was sent to the subject of the complaint, a copy of the notice shall be sent to the subject of the complaint. If the board determines that any allegation contained in the complaint is legally sufficient, the complaint shall be referred to the board staff for investigation of any legally sufficient allegations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1 through 6}}}{{\f5\fs18\hyphpar0\qj{, the board may, on its own motion and without the filing of a complaint by another person, initiate investigations into matters that the board believes may be subject to the board\u8217\'3fs jurisdiction. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not preclude persons from providing information to the board for possible board-initiated investigation instead of filing a complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of an investigation by the board\u8217\'3fs staff is to determine whether there is probable cause to believe that there has been a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or of rules adopted by the board. To facilitate the conduct of investigations, the board may issue and seek enforcement of subpoenas requiring the attendance and testimony of witnesses and subpoenas requiring the production of books, papers, records, and other real evidence relating to the matter under investigation. Upon the request of the board, an appropriate county attorney or the attorney general shall assist the staff of the board in its investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board determines on the basis of an investigation by board staff that there is probable cause to believe the existence of facts that would establish a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or of rules adopted by the board, the board may issue a statement of charges and notice of a contested case proceeding to the complainant and to the person who is the subject of the complaint, in the manner provided for the issuance of statements of charges under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. If the board determines on the basis of an investigation by staff that there is no probable cause to believe that a violation has occurred, the board shall close the investigation, dismiss any related complaint, and the subject of the complaint shall be notified of the dismissal. If the investigation originated from a complaint filed by a person other than the board, the person making the complaint shall also be notified of the dismissal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any stage during the investigation or after the initiation of a contested case proceeding, the board may approve a settlement regarding an alleged violation. Terms of a settlement shall be reduced to writing and be available for public inspection. An informal settlement may provide for any remedy specified in }}}{{\f5\fs18\hyphpar0\qj{section 68B.32D}}}{{\f5\fs18\hyphpar0\qj{. However, the board shall not approve a settlement unless the board determines that the terms of the settlement are in the public interest and are consistent with the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and rules of the board. In addition, the board may authorize board staff to seek informal voluntary compliance in routine matters brought to the attention of the board or its staff.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A complaint shall be a public record, but some or all of the contents may be treated as confidential under }}}{{\f5\fs18\hyphpar0\qj{section 22.7, subsection 18}}}{{\f5\fs18\hyphpar0\qj{, to the extent necessary under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Information informally reported to the board and board staff which results in a board-initiated investigation shall be a public record but may be treated as confidential information consistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 22.7, subsection 18}}}{{\f5\fs18\hyphpar0\qj{. If the complainant, the person who provides information to the board, or the person who is the subject of an investigation publicly discloses the existence of an investigation, the board may publicly confirm the existence of the disclosed formal complaint or investigation and, in the board\u8217\'3fs discretion, make the complaint or the informal referral public, as well as any other documents that were issued by the board to any party to the investigation. However, investigative materials may be furnished to the appropriate law enforcement authorities by the board at any time. Upon the commencement of a contested case proceeding by the board, all investigative material relating to that proceeding shall be made available to the subject of the proceeding. The entire record of any contested case proceeding initiated under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be a public record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Board records used to achieve voluntary compliance to resolve discrepancies and deficiencies shall not be confidential unless otherwise required by law.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1092, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1035, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 126, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768A.101}}}{{\f5\fs12\hyphpar0\qj{, 68B.32A}}}{{\f5\fs12\hyphpar0\qj{, 68B.32C}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.32C}}}{\*\bkmkstart stylerid1_2E8_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contested case proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contested case proceedings initiated as a result of the issuance of a statement of charges pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 68B.32B, subsection 9}}}{{\f5\fs18\hyphpar0\qj{, shall be conducted in accordance with the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. Clear and convincing evidence shall be required to support a finding that a person has violated }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or any rules adopted by the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. A preponderance of the evidence shall be required to support a finding that a person has violated }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{ or any rules adopted by the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{. The case in support of the statement of charges shall be presented at the hearing by one of the board\u8217\'3fs attorneys or staff unless, upon the request of the board, the charges are prosecuted by another legal counsel designated by the attorney general. A person making a complaint under }}}{{\f5\fs18\hyphpar0\qj{section 68B.32B, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, is not a party to contested case proceedings conducted relating to allegations contained in the complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hearings held pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be heard by a quorum of the board, unless the board designates a board member or an administrative law judge to preside at the hearing. If a quorum of the board does not preside at the hearing, the board member or administrative law judge shall make a proposed decision. The board or presiding board member may be assisted by an administrative law judge in the conduct of the hearing and the preparation of a decision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a finding by the board that the party charged has violated }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or rules adopted by the board, the board may impose any penalty provided for by }}}{{\f5\fs18\hyphpar0\qj{section 68B.32D}}}{{\f5\fs18\hyphpar0\qj{. Upon a final decision of the board finding that the party charged has not violated }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or the rules of the board, the complaint shall be dismissed and the party charged and the original complainant, if any, shall be notified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The right of an appropriate county attorney or the attorney general to commence and maintain a district court prosecution for criminal violations of the law is unaffected by any proceedings under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, establishing procedures to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1035, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 126, \'a717}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768A.101}}}{{\f5\fs12\hyphpar0\qj{, 68B.32A}}}{{\f5\fs12\hyphpar0\qj{, 331.756(14)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.32D}}}{\*\bkmkstart stylerid1_2E8_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalties \u8212\'3f recommended actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, after a hearing and upon a finding that a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or rules adopted by the board has occurred, may do one or more of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue an order requiring the violator to cease and desist from the violation found.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue an order requiring the violator to take any remedial action deemed appropriate by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue an order requiring the violator to file any report, statement, or other information as required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or rules adopted by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Publicly reprimand the violator for violations of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or rules adopted by the board in writing and provide a copy of the reprimand to the violator\u8217\'3fs appointing authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make a written recommendation to the violator\u8217\'3fs appointing authority that the violator be removed or suspended from office, and include in the recommendation the length of the suspension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the violation is a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted by the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the violator is an elected official of the executive branch of state government, other than an official who can only be removed by impeachment, make a written recommendation to the attorney general or the appropriate county attorney that an action for removal from office be initiated pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 66}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the violation is a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted by the board pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the violator is a lobbyist of the executive branch of state government, censure, reprimand, or impose other sanctions deemed appropriate by the board. A lobbyist may also be suspended from lobbying activities if the board finds that suspension is an appropriate sanction for the violation committed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue an order requiring the violator to pay a civil penalty of not more than two thousand dollars for each violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 68A}}}{{\f5\fs18\hyphpar0\qj{, or rules adopted by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refer the complaint and supporting information to the attorney general or appropriate county attorney with a recommendation for prosecution or enforcement of criminal penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At any stage during an investigation or during the board\u8217\'3fs review of routine compliance matters, the board may resolve the matter by admonishment to the alleged violator or by any other means not specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ as a posthearing remedy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person fails to comply with an action of the board under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the board may petition the Polk county district court for an order for enforcement of the action of the board. The enforcement proceeding shall be conducted as provided in }}}{{\f5\fs18\hyphpar0\qj{section 68B.33}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1042, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1035, \'a77, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768A.101}}}{{\f5\fs12\hyphpar0\qj{, 68A.401}}}{{\f5\fs12\hyphpar0\qj{, 68A.401A}}}{{\f5\fs12\hyphpar0\qj{, 68A.506}}}{{\f5\fs12\hyphpar0\qj{, 68B.32A}}}{{\f5\fs12\hyphpar0\qj{, 68B.32B}}}{{\f5\fs12\hyphpar0\qj{, 68B.32C}}}{{\f5\fs12\hyphpar0\qj{, 331.756(14)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.33}}}{\*\bkmkstart stylerid1_2E8_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judicial review \u8212\'3f enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Judicial review of the actions of the board may be sought in accordance with }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{. Judicial enforcement of orders of the board may be sought in accordance with }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.32D}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.34}}}{\*\bkmkstart stylerid1_2E8_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to any penalty contained in any other provision of law, a person who knowingly and intentionally violates a provision of }{{\f5\fs18\hyphpar0\qj{sections 68B.2A through 68B.8}}}{, }{{\f5\fs18\hyphpar0\qj{sections 68B.22 through 68B.24}}}{, or }{{\f5\fs18\hyphpar0\qj{sections 68B.35 through 68B.38}}}{ is guilty of a serious misdemeanor and may be reprimanded, suspended, or dismissed from the person\u8217\'3fs position or otherwise sanctioned.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768B.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 213, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1228, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a768B.25}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1116, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 9, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS2009, \'a768B.34}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.34A}}}{\*\bkmkstart stylerid1_2E8_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Actions commenced against local officials or employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Complaints alleging conduct of local officials or local employees which violates }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, except for }}}{{\f5\fs18\hyphpar0\qj{sections 68B.36}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{68B.38}}}{{\f5\fs18\hyphpar0\qj{, shall be filed with the county attorney in the county where the accused resides. However, if the county attorney is the person against whom the complaint is filed, or if the county attorney otherwise has a personal or legal conflict of interest, the complaint shall be referred to another county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Complaints alleging conduct of local officials or local employees which violates }}}{{\f5\fs18\hyphpar0\qj{section 68B.36}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{68B.38}}}{{\f5\fs18\hyphpar0\qj{ shall be filed with the ethics committee of the appropriate house of the general assembly if the conduct involves lobbying activities before the general assembly or with the board if the conduct involves lobbying activities before the executive branch.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a768B.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a768B.26}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1042, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 9, \'a74, 6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS2009, \'a768B.34A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1006, \'a77, 11}}}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER V}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E1_2E2}{PERSONAL FINANCIAL}{\*\bkmkend stylerid1_2E9_2E1_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{DISCLOSURE}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.35}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Personal financial disclosure \u8212\'3f certain officials, members of the general assembly, and candidates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The persons specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall file a financial statement at times and in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ that contains all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list of each business, occupation, or profession in which the person is engaged and the nature of that business, occupation, or profession, unless already apparent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A list of any other sources of income if the source produces more than one thousand dollars annually in gross income. Such sources of income listed pursuant to this paragraph may be listed under any of the following categories, or under any other categories as may be established by rule:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Securities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instruments of financial institutions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Trusts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Real estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Retirement systems.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other income categories specified in state and federal income tax regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financial statement required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be filed by the following persons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any statewide elected official.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The executive or administrative head or heads of any agency of state government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The deputy executive or administrative head or heads of an agency of state government.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The head of a major subunit of a department or independent state agency whose position involves a substantial exercise of administrative discretion or the expenditure of public funds as defined under rules adopted by the board, pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, in consultation with the department or agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the state banking council, the Iowa ethics and campaign disclosure board, the credit union review board, the economic development authority, the employment appeal board, the environmental protection commission, the Iowa finance authority, the Iowa public employees\u8217\'3f retirement system investment board, the Iowa lottery commission created in }}}{{\f5\fs18\hyphpar0\qj{section 99G.8}}}{{\f5\fs18\hyphpar0\qj{, the natural resource commission, the board of parole, the state racing and gaming commission, the state board of regents, the transportation commission, the office of consumer advocate, the utilities commission, the Iowa telecommunications and technology commission, and any full-time members of other boards and commissions as defined under }}}{{\f5\fs18\hyphpar0\qj{section 7E.4}}}{{\f5\fs18\hyphpar0\qj{ who receive an annual salary for their service on the board or commission. The Iowa ethics and campaign disclosure board shall conduct an annual review to determine if members of any other board, commission, or authority should file a statement and shall require the filing of a statement pursuant to rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Candidates for state office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Legislative employees who are the head or deputy head of a legislative agency or whose position involves a substantial exercise of administrative discretion or the expenditure of public funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board, in consultation with each executive department or independent agency, shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ that provide for the time and manner for the filing of financial statements by persons in the department or independent agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ethics committee of each house of the general assembly shall recommend rules for adoption by each house for the time and manner for the filing of financial statements by members or employees of the particular house. The legislative council shall adopt rules for the time and manner for the filing of financial statements by legislative employees of the central legislative staff agencies. The rules shall provide for the filing of the financial statements with either the chief clerk of the house, the secretary of the senate, or other appropriate person or body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A candidate for statewide office shall file a financial statement with the board, a candidate for the office of state representative shall file a financial statement with the chief clerk of the house of representatives, and a candidate for the office of state senator shall file a financial statement with the secretary of the senate. Statements shall contain information concerning the year preceding the year in which the election is to be held.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ providing for the filing of the financial statements with the board and for the deposit, retention, and availability of the financial statements. The ethics committees of the house of representatives and the senate shall recommend rules for adoption by the respective houses providing for the filing of the financial statements with the chief clerk of the house or the secretary of the senate and for the deposit, retention, and availability of the financial statements. Rules adopted shall also include a procedure for notification of candidates of the duty to file disclosure statements under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 163, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1092, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1200, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 61, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a7100, 121}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7142}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1091, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1141, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 9, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a784, 89}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 109, \'a74, 75}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a723, 24}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72294}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1054, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7178, 369}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 120, \'a738}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.3}}}{{\f5\fs12\hyphpar0\qj{, 68B.32}}}{{\f5\fs12\hyphpar0\qj{, 68B.34}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph e amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.35A}}}{\*\bkmkstart stylerid1_2E9_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Personal financial disclosure statements of state officials and employees \u8212\'3f internet access.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Personal financial disclosure statements filed with the chief clerk of the house or the secretary of the senate shall be recorded on the legislative internet site or copies of the personal financial disclosure statements shall be forwarded to the secretary of state for the recording of the information on an internet site. The board shall record personal financial disclosure statements filed with the board on an internet site.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a782}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1091, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a7257}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VI}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E1_30_2E1_2E2}{LOBBYING REGULATION}{\*\bkmkend stylerid1_2E1_30_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.36}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applicability }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ lobbyist registration required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All lobbyists shall, on or before the day their lobbying activity begins, register by electronically filing a lobbyist\u8217\'3fs registration statement at times and in the manner provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. In addition to any other information required by the general assembly, a lobbyist shall identify in the registration statement all clients of the lobbyist and whether the lobbyist will also be lobbying the executive branch. Lobbyists engaged in lobbying activities before the general assembly and before the office of the governor or any state agency shall file the statement with the chief clerk of the house of representatives or the secretary of the senate. The chief clerk of the house and the secretary of the senate shall establish an internet site for the electronic filing of lobbyist registrations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Registration shall be valid from the date of registration until the end of the calendar year. Any change in or addition to the information shall be registered within ten days after the change or addition is known to the lobbyist. Changes or additions for registrations of lobbyists shall be filed with either the chief clerk of the house or the secretary of the senate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning December 1 of each year, a person may preregister to lobby for the following calendar year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a lobbyist\u8217\'3fs service on behalf of all clients, employers, or causes is concluded prior to the end of the calendar year, the lobbyist may cancel the registration by electronically filing a notice of cancellation with the chief clerk of the house or the secretary of the senate. Upon cancellation of registration, a lobbyist is prohibited from engaging in any lobbying activity on behalf of any employer, client, or cause until reregistering.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Federal, state, and local officials who wish to lobby in opposition to the official position of their departments, commissions, boards, or agencies must indicate this on their lobbyist registration statements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief clerk of the house or the secretary of the senate shall post all lobbyist registrations in a searchable database on an internet site. The board shall establish a link on the internet site of the board to the lobbyist registration information on the general assembly\u8217\'3fs internet site.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 163, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1023, \'a783}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1092, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1006, \'a78, 11}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 86, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}{{\f5\fs12\hyphpar0\qj{, 68B.34A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.37}}}{\*\bkmkstart stylerid1_2E1_30_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lobbyist reporting.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1006, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.38}}}{\*\bkmkstart stylerid1_2E1_30_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lobbyist\u8217\'3fs client reporting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On or before July 31 of each year, a lobbyist\u8217\'3fs client shall electronically file with the general assembly a report that contains information on all salaries, fees, retainers, and reimbursement of expenses paid by the lobbyist\u8217\'3fs client to the lobbyist for lobbying purposes during the preceding twelve calendar months, concluding on June 30 of each year. The amount reported to the general assembly shall include the total amount of all salaries, fees, retainers, and reimbursement of expenses paid to a lobbyist for lobbying both the legislative and executive branches.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief clerk of the house and the secretary of the senate shall establish an internet site for the filing of lobbyist\u8217\'3fs client reports in an electronic format.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief clerk of the house and the secretary of the senate shall post all lobbyist\u8217\'3fs client reports filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in a searchable database on an internet site. The board shall establish a link on the internet site of the board to the lobbyist\u8217\'3fs client report information on the general assembly\u8217\'3fs internet site.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1228, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 163, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1042, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 161, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1091, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1006, \'a79, 11}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 86, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a768B.34}}}{{\f5\fs12\hyphpar0\qj{, 68B.34A}}}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER VII}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_2E1_2E2}{SUPREME COURT RULES}{\*\bkmkend stylerid1_2E11_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{68B.39}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supreme court rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The supreme court of this state shall prescribe rules establishing a code of ethics for officials and employees of the judicial branch of this state, and the immediate family members of the officials and employees. Rules prescribed under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall include provisions relating to the receipt or acceptance of gifts and honoraria, interests in public contracts, services against the state, and financial disclosure which are substantially similar to the requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The supreme court of this state shall also prescribe rules which relate to activities by officials and employees of the judicial branch which constitute conflicts of interest.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a768B.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 213, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1228, \'a721}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a768B.39}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 163, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1047, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a718}}}\par}}