\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F5_308B}{\*\bkmkend codeChapter_5F5_308B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 508B}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CONVERSION FROM MUTUAL COMPANY TO STOCK COMPANY}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a787.4}}}{{\f5\fs12\qc{, 296.7}}}{{\f5\fs12\qc{, 331.301}}}{{\f5\fs12\qc{, 364.4}}}{{\f5\fs12\qc{, 505.28}}}{{\f5\fs12\qc{, 505.29}}}{{\f5\fs12\qc{, 521.2}}}{{\f5\fs12\qc{, 521A.14}}}{{\f5\fs12\qc{, 521J.5}}}{{\f5\fs12\qc{, 669.14}}}{{\f5\fs12\qc{, 670.7}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb0\ri1445\li1445\sa146{ }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{Applies to plans of conversion established after July 1, 1985;}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\sa0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\cf5{{\f5\fs12\qc\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/85/CH0127.pdf" }{\fldrslt \cf5 \f5 \fs12{{85 Acts, ch 127, \'a716}}}}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri1445\li1445\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context clearly indicates otherwise:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommissioner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the commissioner of insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMutual life insurance company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmutual company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a level premium and natural premium life insurance company authorized under }}}{{\f5\fs18\hyphpar0\qj{chapter 508}}}{{\f5\fs18\hyphpar0\qj{ upon the mutual plan and includes a domestic company which meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 508.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPlan of conversion\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fconversion plan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a plan authorized by }}}{{\f5\fs18\hyphpar0\qj{section 508B.3}}}{{\f5\fs18\hyphpar0\qj{ and, in the case of plans authorized by }}}{{\f5\fs18\hyphpar0\qj{section 508B.3, subsections 1 and 3}}}{{\f5\fs18\hyphpar0\qj{, includes a procedure by which the mutual company\u8217\'3fs participating policies and contracts in force on the effective date of the conversion plan are operated by the reorganized company as a closed block of participating business for the exclusive benefit of the policies and contracts included, for dividend purposes only; to which are allocated assets of the mutual company in an amount which together with anticipated revenue from the business is reasonably expected to be sufficient to support the business; and which includes, but is not limited to, provisions for payment of claims and reasonable expenses, and provisions for continuation of current payable dividend scales if the experience underlying the scales continues, and a procedure for appropriate adjustments in the scales if the experience changes. However, at the option of the mutual company, some or all classes of group policies and contracts shall not be placed in the closed block but shall continue to be eligible to receive dividends based on the experience of the class or classes.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any amount of the policyholders\u8217\'3f consideration as specified in }}}{{\f5\fs18\hyphpar0\qj{section 508B.3, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for certain classes of policies or contracts is to be paid in the form of increased annual dividends to the policyholders in those classes, that amount is to be added to the assets allocated as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and is to be paid to those classes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPolicyholder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person, determined by the mutual company, who is the holder of a policy or annuity contract for the purposes of }}}{{\f5\fs18\hyphpar0\qj{section 508B.3, subsection 1, 2, or 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPolicyholders\u8217\'3f membership interest\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all policyholders\u8217\'3f rights as members of the mutual company including, but not limited to, rights to vote and participate in any distribution of surplus whether or not incident to liquidation of the mutual company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReorganized company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the domestic stock company into which a mutual company has been converted, converted and merged, or converted and consolidated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fStock life insurance company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstock company\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a life insurance company authorized under }}}{{\f5\fs18\hyphpar0\qj{chapter 508}}}{{\f5\fs18\hyphpar0\qj{ upon the stock plan and includes a domestic company which meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 508.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1237, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1234, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 165, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mutual company becoming stock company \u8212\'3f authorization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mutual life insurance company may become a stock life insurance company pursuant to a plan of conversion established and approved in the manner provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A plan of conversion may provide that a mutual company may convert into a domestic stock company, convert and merge, or convert and consolidate with a domestic stock company, as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 490}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{491}}}{{\f5\fs18\hyphpar0\qj{, whichever is applicable. However, the mutual company is not required to comply with }}}{{\f5\fs18\hyphpar0\qj{sections 491.102 through 491.105}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{sections 490.1102}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{490.1104}}}{{\f5\fs18\hyphpar0\qj{ relating to approval of merger or consolidation plans by boards of directors and shareholders, if at the time of approval of the plan of conversion the board of directors approves the merger or consolidation and if at the time of approval of the plan by policyholders as provided in }}}{{\f5\fs18\hyphpar0\qj{section 508B.6}}}{{\f5\fs18\hyphpar0\qj{, the policyholders approve the merger or consolidation. }}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ supersedes any conflicting provisions of }}}{{\f5\fs18\hyphpar0\qj{chapters 521}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{521A}}}{{\f5\fs18\hyphpar0\qj{. A mutual company may convert, merge, or consolidate as part of a plan of conversion in which a majority or all of the common shares of the stock company are acquired by another corporation, which may be a corporation organized for that purpose, or in which the new stock company consolidates with a stock company to form another stock company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of selecting a plan of conversion provided for in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a mutual company may convert to a stock company pursuant to a plan approved by the commissioner. The commissioner or the mutual company may use any provisions or combination of provisions provided for a plan in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and may adopt any other provisions which are not unfair or inequitable to the policyholders of the mutual company. If a mutual company selects this procedure for conversion purposes, the mutual company shall reimburse the state for expenses incurred by the division in connection with the conversion plan except for expenses that are normal operating expenses of the division.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1237, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1205, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1234, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1154, \'a7108, 125}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conversion plans to be fair and equitable \u8212\'3f alternative procedures and requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A plan of conversion shall be fair and equitable to policyholders. A plan of conversion is fair and equitable if it satisfies the conditions of }{{\f5\fs18\hyphpar0\qj{subsection 1, 2, or 3}}}{. The commissioner may determine whether any other plan proposed by a mutual company is fair and equitable to its policyholders.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a plan of conversion under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall provide all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The policyholders\u8217\'3f membership interest shall be exchanged, in a manner which takes into account the estimated proportionate contribution of surplus of each class of participating policies and contracts, for all of the common shares of the reorganized company or its parent company, if any, or for either or a combination of the common shares of the reorganized company or its parent company, if any, and consideration equal to the proceeds of the sale of the common shares by the issuer or by a trust or other entity existing for the exclusive benefit of policyholders and established solely for the purpose of effecting the conversion, to which trust or other entity the common shares, or the options to acquire or securities convertible into the common shares, shall be issued by the issuer on the effective date of the conversion. The consideration shall be distributed to policyholders during a process of conversion specified in the plan which shall not last more than ten years after the effective date of conversion or until the death of the policyholder, whichever occurs first.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the anticipated issuance within a shorter period is disclosed, the issuer of common shares shall not, within two years after the effective date of reorganization, issue either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any of its common shares or any securities convertible with or without consideration into the common shares or carrying any warrant to subscribe to or purchase common shares.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any warrant, right or option to subscribe to or purchase the common shares or other securities described in subparagraph (1), except for the issue of common shares to or for the benefit of policyholders pursuant to the plan of conversion and the issue of stock in anticipation of options for the purchase of common shares being granted to officers or employees of the reorganized company or its parent company, if any, pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the common shares have a public market when issued, the issuer shall use its best efforts to encourage and assist in the establishment of a public market for the common shares within two years of the effective date of the conversion or a longer period as disclosed in the plan of conversion. Within one year after the offering of stock other than the initial distribution, but no later than six years after the effective date of the conversion, the reorganized company shall offer to make available to policyholders who received and retained shares of stock with minimal values on conversion, a procedure to dispose of those shares of stock at market value without brokerage commissions or similar fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A plan of conversion under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall provide all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The mutual company\u8217\'3fs participating business, comprised of its participating policies and contracts in force on the effective date of the conversion, shall be operated by the reorganized insurer as a closed block of participating business. However, at the option of the mutual company, group policies and group contracts may be omitted from the closed block.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assets of the mutual company shall be allocated to the closed block of participating business in an amount equal to the reserves and liabilities for the mutual life insurer\u8217\'3fs participating policies and contracts in force on the effective date of the conversion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consideration to be given in exchange for the policyholders\u8217\'3f membership interest consists of aggregate consideration in a form or forms selected by the mutual company having a value equal to the amount of the statutory surplus of the mutual life insurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consideration is allocated among the policyholders in a manner which is fair and equitable to the policyholders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reorganized company or its parent corporation shall issue and sell shares of one or more classes having a total price equal to the estimated value in the market on the initial offering date of the shares.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The estimated value shall take into account all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consideration to be given to policyholders pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of the sale of the shares.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any additional value attributable to the shares as a result of a purchaser or a group of purchasers who acted in concert to obtain shares in the initial offering, attaining, through such purchase, control of the reorganized company or its parent corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a purchaser or a group of purchasers acting in concert is to attain such control in the initial offering, the mutual company shall not, directly or indirectly, pay for any of the costs or expenses of conversion of the mutual company, whether or not the conversion is effected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reorganized company may share in the profits of the closed block of participating business for the benefit of stockholders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A plan of conversion under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall satisfy all of paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and may add or substitute, as applicable, the options provided in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fl\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reorganized company or its parent corporation shall issue and sell shares of one or more classes having a total price equal to the estimated market value on the initial offering taking into account the value to be given to participating policyholders pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and the proceeds of the sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The participating policyholders\u8217\'3f consideration shall be based on the latest annual statement, updated to the effective date of the conversion plan, and filed prior to the effective date of the adoption by the board of directors of the plan of conversion. The policyholders\u8217\'3f consideration shall be equal to the sum of the total amount of assets allocated to the participating business and an amount equal to reserves and other liabilities attributable to any group participating policies and contracts not included in the closed block of participating business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consideration to be given in exchange for the policyholders\u8217\'3f membership interest shall consist of the participating policyholders\u8217\'3f consideration and nontransferable preemptive subscription rights to purchase all of the common shares of the issuer and the establishment of a liquidation account for the benefit of the policyholders in the event of a subsequent complete liquidation of the reorganized company having the terms described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fj\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consideration and the preemptive subscription rights to purchase the common shares shall be allocated among the participating policyholders in a manner determined by the reorganized company which takes into account the estimated contribution of each class of participating policies and contracts to the total amount of the policyholders\u8217\'3f consideration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of the common shares which any person, together with any affiliates or group of persons acting in concert, may subscribe for or purchase in the reorganization shall be limited to not more than five percent of the common shares. For this purpose, neither the members of the board of directors of the reorganized company nor of its parent corporation, if any, shall be deemed to be affiliates or a group of persons acting in concert solely by reason of their board membership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the common shares have a public market when issued, officers and directors of the issuer and their affiliates shall not, for at least ninety days after the date of conversion, purchase common shares of the issuer, except in negotiated transactions involving more than ten percent of the outstanding common shares.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless the common shares have a public market when issued, the issuer shall use its best efforts to encourage and assist in the establishment of a public market for the common shares.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The issuer shall not, for at least three years following the conversion, repurchase any of its common shares except pursuant to a pro rata tender offer to all shareholders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Until the liquidation account has been reduced to zero, the issuer shall not declare or pay a cash dividend on, or repurchase any of, its common shares in an amount in excess of its cumulative earned surplus generated after the conversion determined in accordance with generally accepted accounting principles, if the effect would be to cause the amount of the statutory surplus of the reorganized company to be reduced below the then amount of the liquidation account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The liquidation account referred to in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ must be equal to the excess of the total amount of the assets of the mutual company as of the effective date of the conversion over the sum of the total amount of assets allocated to the closed block of participating business and the policyholders\u8217\'3f consideration and other reserves and liabilities attributed to policies and contracts not included in the amount attributable to policies and contracts in force on that effective date. The determinations shall be based on the latest annual statement of the mutual company, updated to the effective date, and filed before the effective date of the conversion plan. The function of the liquidation account is solely to establish a priority on liquidation and its existence does not restrict the use or application of the surplus of the reorganized company except as specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fi\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The liquidation account shall be allocated equally as of the effective date of conversion among the then participating policyholders. The amount allocated to a policy or contract shall not increase and shall be reduced to zero when the policy or contract terminates. In the event of a complete liquidation of the reorganized company, the policyholders among which the liquidation account is allocated are entitled to receive a liquidation distribution in the then amount of the liquidation account before any liquidation distribution is made with respect to shares.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the option of the mutual company, the consideration to be given in exchange for the policyholders\u8217\'3f membership interests may consist of cash, securities of the reorganized company, securities of another institution, a certificate of contribution, additional life insurance, annuity benefits, increased dividends, or other consideration or any combination of forms of consideration. The consideration, if any, given to a class or category of policyholders may differ from the consideration given to another class or category of policyholders. The certificate of contribution shall be repayable in ten years, equal to one hundred percent of the value of the policyholders\u8217\'3f membership interest, and bear interest at the highest rate charged by the reorganized company for policy loans on the effective date of the conversion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the option of the mutual company, a plan may provide that any shares of the stock of the reorganized company or its parent corporation included in the policyholders\u8217\'3f consideration shall be placed on the effective date of the conversion in a trust or other entity existing for the exclusive benefit of the participating policyholders and established solely for the purpose of effecting the reorganization. Under this option, the shares placed in trust shall be sold over a period of not more than ten years and the proceeds of the shares shall be distributed using the distribution priorities prescribed in the plan.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1234, \'a79 \u8211\'3f 14}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1023, \'a78, 60}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7508B.1}}}{{\f5\fs12\hyphpar0\qj{, 508B.5}}}{{\f5\fs12\hyphpar0\qj{, 508B.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Eligible policyholders participation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The policyholders who are entitled to notice of and to vote upon approval of a plan of conversion and entitled to notice of a public hearing are the policyholders whose policies or contracts are in force on the date of adoption of the plan of conversion. Each policyholder whose policy has been in force for at least one year prior to the date is entitled to the consideration, if any, provided for the policyholder in the plan based on the policyholder\u8217\'3fs membership interest determined pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, but only if the policyholder\u8217\'3fs membership interest arose from a policy or contract in force on the effective date of the conversion and such membership interest has been held continuously for at least one year prior to the date of adoption of the plan. For this purpose, any changes in status of, or premiums in excess of, those required on the policies or contracts occurring or made after the date one year prior to the date of adoption of the plan shall be disregarded.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1023, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of consultant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A plan may provide for the appointment by the mutual company of a person as defined in }}}{{\f5\fs18\hyphpar0\qj{section 4.1, subsection 20}}}{{\f5\fs18\hyphpar0\qj{, who is qualified to act as a consultant. The appointment of the consultant shall be reviewed by the commissioner and unless the commissioner finds the consultant unqualified, the consultant shall carry out the duties required by the mutual company and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consultant may assist in determining the equity of the policyholders or value of the mutual company. The consultant may consider the value of the consideration to be given to the participating policyholders in exchange for their membership interests and may consider the valuations necessary to carry out the plans provided for in }}}{{\f5\fs18\hyphpar0\qj{section 508B.3}}}{{\f5\fs18\hyphpar0\qj{. Valuations shall be made taking into account the latest filed annual statement of the mutual company, updated to the effective date of the conversion plan, and any significant developments occurring subsequent to the date of the statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The findings of the consultant may be modified by the mutual company at any time so long as the results are not unfair or inequitable to policyholders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it can be shown by the mutual company to the commissioner that an underwriter of the shares is a qualified person, the underwriter may be appointed as the consultant.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1234, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Approval of plan by policyholders \u8212\'3f notice of election \u8212\'3f effective date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The plan of conversion shall be submitted to and shall not take effect until approved by two-thirds of the policyholders of the mutual company voting on the plan. Notice of a meeting for the purpose of voting on the conversion plan shall be provided by mail to each policyholder entitled to vote in accordance with the articles of incorporation or bylaws of the mutual company. Each policyholder entitled to vote may cast one vote unless otherwise provided in the articles of incorporation or bylaws of the mutual company. Voting shall be by ballot, in person or by proxy. A quorum shall consist of a quorum as defined in the articles of incorporation or bylaws of the mutual company. A copy of the plan of conversion, or a summary of the plan of conversion, shall accompany the notice of meeting and election. The notice of meeting may contain the notice of any planned public hearing. An approved plan of conversion shall take effect on the date specified in the plan.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 165, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7508B.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Review of plan by commissioner \u8212\'3f hearing authorized \u8212\'3f approval.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commissioner of insurance shall review the plan. The commissioner shall approve the plan if the commissioner finds the plan complies with all provisions of law, the plan is fair and equitable to the mutual company and its policyholders, and that the reorganized company will have the amount of capital and surplus deemed by the commissioner to be reasonably necessary for its future solvency. The commissioner may order a hearing on the fairness and equity of the terms of the plan after giving written notice of the hearing to the mutual company, its policyholders, and other interested persons, all of whom have the right to appear at the hearing. Costs incurred in connection with the notice shall be paid by the company.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1234, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1023, \'a710, 60}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7505.23}}}{{\f5\fs12\hyphpar0\qj{, 511.8(4)(f)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Payment of fees, salaries and costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A director, officer, agent or employee of the mutual company shall not receive a fee, commission or other valuable consideration, other than regular salary and compensation, for aiding, promoting or assisting in the conversion except as set forth in the plan approved by the commissioner. }{{\f5\fs18\hyphpar0\qj{This section}}}{ does not prohibit the payment of reasonable fees and compensation to a consultant, attorneys at law, accountants, actuaries or other persons specifically employed for services performed in the practice of their professions while completing the plan of conversion, even if these persons are directors of the mutual company.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Act of conversion \u8212\'3f continuation of company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the commissioner and the policyholders approve the conversion plan as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the commissioner shall issue a new certificate of authority to the reorganized company effective on the effective date of the conversion as provided in the plan. The reorganized company is a continuation of the mutual life insurance company and the conversion shall not annul or modify any of the mutual company\u8217\'3fs existing suits, contracts, or liabilities except as provided in the approved conversion plan. All rights, franchises, and interests of the mutual company in and to property, assets, and other interests shall be transferred to and shall vest in the reorganized company and the reorganized company shall assume all obligations and liabilities of the mutual company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reorganized company shall exercise all rights and powers and perform all duties conferred or imposed by law on life insurance companies writing the classes of insurance written by it, and shall retain the rights and contracts existing before conversion, subject to provisions of the plan.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1237, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1023, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Continuation of officers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The directors and officers of the mutual company shall serve the reorganized company until new directors and officers are elected and qualify pursuant to the articles of incorporation and bylaws of the reorganized company.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The commissioner shall issue rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ to carry out the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a711}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Amendments \u8212\'3f withdrawal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{At any time before the conversion, if done pursuant to rules issued by the commissioner or as may otherwise be required by the commissioner, the board of directors of a mutual company may amend the conversion plan. An amendment to a conversion plan is subject to the prior approval of the commissioner. The board of directors of a mutual company may withdraw the plan of conversion at any time prior to the conversion.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 165, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.13}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibitions on certain offers to acquire shares.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Prior to and for a period of five years following the effective date of the conversion, and in the case of the plans of conversion specified in }{{\f5\fs18\hyphpar0\qj{section 508B.3, subsections 1 and 3}}}{, five years following the date of distribution of consideration to the policyholders in exchange for their membership interests, a person, other than the reorganized company, other than an employee benefit plan or employee benefit trust sponsored by the reorganized company, or as otherwise specifically provided for in the plan of conversion, shall not directly or indirectly acquire or offer to acquire the beneficial ownership of more than five percent of any class of voting security of the reorganized company, and a person, other than the reorganized company or other than an employee benefit plan or employee benefit trust sponsored by the reorganized company, who acquires five percent or more of any class of voting security of the reorganized company prior to the conversion or as specifically provided for in the plan of conversion, shall not directly or indirectly acquire or offer to acquire the beneficial ownership of additional voting securities of the reorganized company, unless the acquisition is approved by the commissioner as not being contrary to the interests of the policyholders of the reorganized company or its life insurance company subsidiary and by the board of directors of the reorganized company. The commissioner and the board of directors may consider the factors set forth in }{{\f5\fs18\hyphpar0\qj{section 490.1108A}}}{. The provisions of }{{\f5\fs18\hyphpar0\qj{section 521A.3}}}{, except }{{\f5\fs18\hyphpar0\qj{section 521A.3, subsection 4}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{, shall be applicable to a proposed acquisition subject to }{{\f5\fs18\hyphpar0\qj{this section}}}{. An approved plan of conversion may include a stock option plan. As used in }{{\f5\fs18\hyphpar0\qj{this section}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbeneficial ownership\u8221\'3f}}}{ means, with respect to a security, the sole or shared power to vote or direct the voting of the security or the sole power to dispose or direct the disposition of the security.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a713}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1234, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 165, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1154, \'a7110, 125}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitation of actions \u8212\'3f security for attorney fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner\u8217\'3fs order approving or disapproving a plan of conversion shall be considered final agency action under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action challenging the validity of a conversion plan, or any part of a conversion plan, shall not be commenced more than thirty days following the date of approval by the commissioner, unless an application for rehearing is filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 17A.16, subsection 2}}}{{\f5\fs18\hyphpar0\qj{. If an application for rehearing is filed, then such action must be filed within thirty days after that application is denied or deemed denied or, if the application is granted, within thirty days after the issuance of the commissioner\u8217\'3fs final decision on rehearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reorganized company or a defendant may petition the court in such an action to give security for the reasonable attorney fees which may be incurred by any party to the action. The amount of the security may be increased or decreased in the discretion of the court having jurisdiction if a showing is made that the security provided is or may become inadequate or excessive.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1234, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 165, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1023, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a7127}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{508B.15}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of secretary of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{After approval of the conversion plan by the commissioner and the policyholders, the secretary of state shall accept for filing a verified copy of the amended articles of incorporation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 127, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1237, \'a733}}}\par}}