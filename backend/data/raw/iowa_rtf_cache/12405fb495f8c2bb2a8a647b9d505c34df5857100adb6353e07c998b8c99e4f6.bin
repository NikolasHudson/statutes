0\qj{; 2025 Acts, ch 148, \'a786, 87}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.86}}}{{\f5\fs12\hyphpar0\qj{, 28J.19}}}{{\f5\fs12\hyphpar0\qj{, 331.301}}}{{\f5\fs12\hyphpar0\qj{, 331.401}}}{{\f5\fs12\hyphpar0\qj{, 347.32}}}{{\f5\fs12\hyphpar0\qj{, 364.4}}}{{\f5\fs12\hyphpar0\qj{, 364.19}}}{{\f5\fs12\hyphpar0\qj{, 420.207}}}{{\f5\fs12\hyphpar0\qj{, 421.1A}}}{{\f5\fs12\hyphpar0\qj{, 421.17}}}{{\f5\fs12\hyphpar0\qj{, 423A.5}}}{{\f5\fs12\hyphpar0\qj{, 427.3}}}{{\f5\fs12\hyphpar0\qj{, 427.13}}}{{\f5\fs12\hyphpar0\qj{, 437A.4}}}{{\f5\fs12\hyphpar0\qj{, 437A.6}}}{{\f5\fs12\hyphpar0\qj{, 456A.16}}}{{\f5\fs12\hyphpar0\qj{, 465A.4}}}{{\f5\fs12\hyphpar0\qj{, 483A.3}}}{{\f5\fs12\hyphpar0\qj{, 904.302}}}{{\f5\fs12\hyphpar0\qj{, 904.705}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Federally owned lands, }{{\f5\fs12\hyphpar0\qj{\'a71.4}}}{ et seq. }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Leased church property, }{{\f5\fs12\hyphpar0\qj{\'a7565.1}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 42 applies retroactively to assessment years beginning on or after January 1, 2024; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1097, \'a75}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{*}{{\f5\fs12\hyphpar0\qj{Chapter 433}}}{ repealed effective July 1, 2024; corrective legislation is pending}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 37, paragraph b amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Taxable property acquired through eminent domain.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Real estate occupied as a public road, and rights-of-way for established public levees and rights-of-way for established, open, public drainage improvements shall not be taxed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When land or rights in land are acquired in connection with or for public use or public purposes, the acquiring authority shall assist in the collection of property taxes and special assessments. However, assistance in the collection of the property taxes does not require the payment of property taxes on the property acquired which exceed the amount of just compensation offered as required by }}}{{\f5\fs18\hyphpar0\qj{section 6B.45}}}{{\f5\fs18\hyphpar0\qj{ for the acquisition of the property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The property owner shall pay all property taxes which are due and payable when the property owner surrenders possession of the property acquired and also those which become due and payable for the fiscal year the property is acquired in an amount equal to one-twelfth of the taxes due and payable on the property acquired for the preceding fiscal year multiplied by the number of months in the fiscal year in which the property was acquired which elapsed prior to the month in which the property owner surrenders possession, and including that month if the surrender of possession occurs after the fifteenth day of a month. For purposes of computing the payments, the property owner has surrendered possession of property acquired by eminent domain proceedings when the acquiring authority has the right to obtain possession of the acquired property as authorized by law. When all of the property is acquired for public use or public purposes, the property owner shall pay all special assessments in full which have been certified to the county treasurer for collection before the possession date of the acquiring authority. When part but not all of the property is acquired for public use or public purposes, taxing authorities may collect property taxes and special assessments which the property owner is obligated to pay, in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 446}}}{{\f5\fs18\hyphpar0\qj{, from that part of the property which is not acquired. The county treasurer shall collect and accept the payment received on property acquired for public use or public purposes as full and final payment of all property tax on the property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For that portion of the prorated year for which the acquiring authority has possession of the property or part of the property acquired in connection with or for public use or public purposes, all taxes shall be canceled by the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From the date of possession by the acquiring authority for land or rights in land acquired in connection with or for public use or public purposes, and for as long as ownership is retained by the acquiring authority, a special assessment shall not be certified to the county treasurer for collection while under public ownership. However, the assessment may be certified for collection to the county treasurer upon the sale of the acquired property by the acquiring authority to a new owner on a prorated basis. Special assessments certified to a county treasurer for collection while under public ownership shall be canceled by the county treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon sale of the acquired property by the acquiring authority to a new owner, the new owner shall pay all property taxes which become due and payable or would have become due and payable but for the acquisition by the acquiring authority for the fiscal year the property is acquired by the new owner in an amount equal to one-twelfth of the taxes multiplied by the number of months in the fiscal year in which the new owner acquired the property which occurred after the month in which the new owner acquired the property.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a7809; C97, \'a71344; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6945;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7427.2}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1183, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1153, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 40, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a7121}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.2A}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Taxation of life estate in property donated to public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Real estate donated to the state or a political subdivision of the state or any agency of the state or political subdivision, for which the donor retains a life estate, or provides for another to possess a life estate shall continue to be subject to property taxation and special assessment to the same extent as the property was so subject during the fiscal year in which the donation was made. The real property shall continue to be taxed until the fiscal year following the fiscal year during which the life estate terminates. Upon termination of the life estate, the real estate shall be subject to taxation as otherwise provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ applies to property donated on or after July 1, 1992, for purposes of property taxes or special assessments due and payable in fiscal years beginning on or after July 1, 1997.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 146, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7168}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a7104}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abatement of taxes of certain exempt entities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board of supervisors may abate the taxes levied against property acquired by gift or purchase by a person or entity if the property acquired by gift or purchase was transferred to the person or entity after the deadline for filing for property tax exemption in the year in which the property was transferred and the property acquired by gift or purchase would have been exempt under }{{\f5\fs18\hyphpar0\qj{section 427.1, subsection 7, 8, or 9}}}{, if the person or entity had been able to file for exemption in a timely manner.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 140, \'a753}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 186, \'a727, 30}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{427.4 through 427.7}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.8}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petition for suspension or abatement of taxes, assessments, and rates or charges, including interest, fees, and costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a person is unable to contribute to the public revenue, the person may file a petition, duly sworn to, with the board of supervisors, stating that fact and giving a statement of parcels, as defined in }{{\f5\fs18\hyphpar0\qj{section 445.1}}}{, owned or possessed by the petitioner, and other information as the board may require. The board of supervisors may order the county treasurer to suspend the collection of the taxes, special assessments, and rates or charges, including interest, fees, and costs, which are assessed against the petitioner or the petitioner\u8217\'3fs estate for the current year and those unpaid for prior years, or the board may abate the taxes, special assessments, and rates or charges, including interest, fees, and costs. The petition, when approved, shall be filed by March 1 of the current tax year with the treasurer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7455; R60, \'a7711; C73, \'a7797; C97, \'a71304; SS15, \'a71304; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6950;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7427.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a733}}}{; }{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1031, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a747}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.402}}}{{\f5\fs12\hyphpar0\qj{, 420.207}}}{{\f5\fs12\hyphpar0\qj{, 425.17}}}{{\f5\fs12\hyphpar0\qj{, 427.9}}}{{\f5\fs12\hyphpar0\qj{, 427.10}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For definitions applicable to this section, see }{{\f5\fs12\hyphpar0\qj{\'a7445.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.9}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspension of taxes, assessments, and rates or charges, including interest, fees, and costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a person is a recipient of federal supplementary security income or state supplementary assistance, as defined in }{{\f5\fs18\hyphpar0\qj{section 249.1}}}{, or is a resident of a health care facility, as defined by }{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{, which is receiving payment from the department of health and human services for the person\u8217\'3fs care, the person shall be deemed to be unable to contribute to the public revenue. The director of health and human services shall notify a person receiving such assistance of the tax suspension provision and shall provide the person with evidence to present to the appropriate county board of supervisors which shows the person\u8217\'3fs eligibility for tax suspension on parcels owned, possessed, or upon which the person is paying taxes as a purchaser under contract. The board of supervisors so notified, without the filing of a petition and statement as specified in }{{\f5\fs18\hyphpar0\qj{section 427.8}}}{, shall order the county treasurer to suspend the collection of all the taxes, special assessments, and rates or charges, including interest, fees, and costs, assessed against the parcels and remaining unpaid by the person or contractually payable by the person, for such time as the person remains the owner or contractually prospective owner of the parcels, and during the period the person receives assistance as described in }{{\f5\fs18\hyphpar0\qj{this section}}}{. The county board of supervisors shall annually send to the department of health and human services the names and social security numbers of persons receiving a tax suspension pursuant to }{{\f5\fs18\hyphpar0\qj{this section}}}{. The department shall verify the continued eligibility for tax suspension of each name on the list and shall return the list to the board of supervisors. The director of health and human services shall advise the person that the person may apply for an additional property tax credit pursuant to }{{\f5\fs18\hyphpar0\qj{sections 425.16 through 425.37}}}{ which shall be credited against the amount of the taxes suspended.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76950-g1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6950.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7427.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1031, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1016, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 151, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a7128}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71152}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.401}}}{{\f5\fs12\hyphpar0\qj{, 420.207}}}{{\f5\fs12\hyphpar0\qj{, 425.17}}}{{\f5\fs12\hyphpar0\qj{, 427.10}}}{{\f5\fs12\hyphpar0\qj{, 427.11}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For definitions applicable to this section, see }{{\f5\fs12\hyphpar0\qj{\'a7445.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.10}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Abatement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board of supervisors may, if in their judgment it is for the best interests of the public and the petitioner referred to in }{{\f5\fs18\hyphpar0\qj{section 427.8}}}{, or the public and the person referred to in }{{\f5\fs18\hyphpar0\qj{section 427.9}}}{, abate the taxes, special assessments, and rates or charges, including interest, fees, and costs, which have previously been suspended as provided in }{{\f5\fs18\hyphpar0\qj{section 427.8}}}{ or }{{\f5\fs18\hyphpar0\qj{427.9}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7455; R60, \'a7711; C73, \'a7797; C97, \'a71304; SS15, \'a71304; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6951;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7427.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a734}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.402}}}{{\f5\fs12\hyphpar0\qj{, 420.207}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For definitions applicable to this section, see }{{\f5\fs12\hyphpar0\qj{\'a7445.1}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.11}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Grantee or devisee to pay tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the petitioner or person described in }{{\f5\fs18\hyphpar0\qj{section 427.9}}}{ sells any parcel upon which the taxes, special assessments, and rates or charges, including interest, fees, and costs, have been suspended, or if any parcel, or any part of the parcel, upon which the taxes, special assessments, and rates or charges, including interest, fees, and costs, have been suspended, passes by devise, bequest, or inheritance to any person other than the surviving spouse or minor child of the petitioner or other person, the total amount due that has been thus suspended shall all become due and payable with the next semiannual installment of taxes. Interest shall accrue on the total amount due at the rate of one and one-half percent per month from the next succeeding delinquency date to the month of payment unless payment is tendered in full before the delinquency date. Interest does not accrue during the suspension period on suspended parcels, including those parcels suspended prior to April 1, 1992. The petitioner, or any other person, may pay the suspended amounts at any time during the suspension period. Except in the case of manufactured or mobile home taxes, special assessments, or rates or charges, the treasurer may accept a partial payment during the suspension period with the partial payment first being applied to interest and costs.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6952;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7427.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a723}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 153, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 176, \'a780}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.207}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For definitions applicable to this section, see }{{\f5\fs12\hyphpar0\qj{\'a7445.1}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.12}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suspended tax record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county treasurer shall maintain within the county system, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{, the official record of suspended taxes, special assessments, and rates or charges, the collection of which has been suspended by order of the board of supervisors. The record shall include, but is not limited to, the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A governmental or platted description of the parcel on which the tax, special assessment, rate, or charge has been levied or on which it is a lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the owner of the parcel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount and year of the tax, special assessment, rate or charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date the suspension was ordered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county system, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{, shall be such that all entries of taxes, special assessments, rates, or charges against the parcel shall be separate from the entry of taxes, special assessments, rates, or charges against all other parcels.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a suspended tax, special assessment, or rate or charge in the county system is paid, or subsequently abated, the treasurer shall enter in the county system a notification of payment or abatement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a suspension ordered by the board of supervisors for any reason provided by law, has been entered in the county system, the entry, on and after its date, is a lien and shall serve as notice of a lien in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 445.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a76952-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6952.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7427.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 191, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.559}}}{{\f5\fs12\hyphpar0\qj{, 445.1}}}{{\f5\fs12\hyphpar0\qj{, 447.9}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For definitions applicable to this section, see }{{\f5\fs12\hyphpar0\qj{\'a7445.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.13}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{What taxable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All other real property is subject to taxation in the manner prescribed, and }{{\f5\fs18\hyphpar0\qj{this section}}}{ is also intended to embrace ferry franchises and toll bridges, which, for the purpose of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are considered real property. However, }{{\f5\fs18\hyphpar0\qj{this section}}}{ is subject to }{{\f5\fs18\hyphpar0\qj{section 427.1}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7456; R60, \'a7712; C73, \'a7801; C97, \'a71308; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6953;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7427.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 296, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a752}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Bridges taxed, }{{\f5\fs12\hyphpar0\qj{\'a7434.20}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.14}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{County lands.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All lands in this state which are owned or held by any other county or counties claiming title under locations with swampland indemnity scrip, or otherwise, shall be taxed the same as other real estate within the limits of the county.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7456; R60, \'a7712; C73, \'a7801; C97, \'a71308; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6954;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7427.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.15}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interest of lessee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In all cases where land belonging to any state institution has been leased and the leases renewed, containing an option of purchase, the interest of the lessees therein shall be subject to assessment and taxation as real estate. The value of such interest shall be fixed by deducting from the value of the lands and improvements the amount required by the lease to acquire the title thereto, which leasehold interest so assessed and taxed may be sold for delinquent taxes and deeds issued thereunder as in other cases of tax sales, and the same rights shall accrue to the grantee therein as were held and owned by the tenant.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a71351; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6955;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7427.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.16}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Historic property \u8212\'3f rehabilitation tax exemption \u8212\'3f application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of supervisors shall annually designate real property in the county for a historic property tax exemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Application for the exemption shall be filed with the assessor, not later than February 1 of the assessment year, on forms provided by the department of revenue. The exemption application shall include an approved application for certified substantial rehabilitation from the state historic preservation officer and documentation of additional property tax relief or financial assistance currently allowed for the real property. Upon receipt of the application, the assessor shall certify whether or not the property is eligible to receive the exemption and shall forward the application to the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before the board may designate real property for the exemption, the board shall establish priorities for which an exemption may be granted. The priorities shall be based upon financial assistance or property tax relief the owner is receiving for the property or for which the property is eligible. A public hearing shall be held with notice given as provided in }}}{{\f5\fs18\hyphpar0\qj{section 73A.2}}}{{\f5\fs18\hyphpar0\qj{ at which the proposed priority list shall be presented. However, a public hearing is not required if the proposed priorities are the same as those established for the previous year. After the public hearing, the board shall adopt by resolution the proposed priority list or another priority list.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After receipt from the assessor of an exemption application with an accompanying approved application from the state historic preservation officer, and the establishment of a priority list, the board shall grant a tax exemption under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ using the adopted priority list. The board shall notify an owner in writing of a denial of the exemption under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and an explanation of the denial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Real property designated for the tax exemption shall be designated by April 15 of the assessment year in which the fiscal year begins for which the exemption is granted. Notification shall be sent to the county auditor and the applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The owner shall apply for an exemption and the exemption may be approved for a period of not more than four years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhistoric property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Property in Iowa listed on the national register of historic places.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A historical site as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8A.702}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Property located in an area of historical significance as defined in }}}{{\f5\fs18\hyphpar0\qj{section 15.445}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Property located in an area designated as an area of historic significance under }}}{{\f5\fs18\hyphpar0\qj{section 15.459}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Property designated a historic building or site as approved by a county or municipal landmark ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsubstantial rehabilitation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means qualified expenditures which exceed the greater of the adjusted basis of the building or five thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadjusted basis\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the acquisition cost of the property to the taxpayer; less the value of the land; less depreciation taken or one-half the current assessed valuation of the property, whichever is greater; plus the cost of additions or improvements to the property since its acquisition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualified expenditures\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means costs incurred to preserve or to maintain a building as a historic property according to the secretary of the interior\u8217\'3fs standards for rehabilitation and guidelines for rehabilitating historic buildings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assessor shall determine the base year valuation of the historic property upon receipt of the approved application and shall make a notation on each statement of assessment that the exemption of the historic property shall be based upon the certification from the state historic preservation officer. An assessor shall make an annual report to the county auditor of all substantial rehabilitations of historic property made in the county which receive a tax exemption under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and shall submit a copy or summary of the record to the state historic preservation officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax exemption granted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is valid if the property continues to be certified by the state historic preservation officer. If the property is sold or transferred, the buyer or transferee is not required to refile for the tax exemption for the year in which the property is purchased or transferred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The valuation for purposes of computing the assessed valuation of property under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ following the four-year exemption period is as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the first year after the expiration of the four-year exemption period, the valuation is the base year valuation plus twenty-five percent of the adjustment in value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the second year after the expiration of the four-year exemption period, the valuation is the base year valuation plus fifty percent of the adjustment in value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the third year after the expiration of the four-year exemption period, the valuation is the base year valuation plus seventy-five percent of the adjustment in value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the fourth year after the expiration of the four-year exemption period, the valuation is based upon the current fair cash value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An additional application for a tax exemption under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for substantial rehabilitation shall not affect }}}{{\f5\fs18\hyphpar0\qj{subsection 11}}}{{\f5\fs18\hyphpar0\qj{ and under }}}{{\f5\fs18\hyphpar0\qj{subsection 13}}}{{\f5\fs18\hyphpar0\qj{ the increase in assessed value of the historic property following a four-year tax exemption period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The economic development authority shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1160, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 150, \'a715, 26}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71420, 2120}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715.121}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.17}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.18}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Token tax liability accrues.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If property which may be exempt from taxation is acquired after July 1 by a person or the state or any of its political subdivisions, the exemption shall not be allowed for that fiscal year and the person or the state or any of its political subdivisions shall pay the property taxes levied against the property for that fiscal year, and payable in the following fiscal year. However, the seller and the purchaser may designate, by written agreement, the party responsible for payment of the property taxes due.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7427.18}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7445.28}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{427.19}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemptions eligibility \u8212\'3f prorating.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All credits for and exemptions from property taxes for which an application is required shall be granted on the basis of eligibility in the fiscal year for which the application is filed. If the property which has received a credit or exemption becomes ineligible for the credit or exemption during the fiscal year for which it was granted, the property is subject to the taxes in a prorated amount for that part of the fiscal year for which the property was ineligible for the credit or exemption.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{C81, \'a7427.19}}}{]}\par}}