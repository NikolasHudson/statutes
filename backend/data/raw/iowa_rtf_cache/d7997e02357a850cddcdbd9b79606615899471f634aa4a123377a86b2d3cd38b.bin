}}{{\f5\fs18\hyphpar0\qj{chapter 123}}}{{\f5\fs18\hyphpar0\qj{ and controlled substances as defined in }}}{{\f5\fs18\hyphpar0\qj{section 124.101}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChief medical officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the medical director in charge of a public or private hospital, or the director\u8217\'3fs physician-designee. }}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ does not negate the authority otherwise reposed by }}}{{\f5\fs18\hyphpar0\qj{chapter 226}}}{{\f5\fs18\hyphpar0\qj{ in the respective superintendents of the state mental health institutes to make decisions regarding the appropriateness of admissions or discharges of patients of those institutes, however, it is the intent of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ that a superintendent who is not a licensed physician shall be guided in these decisions by the chief medical officer of the institute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClerk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the clerk of the district court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFacility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an institution, a detoxification center, or an installation providing care, maintenance and treatment for persons with a substance use disorder licensed by the department under }}}{{\f5\fs18\hyphpar0\qj{section 125.13}}}{{\f5\fs18\hyphpar0\qj{, hospitals licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{{\f5\fs18\hyphpar0\qj{, or the state mental health institutes designated by }}}{{\f5\fs18\hyphpar0\qj{chapter 226}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIncapacitated by a chemical substance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that a person, as a result of the use of a chemical substance, is unconscious or has the person\u8217\'3fs judgment otherwise so impaired that the person is incapable of realizing and making a rational decision with respect to the need for treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInterested person\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who, in the discretion of the court, is legitimately concerned that a respondent receive substance use disorder treatment services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMagistrate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4, subsection 10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMental health professional\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 228.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPsychiatric advanced registered nurse practitioner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual currently licensed as a registered nurse under }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{152E}}}{{\f5\fs18\hyphpar0\qj{ who holds a national certification in psychiatric mental health care and who is licensed by the board of nursing as an advanced registered nurse practitioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRespondent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person against whom an application is filed under }}}{{\f5\fs18\hyphpar0\qj{section 125.75}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSubstance use disorder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a diagnosable substance use disorder of sufficient duration to meet diagnostic criteria specified within the most current diagnostic and statistical manual of mental disorders published by the American psychiatric association that results in a functional impairment. }}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, \'a7123A.1; C71, 73, \'a7123A.1, 123B.1; C75, 77, \'a7125.2; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.2}}}{, }{{\f5\fs18\hyphpar0\qj{229.50}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 58, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5