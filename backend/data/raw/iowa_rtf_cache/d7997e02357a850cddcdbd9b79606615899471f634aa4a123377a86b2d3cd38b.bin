\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E2_2E2}{INVOLUNTARY COMMITMENT OR TREATMENT FOR SUBSTANCE USE DISORDERS}{\*\bkmkend stylerid1_2E8_2E2_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.74}}}{\*\bkmkstart stylerid1_2E8_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Preapplication screening assessment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Prior to filing an application pursuant to }{{\f5\fs18\hyphpar0\qj{section 125.75}}}{, the clerk of the district court or the clerk\u8217\'3fs designee shall inform the interested person referred to in }{{\f5\fs18\hyphpar0\qj{section 125.75}}}{ about the option of requesting a preapplication screening assessment through a preapplication screening assessment program, if available. The state court administrator shall prescribe practices and procedures for implementation of the preapplication screening assessment program.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 130, \'a736}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.75}}}{{\f5\fs12\hyphpar0\qj{, 602.1209}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.75}}}{\*\bkmkstart stylerid1_2E8_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Proceedings for the involuntary commitment or treatment of a person with a substance use disorder to a facility pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or for the involuntary hospitalization of a person pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 229}}}{{\f5\fs18\hyphpar0\qj{ may be commenced by any interested person by filing a verified application with the clerk of a district court.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the verified application was filed in a district court of a county where the respondent is not located and does not reside, the court shall transfer jurisdiction of the case to the district court of the county where the respondent is presently located or which is the respondent\u8217\'3fs place of residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk, or the clerk\u8217\'3fs designee, shall assist an applicant in completing the verified application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application shall:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State the applicant\u8217\'3fs belief that the respondent is a person who presents a danger to self or others and lacks judgmental capacity due to either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A substance use disorder as defined in }}}{{\f5\fs18\hyphpar0\qj{section 125.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A serious mental impairment as defined in }}}{{\f5\fs18\hyphpar0\qj{section 229.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State facts in support of each belief described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Be accompanied by one or more of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written statement of a licensed physician and surgeon or osteopathic physician and surgeon or mental health professional in support of the application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One or more supporting affidavits corroborating the application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Corroborative information obtained and reduced to writing by the clerk or the clerk\u8217\'3fs designee, but only when circumstances make it infeasible to obtain, or when the clerk considers it appropriate to supplement, the information under either subparagraph (1) or (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to the filing of an application pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the clerk or the clerk\u8217\'3fs designee shall inform the interested person referred to in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ about the option of requesting a preapplication screening assessment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 125.74}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The supreme court shall prescribe rules and establish forms as necessary to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.19(1, 2); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7229.51}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1085, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a742, 43, 62}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 130, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 34, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7113, 114}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 95, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.2}}}{{\f5\fs12\hyphpar0\qj{, 125.44}}}{{\f5\fs12\hyphpar0\qj{, 125.74}}}{{\f5\fs12\hyphpar0\qj{, 125.75A}}}{{\f5\fs12\hyphpar0\qj{, 125.77}}}{{\f5\fs12\hyphpar0\qj{, 125.78}}}{{\f5\fs12\hyphpar0\qj{, 125.79}}}{{\f5\fs12\hyphpar0\qj{, 125.85}}}{{\f5\fs12\hyphpar0\qj{, 125.91}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}{{\f5\fs12\hyphpar0\qj{, 331.910}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Summary of involuntary commitment procedures available from clerk; see }{{\f5\fs12\hyphpar0\qj{\'a7229.45}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.75A}}}{\*\bkmkstart stylerid1_2E8_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Involuntary proceedings }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ minors }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The juvenile court has exclusive original jurisdiction in proceedings concerning a minor for whom an application is filed under }{{\f5\fs18\hyphpar0\qj{section 125.75}}}{. In proceedings under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ concerning a minor\u8217\'3fs involuntary commitment or treatment, the term }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcourt\u8221\'3f}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fjudge\u8221\'3f}}}{, or }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fclerk\u8221\'3f}}}{ means the juvenile court, judge, or clerk.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 283, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1124, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 130, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.75B}}}{\*\bkmkstart stylerid1_2E8_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Dual filings.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 130, \'a755}}}{{\f5\fs18\hyphpar0\qj{.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.76}}}{\*\bkmkstart stylerid1_2E8_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appointment of counsel for applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The applicant, if not the county attorney, may apply for the appointment of counsel if financially unable to employ an attorney to assist the applicant in presenting evidence in support of the application for commitment. If the applicant applies for the appointment of counsel, the application shall include the submission of a financial statement as required under }{{\f5\fs18\hyphpar0\qj{section 815.9}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.19(10); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7229.52(6)}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a74}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710044, 10201}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.77}}}{\*\bkmkstart stylerid1_2E8_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Service of notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the filing of an application pursuant to }{{\f5\fs18\hyphpar0\qj{section 125.75}}}{, the clerk shall docket the case and immediately notify a magistrate who is admitted to the practice of law in this state, who shall review the application and accompanying documentation. The clerk shall send copies of the application and supporting documentation, together with the notice informing the respondent of the procedures required by }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{, to the sheriff, for immediate service upon the respondent. If the respondent is taken into custody under }{{\f5\fs18\hyphpar0\qj{section 125.81}}}{, service of the application, documentation, and notice upon the respondent shall be made at the time the respondent is taken into custody.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.19(2); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7229.51(3)}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a75}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 108, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 130, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a737}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.84}}}{{\f5\fs12\hyphpar0\qj{, 125.85}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}{{\f5\fs12\hyphpar0\qj{, 229.45}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.78}}}{\*\bkmkstart stylerid1_2E8_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Procedure after application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As soon as practical after the filing of an application pursuant to }{{\f5\fs18\hyphpar0\qj{section 125.75}}}{, the court shall:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine whether the respondent has an attorney who is able and willing to represent the respondent in the commitment proceeding, and if not, whether the respondent is financially able to employ an attorney and capable of meaningfully assisting in selecting an attorney. In accordance with those determinations, the court shall allow the respondent to select an attorney or shall assign an attorney to the respondent. If the respondent is financially unable to pay an attorney, the county shall compensate the attorney at an hourly rate to be established by the county board of supervisors in substantially the same manner as provided in }}}{{\f5\fs18\hyphpar0\qj{section 815.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the application includes a request for a court-appointed attorney for the applicant and the court is satisfied that a court-appointed attorney is necessary to assist the applicant in a meaningful presentation of the evidence, and that the applicant is financially unable to employ an attorney, the court shall appoint an attorney to represent the applicant and the county shall compensate the attorney at an hourly rate to be established by the county board of supervisors in substantially the same manner as provided in }}}{{\f5\fs18\hyphpar0\qj{section 815.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issue a written order:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Scheduling a tentative time and place for a hearing, subject to the findings of the report required under }}}{{\f5\fs18\hyphpar0\qj{section 125.80, subsections 3 and 4}}}{{\f5\fs18\hyphpar0\qj{, but not less than forty-eight hours after notice to the respondent, unless the respondent waives the forty-eight-hour notice requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Requiring an examination of the respondent, prior to the hearing, by one or more licensed physicians and surgeons or osteopathic physicians and surgeons or mental health professionals who shall submit a written report of the examination to the court as required by }}}{{\f5\fs18\hyphpar0\qj{section 125.80}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.19(1, 2); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7229.51(2, 3)}}}{, }{{\f5\fs18\hyphpar0\qj{229.52(6)}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a76}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1219, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 135, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 130, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 34, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a742}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.79}}}{{\f5\fs12\hyphpar0\qj{, 125.85}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.79}}}{\*\bkmkstart stylerid1_2E8_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Respondent\u8217\'3fs attorney informed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The court shall direct the clerk to furnish at once to the respondent\u8217\'3fs attorney, copies of the application pursuant to }{{\f5\fs18\hyphpar0\qj{section 125.75}}}{ and the supporting documentation, and of the court\u8217\'3fs order issued pursuant to }{{\f5\fs18\hyphpar0\qj{section 125.78, subsection 3}}}{. If the respondent is taken into custody under }{{\f5\fs18\hyphpar0\qj{section 125.81}}}{, the attorney shall also be advised of that fact. The respondent\u8217\'3fs attorney shall represent the respondent at all stages of the proceedings and shall attend the commitment hearing.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a77}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2013 Acts, ch 130, \'a741}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.85}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.80}}}{\*\bkmkstart stylerid1_2E8_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Physician\u8217\'3fs or mental health professional\u8217\'3fs examination }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ report }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ scheduling of hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An examination of the respondent shall be conducted within a reasonable time and prior to the commitment hearing by one or more licensed physicians and surgeons or osteopathic physicians and surgeons or mental health professionals as required by the court\u8217\'3fs order. If the respondent is taken into custody under }}}{{\f5\fs18\hyphpar0\qj{section 125.81}}}{{\f5\fs18\hyphpar0\qj{, the examination shall be conducted within twenty-four hours after the respondent is taken into custody. If the respondent desires, the respondent may have a separate examination by a licensed physician and surgeon or osteopathic physician and surgeon or mental health professional of the respondent\u8217\'3fs own choice. The court shall notify the respondent of the right to choose a licensed physician and surgeon or osteopathic physician and surgeon or mental health professional for a separate examination. The reasonable cost of the examinations shall be paid from county funds upon order of the court if the respondent lacks sufficient funds to pay the cost.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensed physician and surgeon or osteopathic physician and surgeon or mental health professional conducting an examination pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may consult with or request the participation in the examination of facility personnel, and may include with or attach to the written report of the examination any findings or observations by facility personnel who have been consulted or have participated in the examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the respondent is not taken into custody under }}}{{\f5\fs18\hyphpar0\qj{section 125.81}}}{{\f5\fs18\hyphpar0\qj{, but the court is subsequently informed that the respondent has declined to be examined by a licensed physician and surgeon or osteopathic physician and surgeon or mental health professional pursuant to the court order, the court may order limited detention of the respondent as necessary to facilitate the examination of the respondent by the licensed physician and surgeon or osteopathic physician and surgeon or mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written report of the examination by a court-designated licensed physician and surgeon or osteopathic physician and surgeon or mental health professional shall be filed with the clerk prior to the hearing date. A written report of an examination by a licensed physician and surgeon or osteopathic physician and surgeon or mental health professional chosen by the respondent may be similarly filed. The clerk shall immediately:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cause a report to be shown to the judge who issued the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cause the respondent\u8217\'3fs attorney to receive a copy of the report of a court-designated licensed physician and surgeon or osteopathic physician and surgeon or mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the report of a court-designated licensed physician and surgeon or osteopathic physician and surgeon or mental health professional is to the effect that the respondent is not a person with a substance use disorder, the court, without taking further action, shall terminate the proceeding and dismiss the application on its own motion and without notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the report of a court-designated licensed physician and surgeon or osteopathic physician and surgeon or mental health professional is to the effect that the respondent is a person with a substance use disorder, the court shall schedule a commitment hearing as soon as possible. The hearing shall be held not more than forty-eight hours after the report is filed, excluding Saturdays, Sundays, and holidays, unless an extension for good cause is requested by the respondent, or as soon thereafter as possible if the court considers that sufficient grounds exist for delaying the hearing.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.19(1 \u8211\'3f 4); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7229.51}}}{, }{{\f5\fs18\hyphpar0\qj{229.52(1, 2)}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a78}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1085, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a744, 62}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 34, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1056, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7115}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.78}}}{{\f5\fs12\hyphpar0\qj{, 125.84}}}{{\f5\fs12\hyphpar0\qj{, 125.85}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.81}}}{\*\bkmkstart stylerid1_2E8_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Immediate custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person filing an application requests that a respondent be taken into immediate custody, and the court upon reviewing the application and accompanying documentation, finds probable cause to believe that the respondent is a person with a substance use disorder who is likely to injure the person or other persons if allowed to remain at liberty, the court may enter a written order directing that the respondent be taken into immediate custody by the sheriff, and be detained until the commitment hearing, which shall be held no more than five days after the date of the order, except that if the fifth day after the date of the order is a Saturday, Sunday, or a holiday, the hearing may be held on the next business day. The court may order the respondent detained for the period of time until the hearing is held, and no longer except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 125.88}}}{{\f5\fs18\hyphpar0\qj{, in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, if possible, and if not, then in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or, only if neither of these alternatives is available in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Detention may be:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the custody of a relative, friend, or other suitable person who is willing and able to accept responsibility for supervision of the respondent, with reasonable restrictions as the court may order including but not limited to restrictions on or a prohibition of any expenditure, encumbrance, or disposition of the respondent\u8217\'3fs funds or property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a suitable hospital, the chief medical officer of which shall be informed of the reasons why immediate custody has been ordered. The hospital may provide treatment which is necessary to preserve the respondent\u8217\'3fs life, or to appropriately control the respondent\u8217\'3fs behavior which is likely to result in physical injury to the person or to others if allowed to continue, and other treatment as deemed appropriate by the chief medical officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the nearest facility which is licensed to care for persons with mental illness or substance use disorder, provided that detention in a jail or other facility intended for confinement of those accused or convicted of a crime shall not be ordered.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A respondent shall be released from detention prior to the commitment hearing if a licensed physician or mental health professional examines the respondent and determines the respondent no longer meets the criteria for detention under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and provides notification to the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The respondent\u8217\'3fs attorney may be allowed by the court to present evidence and arguments before the court\u8217\'3fs determination under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. If such an opportunity is not provided at that time, respondent\u8217\'3fs attorney shall be allowed to present evidence and arguments after the issuance of the court\u8217\'3fs order of confinement and while the respondent is confined.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a79}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1085, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 108, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1072, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1165, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7187}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a745, 62}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1056, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7116, 117}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.44}}}{{\f5\fs12\hyphpar0\qj{, 125.77}}}{{\f5\fs12\hyphpar0\qj{, 125.79}}}{{\f5\fs12\hyphpar0\qj{, 125.80}}}{{\f5\fs12\hyphpar0\qj{, 125.82}}}{{\f5\fs12\hyphpar0\qj{, 125.84}}}{{\f5\fs12\hyphpar0\qj{, 125.87}}}{{\f5\fs12\hyphpar0\qj{, 125.88}}}{{\f5\fs12\hyphpar0\qj{, 125.91}}}{{\f5\fs12\hyphpar0\qj{, 125.92}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.82}}}{\*\bkmkstart stylerid1_2E8_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commitment hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At a commitment hearing, evidence in support of the contentions made in the application may be presented by the applicant, or by an attorney for the applicant, or by the county attorney. During the hearing, the applicant and the respondent shall be afforded an opportunity to testify and to present and cross-examine witnesses, and the court may receive the testimony of other interested persons. If the respondent is present at the hearing, as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and has been medicated within twelve hours, or a longer period of time as the court may designate, prior to the beginning of the hearing or a session of the hearing, the court shall be informed of that fact and of the probable effects of the medication upon convening of the hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person not necessary for the conduct of the hearing shall be excluded, except that the court may admit a person having a legitimate interest in the hearing. Upon motion of the applicant, the court may exclude the respondent from the hearing during the testimony of a witness if the court determines that the witness\u8217\'3f testimony is likely to cause the respondent severe emotional trauma.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person who filed the application and a licensed physician and surgeon or osteopathic physician and surgeon, mental health professional, or certified alcohol and drug counselor certified by the nongovernmental Iowa board of certification who has examined the respondent in connection with the commitment hearing shall be present at the hearing, unless the court for good cause finds that their presence or testimony is not necessary. The applicant, respondent, and the respondent\u8217\'3fs attorney may waive the presence, televised appearance, or telephonic appearance of the licensed physician and surgeon or osteopathic physician and surgeon, mental health professional, or certified alcohol and drug counselor who examined the respondent and agree to submit as evidence the written report of the licensed physician and surgeon or osteopathic physician and surgeon, mental health professional, or certified alcohol and drug counselor. The respondent\u8217\'3fs attorney shall inform the court if the respondent\u8217\'3fs attorney reasonably believes that the respondent, due to diminished capacity, cannot make an adequately considered waiver decision. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGood cause\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for finding that the testimony of the licensed physician and surgeon or osteopathic physician and surgeon, mental health professional, or certified alcohol and drug counselor who examined the respondent is not necessary may include but is not limited to such a waiver. If the court determines that the testimony of the licensed physician and surgeon or osteopathic physician and surgeon, mental health professional, or certified alcohol and drug counselor is necessary, the court may allow the licensed physician and surgeon or osteopathic physician and surgeon, mental health professional, or certified alcohol and drug counselor to testify by telephone or televised means. The respondent shall be present at the hearing unless prior to the hearing the respondent\u8217\'3fs attorney stipulates in writing that the attorney has conversed with the respondent, and that in the attorney\u8217\'3fs judgment the respondent cannot make a meaningful contribution to the hearing, or that the respondent has waived the right to be present, and the basis for the attorney\u8217\'3fs conclusions. A stipulation to the respondent\u8217\'3fs absence shall be reviewed by the court before the hearing, and may be rejected if it appears that insufficient grounds are stated or that the respondent\u8217\'3fs interests would not be served by the respondent\u8217\'3fs absence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The respondent\u8217\'3fs welfare is paramount, and the hearing shall be tried as a civil matter and conducted in as informal a manner as is consistent with orderly procedure. The hearing may be held by video or telephone conference at the discretion of the court. Discovery as permitted under the Iowa rules of civil procedure is available to the respondent. The court shall receive all relevant and material evidence, but the court is not bound by the rules of evidence. A presumption in favor of the respondent exists, and the burden of evidence and support of the contentions made in the application shall be upon the person who filed the application. If upon completion of the hearing the court finds that the contention that the respondent is a person with a substance use disorder has not been sustained by clear and convincing evidence, the court shall deny the application and terminate the proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the respondent is not taken into custody under }}}{{\f5\fs18\hyphpar0\qj{section 125.81}}}{{\f5\fs18\hyphpar0\qj{, but the court finds good cause to believe that the respondent is about to depart from the jurisdiction of the court, the court may order limited detention of the respondent as authorized in }}}{{\f5\fs18\hyphpar0\qj{section 125.81}}}{{\f5\fs18\hyphpar0\qj{, as is necessary to ensure that the respondent will not depart from the jurisdiction of the court without the court\u8217\'3fs approval until the proceeding relative to the respondent has been concluded.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.19(3-7, 10, 13); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7229.52(1)}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a710}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1085, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 108, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1115, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1116, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1159, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a746, 62}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 34, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1056, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7118}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 139, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.84}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}{{\f5\fs12\hyphpar0\qj{, 602.8103}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.83}}}{\*\bkmkstart stylerid1_2E8_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Placement for evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If upon completion of the commitment hearing, the court finds that the contention that the respondent is a person with a substance use disorder has been sustained by clear and convincing evidence, the court shall order the respondent placed at a facility or under the care of a suitable facility on an outpatient basis as expeditiously as possible for a complete evaluation and appropriate treatment. Any peace officer shall have the authority to take the respondent into custody in any county in which the respondent is found for placement at a facility or under the care of a suitable facility in accordance with an order entered pursuant to }{{\f5\fs18\hyphpar0\qj{this section}}}{. The court shall furnish to the facility at the time of admission or outpatient placement, a written statement of facts setting forth the evidence on which the finding is based. The administrator of the facility shall report to the court no more than fifteen days after the individual is admitted to or placed under the care of the facility, which shall include the chief medical officer\u8217\'3fs recommendation concerning treatment of a substance use disorder. An extension of time may be granted for a period not to exceed seven days upon a showing of good cause. A copy of the report shall be sent to the respondent\u8217\'3fs attorney who may contest the need for an extension of time if one is requested. If the request is contested, the court shall make an inquiry as it deems appropriate and may either order the respondent released from the facility or grant an extension of time for further evaluation. If the administrator fails to report to the court within fifteen days after the individual is admitted to the facility, and no extension of time has been requested, the administrator is guilty of contempt and shall be punished under }{{\f5\fs18\hyphpar0\qj{chapter 665}}}{. The court shall order a rehearing on the application to determine whether the respondent should continue to be held at the facility.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.19(4); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7229.52(2)}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a711}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1020, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1085, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a747, 62}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7119}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 95, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.84}}}{{\f5\fs12\hyphpar0\qj{, 125.85}}}{{\f5\fs12\hyphpar0\qj{, 125.87}}}{{\f5\fs12\hyphpar0\qj{, 125.88}}}{{\f5\fs12\hyphpar0\qj{, 125.89}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.83A}}}{\*\bkmkstart stylerid1_2E8_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Placement in certain federal facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If upon completion of the commitment hearing, the court finds that the contention that the respondent is a person with a substance use disorder has been sustained by clear and convincing evidence, and the court is furnished evidence that the respondent is eligible for care and treatment in a facility operated by the United States department of veterans affairs or another agency of the United States government and that the facility is willing to receive the respondent, the court may so order. The respondent, when so placed in a facility operated by the United States department of veterans affairs or another agency of the United States government within or outside of this state, shall be subject to the rules of the United States department of veterans affairs or other agency, but shall not lose any procedural rights afforded the respondent by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The chief officer of the facility shall have, with respect to the respondent so placed, the same powers and duties as the chief medical officer of a hospital in this state would have in regard to submission of reports to the court, retention of custody, transfer, convalescent leave, or discharge. Jurisdiction is retained in the court to maintain surveillance of the respondent\u8217\'3fs treatment and care, and at any time to inquire into the respondent\u8217\'3fs condition and the need for continued care and custody.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a certificate stating that a respondent placed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is eligible for care and treatment in a facility operated by the United States department of veterans affairs or another agency of the United States government which is willing to receive the respondent without charge to the state of Iowa or any county in the state, the chief medical officer may transfer the respondent to that facility. Upon so doing, the chief medical officer shall notify the court which ordered the respondent\u8217\'3fs placement in the same manner as would be required in the case of a transfer under }}}{{\f5\fs18\hyphpar0\qj{section 125.86, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and the respondent transferred shall be entitled to the same rights as the respondent would have under that subsection. No respondent shall be transferred under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ who is confined pursuant to conviction of a public offense or whose placement was ordered upon contention of incompetence to stand trial by reason of mental illness, without prior approval of the court which ordered that respondent\u8217\'3fs placement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A judgment or order of commitment by a court of competent jurisdiction of another state or the District of Columbia, under which any person is hospitalized or placed in a facility operated by the United States department of veterans affairs or another agency of the United States government, shall have the same force and effect with respect to that person while the person is in this state as the judgment or order would have if the person were in the jurisdiction of the court which issued it. That court shall be deemed to have retained jurisdiction of the person so placed for the purpose of inquiring into that person\u8217\'3fs condition and the need for continued care and custody, as do courts in this state under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Consent is given to the application of the law of the state or district in which the court is situated which issued the judgment or order as regards authority of the chief officer of any facility, operated in this state by the United States department of veterans affairs or another agency of the United States government, to retain custody, transfer, place on convalescent leave, or discharge the person so committed.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 159, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 26, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a748, 62}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7120}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.84}}}{\*\bkmkstart stylerid1_2E8_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Evaluation report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The facility administrator\u8217\'3fs report to the court of the chief medical officer\u8217\'3fs substance use disorder evaluation of the respondent shall be made no later than the expiration of the time specified in }{{\f5\fs18\hyphpar0\qj{section 125.83}}}{. At least two copies of the report shall be filed with the clerk, who shall distribute the copies in the manner described by }{{\f5\fs18\hyphpar0\qj{section 125.80, subsection 2}}}{. The report shall state one of the four following alternative findings:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the respondent does not, as of the date of the report, require further treatment for substance use disorder. If the report so states, the court shall order the respondent\u8217\'3fs immediate release from involuntary commitment and terminate the proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the respondent is a person with a substance use disorder who is in need of full-time custody, care, and treatment in a facility, and is considered likely to benefit from treatment. If the report so states, the court shall enter an order which may require the respondent\u8217\'3fs continued placement and commitment to a facility for appropriate treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the respondent is a person with a substance use disorder who is in need of treatment, but does not require full-time placement in a facility. If the report so states, the report shall include the chief medical officer\u8217\'3fs recommendation for treatment of the respondent on an outpatient or other appropriate basis, and the court shall enter an order which may direct the respondent to submit to the recommended treatment. The order shall provide that if the respondent fails or refuses to submit to treatment, as directed by the court\u8217\'3fs order, the court may order that the respondent be taken into immediate custody as provided by }}}{{\f5\fs18\hyphpar0\qj{section 125.81}}}{{\f5\fs18\hyphpar0\qj{ and, following notice and hearing held in accordance with the procedures of }}}{{\f5\fs18\hyphpar0\qj{sections 125.77}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{125.82}}}{{\f5\fs18\hyphpar0\qj{, may order the respondent treated as a patient requiring full-time custody, care, and treatment as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and may order the respondent involuntarily committed to a facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the respondent is a person with a substance use disorder who is in need of treatment, but in the opinion of the chief medical officer is not responding to the treatment provided. If the report so states, the report shall include the facility administrator\u8217\'3fs recommendation for alternative placement, and the court shall enter an order which may direct the respondent\u8217\'3fs transfer to the recommended placement or to another placement after consultation with the respondent\u8217\'3fs attorney and the facility administrator who made the report under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a712}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1020, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1085, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a749, 62}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7121}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.85}}}{{\f5\fs12\hyphpar0\qj{, 125.86}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}{{\f5\fs12\hyphpar0\qj{, 321J.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.85}}}{\*\bkmkstart stylerid1_2E8_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Custody, discharge, and termination of proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A respondent committed under }}}{{\f5\fs18\hyphpar0\qj{section 125.84, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall remain in the custody of a facility for treatment for a period of thirty days, unless sooner discharged. The department is not required to pay the cost of any medication or procedure provided to the respondent during that period which is not necessary or appropriate to the specific objectives of detoxification and treatment of substance use disorder. At the end of the thirty-day period, the respondent shall be discharged automatically unless the administrator of the facility, before expiration of the period, obtains a court order for the respondent\u8217\'3fs recommitment pursuant to an application under }}}{{\f5\fs18\hyphpar0\qj{section 125.75}}}{{\f5\fs18\hyphpar0\qj{, for a further period not to exceed ninety days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A respondent recommitted under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ who has not been discharged by the facility before the end of the ninety-day period shall be discharged at the expiration of that period unless the administrator of the facility, before expiration of the period, obtains a court order for the respondent\u8217\'3fs recommitment pursuant to an application under }}}{{\f5\fs18\hyphpar0\qj{section 125.75}}}{{\f5\fs18\hyphpar0\qj{, for a further period not to exceed ninety days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of an application for recommitment under }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{, the court shall schedule a recommitment hearing for no later than ten days after the date the application is filed. A copy of the application, the notice of hearing, and any reports shall be served or provided in the manner and to the persons as required by }}}{{\f5\fs18\hyphpar0\qj{sections 125.77 through 125.80}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{125.83}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{125.84}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Following a respondent\u8217\'3fs discharge from a facility or from treatment, the administrator of the facility shall immediately report that fact to the court which ordered the respondent\u8217\'3fs commitment or treatment. The court shall issue an order confirming the respondent\u8217\'3fs discharge from the facility or from treatment, as the case may be, and shall terminate the proceedings pursuant to which the order was issued. Copies of the order shall be sent by regular mail to the facility and the respondent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is placed for evaluation at a facility under }}}{{\f5\fs18\hyphpar0\qj{section 125.83}}}{{\f5\fs18\hyphpar0\qj{ or who is committed to a facility under }}}{{\f5\fs18\hyphpar0\qj{section 125.84, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall remain at that facility unless discharged or otherwise permitted to leave by the court or administrator of the facility. If a person placed at a facility or committed to a facility leaves the facility without permission or without having been discharged, the administrator may notify the sheriff of the person\u8217\'3fs absence and the sheriff shall take the person into custody and return the person promptly to the facility.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.19; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7229.52(3 \u8211\'3f 5)}}}{, }{{\f5\fs18\hyphpar0\qj{229.53}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a713}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1072, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 144, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7122}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.86}}}{\*\bkmkstart stylerid1_2E8_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Periodic reports required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No more than thirty days after entry of a court order for commitment to a facility under }}}{{\f5\fs18\hyphpar0\qj{section 125.84, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and thereafter at successive intervals not to exceed ninety days for as long as involuntary commitment of the respondent continues, the administrator of the facility shall report to the court which entered the order. The report shall be submitted in the manner required by }}}{{\f5\fs18\hyphpar0\qj{section 125.84}}}{{\f5\fs18\hyphpar0\qj{, shall state whether in the opinion of the chief medical officer the respondent\u8217\'3fs condition has improved, remains unchanged, or has deteriorated, and shall indicate the further length of time the respondent will be required to remain at the facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No more than sixty days after entry of a court order for treatment of a respondent under }}}{{\f5\fs18\hyphpar0\qj{section 125.84, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and thereafter at successive intervals not to exceed ninety days for as long as involuntary treatment continues, the administrator of the facility or the psychiatrist or psychiatric advanced registered nurse practitioner treating the patient shall report to the court which entered the order. The report shall be submitted in the manner required by }}}{{\f5\fs18\hyphpar0\qj{section 125.84}}}{{\f5\fs18\hyphpar0\qj{, shall state whether in the opinion of the chief medical officer or the psychiatrist or psychiatric advanced registered nurse practitioner the respondent\u8217\'3fs condition has improved, remains unchanged, or has deteriorated, and shall indicate the further length of time the respondent will require treatment by the facility. If the respondent fails or refuses to submit to treatment as ordered by the court, the administrator of the facility shall at once notify the court, which shall order the respondent committed for treatment as provided by }}}{{\f5\fs18\hyphpar0\qj{section 125.84, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, unless the court finds that the failure or refusal was with good cause, and that the respondent is willing to receive treatment as provided in the court\u8217\'3fs order, or in a revised order if the court sees fit to enter one. If the administrator of the facility reports to the court that the respondent requires full-time custody, care, and treatment in a facility, and the respondent is willing to be admitted voluntarily to the facility for these purposes, the court may enter an order approving the placement upon consultation with the administrator of the facility in which the respondent is to be placed. If the respondent is unwilling to be admitted voluntarily to the facility, the procedure for determining involuntary commitment, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 125.84, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, shall be followed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A psychiatric advanced registered nurse practitioner treating a respondent previously committed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may complete periodic reports pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on the respondent if the respondent has been recommended for treatment on an outpatient or other appropriate basis pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 125.84, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and if a psychiatrist licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ personally evaluates the respondent on at least an annual basis.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An advanced registered nurse practitioner who is not certified as a psychiatric advanced registered nurse practitioner but who meets the qualifications of a mental health professional may complete periodic reports pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a714}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1082, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 90, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 34, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.83A}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}{{\f5\fs12\hyphpar0\qj{, 321J.3}}}{{\f5\fs12\hyphpar0\qj{, 462A.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.87}}}{\*\bkmkstart stylerid1_2E8_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Status during appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a respondent appeals to the supreme court from a lower court\u8217\'3fs finding that commitment is warranted, the respondent shall remain committed if already in custody, pursuant to an order of immediate custody under }{{\f5\fs18\hyphpar0\qj{section 125.81}}}{ or pursuant to an order for evaluation and treatment under }{{\f5\fs18\hyphpar0\qj{section 125.83}}}{, before notice of appeal was filed, unless the supreme court orders otherwise.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a715}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.88}}}{\*\bkmkstart stylerid1_2E8_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Status if commitment delayed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a court directs a respondent who was previously ordered taken into immediate custody under }{{\f5\fs18\hyphpar0\qj{section 125.81}}}{ to be placed at a facility for evaluation and appropriate treatment under }{{\f5\fs18\hyphpar0\qj{section 125.83}}}{, and no suitable facility can immediately admit the respondent, the respondent shall remain in custody as previously ordered by the court, notwithstanding the time limits stated in }{{\f5\fs18\hyphpar0\qj{section 125.81}}}{, until a suitable facility can admit the respondent. The court shall take appropriate steps to expedite the admission of the respondent to a suitable facility at the earliest feasible time.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a716}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.81}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.89}}}{\*\bkmkstart stylerid1_2E8_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Respondents charged with or convicted of crime.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a court orders a respondent placed at a facility for evaluation and treatment under }}}{{\f5\fs18\hyphpar0\qj{section 125.83}}}{{\f5\fs18\hyphpar0\qj{ at a time when the respondent has been convicted of a public offense, or when there is pending against the respondent an unresolved formal charge of a public offense, and the respondent\u8217\'3fs liberty has therefore been restricted in any manner, the findings of fact required by }}}{{\f5\fs18\hyphpar0\qj{section 125.83}}}{{\f5\fs18\hyphpar0\qj{ shall clearly so inform the administrator of the facility where the respondent is placed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commitment powers of the court under }}}{{\f5\fs18\hyphpar0\qj{section 124.409}}}{{\f5\fs18\hyphpar0\qj{ supersede the procedures and requirements of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a717}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.90}}}{\*\bkmkstart stylerid1_2E8_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judicial hospitalization referee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Judicial hospitalization referees shall be utilized as provided in }{{\f5\fs18\hyphpar0\qj{section 229.21}}}{ for performing the duties of the court prescribed by }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7229.51(3)}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a718}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.91}}}{\*\bkmkstart stylerid1_2E8_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Emergency detention.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The procedure prescribed by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall only be used for a person with a substance use disorder due to intoxication or substance-induced incapacitation who has threatened, attempted, or inflicted physical self-harm or harm on another, and is likely to inflict physical self-harm or harm on another unless immediately detained, or who is incapacitated by a chemical substance, if an application has not been filed naming the person as the respondent pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 125.75}}}{{\f5\fs18\hyphpar0\qj{ and the person cannot be ordered into immediate custody and detained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 125.81}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A peace officer who has reasonable grounds to believe that the circumstances described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ are applicable may, without a warrant, take or cause that person to be taken to the nearest available facility referred to in }}}{{\f5\fs18\hyphpar0\qj{section 125.81, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. Such a person with a substance use disorder due to intoxication or substance-induced incapacitation who also demonstrates a significant degree of distress or dysfunction may also be delivered to a facility by someone other than a peace officer upon a showing of reasonable grounds. Upon delivery of the person to a facility under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the attending physician and surgeon or osteopathic physician and surgeon may order treatment of the person, but only to the extent necessary to preserve the person\u8217\'3fs life or to appropriately control the person\u8217\'3fs behavior if the behavior is likely to result in physical injury to the person or others if allowed to continue. The peace officer or other person who delivered the person to the facility shall describe the circumstances of the matter to the attending physician and surgeon or osteopathic physician and surgeon. If the person is a peace officer, the peace officer may do so either in person or by written report.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the attending physician and surgeon or osteopathic physician and surgeon has reasonable grounds to believe that the circumstances in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ are applicable, the facility shall have the authority to detain the person for a period of no longer than twelve hours. Within twelve hours of detaining a person pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the attending physician shall communicate with the nearest available magistrate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once contacted pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the magistrate shall, based upon the circumstances described by the attending physician and surgeon or osteopathic physician and surgeon, give the attending physician and surgeon or osteopathic physician and surgeon oral instructions either directing that the person be released forthwith, or authorizing the person\u8217\'3fs detention in an appropriate facility. The magistrate may also give oral instructions and order that the detained person be transported to an appropriate facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the magistrate orders that the person be detained, the magistrate shall, by the close of business on the next working day, file a written order with the clerk in the county where it is anticipated that an application may be filed under }}}{{\f5\fs18\hyphpar0\qj{section 125.75}}}{{\f5\fs18\hyphpar0\qj{. The order may be filed by facsimile if necessary. The order shall state the circumstances under which the person was taken into custody or otherwise brought to a facility and the grounds supporting the finding of probable cause to believe that the person is a person with a substance use disorder likely to result in physical injury to the person or others if not detained. The order shall confirm the oral order authorizing the person\u8217\'3fs detention including any order given to transport the person to an appropriate facility. The clerk shall provide a copy of that order to the attending physician and surgeon or osteopathic physician and surgeon at the facility to which the person was originally taken, any subsequent facility to which the person was transported, and to any law enforcement department or ambulance service that transported the person pursuant to the magistrate\u8217\'3fs order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attending physician and surgeon or osteopathic physician and surgeon shall examine and may detain the person pursuant to the magistrate\u8217\'3fs order for a period not to exceed forty-eight hours from the time the order is dated, excluding Saturdays, Sundays, and holidays, unless the order is dismissed by a magistrate. The facility may provide treatment which is necessary to preserve the person\u8217\'3fs life or to appropriately control the person\u8217\'3fs behavior if the behavior is likely to result in physical injury to the person or others if allowed to continue or is otherwise deemed medically necessary by the attending physician and surgeon or osteopathic physician and surgeon or mental health professional, but shall not otherwise provide treatment to the person without the person\u8217\'3fs consent. The person shall be discharged from the facility and released from detention no later than the expiration of the forty-eight-hour period, unless an application for involuntary commitment is filed with the clerk pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 125.75}}}{{\f5\fs18\hyphpar0\qj{. The detention of a person by the procedure in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and not in excess of the period of time prescribed by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall not render the peace officer, attending physician and surgeon or osteopathic physician and surgeon, or facility detaining the person liable in a criminal or civil action for false arrest or false imprisonment if the peace officer, attending physician and surgeon or osteopathic physician and surgeon, mental health professional, or facility had reasonable grounds to believe that the circumstances described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ were applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cost of detention in a facility under the procedure prescribed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be paid in the same way as if the person had been committed to the facility pursuant to an application filed under }}}{{\f5\fs18\hyphpar0\qj{section 125.75}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.17, 125.18; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.34(4)}}}{, }{{\f5\fs18\hyphpar0\qj{125.35}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a719}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1085, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 68, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7188}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a750, 62}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1021, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1079, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 34, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1071, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7123}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a719, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.44}}}{{\f5\fs12\hyphpar0\qj{, 125.92}}}{{\f5\fs12\hyphpar0\qj{, 229.21}}}{{\f5\fs12\hyphpar0\qj{, 331.910}}}{{\f5\fs12\hyphpar0\qj{, 602.6405}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.92}}}{\*\bkmkstart stylerid1_2E8_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rights and privileges of committed persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person who is detained, taken into immediate custody, or committed under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ has the right to:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prompt evaluation, emergency services, and care and treatment as indicated by sound clinical practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Render informed consent, except for treatment provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 125.81}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{125.91}}}{{\f5\fs18\hyphpar0\qj{. If the person is incompetent, treatment may be consented to by the person\u8217\'3fs next of kin or guardian notwithstanding the person\u8217\'3fs refusal. If the person refuses treatment which in the opinion of the chief medical officer is necessary, or if the person is incompetent and the next of kin or guardian refuses to consent to the treatment or no next of kin or guardian is available, the facility may petition a court of appropriate jurisdiction for approval to treat the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The protection of the person\u8217\'3fs constitutional rights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enjoy all legal, medical, religious, social, political, personal, and working rights and privileges, which the person would enjoy if not detained, taken into immediate custody, or committed, consistent with the effective treatment of the person and of the other persons in the facility. If the person\u8217\'3fs rights are restricted, the physician and surgeon\u8217\'3fs or osteopathic physician and surgeon\u8217\'3fs or mental health professional\u8217\'3fs direction to that effect shall be noted in the person\u8217\'3fs record. The person or the person\u8217\'3fs next of kin or guardian shall be advised of the person\u8217\'3fs rights and be provided a written copy upon the person\u8217\'3fs admission to or arrival at the facility.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a720}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 34, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1032, \'a734}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.93}}}{\*\bkmkstart stylerid1_2E8_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Commitment records }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ confidentiality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Records of the identity, diagnosis, prognosis, or treatment of a person which are maintained in connection with the provision of substance use disorder treatment services are confidential, consistent with federal confidentiality regulations authorized by the federal }{{\f5\fs18\hyphpar0\qj{Comprehensive Alcohol Abuse and Alcoholism Prevention, Treatment and Rehabilitation Act}}}{, }{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a7290dd-2}}}{. However, such records may be disclosed to an employee of the department of corrections, if authorized by the director of the department of corrections.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a721}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2014 Acts, ch 1092, \'a7168}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 11, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7124}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a720, 137}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a748}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment by 2024 Acts, ch 1161, effective July 1, 2025; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1161, \'a7137}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.94}}}{\*\bkmkstart stylerid1_2E8_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supreme court rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The supreme court may prescribe rules of pleading, practice, and procedure and the forms of process, writs, and notices under }{{\f5\fs18\hyphpar0\qj{section 602.4201}}}{, for all commitment proceedings in a court of this state under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The rules shall be drawn for the purpose of simplifying and expediting the proceedings, so far as is consistent with the rights of the parties involved. The rules shall not abridge, enlarge, or modify the substantive rights of a party to a commitment proceeding under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1212, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710045, 10201}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229.21}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Rules adopted by the supreme court are published in the compilation \u8220\'3fIowa Court Rules\u8221\'3f}\par}}