0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.12}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Comprehensive program for treatment \u8212\'3f regional facilities.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7135, 137}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 repeal effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.13}}}{\*\bkmkstart stylerid1_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Programs licensed \u8212\'3f exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a person shall not maintain or conduct any chemical substitutes or antagonists program, residential program, or nonresidential outpatient program, the primary purpose of which is the treatment and rehabilitation of persons with a substance use disorder without having first obtained a written license for the program from the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Four types of licenses may be issued by the department. A renewable license may be issued for one, two, or three years. A treatment program applying for its initial license may be issued a license for two hundred seventy days. A license issued for two hundred seventy days shall not be renewed or extended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensing requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ do not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hospital providing care or treatment to persons with a substance use disorder licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{{\f5\fs18\hyphpar0\qj{ which is accredited by the joint commission, the commission on accreditation of rehabilitation facilities, the American osteopathic association, or another recognized organization approved by the department. All survey reports from the accrediting or licensing body must be sent to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any practitioner of medicine and surgery or osteopathic medicine and surgery, in the practitioner\u8217\'3fs private practice. However, a program shall not be exempted from licensing by the department by virtue of its utilization of the services of a medical practitioner in its operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Private institutions conducted by and for persons who adhere to the faith of any well recognized church or religious denomination for the purpose of providing care, treatment, counseling, or rehabilitation to persons with a substance use disorder and who rely solely on prayer or other spiritual means for healing in the practice of religion of such church or denomination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A program that provides only education, prevention, referral, or post treatment services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Alcoholics anonymous.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals in private practice who are providing substance use disorder treatment services independent from a program that is required to be licensed under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Intervention and referral programs which are financed and managed by a county or counties, are staffed by county employees, and do not receive state payments pursuant to a contract under }}}{{\f5\fs18\hyphpar0\qj{section 125.44}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Voluntary, nonprofit groups whose funding is provided solely from nontax sources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A substance use disorder treatment program not funded by the department which is accredited or licensed by the joint commission, the commission on the accreditation of rehabilitation facilities, the American osteopathic association, or another recognized organization approved by the department. All survey reports from the accrediting or licensing body must be sent to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hospital substance use disorder treatment program that is accredited or licensed by the joint commission, the commission on the accreditation of rehabilitation facilities, the American osteopathic association, or another recognized organization approved by the department. All survey reports for the hospital substance use disorder treatment program from the accrediting or licensing body shall be sent to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A psychiatric medical institution for children licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 135H}}}{{\f5\fs18\hyphpar0\qj{, unless the psychiatric medical institution for children provides substance use disorder services.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.14, 224B.12, 224B.13; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.13}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 58, \'a74 \u8211\'3f 7}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1244, \'a71, 2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1001, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 243, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1085, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1068, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1108, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 175, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a732, 33, 62}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a785, 86}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7377}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 86, \'a71, 48}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7125.2}}}{{\f5\fs12\hyphpar0\qj{, 125.20}}}{{\f5\fs12\hyphpar0\qj{, 125.21}}}{{\f5\fs12\hyphpar0\qj{, 135H.4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraphs a, i, and j amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, NEW paragraph k}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.14}}}{\*\bkmkstart stylerid1_2E7_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licenses }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ renewal }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall consider all cases involving initial issuance, and renewal, denial, suspension, or revocation of a license. The department shall issue a license to an applicant whom the department determines meets the licensing requirements of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. Licenses shall expire no later than three years from the date of issuance and shall be renewed upon timely application made in the same manner as for initial issuance of a license unless notice of nonrenewal is given to the licensee at least thirty days prior to the expiration of the license. The department shall not charge a fee for licensing or renewal of programs contracting with the department for provision of treatment services. A fee may be charged to other licensees.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7224B.14, 224B.15; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.14}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 58, \'a78}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 243, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1140, \'a719}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1108, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 175, \'a767}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7378}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7144}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.14A}}}{\*\bkmkstart stylerid1_2E7_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Personnel of a licensed program admitting juveniles.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person is being considered for licensure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or for employment involving direct responsibility for a child or with access to a child when the child is alone, by a program admitting juveniles subject to licensure under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or if a person will reside in a facility utilized by such a program, and if the person has been convicted of a crime or has a record of founded child abuse, the record check evaluation system of the department and the program for an employee of the program shall perform an evaluation to determine whether the crime or founded child abuse warrants prohibition of licensure, employment, or residence in the facility. The record check evaluation system shall conduct criminal and child abuse record checks in this state and may conduct these checks in other states. The evaluation shall be performed in accordance with procedures adopted for this purpose by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the record check evaluation system determines that a person has committed a crime or has a record of founded child abuse and is licensed, employed by a program licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or resides in a licensed facility the record check evaluation system shall notify the program that an evaluation will be conducted to determine whether prohibition of the person\u8217\'3fs licensure, employment, or residence is warranted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In an evaluation, the record check evaluation system and the program for an employee of the program shall consider the nature and seriousness of the crime or founded child abuse in relation to the position sought or held, the time elapsed since the commission of the crime or founded child abuse, the circumstances under which the crime or founded child abuse was committed, the degree of rehabilitation, the likelihood that the person will commit the crime or founded child abuse again, and the number of crimes or founded child abuses committed by the person involved. The record check evaluation system may permit a person who is evaluated to be licensed, employed, or to reside, or to continue to be licensed, employed, or to reside in a program, if the person complies with the record check evaluation system\u8217\'3fs conditions relating to the person\u8217\'3fs licensure, employment, or residence, which may include completion of additional training. For an employee of a licensee, these conditional requirements shall be developed with the licensee. The record check evaluation system has final authority in determining whether prohibition of the person\u8217\'3fs licensure, employment, or residence is warranted and in developing any conditional requirements under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the record check evaluation system determines that the person has committed a crime or has a record of founded child abuse which warrants prohibition of licensure, employment, or residence, the person shall not be licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to operate a program admitting juveniles and shall not be employed by a program or reside in a facility admitting juveniles licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the record checks required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the record check evaluation system may conduct dependent adult abuse record checks in this state and may conduct these checks in other states, on a random basis. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, relative to an evaluation following a determination that a person has been convicted of a crime or has a record of founded child abuse, shall also apply to a random check conducted under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A program or facility shall inform all new applicants for employment of the possibility of the performance of a record check and shall obtain, from the applicant, a signed acknowledgment of the receipt of the information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A program or facility shall include the following inquiry in an application for employment:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Do you have a record of founded child or dependent adult abuse or have you ever been convicted of a crime, in this state or any other state?}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1221, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 138, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1163, \'a733}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1130, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a788}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.15}}}{\*\bkmkstart stylerid1_2E7_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may inspect the facilities and review the procedures utilized by any chemical substitutes or antagonists program, residential program, or nonresidential outpatient program that has as a primary purpose the treatment and rehabilitation of persons with a substance use disorder, for the purpose of ensuring compliance with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and the rules adopted pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The examination and review may include case record audits and interviews with staff and patients, consistent with the confidentiality safeguards of state and federal law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7224B.16; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71130}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1140, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a734, 62}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a789}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.15A}}}{\*\bkmkstart stylerid1_2E7_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Licensure \u8212\'3f emergencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may place an employee or agent to serve as a monitor in a licensed substance use disorder treatment program or may petition the court for appointment of a receiver for a program when any of the following conditions exist:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The program is operating without a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department has suspended, revoked, or refused to renew the existing license of the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The program is closing or has informed the department that it intends to close and adequate arrangements for the location of clients have not been made at least thirty days before the closing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department determines that an emergency exists, whether or not it has initiated revocation or nonrenewal procedures, and because of the unwillingness or inability of the licensee to remedy the emergency, the department determines that a monitor or receiver is necessary. As used in this paragraph, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femergency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a threat to the health, safety, or welfare of a client that the program is unwilling or unable to correct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The monitor shall observe operation of the program, assist the program with advice regarding compliance with state regulations, and report periodically to the department on the operation of the program.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 139, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 175, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a790, 91}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7379}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7145}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.16}}}{\*\bkmkstart stylerid1_2E7_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Transfer of license or change of location prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A license issued under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may not be transferred, and the location of the physical facilities occupied or utilized by any program licensed under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall not be changed without the prior written consent of the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7224B.17; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.16}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 175, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7380}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7146}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.17}}}{\*\bkmkstart stylerid1_2E7_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License suspension or revocation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Violation of any of the requirements or restrictions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or of any of the rules adopted pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is cause for suspension, revocation, or refusal to renew a license. The director shall at the earliest time feasible notify a licensee whose license the department is considering suspending or revoking and shall inform the licensee what changes must be made in the licensee\u8217\'3fs operation to avoid such action. The licensee shall be given a reasonable time for compliance, as determined by the director, after receiving such notice or a notice that the department does not intend to renew the license. When the licensee believes compliance has been achieved, or if the licensee considers the proposed suspension, revocation, or refusal to renew unjustified, the licensee may submit pertinent information to the department and the department shall expeditiously make a decision in the matter and notify the licensee of the decision.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7224B.18; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 175, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7381}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7147}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.18}}}{\*\bkmkstart stylerid1_2E7_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applications }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ approval or denial }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ disciplinary actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may deny an application for license, or may place on probation, suspend or revoke a license of, or otherwise discipline a licensee if the department finds that the licensee has not been or will not be operated in compliance with }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and the rules adopted pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, or that there is insufficient assurance of adequate protection for the public. The authorization denial or period of probation, suspension, or revocation, or other disciplinary action shall be effected and may be appealed as provided by }{{\f5\fs18\hyphpar0\qj{section 17A.12}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7224B.19; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.18}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71131}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 175, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a794, 1879}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7382}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7148}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.19}}}{\*\bkmkstart stylerid1_2E7_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reissuance or reinstatement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{After suspension, revocation, or refusal to renew a license pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the affected licensee shall not have the license reissued or reinstated within one year of the effective date of the suspension, revocation, or expiration upon refusal to renew, unless the department orders otherwise. After that time, proof of compliance with the requirements and restrictions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and the rules adopted pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ must be presented to the department prior to reinstatement or reissuance of a license.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7224B.20; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 175, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a795}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7383}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7149}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.20}}}{\*\bkmkstart stylerid1_2E7_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall establish rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ requiring facilities to use reasonable accounting and reimbursement systems which recognize relevant cost-related factors for patients with a substance use disorder. A facility shall not be licensed nor shall any payment be made under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to a facility which fails to comply with those rules or which does not permit inspection by the department or examination of all records, including financial records, methods of administration, general and special dietary programs, the disbursement of drugs and methods of supply, and any other records the department deems relevant to the establishment of such a system. However, rules issued pursuant to }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall not apply to any facility referred to in }{{\f5\fs18\hyphpar0\qj{section 125.13, subsection 2}}}{, or }{{\f5\fs18\hyphpar0\qj{section 125.43}}}{.*}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, \'a7125.13(8); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.20}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71132}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a749}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{*}{{\f5\fs12\hyphpar0\qj{Section 125.43}}}{ repealed by }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1161, \'a7135}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; corrective legislation is pending}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.21}}}{\*\bkmkstart stylerid1_2E7_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Chemical substitutes and antagonists programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department has exclusive power in this state to approve and license chemical substitutes and antagonists programs, and to monitor chemical substitutes and antagonists programs to ensure that the programs are operating within the rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The department shall grant approval and license if the requirements of the rules are met and state funding is not requested. The chemical substitutes and antagonists programs conducted by persons exempt from the licensing requirements of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 125.13, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, are subject to approval and licensure under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide advice, consultation, and technical assistance to chemical substitutes and antagonists programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approve local agencies or bodies to assist the department in carrying out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7224B.21; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.21}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 58, \'a79}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 32, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 203, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 175, \'a773}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a797}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7384}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7150}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{125.22 through 125.24}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.25}}}{\*\bkmkstart stylerid1_2E7_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Approval of facility budget.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7135, 137}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 repeal effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{125.26 through 125.31}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.32}}}{\*\bkmkstart stylerid1_2E7_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Acceptance for treatment \u8212\'3f rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall adopt and may amend and repeal rules for acceptance of persons into the treatment program, subject to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{, considering available treatment resources and facilities, for the purpose of early and effective treatment of persons with a substance use disorder and concerned family members. In establishing the rules the department shall be guided by the following standards:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If possible a patient shall be treated on a voluntary rather than an involuntary basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A patient shall be initially assigned or transferred to outpatient treatment, unless the patient is found to require inpatient, residential, or halfway house treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be denied treatment solely because the person has withdrawn from treatment against medical advice on a prior occasion or because the person has relapsed after earlier treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individualized treatment plan shall be prepared and maintained on a current basis for each patient after the assessment process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provision shall be made for a continuum of coordinated treatment services, so that a person who leaves a facility or a form of treatment will have available and may utilize other appropriate treatment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, \'a7125.15; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.32}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1001, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71134}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1085, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a735, 62}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a799}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.32A}}}{\*\bkmkstart stylerid1_2E7_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Discrimination prohibited.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7135, 137}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 repeal effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.33}}}{\*\bkmkstart stylerid1_2E7_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Voluntary treatment of persons with a substance use disorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person with a substance use disorder may apply for voluntary treatment or rehabilitation services directly to a facility or to a licensed physician and surgeon or osteopathic physician and surgeon or to a mental health professional. If the proposed patient is a minor or an incompetent person, a parent, a legal guardian, or other legal representative may make the application. The licensed physician and surgeon or osteopathic physician and surgeon, mental health professional, or any employee or person acting under the direction or supervision of the physician and surgeon or osteopathic physician and surgeon, mental health professional, or facility shall not report or disclose the name of the person or the fact that treatment was requested or has been undertaken to any law enforcement officer or law enforcement agency; nor shall such information be admissible as evidence in any court, grand jury, or administrative proceeding unless authorized by the person seeking treatment. If the person seeking such treatment or rehabilitation is a minor who has personally made application for treatment, the fact that the minor sought treatment or rehabilitation or is receiving treatment or rehabilitation services shall not be reported or disclosed to the parents or legal guardian of such minor without the minor\u8217\'3fs consent, and the minor may give legal consent to receive such treatment and rehabilitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to rules adopted by the department, the administrator or the administrator\u8217\'3fs designee in charge of a facility may determine who shall be admitted for treatment or rehabilitation. If a person is refused admission, the administrator or the administrator\u8217\'3fs designee, subject to rules adopted by the department, shall refer the person to another facility for treatment if possible and appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person with a substance use disorder seeking treatment or rehabilitation and who is either addicted to or dependent on a chemical substance may first be examined and evaluated by a licensed physician and surgeon or osteopathic physician and surgeon or a mental health professional who may prescribe, if authorized or licensed to do so, a proper course of treatment and medication, if needed. The licensed physician and surgeon or osteopathic physician and surgeon or mental health professional may further prescribe a course of treatment or rehabilitation and authorize another licensed physician and surgeon or osteopathic physician and surgeon, mental health professional, or facility to provide the prescribed treatment or rehabilitation services. Treatment or rehabilitation services may be provided to a person individually or in a group. A facility providing or engaging in treatment or rehabilitation shall not report or disclose to a law enforcement officer or law enforcement agency the name of any person receiving or engaged in the treatment or rehabilitation; nor shall a person receiving or participating in treatment or rehabilitation report or disclose the name of any other person engaged in or receiving treatment or rehabilitation or that the program is in existence, to a law enforcement officer or law enforcement agency. Such information shall not be admitted in evidence in any court, grand jury, or administrative proceeding. However, a person engaged in or receiving treatment or rehabilitation may authorize the disclosure of the person\u8217\'3fs name and individual participation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a patient receiving inpatient or residential care leaves a facility, the patient shall be encouraged to consent to appropriate outpatient or halfway house treatment. If it appears to the administrator in charge of the facility that the patient is a person with a substance use disorder who requires help, the director may arrange for assistance in obtaining supportive services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a patient leaves a facility, with or against the advice of the administrator in charge of the facility, the director may make reasonable provisions for the patient\u8217\'3fs transportation to another facility or to the patient\u8217\'3fs home. If the patient has no home, the patient shall be assisted in obtaining shelter. If the patient is a minor or an incompetent person, the request for discharge from an inpatient facility shall be made by a parent, legal guardian, or other legal representative, or by the minor or incompetent person if the patient was the original applicant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who reports or discloses the name of a person receiving treatment or rehabilitation services to a law enforcement officer or law enforcement agency or any person receiving treatment or rehabilitation services who discloses the name of any other person receiving treatment or rehabilitation services without the written consent of the person in violation of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall upon conviction be guilty of a simple misdemeanor.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, \'a7224A.2, 224A.3; C75, 77, \'a7125.16, 224A.2, 224A.3; C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7125.33}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1001, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71135}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1085, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 121, \'a736, 62}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 34, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7101}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a750}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321J.3}}}{{\f5\fs12\hyphpar0\qj{, 331.910}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.34}}}{\*\bkmkstart stylerid1_2E7_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Treatment and services for persons with a substance use disorder due to intoxication and substance-induced incapacitation.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7135, 137}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 repeal effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{125.35 and 125.36}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.37}}}{\*\bkmkstart stylerid1_2E7_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records confidential.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7135, 137}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 repeal effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{125.38}}}{\*\bkmkstart stylerid1_2E7_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\