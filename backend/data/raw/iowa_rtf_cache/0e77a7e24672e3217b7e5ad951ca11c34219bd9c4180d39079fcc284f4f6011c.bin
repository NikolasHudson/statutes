\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F714B}{\*\bkmkend codeChapter_5F714B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 714B}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{PRIZE PROMOTIONS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7331.307}}}{{\f5\fs12\qc{, 364.22}}}{{\f5\fs12\qc{, 701.1}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdvertisement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 714.16, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMerchandise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 714.16, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means as defined in }}}{{\f5\fs18\hyphpar0\qj{section 714.16, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPrize\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a gift, award, cash award, or other merchandise of value that is offered or awarded to a person in a real or purported contest, competition, sweepstakes, puzzle, drawing, scheme, plan, or other selection process.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRetail value\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of a prize means the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A price at which the sponsor of the prize can substantiate that a substantial number of the items of merchandise have been sold to the public in the year preceding the date of the written prize notice in the regular course of business other than through a prize promotion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No more than one and one-half times the amount the sponsor paid for the prize in a bona fide purchase from an unaffiliated seller, if the sponsor is unable to substantiate a price pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSponsor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who awards another person a prize or who allows the person to receive, use, compete for, or obtain information about a prize.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Written prize notice \u8212\'3f content \u8212\'3f form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sponsor of a prize shall not require a person to purchase merchandise or pay or donate money as a condition of awarding a prize or as a condition of allowing the person to receive, use, compete for, or obtain information about a prize, unless the person has first received a written prize notice which satisfies the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{. A sponsor shall not create the reasonable impression that such a purchase, payment, or donation is required, unless the person has first received a written prize notice which satisfies the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a sponsor is deemed to have created the reasonable impression that a payment, purchase, or donation is required as a condition of awarding the person a prize, or as a condition of allowing the person to receive, use, compete for, or obtain information about a prize, if the sponsor does any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fails to clearly and conspicuously disclose that a purchase, payment, or donation is not required in immediate proximity to, and in the same type and boldness as, each written reference to a purchase, payment, or donation, or in immediate proximity to, and in the same audio volume as, each verbal reference to a purchase, payment, or donation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Uses a verbal or written solicitation, or other advertisement which contains any express or implied representations that a participant\u8217\'3fs likelihood of receiving a prize or other favorable treatment is enhanced by making a purchase, payment, or donation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Uses a verbal or written solicitation, course of solicitation, or other advertisement which when considered in its totality creates an overall impression that a participant\u8217\'3fs likelihood of receiving a prize or other favorable treatment is enhanced by making a purchase, payment, or donation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written prize notice satisfying the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{ must precede every verbal advertisement by a sponsor which requires a person to purchase merchandise or pay or donate money, or gives the reasonable impression that such a purchase, payment, or donation is required, as a condition of awarding a prize, or as a condition of allowing a person to receive, use, compete for, or obtain information about a prize.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each written advertisement by a sponsor which requires a person to purchase merchandise or pay or donate money, or gives the reasonable impression that such a purchase, payment, or donation is required as a condition of awarding a prize or as a condition of allowing a person to receive, use, compete for, or obtain information about a prize, must satisfy the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written prize notice must contain each of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The true name or names of the sponsor and the street address of the sponsor\u8217\'3fs actual principal place of business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The retail value of each prize the person receiving the notice has been selected to receive or may be eligible to receive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement of the odds the person has of receiving each prize identified in the notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any requirement that the person pay shipping or handling fees, or any other charges to obtain or use a prize, including the nature and amount of the charge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that a restriction applies and a description of the restriction, if receipt of the prize is subject to a restriction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any limitations on eligibility to receive a prize.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a sponsor represents that a person is a winner or finalist, has been specially selected, is in first place, or is otherwise among a limited group of persons with an enhanced likelihood of receiving a prize; or that a person is entering a contest, sweepstakes, drawing, or other competitive enterprise from which a single winner or select group of winners will receive a prize, and if the notice is not prohibited under }}}{{\f5\fs18\hyphpar0\qj{section 714B.3, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a statement of the maximum number of persons in the group or purported group with this enhanced likelihood of receiving a prize.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any requirement or invitation for the person to view, hear, or attend a sales presentation in order to claim a prize, a good faith estimate of the length of the sales presentation, a description of the merchandise that is the subject of the sales presentation, and the total cost of such merchandise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information required in the written prize notice pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ must be provided as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The retail value and the statement of odds required under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ must be stated in immediate proximity to each identification of a prize on the written notice, and must be in the same size and boldness of type as the reference to the prize.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The retail value must be stated in Arabic numerals, and must be in the following form:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{Retail value:}{{\f5\fs18\hyphpar0\qj{\~\~}}}{$}{{\f5\fs18\hyphpar0\qj{................}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The statement of odds must include, for each prize, the total number of prizes to be given away and the total number of written prize notices to be distributed. The number of prizes and written prize notices must be stated in Arabic numerals. The statement of odds must be in the following form:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{............}}}{ (number of prizes) out of }{{\f5\fs18\hyphpar0\qj{............}}}{ (notices distributed).}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person is required to pay shipping or handling fees or any other charges to obtain a prize, to be eligible to obtain a prize, or to participate in a contest, a statement must appear in immediate proximity to each listing of the prize in the written prize notice in not less than ten point boldface type as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{YOU MUST PAY $}{{\f5\fs18\hyphpar0\qj{................}}}{ IN ORDER TO RECEIVE OR USE THIS ITEM, or, YOU MUST PAY $}{{\f5\fs18\hyphpar0\qj{................}}}{ IN ORDER TO COMPETE FOR THIS ITEM, as applicable.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The information required under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fh\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ must be on the first page of the written prize notice in not less than ten point boldface type.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement required under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, must appear in immediate proximity to each representation that the person is among a group of persons with an enhanced likelihood of receiving a prize, and must be in the same type size and boldness as the representation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prohibited practices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sponsor of a prize shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Deliver a written prize notice, or an envelope containing a written prize notice, that contains language, or is designed in a manner, that would have the tendency or capacity to mislead intended recipients as to the source of the written prize notice. This prohibition includes, but is not limited to, a written prize notice or envelope which indicates that the notice or envelope originates from a government agency, public utility, insurance company, consumer reporting agency, debt collector, or law firm, unless the written prize notice or envelope originates from such source.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Represent directly or by implication that the number of persons eligible for the prize is limited or that a person has been selected to receive a particular prize, unless the representation is true.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Represent that a person is a winner or finalist, has been specially selected, is in first place, or is otherwise among a limited group of persons with an enhanced likelihood of receiving a prize, or that a person is entering a contest, sweepstakes, drawing, or other competitive enterprise, from which a single winner or select group of winners will receive a prize, when in fact the enterprise is a promotional scheme designed to make contact with prospective customers and all or a substantial number of those receiving the notice are awarded the same prize.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Represent directly or by implication that a person will have an increased chance of receiving a prize by making multiple or duplicate purchases, payments or donations, or by entering a game, drawing, sweepstakes, or other contest more than one time, unless the representation is true. A sponsor is deemed to have made such representation if the sponsor delivers one or more prize notices to a person after the person has already made a purchase, payment, or donation to the sponsor for the same promotion, or has already entered the same game, drawing, sweepstakes, or other contest, unless the sponsor can demonstrate a bona fide error even though the sponsor has implemented procedures reasonably designed to prevent such duplication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Represent directly or by implication that a person is being notified a second or final time of the opportunity to receive or compete for a prize, unless the representation is true.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Represent directly or by implication that a prize notice is urgent, or otherwise convey an impression of urgency by use of description, narrative copy, phrasing on an envelope, or similar method, unless there is a limited time period in which the recipient must take some action to claim or be eligible to receive a prize, and the date by which such action is required appears in immediate proximity to each representation of urgency and in the same type size and boldness as each representation of urgency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly sell, rent, exchange, transfer, or otherwise furnish to or purchase from other persons, financial data regarding Iowans disclosed in connection with a prize promotion not in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, financial data includes credit card numbers, bank account numbers, other payment device numbers, and dollars spent on prize promotions which are not in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Request an individual to disclose the individual\u8217\'3fs phone number, age, birthdate, credit card ownership, or financial data in connection with a prize promotion which is not in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a written prize notice requires or invites a person to view, hear, or attend a sales presentation in order to claim a prize, the sales presentation shall not begin until the sponsor does all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Informs the person of the prize, if any, that has been awarded to the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is awarded a prize, delivers to the person the prize or the item selected by the person as provided in }}}{{\f5\fs18\hyphpar0\qj{section 714B.4}}}{{\f5\fs18\hyphpar0\qj{, if the prize awarded is not available.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7714B.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prize award required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A sponsor of a prize who represents to a person that the person has been awarded a prize shall, no later than thirty days after making the representation, provide the person with the prize; with a voucher, certificate, or other document indicating the person\u8217\'3fs unconditional right to receive the prize; or with either of the following items as selected by the person:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other prize listed in the written prize notice that is available and that is of equal or greater value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The retail value of the prize, as stated in the written notice, in the form of cash, a money order, or a certified check.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7714B.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Information requested by attorney general.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A sponsor shall provide, upon the request of the attorney general made within one year after the termination date of the promotion, a record of the names and addresses of all winners of prizes of one hundred dollars or more.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Criminal penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person who intentionally violates }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ is guilty of an aggravated misdemeanor. A person intentionally violates }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ if the act or acts in violation occur or continue after the attorney general or county attorney has notified the person by certified mail that the person is in violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a77}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ constitutes a violation of }{{\f5\fs18\hyphpar0\qj{section 714.16, subsection 2}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Private action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to any other remedies, a person suffering pecuniary loss as a result of a violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ by another person may bring an action against such other person to recover all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The greater of five hundred dollars or twice the amount of the pecuniary loss.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Costs and reasonable attorney fees.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Compliance with other laws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall not be construed to permit an activity prohibited by }{{\f5\fs18\hyphpar0\qj{section 714.16}}}{, or rules adopted pursuant to that section, or by }{{\f5\fs18\hyphpar0\qj{chapter 725}}}{, or other applicable law.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a710}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{714B.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ does not apply to the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Advertising by sponsors registered pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 557B}}}{{\f5\fs18\hyphpar0\qj{, licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 99B}}}{{\f5\fs18\hyphpar0\qj{, or regulated pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{99E}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{99F}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{99G}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Advertising in connection with the sale or purchase of books, recordings, videocassettes, periodicals, and similar goods through a membership group or club which is regulated by the federal trade commission pursuant to }}}{{\f5\fs18\hyphpar0\qj\cf1{16 C.F.R. \'a7425.1}}}{{\f5\fs18\hyphpar0\qj{, concerning use of negative option plans by sellers in commerce.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Advertising in connection with the sale or purchase of goods ordered through a contractual plan or arrangement such as a continuity plan, subscription arrangement, or a single sale or purchase series arrangement under which the seller ships goods to a consumer who has consented in advance to receive the goods and who, after the receipt of the goods, is given an opportunity to examine the goods and to receive a full refund of charges for the goods upon return of the goods undamaged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Advertising in connection with sales by a catalog seller. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcatalog seller\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person at least fifty percent of whose annual revenues are derived from the sale of merchandise sold in connection with the distribution of catalogs of at least twenty-four pages, which contain written descriptions or illustrations and sale prices for each item of merchandise and which are distributed in more than one state with a total annual distribution of at least two hundred fifty thousand.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1185, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a7116, 121}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7142}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a7195}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 132, \'a739, 45, 46}}}\par}}