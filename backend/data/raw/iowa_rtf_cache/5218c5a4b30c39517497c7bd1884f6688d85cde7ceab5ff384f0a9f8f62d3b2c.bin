\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F347}{\*\bkmkend codeChapter_5F347}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 347}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{COUNTY HOSPITALS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a711.1}}}{{\f5\fs12\qc{, 21.5}}}{{\f5\fs12\qc{, 27.1}}}{{\f5\fs12\qc{, 37.27}}}{{\f5\fs12\qc{, 97B.52A}}}{{\f5\fs12\qc{, 135B.31}}}{{\f5\fs12\qc{, 331.361}}}{{\f5\fs12\qc{, 331.461}}}{{\f5\fs12\qc{, 476B.1}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{347.1 through 347.6}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.7}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tax levies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a county hospital is established, the board of supervisors, at the time of levying ordinary taxes, shall levy a tax at the rate voted not to exceed fifty-four cents per thousand dollars of assessed value in any one year for the erection and equipment of the hospital, and also a tax not to exceed twenty-seven cents per thousand dollars of value for the improvement, maintenance, and replacements of the hospital, as certified by the board of hospital trustees. However, in counties having a population of two hundred twenty-five thousand or over, the levy for taxes payable in the fiscal year beginning July 1, 2001, and for subsequent fiscal years, for improvements and maintenance of the hospital shall not exceed two dollars and five cents per thousand dollars of assessed value in any one year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proceeds of the taxes constitute the county public hospital fund. The fund is subject to review by the board of supervisors in counties having a population of two hundred twenty-five thousand or over. However, the board of trustees of a county hospital, where funds are available in the county public hospital fund of the county which are unappropriated, may use the unappropriated funds for erecting and equipping hospital buildings and additions to the hospital buildings without authority from the voters of the county.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A levy shall not be made for the improvement, maintenance, or replacements of the hospital until the hospital has been constructed, staffed, and receiving patients. If revenue bonds are issued and outstanding under }}}{{\f5\fs18\hyphpar0\qj{section 331.461, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the board may levy a tax to pay operating and maintenance expenses in lieu of the authority otherwise contained in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ not to exceed twenty-seven cents per thousand dollars of assessed value or not to exceed one dollar and twenty-one and one-half cents per thousand dollars of assessed value for improvements and maintenance of the hospital in counties having a population of two hundred twenty-five thousand or over.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to levies otherwise authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the board of hospital trustees may certify for levy a tax at the rate, not to exceed twenty-seven cents per thousand dollars of assessed value, necessary to raise the amount budgeted by the board of hospital trustees for support of ambulance service as authorized in }}}{{\f5\fs18\hyphpar0\qj{section 347.14, subsection 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax levy authorized by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for operation and maintenance of the hospital may be available in whole or in part to any county with or without a county hospital organized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, to be used to enhance rural health services in the county. However, the tax levied may be expended for enhancement of rural health care services only following a local planning process. The department of health and human services shall establish guidelines to be followed by counties in implementing the local planning process which shall require legal notice, public hearings, and a referendum in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ prior to the authorization of any new levy or a change in the use of a levy. The notice shall describe the new levy or the change in the use of the levy, indicate the date and location of the hearing, and shall be published at least once each week for two consecutive weeks in a newspaper having general circulation in the county. The hearing shall not take place prior to two weeks after the second publication.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enhancement of rural health services for which the tax levy may be used includes but is not limited to emergency medical services, health care services shared with other hospitals, rural health clinics, and support for rural health care practitioners and public health services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When alternative use of funds from the tax levy is proposed in a county with a county hospital organized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, use of the funds shall be agreed upon by the elected board of trustees of the county hospital. When alternative use of funds from the tax levy is proposed in a county without a county hospital organized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, use of the funds shall be agreed upon by the board of supervisors and any publicly elected hospital board of trustees within the county prior to submission of the question to the voters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys raised from a tax levied in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for the purpose of enhancing rural health services in a county without a county hospital shall be designated and administered by the board of supervisors in a manner consistent with the purposes of the levy.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-b, -j; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5353;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7347.7}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71061}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 185, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 304, \'a7704}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 159, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 75, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 110, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 179, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 109, \'a711, 20, 21}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a7101, 108}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71107}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.441}}}{{\f5\fs12\hyphpar0\qj{, 347.13}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Additional levies, see }{{\f5\fs12\hyphpar0\qj{\'a7347.13(10)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.8}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.9}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trustees }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ appointment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ terms of office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When it has been determined by the voters of a county to establish a county public hospital, the board shall appoint five or seven trustees chosen from among the resident citizens of the county with reference to their fitness for office. The appointed trustees shall hold office until the following general election, at which time their successors shall be elected, three for a term of four years and the remainder for a term of two years, and they shall determine by lot their respective terms, and thereafter their successors shall be elected for regular terms of four years each.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon approval of a majority of the current board of trustees, the board may reduce an existing seven-member board to a five-member board. The board shall establish how to reduce the number of trustees on the board and shall provide for a staggered election cycle for election to the five-member board, which election shall be for a term of four years. However, the manner of reducing the number of trustees shall ensure that the current trustees on the seven-member board may continue to hold office through the end of their respective terms.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5355;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1200, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 36, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 65, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 110, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1033, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 148, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7183}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 123, \'a725, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.321}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 strike of subsection 3 applies retroactively to persons elected to a county hospital board of trustees on or after January 1, 2024; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 123, \'a726}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 stricken}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.9A}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trustee eligibility \u8212\'3f conflict of interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following persons shall not be eligible to serve as a trustee for a county public hospital:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or spouse of a person with medical or special staff privileges in the county public hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or spouse of a person who receives direct compensation in an amount greater than one thousand five hundred dollars in a calendar year from the county public hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transactions of a hospital trustee or a hospital trustee\u8217\'3fs spouse shall be limited as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A conflict of interest transaction is a transaction with the hospital in which a hospital trustee or a hospital trustee\u8217\'3fs spouse has a direct interest of less than or equal to one thousand five hundred dollars or indirect interest in any amount. A conflict of interest transaction is not voidable on the basis of the conflict of interest if all of the following are true:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The material facts of the transaction and the interest of the trustee or the trustee\u8217\'3fs spouse were disclosed or known to the board of hospital trustees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of hospital trustees authorized, approved, or ratified the transaction. A conflict of interest transaction is authorized, approved, or ratified if it receives the affirmative vote of a majority of the disinterested trustees at a meeting where a quorum is present and where three or more trustees are disinterested in the conflict of interest transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transaction was fair to the hospital at the time of the transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a trustee has an indirect interest in a transaction if either of the following is true:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Another entity in which the trustee or the trustee\u8217\'3fs spouse has a material interest or in which the trustee or the trustee\u8217\'3fs spouse is a general partner is party to the transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Another entity of which the trustee or the trustee\u8217\'3fs spouse is a director, officer, or trustee is a party to the transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a licensed health care practitioner from serving as a hospital trustee if the practitioner\u8217\'3fs sole use of the county hospital is to provide health care service to an individual with an intellectual disability as defined in }}}{{\f5\fs18\hyphpar0\qj{section 4.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 110, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1019, \'a7127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.321}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.10}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Vacancies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Vacancies on the board of trustees may be filled by appointment by the remaining members of the board of trustees or, if fewer than a majority of the trustees remain on the board, by the board of supervisors for the period until the vacancies are filled by election. An appointment made under }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall be for the unexpired balance of the term of the preceding trustee. If a board member is absent for four consecutive regular board meetings, without prior excuse, or fails to comply with more stringent attendance requirements for regular board meetings included in the bylaws governing the board, the member\u8217\'3fs position shall be declared vacant and filled as set out in }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-e; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5356;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1180, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 110, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1033, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 148, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.321}}}{{\f5\fs12\hyphpar0\qj{, 392.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Removal from office, }{{\f5\fs12\hyphpar0\qj{\'a766.1A}}}{, }{{\f5\fs12\hyphpar0\qj{66.31}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.11}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Organization }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ meetings }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ quorum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Hospital trustees shall qualify by taking the usual oath of office as provided in }{{\f5\fs18\hyphpar0\qj{chapter 63}}}{ and organize by the election of a chairperson, a secretary, and a treasurer. The secretary shall report to the county auditor and county treasurer the names of the chairperson, secretary, and treasurer of the board of hospital trustees as soon as practicable after the qualification of each. A board of hospital trustees shall meet as necessary to adequately oversee the operation of the hospital. A majority of the board of trustees shall constitute a quorum necessary for actions by the board of hospital trustees. The secretary shall maintain a complete record of board meetings, proceedings, and actions.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5357;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 170, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 110, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1033, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.12}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revenue collected \u8212\'3f accounting practices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before the fifteenth day of each month, the county treasurer shall give notice to the chairperson of the board of hospital trustees or the chairperson\u8217\'3fs designee of the amount of revenue collected for each fund of the hospital to the first day of that month and the county treasurer shall pay the taxes to the treasurer of the hospital as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.552, subsection 29}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The hospital administrator, or the administrator\u8217\'3fs designee, shall ensure that all accounts, funds, reports, and financial statements of the county hospital conform to generally accepted accounting principles as established by the governmental accounting standards board.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The hospital administrator, or the administrator\u8217\'3fs designee, shall file a financial report with the board of hospital trustees on or before the date of each regularly scheduled board meeting for the period of time since the board\u8217\'3fs previous regularly scheduled meeting.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5358;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.12}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1003, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1024, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 36, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 110, \'a710}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a737.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.13}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Board of trustees \u8212\'3f duties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A board of hospital trustees\u8217\'3f duties shall include all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Engage in all activities necessary to manage, control, and govern the hospital unless otherwise prohibited under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exercise all the rights and duties of hospital trustees including but not limited to authorizing the delivery of any health care service, assisted or independent living service, or other ancillary service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adopt bylaws and rules for its own guidance and for the government of the hospital. The bylaws may contain limits on the number of terms a trustee may serve on the board. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exercise fiduciary duties in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 504.831, subsections 1 through 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employ or contract for an administrator and fix the administrator\u8217\'3fs compensation. The administrator shall have authority to oversee the day-to-day operations of the hospital and its employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approve the appointment of a qualified medical staff and oversee the quality of medical care and services provided by the hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Manage and control the hospital\u8217\'3fs funds in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 540A}}}{{\f5\fs18\hyphpar0\qj{. In addition to investments permitted under }}}{{\f5\fs18\hyphpar0\qj{section 12B.10}}}{{\f5\fs18\hyphpar0\qj{, county hospital investments may include common stocks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish charity care policies for free treatment or financial assistance for care provided by the hospital, and fix the price to be charged to other patients admitted to the hospital for care and treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Procure and pay premiums on any and all insurance policies required for the prudent management of the hospital including but not limited to public liability, professional malpractice liability, workers\u8217\'3f compensation, and vehicle liability. Said insurance may include as additional insureds members of the board of trustees and employees of the hospital. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies to all county hospitals whether organized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 347A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 37}}}{{\f5\fs18\hyphpar0\qj{, or otherwise established by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certify levies for a tax in excess of any tax levy limit to meet its obligations to pay the premium costs on tort liability insurance, property insurance, workers\u8217\'3f compensation insurance, and any other insurance that may be necessary for the prudent management and operation of the county public hospital, the costs of a self-insurance program, the costs of a local government risk pool, and amounts payable under any insurance agreements to provide or procure such insurance, self-insurance program, or local government risk pool.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Publish quarterly in each of the official newspapers of the county as selected by the board of supervisors pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 349.1}}}{{\f5\fs18\hyphpar0\qj{ the schedule of bills allowed, and publish annually in such newspapers the schedule of salaries paid by job classification and category, but not by listing names of individual employees. The names, business addresses, salaries, and job classification of employees paid in whole or in part from a tax levy shall be a public record and open to inspection at reasonable times as designated by the board of trustees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fix the amount necessary for the improvement and maintenance of the hospital and for support of ambulance service during the ensuing fiscal year, and certify the amount to the county auditor before April 30 of each year, subject to any limitation in }}}{{\f5\fs18\hyphpar0\qj{section 347.7}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-d, -g, -h, -j, -l, -m, -p, -r; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5359;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7347.13}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71062}}}{, }{{\f5\fs18\hyphpar0\qj{ch 120, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1201, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 185, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 36, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1032, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1115, \'a757, 71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 110, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1033, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a787, 98}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a721.5}}}{{\f5\fs12\hyphpar0\qj{, 145A.12}}}{{\f5\fs12\hyphpar0\qj{, 347.14}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Removal from office, }{{\f5\fs12\hyphpar0\qj{\'a766.1A}}}{, }{{\f5\fs12\hyphpar0\qj{66.31}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 12 applies to political subdivision budgets for fiscal years beginning on or after July 1, 2024; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a798}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.14}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Board of trustees \u8212\'3f powers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The board of trustees may:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Purchase, condemn, or lease a site for such public hospital and provide and equip suitable hospital buildings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cause plans and specifications to be made and adopted for all hospital buildings, and advertise for bids, as required by law for other county buildings, before making a contract for the construction of a building.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Accept property by gift, devise, bequest, or otherwise. If the board deems it advisable, the board may sell, lease, exchange, or otherwise dispose of any hospital property upon a concurring vote of a majority of all members of the board of hospital trustees. The proceeds of such sale, lease, exchange, or other disposition may be applied to any lawful purpose, subject to approval of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Borrow moneys to be secured solely by hospital revenues for the purposes of improvement, maintenance, or replacement of the hospital or for hospital equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish and maintain in connection with the hospital a training school for nurses or other health professions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish a fund for depreciation as a separate fund. Moneys deposited in the fund shall remain in the fund until such time as in the judgment of the board of trustees it is deemed advisable to use the funds for hospital purposes. Interest earned on moneys in the fund shall be deposited in the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Operate a health care facility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{{\f5\fs18\hyphpar0\qj{ in conjunction with the hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Purchase, lease, equip, maintain, and operate an ambulance or ambulances to provide necessary and sufficient ambulance service or to contract for such vehicles, equipment, maintenance, or service when such ambulance service is not otherwise available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submit to the voters at an election held on a date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a proposition to sell or lease a county public hospital for use as a private hospital or as a merged area hospital under }}}{{\f5\fs18\hyphpar0\qj{chapter 145A}}}{{\f5\fs18\hyphpar0\qj{ or to sell or lease a county hospital in conjunction with the establishment of a merged area hospital. The authorization of the board of hospital trustees submitting the proposition may, but is not required to, contain conditions which provide for maintaining hospital care within the county, for the retention of county public hospital employees and staff, and for the continuation of the board of trustees for the purpose of carrying out provisions of contracts. Proceeds from the sale or lease of the county hospital or other assets of the board of trustees shall not be used for the prepayment of health care services for residents of the county with the purchaser or lessee of the county hospital or to underwrite the sale or lease of the county hospital.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proposition submitted to the voters of the county shall not be set forth at length, but it shall be in substantially the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the board of hospital trustees of }{{\f5\fs18\hyphpar0\qj{................................}}}{ county, state of Iowa, be authorized to }{{\f5\fs18\hyphpar0\qj{........................................................}}}{ (state authorization which may exclude the conditions) in accordance with the terms of authorization approved at the meeting of }{{\f5\fs18\hyphpar0\qj{....................}}}{ (cite date) of the board of hospital trustees?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the proposition is approved by a majority of the total votes cast for and against the proposition at the election, the board of hospital trustees shall proceed to carry out the authorization granted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the board authorizes delivery of additional health care services, assisted or independent living services, or other ancillary services under }}}{{\f5\fs18\hyphpar0\qj{section 347.13, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the board is granted all of the powers and duties necessary for the management, control, and government of the institutions including but not limited to any applicable powers and duties granted boards of trustees under other provisions of the Code relating to hospitals, nursing homes, assisted or independent living services, and other ancillary services irrespective of the chapter of the Code under which such an entity is established, organized, operated, or maintained, unless such provisions are in conflict with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 347.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-d, -k, -o, -q; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5360;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7347.14}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 78, \'a720, 47}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 185, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 160, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 36, \'a77, 8}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1115, \'a758, 71}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 110, \'a712}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7145A.12}}}{{\f5\fs12\hyphpar0\qj{, 347.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Powers under consolidation, }{{\f5\fs12\hyphpar0\qj{\'a7348.2}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.15}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pecuniary interest prohibited }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exceptions.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2001/CH0065.pdf" }{\fldrslt \cf5 \f5 \fs18{{2001 Acts, ch 65, \'a72}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.16}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Treatment in county hospital \u8212\'3f terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any resident of a county in this state who is sick or injured shall be entitled to care and treatment in any public hospital established and maintained by that county under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, so long as that person observes the rules of conduct prescribed by the board of hospital trustees. Each patient admitted under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, or the person legally liable for that patient\u8217\'3fs support, shall pay to the board of hospital trustees reasonable compensation for that patient\u8217\'3fs care and treatment according to the rules established by the board, unless }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ is applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Free care and treatment shall be furnished in a county public hospital to any sick or injured person who fulfills the residency requirements under }}}{{\f5\fs18\hyphpar0\qj{section 47.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, Code 1993, in the county maintaining the hospital, and who is indigent. The board of hospital trustees shall determine whether a person is indigent and entitled to free care under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, or may delegate that determination to the general assistance director or the office of the department of health and human services in that county, subject to guidelines the board may adopt in conformity with applicable statutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Care and treatment may be furnished in a county public hospital to any sick or injured person who has residence outside the county which maintains the hospital, subject to such policies and rules as the board of hospital trustees may adopt. If care and treatment is provided under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to a person who is indigent, the person\u8217\'3fs county of residence, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 331.190}}}{{\f5\fs18\hyphpar0\qj{, shall pay to the board of hospital trustees the fair and reasonable cost of the care and treatment provided by the county public hospital unless the cost of the indigent person\u8217\'3fs care and treatment is otherwise provided for. If care and treatment is provided to an indigent person under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the county public hospital furnishing the care and treatment shall immediately notify, by regular mail, the auditor of the county of residence of the indigent person of the provision of care and treatment to the indigent person including care and treatment provided through the behavioral health service system established in }}}{{\f5\fs18\hyphpar0\qj{section 225A.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-k; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5362;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.16}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1212, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 49, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 119, \'a73, 5}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 110, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1120, \'a7128, 130}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1137, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71108}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7124, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7347.17}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 3 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.17}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Accounts \u8212\'3f collection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be the duty of the trustees either by themselves or through the superintendent to make collections of all accounts for hospital services rendered to persons other than indigent patients or patients entitled to free care as provided in }{{\f5\fs18\hyphpar0\qj{section 347.16}}}{. Such account shall be payable on presentation to the person liable therefor of an itemized statement and if not paid or secured within sixty days after such presentation the said trustees shall proceed to enforce collections by such means as are necessary and are authorized to employ any person for that purpose, and if legal proceedings are required they may employ counsel, the employment in either event to be on such arrangement for compensation as the trustees deem appropriate, provided, however, that should the county attorney act as attorney for the board in any such legal proceedings the county attorney shall serve without additional compensation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5363;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.18}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Discrimination.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0110.pdf" }{\fldrslt \cf5 \f5 \fs18{{2009 Acts, ch 110, \'a717}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.19}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Compensation \u8212\'3f expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A trustee shall not receive any compensation for services performed under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, but a trustee shall be reimbursed for actual and necessary expenses incurred in the performance of the trustee\u8217\'3fs duties.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5365;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.19}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 110, \'a714}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.20}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Municipal jurisdiction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a county hospital is located on land outside of but adjacent to a city, the ordinances of the city relating to fire and police protection and control, sanitary regulations, and public utility service shall be in force upon and over the hospital and grounds, and the city shall have jurisdiction to enforce those ordinances.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a7409-i; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5366;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1021, \'a785}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{347.21 and 347.22}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.23}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{City hospital changed to county hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any hospital organized and existing as a city hospital may become a county hospital organized and managed as provided for in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, upon a proposition for such purpose being submitted to and approved by a majority of the electors of both the city in which such hospital is located and of the county under whose management it is proposed that such hospital be placed. The proposition shall be placed upon the ballot by the board of supervisors when requested by a petition signed by eligible electors of the county equal in number to five percent of the votes cast for president of the United States or governor, as the case may be, at the last general election. The proposition shall be submitted at an election held on a date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. Upon the approval of the proposition the hospital, its assets and liabilities, will become the property of the county and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ will govern its future management.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The question shall be submitted in substantially the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the municipal hospital of }{{\f5\fs18\hyphpar0\qj{........................}}}{, Iowa, be transferred to and become the property of, and be managed by the county of }{{\f5\fs18\hyphpar0\qj{........................}}}{, Iowa?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of computing whether or not said proposition is carried, the votes of the residents of the city in which said hospital is located shall be counted both for the purpose of ascertaining whether or not the proposition is carried within the city and also for the purpose of ascertaining whether or not the proposition is carried within the county.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, \'a7347.23, 380.12; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.23}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 56, \'a727}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1115, \'a759, 71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.381}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.23A}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Memorial hospital or county hospital payable from revenue bonds changed to county hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hospital established as a memorial hospital under }}}{{\f5\fs18\hyphpar0\qj{chapter 37}}}{{\f5\fs18\hyphpar0\qj{ or a county hospital supported by revenue bonds and organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 347A}}}{{\f5\fs18\hyphpar0\qj{ may become, in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a county hospital organized and managed as provided for in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If the hospital is established by a city as a memorial hospital, the city must be located in the county which will own and manage the hospital. A proposition for the change must be submitted to and approved by a majority of the electors of the county which will own and manage the hospital as provided for in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. In addition, if the hospital is a memorial hospital organized by a city under }}}{{\f5\fs18\hyphpar0\qj{chapter 37}}}{{\f5\fs18\hyphpar0\qj{, the proposition must also be approved by a majority of the electors of that city. The proposition shall be submitted to the electors at an election called by the county board of supervisors and held on a date specified in }}}{{\f5\fs18\hyphpar0\qj{section 39.2, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proposition shall be placed upon the ballot by the board of supervisors if requested by the hospital\u8217\'3fs board of trustees or governing commission and the request is endorsed by a petition for this purpose signed by eligible electors of the county equal in number to five percent of the votes cast for president of the United States or governor, as the case may be, at the last general election. Upon the approval of the proposition the hospital, its assets and liabilities, shall become the property of the county and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall govern its future management.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The question for a memorial hospital established by a city under }}}{{\f5\fs18\hyphpar0\qj{chapter 37}}}{{\f5\fs18\hyphpar0\qj{ shall be submitted in substantially the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the }{{\f5\fs18\hyphpar0\qj{....................}}}{ hospital of }{{\f5\fs18\hyphpar0\qj{........................}}}{, Iowa, be transferred to and become the property of, and be managed by the county of }{{\f5\fs18\hyphpar0\qj{........................}}}{, Iowa, under provision of }{{\f5\fs18\hyphpar0\qj{chapter 347}}}{ of the Code of Iowa?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The question for a memorial hospital established by a county under }}}{{\f5\fs18\hyphpar0\qj{chapter 37}}}{{\f5\fs18\hyphpar0\qj{ or a county hospital supported by revenue bonds and organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 347A}}}{{\f5\fs18\hyphpar0\qj{ shall be submitted in substantially the following form:}}}\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{Shall the }{{\f5\fs18\hyphpar0\qj{....................}}}{ hospital of }{{\f5\fs18\hyphpar0\qj{........................}}}{, Iowa, organized and governed under chapter }{{\f5\fs18\hyphpar0\qj{........}}}{ of the Code of Iowa be changed to be established and governed under }{{\f5\fs18\hyphpar0\qj{chapter 347}}}{ of the Code of Iowa?}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of computing whether or not the proposition is carried, if the hospital is a memorial hospital established by a city under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 37}}}{{\f5\fs18\hyphpar0\qj{, the votes of the residents of that city shall be counted both for the purpose of ascertaining whether or not the proposition is carried within the city and also for the purpose of ascertaining whether or not the proposition is carried within the county.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1135, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 56, \'a728}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1115, \'a760, 71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.24}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Law applicable to other hospitals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Hospitals organized under }{{\f5\fs18\hyphpar0\qj{chapter 37}}}{ or }{{\f5\fs18\hyphpar0\qj{chapter 347A}}}{ may be operated as provided for in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ in any way not clearly inconsistent with the specific provisions of their chapters.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.24}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.25}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Election of trustees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The election of hospital trustees whose offices are established by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 145A}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{347A}}}{{\f5\fs18\hyphpar0\qj{ shall take place at the general election on ballots which shall not reflect a nominee\u8217\'3fs political affiliation. Nomination shall be made by petition in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 45}}}{{\f5\fs18\hyphpar0\qj{. The petition form shall be furnished by the county commissioner of elections, shall be signed by fifty eligible electors of the county, and shall be filed with the county commissioner of elections at least sixty-nine days before the date of the election. A plurality is sufficient to elect hospital trustees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be in conflict with any of the laws of this state, then the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall prevail.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.25}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 135, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 129, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a7104}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7184}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 147, \'a750, 54}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a739.21}}}{{\f5\fs12\hyphpar0\qj{, 145A.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.26}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Health care facility in existing hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In any county where there is a county hospital in existence, a health care facility as defined in }{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{ may be established to be operated in conjunction therewith, and all of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and all of the proceedings authorized thereby relating to hospital buildings and additions thereto, shall apply to erecting, equipping and procuring sites for such facilities and additions thereto, as well as for improvements, maintenance and replacements of such facilities.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7347.26}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.27}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{347.28 through 347.30}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2009/CH0110.pdf" }{\fldrslt \f5 \fs18{{2009 Acts, ch 110, \'a717}}}}}}{{\f5\fs18\qj{2009 Acts, ch 110, \'a717}}}{. }{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.31}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Community recreation facilities and programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A county or city hospital may expend available funds for establishment and operation of facilities, programs, and services which provide health benefits to persons served by those facilities, programs, or services. Where appropriate, the county or city hospital shall enter into an agreement pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1072, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{347.32}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tax status.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ does not deprive any hospital of its tax exempt or nonprofit status, except that any portion of hospital property which is used for purposes other than nonprofit, health-related purposes shall be subject to property tax as provided for in }{{\f5\fs18\hyphpar0\qj{section 427.1, subsection 14}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1200, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a785}}}\par}}