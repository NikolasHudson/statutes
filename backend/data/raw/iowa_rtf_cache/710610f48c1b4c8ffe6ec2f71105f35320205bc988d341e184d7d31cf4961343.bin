_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions controlling subchapter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purpose of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ and unless otherwise required by the context:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAnnual inflation factor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an index, expressed as a percentage, determined by the department by October 15 of the calendar year preceding the calendar year for which the factor is determined, which reflects the purchasing power of the dollar as a result of inflation during the fiscal year ending in the calendar year preceding the calendar year for which the factor is determined. In determining the annual inflation factor, the department shall use the annual percent change, but not less than zero percent, in the gross domestic product price deflator computed for the second quarter of the calendar year by the bureau of economic analysis of the United States department of commerce and shall add all of that percent change to one hundred percent. The annual inflation factor and the cumulative inflation factor shall each be expressed as a percentage rounded to the nearest one-tenth of one percent. The annual inflation factor shall not be less than one hundred percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCumulative inflation factor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the product of the annual inflation factor for the calendar year beginning on January 1, 2023, and all annual inflation factors for subsequent calendar years as determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The cumulative inflation factor applies to all tax years beginning on or after January 1 of the calendar year for which the latest annual inflation factor has been determined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual inflation factor for the calendar year beginning on January 1, 2023, is one hundred percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean and include those who have a right to exercise control as to how, when, and where services are to be performed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffiduciary\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a guardian, trustee, executor, administrator, receiver, conservator, or any person, whether individual or corporate, acting in any fiduciary capacity for any person, trust, or estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffiscal year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean an accounting period of twelve months, ending on the last day of any month other than December.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fforeign country\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean any jurisdiction other than one embraced within the United States. The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnited States\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when used in a geographical sense, include the states, the District of Columbia, and the possessions of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhead of household\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ have the same meaning as provided by the Internal Revenue Code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fincome year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the calendar year or the fiscal year upon the basis of which the net income is computed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3findividual\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a natural person; and if an individual is permitted to file as a corporation, under the Internal Revenue Code, that fictional status is not recognized for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and the individual\u8217\'3fs taxable income shall be computed as required under the Internal Revenue Code relating to individuals not filing as a corporation, with the adjustments allowed by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fnonresident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies only to individuals, and includes all individuals who are not \u8220\'3fresidents\u8221\'3f within the meaning of }}}{{\f5\fs18\hyphpar0\qj{subsection 14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNotice of assessment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a notice by the department to a taxpayer advising the taxpayer of an assessment of tax due.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fother person\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean that person or entity properly empowered to act in behalf of an individual payee and shall include authorized agents of such payees whether they be individuals or married couples.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpaid\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for the purposes of the deductions under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, means \u8220\'3fpaid or accrued\u8221\'3f or \u8220\'3fpaid or incurred\u8221\'3f, and the terms }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpaid or incurred\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpaid or accrued\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be construed according to the method of accounting upon the basis of which the net income is computed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freceived\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for the purpose of the computation of net income under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, means \u8220\'3freceived or accrued\u8221\'3f, and the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freceived or accrued\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be construed according to the method of accounting upon the basis of which the net income is computed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fperson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes individuals and fiduciaries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fresident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies only to individuals and includes, for the purpose of determining liability to the tax imposed by }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ upon or with reference to the income of any tax year, any individual domiciled in the state, and any other individual who maintains a permanent place of abode within the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTaxable income\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, in the case of individuals, the net income as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.7}}}{{\f5\fs18\hyphpar0\qj{ minus the deduction allowed by }}}{{\f5\fs18\hyphpar0\qj{section 422.9}}}{{\f5\fs18\hyphpar0\qj{, if available. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTaxable income\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, in the case of estates or trusts, the taxable income without a deduction for personal exemption as computed for federal income tax purposes under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, but with the adjustments specified in }}}{{\f5\fs18\hyphpar0\qj{section 422.7}}}{{\f5\fs18\hyphpar0\qj{, and the deduction allowed by }}}{{\f5\fs18\hyphpar0\qj{section 422.9}}}{{\f5\fs18\hyphpar0\qj{, if available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftax year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the calendar year, or the fiscal year ending during such calendar year, upon the basis of which the net income is computed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a taxpayer has made the election provided by section 441, subsection }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, of the Internal Revenue Code, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftax year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the annual period so elected, varying from fifty-two to fifty-three weeks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the effective date or the applicability of a provision of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ is expressed in terms of a tax year beginning, including, or ending with reference to a specified date which is the first or last day of a month, a tax year described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be treated as beginning with the first day of the calendar month beginning nearest to the first day of the tax year or as ending with the last day of the calendar month ending nearest to the last day of the tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwages\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ has the same meaning as provided by the Internal Revenue Code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwithholding agent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any individual, fiduciary, estate, trust, corporation, partnership or association in whatever capacity acting and including all officers and employees of the state of Iowa, or any municipal corporation of the state of Iowa and of any school district or school board of the state, or of any political subdivision of the state of Iowa, or any tax-supported unit of government that is obligated to pay or has control of paying or does pay to any resident or nonresident of the state of Iowa or the resident\u8217\'3fs or nonresident\u8217\'3fs agent any wages that are subject to the Iowa income tax in the hands of such resident or nonresident, or any of the above-designated entities making payment or having control of making such payment of any taxable Iowa income to any nonresident. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwithholding agent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall also include an officer or employee of a corporation or association, or a member or employee of a partnership, who as such officer, employee, or member has the responsibility to perform an act under }}}{{\f5\fs18\hyphpar0\qj{section 422.16}}}{{\f5\fs18\hyphpar0\qj{ and who subsequently knowingly violates the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 422.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.036;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.4}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 132, \'a71, 2, 9}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1023, \'a71, 30}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1203, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 179, \'a71, 2, 21, 23}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a726, 27}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/87/CH0001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 1st Ex, ch 1, \'a71}}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/87/CH0001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 2nd Ex, ch 1, \'a71}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1028, \'a72 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 268, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1107, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1133, \'a72, 16}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1197, \'a71 \u8211\'3f 4, 13, 18}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 111, \'a71, 8}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 152, \'a72, 40}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7163}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a770, 97, 98, 101 \u8211\'3f 103, 133, 134}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 152, \'a71, 15}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a769}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 422.7(27)(a)}}}{{\f5\fs12\hyphpar0\qj{, 422.25A}}}{{\f5\fs12\hyphpar0\qj{, 422.32}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}{{\f5\fs12\hyphpar0\qj{, 423.14A}}}{{\f5\fs12\hyphpar0\qj{, 425.23}}}{{\f5\fs12\hyphpar0\qj{, 476.20}}}{{\f5\fs12\hyphpar0\qj{, 502.511}}}{{\f5\fs12\hyphpar0\qj{, 541B.2}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2018 amendments to subsection 1, paragraphs b and c, strike of subsection 2, and strike and rewrite of subsection 15, are effective January 1, 2023, and apply to tax years beginning on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2018 Acts, ch 1161, \'a7133, 134}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a71}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.5}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Tax imposed \u8212\'3f exclusions \u8212\'3f alternate tax rate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax is imposed upon every resident and nonresident of the state which tax shall be levied, collected, and paid annually upon and with respect to the entire taxable income as defined in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ at a rate of three and eight-tenths percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax imposed upon the taxable income of a nonresident shall be computed by reducing the amount determined pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ by the amounts of nonrefundable credits under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and by multiplying this resulting amount by a fraction of which the nonresident\u8217\'3fs net income allocated to Iowa, as determined in }}}{{\f5\fs18\hyphpar0\qj{section 422.8, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, is the numerator and the nonresident\u8217\'3fs total net income computed under }}}{{\f5\fs18\hyphpar0\qj{section 422.7}}}{{\f5\fs18\hyphpar0\qj{ is the denominator. This subparagraph also applies to individuals who are residents of Iowa for less than the entire tax year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax imposed upon the taxable income of a resident shareholder in an S corporation or of an estate or trust with a situs in Iowa that is a shareholder in an S corporation, which S corporation has in effect for the tax year an election under subchapter S of the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and carries on business within and without the state, may be computed by reducing the amount determined pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ by the amounts of nonrefundable credits under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and by multiplying this resulting amount by a fraction of which the resident\u8217\'3fs or estate\u8217\'3fs or trust\u8217\'3fs net income allocated to Iowa, as determined in }}}{{\f5\fs18\hyphpar0\qj{section 422.8, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, is the numerator and the resident\u8217\'3fs or estate\u8217\'3fs or trust\u8217\'3fs total net income computed under }}}{{\f5\fs18\hyphpar0\qj{section 422.7}}}{{\f5\fs18\hyphpar0\qj{ is the denominator. If a resident shareholder, or an estate or trust with a situs in Iowa that is a shareholder, has elected to take advantage of this subparagraph (2), and for the next tax year elects not to take advantage of this subparagraph, the resident or estate or trust shareholder shall not reelect to take advantage of this subparagraph for the three tax years immediately following the first tax year for which the shareholder elected not to take advantage of this subparagraph, unless the director consents to the reelection. This subparagraph also applies to individuals who are residents of Iowa for less than the entire tax year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subparagraph (2) shall not affect the amount of the taxpayer\u8217\'3fs checkoffs under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, the credits from tax provided under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, and the allocation of these credits between spouses if the taxpayers filed separate returns.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax shall not be imposed on a resident or nonresident whose net income, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.7}}}{{\f5\fs18\hyphpar0\qj{, is thirteen thousand five hundred dollars or less in the case of married persons filing jointly, heads of household, and surviving spouses or nine thousand dollars or less in the case of all other persons; but in the event that the payment of tax under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ would reduce the net income to less than thirteen thousand five hundred dollars or nine thousand dollars as applicable, then the tax shall be reduced to that amount which would result in allowing the taxpayer to retain a net income of thirteen thousand five hundred dollars or nine thousand dollars as applicable. The preceding sentence does not apply to estates or trusts. For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the entire net income, including any part of the net income not allocated to Iowa, shall be taken into account. In calculating net income for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, any amount of itemized or standard deduction, personal exemption deduction, or qualified business income deduction that was allowed as a deduction in computing federal taxable income under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall be added back. If the combined net income of a husband and wife exceeds thirteen thousand five hundred dollars, neither of them shall receive the benefit of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, and it is immaterial whether they file a joint return or separate returns. However, if a husband and wife file separate returns and have a combined net income of thirteen thousand five hundred dollars or less, neither spouse shall receive the benefit of this paragraph, if one spouse has a net operating loss and elects to carry back or carry forward the loss as provided under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ or in }}}{{\f5\fs18\hyphpar0\qj{section 422.9}}}{{\f5\fs18\hyphpar0\qj{. A person who is claimed as a dependent by another person as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.12}}}{{\f5\fs18\hyphpar0\qj{ shall not receive the benefit of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if the person claiming the dependent has net income exceeding thirteen thousand five hundred dollars or nine thousand dollars as applicable or the person claiming the dependent and the person\u8217\'3fs spouse have combined net income exceeding thirteen thousand five hundred dollars or nine thousand dollars as applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the computation in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, if the married persons\u8217\'3f filing jointly, head of household\u8217\'3fs, or surviving spouse\u8217\'3fs net income exceeds thirteen thousand five hundred dollars, the regular tax imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be the lesser of the alternate state individual income tax rate of four and three-tenths percent times the portion of the net income in excess of thirteen thousand five hundred dollars or the regular tax liability computed without regard to this sentence. Taxpayers electing to file separately shall compute the alternate tax described in this paragraph using the total net income of the spouses. The alternate tax described in this paragraph does not apply if one spouse elects to carry back or carry forward a net operating loss as provided under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ or in }}}{{\f5\fs18\hyphpar0\qj{section 422.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax shall not be imposed on a resident or nonresident who is at least sixty-five years old on December 31 of the tax year and whose net income, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.7}}}{{\f5\fs18\hyphpar0\qj{, is thirty-two thousand dollars or less in the case of married persons filing jointly, heads of household, and surviving spouses or twenty-four thousand dollars or less in the case of all other persons; but in the event that the payment of tax under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ would reduce the net income to less than thirty-two thousand dollars or twenty-four thousand dollars as applicable, then the tax shall be reduced to that amount which would result in allowing the taxpayer to retain a net income of thirty-two thousand dollars or twenty-four thousand dollars as applicable. The preceding sentence does not apply to estates or trusts. For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the entire net income, including any part of the net income not allocated to Iowa, shall be taken into account. In calculating net income for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, any amount of itemized or standard deduction, personal exemption deduction, or qualified business income deduction that was allowed as a deduction in computing federal taxable income under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall be added back. If the combined net income of a husband and wife exceeds thirty-two thousand dollars, neither of them shall receive the benefit of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, and it is immaterial whether they file a joint return or separate returns. However, if a husband and wife file separate returns and have a combined net income of thirty-two thousand dollars or less, neither spouse shall receive the benefit of this paragraph, if one spouse has a net operating loss and elects to carry back or carry forward the loss as provided under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ or in }}}{{\f5\fs18\hyphpar0\qj{section 422.9}}}{{\f5\fs18\hyphpar0\qj{. A person who is claimed as a dependent by another person as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.12}}}{{\f5\fs18\hyphpar0\qj{ shall not receive the benefit of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if the person claiming the dependent has net income exceeding thirty-two thousand dollars or twenty-four thousand dollars as applicable or the person claiming the dependent and the person\u8217\'3fs spouse have combined net income exceeding thirty-two thousand dollars or twenty-four thousand dollars as applicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the computation in }}}{{\f5\fs18\hyphpar0\qj{subsection 1 or 2}}}{{\f5\fs18\hyphpar0\qj{, if the married persons\u8217\'3f filing jointly, head of household\u8217\'3fs, or surviving spouse\u8217\'3fs net income exceeds thirty-two thousand dollars, the regular tax imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be the lesser of the alternate state individual income tax rate of four and three-tenths percent times the portion of the net income in excess of thirty-two thousand dollars or the regular tax liability computed without regard to this sentence. Taxpayers electing to file separately shall compute the alternate tax described in this paragraph using the total net income of the spouses. The alternate tax described in this paragraph does not apply if one spouse elects to carry back or carry forward a net operating loss as provided under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ or in }}}{{\f5\fs18\hyphpar0\qj{section 422.9}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies even though one spouse has not attained the age of sixty-five, if the other spouse is at least sixty-five at the end of the tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax levied under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be computed and collected as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall apply to all salaries received by federal officials or employees of the United States government as provided for herein.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state income tax of a taxpayer whose net income includes the gain or loss from the forfeiture of an installment real estate contract, the transfer of real or personal property securing a debt to a creditor in cancellation of that debt, or from the sale or exchange of property as a result of actual notice of foreclosure where the fair market value of the taxpayer\u8217\'3fs assets exceeds the taxpayer\u8217\'3fs liabilities immediately before such forfeiture, transfer, or sale or exchange shall not be greater than such excess, including any asset transferred within one hundred twenty days prior to such forfeiture, transfer, or sale or exchange. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, in the case of married taxpayers, except in the case of a husband and wife who live apart at all times during the tax year, the assets and liabilities of both spouses shall be considered in determining if the fair market value of the taxpayer\u8217\'3fs assets exceed the taxpayer\u8217\'3fs liabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the other taxes imposed by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a tax is imposed, except under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, on the amount of a lump sum distribution for which the taxpayer has elected under }}}{{\f5\fs18\hyphpar0\qj{section 402(e) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ to be separately taxed for federal income tax purposes for the tax year. The rate of tax is equal to twenty-five percent of the separate federal tax imposed on the amount of the lump sum distribution. A nonresident is liable for this tax only on that portion of the lump sum distribution allocable to Iowa. The total amount of the lump sum distribution subject to separate federal tax shall be included in net income for purposes of determining eligibility under }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{, as applicable, except the amount of the lump sum distribution exempt from state tax in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not be included.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of a lump sum distribution that is received from a governmental or other pension or retirement plan, including defined benefit or defined contribution plans, annuities, individual retirement accounts, plans maintained or contributed to by an employer, or maintained or contributed to by a self-employed person as an employer, and deferred compensation plans or any earnings attributable to the deferred compensation plans is exempt from state tax imposed under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ if received by a person who is disabled, or is fifty-five years of age or older, or is the surviving spouse of an individual or is a survivor having an insurable interest in an individual who would have qualified for the exemption under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for the tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of income derived from the sale or exchange of livestock which qualifies under section 451(e) of the Internal Revenue Code because of drought, the taxpayer may elect to include the income in the taxpayer\u8217\'3fs net income in the tax year following the year of the sale or exchange in accordance with rules prescribed by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an individual\u8217\'3fs federal income tax was forgiven for a tax year under section 692 of the Internal Revenue Code, because the individual was killed while serving in an area designated by the president of the United States or the United States Congress as a combat zone, the individual was missing in action and presumed dead, or the individual was killed outside the United States in a terroristic or military action while the individual was a military or civilian employee of the United States, the individual\u8217\'3fs Iowa income tax is also forgiven for the same tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a taxpayer repays in the current tax year certain amounts of income that were subject to tax under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ in a prior year and a tax benefit would be allowed under similar circumstances under section 1341 of the Internal Revenue Code, a tax benefit shall be allowed on the Iowa return. The tax benefit shall be the reduced tax for the current tax year due to the deduction for the repaid income or the reduction in tax for the prior year or years due to exclusion of the repaid income. The reduction in tax shall qualify as a refundable tax credit on the return for the current year pursuant to rules prescribed by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning on or after January 1, 2023, a taxpayer shall use the same filing status for Iowa income tax purposes as the taxpayer used for federal income tax purposes.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.037;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.5}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 132, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1023, \'a72, 31}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1064, \'a71, 2}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1226, \'a71, 2, 6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 179, \'a73, 20, 22}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 243, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1213, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1232, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1236, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 214, \'a72}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 1st Ex, ch 1, \'a72}}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 2nd Ex, ch 1, \'a72, 3}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1028, \'a75 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 228, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 251, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 268, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 296, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 159, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 196, \'a71}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 2nd Ex, ch 1001, \'a7217, 218, 224}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1166, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1197, \'a714, 15, 18}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1219, \'a727}}}{{\f5\fs