77.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a79, 10}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 34 applies retroactively to January 1, 2021, for tax years beginning on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0154.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 154, \'a72}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 amendment to subsection 37 applies retroactively to January 1, 2021, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 139, \'a711}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 amendment to subsection 38 applies retroactively to July 1, 2020, and applies to federal adjustments and federal partnership adjustments that have a final determination date after July 1, 2020; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 86, \'a732}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 repeal of subsection 39, former paragraph b, applies retroactively to January 1, 2021, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 177, \'a757}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 repeal of former subsection 39A applies retroactively to January 1, 2021, for tax years beginning on or after that date, and for qualified property placed in service on or after that date; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 177, \'a754}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 13 is effective January 1, 2023, and applies to sales consummated on or after January 1, 2023, for tax years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1002, \'a710, 11}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 14 is effective January 1, 2023, and applies to tax years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1002, \'a75, 6}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 19 by }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1002.pdf" }{\fldrslt \cf5 \f5 \fs12{{2022 Acts, ch 1002, \'a727}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{ is effective January 1, 2023, and applies to tax years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1002, \'a728, 29}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Former subsection 41 applies retroactively to January 1, 2022, for tax years beginning on or after January 1, 2022, but before January 1, 2023, for payments received in the 2022 calendar year; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1138, \'a772}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 42 is effective January 1, 2023, and applies to tax years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1002, \'a72, 3}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Repeal of former subsections 39, 39B, 43, and 53, relating to bonus depreciation under section 168 of the Internal Revenue Code or increased expensing under section 179 of the Internal Revenue Code, applies retroactively to property placed in service on or after January 1, 2023; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2018 Acts, ch 1161, \'a7118, 133, 134}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a71}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH0115.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 115, \'a74, 6}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 43 applies retroactively to tax years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 1, \'a711}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 4 applies retroactively to January 1, 2023, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 115, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 5, paragraph a applies retroactively to January 1, 2023, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 115, \'a712}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 13, paragraph a, subparagraph (4) applies retroactively to January 1, 2023, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 115, \'a758}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 14, paragraph f, subparagraph (6) applies retroactively to January 1, 2023, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 115, \'a758}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendments to subsection 19, paragraphs a and c apply retroactively to January 1, 2024, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1138, \'a714}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 22, paragraph c, subparagraph (1), subparagraph division (g) applies retroactively to January 1, 2024, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1147, \'a73}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 44 applies retroactively to January 1, 2023, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1160, \'a72}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 45 applies retroactively to tax years beginning on or after January 1, 2024; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a726}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Former subsection 41 repealed by its own terms effective January 1, 2026; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2022/CH1138.pdf" }{\fldrslt \cf5 \f5 \fs12{{2022 Acts, ch 1138, \'a770}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, NEW paragraph u}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 14, paragraph a amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 14, paragraph f, NEW subparagraph (4) and former subparagraphs (4) and (5) rennumbered as (5) and (6) }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 45}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.8}}}{\*\bkmkstart stylerid1_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Allocation of income earned in Iowa and other states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Under rules prescribed by the director, net income of individuals, estates, and trusts shall be allocated as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of income tax paid to another state or foreign country by a resident taxpayer of this state on income derived from sources outside of Iowa shall be allowed as a credit against the tax computed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, except that the credit shall not exceed what the amount of the Iowa tax would have been on the same income which was taxed by the other state or foreign country. The limitation on this credit shall be computed according to the following formula:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Income earned outside of Iowa and taxed by another state or foreign country shall be divided by the total income of the resident taxpayer of Iowa. This quotient multiplied by the net Iowa tax as determined on the total income of the taxpayer as if entirely earned in Iowa shall be the maximum tax credit against the Iowa net tax.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a resident partner of an entity taxed as a partnership for federal tax purposes, a resident shareholder of an S corporation, or a resident beneficiary of an estate or trust shall be deemed to have paid the resident partner\u8217\'3fs, resident shareholder\u8217\'3fs, or resident beneficiary\u8217\'3fs pro rata share of entity-level income tax paid by the partnership, S corporation, estate, or trust to another state or foreign country on income that is also subject to tax under this subchapter, but only if the entity provides the resident partner, resident shareholder, or resident beneficiary a statement that documents the resident partner\u8217\'3fs, resident shareholder\u8217\'3fs, or resident beneficiary\u8217\'3fs share of the income derived in the other state or foreign country, the income tax liability of the entity in that state or foreign country, and the income tax paid by the entity to that state or foreign country.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a resident shareholder of a regulated investment company shall be deemed to have paid the shareholder\u8217\'3fs pro rata share of entity-level income tax paid by the regulated investment company to another state or foreign country and treated as paid by its shareholders pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 853 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, but only if the regulated investment company provides the resident shareholder a statement that documents the resident shareholder\u8217\'3fs share of the income derived in the other state or foreign country, the income tax liability of the regulated investment company in that state or foreign country, and the income tax paid by the regulated investment company to that state or foreign country.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonresident\u8217\'3fs net income allocated to Iowa is the net income, or portion of net income, which is derived from a business, trade, profession, or occupation carried on within this state or income from any property, trust, estate, or other source within Iowa. However, income derived from a business, trade, profession, or occupation carried on within this state and income from any property, trust, estate, or other source within Iowa shall not include distributions from pensions, including defined benefit or defined contribution plans, annuities, individual retirement accounts, and deferred compensation plans or any earnings attributable thereto so long as the distribution is directly related to an individual\u8217\'3fs documented retirement and received while the individual is a nonresident of this state. If a business, trade, profession, or occupation is carried on partly within and partly without the state, only the portion of the net income which is fairly and equitably attributable to that part of the business, trade, profession, or occupation carried on within the state is allocated to Iowa for purposes of }}}{{\f5\fs18\hyphpar0\qj{section 422.5, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 422.13}}}{{\f5\fs18\hyphpar0\qj{ and income from any property, trust, estate, or other source partly within and partly without the state is allocated to Iowa in the same manner, except that annuities, interest on bank deposits and interest-bearing obligations, and dividends are allocated to Iowa only to the extent to which they are derived from a business, trade, profession, or occupation carried on within the state. Net income described in }}}{{\f5\fs18\hyphpar0\qj{section 29C.24, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), and paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), shall not be allocated and apportioned to the state, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 29C.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A resident\u8217\'3fs income, or the income of an estate or trust with a situs in Iowa, allocable to Iowa is the income determined under }}}{{\f5\fs18\hyphpar0\qj{section 422.7}}}{{\f5\fs18\hyphpar0\qj{ reduced by items of income and expenses from an S corporation that carries on business within and without the state when those items of income and expenses pass directly to the shareholders under provisions of the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{. These items of income and expenses are increased by the greater of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The net income or loss of the corporation which is fairly and equitably attributable to this state under }}}{{\f5\fs18\hyphpar0\qj{section 422.33, subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any cash or the value of property distributions which are made only to the extent that they are paid from income upon which Iowa income tax has not been paid, as determined under rules of the director, reduced by the amount of any of these distributions that are made to enable the shareholder to pay federal income tax on items of income, loss, and expenses from the corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Taxable income of resident and nonresident estates and trusts shall be allocated in the same manner as individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may, in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, and when cost-efficient, administratively feasible, and of mutual benefit to both states, enter into reciprocal agreements with tax administration agencies of other states to further tax administration and eliminate duplicate withholding by exempting from Iowa taxation income earned from personal services in Iowa by residents of another state, if the other state provides a tax exemption for the same type of income earned from personal services by Iowa residents in the other state. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fincome earned from personal services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means wages, salaries, commissions, and tips, and earned income from other sources. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not authorize the department to withhold taxes on deferred compensation payments, pension distributions, and annuity payments when paid to a nonresident of the state of Iowa. All the terms of the agreements shall be described in the rules adopted by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A reciprocal agreement entered into on or after April 4, 2002, with a tax administration agency of another state shall not take effect until such agreement has been authorized by a constitutional majority of each house of the general assembly and approved by the governor. A reciprocal agreement in effect on or after January 1, 2002, shall not be terminated by the state of Iowa unless the termination has been authorized by a constitutional majority of each house of the general assembly and approved by the governor. An amendment to an existing reciprocal agreement does not constitute a new agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the resident or part-year resident is a shareholder of an S corporation which has in effect an election under subchapter S of the Internal Revenue Code, }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 3}}}{{\f5\fs18\hyphpar0\qj{ do not apply to any income taxes paid to another state or foreign country on the income from the corporation which has in effect an election under subchapter S of the Internal Revenue Code.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f8; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.037, 6943.040, 6943.050;}}}{ C46, 50, 54, 58, \'a7422.5, 422.8, 422.18; C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.5}}}{, }{{\f5\fs18\hyphpar0\qj{422.8}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1226, \'a73, 6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 16, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 243, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1028, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1224, \'a71, 2, 4}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1149, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1197, \'a716 \u8211\'3f 18}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 111, \'a75, 6, 8}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1005, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1069, \'a75, 12, 14}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a7242}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7121, 123, 124}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1095, \'a73, 14, 15}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1161.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2018 Acts, ch 1161, \'a777, 97, 98, 119, 133, 134}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a7115 \u8211\'3f 117}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a72.48}}}{{\f5\fs12\hyphpar0\qj{, 29C.24}}}{{\f5\fs12\hyphpar0\qj{, 260E.2}}}{{\f5\fs12\hyphpar0\qj{, 422.5}}}{{\f5\fs12\hyphpar0\qj{, 422.12B}}}{{\f5\fs12\hyphpar0\qj{, 422.13}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.25A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2018 strike of former subsection 4 takes effect January 1, 2023, and applies to tax years beginning on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2018 Acts, ch 1161, \'a7134}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a71}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.9}}}{\*\bkmkstart stylerid1_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Carry over of Iowa net operating loss.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any Iowa net operating loss carried over from a taxable year beginning prior to January 1, 2023, may be deducted as provided in }{{\f5\fs18\hyphpar0\qj{section 422.9, subsection 3}}}{, Code 2018.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1161, \'a7120, 133, 134}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.4}}}{{\f5\fs12\hyphpar0\qj{, 422.5}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For text, history, and footnotes pertaining to deductions from net income prior to January 1, 2023, see }{{\f5\fs12\hyphpar0\qj{\'a7422.9, Code 2022}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section is effective January 1, 2023, and applies to tax years beginning on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2018 Acts, ch 1161, \'a7133, 134}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a71}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.10}}}{\*\bkmkstart stylerid1_2E6_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Research activities credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by a state tax credit for increasing research activities in this state through the tax year beginning on or after January 1, 2025, but before January 1, 2026.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual shall only be eligible for the credit provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ if the business conducting the research meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business is engaged in the manufacturing, life sciences, agriscience, software engineering, or aviation and aerospace industry.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons that shall not be considered to be engaged in the manufacturing, life sciences, agriscience, software engineering, or aviation and aerospace industry, and thus are not eligible for the credit, include but are not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(A)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person engaged in agricultural production as defined in }}}{{\f5\fs18\hyphpar0\qj{section 423.1}}}{{\f5\fs18\hyphpar0\qj{ except if the credit is based on conducting agriscience research as defined in subparagraph part (B) and the person or the business is engaged in bovine and porcine veterinary research, the person shall not be considered to be engaged in agricultural production as defined in }}}{{\f5\fs18\hyphpar0\qj{section 423.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(B)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this subparagraph subdivision, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fagriscience research\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means research that is approved and overseen or monitored by a board that includes, at a minimum, an individual who was employed with, contracted by, or professionally trained by an accredited university as a researcher in an applied animal science and an individual holding a doctor of veterinary medicine or a doctoral degree in an applied animal science; is conducted in this state in an applied animal science; improves the scientific knowledge base or increases scientific innovation, performance, or viability within this state; the results of the research are evaluated by a person educated and trained in statistics by an accredited university and capable of applying generally accepted methodologies to the results in accordance with industry standards in an applied animal science; and the results of the research are made available to the public by submission to or publication in a journal, magazine, or similar periodical, if the statistical evaluation indicated the research is reliable and relevant to an applied animal science.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(C)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this subparagraph subdivision, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fapplied animal science\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the areas of animal science, veterinary medicine, nutritional science, genetic science, and microbiology.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is a contractor, subcontractor, builder, or a contractor-retailer that engages in commercial and residential repair and installation, including but not limited to heating or cooling installation and repair, plumbing and pipe fitting, security system installation, and electrical installation and repair. For purposes of this subparagraph subdivision, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcontractor-retailer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business that makes frequent retail sales to the public or to other contractors and that also engages in the performance of construction contracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A finance or investment company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(v)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A wholesaler.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(vi)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A transportation company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(vii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A publisher.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(viii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agricultural cooperative association as defined in }}}{{\f5\fs18\hyphpar0\qj{section 502.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ix)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A real estate company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(x)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A collection agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(xi)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(xii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An architect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business claims and is allowed a research credit for such qualified research expenses under }}}{{\f5\fs18\hyphpar0\qj{section 41 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ for the same taxable year as it is claiming the credit provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The credit provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is claimed on a return filed by the due date for filing the return, including extensions of time. If timely claimed, the business shall not increase the credit claim on an amended return or otherwise unless either of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amended return is filed within six months of the due date for filing the return which includes extensions of time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The increase results from an audit or examination by the internal revenue service or the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For individuals, the credit equals the sum of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six and one-half percent of the excess of qualified research expenses during the tax year over the base amount for the tax year based upon the state\u8217\'3fs apportioned share of the qualifying expenditures for increasing research activities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six and one-half percent of the basic research payments determined under section 41(e)(1)(A) of the Internal Revenue Code during the tax year based upon the state\u8217\'3fs apportioned share of the qualifying expenditures for increasing research activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state\u8217\'3fs apportioned share of the qualifying expenditures for increasing research activities is a percent equal to the ratio of qualified research expenditures in this state to total qualified research expenditures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of calculating the state\u8217\'3fs apportioned share of the qualifying expenditures for increasing research activities in subparagraph (2), the following criteria shall apply only to the determination of qualified research expenditures in this state:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wages paid to an employee for qualified services, or contract research expenses paid to a third party for the performance of qualified research services, shall only constitute qualified research expenses in this state if the services are performed in this state, and if the following conditions are met, as applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For qualified services performed by employees, during the period of the tax year that the business is engaging in one or more research projects, a majority of the total services performed by the employee for the business are directly related to those research projects. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the performance of qualified research services by a third party, during the period of the business\u8217\'3fs tax year that the third party is performing research services for the business, a majority of the total services performed by the person for the third party are directly related to those research projects of the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The substantially all rule for determining qualified services as described in }}}{{\f5\fs18\hyphpar0\qj{section 41(b)(2)(B) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj\cf1{Treas. Reg. 1.41-2(d)(2)}}}{{\f5\fs18\hyphpar0\qj{ does not apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amounts paid for the right to use computers as described in }}}{{\f5\fs18\hyphpar0\qj{section 41(b)(2)(A)(iii) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall not be qualified research expenses in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning on or after January 1, 2023, but before January 1, 2027, amounts paid for supplies as defined in }}}{{\f5\fs18\hyphpar0\qj{section 41(b)(2)(C) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall only constitute qualified research expenses in this state if the supplies directly relate to research performed in this state and shall be limited to the following allowable percentages:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2023, but before January 1, 2024, eighty percent of the amounts paid for supplies directly related to research performed in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2024, but before January 1, 2025, sixty percent of the amounts paid for supplies directly related to research performed in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2025, but before January 1, 2026, forty percent of the amounts paid for supplies directly related to research performed in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning on or after January 1, 2026, amounts paid for supplies as defined in }}}{{\f5\fs18\hyphpar0\qj{section 41(b)(2)(C) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall not be qualified research expenses in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the credit amount computed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (a), a taxpayer shall elect to compute the credit amount for qualified research expenses incurred in this state in a manner consistent with the alternative simplified credit described in }}}{{\f5\fs18\hyphpar0\qj{section 41(c)(4) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ if the taxpayer elected or was required to use the alternative simplified credit method for federal income tax purposes for the same taxable year. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of the alternate credit computation method in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the following criteria shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The credit percentages applicable to qualified research expenses described in }}}{{\f5\fs18\hyphpar0\qj{section 41(c)(4)(A)}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{clause (ii) of section 41(c)(4)(B) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ are four and fifty-five hundredths percent and one and ninety-five hundredths percent, respectively.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Basic research payments and qualified research expenses shall only include amounts for research conducted in this state. A taxpayer\u8217\'3fs qualified research expenses in this state and average prior year qualified research expenses in this state shall be determined in accordance with the criteria in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, an individual may claim a research credit incurred by a partnership, S corporation, limited liability company, estate, or trust electing to have the income taxed directly to the individual. The amount claimed by the individual shall be based upon the pro rata share of the individual\u8217\'3fs earnings of a partnership, S corporation, limited liability company, estate, or trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbase amount\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the product of the fixed-based percentage times the average annual gross receipts of the taxpayer for the four taxable years preceding the taxable year for which the credit is being determined, but in no event shall the base amount be less than fifty percent of the qualified research expenses for the credit year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbasic research payment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualified research expense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the same as defined for the federal credit for increasing research activities under }}}{{\f5\fs18\hyphpar0\qj{section 41 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, except as otherwise described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), and }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following percentage of any credit in excess of the tax liability imposed by }}}{{\f5\fs18\hyphpar0\qj{section 422.5}}}{{\f5\fs18\hyphpar0\qj{ less the amounts of nonrefundable credits allowed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ for the taxable year shall be refunded with interest in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2023, but before January 1, 2024, ninety percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2024, but before January 1, 2025, eighty percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2025, but before January 1, 2026, seventy percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2026, but before January 1, 2027, sixty percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of claiming a refund pursuant to this paragraph, a taxpayer may elect to have the overpayment otherwise eligible for a refund shown on the taxpayer\u8217\'3fs final, completed return credited to the tax liability for the following taxable year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Commencing with tax years beginning on or after January 1, 2027, fifty percent of any credit in excess of the tax liability imposed by }}}{{\f5\fs18\hyphpar0\qj{section 422.5}}}{{\f5\fs18\hyphpar0\qj{ less the amounts of nonrefundable credits allowed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ for the taxable year shall be refunded with interest in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. In lieu of claiming a refund, a taxpayer may elect to have the overpayment otherwise eligible for a refund shown on the taxpayer\u8217\'3fs final, completed return credited to the tax liability for the following taxable year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In applying the credit in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ against tax liability and computing the eligible refund amount, the credit shall be applied after all nonrefundable credits available to the taxpayer are applied, but before any other refundable credit available to the taxpayer is applied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall by February 15 of each year issue an annual report to the general assembly containing the total amount of all claims made by employers under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the portion of the claims issued as refunds, for all claims processed during the previous calendar year. The report shall contain the name of each claimant for whom a tax credit in excess of five hundred thousand dollars was issued and the amount of the credit received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ is repealed January 1, 2027.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 179, \'a78, 25}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 230, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1007, \'a722}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 2nd Ex, ch 1, \'a710}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1028, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1171, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 159, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 215, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 113, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1166, \'a77, 11}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 152, \'a74, 7}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 23, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 135, \'a76, 9}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1078, \'a76, 10}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 95, \'a77, 12, 13}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1146, \'a74, 9, 11}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1194, \'a79, 21}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, 