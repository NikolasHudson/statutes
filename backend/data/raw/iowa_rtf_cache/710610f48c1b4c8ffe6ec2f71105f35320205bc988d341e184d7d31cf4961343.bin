0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a71}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Composite return unused tax credit carryforwards from tax year 2021; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a752}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.14}}}{\*\bkmkstart stylerid1_2E6_2E61_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E61_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Return by fiduciary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fiduciary subject to taxation under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.6}}}{{\f5\fs18\hyphpar0\qj{, shall make a return, signed in accordance with forms and rules prescribed by the director, for the individual, estate, or trust for whom or for which the fiduciary acts, if the taxable income thereof amounts to six hundred dollars or more. A nonresident fiduciary shall file a copy of the federal income tax return for the current tax year with the return required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A fiduciary required to file a return under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall file the return in an electronic format as specified by the department in a tax year in which any of the following circumstances apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual, estate, or trust for whom or which the fiduciary acts has two hundred fifty thousand dollars or more in gross receipts, as defined by rule by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fiduciary is required to provide ten or more schedules K-1 to the beneficiaries.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fiduciary reports twenty-five thousand dollars or more of Iowa tax credits on the return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies to any form or schedule supporting a return required to be electronically filed or any amended return if the amended return meets any of the circumstances requiring electronic filing in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department may provide an exception to the electronic filing requirement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A return subject to the electronic filing requirement in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that is filed in a manner other than an electronic format specified by the department shall not be considered a valid return unless the department provides an exception pursuant to this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Under such regulations as the director may prescribe, a return may be made by one of two or more joint fiduciaries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fiduciaries required to make returns under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to all the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ which apply to individuals.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f14; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.046;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 251, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a73, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a729C.24}}}{{\f5\fs12\hyphpar0\qj{, 421.60}}}{{\f5\fs12\hyphpar0\qj{, 422.13}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.16B}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 1 applies to tax years ending on or after December 31, 2023, or for tax years ending on or after December 31 of the calendar year in which the department of revenue implements a system for receiving the electronic returns, whichever is later; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.15}}}{\*\bkmkstart stylerid1_2E6_2E62_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E62_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Information at source.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every person or corporation being a resident of or having a place of business in this state, including lessees or mortgagors of real or personal property, fiduciaries, employers and all officers and employees of the state or of any political subdivision of the state, or agent of the person or corporation, having the control, receipt, custody, disposal or payment of interest other than interest coupons payable to bearer, rent, salaries, wages, premiums, annuities, compensations, remunerations, emoluments, unemployment compensation, royalties, patronage dividends, or other fixed or determinable annual or periodical gains, profits and income, in an amount sufficient to require that an information return be filed under the Internal Revenue Code if the income is subject to federal tax, paid or payable during any year to any individual, whether a resident of this state or not, shall make a complete information return under such regulations and in such form and manner and to such extent as may be prescribed by the director. However, the person or corporation shall not be required to file an information return if the information is available to the department from the internal revenue service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every partnership, including limited partnerships, doing business in this state, or deriving income from sources within this state as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.32, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall make a return, stating specifically the net income and capital gains or losses reported on the federal partnership return, the names and addresses of the partners, and their respective shares in said amounts.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A partnership required to file a return under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall file the return in an electronic format specified by the department in a tax year in which any of the following circumstances apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The partnership has two hundred fifty thousand dollars or more in total gross receipts, as defined by rule by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The partnership is required to provide ten or more Iowa schedules K-1 to the partners.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The partnership reports twenty-five thousand dollars or more of Iowa tax credits on the return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies to any form or schedule supporting a return required to be electronically filed or any amended return if the amended return meets any of the circumstances requiring electronic filing in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department may provide an exception to the electronic filing requirement. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A return subject to the electronic filing requirement in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that is filed in a manner other than an electronic format specified by the department shall not be considered a valid return unless the department provides an exception pursuant to this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every fiduciary shall make a return for the individual, estate, or trust for whom or for which the fiduciary acts, and shall set forth in such return the taxable income, the names and addresses of the beneficiaries, and the amounts distributed or distributable to each as reported on the federal fiduciary income tax return. Such return may be made by one or two or more joint fiduciaries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsections 1, 2, and 3}}}{{\f5\fs18\hyphpar0\qj{, or any other provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, withholding of income tax and any reporting requirement shall not be imposed upon a person, corporation, or withholding agent or any payor of deferred compensation, pensions, or annuities with regard to such payments made to a nonresident of the state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f15; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.047;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.15}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1103, \'a71110}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1224, \'a73, 4}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/92/CH1001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 2nd Ex, ch 1001, \'a7237, 250}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1021, \'a7110, 117, 118}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a7122 \u8211\'3f 124}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a7160}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a74, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715.107}}}{{\f5\fs12\hyphpar0\qj{, 29C.24}}}{{\f5\fs12\hyphpar0\qj{, 421.27}}}{{\f5\fs12\hyphpar0\qj{, 422.13}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.16B}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 2 applies to tax years ending on or after December 31, 2022, or for tax years ending on or after December 31 of the calendar year in which the department of revenue implements a system for receiving the electronic returns, whichever is later; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.16}}}{\*\bkmkstart stylerid1_2E6_2E63_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E63_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Withholding of income tax at source }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ interest }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ declaration of estimated tax }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ bond.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwithholding agent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any individual, fiduciary, estate, trust, corporation, partnership or association in whatever capacity acting and including all officers and employees of the state of Iowa, or any municipal corporation of the state of Iowa and of any school district or school board of the state, or of any political subdivision of the state of Iowa, or any tax-supported unit of government that is obligated to pay or has control of paying or does pay to any resident or nonresident of the state of Iowa or the resident\u8217\'3fs or nonresident\u8217\'3fs agent any wages that are subject to the Iowa income tax in the hands of such resident or nonresident, or any of the above-designated entities making payment or having control of making such payment of any taxable Iowa income to any nonresident. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwithholding agent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall also include an officer or employee of a corporation or association, or a member or employee of a partnership, who as such officer, employee, or member has the responsibility to perform an act under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and who subsequently knowingly violates the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwithholding agent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall also include every employer as defined in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and further defined in the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every withholding agent paying wages to an Iowa resident, or nonresident working in Iowa, shall deduct and withhold from the wages an amount which will approximate the annual tax liability of the person on a calendar year basis, calculated on the basis of tables to be prepared by the department and schedules or percentage rates, based on the wages, to be prescribed by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every employee or other person shall declare to the withholding agent the amount of the employee\u8217\'3fs or other person\u8217\'3fs withholding allowance to be used in applying the tables and schedules or percentage rates. However, the amount of withholding allowance declared shall not exceed the amount to which the employee or other person is entitled except as allowed under }}}{{\f5\fs18\hyphpar0\qj{sections 3402(m)(1)}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{3402(m)(3) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and as allowed by rules prescribed by the director. The claiming of an amount of withholding allowance in excess of entitlement is a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a nonresident having income subject to taxation by Iowa, but not subject to withholding of such tax under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 422.16B}}}{{\f5\fs18\hyphpar0\qj{, a withholding agent shall withhold from such income at the same rate as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. A withholding agent and nonresident shall be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, according to the context, except that a withholding agent may be absolved of the requirement to withhold taxes from the income of a nonresident upon receipt of a certificate from the department issued in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 422.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a nonresident having income from a trade or business carried on by the nonresident in whole or in part within the state of Iowa, the nonresident shall be considered to be subject to the provisions of this paragraph unless such trade or business is of such nature that the business entity itself, as a withholding agent, is required to and does withhold Iowa income tax from the distributions made to such nonresident from such trade or business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, at a rate specified by the department, state income tax shall be withheld from pensions, annuities, other similar periodic payments, and other income payments under }}}{{\f5\fs18\hyphpar0\qj{sections 3402(o)}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{3402(p)}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{3402(s)}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{3405(a)}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{3405(b)}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{3405(c) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ made to Iowa residents if the payments are subject to Iowa tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, state income tax shall be withheld on winnings in excess of six hundred dollars derived from gambling activities authorized under }}}{{\f5\fs18\hyphpar0\qj{chapter 99B}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{99G}}}{{\f5\fs18\hyphpar0\qj{. State income tax shall be withheld on winnings in excess of one thousand dollars from gambling activities authorized under }}}{{\f5\fs18\hyphpar0\qj{chapter 99D}}}{{\f5\fs18\hyphpar0\qj{. State income tax shall be withheld on winnings in excess of one thousand two hundred dollars derived from slot machines authorized under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{. State income tax shall be withheld on winnings from sports wagering authorized under }}}{{\f5\fs18\hyphpar0\qj{chapter 99F}}}{{\f5\fs18\hyphpar0\qj{ whenever federal income tax is required to be withheld from the same winnings in accordance with the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, state income tax shall be withheld at the rate described in }}}{{\f5\fs18\hyphpar0\qj{section 422.5}}}{{\f5\fs18\hyphpar0\qj{ from supplemental wages of an employee in those circumstances in which the employer treats the supplemental wages as wholly separate from regular wages for purposes of withholding and federal income tax is withheld from the supplemental wages under }}}{{\f5\fs18\hyphpar0\qj{section 3402(g) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A withholding agent is not required to withhold state income tax from payments subject to taxation made to a nonresident for commodity credit certificates, grain, livestock, domestic fowl, or other agricultural commodities or products sold to a withholding agent by a nonresident or the nonresident\u8217\'3fs representative, if the withholding agent provides on forms prescribed by the department information relating to the sales required by the department to determine the state income tax liabilities of a nonresident. However, a withholding agent may elect to make estimated tax payments on behalf of a nonresident on the basis of the net income of the nonresident from the agricultural commodities or products, if the estimated tax payments are made on or before the last day of the first month after the end of the tax years of the nonresident.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonresidents engaged in any facet of feature film, television, or educational production using the film or videotape disciplines in the state are not subject to Iowa withholding if the employer has applied to the department for exemption from the withholding requirement and the department has determined that any nonresident receiving wages would be entitled to a credit against Iowa income taxes paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals described in }}}{{\f5\fs18\hyphpar0\qj{section 29C.24}}}{{\f5\fs18\hyphpar0\qj{ are not subject to withholding, as provided in that section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A withholding agent required to deduct and withhold tax under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall file a return on or before the last day of the month following the quarterly period on forms prescribed by the director and remit to the department the amount of tax due at the following frequencies:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A withholding agent shall remit income tax withheld on a quarterly basis if the withholding agent withholds less than six thousand dollars annually and no more than five hundred dollars in any one month. Payment shall be due on the same day as the quarterly return.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A withholding agent shall remit income tax withheld on a monthly basis if the withholding agent withholds more than five hundred dollars in any one month and not more than five thousand dollars in a semimonthly period. Payment shall be made on or before the fifteenth day of the month following the month of withholding, except that a deposit for the third month in a calendar quarter shall be due on the same day as the quarterly return.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A withholding agent shall remit income tax withheld on a semimonthly basis if the withholding agent withholds more than five thousand dollars in a semimonthly period. The first semimonthly deposit for the period from the first of the month through the fifteenth of the month is due on the twenty-fifth day of the month in which the withholding occurs. The second monthly deposit for the period from the sixteenth of the month through the end of the month is due on the tenth day of the month following the month in which the withholding occurs.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A withholding agent may elect to remit on an annual basis if the withholding agent employs not more than two employees and expects to employ the employees for the full calendar year. The electing withholding agent shall remit the full amount of income taxes required to be withheld from the wages of the employees for the full calendar year with the quarterly return for the first calendar quarter. The amount to be paid shall be computed as if the employees were employed for the full calendar year for the same wages and with the same pay periods as prevailed during the first quarter of the year with respect to such employees. The electing withholding agent shall only remit the lump sum payment with the written consent of all employees involved. The withholding agent shall be entitled to recover from the employee any part of the lump sum payment that represents an advance to the employee. If a withholding agent pays a lump sum with the first quarterly return, the withholding agent shall be excused from filing further quarterly returns for the calendar year involved unless the withholding agent hires other or additional employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every withholding agent on or before February 15 following the close of the calendar year in which the withholding occurs shall send to the department copies of income statements required by }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{. At the discretion of the director, the withholding agent shall not be required to send income statements if the information is available from the internal revenue service or other state or federal agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director has reason to believe that the collection of the tax provided for in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ is in jeopardy, the director may require the withholding agent to file a return as required in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and pay the tax at any time, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 422.30}}}{{\f5\fs18\hyphpar0\qj{. The director may authorize incorporated banks, trust companies, or other depositories authorized by law which are depositories or financial agents of the United States or of this state, to receive any tax imposed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, in the manner, at the times, and under the conditions the director prescribes. The director shall also prescribe the manner, times, and conditions under which the receipt of the tax by those depositories is to be treated as payment of the tax to the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director, in cooperation with the department of management, may periodically change the filing and remittance thresholds by administrative rule if in the best interest of the state and the taxpayer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every withholding agent who fails to withhold or pay to the department any sums required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to be withheld and paid, shall be personally, individually, and corporately liable to the state of Iowa, and any sum withheld in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall be deemed to be held in trust for the state of Iowa. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 489.304}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ applies to a member or manager of a limited liability company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event a withholding agent fails to withhold and pay over to the department any amount required to be withheld under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, such amount may be assessed against such withholding agent in the same manner as prescribed for the assessment of income tax under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{subchapter VI}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever the director determines that any withholding agent has failed to withhold or pay over to the department sums required to be withheld under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the unpaid amount shall be a lien as described in }}}{{\f5\fs18\hyphpar0\qj{section 422.26}}}{{\f5\fs18\hyphpar0\qj{, shall attach to the property of that withholding agent, and in all other respects the procedure with respect to such lien shall apply as set forth in }}}{{\f5\fs18\hyphpar0\qj{section 422.26}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every withholding agent required to deduct and withhold tax under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall furnish to each employee, nonresident, or other person with respect to the income paid by the employer or withholding agent to each employee, nonresident, or other person during the calendar year, on or before January 31 of the succeeding year, or, in the case of an employee, if the employment of the employee is terminated before the close of the calendar year, within thirty days from the day on which the last payment of wages or other taxable income is made, if requested by the employee, but not later than January 31 of the following year, an income statement showing all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and address of the employer or withholding agent, and the taxpayer identification number of the employer or withholding agent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the employee, nonresident, or other person and the taxpayer identification number of that employee, nonresident, or other person, together with the last known address of the employee, nonresident, or other person to whom wages or other taxable income has been paid during the period.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The gross amount of wages or other taxable income paid to the employee, nonresident, or other person.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total amount deducted and withheld as tax under the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total amount of federal income tax withheld.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An income statement required to be furnished by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ with respect to any wages or other taxable Iowa income or any additional information required to be displayed on the income statement shall be in such form or forms as the director may prescribe by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A withholding agent shall be liable for the payment of the tax required to be deducted and withheld or the amount actually deducted, whichever is greater, under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. Any amount deducted and withheld as tax under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ during any calendar year upon the wages of any employee, nonresident, or other person shall be allowed as a credit to the employee, nonresident, or other person against the tax imposed by }}}{{\f5\fs18\hyphpar0\qj{section 422.5}}}{{\f5\fs18\hyphpar0\qj{ for the tax year in which it was withheld, irrespective of whether or not such tax has been, or will be, paid by the withholding agent to the department as provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the amount of income tax withheld by the withholding agent on behalf of an employee, nonresident, or other person after complying with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is more than the income tax liability of said employee, nonresident, or other person as determined under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, the overpayment of tax may first be credited against any income tax or installment payment then due the state of Iowa by the employee, nonresident, or other person for the tax year, and any balance of one dollar or more shall be refunded to the employee, nonresident, or other person with interest in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amounts less than one dollar shall be refunded to the taxpayer, nonresident, or other person only upon written application, in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 422.73}}}{{\f5\fs18\hyphpar0\qj{, and only if the application is filed within twelve months after the due date of the return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Refunds in the amount of one dollar or more provided for by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be paid by the treasurer of state by warrants drawn by the director of the department of administrative services, or an authorized employee of the department of administrative services, and the taxpayer\u8217\'3fs return of income shall constitute a claim for refund for this purpose, except in respect to amounts of less than one dollar. There is appropriated, out of any funds in the state treasury not otherwise appropriated, a sum sufficient to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to any other penalty provided by law, a withholding agent required to furnish or file an income statement required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is subject to a civil penalty of five hundred dollars for each occurrence of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Willful failure to furnish an employee, nonresident, or other person with an income statement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Willfully furnishing an employee, nonresident, or other person with a false or fraudulent income statement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Willful failure to file an income statement with the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Willfully filing a false or fraudulent income statement with the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A withholding agent is subject to the penalty as provided in }}}{{\f5\fs18\hyphpar0\qj{section 421.27}}}{{\f5\fs18\hyphpar0\qj{. Any penalty assessed under }}}{{\f5\fs18\hyphpar0\qj{section 421.27}}}{{\f5\fs18\hyphpar0\qj{ shall be in addition to the tax or additional tax due under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The taxpayer shall also pay interest on the tax or additional tax at the rate in effect under }}}{{\f5\fs18\hyphpar0\qj{section 421.7}}}{{\f5\fs18\hyphpar0\qj{, for each month counting each fraction of a month as an entire month, computed from the date the semimonthly, monthly, or quarterly deposit form was required to be filed. The penalty and interest become a part of the tax due from the withholding agent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any withholding agent, being a domestic or foreign corporation, required under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to withhold on wages or other taxable Iowa income subject to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, fails to withhold the amounts required to be withheld, make the required returns or remit to the department the amounts withheld, the director may, having exhausted all other means of enforcement of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, certify such fact or facts to the secretary of state, who shall thereupon cancel the articles of incorporation or foreign registration statement, as the case may be, of such corporation, and the rights of such corporation to carry on business in the state of Iowa shall cease. The secretary of state shall immediately notify by registered mail such domestic or foreign corporation of the action taken by the secretary of state. The provisions of }}}{{\f5\fs18\hyphpar0\qj{section 422.40, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, shall be applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall, upon request of any fiduciary, furnish said fiduciary with a certificate of acquittance showing that no liability as a withholding agent exists with respect to the estate or trust for which said fiduciary acts, provided the department has determined that there is no such liability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Taxpayers filing a return shall make estimated tax payments if their Iowa income tax liability can reasonably be expected to amount to one thousand dollars or more for the year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the cases of farmers and fishermen, the exceptions provided in the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ with respect to making estimated payments apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The estimated tax shall be paid in quarterly installments. The first installment shall be paid on or before the last day of the fourth month of the taxpayer\u8217\'3fs tax year for which the estimated payments apply. The other installments shall be paid on or before the last day of the sixth month of the tax year, the last day of the ninth month of the tax year, and the last day of the first month after the tax year. A taxpayer may elect to pay an installment prior to the due date.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a taxpayer filing a return has reason to believe that the taxpayer\u8217\'3fs Iowa income tax may increase or decrease, either for purposes of meeting the requirement to make estimated tax payments or for the purpose of increasing or decreasing estimated tax payments, the taxpayer shall increase or decrease any subsequent estimated tax payments accordingly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any tax still payable after applying credits for taxes paid through withholding, estimated tax, and composite return tax, is due and payable on or before the end of the fourth month following the close of the tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a taxpayer is unable to make the taxpayer\u8217\'3fs estimated tax payments, the payments may be made by a duly authorized agent, or by the guardian or other person charged with the care of the person or property of the taxpayer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Estimated tax paid is a credit against the amount of tax found payable on a final, completed return, as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 10}}}{{\f5\fs18\hyphpar0\qj{, relating to the credit for the tax withheld against the tax found payable on a return properly and correctly prepared under }}}{{\f5\fs18\hyphpar0\qj{sections 422.5 through 422.25}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any overpayment of one dollar or more shall be refunded to the taxpayer and the return constitutes a claim for refund for this purpose. Amounts less than one dollar shall not be refunded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The method provided by }}}{{\f5\fs18\hyphpar0\qj{section 6654 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ for determining what is applicable to the addition to tax for underpayment of the tax payable applies to persons required to make payments of estimated tax under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ except the amount to be added to the tax for underpayment of estimated tax is an amount determined at the rate in effect under }}}{{\f5\fs18\hyphpar0\qj{section 421.7}}}{{\f5\fs18\hyphpar0\qj{. This addition to tax specified for underpayment of the tax payable is not subject to waiver provisions relating to reasonable cause, except as provided in the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{. Underpayment of estimated tax shall be determined in the same manner as provided under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the exceptions in the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ also apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of claiming a refund, the taxpayer may elect to have the overpayment shown on the taxpayer\u8217\'3fs final, completed return for the taxable year credited to the taxpayer\u8217\'3fs tax liability for the following taxable year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall enter into an agreement with the secretary of the treasury of the United States with respect to withholding of income tax as provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, pursuant to an Act of Congress, section 1207 of the }}}{{\f5\fs18\hyphpar0\qj{Tax Reform Act of 1976}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 94-455}}}{{\f5\fs18\hyphpar0\qj{, amending }}}{{\f5\fs18\hyphpar0\qj{5 U.S.C. \'a75517}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may, when necessary and advisable in order to secure the collection of the tax required to be deducted and withheld or the amount actually deducted, whichever is greater, require a withholding agent to file with the director a bond, issued by a surety company authorized to conduct business in this state and approved by the insurance commissioner as to solvency and responsibility, in an amount as the director may fix, to secure the payment of the tax and penalty due or which may become due. In lieu of the bond, securities shall be kept in the custody of the department and may be sold by the director at public or private sale, without notice to the depositor, if it becomes necessary to do so in order to recover any tax and penalty due. Upon a sale, any surplus above the amounts due under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be returned to the withholding agent who deposited the securities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the withholding agent fails to file the bond as requested by the director to secure collection of the tax, the withholding agent is subject to penalty for failure to file the bond. The penalty is equal to fifteen percent of the tax the withholding agent is required to withhold on an annual basis. However, the penalty shall not exceed five thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may allow additional time for filing documents required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ with the department in the case of illness, disability, absence, or if good cause is shown.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.048;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.16}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 131, \'a74 \u8211\'3f 6}}}{, }{{\f5\fs18\hyphpar0\qj{ch 133, \'a71, 4}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1022, \'a71, 2, 8}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1023, \'a729}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1180, \'a72, 8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 160, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 179, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1173, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1007, \'a723 \u8211\'3f 25}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1208, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1241, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 214, \'a74}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 1st Ex, ch 1, \'a726}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1028, \'a725, 26}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1157, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 6, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 251, \'a717, 18}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1172, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1248, \'a711}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[Unnumbered paragraph 2 of subsection 1 was inadvertently deleted in the 1991 Code and 1991 Code Supplement]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 215, \'a74, 8}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/92/CH1001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 2nd Ex, ch 1001, \'a7238}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1165, \'a713 \u8211\'3f 15, 45, 47, 48}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 151, \'a76, 89}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1151, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 178, \'a7111, 121}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 179, \'a7142}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 140, \'a740, 73}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a7101}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 185, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 186, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1162, \'a7135, 154, 155}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1184, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 116, \'a728 \u8211\'3f 30}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1095, \'a75, 14, 15}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a75, 15, 16, 126, 133, 134}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 151, \'a712, 13, 15}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1032, \'a758, 59}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a719 \u8211\'3f 22}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 5, \'a78 \u8211\'3f 10}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a76, 16, 17}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 7, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 148, \'a758 \u8211\'3f 60}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a715.497}}}{{\f5\fs12\hyphpar0\qj{, 29C.24}}}{{\f5\fs12\hyphpar0\qj{, 99B.8}}}{{\f5\fs12\hyphpar0\qj{, 99D.16}}}{{\f5\fs12\hyphpar0\qj{, 99F.18}}}{{\f5\fs12\hyphpar0\qj{, 99G.31}}}{{\f5\fs12\hyphpar0\qj{, 260E.5}}}{{\f5\fs12\hyphpar0\qj{, 260G.4A}}}{{\f5\fs12\hyphpar0\qj{, 260J.1}}}{{\f5\fs12\hyphpar0\qj{, 403.19A}}}{{\f5\fs12\hyphpar0\qj{, 421.62}}}{{\f5\fs12\hyphpar0\qj{, 422.4}}}{{\f5\fs12\hyphpar0\qj{, 422.16B}}}{{\f5\fs12\hyphpar0\qj{, 422.17}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}{{\f5\fs12\hyphpar0\qj{, 904.809}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{A taxpayer making an election under }{{\f5\fs12\hyphpar0\qj{section 422.16C}}}{ is not required to make estimated tax payments for a tax year beginning prior to May 11, 2023; see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH78.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 78, \'a74}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 2, paragraph e applies to tax years beginning on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a717}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 12, paragraph a, subparagraph (1) applies to tax years beginning on or after January 1, 2026; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 148, \'a760}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 2, paragraph d effective January 1, 2026; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 7, \'a73}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 12, paragraph a, subparagraph (1) effective January 1, 2026; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 148, \'a759}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2, paragraph d amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 12, paragraph a, subparagraph (1) amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.16A}}}{\*\bkmkstart stylerid1_2E6_2E64_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E64_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Job training withholding }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ certification and transfer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the completion by a business of its repayment obligation for a training project funded under }{{\f5\fs18\hyphpar0\qj{chapter 260E}}}{, including a job training project funded under }{{\f5\fs18\hyphpar0\qj{section 260J.2}}}{ or repaid in whole or in part by the supplemental new jobs credit from withholding under }{{\f5\fs18\hyphpar0\qj{section 260J.1}}}{ or }{{\f5\fs18\hyphpar0\qj{section 15E.197, Code 2014}}}{, the sponsoring community college shall report to the department of workforce development the amount of withholding paid by the business to the community college during the final twelve months of withholding payments. The department of workforce development shall notify the department of revenue of that amount. The department of revenue shall credit to the workforce development fund account established in }{{\f5\fs18\hyphpar0\qj{section 84G.3}}}{ twenty-five percent of that amount each quarter for a period of ten years. If the amount of withholding from the business or employer is insufficient, the department of revenue shall prorate the quarterly amount credited to the workforce development fund account. The maximum amount from all employers which shall be transferred to the workforce development fund account in any year is seven million seven hundred fifty thousand dollars.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 184, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1180, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 98, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1225, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1196, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1230, \'a723, 35}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 188, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 150, \'a761, 69}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1130, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1132, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 171, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72204}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784G.3}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.16B}}}{\*\bkmkstart stylerid1_2E6_2E65_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E65_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pass-through entity composite returns.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNonresident member\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a partner in a partnership as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.25A}}}{{\f5\fs18\hyphpar0\qj{, a shareholder of an S corporation, or a beneficiary of an estate or trust, who is any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who is not a resident of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A partnership without a commercial domicile in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A trust or estate without a situs in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A C corporation or S corporation without a commercial domicile in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financial institution as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.61}}}{{\f5\fs18\hyphpar0\qj{ without a commercial domicile in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPass-through entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any entity that is a partnership or a pass-through entity as those terms are defined in}}}{{\f5\fs18\hyphpar0\qj{ section 422.25A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTiered pass-through entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a member of a pass-through entity that is itself a pass-through entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pass-through entity shall file a composite return on behalf of all nonresident members and shall report and pay the income or franchise tax imposed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ at the maximum state income or franchise tax rate applicable to the member under }}}{{\f5\fs18\hyphpar0\qj{section 422.5}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.33}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{422.63}}}{{\f5\fs18\hyphpar0\qj{ on the nonresident members\u8217\'3f distributive shares of the income from the pass-through entity.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax rate applicable to a tiered pass-through entity shall be the state income tax rate under }}}{{\f5\fs18\hyphpar0\qj{section 422.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The composite return is due and shall be filed by the due date of the pass-through entity\u8217\'3fs annual return required under }}}{{\f5\fs18\hyphpar0\qj{section 422.14}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.15}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{422.36}}}{{\f5\fs18\hyphpar0\qj{, including extensions. The return shall be on a form prescribed by the department showing the total amounts paid or credited to the pass-through entity\u8217\'3fs nonresident members, the amounts of income or franchise tax remitted in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, if any, and such other information as the department may require. A pass-through entity shall furnish to its nonresident members a record of the amount of Iowa income or franchise tax remitted on behalf of such nonresident member in the manner and form prescribed by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa income or franchise tax on the composite return is due on and shall be paid by the due date of the pass-through entity\u8217\'3fs annual return required under }}}{{\f5\fs18\hyphpar0\qj{section 422.14}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.15}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{422.36}}}{{\f5\fs18\hyphpar0\qj{, without extensions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pass-through entity is liable to the state for the payment of the tax required to be remitted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, together with applicable interest and penalties, but is not liable to any nonresident member for any amount withheld from distributions to or from the distributive share of such nonresident member and remitted in compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a pass-through entity fails to pay any amount of tax required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and thereafter the tax is paid by the nonresident member, the amount of tax as paid by the nonresident member shall not be collected from the pass-through entity, but such payment by the nonresident member shall not relieve the pass-through entity from any penalty or interest associated with the failure to pay.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident member that has been included on a composite return filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall receive credit for Iowa income or franchise tax paid on the nonresident member\u8217\'3fs behalf by the pass-through entity, and any amounts in excess of the nonresident member\u8217\'3fs Iowa tax liability for the applicable tax period may be refunded to the nonresident member with interest in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The nonresident member\u8217\'3fs Iowa return shall constitute a claim for refund for this purpose. In lieu of claiming a refund, the nonresident member may elect to have the overpayment shown on the nonresident member\u8217\'3fs final, completed return for the taxable year credited to the taxpayer\u8217\'3fs tax liability for the following taxable year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tiered pass-through entity shall be subject to the same requirements to file a composite return and pay tax under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ with respect to the distributive shares of the tiered pass-through entity\u8217\'3fs income. Any Iowa income or franchise tax paid on the tiered pass-through entity\u8217\'3fs behalf by another pass-through entity may be applied against that tiered pass-through entity\u8217\'3fs own composite tax remittance obligation imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident individual included on a composite tax return filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be relieved of the requirement to file an individual income tax return under }}}{{\f5\fs18\hyphpar0\qj{section 422.13}}}{{\f5\fs18\hyphpar0\qj{ if income from the pass-through entity is the nonresident individual\u8217\'3fs only Iowa-source income.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pass-through entity shall not be required to remit Iowa income or franchise tax on behalf of a nonresident member if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pass-through entity is a publicly traded partnership as defined in }}}{{\f5\fs18\hyphpar0\qj{section 7704(b) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, provided the publicly traded partnership files with the department an information return that reports the name, address, taxpayer identification number, and any other information requested by the department for each unit holder with an income in this state from the publicly traded partnership in excess of five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A composite return is not required as provided in }}}{{\f5\fs18\hyphpar0\qj{section 29C.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pass-through entity meets any of the following requirements for the tax year:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pass-through entity is a financial institution subject to the franchise tax under }}}{{\f5\fs18\hyphpar0\qj{section 422.60}}}{{\f5\fs18\hyphpar0\qj{ and files a franchise tax return required under }}}{{\f5\fs18\hyphpar0\qj{section 422.62}}}{{\f5\fs18\hyphpar0\qj{ and pays any franchise tax shown due on the return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pass-through entity wholly owns one or more financial institutions subject to the franchise tax under }}}{{\f5\fs18\hyphpar0\qj{section 422.60}}}{{\f5\fs18\hyphpar0\qj{ that are treated as disregarded entities for federal and Iowa income tax purposes, and at least ninety percent of the gross income of the pass-through entity for the tax year is also reportable income on the franchise tax return of the financial institutions wholly owned by the pass-through entity, and such financial institutions file the franchise tax returns required under }}}{{\f5\fs18\hyphpar0\qj{section 422.62}}}{{\f5\fs18\hyphpar0\qj{ and pay any franchise tax shown due on the franchise tax return. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department determines by rule or through a ruling that the nonresident member\u8217\'3fs income should not be subject to composite return reporting, such as a member that is exempt from Iowa income or franchise tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director determines that it is necessary for the efficient administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the director may require that a composite return be filed for nonresidents other than nonresident members of a pass-through entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All powers of the director and requirements of the director apply to returns filed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ including but not limited to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{subchapter VI}}}{{\f5\fs18\hyphpar0\qj{. The provisions of }}}{{\f5\fs18\hyphpar0\qj{section 422.16, subsection 4}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{subsections 7, 11, and 14}}}{{\f5\fs18\hyphpar0\qj{, applying to withholding agents, shall apply in the same manner to pass-through entities under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the efficient administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the director may require or provide for the composite return on the same form as or combined with a pass-through entity\u8217\'3fs annual return required under }}}{{\f5\fs18\hyphpar0\qj{section 422.14}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.15}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{422.36}}}{{\f5\fs18\hyphpar0\qj{, but in such case the composite return shall be considered a separate return for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 421.27}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a pass-through entity is required to file its annual return under }}}{{\f5\fs18\hyphpar0\qj{section 422.14}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.15}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{422.36}}}{{\f5\fs18\hyphpar0\qj{ in an electronic format, the pass-through entity shall file its composite return for the same taxable year in an electronic format specified by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This paragraph applies to any form or schedule supporting a return required to be electronically filed or any amended return if the amended return meets any of the circumstances requiring electronic filing in this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A return subject to the electronic filing requirement in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that is filed in a manner other than an electronic format specified by the department shall not be considered a valid return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 151, \'a714, 15}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 174, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a75, 9}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a718, 52 \u8211\'3f 54}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a77, 16, 17}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a729C.24}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.16C}}}{{\f5\fs12\hyphpar0\qj{, 422.25A}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies to tax years beginning on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 151, \'a715}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 8 applies to tax years ending on or after December 31, 2022, or for tax years ending on or after December 31 of the calendar year in which the department of revenue implements a system for receiving the electronic returns, whichever is later; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a79}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5, paragraph c applies retroactively to January 1, 2023, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 115, \'a754}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Certain requirements of this section shall not apply to any estate for a tax year that began on or after January 1, 2022, and ended before December 31, 2022, if the estate received a certificate of acquittance from the department without having filed a composite return; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH0115.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 115, \'a761}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 2, paragraph a applies to tax years beginning on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.16C}}}{\*\bkmkstart stylerid1_2E6_2E66_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E66_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pass-through entity }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ election }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ entity-level tax }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPartnership\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.25A}}}{{\f5\fs18\hyphpar0\qj{, except a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpartnership\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a pass-through entity that is a publicly traded partnership as defined in }}}{{\f5\fs18\hyphpar0\qj{section 7704 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTaxpayer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a partnership or an S corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning on or after January 1, 2022, notwithstanding any other provision of law to the contrary, a taxpayer may elect to be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ only applies to tax years for which the limitation on individual deductions applies under }}}{{\f5\fs18\hyphpar0\qj{section 164(b)(6) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A separate election shall be made for each tax year on a form and at a time prescribed by the department. An election shall be irrevocable once made and shall be binding on the taxpayer and all partners or shareholders of the taxpayer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an election is made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a taxpayer shall not be required to file a composite return for the same tax year pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 422.16B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A taxpayer making an election under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be subject to tax in an amount equal to the rate under }}}{{\f5\fs18\hyphpar0\qj{section 422.5}}}{{\f5\fs18\hyphpar0\qj{, imposed against the taxable income of the taxpayer for the taxable year properly determined under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and allocated and apportioned to the state under the rules adopted by the department. The tax shall be due with the taxpayer\u8217\'3fs return required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by the credit provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and the franchise tax credit in }}}{{\f5\fs18\hyphpar0\qj{section 422.11, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, and the composite credit in }}}{{\f5\fs18\hyphpar0\qj{section 422.16B, subsection 4}}}{{\f5\fs18\hyphpar0\qj{. Any other tax credits shall not be claimed by the taxpayer against the tax imposed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. A net operating loss or other loss carryback or carryforward shall not be claimed by the taxpayer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a taxable year in which a taxpayer made an election under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, for the partners or shareholders of the taxpayer, the taxes imposed under this subchapter, less the credits allowed under }}}{{\f5\fs18\hyphpar0\qj{section 422.12}}}{{\f5\fs18\hyphpar0\qj{, or the taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{subchapter III}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{V}}}{{\f5\fs18\hyphpar0\qj{, as applicable, shall be reduced by a credit equal to the product of the following amounts:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The ratio of the partner\u8217\'3fs or shareholder\u8217\'3fs share of the taxpayer\u8217\'3fs taxable income over the taxpayer\u8217\'3fs total taxable income multiplied by the state tax liability actually paid by the taxpayer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The difference between one hundred percent and the individual income tax rate in effect for the tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the taxpayer is itself a partner or shareholder of another taxpayer making an election under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the credit under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be allowed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any credit in excess of the tax liability is refundable. In lieu of claiming a refund, the partner or shareholder may elect to have the overpayment shown on the partner\u8217\'3fs or shareholder\u8217\'3fs final, completed return credited to the tax liability for the following tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A nonresident individual who is a partner or shareholder of a taxpayer for a tax year in which an election is made under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be required to file an individual income tax return under }}}{{\f5\fs18\hyphpar0\qj{section 422.13}}}{{\f5\fs18\hyphpar0\qj{ for such tax year if the only Iowa source income of the individual is from a taxpayer making the election under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the credit allowed to the partner or shareholder equals or exceeds the tax liability of the partner or shareholder for the tax imposed in the tax year the election is made, and if the taxpayer files and pays the tax due under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A taxpayer making an election under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is liable for the entity-level tax imposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including applicable penalties and interest. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit the department from assessing direct or indirect partners and shareholders for taxes owed in the event that the taxpayer fails to timely make any payment required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for any reason.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to and not in lieu of any period of limitation provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.25}}}{{\f5\fs18\hyphpar0\qj{, if a taxpayer files an amended return that requests a refund of tax previously paid within one year prior to the expiration of the department\u8217\'3fs applicable period of limitations in }}}{{\f5\fs18\hyphpar0\qj{section 422.25}}}{{\f5\fs18\hyphpar0\qj{, the department has one year from the date of receipt of the amended return to assess any direct or indirect partners and shareholders related to the reduction of any tax credit provided under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 78, \'a72, 6, 7}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a78, 9, 16, 17}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.11}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}{{\f5\fs12\hyphpar0\qj{, 422.85}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{A taxpayer making an election under this section is not required to make estimated tax payments for a tax year beginning prior to May 11, 2023; see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH78.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 78, \'a74}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{The department of revenue may waive penalty and interest for a return filing or tax payment related to an election under this section for a tax year ending prior to May 11, 2023; see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH78.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 78, \'a75}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies retroactively to January 1, 2022, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 78, \'a77}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 4, paragraph a applies to tax years beginning on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a717}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 5, paragraph a, subparagraph (2) applies to tax years beginning on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.17}}}{\*\bkmkstart stylerid1_2E6_2E67_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E67_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate issued by department to make payments without withholding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any nonresident whose Iowa income is not subject to }{{\f5\fs18\hyphpar0\qj{section 422.16, subsection 2}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{, or }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{, in whole or in part, and who elects to be governed by }{{\f5\fs18\hyphpar0\qj{section 422.16, subsection 2}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{, to the extent that the nonresident pays the entire amount of tax properly estimated on or before the last day of the fourth month of the nonresident\u8217\'3fs tax year, for the year, may for the year of the election and payment, be granted a certificate from the department authorizing each withholding agent, the income from whom the nonresident has considered in the payment of estimated tax and to the extent the income is included in the estimate, to make payments of income to the nonresident without withholding tax from those payments. Withholding agents, if payments exceed the tax liability estimated by the nonresident as indicated upon the certificate, shall withhold tax in accordance with }{{\f5\fs18\hyphpar0\qj{section 422.16, subsection 2}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.049;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.17}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1241, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a719}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.18}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.19}}}{\*\bkmkstart stylerid1_2E6_2E69_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E69_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope of nonresidents tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The tax imposed under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ upon certain income of nonresidents shall apply to all such income actually received by such nonresident regardless of when such income was earned. If the nonresident is reporting on the accrual basis it shall apply to all such income which first became available to the nonresident so that the nonresident might demand payment thereof regardless of when such income was earned. The duty to withhold imposed under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ upon withholding agents shall apply only to amounts paid after June 30, 1937.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.051;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7221}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.20}}}{\*\bkmkstart stylerid1_2E6_2E7_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E7_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Information confidential \u8212\'3f redactions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any present or former officer or employee of the state to willfully or recklessly divulge or to make known in any manner whatever not provided by law to any person the amount or source of income, profits, losses, expenditures, or any particular thereof, set forth or disclosed in any income return, or to permit any income return or copy thereof or any book containing any abstract or particulars thereof to be seen or examined by any person except as provided by law.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any person to willfully or recklessly print or publish in any manner whatever not provided by law any income return, or any part thereof or source of income, profits, losses, or expenditures appearing in any income return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person committing an offense described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be guilty of a serious misdemeanor. If the offender is an officer or employee of the state, such person shall also be dismissed from office or discharged from employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall prohibit turning over to duly authorized officers of the United States or tax officials of other states state information and income returns pursuant to agreement between the director and the secretary of the treasury of the United States or the secretary\u8217\'3fs delegate or pursuant to a reciprocal agreement with another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is unlawful for an officer, employee, or agent, or former officer, employee, or agent of the state to willfully or recklessly disclose to any person, except as authorized in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, any federal tax return or return information as defined in }}}{{\f5\fs18\hyphpar0\qj{section 6103(b) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{. It is unlawful for a person to whom any federal tax return or return information, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 6103(b) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, is disclosed in a manner unauthorized by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to thereafter willfully or recklessly print or publish in any manner not provided by law any such return or return information. A person violating }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise expressly permitted by }}}{{\f5\fs18\hyphpar0\qj{section 8G.4}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 11.41}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 96.11, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 421.17, subsections 22, 23, and 26}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 421.17, subsection 27}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 421.17, subsection 31}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 252B.9}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{section 321.40, subsection 6}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 321.120}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{421.19}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{421.28}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{421.59}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{421.65}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{422.72}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{452A.63}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{556.19, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, or another provision of law, a tax return, return information, or investigative or audit information shall not be divulged to any person or entity, other than the taxpayer, the department, or internal revenue service for use in a matter unrelated to tax administration.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This prohibition precludes persons or entities other than the taxpayer, the department, or the internal revenue service from obtaining such information from the department, and a subpoena, order, or process which requires the department to produce such information to a person or entity, other than the taxpayer, the department, or internal revenue service for use in a nontax proceeding is void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may disclose the tax return of a partnership, limited liability company, or S corporation, any such return information, or any investigative information related to the return, to any person who was a partner, shareholder, or member of such an entity during any part of the period covered by the return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to the record in an appeal or contested case being made available for public inspection, the department shall redact the following information from any pleading, exhibit, attachment, motion, written evidence, final order, decision, or opinion contained in that record:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financial account number.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An account number generated by the department to identify an audit or examination.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A social security number.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A federal employer identification number.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of a minor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A medical record or other medical information.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A return as defined in }}}{{\f5\fs18\hyphpar0\qj{section 421.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a motion filed by the taxpayer, the department may redact from the record in an appeal or contested case any other information from a pleading, exhibit, attachment, motion, or written evidence, if the taxpayer proves by clear and convincing evidence that the release of such information would disclose a trade secret or be a clear, unwarranted invasion of personal privacy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when making final orders, decisions, or opinions available for public inspection, the department may disclose the items in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ if the department determines such information is relevant or necessary to the resolution or decision of the appeal or case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as described in paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, all information contained in a pleading, exhibit, attachment, motion, written evidence, final order, decision, opinion, and the record in an appeal or contested case is subject to examination to the extent provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may disclose taxpayer identity information to the press and other media for purposes of notifying persons entitled to tax refunds when the director, after reasonable effort and lapse of time, has been unable to locate the persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may permit, by rule, the disclosure of state tax information to a person a taxpayer has authorized to receive such state tax information, in the manner prescribed by the department.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.20}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 199, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1028, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 159, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 158, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7256}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1113, \'a79, 11}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1146, \'a714, 26}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1193, \'a7147, 149}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 122, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 70, \'a74, 9}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 152, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7222}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1064, \'a720, 28}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a714 \u8211\'3f 16, 73, 74}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 86, \'a778, 79}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a7100}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 148, \'a73, 5}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 421.17}}}{{\f5\fs12\hyphpar0\qj{, 421.19}}}{{\f5\fs12\hyphpar0\qj{, 421.24}}}{{\f5\fs12\hyphpar0\qj{, 421.28}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}{{\f5\fs12\hyphpar0\qj{, 422.72}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}{{\f5\fs12\hyphpar0\qj{, 425.28}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph a amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.21}}}{\*\bkmkstart stylerid1_2E6_2E71_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E71_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form and time of return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Returns shall be in the form the director prescribes, and shall be filed with the department on or before the last day of the fourth month after the expiration of the tax year. However, cooperative associations as defined in section 6072(d) of the Internal Revenue Code shall file their returns on or before the fifteenth day of the ninth month following the close of the taxable year and nonprofit corporations subject to the unrelated business income tax imposed by }}}{{\f5\fs18\hyphpar0\qj{section 422.33, subsection 1A}}}{{\f5\fs18\hyphpar0\qj{, shall file their returns on or before the fifteenth day of the fifth month following the close of the taxable year. If, under the Internal Revenue Code, a corporation is required to file a return covering a tax period of less than twelve months, the state return shall be for the same period and is due forty-five days after the due date of the federal tax return, excluding any extension of time to file. In case of sickness, absence, or other disability, or if good cause exists, the director may allow further time for filing returns. The director shall cause to be prepared blank forms for the returns and shall cause them to be distributed throughout the state and to be furnished upon application, but failure to receive or secure the form does not relieve the taxpayer from the obligation of making a return that is required. The department may as far as consistent with the Code draft income tax forms to conform to the income tax forms of the internal revenue department of the United States government. Each return by a taxpayer upon whom a tax is imposed by }}}{{\f5\fs18\hyphpar0\qj{section 422.5}}}{{\f5\fs18\hyphpar0\qj{ shall show the county of the residence of the taxpayer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual in the armed forces of the United States serving in an area designated by the president of the United States or the United States Congress as a combat zone or as a qualified hazardous duty area, or deployed outside the United States away from the individual\u8217\'3fs permanent duty station while participating in an operation designated by the United States secretary of defense as a contingency operation as defined in }}}{{\f5\fs18\hyphpar0\qj{10 U.S.C. \'a7101(a)(13)}}}{{\f5\fs18\hyphpar0\qj{, or which became such a contingency operation by the operation of law, or an individual serving in support of those forces, is allowed the same additional time period after leaving the combat zone or the qualified hazardous duty area, or ceasing to participate in such contingency operation, or after a period of continuous hospitalization, to file a state income tax return or perform other acts related to the department, as would constitute timely filing of the return or timely performance of other acts described in }}}{{\f5\fs18\hyphpar0\qj{section 7508(a) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{. An individual on active duty federal military service in the armed forces, armed forces military reserve, or national guard who is deployed outside the United States in other than a combat zone, qualified hazardous duty area, or contingency operation is allowed the same additional period of time described in }}}{{\f5\fs18\hyphpar0\qj{section 7508(a) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ to file a state income tax return or perform other acts related to the department. For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fother acts related to the department\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes filing claims for refund for any tax administered by the department, making tax payments other than withholding payments, filing appeals on the tax matters, filing other tax returns, and performing other acts described in the department\u8217\'3fs rules. The additional time period allowed applies to the spouse of the individual described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ to the extent the spouse files jointly with the individual or when the spouse is a party with the individual to any matter for which the additional time period is allowed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall make available to persons required to make personal income tax returns under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, and when such income is derived mainly from salaries and wages or from the operation of a business or profession, a form which shall take into consideration the normal deductions and credits allowable to any such taxpayer, and which will permit the computation of the tax payable without requiring the listing of specific deductions and credits. In arriving at schedules for payment of taxation under such forms the department shall as nearly as possible base such schedules upon a total of deductions and credits which will result in substantially the same payment as would have been made by such taxpayer were the taxpayer to specifically list the taxpayer\u8217\'3fs allowable deductions and credits. In lieu of such return any taxpayer may elect to list permissible deductions and credits as provided by law. It is the intent and purpose of this provision to simplify the procedure of collection of personal income tax, and the director shall have the power in any case when deemed necessary or advisable to require any taxpayer, who has made a return in accordance with the schedule provided for in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, to make an additional return in which all deductions and credits are specifically listed. The department may revise the schedules adopted in connection with such simplified form whenever such revision is necessitated by changes in federal income tax laws, or to maintain the collection of substantially the same amounts from taxpayers as would be received were the specific listing of deductions and credits required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall provide space on the prescribed income tax form, wherein the taxpayer shall enter the name of the school district of the taxpayer\u8217\'3fs residence. Such place shall be indicated by prominent type. A nonresident taxpayer shall so indicate. If such information is not supplied on the tax return it shall be deemed an incompleted return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall determine for the 2023 calendar year and each subsequent calendar year the annual and cumulative inflation factors for each calendar year to be applied to tax years beginning on or after January 1 of that calendar year. The annual and cumulative inflation factors determined by the director are not rules as defined in }}}{{\f5\fs18\hyphpar0\qj{section 17A.2, subsection 11}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall provide on income tax forms or in the instruction booklets in a manner that will be noticeable to the taxpayers a statement that, even though the taxpayer may not have any federal or state income tax liability, the taxpayer may be eligible for the federal earned income tax credit or state child and dependent care credit. The statement shall also contain notice of where the taxpayer may check on the taxpayer\u8217\'3fs eligibility for these credits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If married taxpayers file a joint return in accordance with rules prescribed by the director, both spouses are jointly and severally liable for the total tax due on the return, except when one spouse is eligible for relief under criteria established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 6015 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{. The department may notify the nonrequesting spouse or former spouse and permit, by rule, the intervention of a nonrequesting spouse or former spouse when relief from joint and several liability is requested.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f17; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.053;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.21}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 230, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a756}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/87/CH0001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 2nd Ex, ch 1, \'a711}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1028, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 268, \'a77, 8}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1248, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 159, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 196, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1165, \'a716, 48}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1146, \'a79, 11}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1069, \'a78, 11, 14}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 142, \'a78, 11}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 47, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a7127, 133, 134}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7223}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a775, 76}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a710, 16, 17}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.23}}}{{\f5\fs12\hyphpar0\qj{, 422.7(22)(a)}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}{{\f5\fs12\hyphpar0\qj{, 541B.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2018 amendments to subsections 2, 5, and 7 are effective January 1, 2023, and apply to tax years beginning on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2018 Acts, ch 1161, \'a7133, 134}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a71}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 5 applies to tax years beginning on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.22}}}{\*\bkmkstart stylerid1_2E6_2E72_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E72_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Supplementary returns.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the director shall be of the opinion that any taxpayer required under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ to file a return has failed to file such a return or to include in a return filed, either intentionally or through error, items of taxable income, the director may require from such taxpayer a return or supplementary return in such form as the director shall prescribe, of all the items of income which the taxpayer received during the year for which the return is made, whether or not taxable under the provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{. If from a supplementary return, or otherwise, the director finds that any items of income, taxable under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{, have been omitted from the original return, the director may require the items so omitted to be added to the original return. Such supplementary return and the correction of the original return shall not relieve the taxpayer from any of the penalties to which the taxpayer may be liable under any provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{, whether or not the director required a return or a supplementary return under }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f18; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.054;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.22}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.38}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.23}}}{\*\bkmkstart stylerid1_2E6_2E73_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E73_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Return by administrator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The return by an individual, who, while living, was subject to income tax in the state during the tax year, and who has died before making the return, shall be made in the individual\u8217\'3fs name and behalf by the administrator or executor of the estate and the tax shall be levied upon and collected from the individual\u8217\'3fs estate. In the making of said return, the executor or administrator shall use the same method of computation, either cash or accrual, as was last used by the deceased taxpayer.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f19; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.055;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.23}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1241, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 151, \'a77, 89}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.24}}}{\*\bkmkstart stylerid1_2E6_2E74_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E74_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Payment \u8212\'3f interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For all taxpayers the total tax due shall be paid in full at the time of filing the return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When, at the request of the taxpayer, the time for filing the return is extended, interest at the rate in effect under }}}{{\f5\fs18\hyphpar0\qj{section 421.7}}}{{\f5\fs18\hyphpar0\qj{ for each month counting each fraction of a month as an entire month, on the total tax due, from the time when the return was required to be filed to the time of payment, shall be added and paid.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f20; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.056;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.24}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 131, \'a77}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.39}}}{{\f5\fs12\hyphpar0\qj{, 422.66}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.24A}}}{\*\bkmkstart stylerid1_2E6_2E75_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E75_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Start-up business tax deferment.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1184.pdf" }{\fldrslt \cf5 \f5 \fs18{{2008 Acts, ch 1184, \'a766, 67}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.25}}}{\*\bkmkstart stylerid1_2E6_2E76_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E76_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Computation of tax, interest, and penalties \u8212\'3f limitation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal adjustment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a change to an item or amount required to be determined under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder that is used by the taxpayer to compute state tax owed whether such change results from action by the internal revenue service, or the filing of a timely amended federal return or timely federal refund claim. A federal adjustment is positive to the extent that it increases Iowa taxable income as determined under }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{ and is negative to the extent that it decreases Iowa taxable income as determined under }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal adjustments report\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the method or form required by the department by rule to report final federal adjustments or final federal partnership adjustments as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.25A}}}{{\f5\fs18\hyphpar0\qj{, and in the case of any entity taxed as a partnership or S corporation for federal income tax purposes, identifies all owners that hold an interest directly in such entity and provides the effect of the final federal adjustments on such owner\u8217\'3fs Iowa income.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinal determination date\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in subparagraph divisions (b) and (c), for federal adjustments arising from an internal revenue service audit or other action by the internal revenue service, the final determination date is the first day on which no federal adjustments arising from that audit or other action remain to be finally determined, whether by internal revenue service decision with respect to which all rights of appeal have been waived or exhausted, by agreement, or, if appealed or contested, by a final decision with respect to which all rights of appeal have been waived or exhausted. For agreements required to be signed by the internal revenue service and the taxpayer, the final determination date is the date on which the last party signed the agreement. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For federal adjustments arising from an internal revenue service audit or other action by the internal revenue service, if the taxpayer filed as a member of a consolidated return under }}}{{\f5\fs18\hyphpar0\qj{section 422.37}}}{{\f5\fs18\hyphpar0\qj{, the final determination date is the first day on which no related federal adjustments arising from that audit or other action remain to be finally determined, as described in subparagraph division (a), for the entire group. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For federal adjustments arising from a timely filed amended federal return or a timely filed federal refund claim, or if it is a federal adjustment reported on a timely amended federal return or other similar report filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 6225(c) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, the final determination date is the day on which the amended return, refund claim, or other similar report was filed. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinal federal adjustment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a federal adjustment after the final determination date for that federal adjustment has passed. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within three years after the return is filed or within three years after the return became due, including any extensions of time for filing, whichever time is the later, the department shall examine the return and determine the tax. However, if the taxpayer omits from income an amount which will, under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, extend the statute of limitations for assessment of federal tax to six years under the federal law, the period for examination and determination is six years. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The period for examination and determination of the correct amount of tax is unlimited in the case of a false or fraudulent return made with the intent to evade tax or in the case of a failure to file a return. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person required to file a return with the department fails to file the return with the department, the department may, at any time, estimate the tax due based upon information or knowledge the department is able to obtain.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department estimates an amount of tax under subparagraph (2), the following shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall issue a notice of assessment to the person for which the tax is estimated in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 421.60}}}{{\f5\fs18\hyphpar0\qj{. The notice of assessment shall not be appealable pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 422.28}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{422.29}}}{{\f5\fs18\hyphpar0\qj{, except to appeal the determination that the person is required to file a return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall include a statement with the notice that if the person files a return within three years from the date on the notice of assessment, the department may replace the assessment with the amount shown due on the person\u8217\'3fs return, plus any applicable penalty and interest, and the department may examine that return and determine the tax, penalty, and interest within the period provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person fails to file a return within three years from the date on the notice of assessment, the person may pay the tax, penalty, and interest and file a refund claim within the time period provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.73}}}{{\f5\fs18\hyphpar0\qj{, or may request relief under }}}{{\f5\fs18\hyphpar0\qj{section 421.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the period of limitation for any prior year for which an overpayment of tax or an elimination or reduction of an underpayment of tax due for that prior year results from the carryback to that prior year of a net operating loss or net capital loss, the period is the period of limitation for the taxable year of the net operating loss or net capital loss which results in the carryback. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the applicable period of limitation for examination and determination in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department may make an examination and determination at any time within one year from the date of receipt by the department of a federal adjustments report with respect to a final federal adjustment or final federal partnership adjustment as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.25A}}}{{\f5\fs18\hyphpar0\qj{ for a particular tax year. In order to begin the running of the one-year period, the federal adjustments report related to the final federal adjustment or final federal partnership adjustment shall be transmitted to the department by the taxpayer in the form and manner specified by the department by rule.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department in its discretion may adopt rules to establish a de minimis amount for which subparagraph (1) shall not apply and the taxpayer shall not be required to file a federal adjustments report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may in its discretion and when administratively feasible adopt a process through rule by which a taxpayer may make estimated payments of tax expected to result from a pending internal revenue service audit prior to the filing of a federal adjustments report with the department. The process shall provide that the estimated tax payments shall be credited against any tax liability ultimately found to be due to the state from the internal revenue service audit and will limit the accrual of further statutory interest on that liability. The process shall also provide that if the estimated tax payments exceed the final tax liability and statutory interest ultimately determined to be due, the taxpayer is entitled to a refund or credit for the excess, without interest, provided the taxpayer files a federal adjustments report, or a claim for refund or credit of tax under }}}{{\f5\fs18\hyphpar0\qj{section 422.73}}}{{\f5\fs18\hyphpar0\qj{, no later than one year following the final determination date.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The period of examination and determination is unlimited under this title in the case of any action by the department to recover or rescind any tax expenditure as defined by }}}{{\f5\fs18\hyphpar0\qj{section 2.48, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or any other incentive or assistance, due to a failure to meet or maintain the requirements of a program administered by the economic development authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the tax found due under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ is greater than the amount paid, the department shall compute the amount due, together with interest and penalties as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and shall mail a notice of assessment to the taxpayer and, if applicable, to the taxpayer\u8217\'3fs authorized representative of the total, which shall be computed as a sum certain, with interest computed to the last day of the month in which the notice is dated.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the tax or additional tax determined by the department under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the taxpayer shall pay interest on the tax or additional tax at the rate in effect under }}}{{\f5\fs18\hyphpar0\qj{section 421.7}}}{{\f5\fs18\hyphpar0\qj{ for each month counting each fraction of a month as an entire month, computed from the date the return was required to be filed. In addition to the tax or additional tax, the taxpayer shall pay a penalty as provided in }}}{{\f5\fs18\hyphpar0\qj{section 421.27}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the amount of the tax as determined by the department is less than the amount paid, the excess shall be refunded with interest in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, when the net operating loss or net capital loss carryback to a prior year eliminates or reduces an underpayment of tax due for an earlier year, the full amount of the underpayment of tax shall bear interest at the rate in effect under }}}{{\f5\fs18\hyphpar0\qj{section 421.7}}}{{\f5\fs18\hyphpar0\qj{ for each month counting each fraction of a month as an entire month from the due date of the tax for the earlier year to the last day of the taxable year in which the net operating loss or net capital loss occurred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All payments received must be credited first to the penalty and interest accrued and then to the tax due. If payments in multiple tax periods are unpaid, payments received shall be credited first to the penalty and interest accrued and then tax due for the earliest period, and then credited to each following tax period in chronological order from the earliest tax period to the latest tax period. Payments required to be made within a tax period must be credited first to the earliest deposit period within the tax period. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the department shall not reapply prior payments made on or before the due date of the original return by the taxpayer to penalty or interest determined to be due after the date of those prior payments, except that the taxpayer and the department may agree to apply payments in accordance with rules adopted by the director when there are both agreed and unagreed to items as a result of an examination.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftax period\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a period of time for which a return is required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or withholding agent required to supply information, to pay tax, or to make, sign, or file a deposit form or return required by }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, who willfully makes a false or fraudulent deposit form or return, or willfully fails to pay the tax, supply the information, or make, sign, or file the deposit form or return, at the time or times required by law, is guilty of a fraudulent practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The certificate of the director to the effect that a tax has not been paid, that a return has not been filed, or that information has not been supplied, as required under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be prima facie evidence thereof except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The periods of limitation provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be extended by the taxpayer by signing a waiver agreement to be provided by the department. The agreement shall stipulate the period of extension and the year or years to which the extension applies. It shall provide that a claim for refund may be filed by the taxpayer at any time during the period of extension.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person or withholding agent who willfully attempts in any manner to defeat or evade a tax imposed by }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ or the payment of the tax, upon conviction for each offense is guilty of a class \u8220\'3fD\u8221\'3f felony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prosecution for any offense defined in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ must be commenced within six years after the commission thereof, and not after.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a taxpayer files an amended return within sixty days prior to the expiration of the applicable period of limitations described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the department has sixty days from the date of receipt of the amended return to issue an assessment for any applicable tax, interest, or penalty.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f21; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.057;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.25}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 131, \'a78}}}{, }{{\f5\fs18\hyphpar0\qj{ch 133, \'a72, 4}}}{, }{{\f5\fs18\hyphpar0\qj{ch 134, \'a71, 2}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1180, \'a73, 8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 160, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1025, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1173, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1007, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1241, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1028, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 251, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1172, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1133, \'a73, 4, 16}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 83, \'a73, 34}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 151, \'a78, 9, 89}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 152, \'a73, 40}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1150, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 110, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a76, 15, 16}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a717, 31, 63, 71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 151, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1032, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a726, 40}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799G.30A}}}{{\f5\fs12\hyphpar0\qj{, 257.22}}}{{\f5\fs12\hyphpar0\qj{, 321.105A}}}{{\f5\fs12\hyphpar0\qj{, 421.27}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.16C}}}{{\f5\fs12\hyphpar0\qj{, 422.25A}}}{{\f5\fs12\hyphpar0\qj{, 422.25C}}}{{\f5\fs12\hyphpar0\qj{, 422.39}}}{{\f5\fs12\hyphpar0\qj{, 422.66}}}{{\f5\fs12\hyphpar0\qj{, 422.73}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}{{\f5\fs12\hyphpar0\qj{, 423.42}}}{{\f5\fs12\hyphpar0\qj{, 423A.6}}}{{\f5\fs12\hyphpar0\qj{, 423B.6}}}{{\f5\fs12\hyphpar0\qj{, 423C.4}}}{{\f5\fs12\hyphpar0\qj{, 423D.4}}}{{\f5\fs12\hyphpar0\qj{, 423G.5}}}{{\f5\fs12\hyphpar0\qj{, 428A.8}}}{{\f5\fs12\hyphpar0\qj{, 452A.23}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fraudulent practices, see }{{\f5\fs12\hyphpar0\qj{\'a7714.8 \u8211\'3f 714.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.25A}}}{\*\bkmkstart stylerid1_2E6_2E77_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reporting and treatment of certain partnership adjustments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E6_2E77_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{sections 422.25B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{422.25C}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdministrative adjustment request\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as provided in }}}{{\f5\fs18\hyphpar0\qj{section 6227 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAudited partnership\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a partnership subject to a final federal partnership adjustment resulting from a partnership level audit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fC corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an entity that elects or is required to be taxed as a corporation under }}}{{\f5\fs18\hyphpar0\qj{title 26, chapter 1, subchapter A, part 2, of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCorporate partner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a C corporation partner that is subject to tax pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 422.33}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirect partner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person that holds an interest directly in a partnership or pass-through entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fExempt partner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a partner that is exempt from taxation pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 422.34}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal adjustments report\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.25}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal partnership adjustment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a change to an item or amount required to be determined under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder that is used by a partnership and its direct and indirect partners to compute state tax owed for the reviewed year where such change results from a partnership level audit or an administrative adjustment request. A federal partnership adjustment is positive to the extent that it increases Iowa taxable income as determined under }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{ and is negative to the extent that it decreases Iowa taxable income as determined under }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{. A federal adjustment reported on an amended federal return or other similar report filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 6225(c) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered a federal partnership adjustment for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFederal partnership representative\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the person the partnership designates for the taxable year as the partnership\u8217\'3fs representative, or the person the internal revenue service has appointed to act as the federal partnership representative, pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 6223(a) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFiduciary partner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a partner that is a fiduciary that is subject to tax pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 422.5}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{422.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinal determination date\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any one of the following dates:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a federal partnership adjustment that arises from a partnership level audit, the first day on which no federal adjustments arising from that audit remain to be finally determined, whether by internal revenue service decision with respect to which all rights of appeal have been waived or exhausted, by agreement, or, if appealed or contested, by a final decision with respect to which all rights of appeal have been waived or exhausted. For agreements required to be signed by the internal revenue service and the audited partnership, the final determination date is the date on which the last party signed the agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of a federal partnership adjustment that results from a timely filed administrative adjustment request, the day on which the administrative adjustment request was filed with the internal revenue service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinal federal partnership adjustment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a federal partnership adjustment after the final determination date for that federal partnership adjustment has passed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndirect partner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a partner in a partnership or pass-through entity where such partnership or pass-through entity itself holds an interest directly, or through another indirect partner, in a partnership or pass-through entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndividual partner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a partner who is a natural person that is subject to tax pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 422.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNonresident partner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a partner that is not a resident partner as defined in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPartner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person that holds an interest, directly or indirectly, in a partnership or pass-through entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPartnership\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an entity subject to taxation under }}}{{\f5\fs18\hyphpar0\qj{subchapter K of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder and includes but is not limited to a syndicate, group, pool, joint venture, or other unincorporated organization through or by means of which any business, financial operation, or venture is carried on and which is not, within the meaning of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a trust, estate, or corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPartnership level audit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an examination by the internal revenue service at the partnership level pursuant to }}}{{\f5\fs18\hyphpar0\qj{subchapter C of title 26, subtitle F, chapter 63, of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, as enacted by the }}}{{\f5\fs18\hyphpar0\qj{Bipartisan Budget Act of 2015}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 114-74}}}{{\f5\fs18\hyphpar0\qj{, and as amended, which results in final federal partnership adjustments initiated and made by the internal revenue service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPass-through entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an entity, other than a partnership, that is not subject to tax under }}}{{\f5\fs18\hyphpar0\qj{section 422.33}}}{{\f5\fs18\hyphpar0\qj{ for C corporations but excluding an exempt partner. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPass-through entity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to S corporations, estates, and trusts other than grantor trusts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{t.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReallocation adjustment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a final federal partnership adjustment that changes the shares of items of partnership income, gain, loss, expense, or credit allocated to a partner that holds an interest directly in a partnership or pass-through entity. A positive reallocation adjustment means the portion of a reallocation adjustment that would increase Iowa taxable income for such partners, and a negative reallocation adjustment means the portion of a reallocation adjustment that would decrease Iowa taxable income for such partners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{u.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResident partner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an individual partner, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fresident\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a fiduciary partner, one with situs in Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For all other partners, a partner whose headquarters or principal place of business is located in Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{v.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReviewed year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the taxable year of a partnership that is subject to a partnership level audit from which final federal partnership adjustments arise, or otherwise means the taxable year of the partnership or pass-through entity that is the subject of a state partnership audit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{w.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState partnership audit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an examination by the director at the partnership or pass-through entity level which results in adjustments to partnership or pass-through entity related items or reallocations of income, gains, losses, expenses, credits, and other attributes among such partners for the reviewed year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{x.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTiered partner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any partner that is a partnership or pass-through entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{y.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnrelated business income\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the income which is defined in }}}{{\f5\fs18\hyphpar0\qj{section 512 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E6_2E77_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Application.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Partnerships and their direct partners and indirect partners shall report final federal partnership adjustments as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E6_2E77_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{State pass-through representative.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other law to the contrary, the state pass-through representative for the reviewed year shall have the sole authority to act on behalf of the partnership or pass-through entity with respect to an action required or permitted to be taken by a partnership or pass-through entity under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{section 422.28}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{422.29}}}{{\f5\fs18\hyphpar0\qj{ with respect to final federal partnership adjustments arising from a partnership level audit or an administrative adjustment request, and its direct partners and indirect partners shall be bound by those actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E6_2E77_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Reporting and payment requirements for partnerships and their partners subject to final federal partnership adjustments.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless an audited partnership makes the election in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, a partnership shall do all of the following for all final federal partnership adjustments no later than ninety days after the final determination date:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{File a completed federal adjustments report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notify each direct partner of such partner\u8217\'3fs distributive share of the adjustments in the manner and form prescribed by the department by rule. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{File an amended composite return under }}}{{\f5\fs18\hyphpar0\qj{section 422.13}}}{{\f5\fs18\hyphpar0\qj{, Code 2021, or under }}}{{\f5\fs18\hyphpar0\qj{section 422.16B}}}{{\f5\fs18\hyphpar0\qj{, as applicable, if one was originally required to be filed, and if applicable for withholding from partners, file an amended withholding report under }}}{{\f5\fs18\hyphpar0\qj{section 422.16, Code 2021,}}}{{\f5\fs18\hyphpar0\qj{ and pay the additional amount under }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{ that would have been due had the final federal partnership adjustments been reported properly as required, including any applicable interest and penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless an audited partnership paid an amount on behalf of the direct partners of the partnership pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, all direct partners of the partnership shall do all of the following no later than one hundred eighty days after the final determination date:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{File a completed federal adjustments report reporting the direct partner\u8217\'3fs distributive share of the adjustments required to be reported to such partners under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the direct partner is a tiered partner, notify all partners that hold an interest directly in the tiered partner of such partner\u8217\'3fs distributive share of the adjustments in the manner and form prescribed by the department by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the direct partner is a tiered partner and subject to }}}{{\f5\fs18\hyphpar0\qj{section 422.13}}}{{\f5\fs18\hyphpar0\qj{, Code 2021, or }}}{{\f5\fs18\hyphpar0\qj{section 422.16B}}}{{\f5\fs18\hyphpar0\qj{, file an amended composite return under }}}{{\f5\fs18\hyphpar0\qj{section 422.13}}}{{\f5\fs18\hyphpar0\qj{, Code 2021, or under }}}{{\f5\fs18\hyphpar0\qj{section 422.16B}}}{{\f5\fs18\hyphpar0\qj{, as applicable, if such return was originally required to be filed, and if applicable for withholding from partners file an amended withholding report under }}}{{\f5\fs18\hyphpar0\qj{section 422.16, Code 2021,}}}{{\f5\fs18\hyphpar0\qj{ if one was originally required to be filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pay any additional amount under }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{ that would have been due had the final federal partnership adjustments been reported properly as required, including any applicable penalty and interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless a partnership or tiered partner paid an amount on behalf of the partners pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, each indirect partner shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ninety days after the time for filing and furnishing statements to tiered partners and their partners as established by }}}{{\f5\fs18\hyphpar0\qj{section 6226 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder, file a completed federal adjustments report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the indirect partner is a tiered partner, within ninety days after the time for filing and furnishing statements to tiered partners and their partners as established by }}}{{\f5\fs18\hyphpar0\qj{section 6226 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder but within sufficient time for all indirect partners to also complete the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, notify all of the partners that hold an interest directly in the tiered partner of such partner\u8217\'3fs distributive share of the adjustments in the manner and form prescribed by the department by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ninety days after the time for filing and furnishing statements to tiered partners and their partners as established by }}}{{\f5\fs18\hyphpar0\qj{section 6226 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder, if the indirect partner is a tiered partner and subject to }}}{{\f5\fs18\hyphpar0\qj{section 422.13}}}{{\f5\fs18\hyphpar0\qj{, Code 2021, or }}}{{\f5\fs18\hyphpar0\qj{section 422.16B}}}{{\f5\fs18\hyphpar0\qj{, file an amended composite return under }}}{{\f5\fs18\hyphpar0\qj{section 422.13}}}{{\f5\fs18\hyphpar0\qj{, Code 2021, or under }}}{{\f5\fs18\hyphpar0\qj{section 422.16B}}}{{\f5\fs18\hyphpar0\qj{, as applicable, if such return was originally required to be filed, and if applicable for withholding from partners, file an amended withholding report under }}}{{\f5\fs18\hyphpar0\qj{section 422.16, Code 2021,}}}{{\f5\fs18\hyphpar0\qj{ if one was originally required to be filed. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ninety days after the time for filing and furnishing statements to tiered partners and the partners of the tiered partners as established by }}}{{\f5\fs18\hyphpar0\qj{section 6226 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder, pay any additional amount due under }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{, including any penalty and interest that would have been due had the final federal partnership adjustments been reported properly as required. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E6_2E77_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Election for partnership or tiered partners to pay. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An audited partnership, or a tiered partner of an audited partnership that receives a notification under }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ of a final federal partnership adjustment arising from a partnership level audit, may make an election to pay as provided under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An audited partnership or tiered partner shall make an election to pay under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ in the manner and form prescribed by the department. The audited partnership or tiered partner making an election to pay shall file a completed federal adjustments report, notify each of the direct partners of such partner\u8217\'3fs distributive share of the adjustments, and pay on behalf of its partners an amount calculated in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, including any applicable penalty and interest. These requirements shall all be fulfilled within one of the following time periods:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the audited partnership, no later than ninety days after the final determination date of the audited partnership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a direct tiered partner, no later than one hundred eighty days after the final determination date of the audited partnership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an indirect tiered partner, within ninety days after the time for filing and furnishing statements to a tiered partner and the partner of the tiered partner, as established by }}}{{\f5\fs18\hyphpar0\qj{section 6226 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount due under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ from an audited partnership or tiered partner shall be calculated as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exclude from final federal partnership adjustments and any positive reallocation adjustments the distributive share of such adjustments reported to an exempt partner that holds an interest directly in the audited partnership if the audited partnership is making the election or that holds an interest directly in the tiered partner if the tiered partner is making the election, but only to the extent the distributive share is not unrelated business income.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine the total distributive share of all final federal partnership adjustments and positive reallocation adjustments as modified by }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{ that are reported to corporate partners, and to exempt partners to the extent the distributive share is unrelated business income, and allocate and apportion such adjustments as provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.33}}}{{\f5\fs18\hyphpar0\qj{ at the partnership or tiered partner level, and multiply the resulting amount by the maximum state corporate income tax rate pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 422.33}}}{{\f5\fs18\hyphpar0\qj{ for the reviewed year. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine the total distributive share of all final federal partnership adjustments and positive reallocation adjustments as modified by }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{ that are reported to nonresident individual partners and nonresident fiduciary partners and allocate and apportion such adjustments as provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.33}}}{{\f5\fs18\hyphpar0\qj{ at the partnership or tiered partner level, and multiply the resulting amount by the highest individual income tax rate for the reviewed year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the total distributive share of all final federal partnership adjustments and positive reallocation adjustments as modified by }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{ that are reported to tiered partners:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine the amount of such adjustments which are of a type that would be subject to sourcing to Iowa under }}}{{\f5\fs18\hyphpar0\qj{section 422.8, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, as a nonresident, and then determine the portion of this amount that would be sourced to Iowa under those provisions as if the tiered partner were a nonresident.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine the amount of such adjustments which are of a type that would not be subject to sourcing to Iowa under }}}{{\f5\fs18\hyphpar0\qj{section 422.8, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, as a nonresident. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determine the portion of the amount in subparagraph division (b) that can be established, as prescribed by the department by rule, to be properly allocable to indirect partners that are nonresident partners or other partners not subject to tax on the adjustments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Multiply the total of the amounts determined in subparagraph divisions (a) and (b), reduced by any amount determined in subparagraph division (c), by the highest individual income tax rate for the reviewed year. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the total distributive share of all final federal partnership adjustments and positive reallocation adjustments as modified by }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{ that are reported to resident individual partners and resident fiduciary partners, multiply that amount by the highest individual income tax rate for the reviewed year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Total the amounts computed pursuant to subparagraphs (2) through (5) and calculate any interest and penalty as provided under }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding any provision of law to the contrary, interest and penalties on the amount due by the audited partnership or tiered partner shall be computed from the due date of the reviewed year return without extension, and shall be imposed as if the audited partnership or tiered partner was required to pay tax or show tax due on the original return for the reviewed year, except that a specified business subject to the penalty in }}}{{\f5\fs18\hyphpar0\qj{section 421.27, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for the reviewed year shall not also be subject to the penalty in }}}{{\f5\fs18\hyphpar0\qj{section 421.27, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, on the amount due for that reviewed year pursuant to the election to pay.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director may establish rules providing for the calculation of amounts due under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ for federal partnership adjustments that affect state tax owed but that do not fit within the calculation in subparagraphs (2) through (5), such as tax credit changes. The director may establish rules that include changes related to state-specific issues following a state partnership audit in the election to pay and calculation of amounts due under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to allocation and apportionment. Interest and penalty shall be computed in the same manner as described in subparagraph division (a).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adjustments subject to the election in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ do not include any adjustments arising from an administrative adjustment request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An audited partnership or tiered partner not otherwise subject to any reporting or payment obligation to Iowa that makes an election under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ consents to be subject to the Iowa laws related to reporting, assessment, collection, and payment of Iowa tax, interest, and penalties calculated under the election. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E6_2E77_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Modified reporting and payment method.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt procedures for an audited partnership or tiered partner to enter into an agreement with the department to use an alternative reporting and payment method, including applicable time requirements or any other provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The audited partnership or tiered partner must demonstrate that the requested method will reasonably provide for the reporting and payment of taxes, penalties, and interest due under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Application for approval of an alternative reporting and payment method must be made by the audited partnership or tiered partner within the time for making an election to pay under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ and in the manner prescribed by the department. Approval of such an alternative reporting and payment method shall be at the discretion of the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E6_2E77_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Effect of election by partnership or tiered partner and payment of amount due.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The election made under }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ is irrevocable, unless in the discretion of the director, the director determines otherwise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount determined in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, when properly reported and paid by the audited partnership or tiered partner, shall be treated as paid on behalf of the partners of such audited partnership or tiered partner on the same final federal partnership adjustments, provided, however, that no partner may take any deduction or credit for the amount, claim a refund of the amount, or include the amount on such partner\u8217\'3fs Iowa return in any manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event another state offers to an audited partnership or tiered partner a similar election to pay state tax resulting from final federal partnership adjustments, nothing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall prohibit a resident who holds an interest directly in that audited partnership or tiered partner, as the case may be, from claiming a credit for taxes paid by the resident to another state under }}}{{\f5\fs18\hyphpar0\qj{section 422.8, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, for any amounts paid by the audited partnership or tiered partner on such resident partner\u8217\'3fs behalf to another state, provided such payment otherwise meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 422.8, subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall prohibit the department from assessing direct partners and indirect partners for taxes they owe in the event that a partnership or tiered partner fails to timely make any report or payment required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for any reason. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E6_2E77_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Assessments of additional Iowa income tax, interest, and penalties, and claims for refund, arising from final federal partnership adjustments.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall assess additional Iowa income tax, interest, and penalties arising from final federal partnership adjustments in the same manner as provided in }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{ unless a different treatment is provided by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Since final federal partnership adjustments are determined at the partnership level, any assessment issued to partners shall not be appealable by the partner. The department may assess any taxes, including on-behalf-of amounts, interest, and penalties arising from the final federal partnership adjustments if it issues a notice of assessment to the partnership, tiered partner, or other direct or indirect partner on or before the expiration of the applicable limitations period specified in }}}{{\f5\fs18\hyphpar0\qj{section 422.25}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to the period for claiming a refund or credit provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.73, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 422.73, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a partnership, tiered partner, or other direct or indirect partner, as the case may be, may file a claim for refund of Iowa income tax arising directly or indirectly from a final federal partnership adjustment arising from a partnership level audit on or before the date which is one year from the date the federal adjustments report for that final federal partnership adjustment was required to be filed by such person under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E6_2E77_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E6_2E77_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rules.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt any rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1118, \'a764, 71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 86, \'a722 \u8211\'3f 28, 31, 32}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a745 \u8211\'3f 49, 53, 54}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a7105, 112, 114}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a711, 16, 17}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 421.27}}}{{\f5\fs12\hyphpar0\qj{, 422.16B}}}{{\f5\fs12\hyphpar0\qj{, 422.16C}}}{{\f5\fs12\hyphpar0\qj{, 422.25}}}{{\f5\fs12\hyphpar0\qj{, 422.25B}}}{{\f5\fs12\hyphpar0\qj{, 422.25C}}}{{\f5\fs12\hyphpar0\qj{, 422.39}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 amendments to subsections 1, 4, 5, 7, and 8 apply retroactively to July 1, 2020, and apply to federal adjustments and federal partnership adjustments that have a final determination date after July 1, 2020; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 86, \'a732}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2022 amendment to subsection 5, paragraph c, subparagraph (6), subparagraph division (a) applies retroactively to January 1, 2022, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a754}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 5, paragraph c, subparagraphs (3), (4), and (5) applies to tax years beginning on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a717}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.25B}}}{\*\bkmkstart stylerid1_2E6_2E78_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E78_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State pass-through representative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, all words and phrases defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.25A}}}{{\f5\fs18\hyphpar0\qj{ shall have the same meaning given them by that section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state pass-through representative for the reviewed year for a partnership shall be the partnership\u8217\'3fs federal partnership representative with respect to an action required or permitted to be taken by a state pass-through representative under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for a reviewed year, unless the partnership designates in writing another person as the state pass-through representative as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{. The state pass-through representative for the reviewed year for a pass-through entity is the person designated in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may establish reasonable qualifications for a person to be a state pass-through representative. If a partnership desires to designate a person other than the federal partnership representative, the partnership shall designate such person in the manner and form prescribed by the department. A pass-through entity shall designate a person as the state pass-through representative in the manner and form prescribed by the department. A partnership or pass-through entity shall be allowed to change such designation by notifying the department at the time the change occurs in the manner and form prescribed by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt any rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1118, \'a765, 71}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a750}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 422.25A}}}{{\f5\fs12\hyphpar0\qj{, 422.25C}}}{{\f5\fs12\hyphpar0\qj{, 422.39}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.25C}}}{\*\bkmkstart stylerid1_2E6_2E79_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E79_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Partnership and pass-through entity audits and examinations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ consistent treatment of entity-level items }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ binding actions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ amended returns.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, all words and phrases defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.25A}}}{{\f5\fs18\hyphpar0\qj{ shall have the same meaning given them by that section.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning on or after January 1, 2020, any adjustments to a partnership\u8217\'3fs or pass-through entity\u8217\'3fs items of income, gain, loss, expense, or credit, or an adjustment to such items allocated to a partner that holds an interest in a partnership or pass-through entity for the reviewed year by the department as a result of a state partnership audit, shall be determined at the partnership level or pass-through entity level in the same manner as provided by }}}{{\f5\fs18\hyphpar0\qj{section 6221(a) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder unless a different treatment is specifically provided in }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{. The provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 6222}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{6223}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{6227 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder shall also apply to a partnership or pass-through entity and its direct or indirect partners in the same manner as provided in such sections unless a different treatment is specifically provided in }}}{{\f5\fs18\hyphpar0\qj{this title}}}{{\f5\fs18\hyphpar0\qj{. For purposes of applying such sections, due account shall be made for differences in federal and Iowa terminology. The adjustment provided by }}}{{\f5\fs18\hyphpar0\qj{section 6221(a) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall be determined as provided in such section but shall be based on Iowa taxable income or other tax attributes of the partnership or pass-through entity as determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the reviewed year. The department shall issue a notice of adjustment to the partnership or pass-through entity. Such notice shall be treated as an assessment for the purposes of }}}{{\f5\fs18\hyphpar0\qj{section 422.25}}}{{\f5\fs18\hyphpar0\qj{, and the notice shall be appealable, except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.25}}}{{\f5\fs18\hyphpar0\qj{, by the partnership or pass-through entity pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 422.28}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{422.29}}}{{\f5\fs18\hyphpar0\qj{ and shall be issued within the time period provided by }}}{{\f5\fs18\hyphpar0\qj{section 422.25}}}{{\f5\fs18\hyphpar0\qj{. Once the adjustments to partnership-related or pass-through entity-related items or reallocations of income, gains, losses, expenses, credits, and other attributes among such partners for the reviewed year are finally determined, the partnership or pass-through entity and any direct partners or indirect partners shall then be subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 422.25, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 422.25A}}}{{\f5\fs18\hyphpar0\qj{ in the same manner as if the state partnership audit were a federal partnership level audit, and as if the final state partnership audit adjustment were a final federal partnership adjustment. The penalty exceptions in }}}{{\f5\fs18\hyphpar0\qj{section 421.27, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not apply to a state partnership audit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state pass-through representative for the reviewed year as determined under }}}{{\f5\fs18\hyphpar0\qj{section 422.25B}}}{{\f5\fs18\hyphpar0\qj{ shall have the sole authority to act on behalf of the partnership or pass-through entity with respect to an action required or permitted to be taken by a partnership or pass-through entity under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including proceedings under }}}{{\f5\fs18\hyphpar0\qj{section 422.28}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{422.29}}}{{\f5\fs18\hyphpar0\qj{, and the partnership\u8217\'3fs or pass-through entity\u8217\'3fs direct partners and indirect partners shall be bound by those actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department, the partnership or pass-through entity, and owners representing a majority of the ownership interests in the partnership or pass-through entity agree, the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be applied to tax years beginning before January 1, 2020.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to implement }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1118, \'a766, 71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 86, \'a729, 31, 32}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 148, \'a713 \u8211\'3f 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 422.25A}}}{{\f5\fs12\hyphpar0\qj{, 422.39}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 amendment to subsection 4 applies retroactively to July 1, 2020, and applies to federal adjustments and federal partnership adjustments that have a final determination date after July 1, 2020; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 86, \'a732}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 2 applies retroactively to January 1, 2024; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2025/CH0148.pdf" }{\fldrslt \cf5 \f5 \fs12{{2025 Acts, ch 148, \'a715}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.26}}}{\*\bkmkstart stylerid1_2E6_2E8_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E8_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lien of tax \u8212\'3f collection \u8212\'3f action authorized.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever any taxpayer liable to pay a tax and penalty imposed refuses or neglects to pay the same, the amount, including any interest, penalty, or addition to such tax, together with the costs that may accrue in addition thereto, shall be a lien in favor of the state upon all property and rights to property, whether real or personal, belonging to said taxpayer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The lien shall attach at the time the tax becomes due and payable and shall continue for ten years from the date an assessment is issued unless sooner released or otherwise discharged. The lien may, within ten years from the date an assessment is issued, be extended by filing for record a notice with the appropriate county official of any county and from the time of such filing, the lien shall be extended to the property in such county for ten years, unless sooner released or otherwise discharged, with no limit on the number of extensions. The director shall charge off any account whose lien is allowed to lapse and may charge off any account and release the corresponding lien before the lien has lapsed if the director determines under uniform rules prescribed by the director that the account is uncollectible or collection costs involved would not warrant collection of the amount due.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to preserve the aforesaid lien against subsequent mortgagees, purchasers or judgment creditors, for value and without notice of the lien, on any property situated in a county, the director shall file with the recorder of the county, in which said property is located, a notice of said lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county recorder of each county shall keep in the recorder\u8217\'3fs office an index containing the applicable entries in }}}{{\f5\fs18\hyphpar0\qj{sections 558.49}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{558.52}}}{{\f5\fs18\hyphpar0\qj{ and showing the following data, under the names of taxpayers, arranged alphabetically:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the taxpayer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name \u8220\'3fState of Iowa\u8221\'3f as claimant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Time notice of lien was filed for recording.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Date of notice.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amount of lien then due.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Date of assessment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When satisfied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The recorder shall endorse on each notice of lien the day, hour, and minute when filed for recording and the document reference number, shall preserve the same, and shall index the notice in the index and shall record the lien in the manner provided for recording real estate mortgages. The lien is effective from the time of the indexing of the lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall pay recording fees as provided in }}}{{\f5\fs18\hyphpar0\qj{section 331.604}}}{{\f5\fs18\hyphpar0\qj{, for the recording of the lien, or for its satisfaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the payment of a tax as to which the director has filed notice with a county recorder, the director shall forthwith file with said recorder a satisfaction of said tax and the recorder shall enter said satisfaction on the notice on file in the recorder\u8217\'3fs office and indicate said fact on the index aforesaid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall, substantially as provided in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{chapter 626}}}{{\f5\fs18\hyphpar0\qj{, proceed to collect all taxes and penalties as soon as practicable after they become delinquent, except that no property of the taxpayer is exempt from payment of the tax. If service has not been made on a distress warrant by the officer to whom addressed within five days from the date the distress warrant was received by the officer, the authorized revenue agents of the department may serve and make return of the warrant to the clerk of the district court of the county named in the distress warrant, and all subsequent procedure shall be in compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 626}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The distress warrant shall be in a form as prescribed by the director. It shall be directed to the sheriff of the appropriate county and it shall identify the taxpayer, the tax type, and the delinquent amount. It shall direct the sheriff to distrain, seize, garnish, or levy upon, and sell, as provided by law, any real or personal property belonging to the taxpayer to satisfy the amount of the delinquency plus costs. It shall also direct the sheriff to make due and prompt return to the department or to the district court under }}}{{\f5\fs18\hyphpar0\qj{chapters 626}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{642}}}{{\f5\fs18\hyphpar0\qj{ of all amounts collected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general shall, upon the request of the director, bring an action at law or in equity, as the facts may justify, without bond, to enforce payment of any taxes and penalties, and in such action the attorney general shall have the assistance of the county attorney of the county in which the action is pending.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is expressly provided that the foregoing remedies of the state shall be cumulative and that no action taken by the director or attorney general shall be construed to be an election on the part of the state or any of its officers to pursue any remedy hereunder to the exclusion of any other remedy provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fassessment issued\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the most recent assessment against the taxpayer for the tax type and tax period.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f22; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.058;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7422.26}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71220}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1232, \'a78 \u8211\'3f 10}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a718, 124}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 267, \'a7522}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 23, \'a745}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 44, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1177, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 27, \'a714}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 331.602}}}{{\f5\fs12\hyphpar0\qj{, 331.607}}}{{\f5\fs12\hyphpar0\qj{, 421.9}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.39}}}{{\f5\fs12\hyphpar0\qj{, 422.66}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}{{\f5\fs12\hyphpar0\qj{, 423.4}}}{{\f5\fs12\hyphpar0\qj{, 423.42}}}{{\f5\fs12\hyphpar0\qj{, 425.27}}}{{\f5\fs12\hyphpar0\qj{, 428A.8}}}{{\f5\fs12\hyphpar0\qj{, 437A.22}}}{{\f5\fs12\hyphpar0\qj{, 437B.18}}}{{\f5\fs12\hyphpar0\qj{, 450.55}}}{{\f5\fs12\hyphpar0\qj{, 452A.66}}}{{\f5\fs12\hyphpar0\qj{, 453B.11}}}{{\f5\fs12\hyphpar0\qj{, 453B.14}}}{{\f5\fs12\hyphpar0\qj{, 558.41}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.27}}}{\*\bkmkstart stylerid1_2E6_2E81_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E81_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Final report of fiduciary \u8212\'3f conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A final account of a personal representative shall not be allowed by any court unless the account shows, and the judge of the court finds, that all taxes imposed by }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ upon the personal representative, which have become payable, have been paid, and that all taxes which may become due are secured by bond or deposit, or are otherwise secured. The certificate of acquittances of the department of revenue is conclusive as to the payment of the tax to the extent of the acquittance. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply if all property in the estate of a decedent is held in joint tenancy with right of survivorship by husband and wife alone. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpersonal representative\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an administrator, executor, or trustee as each is defined in }}}{{\f5\fs18\hyphpar0\qj{section 633.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of facilitating the settlement and distribution of estates held by fiduciaries, the director may, on behalf of the state, agree upon the amount of taxes at any time due or to become due from such fiduciaries under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, and payment in accordance with such agreement shall be full satisfaction of the taxes to which the agreement relates.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f23; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.059;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.27}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 148, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1054, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1238, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1241, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1232, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 148, \'a733, 53, 54}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 422.39}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}{{\f5\fs12\hyphpar0\qj{, 633.479}}}{{\f5\fs12\hyphpar0\qj{, 635.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fiduciaries\u8217\'3f reports, }{{\f5\fs12\hyphpar0\qj{\'a7636.33}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Similar settlement provision for estates, }{{\f5\fs12\hyphpar0\qj{\'a7450.58}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2025 amendment to subsection 1 applies retroactively to January 1, 2025, to the estates of decedents dying on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 148, \'a754}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.28}}}{\*\bkmkstart stylerid1_2E6_2E82_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E82_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revision of tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A taxpayer may appeal to the director for revision of the tax, interest, or penalties assessed at any time within sixty days from the date of the notice of the assessment of tax, additional tax, interest, or penalties. The director shall grant a hearing and if, upon the hearing, the director determines that the tax, interest, or penalties are excessive or incorrect, the director shall revise them according to the law and the facts and adjust the computation of the tax, interest, or penalties accordingly. The director shall notify the taxpayer by mail of the result of the hearing and shall refund to the taxpayer the amount, if any, paid in excess of the tax, interest, or penalties found by the director to be due, with interest accruing in accordance with }{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{, paragraph }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f24; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.060;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.28}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 131, \'a79}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1007, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1241, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1133, \'a75, 16}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1110, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a77, 15, 16}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 421.10}}}{{\f5\fs12\hyphpar0\qj{, 422.25}}}{{\f5\fs12\hyphpar0\qj{, 422.25A}}}{{\f5\fs12\hyphpar0\qj{, 422.25C}}}{{\f5\fs12\hyphpar0\qj{, 422.29}}}{{\f5\fs12\hyphpar0\qj{, 422.41}}}{{\f5\fs12\hyphpar0\qj{, 422.66}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}{{\f5\fs12\hyphpar0\qj{, 423.37}}}{{\f5\fs12\hyphpar0\qj{, 428A.8}}}{{\f5\fs12\hyphpar0\qj{, 453B.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.29}}}{\*\bkmkstart stylerid1_2E6_2E83_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E83_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Judicial review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Judicial review of actions of the director may be sought in accordance with the terms of the Iowa administrative procedure Act, }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding the terms of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, petitions for judicial review may be filed in the district court of the county in which the petitioner resides, or in which the petitioner\u8217\'3fs principal place of business is located, or in the case of a nonresident not maintaining a place of business in this state either in any county in which the income involved was earned or derived or in Polk county, within sixty days after the petitioner shall have received notice of a determination by the director as provided for in }}}{{\f5\fs18\hyphpar0\qj{section 422.28}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For cause and upon a showing by the director that collection of the tax in dispute is in doubt, the court may order the petitioner to file with the clerk a bond for the use of the respondent, with sureties approved by the clerk, in the amount of tax appealed from, conditioned that the petitioner shall perform the orders of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An appeal may be taken by the taxpayer or the director to the supreme court of this state irrespective of the amount involved.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f25; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.061;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.29}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1133, \'a76, 16}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a773}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 421B.11}}}{{\f5\fs12\hyphpar0\qj{, 422.25}}}{{\f5\fs12\hyphpar0\qj{, 422.25A}}}{{\f5\fs12\hyphpar0\qj{, 422.25C}}}{{\f5\fs12\hyphpar0\qj{, 422.41}}}{{\f5\fs12\hyphpar0\qj{, 422.66}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}{{\f5\fs12\hyphpar0\qj{, 423.37}}}{{\f5\fs12\hyphpar0\qj{, 423.45}}}{{\f5\fs12\hyphpar0\qj{, 428A.8}}}{{\f5\fs12\hyphpar0\qj{, 453A.29}}}{{\f5\fs12\hyphpar0\qj{, 453A.46}}}{{\f5\fs12\hyphpar0\qj{, 453B.14}}}{{\f5\fs12\hyphpar0\qj{, 602.8102(60)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.30}}}{\*\bkmkstart stylerid1_2E6_2E84_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E84_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Jeopardy assessments }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ posting of bond.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director believes that the assessment or collection of taxes will be jeopardized by delay, the director may immediately make an assessment of the estimated amount of tax due, together with all interest, additional amounts, or penalties, as provided by law. The director shall serve the taxpayer by regular mail at the taxpayer\u8217\'3fs last known address or in person, with a written notice of the amount of tax, interest, and penalty due, which notice may include a demand for immediate payment. Service of the notice by regular mail is complete upon mailing. A distress warrant may be issued or a lien filed against the taxpayer immediately.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall be permitted to accept a bond from the taxpayer to satisfy collection until the amount of tax legally due shall be determined. Such bond to be in an amount deemed necessary, but not more than double the amount of the tax involved, and with securities satisfactory to the director.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f26; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.062;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.30}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1165, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a791, 127}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799G.30A}}}{{\f5\fs12\hyphpar0\qj{, 257.22}}}{{\f5\fs12\hyphpar0\qj{, 321.105A}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}{{\f5\fs12\hyphpar0\qj{, 422.41}}}{{\f5\fs12\hyphpar0\qj{, 422.66}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}{{\f5\fs12\hyphpar0\qj{, 423.42}}}{{\f5\fs12\hyphpar0\qj{, 423A.6}}}{{\f5\fs12\hyphpar0\qj{, 423B.6}}}{{\f5\fs12\hyphpar0\qj{, 423C.4}}}{{\f5\fs12\hyphpar0\qj{, 423D.4}}}{{\f5\fs12\hyphpar0\qj{, 423G.5}}}{{\f5\fs12\hyphpar0\qj{, 425.27}}}{{\f5\fs12\hyphpar0\qj{, 428A.8}}}{{\f5\fs12\hyphpar0\qj{, 450.55}}}{{\f5\fs12\hyphpar0\qj{, 453B.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.31}}}{\*\bkmkstart stylerid1_2E6_2E85_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E85_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statute applicable to personal tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All the provisions of }{{\f5\fs18\hyphpar0\qj{section 422.36, subsection 3}}}{, shall be applicable to persons taxable under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f27; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.063;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.31}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.22}}}{{\f5\fs12\hyphpar0\qj{, 422D.3}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER III}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E2_2E2}{BUSINESS TAX ON CORPORATIONS}{\*\bkmkend stylerid1_2E7_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a715.293A}}}{{\f5\fs12\qc{, 15.319}}}{{\f5\fs12\qc{, 15.355}}}{{\f5\fs12\qc{, 15.496}}}{{\f5\fs12\qc{, 15.508}}}{{\f5\fs12\qc{, 15.524}}}{{\f5\fs12\qc{, 15.533}}}{{\f5\fs12\qc{, 15E.27}}}{{\f5\fs12\qc{, 15E.28}}}{{\f5\fs12\qc{, 15E.52}}}{{\f5\fs12\qc{, 15E.62}}}{{\f5\fs12\qc{, 15E.305}}}{{\f5\fs12\qc{, 15E.364}}}{{\f5\fs12\qc{, 16.64}}}{{\f5\fs12\qc{, 16.82}}}{{\f5\fs12\qc{, 16.82A}}}{{\f5\fs12\qc{, 28A.24}}}{{\f5\fs12\qc{, 29C.24}}}{{\f5\fs12\qc{, 190B.103}}}{{\f5\fs12\qc{, 237A.31}}}{{\f5\fs12\qc{, 404A.2}}}{{\f5\fs12\qc{, 422.1}}}{{\f5\fs12\qc{, 422.16C}}}{{\f5\fs12\qc{, 422.73}}}{{\f5\fs12\qc{, 422.85}}}{{\f5\fs12\qc{, 422.110}}}{{\f5\fs12\qc{, 428A.8}}}{{\f5\fs12\qc{, 476B.2}}}{{\f5\fs12\qc{, 476B.6}}}{{\f5\fs12\qc{, 476B.7}}}{{\f5\fs12\qc{, 476C.4}}}{{\f5\fs12\qc{, 476C.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.32}}}{\*\bkmkstart stylerid1_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and unless otherwise required by the context:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAffiliated group\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a group of corporations as defined in }}}{{\f5\fs18\hyphpar0\qj{section 1504(a) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBusiness income\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means income arising from transactions and activity in the regular course of the taxpayer\u8217\'3fs trade or business; or income from tangible and intangible property if the acquisition, management, and disposition of the property constitute integral parts of the taxpayer\u8217\'3fs regular trade or business operations; or gain or loss resulting from the sale, exchange, or other disposition of real property or of tangible or intangible personal property, if the property while owned by the taxpayer was operationally related to the taxpayer\u8217\'3fs trade or business carried on in Iowa or operationally related to sources within Iowa, or the property was operationally related to sources outside this state and to the taxpayer\u8217\'3fs trade or business carried on in Iowa; or gain or loss resulting from the sale, exchange, or other disposition of stock in another corporation if the activities of the other corporation were operationally related to the taxpayer\u8217\'3fs trade or business carried on in Iowa while the stock was owned by the taxpayer. A taxpayer may have more than one regular trade or business in determining whether income is business income.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the intent of the general assembly to treat as apportionable business income all income that may be treated as apportionable business income under the Constitution of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The filing of an Iowa income tax return on a combined report basis is neither allowed nor required by this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommercial domicile\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the principal place from which the trade or business of the taxpayer is directed or managed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCorporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes joint stock companies, and associations organized for pecuniary profit, and partnerships and limited liability companies taxed as corporations under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDomestic corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any corporation organized under the laws of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fForeign corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any corporation other than a domestic corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIncome from sources within this state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means income from real, tangible, or intangible property located or having a situs in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInternal Revenue Code\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning during the 2019 calendar year, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInternal Revenue Code\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code of 1954}}}{{\f5\fs18\hyphpar0\qj{, prior to the date of its redesignation as the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code of 1986}}}{{\f5\fs18\hyphpar0\qj{ by the }}}{{\f5\fs18\hyphpar0\qj{Tax Reform Act of 1986}}}{{\f5\fs18\hyphpar0\qj{, or means the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code of 1986}}}{{\f5\fs18\hyphpar0\qj{ as amended and in effect on March 24, 2018. This definition shall not be construed to include any amendment to the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ enacted after the date specified in the preceding sentence, including any amendment with retroactive applicability or effectiveness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning on or after January 1, 2020, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInternal Revenue Code\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code of 1954}}}{{\f5\fs18\hyphpar0\qj{, prior to the date of its redesignation as the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code of 1986}}}{{\f5\fs18\hyphpar0\qj{ by the }}}{{\f5\fs18\hyphpar0\qj{Tax Reform Act of 1986}}}{{\f5\fs18\hyphpar0\qj{, or means the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code of 1986}}}{{\f5\fs18\hyphpar0\qj{, as amended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNonbusiness income\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all income other than business income.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any state of the United States, the District of Columbia, the Commonwealth of Puerto Rico, any territory or possession of the United States, and any foreign country or political subdivision thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTaxable in another state\u8221\'3f.}}}{{\f5\fs18\hyphpar0\qj{ For purposes of allocation and apportionment of income under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, a taxpayer is }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftaxable in another state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ if:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In that state the taxpayer is subject to a net income tax, a franchise tax measured by net income, a franchise tax for the privilege of doing business, or a corporate stock tax; or}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That state has jurisdiction to subject the taxpayer to a net income tax regardless of whether, in fact, the state does or does not.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnitary business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business carried on partly within and partly without a state where the portion of the business carried on within the state depends on or contributes to the business outside the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words, terms, and phrases defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.4, subsections 3, 4, 5, 7, 8, 12, 14, 15, and 16}}}{{\f5\fs18\hyphpar0\qj{, when used in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, shall have the meanings ascribed to them in }}}{{\f5\fs18\hyphpar0\qj{section 422.4,}}}{{\f5\fs18\hyphpar0\qj{ except where the context clearly indicates a different meaning.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f28; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.064;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.32}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 132, \'a77, 9}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1023, \'a711, 30}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1103, \'a71111}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1203, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 179, \'a712, 13, 21, 23}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a733, 34}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 1st Ex, ch 1, \'a75}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1028, \'a730 \u8211\'3f 32, 55}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1151, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1165, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 141, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 158, \'a713, 49}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 152, \'a74, 40}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 139, \'a78, 11, 12}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2004 Acts, 1st Ex, ch 1001, \'a739, 41, 42}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 24, \'a77, 10, 11}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1140, \'a76, 10, 11}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 12, \'a75, 7, 8}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1011, \'a76, 9}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 60, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 41, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1007, \'a75, 7, 8}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 1, \'a75, 7, 8}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a788}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1076, \'a74, 6, 7}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1092, \'a789}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 1, \'a75, 7, 8}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 157, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7130}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a787, 97, 98}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.15}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For applicable definition of Internal Revenue Code for a tax year prior to 2019, refer to Iowa Acts and Code for that year}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.33}}}{\*\bkmkstart stylerid1_2E7_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Corporate tax imposed \u8212\'3f credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A tax is imposed annually upon each corporation doing business in this state, or deriving income from sources within this state, in an amount computed by applying the following rates of taxation to the net income received by the corporation during the income year:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the first twenty-five thousand dollars of taxable income, or any part thereof, the rate of six percent for tax years beginning prior to January 1, 2021, and the rate of five and one-half percent for tax years beginning on or after January 1, 2021.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On taxable income between twenty-five thousand dollars and one hundred thousand dollars or any part thereof, the rate of eight percent for tax years beginning prior to January 1, 2021, and the rate of five and one-half percent for tax years beginning on or after January 1, 2021.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On taxable income between one hundred thousand dollars and two hundred fifty thousand dollars or any part thereof, the rate of ten percent for tax years beginning prior to January 1, 2021, and the rate of nine percent for tax years beginning on or after January 1, 2021.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On taxable income of two hundred fifty thousand dollars or more, the rate of twelve percent for tax years beginning prior to January 1, 2021, and the rate of nine and eight-tenths percent for tax years beginning on or after January 1, 2021.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department of management and the department of revenue shall determine corporate income tax rates as provided in this paragraph. A tax rate in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall remain in effect until the tax rate is adjusted pursuant to this paragraph.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By November 1, 2022, and by November 1 each year thereafter, the department of management shall determine the net corporate income tax receipts for the fiscal year preceding the determination date. If net corporate income tax receipts for the preceding fiscal year exceed seven hundred million dollars, the department of revenue shall adjust and apply new corporate income tax rates as provided in subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a determination has been made that net corporate income tax receipts for the preceding fiscal year exceeded seven hundred million dollars, the department of revenue shall adjust the tax rates specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (3) and (4), and apply the adjusted rates for tax years beginning on or after the next January 1 following the determination date.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax rates subject to adjustment shall be adjusted in such a way that when combined with all the other rates specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the tax rates would have generated net corporate income tax receipts that equal seven hundred million dollars in the preceding fiscal year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When adjusting the tax rates, the tax rates shall be adjusted as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(A)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax rate in effect that corresponds with the specified tax rate in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (4), shall first be adjusted but not below the tax rate in effect that corresponds with the specified rate in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(B)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If after the adjustment in subparagraph part (A) is made, and an additional adjustment is necessary, the tax rates that correspond with the rates specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (3) and (4), shall be adjusted on an equal basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax rates adjusted pursuant to this paragraph shall not be adjusted below five and one-half percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax rates, when adjusted, shall be rounded down to the nearest one-tenth of one percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a tax rate is adjusted pursuant to this paragraph, the director of revenue shall cause an advisory notice containing the new corporate tax rates to be published in the Iowa administrative bulletin and on the internet site of the department of revenue. The calculation and publication of the adjusted tax rate by the director of revenue is exempt from }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, and shall be submitted for publication by the first December 31 following the determination date to adjust the tax rates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1A.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is imposed upon each corporation exempt from the general business tax on corporations by }}}{{\f5\fs18\hyphpar0\qj{section 422.34, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, a tax at the rates in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ upon the state\u8217\'3fs apportioned share computed in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{ of the unrelated business income computed in accordance with the Internal Revenue Code and with the adjustments set forth in }}}{{\f5\fs18\hyphpar0\qj{section 422.35}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the trade or business of the corporation is carried on entirely within the state, the tax shall be imposed on the entire net income, but if the trade or business is carried on partly within and partly without the state or if income is derived from sources partly within and partly without the state, or if income is derived from trade or business and sources, all of which are not entirely in the state, the tax shall be imposed only on the portion of the net income reasonably attributable to the trade or business or sources within the state, with the net income attributable to the state to be determined as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonbusiness interest, dividends, rents and royalties, less related expenses, shall be allocated within and without the state in the following manner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonbusiness interest, dividends, and royalties from patents and copyrights shall be allocable to this state if the taxpayer\u8217\'3fs commercial domicile is in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonbusiness rents and royalties received from real property located in this state are allocable to this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonbusiness rents and royalties received from tangible personal property are allocable to this state to the extent that the property is utilized in this state; or in their entirety if the taxpayer\u8217\'3fs commercial domicile is in this state and the taxpayer is not taxable in the state in which the property is utilized. The extent of utilization of tangible personal property in a state is determined by multiplying the rents and royalties by a fraction, the numerator of which is the number of days of physical location of the property in the state during the rental or royalty period in the taxable year and the denominator of which is the number of days of physical location of the property everywhere during all rental or royalty periods in the taxable year. If the physical location of the property during the rental or royalty period is unknown or unascertainable by the taxpayer, tangible personal property is utilized in the state in which the property was located at the time the rental or royalty payor obtained possession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonbusiness capital gains and losses from the sale or other disposition of assets shall be allocated as follows:}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Gains and losses from the sale or other disposition of real property located in this state are allocable to this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Gains and losses from the sale or other disposition of tangible personal property are allocable to this state if the property had a situs in this state at the time of the sale or disposition or if the taxpayer\u8217\'3fs commercial domicile is in this state and the taxpayer is not taxable in the state in which the property had a situs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Gains and losses from the sale or disposition of intangible personal property are allocable to this state if the taxpayer\u8217\'3fs commercial domicile is in this state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Net nonbusiness income of the above class having been separately allocated and deducted as above provided, the remaining net business income of the taxpayer shall be allocated and apportioned as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Business interest, dividends, rents, and royalties shall be reasonably apportioned within and without the state under rules adopted by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Capital gains and losses from the sale or other disposition of assets shall be apportioned to the state based upon the business activity ratio applicable to the year the gain or loss is determined if the corporation determines Iowa taxable income by a sales, gross receipts or other business activity ratio. If the corporation has only allocable income, capital gains and losses from the sale or other disposition of assets shall be allocated in accordance with subparagraph (1), subparagraph division (d).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where income is derived from business other than the manufacture or sale of tangible personal property, the income shall be specifically allocated or equitably apportioned within and without the state under rules of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where income is derived from the manufacture or sale of tangible personal property, the part attributable to business within the state shall be in that proportion which the gross sales made within the state bear to the total gross sales.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding subparagraph division (c), where income is derived by a broadcaster from broadcasting, the part attributable to business within the state shall be in the proportion that the gross receipts from broadcasting derived from customers whose commercial domicile is in this state bears to the total gross receipts from broadcasting.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding subparagraph subdivision (i) or subparagraph division (c), where income is derived by a broadcaster from national or local political advertising that is directed exclusively at one or more markets in this state, all gross receipts from such advertising shall be attributable to business within the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this subparagraph division:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(A)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBroadcaster\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a taxpayer who is engaged in the business of broadcasting. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBroadcaster\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a television network, a cable program network, and a television distribution company. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBroadcaster\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a cable system operator, a direct broadcast satellite system operator, or a television or radio station licensed by the federal communications commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(B)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBroadcasting\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the transmission of film programming by an electronic or other signal conducted by microwaves, wires, lines, coaxial cables, wave guides, fiber optics, satellite transmissions, or through any other means of communication directly or indirectly to viewers and listeners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(C)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCustomer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who has a direct contractual relationship with a broadcaster from whom the broadcaster derives gross receipts. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCustomer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to an advertiser or licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(D)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGross receipts from broadcasting\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means gross receipts of a broadcaster from transactions and activities in the regular course of its business, including but not limited to advertising, licensing, and distribution, but excluding gross receipts from the sale of real property or tangible personal property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding subparagraph division (c), income described in }}}{{\f5\fs18\hyphpar0\qj{section 29C.24, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), shall not be allocated and apportioned to the state, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 29C.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(g)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where income consists of more than one class of income as provided in subparagraph divisions (a) through (e) of this subparagraph, it shall be reasonably apportioned by the business activity ratio provided in rules adopted by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(h)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The gross sales of the corporation within the state shall be taken to be the gross sales from goods delivered or shipped to a purchaser within the state regardless of the F.O.B. point or other conditions of the sale, excluding deliveries for transportation out of the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufacture\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include the extraction and recovery of natural resources and all processes of fabricating and curing. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSale\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include exchange.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTangible personal property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be taken to mean corporeal personal property, such as machinery, tools, implements, goods, wares, and merchandise, and shall not be taken to mean money deposits in banks, shares of stock, bonds, notes, credits, or evidence of an interest in property and evidences of debt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any taxpayer believes that the method of allocation and apportionment prescribed in }}}{{\f5\fs18\hyphpar0\qj{subsections 1A and 2}}}{{\f5\fs18\hyphpar0\qj{, as administered by the director and applied to the taxpayer\u8217\'3fs business, has operated or will so operate as to subject the taxpayer to taxation on a greater portion of the taxpayer\u8217\'3fs net income than is reasonably attributable to business or sources within the state, the taxpayer shall be entitled to file with the director a statement of the taxpayer\u8217\'3fs objections and of such alternative method of allocation and apportionment as the taxpayer believes to be proper under the circumstances with such detail and proof and within such time as the director may reasonably prescribe; and if the director shall conclude that the method of allocation and apportionment theretofore employed is in fact inapplicable and inequitable, the director shall redetermine the taxable income by such other method of allocation and apportionment as seems best calculated to assign to the state for taxation the portion of the income reasonably attributable to business and sources within the state, not exceeding, however, the amount which would be arrived at by application of the statutory rules for apportionment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by a state tax credit through the tax year beginning on or after January 1, 2025, but before January 1, 2026, for increasing research activities in this state equal to the sum of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six and one-half percent of the excess of qualified research expenses during the tax year over the base amount for the tax year based upon the state\u8217\'3fs apportioned share of the qualifying expenditures for increasing research activities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Six and one-half percent of the basic research payments determined under }}}{{\f5\fs18\hyphpar0\qj{section 41(e)(1)(A) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ during the tax year based upon the state\u8217\'3fs apportioned share of the qualifying expenditures for increasing research activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state\u8217\'3fs apportioned share of the qualifying expenditures for increasing research activities is a percent equal to the ratio of qualified research expenditures in this state to the total qualified research expenditures.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of calculating the state\u8217\'3fs apportioned share of the qualifying expenditures for increasing research activities in subparagraph (1), the following criteria shall apply only to the determination of qualified research expenditures in this state:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wages paid to an employee for qualified services, or contract research expenses paid to a third party for the performance of qualified research services, shall only constitute qualified research expenses in this state if the services are performed in this state, and if the following conditions are met, as applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For qualified services performed by employees, during the period of the tax year that the business is engaging in one or more research projects, a majority of the total services performed by the employee for the business are directly related to those research projects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the performance of qualified research services by a third party, during the period of the business\u8217\'3fs tax year that the third party is performing research services for the business, a majority of the total services performed by the person for the third party are directly related to those research projects of the business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The substantially all rule for determining qualified services as described in }}}{{\f5\fs18\hyphpar0\qj{section 41(b)(2)(B) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj\cf1{Treas. Reg. 1.41-2(d)(2)}}}{{\f5\fs18\hyphpar0\qj{ does not apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amounts paid for the right to use computers as described in }}}{{\f5\fs18\hyphpar0\qj{section 41(b)(2)(A)(iii) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall not be qualified research expenses in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning on or after January 1, 2023, but before January 1, 2027, amounts paid for supplies as defined in }}}{{\f5\fs18\hyphpar0\qj{section 41(b)(2)(C) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall only constitute qualified research expenses in this state if the supplies directly relate to research performed in this state and shall be limited to the following allowable percentages:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2023, but before January 1, 2024, eighty percent of the amounts paid for supplies directly related to research performed in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2024, but before January 1, 2025, sixty percent of the amounts paid for supplies directly related to research performed in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2025, but before January 1, 2026, forty percent of the amounts paid for supplies directly related to research performed in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning on or after January 1, 2026, amounts paid for supplies as defined in }}}{{\f5\fs18\hyphpar0\qj{section 41(b)(2)(C) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ shall not be qualified research expenses in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of the credit amount computed in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), a corporation shall elect to compute the credit amount for qualified research expenses incurred in this state in a manner consistent with the alternative simplified credit described in }}}{{\f5\fs18\hyphpar0\qj{section 41(c)(4) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ if the taxpayer elected or was required to use the alternative simplified credit method for federal income tax purposes for the same taxable year. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of the alternate credit computation method in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the following criteria shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The credit percentages applicable to qualified research expenses described in }}}{{\f5\fs18\hyphpar0\qj{section 41(c)(4)(A)}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{clause (ii) of section 41(c)(4)(B) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ are four and fifty-five hundredths percent and one and ninety-five hundredths percent, respectively.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Basic research payments and qualified research expenses shall only include amounts for research conducted in this state. A taxpayer\u8217\'3fs qualified research expenses in this state and average prior year qualified research expenses in this state shall be determined in accordance with the rules in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation shall only be eligible for the credit provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if the business conducting the research meets all of the following requirements:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business is engaged in the manufacturing, life sciences, agriscience, software engineering, or aviation and aerospace industry.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Persons that shall not be considered to be engaged in the manufacturing, life sciences, agriscience, software engineering, or aviation and aerospace industry, and thus are not eligible for the credit, include but are not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(A)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person engaged in agricultural production as defined in }}}{{\f5\fs18\hyphpar0\qj{section 423.1}}}{{\f5\fs18\hyphpar0\qj{, except if the credit is based on conducting agriscience research and the person or the business is engaged in bovine and porcine veterinary research, the person shall not be considered to be engaged in agricultural production as defined in }}}{{\f5\fs18\hyphpar0\qj{section 423.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(B)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this subparagraph subdivision, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fagriscience research\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means research that is approved and overseen or monitored by a board that includes, at a minimum, an individual who was employed with, contracted by, or professionally trained by an accredited university as a researcher in an applied animal science and an individual holding a doctor of veterinary medicine or a doctoral degree in an applied animal science; is conducted in this state in an applied animal science; improves the scientific knowledge base or increases scientific innovation, performance, or viability within this state; the results of the research are evaluated by a person educated and trained in statistics by an accredited university and capable of applying generally accepted methodologies to the results in accordance with industry standards in an applied animal science; and the results of the research are made available to the public by submission to or publication in a journal, magazine, or similar periodical, if the statistical evaluation indicated the research is reliable and relevant to an applied animal science.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(C)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in this subparagraph subdivision, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fapplied animal science\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the areas of animal science, veterinary medicine, nutritional science, genetic science, and microbiology.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is a contractor, subcontractor, builder, or a contractor-retailer that engages in commercial and residential repair and installation, including but not limited to heating or cooling installation and repair, plumbing and pipe fitting, security system installation, and electrical installation and repair. For purposes of this subparagraph subdivision, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcontractor-retailer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business that makes frequent retail sales to the public or to other contractors and that also engages in the performance of construction contracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A finance or investment company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(v)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A wholesaler.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(vi)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A transportation company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(vii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A publisher.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(viii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agricultural cooperative association as defined in }}}{{\f5\fs18\hyphpar0\qj{section 502.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ix)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A real estate company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(x)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A collection agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(xi)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An accountant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(xii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An architect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The business claims and is allowed a research credit for such qualified research expenses under }}}{{\f5\fs18\hyphpar0\qj{section 41 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ for the same taxable year as it is claiming the credit provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The credit provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is claimed on a return filed by the due date for filing the return, including extensions of time. If timely claimed, the business shall not increase the credit claim on an amended return or otherwise unless either of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amended return is filed within six months of the due date for filing the return which includes extensions of time.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The increase results from an audit or examination by the internal revenue service or the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbase amount\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the product of the fixed-based percentage times the average annual gross receipts of the taxpayer for the four taxable years preceding the taxable year for which the credit is being determined, but in no event shall the base amount be less than fifty percent of the qualified research expenses for the credit year.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbasic research payment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualified research expense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the same as defined for the federal credit for increasing research activities under }}}{{\f5\fs18\hyphpar0\qj{section 41 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, except as otherwise described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), and paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following percentage of the credit in excess of the tax liability for the taxable year shall be refunded with interest in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2023, but before January 1, 2024, ninety percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2024, but before January 1, 2025, eighty percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2025, but before January 1, 2026, seventy percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iv)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2026, but before January 1, 2027, sixty percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of claiming a refund pursuant to this subparagraph, a taxpayer may elect to have the overpayment otherwise eligible for a refund shown on its final, completed return credited to the tax liability for the following taxable year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Commencing with tax years beginning on or after January 1, 2027, fifty percent of any credit in excess of the tax liability for the taxable year shall be refunded with interest in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. In lieu of claiming a refund, a taxpayer may elect to have the overpayment otherwise eligible for a refund shown on its final, completed return credited to the tax liability for the following taxable year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In applying the credit in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ against tax liability and computing the eligible refund amount, the credit shall be applied after all nonrefundable credits available to the taxpayer are applied, but before any other refundable credit available to the taxpayer is applied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall by February 15 of each year issue an annual report to the general assembly containing the total amount of all claims made by employers under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and the portion of the claims issued as refunds, for all claims processed during the previous calendar year. The report shall contain the name of each claimant for whom a tax credit in excess of five hundred thousand dollars was issued and the amount of the credit received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ is repealed January 1, 2027.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by a new jobs tax credit. An industry which has entered into an agreement under }}}{{\f5\fs18\hyphpar0\qj{chapter 260E}}}{{\f5\fs18\hyphpar0\qj{ and which has increased its base employment level by at least ten percent within the time set in the agreement or, in the case of an industry without a base employment level, adds new jobs within the time set in the agreement is entitled to this new jobs tax credit for the tax year selected by the industry. In determining if the industry has increased its base employment level by ten percent or added new jobs, only those new jobs directly resulting from the project covered by the agreement and those directly related to those new jobs shall be counted.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of this credit is equal to the product of six percent of the taxable wages, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 96.1A, subsection 36}}}{{\f5\fs18\hyphpar0\qj{, upon which an employer is required to contribute to the state unemployment compensation fund, times the number of new jobs existing in the tax year that directly result from the project covered by the agreement or new jobs that directly result from those new jobs. The tax year chosen by the industry shall either begin or end during the period beginning with the date of the agreement and ending with the date by which the project is to be completed under the agreement. Any credit in excess of the tax liability for the tax year may be credited to the tax liability for the following ten tax years or until depleted in less than the ten years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fagreement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3findustry\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fnew job\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fproject\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 260E.2}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbase employment level\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the number of full-time jobs an industry employs at the plant site which is covered by an agreement under }}}{{\f5\fs18\hyphpar0\qj{chapter 260E}}}{{\f5\fs18\hyphpar0\qj{ on the date of that agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by a franchise tax credit. A taxpayer who is a shareholder in a financial institution, as defined in section 581 of the Internal Revenue Code, which has in effect for the tax year an election under subchapter S of the Internal Revenue Code shall compute the amount of the tax credit by recomputing the amount of tax under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ by reducing the taxable income of the taxpayer by the taxpayer\u8217\'3fs pro rata share of the items of income and expense of the financial institution. This recomputed tax shall be subtracted from the tax computed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and the resulting amount, which shall not exceed the taxpayer\u8217\'3fs pro rata share of franchise tax paid by the financial institution, is the amount of the franchise tax credit allowed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by an assistive device tax credit through the tax year beginning on or after January 1, 2024, but before January 1, 2025. A small business purchasing, renting, or modifying an assistive device or making workplace modifications for an individual with a disability who is employed or will be employed by the small business is eligible, subject to availability of credits, to receive this assistive device tax credit which is equal to fifty percent of the first five thousand dollars paid during the tax year for the purchase, rental, or modification of the assistive device or for making the workplace modifications. The following percentage of any credit in excess of the tax liability shall be refunded with interest in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 421.60, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2023, but before January 1, 2024, ninety-five percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning on or after January 1, 2024, but before January 1, 2025, ninety percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In lieu of claiming a refund, a taxpayer may elect to have the overpayment otherwise eligible for a refund shown on the taxpayer\u8217\'3fs final, completed return credited to the tax liability for the following tax year. If the small business elects to take the assistive device tax credit, the small business shall not deduct for Iowa tax purposes any amount of the cost of an assistive device or workplace modifications which is deductible for federal income tax purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To receive the assistive device tax credit, the eligible small business must submit an application to the economic development authority. If the taxpayer meets the criteria for eligibility, the economic development authority shall issue to the taxpayer a certification of entitlement for the assistive device tax credit. However, the combined amount of tax credits that may be approved for a fiscal year under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not exceed five hundred thousand dollars. Tax credit certificates shall be issued on an earliest filed basis. The certification shall contain the taxpayer\u8217\'3fs name, address, tax identification number, the amount of the credit, and tax year for which the certificate applies. The taxpayer must file the tax credit certificate with the taxpayer\u8217\'3fs corporate income tax return in order to claim the tax credit. The economic development authority and department of revenue shall each adopt rules to jointly administer }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and shall provide by rule for the method to be used to determine for which fiscal year the tax credits are approved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssistive device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any item, piece of equipment, or product system which is used to increase, maintain, or improve the functional capabilities of an individual with a disability in the workplace or on the job. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssistive device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean any medical device, surgical device, or organ implanted or transplanted into or attached directly to an individual. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssistive device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include any device for which a certificate of title is issued by the state department of transportation, but does include any item, piece of equipment, or product system otherwise meeting the definition of }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fassistive device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that is incorporated, attached, or included as a modification in or to such a device issued a certificate of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDisability\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 15.102}}}{{\f5\fs18\hyphpar0\qj{, except that it does not include alcoholism.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSmall business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business that either had gross receipts for its preceding tax year of three million dollars or less or employed not more than fourteen full-time employees during its preceding tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWorkplace modifications\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means physical alterations to the work environment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ is repealed January 1, 2031.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by a historic preservation tax credit allowed under }}}{{\f5\fs18\hyphpar0\qj{chapter 404A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11A.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11B.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by an E-85 gasoline promotion tax credit for each tax year that the taxpayer is eligible to claim the tax credit under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{