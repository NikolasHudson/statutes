fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to any amount of contribution that represents a transfer from the Iowa educational savings plan trust created in }}}{{\f5\fs18\hyphpar0\qj{chapter 12D}}}{{\f5\fs18\hyphpar0\qj{ that meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 22}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (c), and that was previously deducted as a contribution to the Iowa educational savings plan trust.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Add the amount resulting from the cancellation of a participation agreement refunded to the taxpayer as an account owner in the Iowa ABLE savings plan trust or the qualified ABLE program with which the state has contracted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12I.10}}}{{\f5\fs18\hyphpar0\qj{ to the extent previously deducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ by the taxpayer or any other person as a contribution to the trust or qualified ABLE program, or to the extent the amount was previously deducted by the taxpayer or any other person pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 22}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and qualified as a transfer under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Add the amount resulting from a withdrawal made by a taxpayer from the Iowa ABLE savings plan trust or the qualified ABLE program with which the state has contracted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12I.10}}}{{\f5\fs18\hyphpar0\qj{ for purposes other than the payment of qualified disability expenses to the extent previously deducted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ by the taxpayer or any other person as a contribution to the trust or qualified ABLE program, or to the extent the amount was previously deducted by the taxpayer or any other person pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 22}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and qualified as a transfer under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, income from interest and earnings received from the Iowa ABLE savings plan trust created in }}}{{\f5\fs18\hyphpar0\qj{chapter 12I}}}{{\f5\fs18\hyphpar0\qj{, or received by a resident account owner from a qualified ABLE program with which the state has contracted pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 12I.10}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent not otherwise excluded, the amount of withdrawals from qualified retirement plan accounts made during the tax year if the taxpayer or taxpayer\u8217\'3fs spouse is a member of the Iowa national guard or reserve forces of the United States who is ordered to national guard duty or federal active duty. In addition, a penalty for such withdrawals shall not be assessed by the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the restrictions in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subtract the sum of the following amounts: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of contributions made by an account holder during the tax year to the account holder\u8217\'3fs first-time homebuyer savings accounts, not to exceed the following annual limit:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For married taxpayers who file a joint return and maintain a joint first-time homebuyer savings account, four thousand dollars.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any other account holder, two thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning in the 2018 calendar year and for each subsequent tax year, the director shall multiply each dollar amount set forth in subparagraph division (a), subparagraph subdivisions (i) and (ii), by the latest cumulative inflation factor, shall round off the resulting product to the nearest one dollar, and shall incorporate the result into the income tax forms and instructions for each tax year. For purposes of this subparagraph division, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcumulative inflation factor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the product of the annual inflation factor for the 2018 calendar year and all annual inflation factors for subsequent calendar years as determined by }}}{{\f5\fs18\hyphpar0\qj{section 422.4, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. The cumulative inflation factor applies to all tax years beginning on or after January 1 of the calendar year for which the latest annual inflation factor has been determined. Notwithstanding any other provision, the annual inflation factor for the 2018 calendar year is one hundred percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To the extent included, income from interest received from the account holder\u8217\'3fs first-time homebuyer savings accounts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The subtraction in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not exceed the following aggregate lifetime limit:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For married taxpayers who file a joint return and maintain a joint first-time homebuyer savings account, an amount equal to the product of the deductible amount determined for the year in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (a), subparagraph subdivision (i), multiplied by ten.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any other account holder, an amount equal to the product of the deductible amount determined for the year in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), subparagraph division (a), subparagraph subdivision (ii), multiplied by ten.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The subtraction in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall not be allowed to an account holder upon one of the following dates, whichever occurs first:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{January 1 of the tenth calendar year after the calendar year during which the account holder first opened a first-time homebuyer savings account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date on which funds within an account holder\u8217\'3fs first-time homebuyer savings account are withdrawn for purposes other than the payment or reimbursement of the designated beneficiary\u8217\'3fs eligible home costs in connection with a qualified home purchase. Any amount transferred between different first-time homebuyer savings accounts of the same account holder by a person other than the account holder shall not be considered a withdrawal for purposes of this subparagraph division (b).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Add, to the extent previously deducted under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), the amount withdrawn during the tax year from an account holder\u8217\'3fs first-time homebuyer savings account for purposes other than the payment or reimbursement of the designated beneficiary\u8217\'3fs eligible home costs in connection with a qualified home purchase.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, any amount remaining in an account holder\u8217\'3fs first-time homebuyer savings account on January 1 of the tenth calendar year after the calendar year during which the account holder first opened a first-time homebuyer savings account shall be considered immediately withdrawn under subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the transfer of amounts between different first-time homebuyer accounts of the same account holder by a person other than the account holder shall not cause such transfer to be considered a withdrawal under subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any amount considered a withdrawal required to be added to net income pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the account holder shall be assessed a penalty equal to ten percent of the amount of the withdrawal. The penalty shall not apply to withdrawals made by reason of the death of the account holder, or to withdrawals made pursuant to a garnishment, levy, or other order, including but not limited to an order in bankruptcy following a filing for protection under the federal bankruptcy code, }}}{{\f5\fs18\hyphpar0\qj{11 U.S.C. \'a7101 et seq.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Add, to the extent deducted for federal tax purposes, interest, taxes, and other miscellaneous expenses to the extent such amounts are eligible home costs in connection with a qualified home purchase that were paid or reimbursed from funds in a first-time homebuyer savings account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3faccount holder\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdesignated beneficiary\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3feligible home costs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffirst-time homebuyer savings account\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualified home purchase\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 541B.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, military student loan repayments received by the taxpayer serving on active duty in the national guard or armed forces military reserve or on active duty status in the armed forces.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{29.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, all pay received by the taxpayer from the federal government for military service performed while on active duty status in the armed forces, the armed forces military reserve, or the national guard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{30.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the taxpayer, while living, donates one or more of the taxpayer\u8217\'3fs human organs to another human being for immediate human organ transplantation during the tax year, subtract, to the extent not otherwise excluded, the following unreimbursed expenses incurred by the taxpayer and related to the taxpayer\u8217\'3fs organ donation:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Travel expenses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lodging expenses.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lost wages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum amount that may be deducted under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is ten thousand dollars. A taxpayer shall only take the deduction under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ once. If a deduction is taken under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the amount of expenses shall not be considered medical care expenses under section 213 of the Internal Revenue Code for state tax purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhuman organ\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all or part of a liver, pancreas, kidney, intestine, lung, or bone marrow.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{31.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, the amount of any grant provided pursuant to the injured veterans grant program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 35A.14}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{32.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, amounts received from the veterans trust fund for any of the following items:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Travel expenses pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 35A.13, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unemployment assistance pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 35A.13, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{33.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent not otherwise deducted in computing federal taxable income, the amounts paid by the taxpayer to the department of veterans affairs for the purpose of providing grants under the injured veterans grant program established in }}}{{\f5\fs18\hyphpar0\qj{section 35A.14}}}{{\f5\fs18\hyphpar0\qj{. Amounts subtracted under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be used by the taxpayer in computing the amount of charitable contributions as defined by }}}{{\f5\fs18\hyphpar0\qj{section 170 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{34.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, income from interest and earnings received from a burial trust fund as defined in }}}{{\f5\fs18\hyphpar0\qj{section 523A.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{35.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, the amount of victim compensation awards paid under the victim compensation program, victim restitution payments received pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 910}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{915}}}{{\f5\fs18\hyphpar0\qj{, and any damages awarded by a court, and received by the taxpayer, in a civil action filed by the victim against the offender, during the tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{36.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, the amount of any biodiesel production refund provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 423.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{37.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A taxpayer who is an eligible educator as defined in }}}{{\f5\fs18\hyphpar0\qj{section 62(d)(1) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ is allowed to take the deduction for certain expenses of elementary and secondary school teachers allowed under }}}{{\f5\fs18\hyphpar0\qj{section 62(a)(2)(D) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ in computing net income for state tax purposes in excess of the amount of the taxpayer\u8217\'3fs deduction for certain expenses of elementary and secondary school teachers for federal tax purposes allowed under }}}{{\f5\fs18\hyphpar0\qj{section 62(a)(2)(D) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, but not to exceed five hundred dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{38.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any adjustment subtracted from federal taxable income for an adjustment year pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 6225 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder shall be added back in computing net income of the partnership and the partners for state tax purposes for the adjustment year. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{39.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 163(j) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ does not apply in computing net income for state tax purposes. If the taxpayer\u8217\'3fs federal adjusted gross income for the tax year was increased or decreased by reason of the application of }}}{{\f5\fs18\hyphpar0\qj{section 163(j) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, the taxpayer shall recompute net income for state tax purposes under rules prescribed by the director. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any tax year in which paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply, a taxpayer shall not be permitted to deduct any amount of interest expense paid or accrued in a previous taxable year that is allowed as a deduction in the current taxable year by reason of the carryforward of disallowed business interest provisions of }}}{{\f5\fs18\hyphpar0\qj{section 163(j)(2) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, if either of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interest expense was originally paid or accrued during a tax year in which paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applied. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interest expense was originally paid or accrued during a tax year in which the taxpayer was not required to file an Iowa return. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{40.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law to the contrary, any funds received by a student through a higher education institution to support the student\u8217\'3fs financial needs as a result of the COVID-19 pandemic pursuant to }}}{{\f5\fs18\hyphpar0\qj{\'a7\'a73504}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{18004}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{18008 of Pub. L. No. 116-136}}}{{\f5\fs18\hyphpar0\qj{ shall not be included in the student\u8217\'3fs Iowa net income for any tax year ending after March 27, 2020.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{41.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{42.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract the following percentage of the net capital gain from the sale or exchange of capital stock of a qualified corporation for which an election is made by an employee-owner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning in the 2023 calendar year, thirty-three percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the tax year beginning in the 2024 calendar year, sixty-six percent.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For tax years beginning on or after January 1, 2025, one hundred percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee-owner is entitled to make one irrevocable lifetime election to exclude the net capital gain from the sale or exchange of capital stock of one qualified corporation which capital stock was acquired by the employee-owner while employed and on account of employment by such qualified corporation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The election shall apply to all subsequent sales or exchanges of qualifying capital stock of the elected corporation within fifteen years of the date of the election, provided that the subsequent sales or exchanges were of capital stock in the same qualified corporation and were acquired by the employee-owner while employed and on account of employment by such qualified corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The election shall apply to qualifying capital stock that has been transferred by inter vivos gift from the employee-owner to the employee-owner\u8217\'3fs spouse or to a trust for the benefit of the employee-owner\u8217\'3fs spouse following the transfer. This subparagraph (3) shall apply to a spouse only if the spouse was married to the employee-owner on the date of the sale or exchange or the date of death of the employee-owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the employee-owner dies after having sold or exchanged qualifying capital stock without having made an election under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the surviving spouse or, if there is no surviving spouse, the personal representative of the employee-owner\u8217\'3fs estate, may make the election that would have qualified under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The election shall be made in the manner and form prescribed by the department and shall be included with the taxpayer\u8217\'3fs state income tax return for the taxable year in which the election is made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCapital stock\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means common or preferred stock, either voting or nonvoting. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCapital stock\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include stock rights, stock warrants, stock options, or debt securities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmployee-owner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who owns capital stock in a qualified corporation for at least ten years, which capital stock was acquired by the individual while employed and on account of employment by such corporation for at least ten cumulative years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal representative\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 633.3}}}{{\f5\fs18\hyphpar0\qj{, or if there is no such personal representative appointed, then the person legally authorized to perform substantially the same functions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fQualified corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means, with respect to an employee-owner, a corporation which, at the time of the first sale or exchange for which an election is made by the employee- owner under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation employed individuals in this state for at least ten years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation has had at least five shareholders for the ten years prior to the first sale or exchange under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation has had at least two shareholders or groups of shareholders who are not related for the ten years prior to the first sale or exchange under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. Two persons are considered related when, under }}}{{\f5\fs18\hyphpar0\qj{section 318 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, one is a person who owns, directly or indirectly, capital stock that if directly owned would be attributed to the other person, or is the brother, sister, aunt, uncle, cousin, niece, or nephew of the other person who owns capital stock either directly or indirectly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fQualified corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any member of an Iowa affiliated group if the Iowa affiliated group includes a member that has employed individuals in this state for at least ten years. For purposes of this subparagraph division, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa affiliated group\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an affiliated group that has made a valid election to file an Iowa consolidated income tax return under }}}{{\f5\fs18\hyphpar0\qj{section 422.37}}}{{\f5\fs18\hyphpar0\qj{ in the year in which the deduction under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ is claimed. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMember\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any entity included in the consolidated return under }}}{{\f5\fs18\hyphpar0\qj{section 422.37, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, for the tax year in which the deduction is claimed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fQualified corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also includes any corporation that was a party to a reorganization that was entirely or substantially tax free if such reorganization occurred during or after the employment of the employee-owner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{43.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, the amount of an education savings account payment under }}}{{\f5\fs18\hyphpar0\qj{section 257.11B}}}{{\f5\fs18\hyphpar0\qj{ received by the taxpayer for payment of qualified educational expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{44.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this subsection, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fheld\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be determined with reference to the holding period provisions of }}}{{\f5\fs18\hyphpar0\qj{section 1223 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the federal regulations pursuant thereto.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract the net capital gain from the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sale of cattle or horses held by the taxpayer for breeding, draft, dairy, or sporting purposes for a period of twenty-four months or more from the date of acquisition, but only if the taxpayer received more than one-half of the taxpayer\u8217\'3fs gross income from farming or ranching operations during the tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The sale of breeding livestock, other than cattle or horses, held by the taxpayer for a period of twelve months or more from the date of acquisition, but only if the taxpayer received more than one-half of the taxpayer\u8217\'3fs gross income from farming or ranching operations during the tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A retired farmer as defined in }}}{{\f5\fs18\hyphpar0\qj{subsection 13}}}{{\f5\fs18\hyphpar0\qj{ is not eligible for the exclusion in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if taking the exclusion allowed in }}}{{\f5\fs18\hyphpar0\qj{subsection 13}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, in the same tax year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{45.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, the amount of any qualifying state disaster recovery new housing grant issued to an individual or business by the economic development authority.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualifying state disaster recovery new housing grant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an award of a state disaster recovery new housing grant that was applied for between August 20, 2024, and December 31, 2024, and approved and issued by the economic development authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ is repealed January 1, 2028.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f7; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.039;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.7}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 132, \'a74 \u8211\'3f 6, 9 \u8211\'3f 11}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1023, \'a73 \u8211\'3f 8, 25, 30, 31}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1203, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 174, \'a71, 3}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 179, \'a75, 6, 21, 24}}}{{\f5\fs18\hyphpar0\qj{; 