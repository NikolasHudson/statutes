hpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.34}}}{\*\bkmkstart stylerid1_2E7_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exempted corporations and organizations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The following organizations and corporations shall be exempt from taxation under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All state, national, private, cooperative, and savings banks, credit unions, title insurance and trust companies, federally chartered savings and loan associations, production credit associations, insurance companies or insurance associations, reciprocal or inter-insurance exchanges, fraternal beneficiary associations, and investment subsidiaries included on a return due to an election under }}}{{\f5\fs18\hyphpar0\qj{section 422.60, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An organization described in section 501 of the Internal Revenue Code unless the exemption is denied under section 501, 502, 503, or 504 of the Internal Revenue Code.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An organization that would have qualified as an organization exempt from federal income tax under section 501(c)(19) of the Internal Revenue Code but for the fact that the requirement that substantially all of the members who are not past or present members of the United States armed forces is not met because such members include ancestors or lineal descendants, shall be considered for purposes of the exemption from taxation under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ as an organization exempt from federal income tax under section 501(c)(19) of the Internal Revenue Code.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f30; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.066;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.34}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, 2nd Ex, ch 1001, \'a7239, 251}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1165, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 142, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a782}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a720, 24, 25}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7421.27}}}{{\f5\fs12\hyphpar0\qj{, 422.25A}}}{{\f5\fs12\hyphpar0\qj{, 422.33}}}{{\f5\fs12\hyphpar0\qj{, 422.37}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1 applies to tax years beginning on or after January 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1094, \'a725}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.34A}}}{\*\bkmkstart stylerid1_2E7_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exempt activities of foreign corporations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A foreign corporation shall not be considered doing business in this state or deriving income from sources within this state for the purposes of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ by reason of carrying on in this state one or more of the following activities:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Holding meetings of the board of directors or shareholders or holiday parties or employee appreciation dinners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Maintaining bank accounts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Borrowing money, with or without security.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Utilizing Iowa courts for litigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Owning and controlling a subsidiary corporation which is incorporated in or which is transacting business within this state where the holding or parent company has no physical presence in the state as that presence relates to the ownership or control of the subsidiary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Recruiting personnel where hiring occurs outside the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Training employees or educating employees, or using facilities in Iowa for this purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Utilizing a distribution facility within this state, owning or leasing property at a distribution facility within this state that is used at or distributed from the distribution facility, or selling property shipped or distributed from a distribution facility. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdistribution facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an establishment where shipments of tangible personal property are processed for delivery to customers. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDistribution facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include an establishment where retail sales of tangible personal property or returns of such property are undertaken with respect to retail customers on more than twelve days a year except for a distribution facility which processes customer sales orders by mail, telephone, or electronic means, if the distribution facility also processes shipments of tangible personal property to customers provided that not more than ten percent of the dollar amount of goods are delivered and shipped so as to be included in the gross sales of the corporation within this state as provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.33, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), subparagraph division (h).}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1123, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 46, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1179, \'a758, 66}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a7140}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.35}}}{\*\bkmkstart stylerid1_2E7_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Net income of corporation \u8212\'3f how computed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The term }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fnet income\u8221\'3f}}}{ means the taxable income as properly computed for federal income tax purposes under the }{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{, with the following adjustments:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract interest and dividends from federal securities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Add interest and dividends from foreign securities, from securities of state and other political subdivisions, and from regulated investment companies exempt from federal income tax under the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, except for those securities the interest and dividends from which are exempt from taxation by the state of Iowa as otherwise provided by law, including those set forth in }}}{{\f5\fs18\hyphpar0\qj{section 422.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the taxpayer is a small business corporation, subtract an amount equal to sixty-five percent of the wages paid to individuals, but not to exceed twenty thousand dollars per individual, named in subparagraphs (1), (2), and (3) who were hired for the first time by the taxpayer during the tax year for work done in this state:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual with a disability domiciled in this state at the time of the hiring who meets any of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has a physical or mental impairment which substantially limits one or more major life activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has a record of that impairment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is regarded as having that impairment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual domiciled in this state at the time of the hiring who meets any of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has been convicted of a felony in this or any other state or the District of Columbia.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is on parole pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 906}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is on probation pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 907}}}{{\f5\fs18\hyphpar0\qj{, for an offense other than a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is in a work release program pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 904, subchapter IX}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual, whether or not domiciled in this state at the time of the hiring, who is on parole or probation and to whom the interstate compact for adult offender supervision under }}}{{\f5\fs18\hyphpar0\qj{chapter 907B}}}{{\f5\fs18\hyphpar0\qj{ applies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This deduction is allowed for the wages paid to the individuals successfully completing a probationary period named in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1), (2), and (3), during the twelve months following the date of first employment by the taxpayer and shall be deducted in the tax years when paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPhysical or mental impairment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any physiological disorder or condition, cosmetic disfigurement, or anatomical loss affecting one or more of the body systems or any mental or psychological disorder, including intellectual disability, organic brain syndrome, emotional or mental illness, and specific learning disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSmall business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a profit or nonprofit business, including but not limited to an individual, partnership, corporation, joint venture, association, or cooperative, to which the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is not an affiliate or subsidiary of a business dominant in its field of operation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It has either twenty or fewer full-time equivalent positions or not more than the equivalent of three million dollars in annual gross revenues as computed for the preceding fiscal year or as the average of the three preceding fiscal years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It does not include the practice of a profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSmall business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes an employee-owned business which has been an employee-owned business for less than three years or which meets the conditions of subparagraph division (a), subparagraph subdivisions (i) through (iii).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this definition, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdominant in its field of operation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means having more than twenty full-time equivalent positions and more than three million dollars in annual gross revenues, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3faffiliate or subsidiary of a business dominant in its field of operation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a business which is at least twenty percent owned by a business dominant in its field of operation, or by partners, officers, directors, majority stockholders, or their equivalents, of a business dominant in that field of operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the taxpayer is a business corporation and does not qualify for the adjustment under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, subtract an amount equal to sixty-five percent of the wages paid to individuals, but shall not exceed twenty thousand dollars per individual, named in subparagraphs (1) and (2) who were hired for the first time by the taxpayer during the tax year for work done in this state:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual domiciled in this state at the time of the hiring who meets any of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Has been convicted of a felony in this or any other state or the District of Columbia.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is on parole pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 906}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is on probation pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 907}}}{{\f5\fs18\hyphpar0\qj{, for an offense other than a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is in a work release program pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 904, subchapter IX}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual, whether or not domiciled in this state at the time of the hiring, who is on parole or probation and to whom the interstate compact for adult offender supervision under }}}{{\f5\fs18\hyphpar0\qj{chapter 907B}}}{{\f5\fs18\hyphpar0\qj{ applies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This deduction is allowed for the wages paid to the individuals successfully completing a probationary period named in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) and (2), during the twelve months following the date of first employment by the taxpayer and shall be deducted in the tax years when paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall develop and distribute information concerning the deduction available for businesses employing persons named in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraphs (1) and (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Add any federal net operating loss deduction carried over from a taxable year beginning prior to January 1, 2023.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any Iowa net operating loss carried over from a taxable year beginning prior to January 1, 2023, may be deducted as provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.35, subsection 11}}}{{\f5\fs18\hyphpar0\qj{, Code 2018.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract the loss on the sale or exchange of a share of a regulated investment company held for six months or less to the extent the loss was disallowed under section 852(b)(4)(B) of the Internal Revenue Code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Add, to the extent it reduced federal taxable income, any amount contributed under }}}{{\f5\fs18\hyphpar0\qj{section 170 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ to the extent such contribution was made to an organization for the purpose of deposit in the Iowa education savings plan trust established in }}}{{\f5\fs18\hyphpar0\qj{chapter 12D}}}{{\f5\fs18\hyphpar0\qj{, and the taxpayer designated that any part of the contribution be used for the direct benefit of any dependent of a shareholder of the taxpayer or any other single beneficiary designated by the taxpayer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract the amount of foreign dividend income, including subpart F income as defined in section 952 of the Internal Revenue Code, based upon the percentage of ownership as set forth in section 243 of the Internal Revenue Code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, the amount of any biodiesel production refund provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 423.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any adjustment subtracted from federal taxable income for an adjustment year pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 6225 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ and the regulations thereunder shall be added back in computing net income of the partnership and the partners for state tax purposes for the adjustment year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 163(j) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ does not apply in computing net income for state tax purposes. If the taxpayer\u8217\'3fs federal taxable income for the tax year was increased or decreased by reason of the application of }}}{{\f5\fs18\hyphpar0\qj{section 163(j) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, the taxpayer shall recompute net income for state tax purposes under rules prescribed by the director. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any tax year in which paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not apply, a taxpayer shall not be permitted to deduct any amount of interest expense paid or accrued in a previous taxable year that is allowed as a deduction in the current taxable year by reason of the carryforward of disallowed business interest provisions of }}}{{\f5\fs18\hyphpar0\qj{section 163(j)(2) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, if either of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interest expense was originally paid or accrued during a tax year in which paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applied. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The interest expense was originally paid or accrued during a tax year in which the taxpayer was not required to file an Iowa return. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, global intangible low-taxed income under }}}{{\f5\fs18\hyphpar0\qj{section 951A of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, the amount of a federal, state, or local grant provided to a communications service provider, if the grant is used to install broadband infrastructure that facilitates broadband service in targeted service areas at or above the download and upload speeds.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbroadband infrastructure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcommunications service provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ftargeted service area\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.76}}}{{\f5\fs18\hyphpar0\qj{, respectively.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subtract, to the extent included, the amount of any qualifying state disaster recovery new housing grant issued to a business by the economic development authority.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fqualifying state disaster recovery new housing grant\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an award of a state disaster recovery new housing grant that was applied for between August 20, 2024, and December 31, 2024, and approved and issued by the economic development authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ is repealed January 1, 2028.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f31; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.067;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.35}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 132, \'a78, 9}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1023, \'a714, 15, 30, 31}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1203, \'a72}}}{, }{{\f5\fs18\hyphpar0\qj{ch 1206, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 174, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 179, \'a716, 24}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1236, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1238, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1241, \'a723}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 1st Ex, ch 1, \'a78 \u8211\'3f 11}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 175, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 225, \'a720, 21}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1168, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1171, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1195, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1251, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 210, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1222, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1225, \'a72, 5}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1107, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1166, \'a79, 10, 12}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 152, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 135, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1078, \'a78, 12}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1172, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 95, \'a710 \u8211\'3f 13}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 15, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 116, \'a77, 28}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2001 Acts, 2nd Ex, ch 6, \'a723 \u8211\'3f 26, 37}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 139, \'a710 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a747}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2004 Acts, 1st Ex, ch 1001, \'a740 \u8211\'3f 42}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 2, \'a73, 4, 6}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 19, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 24, \'a79 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 140, \'a741, 73}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{2006 Acts, 1st Ex, ch 1001, \'a742, 49}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 54, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 162, \'a78, 13}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 186, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1011, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a7141 \u8211\'3f 143}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 135, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 41, \'a721 \u8211\'3f 25}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 113, \'a758, 60}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1019, \'a7130}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1110, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1136, \'a735, 39 \u8211\'3f 41}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 1, \'a710 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 70, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 100, \'a724, 27}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 1, \'a710 \u8211\'3f 12}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1107, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a794 \u8211\'3f 98, 128 \u8211\'3f 130, 133, 134}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 4, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a767, 71, 78, 80 \u8211\'3f 82, 101, 103, 104, 119 \u8211\'3f 121, 124, 126}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7263, 264}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 86, \'a730 \u8211\'3f 32}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a71, 6 \u8211\'3f 8, 53, 54, 56, 57}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a74 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 28, \'a724 \u8211\'3f 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.33}}}{{\f5\fs12\hyphpar0\qj{, 422.61}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2018 amendments to unnumbered paragraph 1 and subsection 11, and strike of former subsections 3, 4, 5, 7, 8, 10, 16, 17, 18, 19, 19B, 20, 22, and 24 are effective January 1, 2023, and apply to tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2018 Acts, ch 1161, \'a7133, 144}}}{; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 177, \'a71}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{For business expense deductions using forgiven federal Paycheck Protection Program (PPP) proceeds in computing net income for certain fiscal-year filers under the federal Consolidated Appropriations Act, 2021; see }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a79, 10}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 repeal of former subsection 19A applies retroactively to January 1, 2021, for tax years beginning on or after that date, and for qualified property placed in service on or after that date; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 177, \'a754}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 amendment to subsection 10 applies retroactively to July 1, 2020, and applies to federal adjustments and federal partnership adjustments that have a final determination date after July 1, 2020; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 86, \'a732}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 repeal of former subsection 27, paragraph b applies retroactively to January 1, 2021, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 177, \'a757}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Repeal of former subsections 19, 19B, 20, and 24, relating to bonus depreciation under section 168 of the Internal Revenue Code or increased expensing under section 179 of the Internal Revenue Code, applies retroactively to property placed in service on or after January 1, 2023; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2018 Acts, ch 1161, \'a7130, 133, 134}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a71}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH0115.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 115, \'a74, 6}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 14 applies retroactively to tax years beginning on or after January 1, 2024; }{{\f5\fs12\hyphpar0\qj{2025 Acts, ch 28, \'a726}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW subsection 14}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.36}}}{\*\bkmkstart stylerid1_2E7_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Returns.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation shall make a return and the return shall be signed by the president or other duly authorized officer in accordance with forms and rules prescribed by the director. Before a corporation is dissolved and its assets distributed it shall make a return for settlement of the tax for income earned in the income year up to its final date of dissolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When any corporation, liable to taxation under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, conducts its business in such a manner as either directly or indirectly to benefit the members or stockholders thereof or any person interested in such business by selling its products or the goods or commodities in which it deals at less than the fair price which might be obtained therefor, or where a corporation, a substantial portion of whose capital stock is owned either directly or indirectly by another corporation, acquires and disposes of the products, goods or commodities of the corporation so owning a substantial portion of its stock in such a manner as to create a loss or improper net income for either of said corporations, or where a corporation, owning directly or indirectly a substantial portion of the stock of another corporation, acquires and disposes of the products, goods, or commodities, of the corporation of which it so owns a substantial portion of the stock, in such a manner as to create a loss or improper net income for either of said corporations, the department may determine the amount of taxable income of either or any of such corporations for the calendar or fiscal year, having due regard to the reasonable profits which, but for such arrangement or understanding, might or could have been obtained, by the corporation or corporations liable to taxation under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, from dealing in such products, goods, or commodities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where the director has reason to believe that any person or corporation so conducts a trade or business as either directly or indirectly to distort the person\u8217\'3fs or corporation\u8217\'3fs true net income and the net income properly attributable to the state, whether by the arbitrary shifting of income, through price fixing, charges for services, or otherwise, whereby the net income is arbitrarily assigned to one or another unit in a group of taxpayers carrying on business under a substantially common control, the director may require such facts as are necessary for the proper computation of the entire net income and the net income properly attributable to the state, and shall determine the same, and in the determination thereof the director shall have regard to the fair profits which would normally arise from the conduct of the trade or business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Foreign and domestic corporations shall file a copy of their federal income tax return for the current tax year with the return required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where a corporation is not subject to income tax and the stockholders of such corporation are taxed on the corporation\u8217\'3fs income under the provisions of the Internal Revenue Code, the same tax treatment shall apply to such corporation and such stockholders for Iowa income tax purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A foreign corporation is not required to file a return if its only activities in Iowa are the storage of goods for a period of sixty consecutive days or less in a warehouse for hire located in this state whereby the foreign corporation transports or causes a carrier to transport such goods to that warehouse and provided that none of the goods are delivered or shipped so as to be included in the gross sales of the corporation within this state as provided in }}}{{\f5\fs18\hyphpar0\qj{section 422.33, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), subparagraph division (h).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a return is not required by a taxpayer as provided in }}}{{\f5\fs18\hyphpar0\qj{section 29C.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation shall file a return required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in an electronic format specified by the department for any tax year if any of the following circumstances apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation has gross receipts of two hundred fifty thousand dollars or more, as defined by rule by the department.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation reports twenty-five thousand dollars or more of Iowa tax credits on the return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A corporation described in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{ shall file all returns required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in an electronic format specified by the department for any tax year if any of the following circumstances apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation has gross receipts of two hundred fifty thousand dollars or more, as defined by rule by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation is required to provide ten or more Iowa schedules K-1 to shareholders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation reports twenty-five thousand dollars or more of Iowa tax credits on the return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ applies to any form or schedule supporting a return required to be electronically filed or any amended return if the amended return meets any of the circumstances requiring electronic filing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department may provide an exception to the requirement to file a return in an electronic format.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A return subject to the electronic filing requirement in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ that is filed in a manner other than in an electronic format specified by the department shall not be considered a valid return unless the department provides an exception pursuant to this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f32; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.068;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.36}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, 1st Ex, ch 1, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 251, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 97, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1110, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a7141}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1095, \'a77, 14, 15}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a76, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a729C.24}}}{{\f5\fs12\hyphpar0\qj{, 421.27}}}{{\f5\fs12\hyphpar0\qj{, 422.16B}}}{{\f5\fs12\hyphpar0\qj{, 422.31}}}{{\f5\fs12\hyphpar0\qj{, 422.37}}}{{\f5\fs12\hyphpar0\qj{, 422.62}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 8 applies to tax years ending on or after December 31, 2022, or for tax years ending on or after December 31 of the calendar year in which the department of revenue implements a system for receiving the electronic returns, whichever is later; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.37}}}{\*\bkmkstart stylerid1_2E7_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consolidated returns.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any affiliated group of corporations may, not later than the due date for filing its return for the taxable year, including any extensions thereof, under rules to be prescribed by the director, elect, and upon demand of the director shall be required, to make a consolidated return showing the consolidated net income of all such corporations and other information as the director may require, subject to the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The affiliated group filing under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall file a consolidated return for federal income tax purposes for the same taxable year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All members of the affiliated group shall join in the filing of an Iowa consolidated return to the extent they are subject to the tax imposed by }}}{{\f5\fs18\hyphpar0\qj{section 422.33}}}{{\f5\fs18\hyphpar0\qj{, except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{section 29C.24}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the affiliated group exempt from taxation by }}}{{\f5\fs18\hyphpar0\qj{section 422.34}}}{{\f5\fs18\hyphpar0\qj{ of the Code shall not be included in a consolidated return.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All members of the affiliated group shall use the statutory method of allocation and apportionment unless the director has granted permission to all members to use an alternative method of allocation and apportionment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each member of the affiliated group shall consent to the rules governing a consolidated return prescribed by the director at the time the consolidated return is filed, unless the director requires the filing of a consolidated return. The filing of a consolidated return shall be considered the affiliated group\u8217\'3fs consent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The filing of a consolidated return for any taxable year shall require the filing of consolidated returns for all subsequent taxable years so long as the filing taxpayers remain members of the affiliated group unless the director determines that the filing of separate returns will more clearly disclose the taxable incomes of each member of the affiliated group. This determination shall be made after specific request by the taxpayer for the filing of separate returns.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The computation of consolidated taxable income for the members of an affiliated group of corporations subject to tax shall be made in the same manner and under the same procedures, including all intercompany adjustments and eliminations, as are required for consolidating the incomes of affiliated corporations for the taxable year for federal income tax purposes in accordance with section 1502 of the Internal Revenue Code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The affiliated group shall file a return under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ for each taxable year in an electronic format specified by the department, regardless of the total gross receipts of or amount of credits reported by the affiliated group.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of the electronic filing requirement, a return of an affiliated group includes any form or schedule supporting the return or any amended return of the affiliated group.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The financial institution is a corporation subject to the electronic filing requirement under }}}{{\f5\fs18\hyphpar0\qj{section 422.36, subsection 8}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department may provide an exception to file a return in an electronic format. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A return subject to the electronic filing requirement in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that is filed in a manner other than in an electronic format specified by the department shall not be considered a valid return unless the department provides an exception pursuant to this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules to implement }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f33; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.069;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.37}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1213, \'a710}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/87/CH0001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{87 Acts, 1st Ex, ch 1, \'a713}}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/92/CH1001.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 2nd Ex, ch 1001, \'a7240, 252}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1095, \'a78, 14, 15}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1061, \'a77, 9}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a729C.24}}}{{\f5\fs12\hyphpar0\qj{, 421.27}}}{{\f5\fs12\hyphpar0\qj{, 422.7(42)(c)}}}{{\f5\fs12\hyphpar0\qj{, 422.25}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 8 applies to tax years ending on or after December 31, 2022, or for tax years ending on or after December 31 of the calendar year in which the department of revenue implements a system for receiving the electronic returns, whichever is later; }{{\f5\fs12\hyphpar0\qj{2022 Acts, ch 1061, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.38}}}{\*\bkmkstart stylerid1_2E7_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statutes governing corporations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All the provisions of }{{\f5\fs18\hyphpar0\qj{sections 422.15 through 422.22}}}{ of }{{\f5\fs18\hyphpar0\qj{subchapter II}}}{, insofar as the same are applicable, shall apply to corporations taxable under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f34; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.070;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.38}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7225}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.39}}}{\*\bkmkstart stylerid1_2E7_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statutes applicable to corporations and corporation tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All the provisions of }{{\f5\fs18\hyphpar0\qj{sections 422.24 through 422.27}}}{ of }{{\f5\fs18\hyphpar0\qj{subchapter II}}}{, respecting payment, collection, reporting, examination, and assessment, shall apply in respect to a corporation subject to the provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ and to the tax due and payable by a corporation taxable under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{. This includes but is not limited to a corporation that is a pass-through entity as defined in }{{\f5\fs18\hyphpar0\qj{section 422.25A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f35; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.071;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.39}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1118, \'a768, 71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.40}}}{\*\bkmkstart stylerid1_2E7_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cancellation of authority \u8212\'3f penalty \u8212\'3f offenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a corporation required by the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ to file any report or return or to pay any tax or fee, either as a corporation organized under the laws of this state, or as a foreign corporation doing business in this state for profit, or owning and using a part or all of its capital or plant in this state, fails or neglects to make any such report or return or to pay any such tax or fee for ninety days after the time prescribed in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ for making such report or return, or for paying such tax or fee, the director may certify such fact to the secretary of state. The secretary of state shall thereupon cancel the articles of incorporation of any such corporation which is organized under the laws of this state by appropriate entry upon the margin of the record thereof, or cancel the certificate of authority of any such foreign corporation to do business in this state by proper entry. Thereupon all the powers, privileges, and franchises conferred upon such corporation by such articles of incorporation or by such certificate of authority shall cease and determine. The secretary of state shall immediately notify by registered mail such domestic or foreign corporation of the action taken by the secretary of state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person or persons who shall exercise or attempt to exercise any powers, privileges, or franchises under articles of incorporation or certificate of authority after the same are canceled, as provided in any section of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, shall pay a penalty of not less than one hundred dollars nor more than one thousand dollars, to be recovered by an action to be brought by the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any corporation whose articles of incorporation or certificate of authority to do business in this state have been canceled by the secretary of state, as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, or similar provisions of prior revenue laws, upon the filing, within ten years after such cancellation, with the secretary of state, of a certificate from the department that it has complied with all the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and paid all state taxes, fees, or penalties due from it, and upon the payment to the secretary of state of an additional penalty of fifty dollars, shall be entitled again to exercise its rights, privileges, and franchises in this state; and the secretary of state shall cancel the entry made by the secretary under the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ or similar provisions of prior revenue laws, and shall issue a certificate entitling such corporation to exercise its rights, privileges and franchises.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, officer or employee of a corporation, or member or employee of a partnership, who, with intent to evade a requirement of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ or a lawful requirement of the director, fails to pay tax or fails to make, sign, or verify a return or fails to supply information required under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, is guilty of a fraudulent practice. A person, corporation, officer or employee of a corporation, or member or employee of a partnership, who, with intent to evade any of the requirements of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, or any lawful requirements of the director, makes, renders, signs, or verifies a false or fraudulent return or statement, or supplies false or fraudulent information, or who aids, abets, directs, causes, or procures anyone so to do, is guilty of a class \u8220\'3fD\u8221\'3f felony. The penalty is in addition to all other penalties in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f36; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.072;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.40}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 160, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.41}}}{\*\bkmkstart stylerid1_2E7_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Corporations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All the provisions of }{{\f5\fs18\hyphpar0\qj{sections 422.28}}}{, }{{\f5\fs18\hyphpar0\qj{422.29}}}{, and }{{\f5\fs18\hyphpar0\qj{422.30}}}{ of subchapter II in respect to revision, appeal, and jeopardy assessments shall be applicable to corporations taxable under }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f37; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.073;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7422.41}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1062, \'a794}}}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER IV}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E2_2E2}{RETAIL SALES TAX}{\*\bkmkend stylerid1_2E8_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7422.1}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{422.42 through 422.47}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0002.pdf" }{\fldrslt \f5 \fs18{{2003 Acts, 1st Ex, ch 2, \'a7151, 205}}}}}}{{\f5\fs18\qj{2003 Acts, 1st Ex, ch 2, \'a7151, 205}}}{.}{{\f5\fs18\qj{\~\~}}}{See }{{\f5\fs18\qj{chapter 423}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{422.47A through 422.47C}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1996/CH1034.pdf" }{\fldrslt \f5 \fs18{{96 Acts, ch 1034, \'a770}}}}}}{{\f5\fs18\qj{96 Acts, ch 1034, \'a770}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{422.48 through 422.59}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2003/CH0002.pdf" }{\fldrslt \f5 \fs18{{2003 Acts, 1st Ex, ch 2, \'a7151, 205}}}}}}{{\f5\fs18\qj{2003 Acts, 1st Ex, ch 2, \'a7151, 205}}}{.}{{\f5\fs18\qj{\~\~}}}{See }{{\f5\fs18\qj{chapter 423}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER V}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E9_2E2_2E2}{TAXATION OF FINANCIAL INSTITUTIONS}{\*\bkmkend stylerid1_2E9_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a715.293A}}}{{\f5\fs12\qc{, 15.355}}}{{\f5\fs12\qc{, 15.496}}}{{\f5\fs12\qc{, 15.508}}}{{\f5\fs12\qc{, 15E.27}}}{{\f5\fs12\qc{, 15E.28}}}{{\f5\fs12\qc{, 15E.52}}}{{\f5\fs12\qc{, 15E.62}}}{{\f5\fs12\qc{, 15E.305}}}{{\f5\fs12\qc{, 15E.364}}}{{\f5\fs12\qc{, 237A.31}}}{{\f5\fs12\qc{, 404A.2}}}{{\f5\fs12\qc{, 422.1}}}{{\f5\fs12\qc{, 422.11}}}{{\f5\fs12\qc{, 422.16C}}}{{\f5\fs12\qc{, 422.73}}}{{\f5\fs12\qc{, 422.85}}}{{\f5\fs12\qc{, 476B.2}}}{{\f5\fs12\qc{, 476B.6}}}{{\f5\fs12\qc{, 476B.7}}}{{\f5\fs12\qc{, 476C.4}}}{{\f5\fs12\qc{, 476C.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.60}}}{\*\bkmkstart stylerid1_2E9_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Imposition of tax \u8212\'3f credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A franchise tax according to and measured by net income is imposed on financial institutions for the privilege of doing business in this state as financial institutions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financial institution with an investment subsidiary may elect under the regulations of the director to include the income and expenses of an investment subsidiary on the franchise tax return for the purpose of imposing the franchise tax in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An election made under this paragraph shall require the inclusion of the income and expenses of the investment subsidiary on all subsequent returns of the financial institution so long as the investment subsidiary remains a subsidiary of the financial institution unless the director determines that the filing of separate returns will more clearly disclose the taxable income of the investment subsidiary or financial institution. This determination shall be made after specific request by the taxpayer for the filing of separate returns.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by a historic preservation tax credit allowed under }}}{{\f5\fs18\hyphpar0\qj{chapter 404A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall be reduced by an investment tax credit authorized pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 15E.27}}}{{\f5\fs18\hyphpar0\qj{ for an investment in a qualifying business.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphp