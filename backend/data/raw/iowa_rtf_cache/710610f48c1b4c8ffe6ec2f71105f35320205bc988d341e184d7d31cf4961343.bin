s, ch 1161, \'a7123, 133, 134}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a710, 12}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a72.48}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2018 amendment to subsection 2 is effective January 1, 2023, and applies to tax years on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2018 Acts, ch 1161, \'a7133, 134}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a71}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 2 applies retroactively to January 1, 2023, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 115, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.12C}}}{\*\bkmkstart stylerid1_2E6_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Child and dependent care or early childhood development tax credits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, less the amounts of nonrefundable credits allowed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, shall be reduced by a child and dependent care credit equal to the following percentages of the federal child and dependent care credit provided in }}}{{\f5\fs18\hyphpar0\qj{section 21 of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, without regard to whether or not the federal credit was limited by the taxpayer\u8217\'3fs federal tax liability:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a taxpayer with net income of less than ten thousand dollars, seventy-five percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a taxpayer with net income of ten thousand dollars or more but less than twenty thousand dollars, sixty-five percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a taxpayer with net income of twenty thousand dollars or more but less than twenty-five thousand dollars, fifty-five percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a taxpayer with net income of twenty-five thousand dollars or more but less than thirty-five thousand dollars, fifty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a taxpayer with net income of thirty-five thousand dollars or more but less than forty thousand dollars, forty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a taxpayer with net income of forty thousand dollars or more but less than ninety thousand dollars, thirty percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a taxpayer with net income of ninety thousand dollars or more, zero percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The taxes imposed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, less the amounts of nonrefundable credits allowed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, may be reduced by an early childhood development tax credit equal to twenty-five percent of the first one thousand dollars which the taxpayer has paid to others for each dependent, as defined in the }}}{{\f5\fs18\hyphpar0\qj{Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{, ages three through five for early childhood development expenses. In determining the amount of early childhood development expenses for the tax year beginning in the 2006 calendar year only, such expenses paid during November and December of the previous tax year shall be considered paid in the tax year for which the tax credit is claimed. This credit is available to a taxpayer whose net income is less than ninety thousand dollars. If the early childhood development tax credit is claimed for a tax year, the taxpayer and the taxpayer\u8217\'3fs spouse shall not claim the child and dependent care credit under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEarly}}}{{\i\f5\fs18\hyphpar0\qj{ childhood development expenses\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means services provided to the dependent by a preschool, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 237A.1}}}{{\f5\fs18\hyphpar0\qj{, materials, and other activities as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Books that improve child development, including textbooks, music books, art books, teacher\u8217\'3fs editions, and reading books.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Instructional materials required to be used in a child development or educational lesson activity, including but not limited to paper, notebooks, pencils, and art supplies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lesson plans and curricula.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child development and educational activities outside the home, including drama, art, music, and museum activities, and the entrance fees for such activities, but not including food or lodging, membership fees, or other nonacademic expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEarly childhood development expenses\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include services, materials, or activities for the teaching of religious tenets, doctrines, or worship, the purpose of which is to inculcate those tenets, doctrines, or worship.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any credit in excess of the tax liability shall be refunded. In lieu of claiming a refund, a taxpayer may elect to have the overpayment shown on the taxpayer\u8217\'3fs final, completed return credited to the tax liability for the following taxable year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nonresidents or part-year residents of Iowa must determine their Iowa child and dependent care credit under subsection 1 or the early childhood development tax credit under subsection 2 in the ratio of their Iowa source net income to their all source net income. }}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1248, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 159, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 172, \'a744, 56}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 23, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 148, \'a723 \u8211\'3f 27}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1158, \'a723 \u8211\'3f 25, 69}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1026, \'a786}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1120, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1161, \'a7124, 133, 134}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 152, \'a79, 14, 15}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 66, \'a798, 159, 162}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a711, 12}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a72.48}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 amendments to subsections 1 and 2 apply retroactively to tax years beginning on or after January 1, 2021; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 177, \'a74}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2018 amendment to subsection 4 is effective January 1, 2023, and applies to tax years beginning on or after that date; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2018/CH1161.pdf" }{\fldrslt \cf5 \f5 \fs12{{2018 Acts, ch 1161, \'a7133, 134}}}}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs12{{2021 Acts, ch 177, \'a71}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 4 by }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 662023 Acts, ch 66}}}{, applies retroactively to January 1, 2023; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH66.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 66, \'a7162}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 4 by }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 1152023 Acts, ch 115}}}{, applies retroactively to January 1, 2023, for tax years beginning on or after that date; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 115, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.12D}}}{\*\bkmkstart stylerid1_2E6_2E46_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E46_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Income tax checkoff for the Iowa state fair foundation fund.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by its own terms; }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2021/CH0177.pdf" }{\fldrslt \cf5 \f5 \fs18{{2021 Acts, ch 177, \'a777}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{422.12E}}}{\*\bkmkstart stylerid1_2E6_2E47_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E47_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Income tax return checkoffs limited }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ notification of repeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There shall be allowed no more than four income tax return checkoffs on each income tax return. For tax years beginning on or after January 1, 2017, when the same four income tax return checkoffs have been provided on the income tax return for two consecutive tax years, the two checkoffs for which the least amount has been contributed, in the aggregate for the first tax year and through March 15 after the end of the second tax year, are repealed on December 31 after the end of the second tax year and shall be removed from the return form. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If more checkoffs are enacted in the same session of the general assembly than there is space for inclusion on the individual tax return form, the checkoffs with the earliest date of enactment as determined pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 3.7}}}{{\f5\fs18\hyphpar0\qj{ for which there is space for inclusion on the return form shall be included on the return form, and all other checkoffs enacted during that session of the general assembly are repealed on December 31 of the year of enactment. If more checkoffs are enacted in the same session of the general assembly than there is space for inclusion on the individual income tax form and it is indeterminable which checkoffs have the earliest date of enactment pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 3.7}}}{{\f5\fs18\hyphpar0\qj{, the director shall determine which checkoffs shall be included on the return form, and all other checkoffs not included on the return form shall be repealed on December 31 of the year of enactment and shall not be included on the return form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By July 1 of the year in which two checkoffs are repealed pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the department shall notify the Iowa Code editor which two checkoffs received the least amount of contributions and are repealed. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By September 1 of any applicable year, the department shall notify the Iowa Code editor of any repeal pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 144, \'a74, 6}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1199, \'a73 \u8211\'3f 6}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7437, 439}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 186, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1138, \'a734, 35}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 144, \'a76, 14}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 152, \'a749}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7422.12H}}}{{\f5\fs12\hyphpar0\qj{, 422.12K}}}{{\f5\fs12\hyphpar0\qj{, 422.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Checkoff for fish and game protection fund; }{{\f5\fs12\hyphpar0\qj{\'a7422.12H}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Checkoff for child abuse prevention program fund; }{{\f5\fs12\hyphpar0\qj{\'a7422.12K}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\