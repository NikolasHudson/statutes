\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F216E}{\*\bkmkend codeChapter_5F216E}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 216E}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{ASSISTIVE DEVICES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{216E.1}}}{\*\bkmkstart stylerid1_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise provides:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssistive device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any item, piece of equipment, or product system which is purchased, or whose transfer is accepted in this state, and which is used to increase, maintain, or improve the functional capabilities of individuals with disabilities concerning a major life activity. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssistive device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean any medical device, surgical device, or organ implanted or transplanted into or attached directly to an individual. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssistive device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean any device for which a certificate of title is issued by the state department of transportation but does mean any item, piece of equipment, or product system otherwise meeting the definition of }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fassistive device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ that is incorporated, attached, or included as a modification in or to such a certificated device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssistive device dealer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is in the business of selling assistive devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssistive device lessor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who leases assistive devices to consumers, or who holds the lessor\u8217\'3fs rights, under a written lease.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCollateral costs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means expenses incurred by a consumer in connection with the repair of a nonconformity, including the cost of shipping, sales tax, and of obtaining an alternative assistive device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConsumer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purchaser of an assistive device, if the assistive device was purchased from an assistive device dealer or manufacturer for purposes other than resale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person to whom the assistive device is transferred for purposes other than resale, if the transfer occurs before the expiration of an express warranty applicable to the assistive device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who may enforce the warranty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who leases an assistive device from an assistive device lessor under a written lease.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDemonstrator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an assistive device used primarily for the purpose of demonstration to the public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEarly termination costs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any expense or obligation that an assistive device lessor incurs as a result of both the termination of a written lease before the termination date set forth in the lease and the return of an assistive device to the manufacturer. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEarly termination costs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a penalty for prepayment under a finance arrangement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEarly termination savings\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any expense or obligation that an assistive device lessor avoids as a result of both the termination of a written lease before the termination date set forth in the lease and the return of an assistive device to a manufacturer which shall include an interest charge that the assistive device lessor would have paid to finance the assistive device or, if the assistive device lessor does not finance the assistive device, the difference between the total payments remaining for the period of the lease term remaining after the early termination and the present value of those remaining payments at the date of the early termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLoaner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an assistive device, provided free of charge to the consumer, for use by the consumer, that need not be new or be identical to, or have functional capabilities equal to or greater than, those of the original assistive device, but that meets all of the following conditions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The loaner is in good working order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The loaner performs, at a minimum, the most essential functions of the original assistive device, in light of the disabilities of the consumer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any differences between the loaner and the original assistive device do not create a threat to the consumer\u8217\'3fs health or safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMajor life activity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes functions such as caring for one\u8217\'3fs self, performing manual tasks, walking, seeing, hearing, speaking, breathing, learning, or working.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fManufacturer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who manufactures or assembles assistive devices and agents of that person, including an importer, a distributor, a factory branch, distributor branch, and any warrantors of the assistive device, but does not include an assistive device dealer or assistive device lessor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNonconformity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any defect, malfunction, or condition which substantially impairs the use, value, or safety of an assistive device or any of its component parts, but does not include a condition, defect, or malfunction that is the result of abuse, neglect, or unauthorized modification or alteration of the assistive device by the consumer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReasonable attempt to repair\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following occurring within the terms of an express warranty applicable to a new assistive device or within one year after first delivery of the assistive device to a consumer, whichever is sooner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufacturer, assistive device lessor, or any of the manufacturer\u8217\'3fs authorized assistive device dealers accepts return of the new assistive device for repair at least two times.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufacturer, assistive device lessor, or any of the manufacturer\u8217\'3fs authorized assistive device dealers places the assistive device out of service for an aggregate of at least thirty cumulative days because of warranty nonconformities.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1042, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1159, \'a79, 10}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7321.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{216E.2}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Express warranties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A manufacturer or assistive device lessor who sells or leases an assistive device to a consumer, either directly or through an assistive device dealer, shall furnish the consumer with an express warranty for the assistive device, warranting the assistive device to be free of any nonconformity. The duration of the express warranty shall be not less than one year after first delivery of the assistive device to the consumer. If a manufacturer fails to furnish an express warranty as required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the assistive device shall be covered by an express warranty as if the manufacturer had furnished an express warranty to the consumer as required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An express warranty does not take effect until the consumer takes possession of the new assistive device.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1042, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{216E.3}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Assistive device replacement or refund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an assistive device does not conform to an applicable express warranty and the consumer reports the nonconformity to the manufacturer, the assistive device lessor, or any of the manufacturer\u8217\'3fs authorized assistive device dealers, and makes the assistive device available for repair before one year after first delivery of the device to the consumer or within the period of the express warranty if the warranty is longer than one year, a reasonable attempt to repair the nonconformity shall be made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after a reasonable attempt to repair, the nonconformity is not repaired, the manufacturer shall carry out the requirements of either paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ upon the request of a consumer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufacturer shall provide for a refund by doing one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the assistive device was purchased by the consumer, accept return of the assistive device and refund to the consumer and to any holder of perfected security interest in the consumer\u8217\'3fs assistive device, as the holder\u8217\'3fs interest may appear, the full purchase price plus any finance charge paid by the consumer at the point of sale and collateral costs, less a reasonable allowance for use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the assistive device was leased by the consumer, accept return of the assistive device, refund to the assistive device lessor and to any holder of a perfected security interest in the assistive device, as the holder\u8217\'3fs interest may appear, the current value of the written lease and refund to the consumer the amount that the consumer paid under the written lease plus any collateral costs, less a reasonable allowance for use. The manufacturer shall have a cause of action against the dealer or lessor for reimbursement of any amount that the manufacturer pays to a consumer which exceeds the net price received by the manufacturer for the assistive device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufacturer shall provide a comparable new assistive device or offer a refund to the consumer if the consumer does any one of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Offers to transfer possession of the assistive device to the manufacturer. No later than thirty days after that offer, the manufacturer shall provide the consumer with the comparable new assistive device or a refund. When the manufacturer provides the new assistive device or refund, the consumer shall return the assistive device having the nonconformity to the manufacturer, along with any endorsements necessary to transfer legal possession to the manufacturer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Offers to return the assistive device to the manufacturer. No later than thirty days after the offer, the manufacturer shall provide a refund to the consumer. When the manufacturer provides a refund, the consumer shall return the assistive device having the nonconformity to the manufacturer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Offers to transfer possession of a leased assistive device to the manufacturer. No later than thirty days after the offer, the manufacturer shall provide a refund to the assistive device lessor. When the manufacturer provides the refund, the assistive device lessor shall provide to the manufacturer any endorsements necessary to transfer legal possession to the manufacturer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the current value of the written lease equals the total amount for which that lease obligates the consumer during the period of the lease remaining after its early termination, plus the assistive device lessor\u8217\'3fs early termination costs and the value of the assistive device at the lease expiration date if the lease sets forth that value, less the assistive device lessor\u8217\'3fs early termination savings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a reasonable allowance for use shall not exceed the amount obtained by multiplying the total amount for which the written lease obligates the consumer by a fraction, the denominator of which is one thousand eight hundred twenty-five and the numerator of which is the number of days that the consumer used the assistive device before first reporting the nonconformity to the manufacturer, assistive device lessor, or assistive device dealer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not enforce a lease against a consumer after the consumer receives a refund.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1042, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{216E.4}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Manufacturer\u8217\'3fs duty to provide reimbursement or a loaner for temporary replacement of assistive devices \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whenever an assistive device covered by a manufacturer\u8217\'3fs express warranty is tendered by a consumer to the dealer from whom the assistive device was purchased or exchanged for the repair of any defect, malfunction, or nonconformity to which the warranty is applicable, the manufacturer shall provide the consumer, at the consumer\u8217\'3fs choice, for the duration of the repair period, either a rental assistive device reimbursement of up to twenty dollars per day, or a loaner, without cost to the consumer, if a loaner is reasonably available or obtainable by the manufacturer, assistive device lessor, or assistive device dealer, if any of the following applies:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The repair period exceeds ten working days, including the day on which the device is tendered to the manufacturer or an assistive device dealer designated by the manufacturer for repairs. If the assistive device dealer does not tender the assistive device to the manufacturer in a timely enough manner for the manufacturer to make the repairs within ten days, the manufacturer shall have a cause of action against the assistive device dealer for reimbursement of any penalties that the manufacturer must pay.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The nonconformity is the same for which the assistive device has been tendered to the assistive device dealer for repair on at least two previous occasions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ regarding a manufacturer\u8217\'3fs duty shall apply for the period of the applicable express warranty, or until the date any repair required by the warranty is completed and the assistive device is returned to the consumer with the nonconformity eliminated, whichever is later, even if the assistive device is returned after the end of the warranty period.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1042, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{216E.5}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonconformity disclosure requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An assistive device returned by a consumer or assistive device lessor in this state or any other state for nonconformity shall not be sold or leased again in this state unless full written disclosure of the reason for return is made to any prospective buyer or lessee by the manufacturer, assistive device dealer, or assistive device lessor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1042, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{216E.6}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Remedies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not limit rights or remedies available to a consumer under any other law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any waiver of rights by a consumer under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to pursuing any other remedy, a consumer may bring an action to recover any damages caused by a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The court shall award a consumer who prevails in such an action no more than three times the amount of any pecuniary loss, together with costs and reasonable attorney fees, and any equitable relief that the court determines is appropriate.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1042, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{216E.7}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ does not apply to a hearing aid sold, leased, or transferred to a consumer by an audiologist licensed under }{{\f5\fs18\hyphpar0\qj{chapter 154F}}}{, or a hearing aid specialist licensed under }{{\f5\fs18\hyphpar0\qj{chapter 154A}}}{, if the audiologist or specialist provides either an express warranty for the hearing aid or provides for service and replacement of the hearing aid.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1042, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a787}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a784}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 57, \'a716}}}\par}}