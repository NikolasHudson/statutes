}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 repeal effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{222.71 and 222.72}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2004/CH1090.pdf" }{\fldrslt \f5 \fs18{{2004 Acts, ch 1090, \'a755}}}}}}{{\f5\fs18\qj{2004 Acts, ch 1090, \'a755}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.73}}}{\*\bkmkstart stylerid1_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Billing of patient charges \u8212\'3f computation of actual costs \u8212\'3f cost settlement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent of each resource center shall compute by February 1 the average daily patient charge and outpatient treatment charges for which each county will be billed for services provided to patients chargeable to the county during the fiscal year beginning the following July 1. The department shall certify the amount of the charges and notify the counties of the billing charges.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent shall compute the average daily patient charge for a resource center for services provided in the following fiscal year, in accordance with generally accepted accounting procedures, by totaling the expenditures of the resource center for the immediately preceding calendar year, by adjusting the expenditures by a percentage not to exceed the percentage increase in the consumer price index for all urban consumers for the immediately preceding calendar year, and by dividing the adjusted expenditures by the total inpatient days of service provided during the immediately preceding calendar year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall compute the outpatient treatment charges, in accordance with generally accepted accounting procedures, on the basis of the actual cost of the outpatient treatment provided during the immediately preceding calendar year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent shall compute in January the actual per-patient-per-day cost for each resource center for the immediately preceding calendar year, in accordance with generally accepted accounting procedures, by totaling the actual expenditures of the resource center for the calendar year and by dividing the total actual expenditures by the total inpatient days of service provided during the calendar year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A superintendent of a resource center may request that the director enter into a contract with a person for the resource center to provide consultation or treatment services or for fulfilling other purposes which are consistent with the purposes stated in }}}{{\f5\fs18\hyphpar0\qj{section 222.1}}}{{\f5\fs18\hyphpar0\qj{. The contract provisions shall include charges which reflect the actual cost of providing the services. Any income from a contract authorized under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ may be retained by the resource center to defray the costs of providing the services or fulfilling the other purposes. Except for a contract voluntarily entered into by a county under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the costs or income associated with a contract authorized under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be considered in computing charges and per diem costs in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsections 1 and 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72727-a96; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3469;}}}{ C46, 50, 54, 58, 62, \'a7223.5; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1169, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1249, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1276, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 82, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1183, \'a76 \u8211\'3f 8}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1155, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1112, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 155, \'a715 \u8211\'3f 17}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1090, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7263}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1120, \'a786, 130}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 69, \'a716, 17}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 109, \'a71, 20, 21}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7436}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a744, 137, 174, 180}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsections 2 and 4 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 stricken and former subsection 3 renumbered as 2}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4 stricken and former subsection 5 renumbered as 3}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.74}}}{\*\bkmkstart stylerid1_2E46_2E2_2E2}{\*\bkmkend stylerid1_2E46_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duplicate to county.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7135, 137}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 repeal effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.75}}}{\*\bkmkstart stylerid1_2E47_2E2_2E2}{\*\bkmkend stylerid1_2E47_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Delinquent payments \u8212\'3f penalty.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7135, 137}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 repeal effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.76}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.77}}}{\*\bkmkstart stylerid1_2E49_2E2_2E2}{\*\bkmkend stylerid1_2E49_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Patients on leave.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The cost of support of patients placed on convalescent leave or removed as a habilitation measure from a resource center, except when living in the home of a person legally bound for the support of the patient, shall be paid by the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7222.77}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71027}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 123, \'a783, 209}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1112, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1120, \'a787, 130}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a745, 137}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.78}}}{\*\bkmkstart stylerid1_2E5_30_2E2_2E2}{\*\bkmkend stylerid1_2E5_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Parents and others liable for support.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The father and mother of any patient admitted to a resource center, as either an inpatient or an outpatient, and any person, firm, or corporation bound by contract made for support of the patient, are liable for the support of the patient. The patient and those legally bound for the support of the patient shall be liable to the state for all sums advanced relating to reasonable attorney fees and court costs for the patient\u8217\'3fs admission to the resource center, and for the treatment, training, instruction, care, habilitation, support, transportation, or other expenditures made on behalf of the patient pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The liability of any person, other than the patient, who is legally bound for the support of a patient who is under eighteen years of age in a resource center or a special unit shall not exceed the average minimum cost of the care of a minor without an intellectual disability of the same age and sex as the minor patient. The department shall establish the scale for this purpose but the scale shall not exceed the standards for personal allowances established under the family investment program. The father or mother shall incur liability only during any period when the father or mother either individually or jointly receive a net income from whatever source, commensurate with that upon which they would be liable to make an income tax payment to this state. The father or mother of a patient shall not be liable for the support of the patient upon the patient attaining eighteen years of age. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to prevent a relative or other person from voluntarily paying the full actual cost as established by the department for caring for the patient with an intellectual disability.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3477.5;}}}{ C46, 50, 54, 58, 62, \'a7223.16, 223.20; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.78}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 97, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1218, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1112, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1019, \'a757}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1120, \'a788, 130}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 130, \'a728, 35}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7437}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a746, 137}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7218.78}}}{{\f5\fs12\hyphpar0\qj{, 222.79}}}{{\f5\fs12\hyphpar0\qj{, 222.80}}}{{\f5\fs12\hyphpar0\qj{, 222.81}}}{{\f5\fs12\hyphpar0\qj{, 222.82}}}{{\f5\fs12\hyphpar0\qj{, 226.8}}}{{\f5\fs12\hyphpar0\qj{, 234.39}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.79}}}{\*\bkmkstart stylerid1_2E51_2E2_2E2}{\*\bkmkend stylerid1_2E51_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certification statement presumed correct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In actions to enforce the liability imposed by }{{\f5\fs18\hyphpar0\qj{section 222.78}}}{, the superintendent shall submit a certification statement stating the sums charged, and the certification statement shall be considered presumptively correct.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.79}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 155, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1120, \'a789, 130}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a747, 137}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.80}}}{\*\bkmkstart stylerid1_2E52_2E2_2E2}{\*\bkmkend stylerid1_2E52_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Liability to state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person admitted to a county institution or admitted at state expense to a private hospital, sanitarium, or other facility for treatment, training, instruction, care, habilitation, and support as a patient with an intellectual disability shall be liable to the state for the reasonable cost of the support as provided in }{{\f5\fs18\hyphpar0\qj{section 222.78}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.80}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1129, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1019, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1120, \'a790, 130}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 130, \'a729, 35}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a748, 137}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.81}}}{\*\bkmkstart stylerid1_2E53_2E2_2E2}{\*\bkmkend stylerid1_2E53_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Claim against estate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The total amount of liability provided in }{{\f5\fs18\hyphpar0\qj{section 222.78}}}{ shall be allowed as a claim of the sixth class against the estate of the person or against the estate of the father or mother of such person.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.81}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.82}}}{\*\bkmkstart stylerid1_2E54_2E2_2E2}{\*\bkmkend stylerid1_2E54_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Collection of liabilities and claims.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If liabilities and claims exist as provided in }{{\f5\fs18\hyphpar0\qj{section 222.78}}}{ or any other provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the state may proceed as provided in }{{\f5\fs18\hyphpar0\qj{this section}}}{. The state may compromise any and all liabilities to the state arising under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ when such compromise is deemed to be in the best interests of the state. Any collections and liens shall be limited in conformance to }{{\f5\fs18\hyphpar0\qj{section 614.1, subsection 4}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3477.6;}}}{ C46, 50, 54, 58, 62, \'a7223.17; C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.82}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2012 Acts, ch 1120, \'a791, 130}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a749, 137}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.83}}}{\*\bkmkstart stylerid1_2E55_2E2_2E2}{\*\bkmkend stylerid1_2E55_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonresident patients.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The estates of all nonresident patients who are provided treatment, training, instruction, care, habilitation, and support in or by a resource center, and all persons legally bound for the support of such persons, shall be liable to the state for the reasonable value of such services. The certificate of the superintendent of the resource center in which any nonresident is or has been a patient, showing the amounts drawn from the state treasury or due therefrom as provided by law on account of such nonresident patient, shall be presumptive evidence of the reasonable value of such services furnished such patient by the resource center.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.83}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1112, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7175, 180}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.84}}}{\*\bkmkstart stylerid1_2E56_2E2_2E2}{\*\bkmkend stylerid1_2E56_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Patients\u8217\'3f personal deposit fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{There is established at each resource center a patients\u8217\'3f personal deposit fund. }\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.84}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1112, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a781}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7438}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7176, 180}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.85}}}{\*\bkmkstart stylerid1_2E57_2E2_2E2}{\*\bkmkend stylerid1_2E57_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deposit of moneys }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exception to guardians.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any funds coming into the possession of the superintendent or any employee of a resource center belonging to any patient in that institution shall be deposited in the name of the patient in the patients\u8217\'3f personal deposit fund, except that if a guardian of the property has been appointed for the person, the guardian shall have the right to demand and receive such funds. Funds belonging to a patient deposited in the patients\u8217\'3f personal deposit fund may be used for the purchase of personal incidentals, desires, and comforts for the patient.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys paid to a resource center from any source other than state appropriated funds and intended to pay all or a portion of the cost of care of a patient, which cost would otherwise be paid from state funds or from the patient\u8217\'3fs own funds, shall not be deemed \u8220\'3ffunds belonging to a patient\u8221\'3f for the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.85}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1112, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a750, 137, 177, 180}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 2 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.86}}}{\*\bkmkstart stylerid1_2E58_2E2_2E2}{\*\bkmkend stylerid1_2E58_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Payment for care from fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a patient is not receiving medical assistance under }{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{ and the amount in the account of any patient in the patients\u8217\'3f personal deposit fund exceeds two hundred dollars, the department may apply any amount of the excess to reimburse the state for liability incurred by the state for the payment of care, support, and maintenance of the patient when billed by the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a7222.86}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 11, \'a715}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1112, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1120, \'a792, 130}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7439}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a751, 137}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.87}}}{\*\bkmkstart stylerid1_2E59_2E2_2E2}{\*\bkmkend stylerid1_2E59_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Deposit in bank.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall deposit the patients\u8217\'3f personal deposit fund in a commercial account of a bank of reputable standing. When deposits in the commercial account exceed average monthly withdrawals, the department may deposit the excess at interest. The savings account shall be in the name of the patients\u8217\'3f personal deposit fund and interest paid on the account may be used for recreational purposes for the patients at the resource center.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7222.87}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1112, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7440}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a7178, 180}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.88}}}{\*\bkmkstart stylerid1_2E6_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Special intellectual disability unit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7179, 180}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.89}}}{\*\bkmkstart stylerid1_2E61_2E2_2E2}{\*\bkmkend stylerid1_2E61_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Location \u8212\'3f staff and personnel.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7179, 180}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.90}}}{\*\bkmkstart stylerid1_2E62_2E2_2E2}{\*\bkmkend stylerid1_2E62_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Superintendent.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7179, 180}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.91}}}{\*\bkmkstart stylerid1_2E63_2E2_2E2}{\*\bkmkend stylerid1_2E63_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Direct referral to special unit.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1161, \'a7179, 180}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{222.92}}}{\*\bkmkstart stylerid1_2E64_2E2_2E2}{\*\bkmkend stylerid1_2E64_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Net general fund appropriation \u8212\'3f state resource centers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall operate the state resource centers on the basis of net appropriations from the general fund of the state. The appropriation amounts shall be the net amounts of state moneys projected to be needed for the state resource centers for the fiscal year of the appropriations. The purpose of utilizing net appropriations is to encourage the state resource centers to operate with increased self-sufficiency, to improve quality and efficiency, and to support collaborative efforts between the state resource centers and providers of funding for the services available from the state resource centers. The state resource centers shall not be operated under the net appropriations in a manner that results in a cost increase to the state or in cost shifting between the state, the medical assistance program, or other sources of funding for the state resource centers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The net appropriation made for a state resource center may be used throughout the fiscal year in the manner necessary for purposes of cash flow management, and for purposes of cash flow management, a state resource center may temporarily draw more than the amount appropriated, provided the amount appropriated is not exceeded at the close of the fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to the approval of the department, except for revenues segregated as provided in }}}{{\f5\fs18\hyphpar0\qj{section 249A.11}}}{{\f5\fs18\hyphpar0\qj{, revenues received that are attributed to a state resource center for a fiscal year shall be credited to the state resource center\u8217\'3fs account and shall be considered appropriated receipts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The federal share of medical assistance program revenue received under }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Federal Medicare program payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys received from client financial participation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other revenues generated from current, new, or expanded services that the state resource center is authorized to provide.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, up to five hundred thousand dollars of a state resource center\u8217\'3fs revenue that remains unencumbered or unobligated at the close of the fiscal year shall not revert but shall remain available for expenditure for purposes of the state resource center until the close of the succeeding fiscal year.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 175, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1120, \'a793, 130}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 69, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1161, \'a752, 53, 137}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7155, 156}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 amendment to subsection 1 effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2024 strike of subsection 3, paragraph a effective July 1, 2025; }{{\f5\fs12\hyphpar0\qj{2024 Acts, ch 1161, \'a7137}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph a stricken and former paragraphs b \u8211\'3f e redesignated as a \u8211\'3f d}\par}}