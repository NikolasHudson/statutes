\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F5_305A}{\*\bkmkend codeChapter_5F5_305A}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 505A}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{INTERSTATE INSURANCE PRODUCT}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\f5\fs18\qc\fi0\ri0\li0{ REGULATION COMPACT}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a787.4}}}{{\f5\fs12\qc{, 296.7}}}{{\f5\fs12\qc{, 331.301}}}{{\f5\fs12\qc{, 364.4}}}{{\f5\fs12\qc{, 505.28}}}{{\f5\fs12\qc{, 505.29}}}{{\f5\fs12\qc{, 669.14}}}{{\f5\fs12\qc{, 670.7}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{505A.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interstate insurance product regulation compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The interstate insurance product regulation compact is hereby entered into and enacted into law with all jurisdictions legally joining therein, in the form substantially as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E5_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article I \u8212\'3f Purposes.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purposes of this compact are, through means of joint and cooperative action among the compacting states:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To promote and protect the interest of consumers of individual and group annuity, life insurance, disability income and long-term care insurance products.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To develop uniform standards for insurance products covered under this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish a central clearinghouse to receive and provide prompt review of insurance products covered under the compact and, in certain cases, advertisements related thereto, submitted by insurers authorized to do business in one or more compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To give appropriate regulatory approval to those product filings and advertisements satisfying the applicable uniform standard.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To improve coordination of regulatory resources and expertise between state insurance departments regarding the setting of uniform standards and review of insurance products covered under this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To create the interstate insurance product regulation commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To perform these and such other related functions as may be consistent with the state regulation of the business of insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article II \u8212\'3f Definitions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this compact, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdvertisement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any material designed to create public interest in a product, or induce the public to purchase, increase, modify, reinstate, borrow on, surrender, replace or retain a policy, as more specifically defined in the rules and operating procedures of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBylaws\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means those bylaws established by the commission for its governance, or for directing or controlling the commission\u8217\'3fs actions or conduct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommission\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the interstate insurance product regulation commission established by this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommissioner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the chief insurance regulatory official of a state including, but not limited to, commissioner, superintendent, director, or administrator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompacting state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any state that has enacted this compact legislation and that has not withdrawn pursuant to article XIV, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or been terminated pursuant to article XIV, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDomiciliary state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the state in which an insurer is incorporated or organized, or, in the case of an alien insurer, its state of entry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInsurer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any entity licensed by a state to issue contracts of insurance for any of the lines of insurance covered by this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMember\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the person chosen by a compacting state as its representative to the commission, or the person\u8217\'3fs designee. The commissioner of insurance shall be the representative member of the compact for the state of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNoncompacting state\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any state which is not at the time a compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOperating procedures\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means procedures promulgated by the commission implementing a rule, uniform standard, or a provision of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProduct\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the form of a policy or contract, including any application, endorsement, or related form which is attached to and made a part of the policy or contract, and any evidence of coverage or certificate, for an individual or group annuity, life insurance, disability income, or long-term care insurance product that an insurer is authorized to issue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a statement of general or particular applicability and future effect promulgated by the commission, including a uniform standard developed pursuant to article VII, designed to implement, interpret, or prescribe law or policy, or describing the organization, procedure, or practice requirements of the commission, which shall have the force and effect of law in the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any state, district, or territory of the United States of America.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fThird-party filer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an entity that submits a product filing to the commission on behalf of an insurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUniform standard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a standard adopted by the commission for a product line, pursuant to article VII, and shall include all of the product requirements in aggregate, provided that each uniform standard shall be construed, whether express or implied, to prohibit the use of any inconsistent, misleading, or ambiguous provisions in a product, and the form of the product made available to the public shall not be unfair, inequitable, or against public policy as determined by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E5_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article III \u8212\'3f Establishment of the commission and venue.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The compacting states hereby create and establish a joint public agency known as the interstate insurance product regulation commission. Pursuant to article IV, the commission has the power to develop uniform standards for product lines, receive and provide prompt review of products filed therewith, and give approval to those product filings satisfying applicable uniform standards, provided it is not intended for the commission to be the exclusive entity for receipt and review of insurance product filings. Nothing herein shall prohibit any insurer from filing its product in any state wherein the insurer is licensed to conduct the business of insurance, and any such filing shall be subject to the laws of the state where filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission is a body corporate and politic, and an instrumentality of the compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission is solely responsible for its liabilities except as otherwise specifically provided in this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Venue is proper and judicial proceedings by or against the commission shall be brought solely and exclusively in a court of competent jurisdiction where the principal office of the commission is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E5_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IV \u8212\'3f Powers of the commission.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall have the following powers:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To promulgate rules, pursuant to article VII, which shall have the force and effect of law and shall be binding in the compacting states to the extent and in the manner provided in this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To exercise its rulemaking authority and establish reasonable uniform standards for products covered under this compact, and advertisement related thereto, which shall have the force and effect of law and shall be binding in the compacting states, but only for those products filed with the commission, provided that a compacting state shall have the right to opt out of such uniform standard pursuant to article VII, to the extent and in the manner provided in this compact, and, provided further, that any uniform standard established by the commission for long-term care insurance products may provide the same or greater protections for consumers as, but shall not provide less than, those protections set forth in the national association of insurance commissioners\u8217\'3f long-term care insurance model act and long-term care insurance model regulation, respectively, adopted as of 2001. The commission shall consider whether any subsequent amendments to the long-term care insurance model act or long-term care insurance model regulation adopted by the national association of insurance commissioners require amending of the uniform standards established by the commission for long-term care insurance products.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To receive and review in an expeditious manner products filed with the commission, and rate filings for disability income and long-term care insurance products, and give approval of those products and rate filings that satisfy the applicable uniform standard, where such approval shall have the force and effect of law, and be binding on the compacting states to the extent and in the manner provided in the compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To receive and review in an expeditious manner advertisement relating to long-term care insurance products for which uniform standards have been adopted by the commission, and give approval to all advertisement that satisfies the applicable uniform standard. For any product covered under this compact, other than long-term care insurance products, the commission shall have the authority to require an insurer to submit all or any part of its advertisement with respect to that product for review or approval prior to use, if the commission determines that the nature of the product is such that an advertisement of the product could have the capacity or tendency to mislead the public. The actions of the commission as provided in this article shall have the force and effect of law and shall be binding in the compacting states to the extent and in the manner provided in this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To exercise its rulemaking authority and designate products and advertisement that may be subject to a self-certification process without the need for prior approval by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To promulgate operating procedures, pursuant to article VII, which shall be binding in the compacting states to the extent and in the manner provided in this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To bring and prosecute legal proceedings or actions in its name as the commission, provided that the standing of any state insurance department to sue or be sued under applicable law shall not be affected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To issue subpoenas requiring the attendance and testimony of witnesses and the production of evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish and maintain offices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To purchase and maintain insurance and bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To borrow, accept, or contract for services of personnel, including, but not limited to, employees of a compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To hire employees, professionals, or specialists, and elect or appoint officers, and to fix their compensation, define their duties, and give them appropriate authority to carry out the purposes of this compact, and determine their qualifications, and to establish the commission\u8217\'3fs personnel policies and programs relating to, among other things, conflicts of interest, rates of compensation, and qualifications of personnel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To accept any and all appropriate donations and grants of money, equipment, supplies, materials, and services, and to receive, utilize, and dispose of the same, provided that at all times the commission shall strive to avoid any appearance of impropriety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To lease, purchase, accept appropriate gifts or donations of, or otherwise to own, hold, improve, or use, any property, real, personal, or mixed, provided that at all times the commission shall strive to avoid any appearance of impropriety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To sell, convey, mortgage, pledge, lease, exchange, abandon, or otherwise dispose of any property, real, personal, or mixed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To remit filing fees to compacting states as may be set forth in the bylaws, rules, or operating procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To enforce compliance by compacting states with rules, uniform standards, operating procedures, and bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide for dispute resolution among compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To advise compacting states on issues relating to insurers domiciled or doing business in noncompacting jurisdictions, consistent with the purposes of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{t.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide advice and training to those personnel in state insurance departments responsible for product review, and to be a resource for state insurance departments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{u.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To establish a budget and make expenditures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{v.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To borrow money.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{w.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To appoint committees, including advisory committees comprising members, state insurance regulators, state legislators or their representatives, insurance industry and consumer representatives, and such other interested persons as may be designated in the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{x.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To provide and receive information from, and to cooperate with, law enforcement agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{y.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To adopt and use a corporate seal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{z.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To perform such other functions as may be necessary or appropriate to achieve the purposes of this compact consistent with the state regulation of the business of insurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E5_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article V \u8212\'3f Organization of the commission.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E5_2E8_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Membership, voting, and bylaws.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each compacting state shall have and be limited to one member. Each member shall be qualified to serve in that capacity pursuant to applicable law of the compacting state. Any member may be removed or suspended from office as provided by the law of the state from which the member is appointed. Any vacancy occurring in the commission shall be filled in accordance with the laws of the compacting state wherein the vacancy exists. Nothing herein shall be construed to affect the manner in which a compacting state determines the election or appointment and qualification of its own commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each member shall be entitled to one vote and shall have an opportunity to participate in the governance of the commission in accordance with the bylaws. Notwithstanding any provision herein to the contrary, no action of the commission with respect to the promulgation of a uniform standard shall be effective unless two-thirds of the members vote in favor thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall, by a majority of the members, prescribe bylaws to govern its conduct as may be necessary or appropriate to carry out the purposes, and exercise the powers, of the compact, including, but not limited to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing the fiscal year of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing reasonable procedures for appointing and electing members, as well as holding meetings, of the management committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing reasonable standards and procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the establishment and meetings of other committees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Governing any general or specific delegation of any authority or function of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing reasonable procedures for calling and conducting meetings of the commission that consists of a majority of commission members ensuring reasonable advance notice of each such meeting, and providing for the right of citizens to attend each such meeting with enumerated exceptions designed to protect the public\u8217\'3fs interest, the privacy of individuals, and insurers\u8217\'3f proprietary information, including trade secrets. The commission may meet in camera only after a majority of the entire membership votes to close a meeting en toto or in part. As soon as practicable, the commission shall make public:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A copy of the vote to close the meeting, revealing the vote of each member, with no proxy votes allowed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Votes taken during such meeting.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing the titles, duties, and authority, and reasonable procedures for the election of the officers of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing reasonable standards and procedures for the establishment of the personnel policies and programs of the commission. Notwithstanding any civil service or other similar laws of any compacting state, the bylaws shall exclusively govern the personnel policies and programs of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(g)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Providing a mechanism for winding up the operations of the commission and the equitable disposition of any surplus funds that may exist after the termination of this compact after the payment or reserving of all of its debts and obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(h)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promulgating a code of ethics to address permissible and prohibited activities of commission members and employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall publish its bylaws in a convenient form and file a copy of the bylaws, along with any amendments, with the appropriate agency or officer in each of the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E5_2E8_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Management committee, officers, and personnel.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A management committee comprising no more than fourteen members shall be established as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member from each of the six compacting states with the largest premium volume for individual and group annuities, life, disability income, and long-term care insurance products, determined from the records of the national association of insurance commissioners for the prior year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Four members from those compacting states with at least two percent of the market based on the premium volume described in subparagraph division (a), other than the six compacting states with the largest premium volume, selected on a rotating basis as provided in the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Four members from those compacting states with less than two percent of the market, based on the premium volume described in subparagraph division (a), with one selected from each of the four zone regions of the national association of insurance commissioners as provided in the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The management committee shall have such authority and duties as may be set forth in the bylaws, including but not limited to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Managing the affairs of the commission in a manner consistent with the bylaws and purposes of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establishing and overseeing an organizational structure within, and appropriate procedures for, the commission to provide for the creation of uniform standards and other rules, receipt and review of product filings, administrative and technical support functions, review of decisions regarding the disapproval of a product filing, and the review of elections made by a compacting state to opt out of a uniform standard, provided that a uniform standard shall not be submitted to the compacting states for adoption unless approved by two-thirds of the members of the management committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Overseeing the offices of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Planning, implementing, and coordinating communications and activities with other state, federal, and local government organizations in order to advance the goals of the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall elect annually officers from the management committee, with each having such authority and duties, as may be specified in the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The management committee may, subject to the approval of the commission, appoint or retain an executive director for such period, upon such terms and conditions and for such compensation as the commission may deem appropriate. The executive director shall serve as secretary to the commission, but shall not be a member of the commission. The executive director shall hire and supervise such other staff as may be authorized by the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E5_2E8_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Legislative and advisory committees.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A legislative committee comprising state legislators or their designees shall be established to monitor the operations of, and make recommendations to, the commission, including the management committee, provided that the manner of selection and term of any legislative committee member shall be as set forth in the bylaws. Prior to the adoption by the commission of any uniform standard, revision to the bylaws, annual budget, or other significant matter as may be provided in the bylaws, the management committee shall consult with and report to the legislative committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall establish two advisory committees, one of which shall comprise consumer representatives independent of the insurance industry, and the other comprising insurance industry representatives.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission may establish additional advisory committees as its bylaws may provide for the carrying out of its functions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{\*\bkmkstart stylerid1_2E5_2E8_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Corporate records of the commission.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall maintain its corporate books and records in accordance with the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{\*\bkmkstart stylerid1_2E5_2E8_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Qualified immunity, defense, and indemnification.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members, officers, executive director, employees, and representatives of the commission shall be immune from suit and liability, either personally or in their official capacity, for any claim for damage to, or loss of, property, personal injury, or other civil liability caused by or arising out of any actual or alleged act, error, or omission that occurred, or that the person against whom the claim is made had a reasonable basis for believing occurred, within the scope of commission employment, duties, or responsibilities, provided that nothing in this subparagraph shall be construed to protect any such person from suit or liability for any damage, loss, injury, or liability caused by the intentional or willful and wanton misconduct of that person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall defend any member, officer, executive director, employee, or representative of the commission in any civil action seeking to impose liability arising out of any actual or alleged act, error, or omission that occurred within the scope of commission employment, duties, or responsibilities, or that the person against whom the claim is made had a reasonable basis for believing occurred within the scope of commission employment, duties, or responsibilities, provided that nothing herein shall be construed to prohibit that person from retaining the person\u8217\'3fs own counsel; and, provided further, that the actual or alleged act, error, or omission did not result from that person\u8217\'3fs intentional or willful and wanton misconduct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall indemnify and hold harmless any member, officer, executive director, employee, or representative of the commission for the amount of any settlement or judgment obtained against that person arising out of any actual or alleged act, error, or omission that occurred within the scope of commission employment, duties, or responsibilities, or that such person had a reasonable basis for believing occurred within the scope of commission employment, duties, or responsibilities, provided that the actual or alleged act, error, or omission did not result from the intentional or willful and wanton misconduct of that person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E5_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VI \u8212\'3f Meetings and acts of the commission.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall meet and take such actions as are consistent with the provisions of this compact and the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each member of the commission shall have the right and power to cast a vote to which that compacting state is entitled and to participate in the business and affairs of the commission. A member shall vote in person or by such other means as provided in the bylaws. The bylaws may provide for members\u8217\'3f participation in meetings by telephone or other means of communication.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall meet at least once during each calendar year. Additional meetings shall be held as set forth in the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VII \u8212\'3f Rules and operating procedures \u8212\'3f rulemaking functions of the commission and opting out of uniform standards.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rulemaking authority.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall promulgate reasonable rules, including uniform standards and operating procedures, in order to effectively and efficiently achieve the purposes of this compact. Notwithstanding the foregoing, in the event the commission exercises its rulemaking authority in a manner that is beyond the scope of the purposes of this compact, or the powers granted hereunder, such an action by the commission shall be invalid and have no force and effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rulemaking procedure.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rules and operating procedures shall be made pursuant to a rulemaking process that conforms to the model state administrative procedure act of 1981 as amended, as may be appropriate to the operations of the commission. Before the commission adopts a uniform standard, the commission shall give written notice to the relevant state legislative committee or committees in each compacting state responsible for insurance issues of its intention to adopt the uniform standard. The commission, in adopting a uniform standard, shall consider fully all submitted materials and issue a concise explanation of its decision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Effective date and opt out of a uniform standard.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A uniform standard shall become effective ninety days after its promulgation by the commission or such later date as the commission may determine, provided, however, that a compacting state may opt out of a uniform standard as provided in this article. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOpt out\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any action by a compacting state to decline to adopt or participate in a promulgated uniform standard. All other rules and operating procedures, and amendments thereto, shall become effective as of the date specified in each rule, operating procedure, or amendment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Opt-out procedure.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A compacting state may opt out of a uniform standard, either by legislation or regulation duly promulgated by the insurance department under the compacting state\u8217\'3fs administrative procedure act. If a compacting state elects to opt out of a uniform standard by regulation, it must do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Give written notice to the commission no later than ten business days after the uniform standard is promulgated, or at the time the state becomes a compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Find that the uniform standard does not provide reasonable protections to the citizens of the state, given the conditions in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner shall make specific findings of fact and conclusions of law, based on a preponderance of the evidence, detailing the conditions in the state which warrant a departure from the uniform standard and determining that the uniform standard would not reasonably protect the citizens of the state. The commissioner must consider and balance the following factors and find that the conditions in the state and needs of the citizens of the state outweigh both of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The intent of the legislature to participate in, and the benefits of, an interstate agreement to establish national uniform consumer protections for the products subject to this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The presumption that a uniform standard adopted by the commission provides reasonable protections to consumers of the relevant product.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding the foregoing, a compacting state may, at the time of its enactment of this compact, prospectively opt out of all uniform standards involving long-term care insurance products by expressly providing for such opt out in the enacted compact, and such an opt out shall not be treated as a material variance in the offer or acceptance of any state to participate in this compact. Such an opt out shall be effective at the time of enactment of this compact by the compacting state and shall apply to all existing uniform standards involving long-term care insurance products and those subsequently promulgated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Effect of opt out.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a compacting state elects to opt out of a uniform standard, the uniform standard shall remain applicable in the compacting state electing to opt out until such time the opt-out legislation is enacted into law or the regulation opting out becomes effective.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once the opt out of a uniform standard by a compacting state becomes effective, as provided under the laws of that state, the uniform standard shall have no further force and effect in that state unless and until the legislation or regulation implementing the opt out is repealed or otherwise becomes ineffective under the laws of the state. If a compacting state opts out of a uniform standard after the uniform standard has been made effective in that state, the opt out shall have the same prospective effect as provided under article XIV for withdrawals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E5_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article VIII \u8212\'3f Commission records and enforcement.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall promulgate rules establishing conditions and procedures for public inspection and copying of its information and official records, except such information and records involving the privacy of individuals and insurers\u8217\'3f trade secrets. The commission may promulgate additional rules under which it may make available to federal and state agencies, including law enforcement agencies, records, and information otherwise exempt from disclosure, and may enter into agreements with such agencies to receive or exchange information or records subject to nondisclosure and confidentiality provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as to privileged records, data, and information, the laws of any compacting state pertaining to confidentiality or nondisclosure shall not relieve any compacting state commissioner of the duty to disclose any relevant records, data, or information to the commission, provided that disclosure to the commission shall not be deemed to waive or otherwise affect any confidentiality requirement, and further provided that, except as otherwise expressly provided in this compact, the commission shall not be subject to the compacting state\u8217\'3fs laws pertaining to confidentiality and nondisclosure with respect to records, data, and information in its possession. Confidential information of the commission shall remain confidential after such information is provided to any commissioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall monitor compacting states for compliance with duly adopted bylaws, rules, including uniform standards, and operating procedures. The commission shall notify any noncomplying compacting state in writing of its noncompliance with commission bylaws, rules, or operating procedures. If a noncomplying compacting state fails to remedy its noncompliance within the time specified in the notice of noncompliance, the compacting state shall be deemed to be in default as set forth in article XIV.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner of any state in which an insurer is authorized to do business, or is conducting the business of insurance, shall continue to exercise the commissioner\u8217\'3fs authority to oversee the market regulation of the activities of the insurer in accordance with the provisions of the state\u8217\'3fs law. The commissioner\u8217\'3fs enforcement of compliance with the compact is governed by the following provisions:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With respect to the commissioner\u8217\'3fs market regulation of a product or advertisement that is approved or certified to the commission, the content of the product or advertisement shall not constitute a violation of the provisions, standards, or requirements of this compact except upon a final order of the commission, issued at the request of a commissioner after prior notice to the insurer and an opportunity for hearing before the commission.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before a commissioner may bring an action for violation of any provision, standard, or requirement of this compact relating to the content of an advertisement not approved or certified to the commission, the commission, or an authorized commission officer or employee, must authorize the action. However, authorization pursuant to this subparagraph does not require notice to the insurer, opportunity for hearing, or disclosure of requests for authorization or records of the commission\u8217\'3fs action on such requests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{\*\bkmkstart stylerid1_2E5_2E11_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E11_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Stay of uniform standard.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a compacting state has formally initiated the process of opting out of a uniform standard by regulation, and while the regulatory opt out is pending, the compacting state may petition the commission, at least fifteen days before the effective date of the uniform standard, to stay the effectiveness of the uniform standard in that state. The commission may grant a stay if it determines the regulatory opt out is being pursued in a reasonable manner and there is a likelihood of success. If a stay is granted or extended by the commission, the stay or extension thereof may postpone the effective date by up to ninety days, unless affirmatively extended by the commission, provided a stay may not be permitted to remain in effect for more than one year unless the compacting state can show extraordinary circumstances which warrant a continuance of the stay, including, but not limited to, the existence of a legal challenge which prevents the compacting state from opting out. A stay may be terminated by the commission upon notice that the rulemaking process has been terminated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than thirty days after a rule or operating procedure is adopted, any person may file a petition for judicial review of the rule or operating procedure, provided that the filing of such a petition shall not stay or otherwise prevent the rule or operating procedure from becoming effective unless the court finds that the petitioner has a substantial likelihood of success. The court shall give deference to the actions of the commission consistent with applicable law and shall not find the rule or operating procedure to be unlawful if the rule or operating procedure represents a reasonable exercise of the commission\u8217\'3fs authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E5_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article IX \u8212\'3f Dispute resolution.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall attempt, upon the request of a member, to resolve any disputes or other issues which are subject to this compact and which may arise between two or more compacting states, or between compacting states and noncompacting states, and the commission shall promulgate an operating procedure providing for resolution of such disputes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E5_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article X \u8212\'3f Product filing and approval.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Insurers and third-party filers seeking to have a product approved by the commission shall file the product with, and pay applicable filing fees to, the commission. Nothing in this compact shall be construed to restrict or otherwise prevent an insurer from filing its product with the insurance department in any state wherein the insurer is licensed to conduct the business of insurance, and such filing shall be subject to the laws of the states where filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall establish appropriate filing and review processes and procedures pursuant to commission rules and operating procedures. Notwithstanding any provision herein to the contrary, the commission shall promulgate rules to establish conditions and procedures under which the commission will provide public access to product filing information. In establishing such rules, the commission shall consider the interests of the public in having access to such information, as well as protection of personal medical and financial information and trade secrets, that may be contained in a product filing or supporting information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any product approved by the commission may be sold or otherwise issued in those compacting states in which the insurer is legally authorized to do business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E5_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XI \u8212\'3f Review of commission decisions regarding filings.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than thirty days after the commission has given notice of a disapproved product or advertisement filed with the commission, the insurer or third-party filer whose filing was disapproved may appeal the determination to a review panel appointed by the commission. The commission shall adopt rules to establish procedures for appointing such review panels and provide for notice and hearing. An allegation that the commission, in disapproving a product or advertisement filed with the commission, acted arbitrarily, capriciously, or in a manner that is an abuse of discretion or otherwise not in accordance with the law, is subject to judicial review in accordance with article III, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall have authority to monitor, review, and reconsider products and advertisement subsequent to their filing or approval upon a finding that the product does not meet the relevant uniform standard. Where appropriate, the commission may withdraw or modify its approval after proper notice and hearing, subject to the appeal process in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{\*\bkmkstart stylerid1_2E5_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XII \u8212\'3f Finance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall pay or provide for the payment of the reasonable expenses of its establishment and organization. To fund the cost of its initial operations, the commission may accept contributions and other forms of funding from the national association of insurance commissioners, compacting states, and other sources. Contributions and other forms of funding from other sources shall be of such a nature that the independence of the commission concerning the performance of its duties shall not be compromised.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall collect a filing fee from each insurer and third-party filer filing a product with the commission to cover the cost of the operations and activities of the commission and its staff in a total amount sufficient to cover the commission\u8217\'3fs annual budget.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission\u8217\'3fs budget for a fiscal year shall not be approved until it has been subject to notice and comment as set forth in article VII.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall be exempt from all taxation in and by the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall not pledge the credit of any compacting state, except by and with the appropriate legal authority of that compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall keep complete and accurate accounts of all its internal receipts, including grants and donations, and disbursements of all funds under its control. The internal financial accounts of the commission shall be subject to the accounting procedures established under its bylaws. The financial accounts and reports, including the system of internal controls and procedures of the commission, shall be audited annually by an independent certified public accountant. Upon the determination of the commission, but no less frequently than every three years, the review of the independent auditor shall include a management and performance audit of the commission. The commission shall make an annual report to the governor and legislature of the compacting states, which shall include a report of the independent audit. The commission\u8217\'3fs internal accounts shall not be confidential and such materials may be shared with the commissioner of any compacting state upon request; provided, however, that any work papers related to any internal or independent audit and any information regarding the privacy of the individuals and insurers\u8217\'3f proprietary information, including trade secrets, shall remain confidential.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A compacting state shall not have any claim to or ownership of any property held by or vested in the commission or to any commission funds held pursuant to the provisions of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{\*\bkmkstart stylerid1_2E5_2E16_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E16_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XIII \u8212\'3f Compacting states, effective date, and amendment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any state is eligible to become a compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact shall become effective and binding upon legislative enactment of this compact into law by two compacting states, provided the commission shall become effective for purposes of adopting uniform standards for reviewing, and giving approval or disapproval of, products filed with the commission that satisfy applicable uniform standards only after twenty-six states are compacting states or, alternatively, by states representing greater than forty percent of the premium volume for life insurance, annuity, disability income, and long-term care insurance products, based on records of the national association of insurance commissioners for the prior year. Thereafter, it shall become effective and binding as to any other compacting state upon enactment of this compact into law by that state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Amendments to this compact may be proposed by the commission for enactment by the compacting states. An amendment shall not become effective and binding upon the commission and the compacting states unless and until all compacting states enact the amendment into law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{\*\bkmkstart stylerid1_2E5_2E17_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E17_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XIV \u8212\'3f Withdrawal, default, and termination.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E5_2E17_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E17_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Withdrawal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once effective, this compact shall continue in force and remain binding upon each and every compacting state, provided that a compacting state may withdraw from this compact by enacting a statute specifically repealing the statute which enacted the compact into law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The effective date of withdrawal is the effective date of the repealing statute. However, the withdrawal shall not apply to any product filings approved or self-certified, or any advertisement of such products, on the date the repealing statute becomes effective, except by mutual agreement of the commission and the withdrawing state unless the approval is rescinded by the withdrawing state as provided in subparagraph (5).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commissioner of the withdrawing state shall immediately notify the management committee in writing upon the introduction of legislation repealing this compact in the withdrawing state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The commission shall notify the other compacting states of the introduction of such legislation within ten days after its receipt of notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The withdrawing state is responsible for all obligations, duties, and liabilities incurred through the effective date of withdrawal, including any obligations, the performance of which extend beyond the effective date of withdrawal, except to the extent those obligations may have been released or relinquished by mutual agreement of the commission and the withdrawing state. The commission\u8217\'3fs approval of products and advertisement prior to the effective date of withdrawal shall continue to be effective and be given full force and effect in the withdrawing state, unless formally rescinded by the withdrawing state in the same manner as provided by the laws of the withdrawing state for the prospective disapproval of products or advertisement previously approved under state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reinstatement following withdrawal of any compacting state shall occur upon the effective date of the withdrawing state reenacting the compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E5_2E17_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E17_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Default.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the commission determines that any compacting state has at any time defaulted in the performance of any of its obligations or responsibilities under this compact, the bylaws or duly promulgated rules or operating procedures, then, after notice and hearing as set forth in the bylaws, all rights, privileges, and benefits conferred by this compact on the defaulting state shall be suspended from the effective date of default as fixed by the commission. The grounds for default include, but are not limited to, failure of a compacting state to perform its obligations or responsibilities, and any other grounds designated in commission rules. The commission shall immediately notify the defaulting state in writing of the defaulting state\u8217\'3fs suspension, pending a cure of the default. The commission shall stipulate the conditions and the time period within which the defaulting state must cure its default. If the defaulting state fails to cure the default within the time period specified by the commission, the defaulting state shall be terminated from this compact and all rights, privileges, and benefits conferred by this compact shall be terminated from the effective date of termination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Product approvals by the commission or product self-certifications, or any advertisement in connection with such product, that are in force on the effective date of termination shall remain in force in the defaulting state in the same manner as if the defaulting state had withdrawn voluntarily pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reinstatement following termination of any compacting state requires a reenactment of this compact.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E5_2E17_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E17_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Dissolution of compact.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This compact dissolves effective upon the date of the withdrawal or default of the compacting state which reduces membership in this compact to one compacting state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the dissolution of this compact, this compact becomes null and void and shall be of no further force or effect, and the business and affairs of the commission shall be wound up and any surplus funds shall be distributed in accordance with the bylaws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{\*\bkmkstart stylerid1_2E5_2E18_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E18_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XV \u8212\'3f Severability and construction.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of this compact shall be severable, and if any phrase, clause, sentence, or provision is deemed unenforceable, the remaining provisions of this compact shall be enforceable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of this compact shall be liberally construed to effectuate its purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{\*\bkmkstart stylerid1_2E5_2E19_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E19_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Article XVI \u8212\'3f Binding effect of compact and other laws.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E5_2E19_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E19_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Other laws.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing herein prevents the enforcement of any other law of a compacting state, except as provided in subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For any product approved or certified to the commission, the rules, uniform standards, and any other requirements of the commission shall constitute the exclusive provisions applicable to the content, approval, and certification of such products. For advertisement that is subject to the commission\u8217\'3fs authority, any rule, uniform standard, or other requirement of the commission which governs the content of the advertisement shall constitute the exclusive provision that a commissioner may apply to the content of the advertisement. Notwithstanding the foregoing, action taken by the commission shall not abrogate or restrict:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The access of any person to state courts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Remedies available under state law related to breach of contract, tort, general consumer protection laws, or general consumer protection regulations that apply to the sale or advertisement of the product or other laws not specifically directed to the content of the product.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{State law relating to the construction of insurance contracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The authority of the attorney general of the state, including but not limited to maintaining any actions or proceedings, as authorized by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All insurance products filed with individual states shall be subject to the laws of those states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E5_2E19_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E19_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Binding effect of this compact.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All lawful actions of the commission, including all rules and operating procedures adopted by the commission, are binding upon the compacting states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All agreements between the commission and the compacting states are binding in accordance with their terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the request of a party to a conflict over the meaning or interpretation of commission actions, and upon a majority vote of the compacting states, the commission may issue advisory opinions regarding the meaning or interpretation in dispute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event any provision of this compact exceeds the constitutional limits imposed on the legislature of any compacting state, the obligations, duties, powers, or jurisdiction sought to be conferred by that provision upon the commission shall be ineffective as to that compacting state, and those obligations, duties, powers, or jurisdiction shall remain in the compacting state and shall be exercised by the agency thereof to which those obligations, duties, powers, or jurisdiction are delegated by law in effect at the time this compact becomes effective.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 91, \'a754}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 179, \'a774}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1110, \'a76 \u8211\'3f 16}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 70, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a7263}}}\par}}