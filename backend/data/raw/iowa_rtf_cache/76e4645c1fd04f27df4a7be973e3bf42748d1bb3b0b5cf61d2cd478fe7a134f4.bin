\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F376}{\*\bkmkend codeChapter_5F376}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 376}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CITY ELECTIONS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a743.112}}}{{\f5\fs12\qc{, 362.1}}}{{\f5\fs12\qc{, 362.9}}}{{\f5\fs12\qc{, 420.137}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{City election held.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall hold a regular city election on the first Tuesday after the first Monday in November of each odd-numbered year. A city shall hold regular, special, primary, or runoff city elections as provided by state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The mayor or council shall give notice of any special election to the county commissioner of elections. The county commissioner of elections shall publish notice of any city election and conduct the election pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapters 39 through 53}}}{{\f5\fs18\hyphpar0\qj{, except as otherwise specifically provided in }}}{{\f5\fs18\hyphpar0\qj{chapters 362 through 392}}}{{\f5\fs18\hyphpar0\qj{. The results of any election shall be canvassed by the county board of supervisors and certified by the county commissioner of elections to the mayor and the council of the city for which the election is held.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71130; C73, \'a7501; C97, \'a7642, 936; S13, \'a7646, 1056-a20, -a21; SS15, \'a71056-b5, -b6; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5627, 6488, 6494, 6507, 6514, 6643, 6644, 6737;}}}{ C46, 50, \'a7363.5, 416.12, 416.18, 416.31, 416.38, 419.29, 419.30; C54, 58, 62, 66, 71, 73, \'a7363.8, 363.20, 363.24, 363.26; C75, 77, 79, 81, \'a7376.1]}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7202}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a739.20}}}{{\f5\fs12\hyphpar0\qj{, 331.383}}}{{\f5\fs12\hyphpar0\qj{, 372.13}}}{{\f5\fs12\hyphpar0\qj{, 388.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Terms of city officers begin and end at noon on the first day in January which is not a Sunday or legal holiday, following a regular city election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided by state law or the city charter, terms for elective offices are two years. However, the term of an elective office may be changed to two or four years by petition and election. Upon receipt of a petition meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 362.4}}}{{\f5\fs18\hyphpar0\qj{, requesting that the term of an elective office be changed, the council shall submit the question at a special election. If a majority of the persons voting at the special election approves the changed term, it becomes effective at the beginning of the term following the next regular city election. If a majority does not approve the changed term, the council shall not submit the same proposal to the voters within the next four years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the first regular city election after the terms of council members are changed to four years, terms shall be staggered as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an even number of council members are elected at large, the half of the elected council members who receive the highest number of votes are elected for four-year terms. The remainder are elected for two-year terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an odd number of council members are elected at large, the majority of the elected council members who receive the highest number of votes are elected for four-year terms. The remainder are elected for two-year terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In case of a tie the mayor and clerk shall determine by lot which council members are elected for four-year terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the council members are elected from wards, the council members elected from the odd-numbered wards are elected for four-year terms and the council members elected from even-numbered wards are elected for two-year terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After July 1, 1986, a petition submitted under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to change the term of council members from two to four years shall specify if the terms are to be staggered or run concurrently. If the petition provides for concurrent terms and the changed term is approved by the voters, }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall not apply and the terms shall be concurrent. If valid petitions for staggered and concurrent terms are submitted, the first filed shall govern.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71081, 1084, 1091, 1093, 1106; C73, \'a7390, 511, 514, 518, 521, 535; C97, \'a7646 \u8211\'3f 649; S13, \'a7646 \u8211\'3f 649; SS15, \'a71056-b3; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5632, 6625, 6626;}}}{ C46, 50, \'a7363.10, 419.11, 419.12; C54, 58, 62, 66, 71, 73, \'a7363.9, 363.10, 363.28; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1224, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1134, \'a7105, 115}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1115, \'a767, 71}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a7106}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a739.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nominations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Candidates for elective city offices must be nominated as provided in }{{\f5\fs18\hyphpar0\qj{sections 376.4 through 376.9}}}{, unless by ordinance a city chooses the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 44}}}{ or }{{\f5\fs18\hyphpar0\qj{45}}}{. However, a city acting under a special charter in 1973 and having a population of over fifty thousand shall continue to hold partisan elections as provided in }{{\f5\fs18\hyphpar0\qj{sections 43.112 through 43.118}}}{ and }{{\f5\fs18\hyphpar0\qj{sections 420.126 through 420.137}}}{, unless the city by election as provided in }{{\f5\fs18\hyphpar0\qj{section 43.112}}}{ chooses to conduct city elections under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or }{{\f5\fs18\hyphpar0\qj{chapter 44}}}{ or }{{\f5\fs18\hyphpar0\qj{45}}}{. The choice of one of these options by such a special charter city does not otherwise affect the validity of the city\u8217\'3fs charter. However, special charter cities which choose to exercise the option to conduct nonpartisan city elections may choose, in the same manner the original decision was made, to resume holding city elections on a partisan basis.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71056-a21; SS15, \'a71056-b4; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6492, 6496, 6634, 6638;}}}{ C46, 50, \'a7416.16, 416.20, 419.20, 419.24; C54, 58, 62, 66, 71, 73, \'a7363.11, 363.16; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.3}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1097, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1063, \'a7203}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a761}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Candidacy }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ nomination petition signature requirements }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ withdrawals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An eligible elector of a city may become a candidate for an elective city office by filing with the county commissioner of elections responsible under }}}{{\f5\fs18\hyphpar0\qj{section 47.2}}}{{\f5\fs18\hyphpar0\qj{ for conducting elections held for the city a valid petition requesting that the elector\u8217\'3fs name be placed on the ballot for that office, or by filing a valid petition with the designated city clerk. The petition must be filed not more than seventy-one days and not less than forty-seven days before the date of the election, and must be signed by eligible electors equal in number to at least two percent of those who voted to fill the same office at the last regular city election, but not less than ten persons. However, for those cities which may be required to hold a primary election, the petition must be filed not more than eighty-five days and not less than sixty-eight days before the date of the regular city election. Nomination petitions shall be filed not later than 5:00 p.m. on the last day for filing.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petitioners for an individual seeking election from a ward must be residents of the ward at the time of signing the petition. An individual is not eligible for election from a ward unless the individual is a resident of the ward at the time the individual files the petition and at the time of election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county commissioner may designate the city clerk of a city to receive nomination papers for elective city offices. If so designated, the city clerk shall have all the duties of the county commissioner provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition must include space for the signatures of the petitioners, a statement of their place of residence, and the date on which they signed the petition. A person may sign nomination petitions for more than one candidate for the same office, and the signature is not invalid solely because the person signed nomination petitions for one or more other candidates for the office.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition must include the affidavit of the individual for whom it is filed, stating the individual\u8217\'3fs name, the individual\u8217\'3fs residence, that the individual is a candidate and eligible for the office, and that if elected the individual will qualify for the office. The affidavit shall also state that the candidate is aware that the candidate is disqualified from holding office if the candidate has been convicted of a felony or other infamous crime and the candidate\u8217\'3fs rights have not been restored by the governor or by the president of the United States.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{On the final date for filing nomination papers the office of the county commissioner and the office of the city clerk designated pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall remain open until 5:00 p.m.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county commissioner or the city clerk designated pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall review each petition and affidavit of candidacy for completeness following the standards in }}}{{\f5\fs18\hyphpar0\qj{section 45.5}}}{{\f5\fs18\hyphpar0\qj{ and shall accept the petition for filing if on its face it appears to have the requisite number of signatures and if it is timely filed. The county commissioner or the designated city clerk shall note upon each petition and affidavit accepted for filing the date and time that they were filed. The county commissioner or the designated city clerk shall return any rejected nomination papers to the person on whose behalf the nomination papers were filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nomination papers filed with the county commissioner or the city clerk designated pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be available for public inspection.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The city clerk shall deliver the text of any public measure being submitted by the city council to the electorate to the county commissioner of elections. If the county commissioner has designated the city clerk to receive nomination papers for elective city offices pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the city clerk shall deliver the nomination papers accepted for filing to the county commissioner. The text of any public measure and nomination papers required to be delivered under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be delivered no later than the day after the last day on which nomination petitions can be filed, and not later than 12:00 noon on that day.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person on whose behalf nomination petitions have been filed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may withdraw as a candidate by filing a signed statement to that effect as prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 44.9}}}{{\f5\fs18\hyphpar0\qj{. Objections to the legal sufficiency of petitions shall be filed in accordance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 44.4}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{44.5}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{44.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71056-a21, -a40; SS15, \'a71056-b4; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6478, 6495 \u8211\'3f 6498, 6634 \u8211\'3f 6638;}}}{ C46, 50, \'a7416.2, 416.19 \u8211\'3f 416.22, 419.20 \u8211\'3f 419.24; C54, 58, 62, 66, 71, 73, \'a7363.11 \u8211\'3f 363.16; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1224, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 221, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1119, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 136, \'a772}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1238, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1180, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 170, \'a791}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1052, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 57, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1033, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1101, \'a79, 10}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1062, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a749.31}}}{{\f5\fs12\hyphpar0\qj{, 69.12}}}{{\f5\fs12\hyphpar0\qj{, 372.13}}}{{\f5\fs12\hyphpar0\qj{, 376.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.4A}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Change to direct election of mayor \u8212\'3f nomination petition signature requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If there is a change in government pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 372.6, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, the number of signatures required on a nomination petition for the office of mayor for the first election that office is on the ballot shall be an amount equal to the product of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total number of votes cast for at-large city council offices at the last regular city election divided by the number of city council seats to be filled at the last regular city election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Two hundredths.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the product of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, is less than ten, the required number of signatures is ten.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 18, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7372.13}}}{{\f5\fs12\hyphpar0\qj{, 376.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Publication of ballot.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notice for each regular, special, primary, or runoff city election shall be published by the county commissioner of elections as provided in }{{\f5\fs18\hyphpar0\qj{section 362.3}}}{, except that notice of a regular, primary, or runoff election may be published not less than four days before the date of the election. The published notice must list the names of all candidates, and must not contain any party designations. The published notice must include any question to be submitted to the voters. The notice may contain one or more facsimiles of the portion of the ballot containing the first arrangement of candidates as prescribed by }{{\f5\fs18\hyphpar0\qj{section 49.31, subsection 2}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71056-a21; SS15, \'a71056-b4; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6499, 6500, 6501, 6503, 6640;}}}{ C46, 50, \'a7416.23 \u8211\'3f 416.25, 416.27, 419.26; C58, 62, 66, 71, 73, \'a7363.19; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2019 Acts, ch 148, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 147, \'a751, 54}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a798}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7372.13}}}{{\f5\fs12\hyphpar0\qj{, 376.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Primary or other method of nomination \u8212\'3f certification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual for whom a valid petition is filed becomes a candidate in the regular city election for the office for which the individual has filed, except that a primary election must be held for offices for which the number of individuals for whom valid petitions are filed is more than twice the number of positions to be filled. However:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The council may by ordinance choose to have a runoff election, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 376.9}}}{{\f5\fs18\hyphpar0\qj{, in lieu of a primary election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the council has by ordinance chosen to have nominations made in the manner provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 44}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{45}}}{{\f5\fs18\hyphpar0\qj{, neither a primary election nor a runoff election is required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each city clerk shall certify to the city\u8217\'3fs controlling commissioner of elections under }}}{{\f5\fs18\hyphpar0\qj{section 47.2}}}{{\f5\fs18\hyphpar0\qj{ the type of nomination process to be used for the city no later than ninety days before the date of the regular city election. If the city has by ordinance chosen a runoff election or has chosen to have nominations made in the manner provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 44}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{45}}}{{\f5\fs18\hyphpar0\qj{, or has repealed nomination provisions under those sections in preference for the primary election method, a copy of the city ordinance shall be attached. No changes in the method of nomination to be used in a city shall be made after the clerk has filed the certification with the commissioner, unless the change will not take effect until after the next regular city election.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71056-a21; SS15, \'a71056-b4; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6492, 6510, 6638;}}}{ C46, 50, \'a7416.16, 416.34, 419.24; C54, 58, 62, 66, 71, 73, \'a7363.16, 363.18; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1119, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1134, \'a7106, 115}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 155, \'a741, 44}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7372.13}}}{{\f5\fs12\hyphpar0\qj{, 376.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Date of primary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a primary election is necessary, it shall be held on the Tuesday four weeks before the date of the regular city election. For each office on the ballot, a voter shall only vote for the number of persons to be elected to that office at the regular city election. The county board of supervisors shall publicly canvass the tally lists of the vote cast in the primary election, following the procedures prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 50.24}}}{{\f5\fs18\hyphpar0\qj{, at a meeting to be held on the second day following the primary election, and beginning no earlier than 1:00 p.m. on that day.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The names of those candidates who receive the highest number of votes for each office on the primary election ballot, to the extent of twice the number of unfilled positions, must be placed on the ballot for the regular city election as candidates for that office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the city holding a primary election is located in more than one county, the controlling commissioner for that city under }}}{{\f5\fs18\hyphpar0\qj{section 47.2, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, shall conduct a second canvass on the first Monday or Tuesday after the day of the election. However, if a recount is requested pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.48}}}{{\f5\fs18\hyphpar0\qj{, the controlling commissioner shall conduct the second canvass within two business days after the conclusion of the recount proceeding. Each commissioner conducting a canvass for the city pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.24, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall transmit abstracts for the offices of that city to the controlling commissioner for that city, along with individual tallies for each write-in candidate. At the second canvass, the county board of supervisors of the county of the controlling commissioner shall canvass the abstracts received pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and shall prepare a combined city abstract stating the number of votes cast in the city for each office. The combined city abstract shall further indicate the name of each person who received votes for each office on the ballot, and the number of votes each person received for that office. The votes of all write-in candidates who each received less than five percent of the total votes cast in the city for an office shall be reported collectively under the heading \u8220\'3fscattering\u8221\'3f.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71056-a21; SS15, \'a71056-b5; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6493, 6507, 6643;}}}{ C46, 50, \'a7416.17, 416.31, 419.29; C54, 58, 62, 66, 71, 73, \'a7363.17, 363.24; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1224, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1033, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 148, \'a759}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a750.48}}}{{\f5\fs12\hyphpar0\qj{, 331.383}}}{{\f5\fs12\hyphpar0\qj{, 372.13}}}{{\f5\fs12\hyphpar0\qj{, 376.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons elected in city elections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a regular city election following a city primary, the candidates receiving the greatest number of votes cast for each office on the ballot are elected, to the extent necessary to fill the positions open.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a regular city election held for a city where the council has chosen a runoff election in lieu of a primary, candidates are elected as provided by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, except that no candidate is elected who fails to receive a majority of the votes cast for the office in question. In the case of at-large elections to a multimember body, a majority is one vote more than half the quotient found by dividing the total number of votes cast for all candidates for that body by the number of positions to be filled. In calculating the number of votes necessary to constitute a majority, fractions shall be rounded up to the next higher whole number.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a regular city election held for a city where the council has chosen to have nominations made in the manner provided by }}}{{\f5\fs18\hyphpar0\qj{chapter 44}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{45}}}{{\f5\fs18\hyphpar0\qj{, the candidates who receive the greatest number of votes for each office on the ballot are elected, to the extent necessary to fill the positions open.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71056-a21; SS15, \'a71056-b4; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6492, 6638;}}}{ C46, 50, \'a7416.16, 419.24; C54, 58, 62, 66, 71, 73, \'a7363.16; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1119, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7153}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7372.13}}}{{\f5\fs12\hyphpar0\qj{, 376.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Runoff election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A runoff election may be held only for positions unfilled because of failure of a sufficient number of candidates to receive a majority vote in the regular city election. When a council has chosen a runoff election in lieu of a primary, the county board of supervisors shall publicly canvass the tally lists of the vote cast in the regular city election, following the procedures prescribed in }}}{{\f5\fs18\hyphpar0\qj{section 50.24}}}{{\f5\fs18\hyphpar0\qj{. Candidates who do not receive a majority of the votes cast for an office, but who receive the highest number of votes cast for that office in the regular city election, to the extent of twice the number of unfilled positions, are candidates in the runoff election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Runoff elections shall be held four weeks after the date of the regular city election and shall be conducted in the same manner as regular city elections, except that the county board of supervisors required to canvass the vote of the runoff election pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.24}}}{{\f5\fs18\hyphpar0\qj{ shall meet to canvass the vote on the Thursday following the runoff election.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a city that is located in more than one county, the county board of supervisors conducting the canvass under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall transmit abstracts for the offices and public measures of that city, along with individual tallies for each write-in candidate, to the city\u8217\'3fs controlling commissioner under }}}{{\f5\fs18\hyphpar0\qj{section 47.2}}}{{\f5\fs18\hyphpar0\qj{ within twenty-four hours of completing the canvass. The county board of supervisors of the county of the controlling commissioner shall canvass the abstracts received pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ on the first Monday or the first Tuesday after the day of the runoff election and shall proceed as provided in }}}{{\f5\fs18\hyphpar0\qj{section 50.24, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Candidates in the runoff election who receive the highest number of votes cast for each office on the ballot are elected to the extent necessary to fill the positions open.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, \'a7363.16; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1224, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1033, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 155, \'a742, 44}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 148, \'a760}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a750.48}}}{{\f5\fs12\hyphpar0\qj{, 331.383}}}{{\f5\fs12\hyphpar0\qj{, 372.13}}}{{\f5\fs12\hyphpar0\qj{, 376.3}}}{{\f5\fs12\hyphpar0\qj{, 376.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A nomination or election to a city office may be contested in the manner provided in }{{\f5\fs18\hyphpar0\qj{chapter 62}}}{ for contesting elections to county offices, except that a statement of intent to contest must be filed with the city clerk within ten days after the nomination or election.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a7678, 679; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5629;}}}{ C46, 50, \'a7363.7; C54, 58, 62, 66, 71, 73, \'a7363.22; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 170, \'a792}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7372.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{376.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Write-in votes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Write-in votes are permitted to be cast in all elections for city offices. A person who receives a sufficient number of write-in votes to be elected to a city office shall be declared the winner of the election. If the result is a tie vote, lots shall be drawn pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.44}}}{{\f5\fs18\hyphpar0\qj{. If a person who was elected by write-in votes chooses not to serve in that office, the person shall submit a resignation in writing to the city clerk not later than 5:00 p.m. on the tenth day following the canvass of the election. If a person who was elected by write-in votes resigns at a later time, the office shall be considered vacant at the end of the term and the council shall fill the vacancy pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 372.13, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except in cities where the council has chosen a runoff election in lieu of a primary, following the resignation of a person who was elected by write-in votes, the city clerk shall notify the person who received the next highest number of votes cast for the office that the person may assume the office. If there is more than one person who received the next highest number of votes cast for the office, lots shall be drawn pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 50.44}}}{{\f5\fs18\hyphpar0\qj{ to determine the person who received the next highest number of votes. If the person accepts the position, the person shall be considered the duly elected officer unless, within ten days after the clerk has given notice, a petition requesting a special election is filed by eligible electors of the city equal in number to twenty-five percent of the number of persons who voted for the office at the election. If the person declines, the person shall do so in writing to the city clerk within ten days and the office shall be considered vacant at the end of the term. The vacancy shall be filled pursuant to the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 372.13, subsection 2}}}{{\f5\fs18\hyphpar0\qj{. If the council chooses to appoint, the appointment may be made before the end of the current term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In city primary elections any person who receives write-in votes shall execute an affidavit in substantially the form required by }}}{{\f5\fs18\hyphpar0\qj{section 45.3}}}{{\f5\fs18\hyphpar0\qj{, and file it with the county commissioner of elections not later than 5:00 p.m. on the day after the canvass of the primary election. If any person who received write-in votes fails to file the affidavit at the time required, the county commissioner shall disregard the write-in votes cast for that person. A notation shall be made on the abstract of votes showing which persons who received write-in votes filed affidavits. The total number of votes cast for each office on the ballot shall be amended by subtracting the write-in votes of those candidates who failed to file the affidavit. It is not necessary for a candidate whose name was printed upon the ballot to file an affidavit. Of the remaining candidates, those who receive the highest number of votes to the extent of twice the number of unfilled positions shall be placed on the ballot for the regular city election as candidates for that office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In cities in which the city council has chosen a runoff election in lieu of a primary, if a person who was elected by write-in votes chooses not to accept the office by filing a resignation notice with the commissioner of elections not later than 5:00 p.m. on the day following the canvass, all remaining persons who received write-in votes and who wish to be considered candidates for the runoff election shall execute an affidavit in substantially the form required by }}}{{\f5\fs18\hyphpar0\qj{section 45.3}}}{{\f5\fs18\hyphpar0\qj{ and file it with the county commissioner not later than 5:00 p.m. of the fourth day following the canvass. If a person receiving write-in votes fails to file the affidavit at the time required, the county commissioner of elections shall disregard the write-in votes cast for that person. The abstract of votes shall be amended to show that the person who was declared elected declined the office and a notation shall be made next to the names of those persons who did not file the affidavit. A runoff election shall be held with the remaining candidates who have the highest number of votes to the extent of twice the number of unfilled positions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a city in which the council has chosen a runoff election, if no person was declared elected for an office, all persons who received write-in votes shall execute an affidavit in substantially the form required by }}}{{\f5\fs18\hyphpar0\qj{section 45.3}}}{{\f5\fs18\hyphpar0\qj{ and file it with the county commissioner of elections not later than 5:00 p.m. on the day following the canvass of votes. If any person who received write-in votes fails to file the affidavit, the county commissioner of elections shall disregard the write-in votes cast for that person. The abstract of votes shall be amended to note which of the write-in candidates failed to file the affidavit. A runoff election shall be held with the remaining candidates who have the highest number of votes to the extent of twice the number of unfilled positions.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7376.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1119, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 59, \'a718, 19}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1033, \'a754}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1101, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7372.13}}}\par}}