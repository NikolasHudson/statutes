\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F28F}{\*\bkmkend codeChapter_5F28F}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 28F}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{JOINT FINANCING OF PUBLIC WORKS AND FACILITIES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a716.151}}}{{\f5\fs12\qc{, 28G.5}}}{{\f5\fs12\qc{, 389.4}}}{{\f5\fs12\qc{, 390.9}}}{{\f5\fs12\qc{, 390.10}}}{{\f5\fs12\qc{, 390.11}}}{{\f5\fs12\qc{, 390.12}}}{{\f5\fs12\qc{, 418.1}}}{{\f5\fs12\qc{, 418.4}}}{{\f5\fs12\qc{, 418.14}}}{{\f5\fs12\qc{, 418.15}}}{{\f5\fs12\qc{, 427.1(2)}}}{{\f5\fs12\qc{, 437A.3}}}{{\f5\fs12\qc{, 437A.6}}}{{\f5\fs12\qc{, 437A.7}}}{{\f5\fs12\qc{, 437A.15}}}{{\f5\fs12\qc{, 476.1B}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope of chapter \u8212\'3f limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ provides a means for the joint financing by public agencies of works or facilities useful and necessary for the collection, treatment, purification, and disposal in a sanitary manner of liquid and solid waste, sewage, and industrial waste, facilities used for the conversion of solid waste to energy, gasworks and facilities useful for the delivery of natural gas service, and also electric power facilities constructed within the state of Iowa, except that hydroelectric power facilities may also be located in the waters and on the dams of or on land adjacent to either side of the Mississippi or Missouri river bordering the state of Iowa, water supply systems, swimming pools or golf courses. }}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ applies to the acquisition, construction, reconstruction, ownership, operation, repair, extension, or improvement of such works or facilities, by a separate administrative or legal entity created pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 389}}}{{\f5\fs18\hyphpar0\qj{. When the legal entity created under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is comprised solely of cities, counties, and sanitary districts established under }}}{{\f5\fs18\hyphpar0\qj{chapter 358}}}{{\f5\fs18\hyphpar0\qj{, or any combination thereof or any combination of the foregoing with other public agencies, the entity shall be both a corporation and a political subdivision with the name under which it was organized. The legal entity may sue and be sued, contract, acquire and hold real and personal property necessary for corporate purposes, adopt a corporate seal and alter the seal at pleasure, and execute all the powers conferred in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city shall not join an entity created under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ for the purpose of financing electric power facilities unless that city had established a municipal electric utility as of July 1, 1984. Power supplied by a municipal power agency shall not be furnished to a municipal utility not existing as of July 1, 1984.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a728F.1}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 31, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 127, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 78, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 225, \'a7402}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 168, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1018, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1135, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728F.2}}}{{\f5\fs12\hyphpar0\qj{, 28F.3}}}{{\f5\fs12\hyphpar0\qj{, 28F.13}}}{{\f5\fs12\hyphpar0\qj{, 28F.14}}}{{\f5\fs12\hyphpar0\qj{, 389.3}}}{{\f5\fs12\hyphpar0\qj{, 390.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectric power agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an entity financing or acquiring electric power facilities pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProject\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fprojects\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any works or facilities referred to in }}}{{\f5\fs18\hyphpar0\qj{section 28F.1}}}{{\f5\fs18\hyphpar0\qj{ and shall include all property real and personal, pertinent thereto or connected with such project or projects, and the existing works or facilities, if any, to which such project or projects are an extension, addition, betterment, or improvement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPublic agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fprivate agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall have the meanings prescribed by }}}{{\f5\fs18\hyphpar0\qj{section 28E.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a728F.2}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 31, \'a77}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, 1st Ex, ch 4, \'a73, 36}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1018, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a712C.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Electric power agencies, see also }{{\f5\fs12\hyphpar0\qj{chapter 390}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revenue bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An entity created to carry out an agreement authorizing the joint exercise of those governmental powers enumerated in }{{\f5\fs18\hyphpar0\qj{section 28F.1}}}{ shall have power to construct, acquire, own, repair, improve, expand, operate and maintain a project or projects necessary to carry out the purposes of such agreement, and to issue from time to time revenue bonds payable from the revenues derived from such project or projects, or any combination of such projects, to finance the cost or part of the cost of the acquisition, construction, reconstruction, repair, extension or improvement of such project or projects, including the acquisition for the purposes of such agreement, of any property, real or personal or mixed therefor. The power of the entity to issue revenue bonds shall not be exercised until authorized by resolution duly adopted by each of the public agencies participating in such agreement. Public agencies participating in such an agreement may not withdraw or in any way terminate, amend, or modify in any manner to the detriment of the bondholders said agreement if revenue bonds or obligations issued in anticipation of the issuance of said revenue bonds have been issued and are then outstanding and unpaid as provided for herein. Any revenue bonds for the payment and discharge of which, upon maturity or upon redemption prior to maturity, provision has been made through the setting apart in a reserve fund or special trust account created pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to insure the payment thereof, of moneys sufficient for that purpose or through the irrevocable segregation for that purpose in a sinking fund or other fund or trust account of moneys sufficient therefor, shall be deemed to be no longer outstanding and unpaid within the meaning of any provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a728F.3}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728F.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Use of proceeds \u8212\'3f negotiability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Revenue bonds may be issued, as provided in }{{\f5\fs18\hyphpar0\qj{section 28F.3}}}{, to provide all or any part of the funds required to finance the cost of the acquisition, construction, reconstruction, repair, extension or improvement of any project or projects or other purposes authorized under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and such cost shall include, but shall not be limited to, administrative expenses, acquisition and construction costs, engineering, fiscal or financial and legal expenses, surveys, plans and specifications, interest during such construction, reconstruction, repair, extension or improvement or acquisition and for one year after completion of such construction, reconstruction, repair, extension or improvement or after acquisition of the project or projects, initial reserve funds, acquisition of real or personal property, including franchises, and such other costs as are necessary and incidental to the construction, reconstruction, repair, extension or improvement, or acquisition of such project or projects and the financing thereof. Such an entity shall have the power to retain and enter into agreements with engineers, fiscal agents, financial advisers, attorneys, architects or other consultants or advisers for planning, supervision and financing of such project or projects upon such terms and conditions as shall be deemed advisable and in the best interest of the entity. Bonds issued under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are declared to be investment securities under the laws of the state of Iowa.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a728F.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Source of payment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ rates and charges, pledge of revenues.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity shall have the power to pledge all or part of the net revenues of a project or projects to the payment of the principal of and interest on the bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and shall provide by resolution authorizing the issuance of said bonds that such net revenues of the project or projects shall be set apart in a sinking fund for that purpose and kept separate and distinct from all other revenues of the entity. The principal of and interest on the bonds so issued shall be secured by a pledge of such net revenues of the project or projects in the manner and to the extent provided in the resolution authorizing the issuance of said bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity shall have the power to fix, establish and maintain such rates, tolls, fees, rentals or other charges and collect the same from the public agencies participating in the agreement or from private agencies or persons for the payment of the services and facilities provided by said project or projects. Such rates, tolls, fees, rentals or other charges shall be so fixed, established and maintained and revised from time to time whenever necessary as will always provide revenues sufficient to pay the cost of maintaining, repairing and operating the project or projects, to pay the principal of and interest on the bonds then outstanding which are payable therefrom as the same become due and payable, to provide adequate and sufficient reserves therefor, to provide for replacements, depreciations and necessary extensions and enlargements and to provide a margin of safety for the making of such payments and providing such reserves. Notwithstanding the foregoing such an entity shall have the further right to pledge to the payment of the bonds issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, in addition to the net revenues of the project or projects pledged therefor, such other moneys that it may have and which are lawfully available therefor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to pay the rates, tolls, fees, rentals or other charges levied against a public agency by an entity for the payment of the services and facilities provided by a project or projects authorized by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, public agencies participating in such an agreement shall have the power by ordinance to fix, establish and maintain, rates or other charges for the use of and the services and facilities rendered by said project or projects. Such rates or charges may be so fixed, established and maintained and revised from time to time whenever necessary as will always provide such public agencies with sufficient revenue to pay the rates, tolls, fees, rentals or other charges levied against it by the entity for the payments of the services and facilities provided by said project or projects. All such rates or charges to be paid by the owners of real property, if not paid as by the ordinance provided, when due, shall constitute a lien upon such real property served by such project or projects, and shall be collected in the same manner as general taxes.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a728F.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 29, \'a721}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728F.6}}}{{\f5\fs12\hyphpar0\qj{, 390.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Collection of taxes, see }{{\f5\fs12\hyphpar0\qj{chapter 445}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bonds not debts of the public agencies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The principal of and interest on the bonds issued by an entity under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be payable solely from and secured by the net revenues of the project or projects and from other funds of the entity lawfully available therefor as provided in }{{\f5\fs18\hyphpar0\qj{section 28F.5}}}{ and said bonds shall not in any respect be a general obligation of any public agency participating in said entity nor shall the entity or any public agency participating in said entity be in any manner liable by reason of such net revenues or other funds being insufficient to pay said bonds. All bonds issued by the entity shall contain a recital on their face that neither the payment of the principal nor any part thereof nor any interest thereon constitutes a debt, liability or obligation of any of the public agencies participating in the agreement creating such entity or of the entity itself, except that the entity shall be liable for the payment of such bonds from the net revenues derived from the project or projects and from the other moneys lawfully available therefor and pledged thereto pursuant to the provisions of the resolution which authorized their issuance. Said bonds issued by the entity shall be authorized by resolution which may be adopted at the same meeting at which it was introduced by a majority of the members of the governing body of the entity. The terms, conditions and provisions for the authorization, issuance, sale, and security of said bonds and of the holders thereof shall be set forth in said resolution.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a728F.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Construction and operation of project.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entity shall operate, maintain and preserve a project in good repair and working order, and shall construct and operate the project in an efficient and economical manner, provided that the entity may lease or rent a project or any part of a project, or otherwise provide for the construction and operation of a project or any part of a project in the manner and upon the terms as the governing body of the entity directs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The electric light and power plant and system of any public agency participating in and receiving wholesale power from electric power facilities owned, operated, or financed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall meet the standards of the national electric safety code of 1968, as amended to and including January 1, 1981, of the national fire protection association.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a728F.7}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 31, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Details of revenue bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Revenue bonds issued pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall bear interest at rates not exceeding those permitted by }{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{ for revenue bonds issued by a city, may be in one or more series, may bear dates, may mature at times not exceeding forty years from their respective dates, may be payable in a medium of payment, at places within the state, may carry registration privileges, may be subject to terms of prior redemption, with or without premium, may be executed in the manner, may contain terms, covenants and conditions, may be sold at public or private sale in the manner and on terms provided by the entity or may be exchanged for outstanding interim notes, and may be in a form otherwise, as the resolution or subsequent resolutions provide.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a728F.8}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 31, \'a73}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Issuance of interim notes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The entity may borrow money for the purposes for which bonds may be issued, in anticipation of the receipt of the proceeds of the sale of bonds. Notes shall be issued for moneys borrowed under }{{\f5\fs18\hyphpar0\qj{this section}}}{, and the notes may be renewed. The notes shall be authorized by resolution of the governing body of the entity and may be issued in denominations, bear interest at rates not exceeding the maximum rate of interest permitted by }{{\f5\fs18\hyphpar0\qj{chapter 74A}}}{ for pledge orders issued by a city, shall be in a form and shall be executed in a manner, all as the entity prescribes. If the notes are renewal notes, they may be exchanged for notes then outstanding on terms the governing body of the entity determines. Notes may be sold at public or private sale or may be issued to persons furnishing materials and services constituting a part of the cost of the acquisition, construction, reconstruction, repair, extension or improvement of a project. The governing body of the entity may retire any notes from the revenues derived from the project or from other moneys of the entity which are lawfully available for that purpose or from a combination of each, in lieu of retiring them by means of bond proceeds.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a728F.9}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 31, \'a74}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Refunding bonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Refunding bonds may be issued by an entity in a principal amount sufficient to provide funds for the payment, including premium, if any, of bonds issued by the entity pursuant to the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to be refunded thereby and the interest thereon and in addition for the payment of all expenses incident to the calling, retiring, or paying of such outstanding bonds to be refunded. Refunding bonds may also finance the construction of a project or projects authorized by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or the improvement, addition, betterment or extension of an existing project or projects so authorized. Refunding bonds shall not be issued to refund the principal of and interest on any bonds to be refunded unless such bonds mature or are redeemable under their terms within ten years from the date of delivery of the refunding bonds. The proceeds of the refunding bonds to be used for the payment of the principal of, interest on and redemption premiums, if any, on the bonds to be refunded which will not be due and payable immediately shall be deposited in trust for the sole purpose of making such payments in a bank or trust company within the state. Any moneys in such trust fund, prior to the date such funds will be needed for the payment of such principal of, interest on and redemption premiums, if any, of such outstanding bonds to be refunded, may be invested or reinvested as provided in the resolution authorizing the refunding bonds. Refunding bonds shall be issued in the same manner and detail as revenue bonds herein authorized.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a728F.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1011, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 29, \'a722}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Eminent domain.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any public agency participating in an agreement authorizing the joint exercise of governmental powers pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may exercise its power of eminent domain to acquire interests in property, under provisions of law then in effect and applicable to the public agency, for the use of the entity created to carry out the agreement, provided that the power of eminent domain is not used to acquire interests in property which is part of a system of facilities in existence, under construction, or planned, for the generation, transmission or sale of electric power, or for the transmission, transportation, or sale of natural gas. In the exercise of the power of eminent domain, the public agency shall proceed in the manner provided by }{{\f5\fs18\hyphpar0\qj{chapter 6B}}}{. Any interests in property acquired are acquired for a public purpose, as defined in }{{\f5\fs18\hyphpar0\qj{chapter 6A}}}{, of the condemning public agency, and the payment of the costs of the acquisition may be made pursuant to the agreement or to any separate agreement between the public agency and the entity or the other public agencies participating in the entity or any of them. Upon payment of costs, any property acquired is the property of the entity.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a728F.11}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 31, \'a75}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, 1st Ex, ch 1001, \'a728, 49}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1135, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728F.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.12}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional powers of the entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the entity is comprised solely of cities, counties, and sanitary districts established under }}}{{\f5\fs18\hyphpar0\qj{chapter 358}}}{{\f5\fs18\hyphpar0\qj{, or any combination thereof, the entity shall have in addition to all the powers enumerated in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the powers that a county has with respect to solid waste disposal projects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the entity is comprised solely of cities, counties, and sanitary districts established under }}}{{\f5\fs18\hyphpar0\qj{chapter 358}}}{{\f5\fs18\hyphpar0\qj{, or any combination thereof, it is a governmental entity with respect to projects undertaken pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 418}}}{{\f5\fs18\hyphpar0\qj{ and may exercise all of the powers of a governmental entity under that chapter in connection with a flood mitigation project. Unless otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 418}}}{{\f5\fs18\hyphpar0\qj{, if the entity is undertaking a flood mitigation project as a governmental entity under }}}{{\f5\fs18\hyphpar0\qj{chapter 418}}}{{\f5\fs18\hyphpar0\qj{, the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 418}}}{{\f5\fs18\hyphpar0\qj{ shall prevail over any conflicting provision in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81}}}{, }{{\f5\fs18\hyphpar0\qj{S81, \'a728F.12}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 117, \'a71003}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 120, \'a712, 24, 25}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1073, \'a715}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.13}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Laws applicable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An entity created to carry out an agreement authorizing the joint exercise of the powers enumerated in }{{\f5\fs18\hyphpar0\qj{section 28F.1}}}{ with regard to electric power facilities shall be subject to the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 21}}}{, relating to open meetings, }{{\f5\fs18\hyphpar0\qj{chapter 22}}}{, relating to the examination of public records, }{{\f5\fs18\hyphpar0\qj{chapter 97B}}}{, relating to the Iowa public employees\u8217\'3f retirement system and }{{\f5\fs18\hyphpar0\qj{chapter 476A}}}{, relating to electric power generators.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[}{{\f5\fs18\hyphpar0\qj{S81, \'a728F.13}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 31, \'a76}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{28F.14}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hydroelectric utilities \u8212\'3f eminent domain \u8212\'3f contracts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhydroelectric utility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an entity comprised of any number of public agencies or entities created to carry out an agreement authorizing the joint exercise of any of the governmental powers enumerated in }}}{{\f5\fs18\hyphpar0\qj{section 28F.1}}}{{\f5\fs18\hyphpar0\qj{, which owns or operates or proposes to own or operate all or part of a hydroelectric power facility or the capacity or use of a hydroelectric power facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to other powers, a hydroelectric utility having complied with }}}{{\f5\fs18\hyphpar0\qj{chapter 469A}}}{{\f5\fs18\hyphpar0\qj{ shall have the power of eminent domain for the purposes of constructing a hydroelectric utility but before exercising the power it shall first exhaust all efforts to secure the necessary voluntary easements. The hydroelectric utility shall comply with provisions of law then in effect, including }}}{{\f5\fs18\hyphpar0\qj{section 28F.11}}}{{\f5\fs18\hyphpar0\qj{, and applicable to those public agencies comprising the hydroelectric utility in connection with the construction of hydroelectric power facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to other powers, the governing body of a hydroelectric utility may purchase all or part of any power plant and may purchase all or part of the capacity, power or energy associated with any power plant owned by, or contract to sell all or part of the hydroelectric utility\u8217\'3fs power and energy including any surplus to, a public agency or private agency or an entity created to carry out an agreement authorizing the joint exercise of any of the governmental powers enumerated in }}}{{\f5\fs18\hyphpar0\qj{section 28F.1}}}{{\f5\fs18\hyphpar0\qj{. Any such entity, public agency, or hydroelectric utility may enter into contracts for the purchase or supply, from any source, of all or a portion of the capacity, power and energy requirements of the entity, public agency or hydroelectric utility on terms and conditions as the governing body of the entity, public agency or hydroelectric utility deems fit, subject to }}}{{\f5\fs18\hyphpar0\qj{section 476.43}}}{{\f5\fs18\hyphpar0\qj{. The terms may include provisions for the payment for capacity or output of a facility whether the facility is completed or operating, and for establishing the rights and obligations of all parties to the contract in the event of default. Payments made by an entity, public agency or hydroelectric utility under contracts constitute operating expenses of the entity, public agency or hydroelectric utility payable from the revenues derived from the electric power plant and systems of the entity, public agency or hydroelectric utility.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 78, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a7121}}}\par}}