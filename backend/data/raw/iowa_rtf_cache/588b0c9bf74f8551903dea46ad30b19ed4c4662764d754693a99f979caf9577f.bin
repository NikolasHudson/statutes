...................}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{25}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{12,500}{{\f5\fs18\hyphpar0\qj{\~\~\~\~}}}{ \u8212\'3f }{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~}}}{14,499.99}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{................................}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{17}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{\~\~}}}{14,500}{{\f5\fs18\hyphpar0\qj{\~\~\~\~}}}{ \u8212\'3f }{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~}}}{16,499.99}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{................................}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{12}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tentative credit for a claimant described in }}}{{\f5\fs18\hyphpar0\qj{section 425.17, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (3), shall be the greater of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of the credit under the schedule specified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ as if the claimant was a claimant as defined in }}}{{\f5\fs18\hyphpar0\qj{section 425.17, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), filing for a credit under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The difference between the actual amount of property taxes due on the homestead during the fiscal year next following the base year minus the actual amount of property taxes due on the homestead during the first fiscal year for which the claimant filed a claim for a credit calculated under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and for which the property taxes due on the homestead were calculated on an assessed valuation that was not a partial assessment and if the claimant has filed for the credit calculated under this paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for each of the subsequent fiscal years after the first credit claimed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The actual credit for property taxes due shall be determined by subtracting from the tentative credit the amount of the homestead credit under }}}{{\f5\fs18\hyphpar0\qj{section 425.1}}}{{\f5\fs18\hyphpar0\qj{ which is allowed as a credit against property taxes due in the fiscal year next following the base year by the claimant or any person of the claimant\u8217\'3fs household. If the subtraction produces a negative amount, there shall be no credit but no refund shall be required. The actual reimbursement for rent constituting property taxes paid shall be equal to the tentative reimbursement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is eligible to file a claim for credit for property taxes due and who has a household income of eight thousand five hundred dollars or less and who has an unpaid special assessment levied against the homestead may file a claim for a special assessment credit with the county treasurer. The department of revenue shall provide to the respective treasurers the forms necessary for the administration of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The claim shall be filed not later than September 30 of each year. Upon the filing of the claim, interest for late payment shall not accrue against the amount of the unpaid special assessment due and payable. The claim filed by the claimant constitutes a claim for credit of an amount equal to the actual amount due upon the unpaid special assessment, plus interest, payable during the fiscal year for which the claim is filed against the homestead of the claimant. However, where the claimant is an individual described in }}}{{\f5\fs18\hyphpar0\qj{section 425.17, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), and the tentative credit is determined according to the schedule in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2), of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the claim filed constitutes a claim for credit of an amount equal to one-half of the actual amount due and payable during the fiscal year. The treasurer shall certify to the director of revenue not later than October 15 of each year the total amount of dollars due for claims allowed. The amount of reimbursement due each county shall be certified by the director of revenue and paid by the director of the department of administrative services by November 15 of each year, drawn upon warrants payable to the respective treasurer. There is appropriated annually from the general fund of the state to the department of revenue an amount sufficient to carry out the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The treasurer shall credit any moneys received from the department of revenue against the amount of the unpaid special assessment due and payable on the homestead of the claimant.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, in computing household income, a person with a total disability shall deduct all medical and necessary care expenses paid during the twelve-month income tax accounting periods used in computing household income which are attributable to the person\u8217\'3fs total disability. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMedical and necessary care expenses\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are those used in computing the federal income tax deduction under section 213 of the Internal Revenue Code as defined in }}}{{\f5\fs18\hyphpar0\qj{section 422.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the base year beginning in the 1999 calendar year and for each subsequent base year, the dollar amounts set forth in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and}}}{{\f5\fs18\hyphpar0\qj{ subsection 3}}}{{\f5\fs18\hyphpar0\qj{ shall be multiplied by the cumulative adjustment factor for that base year. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCumulative adjustment factor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the product of the annual adjustment factor for the 1998 base year and all annual adjustment factors for subsequent base years. The cumulative adjustment factor applies to the base year beginning in the calendar year for which the latest annual adjustment factor has been determined.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual adjustment factor for the 1998 base year is one hundred percent. For each subsequent base year, the annual adjustment factor equals the annual inflation factor for the calendar year, in which the base year begins, as computed in }}}{{\f5\fs18\hyphpar0\qj{section 422.4}}}{{\f5\fs18\hyphpar0\qj{ for purposes of the individual income tax.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cumulative adjustment factor shall be determined annually by the department of revenue.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, \'a7425.1(5); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.23}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 172, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 83 Acts, ch 189, \'a73, 5, 6}}}{{\f5\fs18\hyphpar0\qj{; 84 Acts, ch 1305, \'a735}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1139, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1250, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 267, \'a7524}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1016, \'a713, 42}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{92 Acts, 2nd Ex, ch 1001, \'a7221 \u8211\'3f 223, 225}}}}}}}\par}{\pard\plain\f5\fs18\hyphpa