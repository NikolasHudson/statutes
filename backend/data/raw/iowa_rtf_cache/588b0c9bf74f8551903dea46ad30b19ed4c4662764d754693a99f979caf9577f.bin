\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A veteran of any of the military forces of the United States, who acquired the homestead under }}}{{\f5\fs18\hyphpar0\qj{38 U.S.C. \'a721.801}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{21.802}}}{{\f5\fs18\hyphpar0\qj{, prior to August 6, 1991, or under }}}{{\f5\fs18\hyphpar0\qj{38 U.S.C. \'a72101}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{2102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A veteran as defined in }}}{{\f5\fs18\hyphpar0\qj{section 35.1}}}{{\f5\fs18\hyphpar0\qj{ with a permanent service-connected disability rating of one hundred percent, as certified by the United States department of veterans affairs, or a permanent and total disability rating based on individual unemployability that is compensated at the one hundred percent disability rate, as certified by the United States department of veterans affairs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A former member of the national guard of any state who otherwise meets the service requirements of }}}{{\f5\fs18\hyphpar0\qj{section 35.1, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2) or (7), with a permanent service-connected disability rating of one hundred percent, as certified by the United States department of veterans affairs, or a permanent and total disability rating based on individual unemployability that is compensated at the one hundred percent disability rate, as certified by the United States department of veterans affairs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual who is a surviving spouse or a child and who is receiving dependency and indemnity compensation pursuant to }}}{{\f5\fs18\hyphpar0\qj{38 U.S.C. \'a71301 et seq.}}}{{\f5\fs18\hyphpar0\qj{, as certified by the United States department of veterans affairs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an owner described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the credit allowed shall be continued to the estate of an owner who is deceased or the surviving spouse and any child, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 234.1}}}{{\f5\fs18\hyphpar0\qj{, who are the beneficiaries of a deceased owner, so long as the surviving spouse remains unmarried. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fd\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, is no longer eligible for the credit upon termination of dependency and indemnity compensation under }}}{{\f5\fs18\hyphpar0\qj{38 U.S.C. \'a71301 et seq.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner or a beneficiary of an owner who elects to secure the credit provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is not eligible for any other real property tax exemption provided by law for veterans of military service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an owner acquires a different homestead, the credit allowed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be claimed on the new homestead unless the owner fails to meet the other requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the list of the names and addresses of individuals allowed a credit under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and maintained by the county recorder, county treasurer, county assessor, city assessor, or other government body is confidential information and shall not be disseminated to any person unless otherwise ordered by a court or released by the lawful custodian of the records pursuant to state or federal law. The county recorder, county treasurer, county assessor, city assessor, or other government body responsible for maintaining the names and addresses of individuals allowed a credit under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may display such credit on individual paper records and individual electronic records, including display on an internet site.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request, a county recorder, county assessor, city assessor, or other entity may share information as described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ to a county veterans service officer for purposes of providing information on benefits and services available to veterans and their families.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpermanent and total disability rating based on individual unemployability\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a condition under which a person has either a permanent service-connected disability rating of sixty percent or two or more permanent service-connected disability conditions in which one of the conditions has at least a forty percent rating and the combined rating for all the conditions is at least seventy percent, and the person has an administrative adjustment added to the service-connected disability rating, due to individual unemployability, such that the United States department of veterans affairs rates the veteran permanently and totally disabled for purposes of disability compensation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1250, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1151, \'a716, 36}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1117, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1141, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 6, \'a71 \u8211\'3f 5}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1057, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 41, \'a714, 36}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 148, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}{{\f5\fs12\hyphpar0\qj{,