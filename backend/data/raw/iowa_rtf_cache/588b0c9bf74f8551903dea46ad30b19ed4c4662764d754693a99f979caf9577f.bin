\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F425}{\*\bkmkend codeChapter_5F425}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 425}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{HOMESTEAD TAX CREDITS, EXEMPTIONS, AND REIMBURSEMENT}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a72.48}}}{{\f5\fs12\qc{, 10A.518}}}{{\f5\fs12\qc{, 321.1}}}{{\f5\fs12\qc{, 331.512}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{For requirements relating to state funding of property tax credits, see }{{\f5\fs12\qc{\'a725B.7}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER I}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E2_2E2}{HOMESTEAD TAX CREDITS AND EXEMPTIONS}{\*\bkmkend stylerid1_2E6_2E2_2E2}\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7425.17}}}{{\f5\fs12\qc{, 435.26}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.1}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Homestead credit fund \u8212\'3f apportionment \u8212\'3f payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A homestead credit fund is created. There is appropriated annually from the general fund of the state to the department of revenue to be credited to the homestead credit fund, an amount sufficient to implement }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of administrative services shall issue warrants on the homestead credit fund payable to the county treasurers of the several counties of the state under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The homestead credit fund shall be apportioned each year so as to give a credit against the tax on each eligible homestead in the state in an amount equal to the actual levy on the first four thousand eight hundred fifty dollars of actual value for each homestead.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount due each county shall be paid in two payments on November 15 and March 15 of each fiscal year, drawn upon warrants payable to the respective county treasurers. The two payments shall be as nearly equal as possible.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annually the department of revenue shall certify to the county auditor of each county the credit and its amount in dollars. Each county auditor shall then enter the credit against the tax levied on each eligible homestead in each county payable during the ensuing year, designating on the tax lists the credit as being from the homestead credit fund, and credit shall then be given to the several taxing districts in which eligible homesteads are located in an amount equal to the credits allowed on the taxes of the homesteads. The amount of credits shall be apportioned by each county treasurer to the several taxing districts as provided by law, in the same manner as though the amount of the credit had been paid by the owners of the homesteads. However, the several taxing districts shall not draw the funds so credited until after the semiannual allocations have been received by the county treasurer, as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. Each county treasurer shall show on each tax receipt the amount of credit received from the homestead credit fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the homestead tax credit computed under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is less than sixty-two dollars and fifty cents, the amount of homestead tax credit on that eligible homestead shall be sixty-two dollars and fifty cents subject to the limitation imposed in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The homestead tax credit allowed in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall not exceed the actual amount of taxes payable on the eligible homestead, exclusive of any special assessments levied against the homestead.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76943-f63, -f64; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.100, 6943.142;}}}{ C46, \'a7422.69, 425.1; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.1}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1186, \'a72, 5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 172, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1244, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7258, 286}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 140, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 41, \'a72, 36}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}{{\f5\fs12\hyphpar0\qj{, 216.12}}}{{\f5\fs12\hyphpar0\qj{, 404.3}}}{{\f5\fs12\hyphpar0\qj{, 425.16}}}{{\f5\fs12\hyphpar0\qj{, 425.23}}}{{\f5\fs12\hyphpar0\qj{, 441.21}}}{{\f5\fs12\hyphpar0\qj{, 441.73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.1A}}}{\*\bkmkstart stylerid1_2E6_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Homestead tax exemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following exemptions from taxation shall be allowed in addition to the homestead credit for an owner that has attained the age of sixty-five years by January 1 of the assessment year:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the assessment year beginning January 1, 2023, the eligible homestead, not to exceed three thousand two hundred fifty dollars in taxable value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the assessment year beginning January 1, 2024, and each succeeding assessment year, the eligible homestead, not to exceed six thousand five hundred dollars in taxable value.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 25B.7, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, shall not apply to the property tax exemption provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The list of the names, addresses, and dates of birth of individuals allowed an exemption under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and maintained by the county recorder, county treasurer, county assessor, city assessor, or other governmental body and obtained for purposes of allowing an exemption under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is confidential information and shall not be disseminated to any person unless otherwise ordered by a court or released by the lawful custodian of the records pursuant to state or federal law. The county recorder, county treasurer, county assessor, city assessor, or other governmental body responsible for maintaining the names, addresses, and dates of birth of individuals allowed an exemption under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may display such exemption on individual paper records and individual electronic records, including display on an internet site.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 71, \'a730, 48, 49}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1094, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7425.2}}}{{\f5\fs12\hyphpar0\qj{, 425.16}}}{{\f5\fs12\hyphpar0\qj{, 425.17}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.2}}}{\*\bkmkstart stylerid1_2E6_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Qualifying for credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who wishes to qualify for the homestead credit allowed under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall obtain the appropriate forms for filing for the credit from the assessor. The person claiming the credit shall file a verified statement and designation of homestead with the assessor for the year for which the person is first claiming the credit. The claim shall be filed not later than July 1 of the year for which the person is claiming the credit. A claim filed after July 1 of the year for which the person is claiming the credit shall be considered as a claim filed for the following year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing and allowance of the claim, the claim shall be allowed on that homestead for successive years without further filing as long as the property is legally or equitably owned and used as a homestead by that person or that person\u8217\'3fs spouse on July 1 of each of those successive years, and the owner of the property being claimed as a homestead declares residency in Iowa for purposes of income taxation, and the property is occupied by that person or that person\u8217\'3fs spouse for at least six months in each of those calendar years in which the fiscal year begins. When the property is sold or transferred, the buyer or transferee who wishes to qualify shall refile for the credit. However, when the property is transferred as part of a distribution made pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 598}}}{{\f5\fs18\hyphpar0\qj{, the transferee who is the spouse retaining ownership of the property is not required to refile for the credit. Property divided pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 598}}}{{\f5\fs18\hyphpar0\qj{ shall not be modified following the division of the property. An owner who ceases to use a property for a homestead or intends not to use it as a homestead for at least six months in a calendar year shall provide written notice to the assessor by July 1 following the date on which the use is changed. A person who sells or transfers a homestead or the personal representative of a deceased person who had a homestead at the time of death, shall provide written notice to the assessor that the property is no longer the homestead of the former claimant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In case the owner of the homestead is in active service in the armed forces of this state or of the United States, or is sixty-five years of age or older, or is disabled, the statement and designation may be signed and delivered by any member of the owner\u8217\'3fs family, by the owner\u8217\'3fs guardian or conservator, or by any other person who may represent the owner under power of attorney. If the owner of the homestead is married, the spouse may sign and deliver the statement and designation. The director of health and human services or the director\u8217\'3fs designee may make application for the benefits of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ as the agent for and on behalf of persons receiving assistance under }}}{{\f5\fs18\hyphpar0\qj{chapter 249}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The form for claiming the credit shall also include the ability to claim the exemption under }}}{{\f5\fs18\hyphpar0\qj{section 425.1A}}}{{\f5\fs18\hyphpar0\qj{ for qualified owners. If the claim for the homestead credit is allowed, such allowance shall also include allowance of the homestead exemption if the owner meets the age criteria for the exemption. The homestead exemption shall be allowed for successive years without further filing in the same manner as the homestead credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person sixty-five years of age or older or any person who is disabled may request, in writing, from the appropriate assessor forms for filing for homestead tax credit. Any person sixty-five years of age or older or who is disabled may complete the form, which shall include a statement of homestead, and mail or return it to the appropriate assessor. The signature of the claimant on the statement shall be considered the claimant\u8217\'3fs acknowledgment that all statements and facts entered on the form are correct to the best of the claimant\u8217\'3fs knowledge.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon adoption of a resolution by the county board of supervisors, any person may request, in writing, from the appropriate assessor forms for the filing for homestead tax credit. The person may complete the form, which shall include a statement of homestead, and mail or return it to the appropriate assessor. The signature of the claimant on the statement of homestead shall be considered the claimant\u8217\'3fs acknowledgment that all statements and facts entered on the form are correct to the best of the claimant\u8217\'3fs knowledge.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.143;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.2}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1246, \'a71, 11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 96, \'a7157, 159}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1109, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 198, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1141, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 256, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1087, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a749}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1073, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1143, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 206, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 41, \'a73, 36}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71127}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a731, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}{{\f5\fs12\hyphpar0\qj{, 331.401}}}{{\f5\fs12\hyphpar0\qj{, 425.7}}}{{\f5\fs12\hyphpar0\qj{, 425.11}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4 applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.3}}}{\*\bkmkstart stylerid1_2E6_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Verification of claims for homestead credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assessor shall retain a permanent file of current homestead claims filed in the assessor\u8217\'3fs office. The assessor shall file a notice of transfer of property for which a claim is filed when notice is received from the office of the county recorder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county recorder shall give notice to the assessor of each transfer of title filed in the recorder\u8217\'3fs office. The notice shall describe the property transferred, the name of the person transferring the title to the property, and the name of the person to whom title to the property has been transferred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not later than July 6 of each year, the assessor shall remit the statements and designation of homesteads to the county auditor with the assessor\u8217\'3fs recommendation for allowance or disallowance. If the assessor recommends disallowance of a claim, the assessor shall submit the reasons for the recommendation, in writing, to the county auditor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The county auditor shall forward the claims to the board of supervisors. The board shall allow or disallow the claims. If the board disallows a claim, it shall send written notice, by mail, to the claimant at the claimant\u8217\'3fs last known address. The notice shall state the reasons for disallowing the claim. The board is not required to send notice that a claim is disallowed if the claimant voluntarily withdraws the claim.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.144;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.3}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1246, \'a72, 11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1241, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1144, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 29, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a732, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}{{\f5\fs12\hyphpar0\qj{, 331.401}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 4 applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.4}}}{\*\bkmkstart stylerid1_2E6_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certification to treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All claims which have been allowed by the board of supervisors shall be certified on or before August 1, in each year, by the county auditor to the county treasurer, which certificates shall list the total amount of dollars, listed by taxing district in the county, due for homestead tax exemptions and credits claimed and allowed. The county treasurer shall then certify to the department of revenue the total amount of dollars, listed by taxing district in the county, due for homestead tax credits claimed and allowed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.145;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a733, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}{{\f5\fs12\hyphpar0\qj{, 331.559}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.5}}}{\*\bkmkstart stylerid1_2E6_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Correcting listing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the assessor who last listed and valued a claimed eligible homestead did not, in the description and valuation thereof, comply with the provisions of }{{\f5\fs18\hyphpar0\qj{section 428.7}}}{, the assessor shall, if still in office, on the written request of such claimant and without expense to the claimant or to the county, correct the listing and valuations of such claimed homestead and contiguous real property originally listed and valued by the assessor, and file such corrected listing and valuations with the county auditor, who forthwith shall certify the same to the county treasurer, and said county treasurer shall so correct the tax books; provided, that if the assessor who last listed and valued such property is not still in office, the assessor in office shall, on such written request and at the expense of the county, so correct such listing and valuations of said homestead and said contiguous real property.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.146;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.5}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}{{\f5\fs12\hyphpar0\qj{, 331.559}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.6}}}{\*\bkmkstart stylerid1_2E6_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Waiver by neglect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a person fails to file a claim or to have a claim on file with the assessor for the credits provided in }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{, the person is deemed to have waived the homestead exemption and credit for the year in which the person failed to file the claim or to have a claim on file with the assessor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.147;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.6}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1246, \'a73, 11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 41, \'a74, 36}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a734, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.7}}}{\*\bkmkstart stylerid1_2E6_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeals permitted \u8212\'3f disallowed claims and penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person whose claim is denied under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ may appeal from the action of the board of supervisors to the district court of the county in which said claimed homestead is situated by giving written notice of such appeal to the county auditor of said county within twenty days from the date of mailing of notice of such action by the board of supervisors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event any claim under }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ is allowed, any owner of an eligible homestead may appeal from the action of the board of supervisors to the district court of the county in which said claimed homestead is situated, by giving written notice of such appeal to the county auditor of said county and such notice to the owner of said claimed homestead as a judge of the district court shall direct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department of revenue determines that a claim for homestead exemption and credit has been allowed by the board of supervisors which is not justifiable under the law and not substantiated by proper facts, the department may, at any time within thirty-six months from July 1 of the year in which the claim is allowed, set aside the allowance. Notice of the disallowance shall be given to the county auditor of the county in which the claim has been improperly granted and a written notice of the disallowance shall also be addressed to the claimant at the claimant\u8217\'3fs last known address. The claimant or board of supervisors may appeal to the director of revenue within thirty days from the date of the notice of disallowance. The director shall grant a hearing and if, upon the hearing, the director determines that the disallowance was incorrect, the director shall set aside the disallowance. The director shall notify the claimant and the board of supervisors of the result of the hearing. The claimant or the board of supervisors may seek judicial review of the action of the director of revenue in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a claim is disallowed by the department of revenue and not appealed to the director of revenue or appealed to the director of revenue and thereafter upheld upon final resolution, including any judicial review, any amounts of exemptions allowed and credits allowed and paid from the homestead credit fund including the penalty, if any, become a lien upon the property on which the exemption or credit was originally granted, if still in the hands of the claimant, and not in the hands of a bona fide purchaser, and any amount so erroneously paid including the penalty, if any, shall be collected by the county treasurer in the same manner as other taxes and the collections shall be returned to the department of revenue and credited to the homestead credit fund. The director of revenue may institute legal proceedings against a homestead credit claimant for the collection of payments made on disallowed credits and the penalty, if any. If a person makes a false claim or affidavit with fraudulent intent to obtain the homestead exemption or credit, the person is guilty of a fraudulent practice and the claim shall be disallowed in full. If the credit has been paid, the amount of the credit plus a penalty equal to twenty-five percent of the amount of credit plus interest, at the rate in effect under }}}{{\f5\fs18\hyphpar0\qj{section 421.7}}}{{\f5\fs18\hyphpar0\qj{, from the time of payment shall be collected by the county treasurer in the same manner as other property taxes, penalty, and interest are collected and when collected shall be paid to the director of revenue. If a homestead exemption or credit is disallowed and the claimant failed to give written notice to the assessor as required by }}}{{\f5\fs18\hyphpar0\qj{section 425.2}}}{{\f5\fs18\hyphpar0\qj{ when the property ceased to be used as a homestead by the claimant, a civil penalty equal to five percent of the amount of the disallowed exemption or credit is assessed against the claimant.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.148;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.7}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1246, \'a74, 11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 251, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 158, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 154, \'a71, 6}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1151, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1010, \'a7106}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a7143}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 109, \'a77, 75}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 41, \'a75, 36}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a735, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}{{\f5\fs12\hyphpar0\qj{, 331.559}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fraudulent practices; }{{\f5\fs12\hyphpar0\qj{\'a7714.8 \u8211\'3f 714.14}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 3 applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.8}}}{\*\bkmkstart stylerid1_2E6_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Forms }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of revenue shall prescribe the form for the making of a verified statement and designation of homestead, the form for the supporting affidavits required herein, and such other forms as may be necessary for the proper administration of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. Whenever necessary, the department of revenue shall forward to the county auditors of the several counties in the state the prescribed sample forms, and the county auditors shall furnish blank forms prepared in accordance therewith with the assessment rolls, books, and supplies delivered to the assessors. The department of revenue shall prescribe and the county auditors shall provide on the forms for claiming the homestead credit a statement to the effect that the owner realizes that the owner must give written notice to the assessor when the owner changes the use of the property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of revenue may prescribe rules, not inconsistent with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, necessary to carry out and effectuate its purposes.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.149;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.8}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1246, \'a75, 11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a7104}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a7230}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 41, \'a76, 36}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.9}}}{\*\bkmkstart stylerid1_2E6_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Credits in excess of tax }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ appeals }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ refunds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the amount of credit apportioned to any homestead under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ in any year shall exceed the total tax, exclusive of any special assessments levied against said homestead, then such excess shall be remitted by the county treasurer to the department of revenue to be redeposited in the homestead credit fund and be reallocated the following year by the department as provided in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any claim for exemption or credit has been denied by the board of supervisors, and such action is subsequently reversed on appeal, the exemption or credit shall be allowed on the homestead involved in said appeal, and the director of revenue, the county auditor, and the county treasurer shall make such exemption or credit and change their books and records accordingly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event the appealing taxpayer has paid one or both of the installments of the tax payable in the year or years in question on such homestead valuation, remittance shall be made to such taxpayer of the amount of such credit or exemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount of such credit shall be allocated and paid from the surplus redeposited in the homestead credit fund provided for in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.150;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7135}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 41, \'a77, 36}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a736, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}{{\f5\fs12\hyphpar0\qj{, 331.559}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsections 2 and 3 applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.10}}}{\*\bkmkstart stylerid1_2E6_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reversal of allowed claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In the event any claim is allowed, and subsequently reversed on appeal, any exemption and credit made under the claim shall be void. The amount of the erroneous credit shall be charged against the property in question, and the director of revenue, the county auditor, and the county treasurer are authorized and directed to correct their books and records accordingly. The amount of the erroneous credit, when collected, shall be returned by the county treasurer to the homestead credit fund to be reallocated the following year as provided in }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{. Taxes due following reversal of a claim for an exemption shall be collected by the county treasurer and allocated to the appropriate taxing entities.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.151;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a7136}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 41, \'a78, 36}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a7104}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a737, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}{{\f5\fs12\hyphpar0\qj{, 331.559}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.11}}}{\*\bkmkstart stylerid1_2E6_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ and wherever used in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAssessed valuation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the taxable valuation of the homestead as fixed by the assessor, or by the board of review, under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 441.21}}}{{\f5\fs18\hyphpar0\qj{, without deducting therefrom the exemptions authorized in }}}{{\f5\fs18\hyphpar0\qj{section 426A.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBook\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flist\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecord\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschedule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ kept by a county auditor, assessor, treasurer, recorder, sheriff, or other county officer, unless the context otherwise requires, means the county system as defined in }}}{{\f5\fs18\hyphpar0\qj{section 445.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDwelling house\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall embrace any building occupied wholly or in part by the claimant as a home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHomestead\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall have the following meaning:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The homestead includes the dwelling house which the owner, in good faith, is occupying as a home on July 1 of the year for which the credit is claimed and occupies as a home for at least six months during the calendar year in which the fiscal year begins, except as otherwise provided.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When any person is inducted into active service under the }}}{{\f5\fs18\hyphpar0\qj{Selective Training and Service Act of the United States}}}{{\f5\fs18\hyphpar0\qj{ or whose voluntary entry into active service results in a credit on the quota of persons required for service under the }}}{{\f5\fs18\hyphpar0\qj{Selective Training and Service Act}}}{{\f5\fs18\hyphpar0\qj{, or who, being a member of any component part of the military, naval, or air forces or nurse corps of this state or nation, is called or ordered into active service, such person shall be considered as occupying or living on the homestead during such service and, where equitable or legal title of the homestead is in the spouse of the person who is a member of or is inducted into the armed services of the United States, the spouse shall be considered as occupying or living on the homestead during such service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When any person is confined in a nursing home, extended-care facility, or hospital, such person shall be considered as occupying or living on a homestead where such person is the owner of such homestead and such person maintains such homestead and does not lease, rent, or otherwise receive profits from other persons for the use thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It may contain one or more contiguous lots or tracts of land with the buildings or other appurtenances thereon habitually, and in good faith, used as a part of the homestead.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It must not embrace more than one dwelling house, but where a homestead has more than one dwelling house situated thereon, the exemption and credit provided for in }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{ shall apply to the home and buildings used by the owner, but shall not apply to any other dwelling house and buildings appurtenant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOwner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the person who holds the fee simple title to the homestead. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOwner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also includes the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person occupying as a surviving spouse.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person occupying under a contract of purchase which contract has been recorded in the office of the county recorder of the county in which the property is located.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person occupying the homestead under devise or by operation of the inheritance laws where the whole interest passes or where the divided interest is shared only by persons related or formerly related to each other by blood, marriage, or adoption.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person occupying the homestead is a shareholder of a family farm corporation that owns the property.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person occupying the homestead under a deed which conveys a divided interest where the divided interest is shared only by persons related or formerly related to each other by blood, marriage, or adoption.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(f)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where the person occupying the homestead holds a life estate with the reversion interest held by a nonprofit corporation organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 504}}}{{\f5\fs18\hyphpar0\qj{, provided that the holder of the life estate is liable for and pays property tax on the homestead.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(g)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where the person occupying the homestead holds an interest in a horizontal property regime under }}}{{\f5\fs18\hyphpar0\qj{chapter 499B}}}{{\f5\fs18\hyphpar0\qj{, regardless of whether the underlying land committed to the horizontal property regime is in fee or as a leasehold interest, provided that the holder of the interest in the horizontal property regime is liable for and pays property tax on the homestead.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(h)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where the person occupying the homestead is a member of a community land trust as defined in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a712773}}}{{\f5\fs18\hyphpar0\qj{, regardless of whether the underlying land is in fee or as a leasehold interest, provided that the member of the community land trust is occupying the homestead and is liable for and pays property tax on the homestead.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person occupying the homestead regardless of whether the underlying land is in fee or as a leasehold interest, provided that the person is occupying the homestead and is liable for and pays property tax on the homestead.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{, the word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fowner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to mean a bona fide owner and not one for the purpose only of availing the person of the benefits of }}}{{\f5\fs18\hyphpar0\qj{this subchapter}}}{{\f5\fs18\hyphpar0\qj{. In order to qualify for the homestead tax credit and exemption, evidence of ownership shall be on file in the office of the clerk of the district court or recorded in the office of the county recorder at the time the owner files with the assessor a verified statement of the homestead claimed by the owner as provided in }}}{{\f5\fs18\hyphpar0\qj{section 425.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where not in conflict with the terms of the definitions set out in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 561}}}{{\f5\fs18\hyphpar0\qj{ shall control.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.152;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.11}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1246, \'a76, 11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 256, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1087, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1250, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 97, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1148, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7200, 201}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1049, \'a7191}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7393}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1158, \'a756, 69}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a7166}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 41, \'a79 \u8211\'3f 11, 36}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a738, 39, 48, 49}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 115, \'a745 \u8211\'3f 47}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a791}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 1, paragraph d, subparagraph (3) applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 1, paragraph e applies to claims under chapter 425, subchapter I, for credits against property taxes due and payable in fiscal years beginning on or after July 1, 2024; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 115, \'a747}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.12}}}{\*\bkmkstart stylerid1_2E6_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Indian land.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each forty acres of land, or fraction thereof, occupied by a member or members of the Sac and Fox Indians in Tama county, which land is held in trust by the secretary of the interior of the United States for said Indians, shall be given a homestead tax exemption and credit within the meaning and under the provisions of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{. Application for such homestead tax exemption and credit shall be made to the county auditor of Tama county and may be made by a representative of the tribal council.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.153;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 41, \'a712, 36}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a740, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.13}}}{\*\bkmkstart stylerid1_2E6_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conspiracy to defraud.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any two or more persons conspire and confederate together with fraudulent intent to obtain the exemption or credit provided for under the terms of }{{\f5\fs18\hyphpar0\qj{this subchapter}}}{ by making a false deed, or a false contract of purchase, they are guilty of a fraudulent practice.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6943.154;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7425.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 41, \'a713, 36}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a741, 48, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a725B.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Fraudulent practices, see }{{\f5\fs12\hyphpar0\qj{\'a7714.8 \u8211\'3f 714.14}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{425.14}}}{\*\bkmkstart stylerid1_2E6_2E18_2E2_2E2}{\*\b