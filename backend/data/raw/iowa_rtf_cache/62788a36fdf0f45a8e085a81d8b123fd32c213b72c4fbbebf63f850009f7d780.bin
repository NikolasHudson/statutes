\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F527}{\*\bkmkend codeChapter_5F527}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 527}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{ELECTRONIC TRANSFER OF FUNDS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7524.821}}}{{\f5\fs12\qc{, 524.1204}}}{{\f5\fs12\qc{, 533.301}}}{{\f5\fs12\qc{, 536A.24}}}{{\f5\fs12\qc{, 669.14}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statement of intent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The general assembly declares as its purpose in adopting }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ to provide:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That electronic funds transfer systems should provide reliable service to the consumer with full protection of privacy of personal financial information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That electronic funds transfer systems should not impair the safety and soundness of a person\u8217\'3fs funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That electronic funds transfer systems are essential facilities in the channels of commerce.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That regulation of electronic funds transfer systems should be fair and not unduly impede the development of new technologies which benefit the public.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the following definitions shall apply unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAccess device\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a card, code, or other mechanism, or any combination thereof, that may be used by a customer for the purpose of initiating a transaction by means of a satellite terminal which will affect a customer asset account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdministrator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes the superintendent of banking and the superintendent of credit unions within the department of insurance and financial services and the supervisor of industrial loan companies within the office of the superintendent of banking. However, the powers of administration and enforcement of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be exercised only as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 527.3}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{527.5, subsection 7}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 527.11}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{527.12}}}{{\f5\fs18\hyphpar0\qj{, and any other pertinent provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBatch basis\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the delivery of an accumulation of messages representing multiple transactions after completion of the transactions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCentral routing unit\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any facility where electronic impulses or other indicia of a transaction originating at a satellite terminal are received and are routed and transmitted to a financial institution, or to a data processing center, or to another central routing unit, wherever located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompletion of the transaction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means when the presence of the customer at a satellite terminal is no longer needed to consummate the sale of goods or services, to grant to the seller the right to receive payment for the goods or services, and to issue a receipt to the customer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCustomer asset account\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3faccount\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a demand deposit, share, checking, savings, or other customer account, other than an occasional or incidental credit balance in a credit plan, which represents a liability of the financial institution which maintains such account at a business location or office located in this state, either directly or indirectly for the benefit of a customer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fData processing center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a facility, wherever located, at which electronic impulses or other indicia of a transaction originating at a satellite terminal are received and are processed in order to enable the satellite terminal to perform any function for which it is designed. However, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdata processing center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include a facility which is directly connected to a satellite terminal and which performs only the functions of direct transmission of all requested transactions from that terminal to a data processing facility without performing any review of the requested transactions for the purpose of categorizing, separating, or routing. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCategorizing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the process of reviewing and grouping of requested electronic funds transfer transactions according to the source or nature of the requested transaction. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSeparating\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the process of interpreting and segregating requested electronic funds transfer transactions, or portions of such transactions, to provide for processing of information relating to such requested transactions or portions of such transactions. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRouting\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the process of interpreting and transmitting requested electronic funds transfer transactions to a destination selected at the time of interpretation and transmission from two or more alternative destinations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fElectronic personal identifier\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a personal and confidential code or other security mechanism which has been designated by a financial institution issuing an access device to a customer to serve as a supplemental means of access to a customer\u8217\'3fs account that may be used by the customer in conjunction with an access device for the purpose of initiating a transaction by means of a satellite terminal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFinancial institution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes any bank incorporated under the provisions of any state or federal law, any savings and loan association incorporated under the provisions of federal law, any credit union organized under the provisions of any state or federal law, any corporation licensed as an industrial loan company under }}}{{\f5\fs18\hyphpar0\qj{chapter 536A}}}{{\f5\fs18\hyphpar0\qj{, and any affiliate of a bank, savings and loan association, credit union, or industrial loan company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLimited-function terminal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an on-line point-of-sale terminal, an off-line point-of-sale terminal, or a multiple use terminal, which is not operated in a manner to accept an electronic personal identifier. Except as otherwise provided, a limited-function terminal shall not be subject to the requirements imposed upon other satellite terminals pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 527.4}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{527.5, subsections 1, 2, 3, 7, and 8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMultiple use terminal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any machine or device to which all of the following are applicable:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The machine or device is established and owned or operated by a person who primarily engages in a service, business or enterprise, including but not limited to the retail sale of goods or services, but who is not organized under the laws of this state or under federal law as a bank, savings and loan association, or credit union;}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The machine or device is used by the person by whom it is owned or operated in some capacity other than as a satellite terminal; and}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financial institution proposes to contract or has contracted to utilize that machine or device as a satellite terminal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMunicipal corporation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an incorporated city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOffice\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes any business location in this state of a financial institution at which is offered the services of accepting deposits, originating loans, and dispensing cash, by financial institution personnel in the office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOff-line point-of-sale terminal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a satellite terminal at any location in this state off the premises of the financial institution, other than an on-line point-of-sale terminal, that satisfies all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The satellite terminal is not operated to accept deposits or to dispense scrip or other negotiable instruments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The satellite terminal is not operated to dispense cash except when operated by a person other than the customer initiating the transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The satellite terminal is utilized for the purpose of making payment to the provider of goods or services purchased or provided at the location of the satellite terminal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOn-line point-of-sale terminal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a satellite terminal at any location in this state off the premises of the financial institution operated on an on-line real time basis, that satisfies all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The satellite terminal is not operated to accept deposits or to dispense scrip or other negotiable instruments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The satellite terminal is not operated to dispense cash except when operated by a person other than the customer initiating the transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The satellite terminal is utilized for the purpose of making payment to the provider of goods or services purchased or provided at the location of the satellite terminal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOn-line real time basis\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the delivery or return of a message initiated at a satellite terminal through transmission of electronic impulses to or from a location remote from the location of the satellite terminal prior to completion of the transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPersonal terminal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes a satellite terminal located in a personal residence and a telephone, wherever located, operated by a customer of a financial institution for the purpose of initiating a transaction affecting a noncommercial account of the customer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPremises\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes only those locations where, by applicable law, financial institutions are authorized to maintain a principal place of business and other offices for the conduct of their respective businesses; provided that with respect to an industrial loan company, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpremises\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means only a location where business may be conducted under a single license issued to the industrial loan company.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fReciprocal basis\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that a financial institution whose licensed or principal place of business is located in this state has the express authority under the laws of a state other than Iowa to conduct business under qualifications and conditions which are no more restrictive than those imposed by the laws of the other state on financial institutions whose licensed or principal place of business is located in the other state, as determined by the administrator, and the laws of Iowa are no more restrictive of financial institutions whose licensed or principal place of business is located in such other state than they are of financial institutions whose licensed or principal place of business is located in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSatellite terminal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes any machine or device located off the premises of a financial institution, and any machine or device located on the premises of a financial institution only if the machine or device is available for use by customers of other financial institutions, whether attended or unattended, by means of which the financial institution and its customers utilizing an access device may engage through either the immediate transmission of electronic impulses to or from the financial institution or the recording of electronic impulses or other indicia of a transaction for delayed transmission to the financial institution, in transactions which affect a customer asset account and which otherwise are specifically permitted by applicable law. However, the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsatellite terminal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include any such machine or device, wherever located, if that machine or device is not generally accessible to persons other than employees of a financial institution or an affiliate of a financial institution.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 158, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 86, \'a71 \u8211\'3f 7}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 216, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 66, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1232, \'a799, 107}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a7121}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72742}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a799D.9}}}{{\f5\fs12\hyphpar0\qj{, 99F.7}}}{{\f5\fs12\hyphpar0\qj{, 234.12A}}}{{\f5\fs12\hyphpar0\qj{, 279.30}}}{{\f5\fs12\hyphpar0\qj{, 423.3}}}{{\f5\fs12\hyphpar0\qj{, 524.1212}}}{{\f5\fs12\hyphpar0\qj{, 525.1}}}{{\f5\fs12\hyphpar0\qj{, 547A.1}}}{{\f5\fs12\hyphpar0\qj{, 714.16B}}}{{\f5\fs12\hyphpar0\qj{, 715A.1}}}{{\f5\fs12\hyphpar0\qj{, 715A.8}}}{{\f5\fs12\hyphpar0\qj{, 715A.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Enforcement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ the superintendent of banking only has the power to issue rules applicable to, to accept and approve or disapprove applications or informational statements from, to conduct hearings and revoke any approvals relating to, and to exercise all other supervisory authority created by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ with respect to banks; the superintendent of credit unions only has such powers and authority with respect to credit unions; and the superintendent of banking or the superintendent\u8217\'3fs designee only has such powers and authority with respect to industrial loan companies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The administrator shall have the authority to examine any person who operates a multiple use terminal, limited-function terminal, or other satellite terminal, and any other device or facility with which such terminal is interconnected, as to any transaction by, with, or involving a financial institution which affects a customer asset account. Information obtained in the course of such an examination shall not be disclosed, except as provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing contained in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall authorize the administrator to regulate the conduct of business functions or to obtain access to any business records, data, or information of a person who operates a multiple use terminal, except those pertaining to a financial transaction engaged in through a satellite terminal, or as may otherwise be provided by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing contained in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to prohibit or to authorize the administrator to prohibit an operator of a multiple use terminal, other than a financial institution, or an operator of any other device or facility with which such terminal is interconnected, other than a central routing unit or data processing center from using those facilities to perform internal proprietary functions, including the extension of credit pursuant to an open-end credit arrangement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An administrator may conduct hearings and exercise any other appropriate authority conferred by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ regarding the operation or control of a satellite terminal upon the written request of a person, including but not limited to, a retailer, financial institution, or consumer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The authority of an administrator pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 527.5, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, to approve access cards issued by a financial institution for use as an access device includes the requirement that a registration statement shall be filed with the administrator and be maintained on a current basis by each financial institution issuing access cards within the state. The registration statement shall be in writing on a form prescribed by the administrator, and contain the name and address of the registrant, a depiction of both sides of the access card, and any other information the administrator deems relevant relating to the access card and transactions utilizing the access card which affect a customer asset account.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financial institution shall not be required to join, be a member or shareholder of, or otherwise participate in, any corporation, association, partnership, cooperative, or other enterprise as a condition of the financial institution\u8217\'3fs utilization of any satellite terminal located within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An administrator may issue any order necessary to secure compliance with or prevent a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or the rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, regarding the establishment and operation of a satellite terminal, limited-function terminal, upgraded, altered, modified, or replaced limited-function terminal, and any other device or facility with which such terminal is interconnected. A person who violates a provision of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or any rule or any order issued pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is subject to a civil penalty not to exceed one thousand dollars for each day the violation continues. A person aggrieved by an order of an administrator may appeal the order by filing a written notice of appeal with the administrator within thirty days of the issuance of the order. The administrator shall schedule a hearing for the purpose of hearing the arguments of the aggrieved person within thirty days of the filing of the notice of appeal. The provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ shall apply to all matters related to the appeal. The attorney general, on request of the administrator, shall institute any legal proceedings necessary to obtain compliance with an order of the administrator or to prosecute a person for a violation of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 158, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 92, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 216, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 66, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a7122}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a791}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7527.2}}}{{\f5\fs12\hyphpar0\qj{, 527.12}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Establishment of satellite terminals \u8212\'3f restrictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A satellite terminal shall not be established within this state except by a financial institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financial institution may establish a satellite terminal at any location within this state. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not amend, modify, or supersede any provision of }}}{{\f5\fs18\hyphpar0\qj{chapter 524}}}{{\f5\fs18\hyphpar0\qj{ regulating the number or locations of bank offices of a state or national bank, or authorize the establishment by a financial institution of any offices or other facilities except satellite terminals at locations permitted by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financial institution whose licensed or principal place of business is not located in this state may establish, control, maintain, or operate any number of satellite terminals at any location within this state if all satellite terminals, wherever located, that are owned, controlled, maintained, or operated by the financial institution are available for use on a nondiscriminatory basis by any other financial institution which engages in electronic transactions in this state and by all customers who have minimum contact with this state and who have been designated by a financial institution using the satellite terminal and who have been provided with an access device, approved by the administrator, by which to engage in electronic transactions by means of the satellite terminal.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 158, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 86, \'a78 \u8211\'3f 11}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 216, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1232, \'a7100 \u8211\'3f 103, 107}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7527.2}}}{{\f5\fs12\hyphpar0\qj{, 527.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Satellite terminal requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A satellite terminal may be utilized by a financial institution to the extent permitted in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ only if the satellite terminal is utilized and maintained in compliance with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and only if all of the following are complied with:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A satellite terminal in this state may be established by one or more financial institutions. The establishing financial institutions shall designate a single controlling financial institution which shall maintain the location, use, and operation of the satellite terminal, wherever located, in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The use and operation of a satellite terminal shall be governed by a written agreement between the controlling financial institution and the person controlling the physical location at which the satellite terminal is placed. The written agreement shall specify all of the terms and conditions, including any fees and charges, under which the satellite terminal is placed at that location. If the satellite terminal is a multiple use terminal, the written agreement shall specify, and may limit, the specific types of transactions incidental to the conduct of the business of a financial institution which may be engaged in through that terminal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A satellite terminal shall be available for use on a nondiscriminatory basis by any other financial institution which has its principal place of business within this state, and by all customers who have been designated by a financial institution using the satellite terminal and who have been provided with an access device, approved by the administrator, by which to engage in electronic transactions by means of the satellite terminal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of complying with paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, an on-line point-of-sale terminal is not required to be available for use by customers of a financial institution by means of an access device by which an off-line point-of-sale terminal can be used to engage in electronic transactions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All off-line point-of-sale terminals located at the retail location or retail locations within this state of a single retailer are exempt from paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ if electronic transactions can be initiated at each of such terminals only by an access device unique to the retailer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ applies to a financial institution whose licensed or principal place of business is located in a state other than Iowa, whether or not the financial institution has a business location in this state, if all satellite terminals or other similar type terminals owned, controlled, operated, or maintained by the financial institution, wherever located, are available on a reciprocal basis to each financial institution with a principal place of business in this state and to each financial institution with a business location in this state which complies with this paragraph, and to all customers who have been designated by any such financial institution using the satellite terminal and who have been provided with an access device.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An informational statement shall be filed and shall be maintained on a current basis with the administrator by the financial institution controlling a satellite terminal in this state, which sets forth all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and business address of the controlling financial institution.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location of the satellite terminal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A schedule of the charges which will be required to be paid by a financial institution utilizing the satellite terminal.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agreement with the administrator that the financial institution controlling the satellite terminal will maintain that satellite terminal in compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The informational statement shall be accompanied by a copy of the written agreement required by }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The informational statement also shall be accompanied by a statement or copy of any agreement, whether oral or in writing, between the controlling financial institution and a data processing center or a central routing unit, unless operated by or solely on behalf of the controlling financial institution, by which transactions originating at that terminal will be received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A satellite terminal in this state shall not be attended or operated at any time by an employee of a financial institution or an affiliate of a financial institution, except for the purpose of instructing customers, on a temporary basis, in the use of the satellite terminal, for the purpose of testing the terminal, or for the purpose of transacting business on the employee\u8217\'3fs own behalf.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A satellite terminal shall bear a sign or label no larger than three inches by two inches identifying the name, address, and telephone number of the owner of the satellite terminal. The administrator may authorize methods of identification the administrator deems necessary to enable the general public to determine the accessibility of a satellite terminal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The charges required to be paid by any financial institution which utilizes the satellite terminal for transactions involving an access device shall not exceed a pro rata portion of the costs, determined in accordance with generally accepted accounting principles, of establishing, operating and maintaining the satellite terminal, plus a reasonable return on these costs to the owner of the satellite terminal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the administrator deems the informational statement or any amendment to that statement or amendment to be complete and finds no grounds for denying establishment of a satellite terminal, the administrator may notify the person filing the informational statement that the administrator has expressly approved the establishment and operation of the satellite terminal as described in the informational statement or amendment and according to the agreements attached to the statement or amendment. Operation of the satellite terminal may commence immediately upon a person receiving such express approval from the administrator. If the administrator finds grounds, under any applicable law or rule, for denying establishment of a satellite terminal the administrator shall notify the person filing the informational statement or an amendment thereto, within thirty days of the filing thereof, of the existence of such grounds. If such notification is not given by the administrator, the administrator shall be considered to have expressly approved the establishment and operation of the satellite terminal as described in the informational statement or amendment and according to the agreements attached thereto, and operation of the satellite terminal in accordance therewith may commence on or after the thirtieth day following such filing. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit the administrator from enforcing the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, nor shall it be construed to constitute a waiver of any prohibition, limitation, or obligation imposed by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Satellite terminals located in this state shall be directly connected to either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A central routing unit approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A data processing center which is directly connected to a central routing unit approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a data processing center which is directly connected to a satellite terminal located in this state does not authorize or reject a transaction originated at that terminal, the transaction shall be immediately transmitted by the data processing center to a central routing unit approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, unless one of the following applies:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transaction is not authorized because of a mechanical failure of the data processing center or satellite terminal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The transaction does not affect a customer asset account held by a financial institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not limit the authority of a data processing center to authorize or reject transactions requested by customers of a financial institution pursuant to an agreement whereby the data processing center authorizes or rejects requested transactions on behalf of the financial institution and provides to the financial institution, on a batch basis and not on an on-line real time basis, information concerning authorized or rejected transactions of customers of the financial institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A personal terminal may be utilized by a financial institution to the extent permitted by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ if the use and operation of the personal terminal is governed by a written agreement between the controlling financial institution and its customer and if the personal terminal is utilized and maintained in compliance with }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{ and all other applicable sections of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. A telephone located at other than a personal residence and used primarily as a personal terminal must be utilized and maintained in compliance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 4.1, subsection 20}}}{{\f5\fs18\hyphpar0\qj{, establishing a limited-function terminal within this state, except for a multiple use terminal, which is utilized to initiate transactions affecting a customer asset account shall file with the administrator and shall maintain on a current basis a registration statement on a form prescribed by the administrator containing the name and address of the registrant, the location of the limited-function terminal, and any other information the administrator deems relevant. All limited-function terminals established in this state prior to July 1, 1991, shall be registered in a similar manner by the establishing person no later than July 1, 1992.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time, a limited-function terminal at a location in this state off the premises of the financial institution is replaced by a device constituting either an on-line or an off-line point-of-sale terminal which may be utilized to initiate transactions which affect customer asset accounts through the use of an electronic personal identifier, or is upgraded, altered, or modified to be operated in a manner which allows the use of an electronic personal identifier to initiate transactions which affect customer asset accounts, or an on-line or an off-line point-of-sale terminal which may be utilized to initiate transactions which affect customer asset accounts through the use of an electronic personal identifier is newly established at a location in this state off the premises of the financial institution, then such upgraded, altered, or modified limited-function terminal or replacement point-of-sale terminal or such newly established point-of-sale terminal is deemed to be a full-function point-of-sale terminal for purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and all requirements of a satellite terminal in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ apply to the full-function point-of-sale terminal with regard to all transactions affecting customer asset accounts which are initiated through the use of an electronic personal identifier, except for }}}{{\f5\fs18\hyphpar0\qj{section 527.4, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{subsections 1, 3, and 7}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A full-function point-of-sale terminal, as identified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, which is operated in a manner which permits all access devices to be utilized to initiate transactions which affect customer asset accounts, and where all such transactions can be directly routed for authorization purposes as established in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, is also exempt from the provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 8}}}{{\f5\fs18\hyphpar0\qj{. However, if a data processing center directly connected to such full-function point-of-sale terminal does not authorize or reject a transaction affecting a customer asset account initiated at the terminal through the use of an electronic personal identifier, the transaction shall be immediately transmitted by the data processing center to either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A central routing unit approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An electronic funds transfer processing facility maintained or operated by a national card association and utilized for the processing of transactions initiated through the use of electronic funds transfer transaction cards or access devices depicting a service mark, logo, or trademark associated with the national card association. However, if the national card association\u8217\'3fs processing facility is unable to immediately authorize or reject a transaction affecting a customer asset account initiated at that terminal through the use of an access device which bears a service mark, logo, or trademark associated with a central routing unit approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ but does not bear a service mark, logo, or trademark associated with a national card association, or which bears a service mark, logo, or trademark other than that associated with either a central routing unit approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or a national card association, the transaction shall be immediately transmitted to a central routing unit approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, whether the transaction initiated through the use of such access device was transmitted to the national card association\u8217\'3fs processing facility by a data processing center directly connected to the full-function point-of-sale terminal, or the national card association\u8217\'3fs processing facility received the transmission of transaction data directly from the full-function point-of-sale terminal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the national card association\u8217\'3fs electronic funds transfer processing facility directly or indirectly receives a transaction affecting a customer asset account initiated at a full-function point-of-sale terminal through the use of an electronic personal identifier and an access device bearing a service mark, logo, or trademark associated with a national card association, whether or not the access device also bears the service mark, logo, or trademark of an approved central routing unit, and the national card association\u8217\'3fs processing facility cannot immediately authorize or reject the transaction, such transaction shall be immediately transmitted to a central routing unit approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or to a financial institution, or its data processing center, which is capable of immediately authorizing or rejecting the transaction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a national card association must be a membership corporation or organization, wherever incorporated and maintaining a principal place of business, which is engaged in the business of administering for the benefit of the association\u8217\'3fs members a program involving electronic funds transfer transaction cards or access devices depicting a service mark, logo, or trademark associated with the national card association and which may be utilized to perform transactions at point-of-sale terminals. A national card association must have a membership solely comprised of insured depository financial institutions, organizations directly or indirectly owned or controlled solely by insured depository financial institutions, entities wholly owned by one or more insured depository financial institutions, holding companies having at least two-thirds of their assets consisting of the voting stock of insured depository financial institutions, organizations wholly owned by one or more holding companies having at least two-thirds of their assets consisting of the voting stock of insured depository financial institutions and which are solely engaged in activities related to the programs sponsored by the national card association, or such other entities or organizations which are authorized by the national card association\u8217\'3fs bylaws to participate in the electronic funds transfer transaction card or access device programs or other services and programs sponsored by the national card association. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a national card association shall not include a financial institution, bank holding company as defined in }}}{{\f5\fs18\hyphpar0\qj{section 524.1801}}}{{\f5\fs18\hyphpar0\qj{, or in the }}}{{\f5\fs18\hyphpar0\qj{federal Bank Holding Company Act of 1956}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{12 U.S.C. \'a71842(d)}}}{{\f5\fs18\hyphpar0\qj{, as amended to July 1, 1994, or any other financial institution holding company organized under federal or state law, or a subsidiary or affiliate corporation owned or controlled by a financial institution or financial institution holding company, which has authorized a customer or member to engage in satellite terminal transactions. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, a national card association shall also not include a membership corporation or organization which is conducting business as a regional or nationwide network of shared electronic funds transfer terminals which do not constitute point-of-sale terminals, and is engaged in satellite terminal transaction services utilizing a common service mark, logo, or trademark to identify such terminal services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to satellite terminals located in this state, other than on-line and off-line full-function point-of-sale terminals as identified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, or multiple use terminals located in this state which are capable of being operated in a manner to initiate transactions affecting customer asset accounts through the use of an electronic personal identifier.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Effective July 1, 1994, any transaction engaged in with a retailer through a satellite terminal at a location in this state off the premises of the financial institution by means of an access device which results in a debit to a customer asset account shall be cleared and paid at par during the settlement of such transaction. Notwithstanding the terms of any contractual agreement between a retailer or financial institution and a national card association as described in }}}{{\f5\fs18\hyphpar0\qj{subsection 11}}}{{\f5\fs18\hyphpar0\qj{, an electronic funds transfer processing facility of a national card association, a central routing unit approved pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or a data processing center, the processing fees and charges for such transactions to the retailer shall be as contractually agreed upon between the retailer and the financial institution which establishes, owns, operates, controls, or processes transactions initiated at the satellite terminal. All accounting documents reflecting such fees and charges imposed on the retailer shall separately identify transactions which have resulted in a debit to a customer asset account and the charges imposed. The provisions of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall apply to all satellite terminals, including limited-function terminals, full-function point-of-sale terminals as identified in }}}{{\f5\fs18\hyphpar0\qj{subsection 11}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and multiple use terminals.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.5}}}{; }{{\f5\fs18\hyphpar0\qj{82 Acts, ch 1094, \'a72}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 158, \'a75 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 86, \'a712 \u8211\'3f 14}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 216, \'a77 \u8211\'3f 11}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 36, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 37, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 66, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1094, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1232, \'a7104 \u8211\'3f 107}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a7123}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a7157}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7527.2}}}{{\f5\fs12\hyphpar0\qj{, 527.3}}}{{\f5\fs12\hyphpar0\qj{, 527.9}}}{{\f5\fs12\hyphpar0\qj{, 715A.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.6}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records maintained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All transactions engaged in through a satellite terminal shall be recorded in a form from which it will be possible to produce a humanly readable record of any transaction, and these recordings shall be retained by the utilizing financial institutions for the periods required by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The machine receipt provided to a satellite account transaction card user by a satellite terminal shall be admissible as evidence in any legal action or proceeding and shall constitute prima facie proof of the transaction evidence by that receipt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financial institution shall provide each of its satellite account holders with a periodic account statement that shall contain a brief description of all satellite terminal transactions sufficient to enable the account holder to identify any transaction and to relate it to machine receipts provided by satellite terminals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a periodic account statement includes both satellite terminal transactions and other nonsatellite terminal transactions, all satellite terminal transactions shall be indicated as such, and shall be accompanied by the description required by }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The administrator may provide by rule for the recording and maintenance, by any financial institution utilizing a satellite terminal, of amounts involved in a transaction engaged in through the satellite terminal which are of a known tax consequence to the customer initiating the transaction. For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this subsection,}}}{{\f5\fs18\hyphpar0\qj{ }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fknown tax consequences\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes but shall not be limited to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An amount directly or indirectly received from a customer and applied to a loan account of the customer which represents interest paid by the customer to the financial institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any transaction where the total amount involved is deducted from funds in a customer\u8217\'3fs account and is simultaneously paid either directly or indirectly by the financial institution to the account of a third party, any portion of the transaction amount which represents a sales or other tax imposed upon or included within the transaction and collected by that third party from the customer, or any portion of the transaction amount which represents interest paid to the third party by the customer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any other transaction which the administrator determines to have direct tax consequences to the customer. The administrator also may provide for the periodic distribution to customers of summaries of transactions having known tax consequences.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 216, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a7136}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.8}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.8A}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Exemptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Transactions initiated at a satellite terminal which do not involve the use of an access device to directly or indirectly affect a customer asset account are not governed by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 216, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Central routing units.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A central routing unit shall not be operated in this state unless written approval for that operation has been obtained from the administrator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person desiring to operate a central routing unit shall submit to the administrator an application which shall contain all of the following information:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and business address of the owner of the proposed unit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name and business address of each data processing center and other central routing unit with which the proposed central routing unit will have direct electronic communication.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The location of the proposed central routing unit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A schedule of the charges which will be required to be paid to that applicant by each financial institution which utilizes the proposed central routing unit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agreement by the applicant that the proposed central routing unit will be capable of accepting and routing, and will be operated to accept and route, transmissions of data originating at any satellite terminal located in this state, except limited-function terminals, whether receiving from that terminal or from a data processing center or other central routing unit.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A representation and undertaking that the proposed central routing unit is directly connected to every data processing center that is directly connected to a satellite terminal located in this state, and that the proposed central routing unit will provide for direct connection in the future with any data processing center that becomes directly connected to a satellite terminal located in this state. This representation and undertaking is not required of a central routing unit with respect to limited-function terminals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application shall be accompanied by all agreements between the proposed central routing unit and all data processing centers and other central routing units respecting the transmission of transaction data; and a copy of any agreement between the proposed central routing unit and any financial institution establishing a satellite terminal unless that agreement theretofore has been filed with the administrator pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 527.5}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The administrator shall approve or disapprove an application for operation of a central routing unit within sixty days after receipt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A central routing unit operating under the approval of the administrator shall be subject to examination by the administrator for the purpose of determining compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Effective July 1, 1987, a person owning or operating a central routing unit authorized under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall include public representation on any board setting policy for the central routing unit. Four or five public members shall be appointed to the board in the following manner:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Three members shall be appointed by the superintendent of banking.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One member shall be appointed by the superintendent of credit unions.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an industrial loan company is connected to the central routing unit, one member shall be appointed by the superintendent of banking.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The superintendent of banking and superintendent of credit unions shall form a committee to set, in conjunction with the entity owning or operating the central routing unit, the term of office, the rate of compensation, and the rate of reimbursement for each public member. However, the public members shall be entitled to reasonable compensation and reimbursement from the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each public member is entitled to all the rights of participation and voting as any other member of the board. The public members are to represent the interest of consumers and the business and agricultural communities in establishing policies for the central routing unit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the intention of the general assembly that the ratio of public members to the overall membership of the board shall not be less than one public member for each seven members of the board. If the number of members on the board is increased, then the number of members appointed pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be increased to maintain the minimum ratio. In this event, the superintendent of banking and the superintendent of credit unions shall appoint additional public members in order to maintain the minimum ratio.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual shall not be appointed as a public member pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if the individual is a director of a financial institution or is directly employed by a financial institution doing business in this state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 158, \'a713, 14}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 86, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 216, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1017, \'a7124}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1023, \'a7137}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Confidentiality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A satellite terminal, data processing center, or central routing unit shall not be operated in any manner to permit any person to obtain information concerning the account of any person with a financial institution, unless such information is essential to complete or prevent the completion of a transaction then being engaged in through the use of that facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A financial institution, data processing center, central routing unit, or other person shall not disseminate any information relating to the use of a multiple use terminal without the written authorization of the retailer on whose premises the terminal is located, or of the owner or operator of the terminal or the financial institution controlling the terminal. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not, however, prohibit or restrict the use of information received in the processing, authorization, or rejection of a requested electronic funds transfer transaction, where such use is necessary or incidental to the processing, authorization, or rejection, or to reconciling disputes or resolving questions raised by a retailer, financial institution, consumer, or any other person regarding the transaction.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 158, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a7150}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rulemaking.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The administrator shall have the power to adopt and promulgate rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ as in the administrator\u8217\'3fs opinion will be necessary to properly and effectively carry out and enforce the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.11}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7527.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{527.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Revocation of privilege.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Whenever the administrator determines, upon notice and hearing pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{, that a satellite facility or data processing center or central routing unit is being operated in violation of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the administrator may revoke the approval to operate that facility. If the administrator does not have any direct authority over the facility because of the provisions of }{{\f5\fs18\hyphpar0\qj{section 527.3}}}{, the administrator may revoke with respect to any financial institution over which the administrator does have direct authority the privilege to engage in transactions through or with that facility. A revocation by the administrator shall be effective when ordered by the administrator, anything in }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ to the contrary notwithstanding. The administrator may bring an action in the district court in the name of the state to enjoin any financial institution or other person who continues to utilize or to operate a satellite terminal or data processing center or central routing unit after the approval has been revoked. The administrator also may bring such an action to enjoin any person who fails to obtain any approval required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7527.12}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7527.2}}}\par}}