r0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Delinquent support payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If support payments ordered under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or }{{\f5\fs18\hyphpar0\qj{chapter 232}}}{, }{{\f5\fs18\hyphpar0\qj{234}}}{, }{{\f5\fs18\hyphpar0\qj{252A}}}{, }{{\f5\fs18\hyphpar0\qj{252C}}}{, }{{\f5\fs18\hyphpar0\qj{252E}}}{, }{{\f5\fs18\hyphpar0\qj{252F}}}{, }{{\f5\fs18\hyphpar0\qj{598}}}{, }{{\f5\fs18\hyphpar0\qj{600B}}}{, or any other applicable chapter, or under a comparable statute of another state or foreign country, as certified to child support services, are not paid to the clerk of the district court or the collection services center pursuant to }{{\f5\fs18\hyphpar0\qj{section 598.22}}}{ or, as appropriate, a comparable government entity in another state as provided in }{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{, and become delinquent in an amount equal to the payment for one month, child support services may enter an ex parte order or, upon application of a person entitled to receive the support payments, the district court may enter an ex parte order, notifying the person whose income is to be withheld, of the delinquent amount, of the amount of income to be withheld, and of the procedure to file a motion to quash the order for income withholding, and ordering the withholding of specified sums to be deducted from the delinquent person\u8217\'3fs income as defined in }{{\f5\fs18\hyphpar0\qj{section 252D.16}}}{ sufficient to pay the support obligation and, except as provided in }{{\f5\fs18\hyphpar0\qj{section 598.22}}}{, requiring the payment of such sums to the clerk of the district court or the collection services center or, as appropriate, a comparable government entity in another state as provided in }{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{. All income withholding payments shall be paid to the collection services center or, as appropriate, a comparable government entity in another state as provided in }{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{. Notification of income withholding shall be provided to the obligor and to the payor of income pursuant to }{{\f5\fs18\hyphpar0\qj{section 252D.17}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1239, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 100, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 178, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1191, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1245, \'a71421}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7317, 323}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1218, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1224, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1253, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1195, \'a7104}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 78, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 79, \'a745}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 175, \'a756}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1170, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 22, \'a757}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 110, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7880}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7252D.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.2}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1997/CH0175.pdf" }{\fldrslt \cf5 \f5 \fs18{{97 Acts, ch 175, \'a769}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{\'a7252D.31}}}{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.3}}}{\*\bkmkstart stylerid1_2E5_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice of income withholding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All orders for support entered on or after July 1, 1984, shall notify the person ordered to pay support of the mandatory withholding of income required under }{{\f5\fs18\hyphpar0\qj{section 252D.1}}}{. However, this }{{\f5\fs18\hyphpar0\qj{subchapter}}}{ is sufficient notice of implementation of mandatory withholding of income under }{{\f5\fs18\hyphpar0\qj{section 252D.1}}}{ without any further notice.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1239, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{85 Acts, ch 100, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a757}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 112, \'a78}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{252D.4 through 252D.7}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER II}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E6_2E1_2E2}{IMMEDIATE INCOME WITHHOLDING}{\*\bkmkend stylerid1_2E6_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.8}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Persons subject to immediate income withholding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a support order issued or modified on or after November 1, 1990, for which services are being provided by child support services, and in any support orders issued or modified after January 1, 1994, for which services are not provided by child support services, the income of a support obligor is subject to withholding, on the effective date of the order, regardless of whether support payments by the obligor are in arrears. If services are being provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 252B}}}{{\f5\fs18\hyphpar0\qj{, child support services may enter an ex parte order for an immediate withholding of income. The district court may enter an ex parte order for immediate income withholding for cases in which child support services is not providing services. The income of the obligor is subject to immediate withholding unless one of the following occurs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One of the parties demonstrates and the court or child support services finds there is good cause not to require immediate withholding. A finding of good cause shall be based on, at a minimum, written findings and conclusions by the court or administrative authority as to why implementing immediate withholding would not be in the best interests of the child. In cases involving modifications, the findings shall also include proof of timely payment of previously ordered support.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written agreement is reached between both parties which provides for an alternative arrangement. If the support payments have been assigned to the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 234}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{239B}}}{{\f5\fs18\hyphpar0\qj{, or a comparable statute of another jurisdiction, the department shall be considered a party to the support order, and a written agreement pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to waive immediate withholding is void unless approved by child support services. Any agreement existing at the time an assignment of support is made pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 234}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{239B}}}{{\f5\fs18\hyphpar0\qj{ or pursuant to a comparable statute of another jurisdiction shall not prevent child support services from implementing immediate withholding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an order not requiring immediate withholding, income of an obligor is subject to immediate withholding, without regard to whether there is an arrearage, on the earliest of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date the obligor requests that the withholding begin.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date the custodial parent or party to the proceeding requests that the withholding begin, if the request is approved by the district court or, in cases in which services are being provided pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 252B}}}{{\f5\fs18\hyphpar0\qj{, if child support services approves the request.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1123, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 78, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1171, \'a724}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 41, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7881}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7252D.31}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.9}}}{\*\bkmkstart stylerid1_2E6_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sums subject to immediate withholding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Specified sums shall be deducted from the obligor\u8217\'3fs income sufficient to pay the support obligation and any judgment established or delinquency accrued under the support order. The amount withheld pursuant to an income withholding order or notice of order for income withholding shall not exceed the amount specified in 15 U.S.C. \'a71673(b).}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1123, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1195, \'a7206}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a758}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.10}}}{\*\bkmkstart stylerid1_2E6_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice of immediate income withholding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An order for support entered after November 1, 1990, shall contain the notice of immediate income withholding. However, this }{{\f5\fs18\hyphpar0\qj{subchapter}}}{ is sufficient notice for implementation of immediate income withholding without any further notice.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1123, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a759}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 112, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.11}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/1997/CH0175.pdf" }{\fldrslt \cf5 \f5 \fs18{{97 Acts, ch 175, \'a769}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{\'a7252D.31}}}{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{252D.12 through 252D.15}}}{Reserved. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{\pard\plain\f5\fs18\qc\fi0\sb360\ri0\li0{{\f5\fs18\qc{SUBCHAPTER III}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E7_2E1_2E2}{GENERAL PROVISIONS}{\*\bkmkend stylerid1_2E7_2E1_2E2}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.16}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild support services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as child support services created in }}}{{\f5\fs18\hyphpar0\qj{section 252B.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIncome\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any periodic form of payment due an individual, regardless of source, including but not limited to wages, salaries, commissions, bonuses, workers\u8217\'3f compensation, disability payments, payments pursuant to a pension or retirement program, and interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sole payment or lump sum as provided in }}}{{\f5\fs18\hyphpar0\qj{section 252D.18C}}}{{\f5\fs18\hyphpar0\qj{, including but not limited to payment from an estate including inheritance, or payment for personal injury or property damage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Irregular income as defined in }}}{{\f5\fs18\hyphpar0\qj{section 252D.18B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPayor of income\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpayor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes but is not limited to an obligor\u8217\'3fs employer, trustee, the state of Iowa and all governmental subdivisions and agencies, and any other person from whom an obligor receives income.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSupport\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsupport payments\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any amount which the court or administrative agency may require a person to pay for the benefit of a child under a temporary order or a final judgment or decree entered under }}}{{\f5\fs18\hyphpar0\qj{chapter 232}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{234}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{252A}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{252C}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{252F}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{252H}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{598}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{600B}}}{{\f5\fs18\hyphpar0\qj{, or any other comparable chapter, and may include child support, maintenance, medical support as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 252E}}}{{\f5\fs18\hyphpar0\qj{, spousal support, and any other term used to describe these obligations. These obligations may include support for a child of any age who is dependent on the parties to the dissolution proceedings because of physical or mental disability. The obligations may include support for a child eighteen or more years of age with respect to whom a child support order has been issued pursuant to the laws of another state or foreign country. These obligations shall not include amounts for a postsecondary education subsidy as defined in }}}{{\f5\fs18\hyphpar0\qj{section 598.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 112, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 110, \'a793}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7882}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 119, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a751}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a78.89}}}{{\f5\fs12\hyphpar0\qj{, 84A.5}}}{{\f5\fs12\hyphpar0\qj{, 252B.1}}}{{\f5\fs12\hyphpar0\qj{, 252B.13A}}}{{\f5\fs12\hyphpar0\qj{, 252B.14}}}{{\f5\fs12\hyphpar0\qj{, 252B.24}}}{{\f5\fs12\hyphpar0\qj{, 252D.1}}}{{\f5\fs12\hyphpar0\qj{, 252D.16A}}}{{\f5\fs12\hyphpar0\qj{, 252I.1}}}{{\f5\fs12\hyphpar0\qj{, 252J.1}}}{{\f5\fs12\hyphpar0\qj{, 627.11}}}{{\f5\fs12\hyphpar0\qj{, 627.12}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.16A}}}{\*\bkmkstart stylerid1_2E7_2E3_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E3_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Income withholding order }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ child support services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If support payments are ordered under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, }{{\f5\fs18\hyphpar0\qj{chapter 232}}}{, }{{\f5\fs18\hyphpar0\qj{234}}}{, }{{\f5\fs18\hyphpar0\qj{252A}}}{, }{{\f5\fs18\hyphpar0\qj{252C}}}{, }{{\f5\fs18\hyphpar0\qj{252E}}}{, }{{\f5\fs18\hyphpar0\qj{252F}}}{, }{{\f5\fs18\hyphpar0\qj{252H}}}{, }{{\f5\fs18\hyphpar0\qj{598}}}{, }{{\f5\fs18\hyphpar0\qj{600B}}}{, or any other applicable chapter, or under a comparable statute of another state or foreign country, and if income withholding relative to such support payments is allowed under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, child support services may enter an ex parte order notifying the person whose income is to be withheld of the procedure to file a motion to quash the order for income withholding, and ordering the withholding of sums to be deducted from the delinquent person\u8217\'3fs income as defined in }{{\f5\fs18\hyphpar0\qj{section 252D.16}}}{ sufficient to pay the support obligation and requiring the payment of such sums to the collection services center or, as appropriate, a comparable government entity in another state as provided in }{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{. Child support services shall include the amount of any delinquency and the amount to be withheld in the notice provided to the obligor pursuant to }{{\f5\fs18\hyphpar0\qj{section 252D.17A}}}{. Notice of income withholding shall be provided to the obligor and to the payor of income pursuant to }{{\f5\fs18\hyphpar0\qj{sections 252D.17}}}{ and }{{\f5\fs18\hyphpar0\qj{252D.17A}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1119, \'a73, 11}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 110, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7883}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.17}}}{\*\bkmkstart stylerid1_2E7_2E4_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E4_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice to payor of income }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ duties and liability }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ criminal penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The district court shall provide notice by sending a copy of the order for income withholding or a notice of the order for income withholding to the obligor and the obligor\u8217\'3fs payor of income by regular mail, with proof of service completed according to }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.442}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. Child support services shall provide notice of the income withholding order by sending a notice of the order to the obligor\u8217\'3fs payor of income by regular mail or by electronic means. Proof of service may be completed according to }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs18{{\f5\b\fs18\hyphpar0\qj\cf5{rule of civil procedure 1.442}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. Child support services\u8217\'3f notice of the order may be sent to the payor of income on the same date that the order is sent to the clerk of court for filing. In all other instances, the income withholding order shall be filed with the clerk of court prior to sending the notice of the order to the payor of income. In addition to the amount to be withheld for payment of support, the order or the notice of the order shall be in a standard format as prescribed by child support services and shall include all of the following information regarding the duties of the payor in implementing the withholding order:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The withholding order or notice of the order for income withholding for child support or child support and spousal support has priority over a garnishment or an assignment for any other purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As reimbursement for the payor\u8217\'3fs processing costs, the payor may deduct a fee of no more than two dollars for each payment in addition to the amount withheld for support. The payor of income is not required to vary the payroll cycle to comply with the frequency of payment of a support order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount withheld for support, including the processing fee, shall not exceed the amounts specified in }}}{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a71673(b)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The income withholding order is binding on an existing or future payor of income ten days after receipt of the copy of the order or the notice of the order, and is binding whether or not the copy of the order received is file-stamped.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The payor shall send the amounts withheld to the collection services center or the clerk of the district court pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 252B.14}}}{{\f5\fs18\hyphpar0\qj{ or, as appropriate, a comparable government entity in another state as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{{\f5\fs18\hyphpar0\qj{, within seven business days of the date the obligor is paid. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBusiness day\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a day on which state offices are open for regular business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The payor may combine amounts withheld from the obligors\u8217\'3f income in a single payment to the clerk of the district court or to the collection services center or a comparable government entity in another state as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{{\f5\fs18\hyphpar0\qj{, as appropriate. Whether combined or separate, payments shall be identified by the name of the obligor, account number, amount, and the date withheld. If payments for multiple obligors are combined, the portion of the payment attributable to each obligor shall be specifically identified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The withholding is binding on the payor until further notice by the court or child support services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the payor, with actual knowledge and intent to avoid legal obligation, fails to withhold income or to pay the amounts withheld to the collection services center or the clerk of court or, as appropriate, a comparable government entity in another state as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{{\f5\fs18\hyphpar0\qj{ in accordance with the provisions of the order, the notice of the order, or the notification of payors of income provisions established in }}}{{\f5\fs18\hyphpar0\qj{section 252B.13A}}}{{\f5\fs18\hyphpar0\qj{, the payor commits a simple misdemeanor for a first offense and is liable for the accumulated amount which should have been withheld, together with costs, interest, and reasonable attorney fees related to the collection of the amounts due from the payor. For each subsequent offense prescribed under this paragraph, the payor commits a serious misdemeanor and is liable for the accumulated amount which should have been withheld, together with costs, interest, and reasonable attorney fees related to the collection of the amounts due from the payor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The payor shall promptly notify the court or child support services when the obligor\u8217\'3fs employment or other income terminates, and provide the obligor\u8217\'3fs last known address and the name and address of the obligor\u8217\'3fs new employer, if known.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any payor who discharges an obligor, refuses to employ an obligor, or takes disciplinary action against an obligor based upon income withholding is guilty of a simple misdemeanor. A withholding order or the notice of the order for income withholding has the same force and effect as any other district court order, including but not limited to contempt of court proceedings for noncompliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning July 1, 1997, if a payor of income does business in another state through a registered agent and receives a notice of income withholding issued by another state, the payor shall, and beginning January 1, 1998, any payor of income shall, withhold funds as directed in a notice issued by another state, except that a payor of income shall follow the laws of the obligor\u8217\'3fs principal place of employment when determining all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The payor\u8217\'3fs fee for processing an income withholding payment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The maximum amount permitted to be withheld from the obligor\u8217\'3fs income.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The time periods for implementing the income withholding order and forwarding the support payments.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The priorities for withholding and allocating income withheld for multiple child support obligees.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(e)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any withholding terms or conditions not specified in the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A payor of income who complies with an income withholding notice that is regular on its face shall not be subject to any civil liability to any individual or agency for conduct in compliance with the notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The payor of income shall comply with }}}{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{{\f5\fs18\hyphpar0\qj{ when receiving a notice of income withholding from another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall establish criteria and a phased-in schedule to require, no later than June 30, 2015, payors of income to electronically transmit the amounts withheld under an income withholding order. The department shall assist payors of income in complying with the required electronic transmission, and shall adopt rules setting forth procedures for use in electronic transmission of funds, and exemption from use of electronic transmission taking into consideration any undue hardship electronic transmission creates for payors of income.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 78, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 52, \'a75, 6}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{; }{{\f5\fs18\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts//CH0000.pdf" }{\fldrslt \f5 \fs18{{\f5\fs18\hyphpar0\qj\cf5{96 Acts, ch 1141, \'a710, 11}}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 175, \'a761, 70, 72}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1170, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1125, \'a72, 4}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1119, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1031, \'a7337}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a755}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 140, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 110, \'a795}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7884, 885}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7252D.1}}}{{\f5\fs12\hyphpar0\qj{, 252D.16A}}}{{\f5\fs12\hyphpar0\qj{, 252D.18}}}{{\f5\fs12\hyphpar0\qj{, 252D.18A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.17A}}}{\*\bkmkstart stylerid1_2E7_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice to obligor of implementation of income withholding order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Child support services or the district court shall send a notice of the income withholding order to the obligor at the time the notice is sent to the payor of income.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7886}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7252D.16A}}}{{\f5\fs12\hyphpar0\qj{, 252D.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.18}}}{\*\bkmkstart stylerid1_2E7_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Modification or termination of withholding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court or child support services may, by ex parte order, modify a previously entered income withholding order if the court or child support services determines any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There has been a change in the amount of the current support obligation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount required to be withheld under the income withholding order is in error.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any past due support debt has been paid in full. Should a delinquency later accrue, the withholding order may be modified to secure payment toward the delinquency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There has been a change in the rules adopted by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ regarding the amount of income to be withheld to pay a delinquency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child support services may modify an amount specified in an income withholding order or notice of income withholding by providing notice to the payor of income and the obligor pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 252D.17}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{252D.17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court or child support services may, by ex parte order, terminate an income withholding order when the current support obligation has terminated and when the delinquent support obligation has been fully satisfied as applicable to all of the children covered by the income withholding order. Child support services may, by ex parte order, terminate an income withholding order when child support services will no longer be providing services under }}}{{\f5\fs18\hyphpar0\qj{chapter 252B}}}{{\f5\fs18\hyphpar0\qj{, or when another state or foreign country will be providing services under }}}{{\f5\fs18\hyphpar0\qj{Tit. IV-D of the federal Social Security Act}}}{{\f5\fs18\hyphpar0\qj{ or a comparable law in a foreign country.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In no case shall payment of overdue support be the sole basis for termination of withholding.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1123, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 177, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1195, \'a7106}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 78, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1170, \'a744}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1119, \'a75, 11}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 67, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 110, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7887}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.18A}}}{\*\bkmkstart stylerid1_2E7_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Multiple income withholding orders \u8212\'3f amounts withheld by payor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When the obligor is responsible for paying more than one support obligation and the payor of income has received more than one income withholding order or notice of an order for the obligor, the payor shall withhold amounts in accordance with all of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The total of all amounts withheld shall not exceed the amounts specified in }}}{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a71673(b)}}}{{\f5\fs18\hyphpar0\qj{. For orders or notices issued by child support services, the limit for the amount to be withheld shall be specified in the order or notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As reimbursement for the payor\u8217\'3fs processing costs, the payor may deduct a fee of no more than two dollars for each payment withheld in addition to the amount withheld for support.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Priority shall be given to the withholding of current support rather than delinquent support. The payor shall not allocate amounts withheld in a manner which results in the failure to withhold an amount for one or more of the current support obligations.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To arrive at the amount to be withheld for each obligee, the payor shall total the amounts due for current support under the income withholding orders and the notices of orders and determine the proportionate share for each obligee. The proportionate share shall be determined by dividing the amount due for current support for each order or notice of order by the total due for current support for all orders and notices of orders. The results are the percentages of the obligor\u8217\'3fs net income which shall be withheld for each obligee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after completing the calculation in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the withholding limit specified under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ has not been attained, the payor shall total the amounts due for arrearages and determine the proportionate share for each obligee. The proportionate share amounts shall be established utilizing the procedures established in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ for current support obligations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The payor shall identify and report payments by the obligor\u8217\'3fs name, account number, amount, and date withheld pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 252D.17}}}{{\f5\fs18\hyphpar0\qj{. If payments for multiple obligees are combined, the portion of the payment attributable to each obligee shall be specifically identified only if the payor is directed to do so by child support services.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 78, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1141, \'a712, 13}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a763, 64}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1170, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1018, \'a71, 2}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 15, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7888}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.18B}}}{\*\bkmkstart stylerid1_2E7_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Irregular income.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When payment of income is irregular, and an order for immediate or mandatory income withholding has been entered by child support services or the district court, the income payor shall withhold income equal to the total that would have been withheld had there been regular monthly income. The amounts withheld shall not exceed the amounts specified in }{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a71673(b)}}}{. For the purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{, an income source is irregular when there are periods in excess of one month during which the income payor makes no payment to the obligor and the periods are not the result of termination or suspension of employment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 78, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7889}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7252D.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.18C}}}{\*\bkmkstart stylerid1_2E7_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Withholding from lump sum payments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Child support services or the district court may enter an ex parte order for income withholding when the obligor is paid by a lump sum income source. When a sole payment is made or payment occurs at two-month or greater intervals, the withholding order may include all current and delinquent support due through the current month, but shall not exceed the amounts specified in }{{\f5\fs18\hyphpar0\qj{15 U.S.C. \'a71673(b)}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 78, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7890}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7252D.16}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.19}}}{\*\bkmkstart stylerid1_2E7_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Other remedies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The remedies provided in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ do not exclude the use of other civil or criminal remedies in enforcing support obligations.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1123, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.19A}}}{\*\bkmkstart stylerid1_2E7_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disparity between order and pay dates \u8212\'3f not delinquent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An obligor whose support payments are automatically withheld from the obligor\u8217\'3fs paycheck shall not be delinquent or in arrears if all of the following conditions are met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any delinquency or arrearage is caused solely by a disparity between the schedules of the obligor\u8217\'3fs regular pay dates and the scheduled date the support is due.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The amount calculated to be withheld is such that the total amount of current support to be withheld from the paychecks of the obligor and the amount ordered to be paid in the support order are the same on an annual basis.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The automatic deductions for support are continuous and occurring.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If child support services takes an enforcement action during a calendar year against an obligor and the obligor is not delinquent or in arrears solely due to the applicability of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the obligor, upon discovering the circumstances, child support services shall promptly discontinue the enforcement action.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a765}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7891}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.20}}}{\*\bkmkstart stylerid1_2E7_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administration of income withholding procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Child support services is designated as the entity of the state to administer income withholding in accordance with the procedures specified for keeping adequate records to document, track, and monitor support payments on cases subject to }{{\f5\fs18\hyphpar0\qj{Tit. IV-D of the federal Social Security Act}}}{. The collection services center is designated as the entity for administering income withholding for cases which are not subject to Tit. IV-D. The collection services center\u8217\'3fs responsibilities for administering income withholding in cases not subject to Tit. IV-D are limited to the receipt, recording, and disbursement of income withholding payments and to responding to requests for information on the current status of support payments pursuant to }{{\f5\fs18\hyphpar0\qj{section 252B.13A}}}{. Notwithstanding }{{\f5\fs18\hyphpar0\qj{section 622.53}}}{, in cases where the court or child support services is enforcing an order of another state or foreign country through income withholding, a certified copy of the underlying judgment is sufficient proof of authenticity.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1123, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1195, \'a7404}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1170, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 110, \'a797}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7892}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.21}}}{\*\bkmkstart stylerid1_2E7_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty for misrepresentation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person who knowingly makes a false statement or representation of a material fact or knowingly fails to disclose a material fact in order to secure an income withholding order or notice of income withholding against another person and to receive support payments or additional support payments pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, is guilty, upon conviction, of a serious misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1123, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a766}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.22}}}{\*\bkmkstart stylerid1_2E7_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall adopt the administrative rules necessary to implement the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ as they pertain to the operations of child support services.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1123, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7893}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.23}}}{\*\bkmkstart stylerid1_2E7_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Filing of withholding order }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ order effective as district court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An income withholding order entered by child support services pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be filed with the clerk of the district court. In lieu of any signature on the order which may otherwise be required by law or rule, the order shall have affixed the name and address of child support services. For the purposes of demonstrating compliance by the payor of income, the copy of the withholding order or the notice of the order received, whether or not the copy of the order is file-stamped, shall have all the force, effect, and attributes of a docketed order of the district court including, but not limited to, availability of contempt of court proceedings against a payor of income for noncompliance. However, any information contained in the income withholding order or the notice of the order related to the amount of the accruing or accrued support obligation which does not reflect the correct amount of support due does not modify the underlying support judgment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1195, \'a7207}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1171, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 52, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1141, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a767}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 127, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7894}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.24}}}{\*\bkmkstart stylerid1_2E7_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Applicability to support orders of other jurisdictions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An income withholding order may be entered to enforce a support order of another state or foreign country. That support order may be entered and filed with the clerk of the district court at the time the income withholding order is entered. Entry of the support order of another state or foreign country under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not constitute registration of the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Income withholding for a support order issued by another state or foreign country is governed by }}}{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, as appropriate.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 78, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 175, \'a771}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 112, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 110, \'a798}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.25}}}{\*\bkmkstart stylerid1_2E7_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitations on scope of proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issues related to visitation, custody, or other provisions not related to the support provisions of a support order are not grounds for a motion to quash, revoke, suspend, or stay a withholding order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Support orders shall not be modified under a motion to quash a withholding order.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 78, \'a718}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{252D.26 through 252D.29}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.30}}}{\*\bkmkstart stylerid1_2E7_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Ex parte order \u8212\'3f provisions for medical support.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An ex parte order entered under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may also include provisions for enforcement of medical support when medical support provisions are included in the support order. The ex parte order may require income withholding of a dollar amount for medical support or implementation of provision for dependent coverage under a health benefit plan pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 252E}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 78, \'a719}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{252D.31}}}{\*\bkmkstart stylerid1_2E7_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Motion to quash.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An obligor under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may move to quash an income withholding order or a notice of income withholding by filing a motion to quash with the clerk of court.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Grounds for contesting a withholding order under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mistake of fact, which for purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ means an error in the amount withheld or the amount of the withholding or the identity of the obligor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For immediate withholding only, the conditions for exception to immediate income withholding as defined under }}}{{\f5\fs18\hyphpar0\qj{section 252D.8}}}{{\f5\fs18\hyphpar0\qj{ existed at the time of implementation of the withholding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The clerk of the district court shall schedule a hearing on the motion to quash for a time not later than seven days after the filing of the motion to quash and the notice of the motion to quash. The clerk shall mail to the parties copies of the motion to quash, the notice of the motion to quash, and the order scheduling the hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The payor shall withhold and transmit the amount specified in the order or notice of the order of income withholding to the clerk of the district court or the collection services center or a comparable government entity in another state as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 252K}}}{{\f5\fs18\hyphpar0\qj{, as appropriate, until the notice that a motion to quash has been granted is received.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 175, \'a768}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 110, \'a799}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7252E.6A}}}\par}}