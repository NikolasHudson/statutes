\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F529}{\*\bkmkend codeChapter_5F529}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 529}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{IOWA FINANCIAL TRANSACTION REPORTING ACT}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7669.14}}}{{\f5\fs12\qc{, 706B.2}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{529.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAuthorized delegate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person designated by the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCheck cashing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means exchanging for compensation a check, draft, money order, traveler\u8217\'3fs check, or a payment instrument of a money transmitter for money delivered to the presenter at the time and place of the presentation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompensation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any fee, commission, or other benefit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConduct the business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means engaging in activities of a licensee or money transmitter more than ten times in any calendar year for compensation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fForeign money exchange\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means exchanging for compensation money of the United States government or a foreign government to or from money of another government at a conspicuously posted exchange rate at the time and place of the presentation of the money to be exchanged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person licensed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.*}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLocation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a place of business at which activity conducted by a licensee or money transmitter occurs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMoney\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a medium of exchange authorized or adopted by a domestic or foreign government as a part of its currency and that is customarily used and accepted as a medium of exchange in the country of issuance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMoney transmitter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is located or doing business in this state, including a check casher and a foreign money exchanger, and who does any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sells or issues payment instruments.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conducts the business of receiving money for the transmission of or transmitting money.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conducts the business of exchanging payment instruments or money into any form of money or payment instrument.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conducts the business of receiving money for obligors for the purpose of paying obligors\u8217\'3f bills, invoices, or accounts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Meets the definition of a bank, financial agency, or financial institution as prescribed by }}}{{\f5\fs18\hyphpar0\qj{31 U.S.C. \'a75312}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj\cf1{31 C.F.R. \'a7103.11}}}{{\f5\fs18\hyphpar0\qj{ and any successor provisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPayment instrument\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a check, draft, money order, traveler\u8217\'3fs check, or other instrument or order for the transmission or payment of money, sold to one or more persons, whether or not that instrument or order is negotiable. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPayment instrument\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include an instrument that is redeemable by the issuer in merchandise or service, a credit card voucher, or a letter of credit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProceeds\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means property acquired or derived directly or indirectly from, produced through, realized through, or caused by an act or omission and includes any property of any kind.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProperty\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means anything of value, and includes any interest in property, including any benefit, privilege, claim, or right with respect to anything of value, whether real or personal, tangible or intangible, without reduction for expenses incurred for acquisition, maintenance, production, or any other purpose.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSuperintendent\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the superintendent of banking or the superintendent of credit unions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTransaction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a purchase, sale, trade, loan, pledge, investment, gift, transfer, transmission, delivery, deposit, withdrawal, payment, transfer between accounts, exchange of currency, extension of credit, purchase or sale of any monetary instrument, use of a safe deposit box, or any other acquisition or disposition of property by whatever means effected.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTransmitting money\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the transmission of money by any means including transmission within this country or to or from locations abroad by payment instrument, wire, facsimile, or electronic transfer, courier, or otherwise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTraveler\u8217\'3fs check\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an instrument identified as a traveler\u8217\'3fs check on its face or commonly recognized as a traveler\u8217\'3fs check and issued in a money multiple of United States or foreign currency with a provision for a specimen signature of the purchaser to be completed at the time of purchase and a countersignature of the purchaser to be completed at the time of negotiation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1133, \'a734}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1074, \'a730}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{*This chapter does not include licensing provisions }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{529.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee, authorized delegate, or money transmitter required to file a report regarding business conducted in this state pursuant to the federal }}}{{\f5\fs18\hyphpar0\qj{Currency and Foreign Transactions Reporting Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{31 U.S.C. \'a75311 through 5326}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj\cf1{31 C.F.R. pt. 103}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj\cf1{12 C.F.R. \'a721.11}}}{{\f5\fs18\hyphpar0\qj{, shall file a duplicate of that report with the department of public safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All persons engaged in a trade or business who are required to file a report pursuant to }}}{{\f5\fs18\hyphpar0\qj{26 U.S.C. \'a76050I}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj\cf1{26 C.F.R. \'a71.6050I}}}{{\f5\fs18\hyphpar0\qj{, and any successor provisions, concerning returns relating to cash received in trade or business, shall file a copy of the report with the department of public safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee, authorized delegate, or money transmitter that is regulated under the federal }}}{{\f5\fs18\hyphpar0\qj{Currency and Foreign Transactions Reporting Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{31 U.S.C. \'a75325}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj\cf1{31 C.F.R. pt. 103}}}{{\f5\fs18\hyphpar0\qj{, and that is required to make available prescribed records to the secretary of the United States department of treasury upon request at any time, shall follow the same prescribed procedures and create and maintain the same prescribed records relating to a transaction and shall make these records available to the department of public safety pursuant to a prosecuting attorney subpoena.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The timely filing of a report required by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ with the appropriate federal agency shall be deemed compliance with the reporting requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the attorney general or the department of public safety has notified the superintendent that reports of that type are not being regularly and comprehensively transmitted by that federal agency to the department of public safety.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{{\f5\fs18\hyphpar0\qj{ does not preclude a licensee, authorized delegate, money transmitter, financial institution, or a person engaged in a trade or business, in its discretion, from instituting contact with, and thereafter communicating with and disclosing customer financial records to appropriate state or local law enforcement agencies if the licensee, authorized delegate, money transmitter, financial institution, or person has information that may be relevant to a possible violation of any criminal statute or to the evasion or attempted evasion of any reporting requirement of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee, authorized delegate, money transmitter, financial institution, person engaged in a trade or business, or any officer, employee, agent, or authorized delegate of any of them, or any public official or governmental employee who keeps or files a record pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or who communicates or discloses information or records under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, is not liable to its customer, to a state or local agency, or to any person for any loss or damage caused in whole or in part by the making, filing, or governmental use of the report, or any information contained in that report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general or the department of public safety may report any possible violations indicated by analysis of the reports required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to any appropriate law enforcement agency for use in the proper discharge of its official duties. The attorney general or the department of public safety shall provide copies of the reports required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to any appropriate prosecutorial or law enforcement agency upon being provided with a written request for records relating to a specific individual or entity and stating that the agency has an articulable suspicion that such individual or entity has committed a felony offense or a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to which the reports are relevant. A person who releases information received pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ except in the proper discharge of the person\u8217\'3fs official duties is guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It shall be unlawful for any person to do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With intent to disguise the fact that money or a payment instrument is the proceeds of criminal conduct, or with intent to promote, manage, establish, carry on, or facilitate the promotion, management, establishment, or carrying on of any criminal conduct, to knowingly furnish or provide to a licensee, authorized delegate, money transmitter, financial institution, person engaged in a trade or business, or any officer, employee, agent, or authorized delegate of any of them, or to the attorney general or department of public safety, any false, inaccurate, or incomplete information; or to knowingly conceal a material fact in connection with a transaction for which a report is required to be filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{With the intent to disguise the fact that money or a payment instrument is the proceeds of criminal conduct, or with intent to promote, manage, establish, carry on, or facilitate the promotion, management, establishment, or carrying on of any criminal conduct, or with intent to evade the making or filing of a report required under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or with intent to cause the making or filing of a report that contains a material omission or misstatement of fact, to conduct or structure a transaction or series of transactions by or through one or more licensees, authorized delegates, money transmitters, financial institutions, or persons engaged in a trade or business.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{subsection 6}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a class \u8220\'3fC\u8221\'3f felony and is also subject to a civil penalty of three times the value of the property involved in the transaction, or, if no transaction is involved, five thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of law, each violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ constitutes a separate, punishable offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any report, record, information, analysis, or request obtained by the attorney general or department of public safety pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is not a public record as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{ and is not subject to disclosure.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1133, \'a735}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1074, \'a731}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a722.7(34)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{529.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Investigations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general or county attorney may conduct investigations within or outside this state to determine if any licensee, authorized delegate, money transmitter, or person engaged in a trade or business has failed to file a report required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ or has engaged or is engaging in any act, practice, or transaction that constitutes a violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon presentation of a subpoena from a prosecuting attorney, all licensees, authorized delegates, money transmitters, and financial institutions shall make their books and records available to the attorney general or county attorney or peace officer during normal business hours for inspection and examination in connection with an investigation pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1133, \'a736}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{529.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Uniformity of construction and application.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be liberally construed to effectuate its remedial purposes. Civil remedies under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be supplemental and not mutually exclusive. The civil remedies do not preclude and are not precluded by other provisions of law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be applied and construed to effectuate its general purpose to make uniform the law with respect to the subject of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ among states enacting the law and to make the reporting requirements regarding financial transactions under Iowa law uniform with the reporting requirements regarding financial transactions under federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general is authorized to enter into reciprocal agreements with the attorney general or chief prosecuting attorney of any state to effectuate the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1133, \'a737}}}\par}}