\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F362}{\*\bkmkend codeChapter_5F362}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 362}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{DEFINITIONS AND MISCELLANEOUS PROVISIONS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7376.1}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Citation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ and }{{\f5\fs18\hyphpar0\qj{chapters 364}}}{, }{{\f5\fs18\hyphpar0\qj{368}}}{, }{{\f5\fs18\hyphpar0\qj{372}}}{, }{{\f5\fs18\hyphpar0\qj{376}}}{, }{{\f5\fs18\hyphpar0\qj{380}}}{, }{{\f5\fs18\hyphpar0\qj{384}}}{, }{{\f5\fs18\hyphpar0\qj{388}}}{, and }{{\f5\fs18\hyphpar0\qj{392}}}{ may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCity Code of Iowa\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7362.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 30, \'a762}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in the city code of Iowa, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdministrative agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an agency established by a city for any city purpose or for the administration of any city facility, as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 392}}}{{\f5\fs18\hyphpar0\qj{, except a board established to administer a municipal utility, a zoning commission and zoning board of adjustment, or any other agency which is controlled by state law. An administrative agency may be designated as a board, board of trustees, commission, or by another title. If an agency is advisory only, such a designation must be included in its title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAmendment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a revision or repeal of an existing ordinance or code of ordinances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCharter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the form of government selected by a city as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 372}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a municipal corporation, but not including a county, township, school district, or any special-purpose district or authority. When used in relation to land area, \u8220\'3fcity\u8221\'3f includes only the area within the city limits.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCity code\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the city code of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCity utility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all or part of a waterworks, gasworks, sanitary sewage system, storm water drainage system, electric light and power plant and system, heating plant, cable communication or television system, telephone or telecommunications systems or services offered separately or combined with any system or service specified in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ or authorized by other law, any of which are owned by a city, including all land, easements, rights-of-way, fixtures, equipment, accessories, improvements, appurtenances, and other property necessary or useful for the operation of the utility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fClerk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the recording and recordkeeping officer of a city regardless of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCouncil\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the governing body of a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCouncil member\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a member of a council, including an alderman.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible elector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as it is defined in }}}{{\f5\fs18\hyphpar0\qj{section 39.3, subsection 6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGovernmental body\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the United States of America or an agency thereof, a state, a political subdivision of a state, a school corporation, a public authority, a public district, or any other public body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMay\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ confers a power.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMeasure\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an ordinance, amendment, resolution, or motion.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMust\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ states a requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOfficer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a natural person elected or appointed to a fixed term and exercising some portion of the power of a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOrdinance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a city law of a general and permanent nature.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPerson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual, firm, partnership, domestic or foreign corporation, company, association or joint stock association, trust, or other legal entity, and includes a trustee, receiver, assignee, or similar representative thereof, but does not include a governmental body.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProperty\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freal property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpersonal property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ have the same meaning as provided in }}}{{\f5\fs18\hyphpar0\qj{section 4.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecorded vote\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a record, roll call vote.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRegistered voter\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as it is defined in }}}{{\f5\fs18\hyphpar0\qj{section 39.3, subsection 11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fResolution\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmotion\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a council statement of policy or a council order for action to be taken, but \u8220\'3fmotion\u8221\'3f does not require a recorded vote.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSecretary\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of a utility board means the recording and recordkeeping officer of the utility board regardless of title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fShall\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ imposes a duty.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C50, \'a7391A.1; C54, 58, 62, 66, 71, 73, \'a7363A.2, 391A.1; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7362.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1206, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 153, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1169, \'a765}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 63, \'a72, 8}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728J.1}}}{{\f5\fs12\hyphpar0\qj{, 29D.2}}}{{\f5\fs12\hyphpar0\qj{, 169C.1}}}{{\f5\fs12\hyphpar0\qj{, 200.22}}}{{\f5\fs12\hyphpar0\qj{, 206.34}}}{{\f5\fs12\hyphpar0\qj{, 364.4}}}{{\f5\fs12\hyphpar0\qj{, 386.1}}}{{\f5\fs12\hyphpar0\qj{, 390.1}}}{{\f5\fs12\hyphpar0\qj{, 403.7}}}{{\f5\fs12\hyphpar0\qj{, 404A.1}}}{{\f5\fs12\hyphpar0\qj{, 455B.291}}}{{\f5\fs12\hyphpar0\qj{, 476C.1}}}{{\f5\fs12\hyphpar0\qj{, 478.16}}}{{\f5\fs12\hyphpar0\qj{, 592.9}}}{{\f5\fs12\hyphpar0\qj{, 717.1}}}{{\f5\fs12\hyphpar0\qj{, 717B.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Publication of notices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided by state law:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If notice of an election, hearing, or other official action is required by the city code, the notice must be published at least once, not less than four nor more than twenty days before the date of the election, hearing, or other action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A publication required by the city code must be in a newspaper published at least once weekly and having general circulation in the city. However, if the city has a population of two hundred or less, or in the case of ordinances and amendments to be published in a city in which no newspaper is published, a publication may be made by posting in three public places in the city which have been permanently designated by ordinance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the case of notices of elections, a city with a population of two hundred or less meets the publication requirement of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by posting notices of elections in three public places which have been designated by ordinance.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71133; C73, \'a7492; C97, \'a7686, 687; C24, 27, 31, 35, \'a75720, 5721, 5721-a1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5720, 5721, 5721.1;}}}{ C46, 50, \'a7366.7 \u8211\'3f 366.9; C54, 58, 62, 66, 71, 73, \'a7366.7; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7362.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 143, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1180, \'a750}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a724.2A}}}{{\f5\fs12\hyphpar0\qj{, 26.12}}}{{\f5\fs12\hyphpar0\qj{, 26.15}}}{{\f5\fs12\hyphpar0\qj{, 37.4}}}{{\f5\fs12\hyphpar0\qj{, 103A.12}}}{{\f5\fs12\hyphpar0\qj{, 330.18}}}{{\f5\fs12\hyphpar0\qj{, 336.13}}}{{\f5\fs12\hyphpar0\qj{, 336.16}}}{{\f5\fs12\hyphpar0\qj{, 364.2}}}{{\f5\fs12\hyphpar0\qj{, 364.7}}}{{\f5\fs12\hyphpar0\qj{, 364.12}}}{{\f5\fs12\hyphpar0\qj{, 368.2}}}{{\f5\fs12\hyphpar0\qj{, 368.3}}}{{\f5\fs12\hyphpar0\qj{, 368.15}}}{{\f5\fs12\hyphpar0\qj{, 368.20}}}{{\f5\fs12\hyphpar0\qj{, 372.4}}}{{\f5\fs12\hyphpar0\qj{, 372.9}}}{{\f5\fs12\hyphpar0\qj{, 372.13}}}{{\f5\fs12\hyphpar0\qj{, 376.5}}}{{\f5\fs12\hyphpar0\qj{, 380.7}}}{{\f5\fs12\hyphpar0\qj{, 380.8}}}{{\f5\fs12\hyphpar0\qj{, 380.10}}}{{\f5\fs12\hyphpar0\qj{, 384.12}}}{{\f5\fs12\hyphpar0\qj{, 384.16}}}{{\f5\fs12\hyphpar0\qj{, 384.22}}}{{\f5\fs12\hyphpar0\qj{, 384.25}}}{{\f5\fs12\hyphpar0\qj{, 384.26}}}{{\f5\fs12\hyphpar0\qj{, 384.37}}}{{\f5\fs12\hyphpar0\qj{, 384.38}}}{{\f5\fs12\hyphpar0\qj{, 384.40}}}{{\f5\fs12\hyphpar0\qj{, 384.50}}}{{\f5\fs12\hyphpar0\qj{, 384.60}}}{{\f5\fs12\hyphpar0\qj{, 384.83}}}{{\f5\fs12\hyphpar0\qj{, 386.3}}}{{\f5\fs12\hyphpar0\qj{, 392.7}}}{{\f5\fs12\hyphpar0\qj{, 400.1}}}{{\f5\fs12\hyphpar0\qj{, 403.9}}}{{\f5\fs12\hyphpar0\qj{, 404.2}}}{{\f5\fs12\hyphpar0\qj{, 404B.2}}}{{\f5\fs12\hyphpar0\qj{, 404B.3}}}{{\f5\fs12\hyphpar0\qj{, 414.3}}}{{\f5\fs12\hyphpar0\qj{, 414.4}}}{{\f5\fs12\hyphpar0\qj{, 427B.1}}}{{\f5\fs12\hyphpar0\qj{, 427B.26}}}{{\f5\fs12\hyphpar0\qj{, 476.84}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petition of eligible electors.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a petition of the voters is authorized by the city code, the petition is valid if signed by eligible electors of the city equal in number to ten percent of the persons who voted at the last preceding regular city election, but not less than ten persons, unless otherwise provided by state law. The petition shall include the signatures of the petitioners, a statement of their place of residence, and the date on which they signed the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The petition shall be examined before it is accepted for filing. If the petition appears valid on its face it shall be accepted for filing. If it lacks the required number of signatures it shall be returned to the petitioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Petitions which have been accepted for filing are valid unless written objections are filed with the city clerk within five working days after the petition is received. The objection process in }}}{{\f5\fs18\hyphpar0\qj{section 44.8}}}{{\f5\fs18\hyphpar0\qj{ shall be followed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7362.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 136, \'a770}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1180, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 54, \'a776}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a728E.17}}}{{\f5\fs12\hyphpar0\qj{, 37.2}}}{{\f5\fs12\hyphpar0\qj{, 43.112}}}{{\f5\fs12\hyphpar0\qj{, 44.8}}}{{\f5\fs12\hyphpar0\qj{, 330.17}}}{{\f5\fs12\hyphpar0\qj{, 364.2}}}{{\f5\fs12\hyphpar0\qj{, 364.4}}}{{\f5\fs12\hyphpar0\qj{, 368.3}}}{{\f5\fs12\hyphpar0\qj{, 372.4}}}{{\f5\fs12\hyphpar0\qj{, 372.6}}}{{\f5\fs12\hyphpar0\qj{, 372.11}}}{{\f5\fs12\hyphpar0\qj{, 372.13}}}{{\f5\fs12\hyphpar0\qj{, 376.2}}}{{\f5\fs12\hyphpar0\qj{, 384.7}}}{{\f5\fs12\hyphpar0\qj{, 384.24A}}}{{\f5\fs12\hyphpar0\qj{, 384.26}}}{{\f5\fs12\hyphpar0\qj{, 388.2}}}{{\f5\fs12\hyphpar0\qj{, 389.2}}}{{\f5\fs12\hyphpar0\qj{, 392.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interest in public contract prohibited }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcontract\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any claim, account, or demand against or agreement with a city, express or implied.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A city officer or employee shall not have an interest, direct or indirect, in any contract or job of work or material or the profits thereof or services to be furnished or performed for the officer\u8217\'3fs or employee\u8217\'3fs city. A contract entered into in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is void.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ do not apply to:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The payment of lawful compensation of a city officer, volunteer fire fighter as defined in }}}{{\f5\fs18\hyphpar0\qj{section 85.61}}}{{\f5\fs18\hyphpar0\qj{, emergency medical care provider as defined in }}}{{\f5\fs18\hyphpar0\qj{section 147A.1}}}{{\f5\fs18\hyphpar0\qj{, or employee holding more than one city office or position, the holding of which is not incompatible with another public office or is not prohibited by law. }}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit nominal stipends, compensation, incentives, or benefits for volunteer fire fighters or emergency medical care providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The designation of a bank or trust company as a depository, paying agent, or for investment of funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employee of a bank or trust company, who serves as treasurer of a city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts made by a city, upon competitive bid in writing, publicly invited and opened.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts in which a city officer or employee has an interest solely by reason of employment, or a stock interest of the kind described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fi\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, or both, if the contracts are made by competitive bid in writing, publicly invited and opened, or if the remuneration of employment will not be directly affected as a result of the contract and the duties of employment do not directly involve the procurement or preparation of any part of the contract. The competitive bid qualification of this paragraph does not apply to a contract for professional services not customarily awarded by competitive bid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The designation of an official newspaper.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract in which a city officer or employee has an interest if the contract was made before the time the officer or employee was elected or appointed, but the contract may not be renewed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts with volunteer fire fighters or civil defense volunteers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract with a corporation in which a city officer or employee has an interest by reason of stockholdings when less than five percent of the outstanding stock of the corporation is owned or controlled directly or indirectly by the officer or employee or the spouse or immediate family of such officer or employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts not otherwise permitted by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, for the purchase of goods or services by a city which benefit a city officer or employee, if the purchases benefiting that officer or employee do not exceed a cumulative total purchase price of six thousand dollars in a fiscal year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Franchise agreements between a city and a utility and contracts entered into by a city for the provision of essential city utility services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A contract that is a bond, note, or other obligation of the city and the contract is not acquired directly from the city, but is acquired in a transaction with a third party who may or may not be the original underwriter, purchaser, or obligee of the contract.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a71122; C73, \'a7490; C97, \'a7943; S13, \'a7668, 879-q, 1056-a31; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{5673, 6534, 6710;}}}{ C46, 50, \'a7363.47, 416.58, 420.20; C54, 58, 62, 66, 71, 73, \'a7368A.22; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7362.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1228, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 203, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1246, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1209, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 60, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1036, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 36, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7148}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 74, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 90, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7372.13}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph a amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conflict of interest.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A measure voted upon is not invalid by reason of conflict of interest in an officer of a city, unless the vote of the officer was decisive to passage of the measure. If a specific majority or unanimous vote of a municipal body is required by statute, the majority or vote must be computed on the basis of the number of officers not disqualified by reason of conflict of interest. However, a majority of all members is required for a quorum. For the purposes of }{{\f5\fs18\hyphpar0\qj{this section}}}{, the statement of an officer that the officer declines to vote by reason of conflict of interest is conclusive and must be entered of record.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, \'a7368A.25; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7362.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prior measures valid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A valid measure adopted by a city prior to July 1, 1975, remains valid unless the measure is irreconcilable with the city code.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7362.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The city code, being necessary for the public safety and welfare, shall be liberally construed to effectuate its purposes.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7362.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application of city code.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and }{{\f5\fs18\hyphpar0\qj{chapters 364}}}{, }{{\f5\fs18\hyphpar0\qj{368}}}{, }{{\f5\fs18\hyphpar0\qj{372}}}{, }{{\f5\fs18\hyphpar0\qj{376}}}{, }{{\f5\fs18\hyphpar0\qj{380}}}{, }{{\f5\fs18\hyphpar0\qj{384}}}{, }{{\f5\fs18\hyphpar0\qj{388}}}{, and }{{\f5\fs18\hyphpar0\qj{392}}}{ are applicable to all cities.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7362.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 30, \'a763}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Police officers and fire fighters.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The maximum age for a regular law enforcement officer, as defined in }{{\f5\fs18\hyphpar0\qj{section 80B.3}}}{, police officer, or marshal, employed full-time or part-time for police or law enforcement duties, or a paid professional fire fighter, employed full-time or part-time for the duty of fighting fires, is sixty-five years of age. }{{\f5\fs18\hyphpar0\qj{This section}}}{ does not apply to a reserve peace officer, as defined in }{{\f5\fs18\hyphpar0\qj{section 80D.1A}}}{, or to a volunteer fire fighter.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a76326-f6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{6326.08;}}}{ C46, 50, 54, 58, 62, \'a7411.6; C66, 71, 73, 75, 77, 79, \'a7410.6, 411.6; }{{\f5\fs18\hyphpar0\qj{C81, \'a7362.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1183, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 53, \'a71, 2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{362.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Elections on public measures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Unless otherwise stated, the dates of elections on public measures authorized in the city code are limited to those specified for cities in }{{\f5\fs18\hyphpar0\qj{section 39.2}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1115, \'a761, 71}}}\par}}