ons 514B.3B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{514B.12}}}{{\f5\fs18\hyphpar0\qj{ apply to all foreign and domestic limited service organizations authorized to do business in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flimited service organization\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an organization providing dental care services, vision care services, mental health services, substance use disorder services, pharmaceutical services, podiatric care services, or such other services as may be determined by the commissioner.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLimited service organization\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include an organization providing hospital, medical, surgical, or emergency services, except as such services are provided incident to those services identified in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 186, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 91, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1117, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71197}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7507C.3}}}{{\f5\fs12\hyphpar0\qj{, 508C.3}}}\par}}