j{ on types of contracts entered into between doctors and hospitals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health maintenance organization authorized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be considered a person for purposes of }}}{{\f5\fs18\hyphpar0\qj{chapter 507B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be applicable to a managed care organization acting pursuant to a contract with the department of health and human services to administer the medical assistance program under }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{, or the healthy and well kids in Iowa (Hawki) program under }}}{{\f5\fs18\hyphpar0\qj{chapter 514I}}}{{\f5\fs18\hyphpar0\qj{, only with respect to licensure and solvency standards as evidenced by the managed care organization obtaining and maintaining a certificate of authority, and maintaining compliance with the solvency standards set forth in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7514B.32}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 28, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 88, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1131, \'a764}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71196}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0