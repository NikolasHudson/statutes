\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F327C}{\*\bkmkend codeChapter_5F327C}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 327C}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{SUPERVISION OF CARRIERS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7307.26}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdepartment\u8221\'3f}}}{ means the department of transportation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, \'a7474.54; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.1}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71958}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General jurisdiction of department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department has general supervision of all railroads in the state, express companies, car companies, freight and freight-line companies, motor carriers, and any common carrier engaged in the transportation of passengers or freight. However, the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ regarding the supervision of carriers do not apply to regular route motor carriers of passengers or charter carriers, as defined under }{{\f5\fs18\hyphpar0\qj{section 325A.12}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72112; S13, \'a72120-n; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7874;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.10; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1161, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1100, \'a751}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a76A.21}}}{{\f5\fs12\hyphpar0\qj{, 6B.42}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Removal of interfering lights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department is hereby vested with authority to order the removal or alteration of any lights erected for illuminating purposes, whether on public or private property, when such lights interfere with the easy observation of railroad signals by those engaged in the operation of railroad trains or equipment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7874.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.11; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Inspection \u8212\'3f notice to repair.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall inspect the condition of each railroad\u8217\'3fs rail track, and may inspect the condition of each railroad\u8217\'3fs rail facilities, equipment, rolling stock, operations and pertinent records at reasonable times and in a reasonable manner to insure proper operations. Employees of the department shall have proper identification which shall be displayed upon request. If found unsafe, the department shall immediately notify the railroad corporation whose duty it is to put the same in repair, which shall be done by it within such time as the department shall fix. If any corporation fails to perform this duty the department may forbid and prevent it from running trains over the defective portion while unsafe or may regulate the speed and operation of trains moving over the defective portion of the railroad. If the railroad corporation violates any requirement provided by the department, the railroad corporation shall be subject to a schedule \u8220\'3ftwo\u8221\'3f penalty for each day the repairs have not been made from the date the department set for repairs to be completed. The court may consider the willingness and ability of the railroad corporation to cooperate in removing the safety hazard. Notwithstanding the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 669}}}{, the state shall not be held liable for damages for any act or failure to act under the provisions of }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72113; S13, \'a72113; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7875;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.12; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 87, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Schedule violations \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Violations of the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and }{{\f5\fs18\hyphpar0\qj{chapters 327D through 327G}}}{ shall be punished as a schedule \u8220\'3fone\u8221\'3f penalty unless otherwise indicated. Violations of a continuing nature shall constitute a separate offense for each violation unless otherwise provided. The schedule of violations shall be:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchedule one\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a penalty of one hundred dollars per violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchedule two\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a penalty of not less than one hundred dollars nor more than five hundred dollars per violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchedule three\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a penalty of not less than five hundred dollars nor more than one thousand dollars per violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchedule four\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a penalty of not less than five hundred dollars nor more than five thousand dollars per violation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSchedule five\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a penalty of not less than five hundred dollars nor more than five thousand dollars for the first violation and not less than five thousand dollars nor more than ten thousand dollars for each subsequent violation.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1010, \'a792}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 22, \'a770}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327F.13}}}{{\f5\fs12\hyphpar0\qj{, 327F.39}}}{{\f5\fs12\hyphpar0\qj{, 327G.32}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Changes in operation and improvements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When, in the judgment of the department, any railroad corporation fails in any respect to comply with the laws of the state; or if any railroad corporation fails to operate its railroad and business in a reasonable and expedient manner which is safe and convenient to the public, the department may order such changes as it finds to be proper and shall serve an order upon such corporation. Nothing in }{{\f5\fs18\hyphpar0\qj{this section}}}{ or }{{\f5\fs18\hyphpar0\qj{section 327C.4}}}{ shall be construed as to nullify responsibility or liability for damage to person or property by any railroad corporation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72113; S13, \'a72113; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7877;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.14; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Withdrawal of service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be unlawful for any railroad corporation owning or operating any railroad in this state, to withdraw agency service, unless it shall first have filed notice of its intention with the department and otherwise complied with the provisions of }{{\f5\fs18\hyphpar0\qj{this section}}}{ and }{{\f5\fs18\hyphpar0\qj{sections 327C.8}}}{ and }{{\f5\fs18\hyphpar0\qj{327C.9}}}{. Upon the receipt of such notice the department shall specify a notice be published and the railroad corporation shall, at its own expense, cause such notice to be published at least fifteen days in advance of the action to discontinue such agency and shall file proof of publication with the department. The notice shall be in such form as prescribed by the department and shall be published in a newspaper published in the county in which the station is located. An alternative notice procedure giving comparable public notice by registered mail to affected shippers may be prescribed by the department according to rules promulgated under }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7877.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.15; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.7}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Objections }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person directly affected by the proposed discontinuance of an agency may file written objections with the department stating the grounds for the objections, within fifteen days from the time of the publication of the notice as provided in }{{\f5\fs18\hyphpar0\qj{section 327C.7}}}{. Upon the filing of objections the department shall request the department of inspections, appeals, and licensing to hold a hearing, which shall be held within sixty days from the filing of the objections. Written notice of the time and place of the hearing shall be mailed by the department of inspections, appeals, and licensing to the railroad corporation and the person filing objections at least ten days prior to the date fixed for the hearing.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7877.2;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.16; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.8}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 273, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71985}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Order of department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon said hearing the department may prohibit the discontinuance of such agency or may make such other order as is warranted by the evidence produced at such hearing. But if no objections are filed the department may make an order permitting the railroad corporation to proceed with such discontinuance.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7877.3;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.17; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.9}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Investigation and inquiry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may investigate and inquire into the management of all common carriers subject to its jurisdiction. The department may obtain from the carriers full and complete information necessary to enable the department to perform its duties including the administration of railroad assistance agreements. The department may require the attendance and testimony of witnesses, and the production of all books, papers, tariff schedules, contracts, agreements, and documents, relating to any matter under investigation, and may inspect them; and may examine under oath or otherwise any officer, director, agent, or employee of a common carrier; and may issue subpoenas and enforce obedience to them.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72115, 2133; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7878;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.18; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.10}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71959}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.11}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.12}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Aid from courts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department or the department of inspections, appeals, and licensing may invoke the aid of any court of record in the state in requiring the attendance and testimony of witnesses and the production of books, papers, tariff schedules, agreements, and other documents. If a person refuses to obey a subpoena or other process, a court having jurisdiction of the inquiry shall issue an order requiring any of the officers, agents, or employees of a carrier or other person to appear before either department and produce all books and papers required by the order and testify in relation to any matter under investigation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72133; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7879;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.20; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.12}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 273, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71986}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Contempts, }{{\f5\fs12\hyphpar0\qj{chapter 665}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.13}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hindering or obstructing department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person who shall willfully obstruct the department in the performance of their duties, or who shall refuse to give any information within that person\u8217\'3fs possession that may be required by the department within the line of their duty, shall, upon conviction, be subject to a schedule \u8220\'3ftwo\u8221\'3f penalty.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72115; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7880;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.21; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.13}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See }{{\f5\fs12\hyphpar0\qj{\'a7327C.5}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.14}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cumulative remedies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Nothing in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or }{{\f5\fs18\hyphpar0\qj{chapter 327D}}}{ shall be construed to estop or hinder any persons from bringing action against any railway corporation for any violation of the laws of the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72118; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7882;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.23; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.15}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.16}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mandatory injunction \u8212\'3f contempt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It shall be the duty of the court in which any such cause shall be pending to require the issue to be made up within twenty days after commencement of the action and to give the same precedence over other civil business. If the court shall find that such rule, regulation, or order is reasonable and just, and that in refusing compliance therewith said railway company is neglecting and omitting the performance of any public duty or obligation, the court shall decree a mandatory and perpetual injunction, compelling obedience to and compliance with such rule, order, or regulation by said railroad company or person, its officers, agents, servants and employees, and may grant such other relief as may be deemed just and proper. All violations of such decree shall render the company, persons, officers, agents, servants and employees who are in any manner instrumental in such violation, guilty of contempt of court, and the court may punish such contempt by a fine not exceeding one thousand dollars for each offense. Such decree shall continue and remain in effect and be enforced until the rule, order, or regulation shall be modified or vacated by the department.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72119; S13, \'a72119; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7884;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.25; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.16}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.21}}}{{\f5\fs12\hyphpar0\qj{, 364.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.17}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a railroad fails or refuses to comply with a rule or order made by the state department of transportation or the department of inspections, appeals, and licensing within the time specified, the railroad is, for each day of such failure, subject to a schedule \u8220\'3ftwo\u8221\'3f penalty.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72119; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7885;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.26; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.17}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 273, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71987}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.21}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See }{{\f5\fs12\hyphpar0\qj{\'a7327C.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.18}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Time may be extended to test legality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The time for the taking effect of any rule, order, or regulation affecting public rights, made by the department, may, in its discretion, be extended; and said extension of time may be granted for the purpose of testing the legality thereof, upon application by any such aggrieved railroad, showing reasonable grounds therefor, and that said application is made in good faith and not for the purpose of delay.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72119; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7886;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.27; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.18}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.19}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A decision of the department of inspections, appeals, and licensing is subject to review by the state department of transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Judicial review of the actions of the state department of transportation may be sought in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72119; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7887;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.28; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.19}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 273, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a7150}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71988}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.20}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Remitting penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a common carrier fails in a judicial review proceeding to secure a vacation of the order objected to, it may apply to the court in which the review proceeding is finally adjudicated for an order remitting the penalty which has accrued during the review proceeding. Upon a satisfactory showing that the petition for judicial review was filed in good faith and not for the purpose of delay, and that there were reasonable grounds to believe that the order was unreasonable or unjust or that the power of the department of transportation or the department of inspections, appeals, and licensing to make the order was doubtful, the court may remit the penalty that has accrued during the review proceeding.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72119; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7888;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.29; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.20}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 273, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71989}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.21}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.21}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Costs }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ attorney fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a decree is entered against a railroad corporation or person under }{{\f5\fs18\hyphpar0\qj{sections 327C.16 through 327C.20}}}{, the court shall render judgment for costs, and attorney fees for counsel representing the state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72120; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7889;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.30; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.21}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 80, \'a7188}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.22}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interstate freight rates.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall exercise constant diligence to ascertain the rates, charges, rules, and practices of common carriers operating in this state, in relation to the transportation of freight in interstate business. When it shall ascertain from any source or have reasonable grounds to believe that the rates charged on such interstate business or the rules or practices in relation thereto discriminate unjustly against any of the citizens, industries, interests, or localities of the state, or place any of them at an unreasonable disadvantage as compared with those of other states, or are in violation of the laws of the United States regulating commerce, or in conflict with the rulings, orders, or regulations of the surface transportation board, the department shall take the necessary steps to prevent the continuance of such rates, rules, or practices.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72120-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7890;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.31; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.22}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 108, \'a759}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.23}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Application to surface transportation board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When any common carrier has put in force any rates, rules, or practices in relation to interstate freight business, in violation of the laws of the United States regulating commerce, or of the orders, rules, or regulations of the surface transportation board, or shall unjustly discriminate against any of the citizens, industries, interests, or localities of the state, the department shall present the material facts involved in such violations or discrimination to the surface transportation board and seek relief therefrom, and, if deemed necessary or expedient, the department shall prosecute any charge growing out of such violation or discrimination, at the expense of the state, before the surface transportation board.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72120-b; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7891;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.32; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.23}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 108, \'a760}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.24}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Choice of remedies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person claiming damages from a common carrier on account of any violation of the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 327D}}}{ may either make complaint to the department, or may bring action on the person\u8217\'3fs behalf for the recovery of such damages; but the person shall not have the right to pursue both of said remedies at the same time.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72131; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7892;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.33; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.24}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.25}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Complaints.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person may file with the department a petition setting forth any particular in which a common carrier has violated the law to which it is subject and the amount of damages sustained by reason of the violation. The department shall furnish a copy of the complaint to the carrier against which a complaint is filed. The department shall request the department of inspections, appeals, and licensing to schedule a hearing in which the carrier shall answer the petition or satisfy the demands of the complaint. If the carrier fails to satisfy the complaint within the time fixed or there appears to be reasonable grounds for investigating the matters set forth in the petition, the department of inspections, appeals, and licensing shall hear and determine the questions involved and make orders it finds proper. If the department of transportation has reason to believe that a carrier is violating any of the laws to which it is subject, the department may institute an investigation and request the department of inspections, appeals, and licensing to conduct a hearing in relation to the matters as if a petition had been filed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72134; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7893;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.34; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.25}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 273, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71990}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.26}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When a hearing has been held before the department of inspections, appeals, and licensing after notice, it shall make a report in writing setting forth the findings of fact and its conclusions together with its recommendations as to what reparation, if any, the offending carrier shall make to a party who has suffered damage. The findings of fact are prima facie evidence in all further legal proceedings of every fact found. All reports of hearings and investigations made by the department of inspections, appeals, and licensing shall be entered of record and a copy furnished to the carrier against which the complaint was filed, to the party complaining, and to any other person having a direct interest in the matter. A reasonable fee not to exceed the actual duplication costs may be charged for the copies.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72135; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7894;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.35; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.26}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 273, \'a725}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71991}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.27}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Orders \u8212\'3f compliance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When the department finds as the result of any investigation or hearing that a common carrier has violated or is violating any of the provisions of law to which it is subject, or that any complainant or other person has sustained damages by reason of such violation, the department shall order such carrier to cease such violation at once and shall fix a time within which it shall pay the amount of damage which has been found due to any person as a result of such violation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72136; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7895;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.36; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.27}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.28}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violation of order }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ petition }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a person violates or fails to obey a lawful order or requirement of the department of transportation or the department of inspections, appeals, and licensing, the department of transportation or the department of inspections, appeals, and licensing shall apply by petition in the name of the state against the person, to the district court, alleging the violation or failure to obey. The court shall hear and determine the matter set forth in the petition on reasonable notice to the person, to be fixed by the court and to be served in the same manner as an original notice for the commencement of action.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72137; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7896;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.37; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.28}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 273, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71992}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.29}}}{{\f5\fs12\hyphpar0\qj{, 327C.30}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Manner of service, }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0{{\f5\fs12\hyphpar0\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/ACO/CourtRulesChapter/1.pdf" }{\fldrslt \f5 \fs12{{\f5\b\fs12\hyphpar0\qj\cf5{R.C.P. 1.302 \u8211\'3f 1.315}}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.29}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Interested party may begin proceedings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person interested in enforcing an order or requirement of the department of transportation or the department of inspections, appeals, and licensing, may file a petition against the violator, alleging the failure to comply with the order or requirement and asking for summary relief to the same extent and in the same manner as the department of transportation or the department of inspections, appeals, and licensing may under }{{\f5\fs18\hyphpar0\qj{section 327C.28}}}{, and the proceedings after the filing of the petition shall be the same as in }{{\f5\fs18\hyphpar0\qj{section 327C.28}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72137; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7897;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.38; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.29}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 273, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71993}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7327C.30}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.30}}}{\*\bkmkstart stylerid1_2E34_2E2_2E2}{\*\bkmkend stylerid1_2E34_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duty of department, attorney general, and county attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When any proceeding has been instituted under }{{\f5\fs18\hyphpar0\qj{sections 327C.28}}}{ and }{{\f5\fs18\hyphpar0\qj{327C.29}}}{, the attorney general shall prosecute the same, and the county attorney of the county in which such proceeding is pending shall render such assistance as the attorney general may require.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72137; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7898;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.39; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.30}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72066, 2073}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.756(49)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.31}}}{\*\bkmkstart stylerid1_2E35_2E2_2E2}{\*\bkmkend stylerid1_2E35_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Hearing in equity \u8212\'3f injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All such causes shall be in equity, and the order or report of the department in question shall be considered prima facie evidence. If the court shall find that the order or requirement in question is lawful and has been violated, it shall issue an injunction or other proper process.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72137; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7899;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.40; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.31}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.32}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.33}}}{\*\bkmkstart stylerid1_2E37_2E2_2E2}{\*\bkmkend stylerid1_2E37_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Appeal \u8212\'3f effect.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An appeal to the supreme court shall not stay or supersede the order of the court or the execution of any writ or process thereon. When appeal is taken by the department, it shall not be required to give an appeal bond or security for costs.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72137; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7901;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.42; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.33}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.34}}}{\*\bkmkstart stylerid1_2E38_2E2_2E2}{\*\bkmkend stylerid1_2E38_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Suits by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When the department has reason to believe that any person has been guilty of unjust discrimination, the department shall cause action to be commenced against such person. Such action may be brought in the district court of any county through which the railway owned or operated by such person may extend.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72149, 2150; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7902;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.43; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.34}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 22, \'a722}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.35}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.36}}}{\*\bkmkstart stylerid1_2E4_30_2E2_2E2}{\*\bkmkend stylerid1_2E4_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rights and remedies not exclusive.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Nothing in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall abridge any rights or remedies existing at common law or by statute, but shall be in addition to such remedies.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7904;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.45; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.36}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.37}}}{\*\bkmkstart stylerid1_2E41_2E2_2E2}{\*\bkmkend stylerid1_2E41_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Accidents \u8212\'3f investigations of \u8212\'3f report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon the occurrence of any serious accident upon any railroad within this state, which shall result in personal injury, or loss of life, the corporation operating the road upon which the accident occurred shall give immediate notice thereof to the department whose duty it shall be, if they deem it necessary, to investigate the same, and promptly report to the governor the extent of the personal injuries, or loss of life, and whether the same was the result of mismanagement or neglect of the corporation on whose line the injury or loss of life occurred; but such report shall not be evidence or referred to in any case in any court.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72120-k; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7905;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.46; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.37}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.38}}}{\*\bkmkstart stylerid1_2E42_2E2_2E2}{\*\bkmkend stylerid1_2E42_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual reports from companies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall require annual reports from all common carriers subject to the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 327D}}}{ and prescribe the manner in which specific answers to all questions upon which it may need information shall be made.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a71280; C97, \'a72143; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7906;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.47; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.38}}}{]}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{327C.39 and 327C.40}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.41}}}{\*\bkmkstart stylerid1_2E44_2E2_2E2}{\*\bkmkend stylerid1_2E44_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional reports.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may also require of any and all common carriers subject to the provisions of }{{\f5\fs18\hyphpar0\qj{chapter 327D}}}{ such other reports, and fix the time for filing the same, as in its judgment shall be necessary and reasonable, which reports shall be in such form, and concerning such subjects, and be from such sources as it shall direct, except as otherwise provided herein.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72143; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7909;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.50; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.41}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.42}}}{\*\bkmkstart stylerid1_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Uniform accounts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may prescribe uniformity and methods of keeping accounts, as near as may be, and fix a time when such regulations shall take effect.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72143; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7910;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.51; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.42}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{327C.43}}}{\*\bkmkstart stylerid1_2E46_2E2_2E2}{\*\bkmkend stylerid1_2E46_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any corporation, company, or individual owning or operating a railway within the state, neglecting or refusing to make the required reports by the date fixed by rule of the department, shall, upon conviction, be subject to a schedule \u8220\'3fone\u8221\'3f penalty for each and every day of delay in making the same after the date thus fixed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a71281, 1282; C97, \'a72143; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7911;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, \'a7474.52; C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7327C.43}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See }{{\f5\fs12\hyphpar0\qj{\'a7327C.5}}}{ }\par}}