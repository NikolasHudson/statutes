\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F582}{\*\bkmkend codeChapter_5F582}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 582}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{HOSPITAL LIEN}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7602.8102(82)}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{582.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth plan\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual or group plan that provides, or pays the costs of, medical care as that term is defined in the federal Health Insurance Portability and Accountability Act of 1996, Pub. L. No. 104-191 and regulations promulgated thereunder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHospital\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a public or private institution licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProvider agreement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a contract, understanding, or arrangement made by an association, corporation, county, municipal corporation, or other institution maintaining a hospital in the state, with any health plan or other entity for the provision or payment of health care services.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 154, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 34, \'a7132}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{582.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nature of lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every association, corporation, county, municipal corporation, or other institution maintaining a hospital in the state, which shall furnish medical or other service to any patient injured by reason of an accident not covered by the workers\u8217\'3f compensation Act, shall, if such injured party shall assert or maintain a claim against another for damages on account of such injuries, have a lien upon that part going or belonging to such patient of any recovery or sum had or collected or to be collected by such patient, or by the patient\u8217\'3fs heirs or personal representatives in the case of the patient\u8217\'3fs death, whether by judgment or by settlement or compromise to the amount of the reasonable and customary charges of such hospital for the treatment, care, and maintenance of such patient in such hospital up to the date of payment of such damages, except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a patient provides proof of insurance coverage under a health plan within thirty days of the patient\u8217\'3fs discharge from a hospital, the hospital shall submit all charges to the patient\u8217\'3fs health plan prior to filing the notice of the lien pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 582.2}}}{{\f5\fs18\hyphpar0\qj{. The patient\u8217\'3fs health plan shall not deny payment for hospital services received on the basis that a third party or other insurance carrier is responsible for the patient\u8217\'3fs injuries. If the health plan denies payment for any other reason, the health plan shall nonetheless provide the hospital and the patient with a statement detailing the amount the health plan would have paid for the hospital services provided and the amount the patient would have been responsible for had the claim not been denied. In such a case, the amount of the lien shall be limited to the amount the hospital would have received if such charges were covered by the patient\u8217\'3fs health plan. A health plan\u8217\'3fs failure to provide a statement shall not affect the limitations on a hospital lien pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not prohibit a hospital from filing notice of a lien pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 582.2}}}{{\f5\fs18\hyphpar0\qj{ for the amount owed to the hospital due to patient responsibility including but not limited to deductibles, copayments, and coinsurance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at any time subsequent to the filing of the notice of the lien a hospital receives health plan information regarding a patient, the hospital shall not be required to withdraw notice of the lien but shall submit the hospital\u8217\'3fs charges to the health plan. In such a case, the amount of the hospital\u8217\'3fs lien shall be limited pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The lien shall not in any way prejudice or interfere with any lien or contract which may be made by such patient or the patient\u8217\'3fs heirs or personal representatives with any attorney or attorneys for handling the claim on behalf of such patient, the patient\u8217\'3fs heirs, or personal representatives; provided, further, that the lien shall not be applied or considered valid against a patient covered under the workers\u8217\'3f compensation Act pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapters 85}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{85A}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{85B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A hospital that recovers from a judgment, verdict, or settlement pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be responsible for the pro rata share of the legal and administrative expenses incurred in obtaining the judgment, verdict, or settlement.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a710347-f5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{10347.14;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7582.1}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 154, \'a72}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{CS2007, \'a7582.1A}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7582.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{582.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Written notice of lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No such lien shall be effective, however, unless a written notice containing the name and address of the injured person, the date of the accident, the name and location of the hospital, and the name of the person or persons, firm or firms, corporation or corporations alleged to be liable to the injured party for the injuries received, shall be filed in the office of the clerk of the district court of the county in which such hospital is located, prior to the payment of any moneys to such injured person, the person\u8217\'3fs attorneys or legal representative, as compensation for such injuries; nor unless the hospital shall also mail, postage prepaid, a copy of such notice with a statement of the date of filing thereof to the person or persons, firm or firms, corporation or corporations alleged to be liable to the injured party for the injuries sustained prior to the payment of any moneys to such injured person, the person\u8217\'3fs attorneys or legal representative, as compensation for such injuries. Such hospital shall mail a copy of such notice to any insurance carrier which has insured such person, firm or corporation against such liability, if the name and address shall be known. Such hospital shall also mail a copy of such notice to the injured person or to the injured person\u8217\'3fs attorney or legal representative, if known.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a710347-f6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{10347.15;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7582.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 154, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7582.1A}}}{{\f5\fs12\hyphpar0\qj{, 582.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{582.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duration and enforcement of lien.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person, firm, or corporation, including an insurance carrier, making any payment to such patient or to the patient\u8217\'3fs attorneys or heirs or legal representatives as compensation for the injury sustained, after the filing and mailing of such notice without paying to such hospital the amount of its lien recoverable pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 582.1A}}}{{\f5\fs18\hyphpar0\qj{ from such person, firm, or corporation or so much thereof as can be satisfied out of the moneys due under any final judgment or compromise or settlement agreement, after paying the amount of any prior liens, shall, for a period of one year from the date of payment to such patient or the patient\u8217\'3fs heirs, attorneys, or legal representatives, as aforesaid, be and remain liable to such hospital for the amount which such hospital was entitled to receive as aforesaid; any such association, corporation, or other institution maintaining such hospital may, within such period, enforce its lien by a suit at law against such person, firm, or corporation making any such payment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prior to payment by a person, firm, or corporation, including an insurance carrier, to a patient\u8217\'3fs attorney, the patient\u8217\'3fs attorney may notify the person, firm, or corporation that will be making the payment that the attorney agrees to assume responsibility for the satisfaction of some or all liens of which the person, firm, or attorney has received notice pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 582.2}}}{{\f5\fs18\hyphpar0\qj{. Upon receipt of such notification by the patient\u8217\'3fs attorney, such person, firm, or corporation shall provide the patient\u8217\'3fs attorney with copies of any lien notice relating to a hospital lien for which the attorney has agreed to assume responsibility and such person, firm, or corporation shall not thereafter be responsible to any hospital encompassed by such notification. A patient\u8217\'3fs attorney who so notifies a person, firm, or corporation and who receives a copy of any lien notice encompassed by such notification from the person, firm, or corporation shall pay such hospital the amount to which the hospital is entitled pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 582.1A}}}{{\f5\fs18\hyphpar0\qj{ from the amount received from the person, firm, or corporation. If there is a dispute concerning the amount owed to a hospital pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 582.1A}}}{{\f5\fs18\hyphpar0\qj{, a patient\u8217\'3fs attorney shall hold in trust the maximum amount to which the hospital may be entitled pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 582.1A}}}{{\f5\fs18\hyphpar0\qj{ and may disburse any other amounts to the patient, attorney, or other persons entitled to the funds. Any dispute concerning the amount owed to a hospital pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 582.1A}}}{{\f5\fs18\hyphpar0\qj{ shall be resolved by the court in which the patient filed an action to recover for the patient\u8217\'3fs injury and the court shall retain jurisdiction of the case to resolve the amount of the lien after dismissal of the action. If no such action was commenced by the patient, a court in which such action could have been brought shall have jurisdiction to determine the amount owed to the hospital.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a710347-f7; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{10347.16;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7582.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 154, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{582.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lien docket \u8212\'3f fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every clerk of the district court shall maintain a hospital lien docket in which, upon the filing of any lien claim under the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, the clerk shall enter the name of the injured person, the date of the accident, and the name of the hospital or other institution making the claim. The clerk shall make a proper index of the same in the name of the injured person and the clerk shall collect a fee in the amount provided for in }{{\f5\fs18\hyphpar0\qj{section 602.8105}}}{ for filing each lien claim.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a710347-f8; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{10347.17;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7582.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 91, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1144, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7602.8104}}}\par}}