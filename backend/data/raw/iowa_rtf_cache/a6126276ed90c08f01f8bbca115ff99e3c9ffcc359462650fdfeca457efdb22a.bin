is subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpermanent organization\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an organization that is continuing, stable, and enduring, and was originally organized for purposes other than engaging in election activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E9_2E4_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E9_2E4_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Election year defined.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3felection year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a year in which the name of the candidate or ballot issue that is expressly advocated for or against appears on any ballot to be voted on by the electors of the state of Iowa. For state and county statutory political committees, and all other political committees except for political committees that advocate for or against ballot issues, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3felection year\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a year in which primary and general elections are held.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a71137-a1, -a3; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{972, 973, 975, 976;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, \'a756.1, 56.2, 56.4, 56.5; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a756.6}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 35, \'a76 \u8211\'3f 8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 139, \'a74 \u8211\'3f 9, 14}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1023, \'a75 \u8211\'3f 9}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1224, \'a738}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 112, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 107, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 123