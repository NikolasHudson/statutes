\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F448}{\*\bkmkend codeChapter_5F448}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 448}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{TAX DEEDS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7306.22}}}{{\f5\fs12\qc{, 321.46}}}{{\f5\fs12\qc{, 331.559}}}{{\f5\fs12\qc{, 435.25}}}{{\f5\fs12\qc{, 437A.11}}}{{\f5\fs12\qc{, 437B.7}}}{{\f5\fs12\qc{, 445.1}}}{{\f5\fs12\qc{, 446.14}}}{{\f5\fs12\qc{, 446.16}}}{{\f5\fs12\qc{, 461A.25}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb0\ri1445\li1445\sa146{ }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{For definitions applicable to chapter, see }{{\f5\fs12\qc{\'a7445.1}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Return of certificate of purchase }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ execution of deed }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Immediately after the expiration of ninety days from the date of completed service of the notice provided in }}}{{\f5\fs18\hyphpar0\qj{section 447.12}}}{{\f5\fs18\hyphpar0\qj{, the county treasurer shall make out a deed for each parcel sold and unredeemed upon the return of the certificate of purchase and payment of the appropriate deed and recording fees by the purchaser. The treasurer shall record the deed with the county recorder prior to delivering the deed to the purchaser. The treasurer shall receive twenty-five dollars for each deed made by the treasurer, and the treasurer may include any number of parcels purchased by one person in one deed, if authorized by the treasurer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The tax sale certificate holder shall return the certificate of purchase and remit the appropriate deed issuance fee and recording fee to the county treasurer within ninety calendar days after the redemption period expires. The treasurer shall cancel the certificate for any tax sale certificate holder who fails to comply with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to certificates held by a county. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ is applicable to all certificates of purchase issued before, on, or after July 1, 1997. Holders of certificates of purchase that are outstanding on July 1, 1997, shall return the certificate of purchase and remit the appropriate deed issuance fee to the county treasurer within ninety calendar days from that date.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7503, 504; R60, \'a7781, 782; C73, \'a7895; C97, \'a71442; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7284;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7100}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 121, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1085, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a753}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.552}}}{{\f5\fs12\hyphpar0\qj{, 420.241}}}{{\f5\fs12\hyphpar0\qj{, 446.19A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Acquisition of title by municipal corporations, }{{\f5\fs12\hyphpar0\qj{chapter 569}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Deeds executed by the county treasurer shall be substantially in the following form:}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{KNOW ALL PERSONS BY THESE PRESENTS, that the following described parcel:}{{\f5\fs18\hyphpar0\qj{\~\~}}}{(Here follows the description), situated in the county of }{{\f5\fs18\hyphpar0\qj{................................}}}{ and state of Iowa, was subject to taxes for the year (or years) A.D.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{............}}}{, and the taxes on the parcel for the year (or years) stated remained due and unpaid at the date of the sale; and the treasurer of the county, on the }{{\f5\fs18\hyphpar0\qj{....................}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{, A.D.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{............}}}{, by virtue of the authority vested by law in the treasurer, at (an adjournment of) the sale begun and publicly held on the third Monday of June, A.D.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{............}}}{, exposed to public sale at the office of the county treasurer in the county named, in substantial conformity with all the requirements of the statute, the parcel described, for the payment of the total amount then due and remaining unpaid on the parcel, and at that time and place }{{\f5\fs18\hyphpar0\qj{....................}}}{, of the county of }{{\f5\fs18\hyphpar0\qj{....................}}}{ and state of }{{\f5\fs18\hyphpar0\qj{....................}}}{, offered to pay the sum of }{{\f5\fs18\hyphpar0\qj{............................}}}{ dollars and }{{\f5\fs18\hyphpar0\qj{............................}}}{ cents, being the total amount then due and remaining unpaid on the parcel, for (here follows the description of the parcel sold) which was the least quantity bid for, and payment of that sum was made by that person to the treasurer, the parcel was stricken off to that person at that price; and }{{\f5\fs18\hyphpar0\qj{............................}}}{ did, on the }{{\f5\fs18\hyphpar0\qj{....................}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{, A.D.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{............}}}{, assign the certificate of the sale of the parcel and all right, title, and interest to the parcel to }{{\f5\fs18\hyphpar0\qj{........................}}}{ of the county of }{{\f5\fs18\hyphpar0\qj{....................}}}{ and state of }{{\f5\fs18\hyphpar0\qj{....................}}}{; and by the affidavit of }{{\f5\fs18\hyphpar0\qj{............................}}}{, filed in the treasurer\u8217\'3fs office on the }{{\f5\fs18\hyphpar0\qj{....................}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{, A.D.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{............}}}{, it appears that notice has been given more than ninety days before the execution of this deed to }{{\f5\fs18\hyphpar0\qj{........................}}}{ and }{{\f5\fs18\hyphpar0\qj{........................}}}{ of the expiration of the time of redemption allowed by law; and two years have elapsed since the date of the sale, and the parcel has not been redeemed:}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{Now, I, }{{\f5\fs18\hyphpar0\qj{........................}}}{, treasurer of the county, for the consideration of the stated sum paid to the treasurer and by virtue of law, have granted, bargained, and sold, and by these presents do grant, bargain, and sell to }{{\f5\fs18\hyphpar0\qj{................................}}}{ (or }{{\f5\fs18\hyphpar0\qj{................................}}}{), and that person\u8217\'3fs heirs and assigns, the parcel described, to have and to hold unto that person (or }{{\f5\fs18\hyphpar0\qj{........................}}}{), and that person\u8217\'3fs heirs and assigns, forever; subject, however, to all the rights of redemption provided by law. In witness whereof, I, }{{\f5\fs18\hyphpar0\qj{........................}}}{, treasurer of }{{\f5\fs18\hyphpar0\qj{........................}}}{ county, by virtue of the authority vested in me, have subscribed my name on this }{{\f5\fs18\hyphpar0\qj{........}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{, A.D.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{............}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{....................................}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Treasurer}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{State of Iowa,}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{........................}}}{ County.}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{) ss.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{I certify that before me, }{{\f5\fs18\hyphpar0\qj{........................}}}{, in and for said county, personally appeared the above named }{{\f5\fs18\hyphpar0\qj{........................}}}{, treasurer of the county, personally known to me to be the treasurer of the county at the date of the execution of the above conveyance, and to be the identical person whose name is affixed to and who executed the above conveyance as treasurer of the county, and acknowledged the execution of the conveyance to be the treasurer\u8217\'3fs voluntary act and deed as treasurer of the county, for the purposes expressed in the conveyance.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{Given under my hand (and seal) this }{{\f5\fs18\hyphpar0\qj{................}}}{ day of }{{\f5\fs18\hyphpar0\qj{........................}}}{, A.D.}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{............}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{....................................}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7783; C73, \'a7896; C97, \'a71443; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7285;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.2}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 101, \'a792}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7101}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1058, \'a741}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.243}}}{{\f5\fs12\hyphpar0\qj{, 448.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Execution and effect of deed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The deed shall be signed by the county treasurer as such, and acknowledged by the treasurer before some officer authorized to take acknowledgments, and when substantially thus executed and recorded in the proper record in the office of the recorder of the county in which the parcel is situated, shall vest in the purchaser all the right, title, interest, and claim of the state and county to the parcel, and all the right, title, interest, and estate of the former owner in and to the parcel conveyed. However, the deed is subject to all restrictive covenants, resulting from prior conveyances in the chain of title to the former owner, and subject to all the right and interest of a holder of a certificate of purchase from a tax sale occurring after the tax sale for which the deed was issued. The issuance of the deed shall operate to cancel all suspended taxes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the event that an owner of record or a person in whose name the parcel is taxed establishes that such person was not served with notice of expiration of right of redemption in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 447.9}}}{{\f5\fs18\hyphpar0\qj{, then the county treasurer\u8217\'3fs deed is void, subject to the provisions of }}}{{\f5\fs18\hyphpar0\qj{sections 448.15}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{448.16}}}{{\f5\fs18\hyphpar0\qj{. If a person entitled to service of notice under }}}{{\f5\fs18\hyphpar0\qj{section 447.9}}}{{\f5\fs18\hyphpar0\qj{, other than an owner of record or a person in whose name the parcel is taxed, establishes that such person was not served with notice in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 447.9}}}{{\f5\fs18\hyphpar0\qj{, the deed is not thereby rendered invalid. However, the deed is subject to all of the right and interest of such person not served with notice, as provided in }}}{{\f5\fs18\hyphpar0\qj{sections 448.15}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{448.16}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7503; R60, \'a7784; C73, \'a7897; C97, \'a71444; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7286;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7102}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 57, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 121, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1050, \'a71, 2}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.244}}}{{\f5\fs12\hyphpar0\qj{, 448.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presumptive evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The deed shall be presumptive evidence in all the courts of this state in all controversies and actions in relation to the rights of the purchaser, and the purchaser\u8217\'3fs heirs or assigns, to the parcel conveyed, of the following facts:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the parcel conveyed was subject to taxes for the year or years stated in the deed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the taxes were not paid at any time before the sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the parcel conveyed had not been redeemed from the sale at the date of the deed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the parcel had been listed and assessed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the taxes were levied or set according to law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the parcel was duly advertised for sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the parcel was sold as stated in the deed.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7503; R60, \'a7784; C73, \'a7897; C97, \'a71444; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7287;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7103}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.244}}}{{\f5\fs12\hyphpar0\qj{, 448.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conclusive evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The deed shall be conclusive evidence of the following facts:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the manner in which the listing, assessment, levy, notice and sale were conducted was in all respects as the law directed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the grantee named in the deed was the purchaser.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That all the prerequisites of the law were complied with by all the officers who had, or whose duty it was to have had, any part or action in any transaction relating to or affecting the title conveyed or purporting to be conveyed by the deed, from the listing and valuation of the parcel up to the execution of the deed, both inclusive, and that all things required by law to make a good and valid sale and to vest the title in the purchaser were done, except in regard to the points named in }}}{{\f5\fs18\hyphpar0\qj{section 448.4}}}{{\f5\fs18\hyphpar0\qj{ for which the deed shall be presumptive evidence only.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7503; R60, \'a7784; C73, \'a7897; C97, \'a71444; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7288;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.5}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7104}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.244}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Action to challenge treasurer\u8217\'3fs deed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A deed executed by the county treasurer in conformity with the requirements of }}}{{\f5\fs18\hyphpar0\qj{sections 448.2}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{448.3}}}{{\f5\fs18\hyphpar0\qj{ shall be presumed to effect a valid title conveyance, and the treasurer\u8217\'3fs deed may be challenged only by an equitable action in the district court in the county in which the parcel is located. If the action seeks an order of the court to allow redemption after delivery of the treasurer\u8217\'3fs deed because the person seeking to redeem is a person with a legal disability who was entitled to redeem prior to the delivery of the treasurer\u8217\'3fs deed, the action shall be brought in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 447.7}}}{{\f5\fs18\hyphpar0\qj{. If the action seeks an order of the court to allow redemption after delivery of the treasurer\u8217\'3fs deed based on improper service of notice of expiration of right of redemption, the action shall be brought in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 447.8}}}{{\f5\fs18\hyphpar0\qj{. If the action is not brought under }}}{{\f5\fs18\hyphpar0\qj{section 447.7}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{447.8}}}{{\f5\fs18\hyphpar0\qj{, the action shall be controlled by the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be permitted to maintain the action unless the person establishes that the person, or the person under whom the person claims title, had title to the parcel at the time of the sale, or that the title was obtained from the United States or this state after the sale, and that all amounts due upon the parcel for the applicable tax years have been paid by that person or by the person under whom that person claims title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person maintaining the action shall name as defendants the holder of the tax title and the treasurer of the county in which the parcel is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person challenging the deed shall be required to prove, in order to invalidate the deed, any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the parcel was not subject to taxes for the year or years named in the deed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the taxes had been paid before the sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the parcel had been redeemed from the sale and that the redemption was made for the use and benefit of persons having the right of redemption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That there had been an entire omission to list or assess the parcel, or to levy the taxes, or to give notice of the sale, or to sell the parcel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines that the person challenging the treasurer\u8217\'3fs deed has established one or more of the elements required under }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ to be proven in order to invalidate the deed, the court shall enter judgment declaring the deed to be invalid. The judgment shall order the treasurer to refund to the person claiming under the tax title all sums paid to the treasurer for the purchase of the tax sale certificate and for any subsequent taxes paid by the certificate holder. If the person claiming under the tax title is determined by the court to have made improvements to the parcel, the court shall enter judgment in favor of the person claiming under the tax title for an amount equal to the value of such improvements made after the treasurer\u8217\'3fs deed was issued, and such judgment shall be a lien on the parcel until paid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an affidavit is filed pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 448.15}}}{{\f5\fs18\hyphpar0\qj{, and if the time period for filing a claim under }}}{{\f5\fs18\hyphpar0\qj{section 448.16}}}{{\f5\fs18\hyphpar0\qj{ expires with no claims having been filed, all persons are thereafter barred and estopped from commencing an action under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7503; R60, \'a7784; C73, \'a7897; C97, \'a71445; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7289;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7105}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 34, \'a721, 26}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1039, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}{{\f5\fs12\hyphpar0\qj{, 448.12}}}{{\f5\fs12\hyphpar0\qj{, 448.16}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{\u8220\'3fPerson with a legal disability\u8221\'3f defined, see }{{\f5\fs12\hyphpar0\qj{\'a7445.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional facts necessary.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2005/CH0034.pdf" }{\fldrslt \cf5 \f5 \fs18{{2005 Acts, ch 34, \'a725, 26}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{\'a7448.6}}}{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale made by mistake.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If an amount due was paid, and through mistake in the entry made in the county system, the parcel was afterward sold, the treasurer\u8217\'3fs deed does not convey the title.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7784; C73, \'a7897; C97, \'a71445; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7291;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7107}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Fraudulent sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the owner of a parcel sold for taxes resists the validity of the tax title, the owner may prove fraud committed by the officer selling the parcel, or in the purchaser, to defeat the title, and, if fraud is established, the sale and title shall be void.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7784; C73, \'a7897; C97, \'a71445; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7292;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7108}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Wrongful sales \u8212\'3f purchaser indemnified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If, by mistake or wrongful act of the county treasurer, a parcel has been sold on which no tax was due at the time, or when a parcel is sold in consequence of error in describing it within the county system, the county shall hold the purchaser harmless by paying the purchaser the amount due to which the purchaser would have been entitled had the parcel been rightfully sold, and the treasurer and the treasurer\u8217\'3fs surety shall be liable to the county to the amount of the treasurer\u8217\'3fs official bond; or the purchaser, or the purchaser\u8217\'3fs assignee, may recover the amount directly from the treasurer and the treasurer\u8217\'3fs surety.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a7509; R60, \'a7785; C73, \'a7899; C97, \'a71446; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7293;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7109}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}{{\f5\fs12\hyphpar0\qj{, 420.246}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Correcting wrongful sale.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{When it is made known to the county treasurer, before the execution of a deed for a parcel sold, or if the deed is returned by the purchaser, that a parcel was sold which was not subject to taxation, or upon which the taxes had been paid, the treasurer shall make an entry in the county system that the parcel was erroneously sold, and the entry shall be evidence of the fact, and the purchase money shall be refunded to the purchaser.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7789; C73, \'a7901; C97, \'a71447; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7294;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7110}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}{{\f5\fs12\hyphpar0\qj{, 420.246}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Limitation of actions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An action under }{{\f5\fs18\hyphpar0\qj{section 447.8}}}{ or }{{\f5\fs18\hyphpar0\qj{448.6}}}{ or for the recovery of a parcel sold for the nonpayment of taxes shall not be brought after three years from the execution and recording of the county treasurer\u8217\'3fs deed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7790; C73, \'a7902; C97, \'a71448; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7295;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.12}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 21, \'a744}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7111}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1016, \'a734}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1129, \'a7113}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 34, \'a722, 26}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}{{\f5\fs12\hyphpar0\qj{, 420.246}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.13}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cancellation of tax sale and certificate of purchase }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ refund of purchase money.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the county treasurer receives a verified statement from a city or county stating that a parcel sold at tax sale contains a building that is abandoned, as those terms are defined in }{{\f5\fs18\hyphpar0\qj{section 657A.1}}}{, prior to redemption of the parcel under }{{\f5\fs18\hyphpar0\qj{chapter 447}}}{ or the issuance of a tax deed for the parcel, and the verified statement is accompanied by a petition filed by the city or county under }{{\f5\fs18\hyphpar0\qj{section 657A.10B}}}{ for title to the parcel, the county treasurer shall make an entry in the county system canceling the sale of the parcel and shall refund the purchase money to the tax sale certificate holder.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2010 Acts, ch 1050, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 55, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Officers de facto.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In all actions and controversies involving the question of title to a parcel held under a county treasurer\u8217\'3fs deed, all acts of assessors, treasurers, auditors, supervisors, and other officers de facto shall be of the same validity as acts of officers de jure.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[R60, \'a7786; C73, \'a7903; C97, \'a71449; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{7296;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.14}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7112}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7420.245}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.15}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Affidavit by tax-title holder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After taking possession of the parcel, after the issuance and recording of a tax deed or an instrument purporting to be a tax deed issued by a county treasurer of this state, the then owner or holder of the title or purported title may file with the county recorder of the county in which the parcel is located an affidavit substantially in the following form:}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{State of Iowa,}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{)}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{........................}}}{ County.}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{)}{{\f5\fs18\hyphpar0\qj{\~\~}}}{ss.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{I, }{{\f5\fs18\hyphpar0\qj{....................................}}}{, being first duly sworn, on oath depose and say that on }{{\f5\fs18\hyphpar0\qj{........................}}}{ (date) the county treasurer issued a tax deed to }{{\f5\fs18\hyphpar0\qj{............................}}}{ (grantee) for the following described parcel:}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{....................................................}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{that the tax deed was filed for record in the office of the county recorder of }{{\f5\fs18\hyphpar0\qj{........................}}}{ county, Iowa, on }{{\f5\fs18\hyphpar0\qj{........................}}}{ (date), and appears in the records of that office in }{{\f5\fs18\hyphpar0\qj{........................}}}{ county as document reference number }{{\f5\fs18\hyphpar0\qj{................}}}{; and that }{{\f5\fs18\hyphpar0\qj{................}}}{ claims title to an undivided }{{\f5\fs18\hyphpar0\qj{................}}}{ percent interest in the parcel by virtue of the tax deed, or purported tax title.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person claiming any right, title, or interest in or to the parcel adverse to the title or purported title by virtue of the tax deed referred to shall file a claim with the recorder of the county where the parcel is located, within one hundred twenty days after the filing of this affidavit, the claim to set forth the nature of the interest, also the time and manner in which the interest claimed was acquired. A person who files such a claim shall commence an action to enforce the claim within sixty days after the filing of the claim. If a claimant fails to file a claim within one hundred twenty days after the filing of this affidavit, or files a claim but fails to commence an action to enforce the claim within sixty days after the filing of the claim, the claim thereafter shall be forfeited and canceled without any further notice or action, and the claimant thereafter shall be forever barred and estopped from having or claiming any right, title, or interest in the parcel adverse to the tax title or purported tax title.}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{................................................................................}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~}}}{Subscribed and sworn to before me this }{{\f5\fs18\hyphpar0\qj{................}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{day of }{{\f5\fs18\hyphpar0\qj{........................}}}{ (month), }{{\f5\fs18\hyphpar0\qj{............}}}{ (year).}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{....................................................}}}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Notary Public in and for}\par}{\pard\plain\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{........................}}}{ County, Iowa.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner or holder of a title or purported title who has entered into a lease agreement conveying possessory rights in the parcel to a tenant in possession shall be deemed to be in possession for purposes of filing an affidavit under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, if a tax deed or instrument purporting to be a tax deed has been issued to convey an undivided interest in the parcel of less than one hundred percent, the owner or holder of the tax title or purported tax title shall be deemed to be in possession and entitled to file the affidavit in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. However, before filing the affidavit, the owner or holder of the tax title or purported tax title shall serve a copy of the affidavit on any other person in possession of the parcel by sending a copy of the affidavit by both regular and certified mail to the person at the address of the parcel or at the person\u8217\'3fs last known address if different from the address of the parcel. Such service is deemed completed when the affidavit mailed by certified mail is postmarked for delivery. An affidavit of service shall be attached to, and filed with, the affidavit in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The affidavit of service shall include the names and addresses of all persons served and the time of mailing.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.15}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7113}}}{; }{{\f5\fs18\hyphpar0\qj{95 Acts, ch 57, \'a723}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1058, \'a756}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 34, \'a723, 26}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 101, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7447.7}}}{{\f5\fs12\hyphpar0\qj{, 447.8}}}{{\f5\fs12\hyphpar0\qj{, 448.3}}}{{\f5\fs12\hyphpar0\qj{, 448.6}}}{{\f5\fs12\hyphpar0\qj{, 448.16}}}{{\f5\fs12\hyphpar0\qj{, 448.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.16}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Claims adverse to tax title barred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the affidavit described in }}}{{\f5\fs18\hyphpar0\qj{section 448.15}}}{{\f5\fs18\hyphpar0\qj{ is filed it shall be notice to all persons, and any person claiming any right, title, or interest in or to the parcel described adverse to the title or purported title by virtue of the tax deed referred to, shall file a claim with the county recorder of the county in which the parcel is located within one hundred twenty days after the filing of the affidavit, which claim shall set forth the nature of the interest, the time when and the manner in which the interest was acquired.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the expiration of the period of one hundred twenty days, if no such claim has been filed, the validity of the tax title or purported tax title shall be conclusively established as a matter of law, and all persons shall thereafter be forever barred and estopped from having or claiming any right, title, or interest in the parcel adverse to the tax title or purported tax title, including but not limited to any claim alleging improper service of notice of expiration of right of redemption. An action shall not thereafter be brought to challenge the tax deed or tax title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action to enforce a claim filed under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be commenced within sixty days after the date of filing the claim. The action may be commenced by the claimant, or a person under whom the claimant claims title, under section }}}{{\f5\fs18\hyphpar0\qj{447.7}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{447.8}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{448.6}}}{{\f5\fs18\hyphpar0\qj{. If an action by the claimant, or such other person, is not filed within sixty days after the filing of the claim, the claim thereafter shall be forfeited and canceled without any further notice or action, and the claimant, or the person under whom the claimant claims title, thereafter shall be forever barred and estopped from having or claiming any right, title, or interest in the parcel adverse to the tax title or purported tax title.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.16}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7114}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 34, \'a724, 26}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1039, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7447.7}}}{{\f5\fs12\hyphpar0\qj{, 447.8}}}{{\f5\fs12\hyphpar0\qj{, 448.3}}}{{\f5\fs12\hyphpar0\qj{, 448.6}}}{{\f5\fs12\hyphpar0\qj{, 448.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.17}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Indexing and recording of affidavits and claims.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{All affidavits and claims as provided for in }{{\f5\fs18\hyphpar0\qj{sections 448.15}}}{ and }{{\f5\fs18\hyphpar0\qj{448.16}}}{, filed with the county recorder, shall be recorded as other instruments affecting parcels, and the entries required in those sections and any applicable entries specified in }{{\f5\fs18\hyphpar0\qj{sections 558.49}}}{ and }{{\f5\fs18\hyphpar0\qj{558.52}}}{ shall be indexed by the recorder.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7448.17}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 191, \'a7115}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 101, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.602}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{448.17A}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbook\u8221\'3f}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flist\u8221\'3f}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frecord\u8221\'3f}}}{, or }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschedule\u8221\'3f}}}{ kept by a county auditor, assessor, treasurer, recorder, sheriff, or other county officer means the county system as defined in }{{\f5\fs18\hyphpar0\qj{section 445.1}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1148, \'a71}}}\par}}