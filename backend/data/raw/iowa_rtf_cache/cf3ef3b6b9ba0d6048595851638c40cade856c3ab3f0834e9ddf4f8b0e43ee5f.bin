18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcooperative association\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An association organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 497}}}{{\f5\fs18\hyphpar0\qj{, regardless of whether it is referred to as an \u8220\'3fassociation\u8221\'3f, \u8220\'3fcompany\u8221\'3f, \u8220\'3fcorporation\u8221\'3f, \u8220\'3fexchange\u8221\'3f, \u8220\'3fsociety\u8221\'3f, or \u8220\'3funion\u8221\'3f as provided in that chapter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cooperative association organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 498}}}{{\f5\fs18\hyphpar0\qj{, regardless of whether it is referred to as an \u8220\'3fassociation\u8221\'3f, \u8220\'3fexchange\u8221\'3f, \u8220\'3fsociety\u8221\'3f, or \u8220\'3funion\u8221\'3f as provided in that chapter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A cooperative association may elect to be governed by and to comply with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The election shall be governed by the following procedures:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors and members must adopt a resolution reciting that the cooperative association elects to be governed by and to comply with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The cooperative association, to the extent necessary, shall change its name to comply with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The resolution shall be adopted according to the same procedures as provided in }}}{{\f5\fs18\hyphpar0\qj{section 499.41}}}{{\f5\fs18\hyphpar0\qj{. Upon the adoption of the resolution, the cooperative association shall execute an instrument on forms prescribed by the secretary of state. The instrument must be signed by the president and secretary and verified by one of the officers signing the instrument. The instrument shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the cooperative association, before and after this election.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A description of each resolution adopted by the cooperative association pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, including the date each resolution was adopted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The instrument shall be filed with the secretary of state. The cooperative association shall amend its articles of incorporation pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 499.41}}}{{\f5\fs18\hyphpar0\qj{ to comply with the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The secretary of state shall not file the instrument unless the cooperative association organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 497}}}{{\f5\fs18\hyphpar0\qj{ is in compliance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 497}}}{{\f5\fs18\hyphpar0\qj{ at the time of filing. The secretary of state shall not file the instrument unless the cooperative association organized under }}}{{\f5\fs18\hyphpar0\qj{chapter 498}}}{{\f5\fs18\hyphpar0\qj{ is in compliance with the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 498}}}{{\f5\fs18\hyphpar0\qj{ at the time of filing. A cooperative association shall file a biennial report which is due pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 499.49}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon filing the instrument with the secretary as required in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, all of the following shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The cooperative association shall be deemed to be organized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall apply to the cooperative association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The secretary of state shall issue a certificate to the cooperative association acknowledging that it is deemed to be organized under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The application of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the cooperative association does not affect any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\q