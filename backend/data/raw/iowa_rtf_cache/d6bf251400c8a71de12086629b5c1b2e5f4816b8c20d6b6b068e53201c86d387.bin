\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F25B}{\*\bkmkend codeChapter_5F25B}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 25B}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{STATE MANDATES \u8212\'3f FUNDING REQUIREMENTS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7618.11}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Implementation of new or revised federal block grants affecting political subdivisions; see }{{\f5\fs12\qc{\'a78.41}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{25B.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState Mandates Act\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 142, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{25B.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Findings and purpose \u8212\'3f effect of unfunded state mandate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly finds that preceding actions of state government in specifying the manner, standards, and conditions under which public services are rendered to citizens by the political subdivisions of this state in some cases have not resulted in equitable relationships between the state government and its political subdivisions. Some state actions have dealt in detail with the internal management of the political subdivisions; some have specified the establishment of new services and facilities without providing new revenue sources or financial participation by the state to meet the additional costs; and other actions have specified the adoption of higher service standards without a complete assessment of the impact on the expenditures and tax rates of the political subdivisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{It is the purpose of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to enunciate policies, criteria, and procedures to govern future state-initiated specification of local government services, standards, employment conditions, and retirement benefits that necessitates increased expenditures by political subdivisions or agencies and entities which contract with a political subdivision to provide services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, on or after July 1, 1994, a state mandate is enacted by the general assembly, or otherwise imposed, on a political subdivision and the state mandate requires a political subdivision to engage in any new activity, to provide any new service, or to provide any service beyond that required by any law enacted prior to July 1, 1994, and the state does not appropriate moneys to fully fund the cost of the state mandate, the political subdivision is not required to perform the activity or provide the service and the political subdivision shall not be subject to the imposition of any fines or penalties for the failure to comply with the state mandate unless the legislation specifies the amount or proportion of the cost of the state mandate which the state shall pay annually. However, }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ does not apply to any requirement imposed on a political subdivision relating to public employee retirement systems under }}}{{\f5\fs18\hyphpar0\qj{chapters 97B}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{410}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{411}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, any requirement originating from the federal government and administered, implemented, or enacted by the state, or any allocation of federal moneys conditioned upon enactment of a state law or rule, is not a state mandate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpolitical subdivision\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes community colleges and area education agencies.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 142, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1173, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7201}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{25B.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, unless the context otherwise requires:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPolitical subdivision\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a city, county, township, or school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fState mandate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a statutory requirement or appropriation which requires a political subdivision of the state to establish, expand, or modify its activities in a manner which necessitates additional combined annual expenditures of local revenue by all affected political subdivisions of at least one hundred thousand dollars, or additional combined expenditures of local revenue by all affected political subdivisions within five years of enactment of five hundred thousand dollars or more, excluding an order issued by a court of this state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 142, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1123, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1173, \'a73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{25B.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State mandate information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director of the department of management shall report at least biennially to the governor and the general assembly regarding the administration of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ including any proposed changes.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 142, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{25B.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Cost estimates \u8212\'3f notation in Acts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a bill or joint resolution is requested, the legislative services agency shall make an initial determination of whether the bill or joint resolution may impose a state mandate. If a state mandate may be included, that fact shall be included in the explanation of the bill or joint resolution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a bill or joint resolution may include a state mandate, the legislative services agency shall determine if the bill or joint resolution contains a state mandate. If the bill or joint resolution contains a state mandate and is still eligible for consideration during the legislative session for which the bill or joint resolution was drafted, the legislative services agency shall prepare an estimate of the amount of costs imposed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a bill or joint resolution containing a state mandate is enacted, unless the estimate already on file with the house of origin is sufficient, the legislative services agency shall prepare a final estimate of additional local revenue expenditures required by the state mandate and file the estimate with the secretary of state for inclusion with the official copy of the bill or resolution to which it applies. A notation of the filing of the estimate shall be made in the Iowa Acts published pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 2B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 142, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1123, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 35, \'a739, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a72B.10}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{25B.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{State rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state agency or department shall not propose or adopt an administrative rule which exceeds its statutory authority by mandating expenditures by political subdivisions, or agencies and entities which contract with political subdivisions to provide services. A state administrative rule, proposed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{, which necessitates additional combined annual expenditures exceeding one hundred thousand dollars by all affected political subdivisions or agencies and entities which contract with the affected political subdivisions to provide services shall be accompanied by a fiscal impact statement outlining the costs. An affected political subdivision, or an entity representing an affected political subdivision, shall cooperate in the preparation of the fiscal impact statement. The fiscal impact statement shall be submitted to the administrative rules coordinator for publication in the Iowa administrative bulletin along with the notice of intended action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The fiscal impact statement shall also be submitted to the legislative fiscal committee of the legislative council. Beginning in the first full fiscal year after adoption of the state administrative rule, the fiscal committee shall annually prepare a report for each fiscal impact statement submitted detailing the fiscal impact of the administrative rule on the affected political subdivision, or agencies and entities which contract with the political subdivision to provide services. The report shall be transmitted to the governor and the general assembly.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 142, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 179, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1173, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1062, \'a794}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1021, \'a716}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{25B.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Funding property tax credits and exemptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Beginning with property taxes due and payable in the fiscal year beginning July 1, 1998, the cost of providing a property tax credit or property tax exemption which is enacted by the general assembly on or after January 1, 1997, shall be fully funded by the state. If a state appropriation made to fund a credit or exemption which is enacted on or after January 1, 1997, is not sufficient to fully fund the credit or exemption, the political subdivision shall be required to extend to the taxpayer only that portion of the credit or exemption estimated by the department of revenue to be funded by the state appropriation. The department of revenue shall determine by June 15 the estimated portion of the credit or exemption which will be funded by the state appropriation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement for fully funding and the consequences of not fully funding credits and exemptions under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ also apply to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Homestead tax credit pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 425.1}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{sections 425.2 through 425.13}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 425.15}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Low-income property tax credit and elderly and disabled property tax credit pursuant to }}}{{\f5\fs18\hyphpar0\qj{sections 425.16 through 425.40}}}{{\f5\fs18\hyphpar0\qj{, subject to the limitation of }}}{{\f5\fs18\hyphpar0\qj{section 425.39, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 206, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 180, \'a722, 24}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 177, \'a7124, 131}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 71, \'a724, 48 \u8211\'3f 50, 55, 56}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7425.1A}}}{{\f5\fs12\hyphpar0\qj{, 425.39}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2021 amendment to subsection 2, paragraph b applies to claims under }{{\f5\fs12\hyphpar0\qj{chapter 425, subchapter II}}}{, filed on or after January 1, 2022; }{{\f5\fs12\hyphpar0\qj{2021 Acts, ch 177, \'a7131}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendment to subsection 2, paragraph a applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a749}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 strike of former subsection 2, paragraph c applies retroactively to assessment years beginning on or after January 1, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 71, \'a756}}}\par}}