\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F4}{\*\bkmkend codeChapter_5F4}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 4}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{CONSTRUCTION OF STATUTES}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a791A.2}}}{{\f5\fs12\qc{, 91E.1}}}{{\f5\fs12\qc{, 94.1}}}{{\f5\fs12\qc{, 147.161}}}{{\f5\fs12\qc{, 162.2}}}{{\f5\fs12\qc{, 514B.1}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In the construction of the statutes, the following rules shall be observed, unless such construction would be inconsistent with the manifest intent of the general assembly, or repugnant to the context of the statute:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E5_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Appellate court.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fappellate court\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means and includes both the supreme court and the court of appeals. Where an act, omission, right, or liability is by statute conditioned upon the filing of a decision by an appellate court, the term means any final decision of either the supreme court or the court of appeals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChild\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes child by adoption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E5_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Clerk \u8212\'3f clerk\u8217\'3fs office.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fclerk\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means clerk of the court in which the action or proceeding is brought or is pending; and the words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fclerk\u8217\'3fs office\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ mean the office of that clerk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E5_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Consanguinity and affinity.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Degrees of consanguinity and affinity shall be computed according to the civil law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCourt employee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3femployee of the judicial branch\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ include every officer or employee of the judicial branch except a judicial officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E5_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Deed \u8212\'3f bond \u8212\'3f indenture \u8212\'3f undertaking.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fdeed\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is applied to an instrument conveying lands, but does not imply a sealed instrument; and the words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbond\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3findenture\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ do not necessarily imply a seal, and the word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fundertaking\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a promise or security in any form.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Executor \u8212\'3f administrator.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fexecutor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes administrator, and the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fadministrator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes executor, where the subject matter justifies such use.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E5_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Figures and words.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If there is a conflict between figures and words in expressing a number, the words govern.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E5_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Highway \u8212\'3f road.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhighway\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3froad\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ include public bridges, and may be held equivalent to the words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcounty way\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcounty road\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcommon road\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstate road\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9A.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIntellectual disability\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a diagnosis of intellectual disability or intellectual developmental disorder, global developmental delay, or unspecified intellectual disability or intellectual developmental disorder which diagnosis shall be made only when the onset of the person\u8217\'3fs condition was during the developmental period and based on an assessment of the person\u8217\'3fs intellectual functioning and level of adaptive skills. A diagnosis of intellectual disability shall be made by a licensed psychologist or psychiatrist who is professionally trained to administer the tests required to assess intellectual functioning and to evaluate a person\u8217\'3fs adaptive skills and shall be made in accordance with the criteria provided in the current version of the diagnostic and statistical manual of mental disorders published by the American psychiatric association.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9B.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInternet\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the federated international system that is composed of allied electronic communication networks linked by telecommunication channels, that uses standardized protocols, and that facilitates electronic communication services, including but not limited to use of the world wide web; the transmission of electronic mail or messages; the transfer of files and data or other electronic information; and the transmission of voice, image, and video.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9C.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInternet site\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a specific location on the internet that is determined by internet protocol numbers, by a domain name, or by both, including but not limited to domain names that use the designations \u8220\'3f.com\u8221\'3f, \u8220\'3f.edu\u8221\'3f, \u8220\'3f.gov\u8221\'3f, \u8220\'3f.org\u8221\'3f, and \u8220\'3f.net\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E5_2E16_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E16_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Issue.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fissue\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ as applied to descent of estates includes all lawful lineal descendants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E5_2E17_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E17_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Joint authority.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Words giving a joint authority to three or more public officers or other persons shall be construed as giving such authority to a majority of them, unless it be otherwise expressed in the Act giving the authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fJudicial officer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a supreme court justice, a judge of the court of appeals, a district judge, a district associate judge, an associate juvenile judge, an associate probate judge, or a magistrate. The term also includes a person who is temporarily serving as a justice, judge, or magistrate as permitted by }}}{{\f5\fs18\hyphpar0\qj{section 602.1612}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{602.9206}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{\*\bkmkstart stylerid1_2E5_2E19_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E19_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Land \u8212\'3f real estate.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fland\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and the phrases }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freal estate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3freal property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ include lands, tenements, hereditaments, and all rights thereto and interests therein, equitable as well as legal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13A.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLivestock\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes but is not limited to an animal classified as an ostrich, rhea, or emu.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMagistrate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a judicial officer appointed under }}}{{\f5\fs18\hyphpar0\qj{chapter 602, article 6, part 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{\*\bkmkstart stylerid1_2E5_2E23_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E23_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Month \u8212\'3f year \u8212\'3f A.D.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmonth\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a calendar month, and the word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fyear\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and the abbreviation }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fA.D.\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ are equivalent to the expression }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fyear of our Lord\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{\*\bkmkstart stylerid1_2E5_2E24_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E24_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Number and gender.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise specifically provided by law the singular includes the plural, and the plural includes the singular. Words of one gender include the other genders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{\*\bkmkstart stylerid1_2E5_2E25_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E25_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Numerals \u8212\'3f figures.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Roman numerals and the Arabic figures are to be taken as parts of the English language.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{\*\bkmkstart stylerid1_2E5_2E26_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E26_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Oath \u8212\'3f affirmation.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3foath\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes affirmation in all cases where an affirmation may be substituted for an oath, and in like cases the word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fswear\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3faffirm\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{\*\bkmkstart stylerid1_2E5_2E27_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E27_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Person.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise provided by law, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fperson\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means individual, corporation, limited liability company, government or governmental subdivision or agency, business trust, estate, trust, partnership or association, or any other legal entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{\*\bkmkstart stylerid1_2E5_2E28_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E28_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Personal property.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpersonal property\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ include money, goods, chattels, evidences of debt, and things in action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21A.}}}{\*\bkmkstart stylerid1_2E5_2E29_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E29_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Persons with mental illness.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpersons with mental illness\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ include persons with psychosis, persons who are severely depressed, and persons with any type of mental disease or mental disorder, except that mental illness does not refer to intellectual disability, or to insanity, diminished responsibility, or mental incompetency as defined and used in the Iowa criminal code or in the rules of criminal procedure, Iowa court rules. A person who is hospitalized or detained for treatment of mental illness shall not be deemed or presumed to be incompetent in the absence of a finding of incompetence made pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229.27}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{\*\bkmkstart stylerid1_2E5_2E3_30_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E3_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Population.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpopulation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ where used in this Code or any statute means the population shown by the latest preceding certified federal census, unless otherwise specifically provided.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPreceding\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffollowing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ when used by way of reference to a chapter or other part of a statute mean the next preceding or next following chapter or other part.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{\*\bkmkstart stylerid1_2E5_2E32_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E32_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Property.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fproperty\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes personal and real property.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{\*\bkmkstart stylerid1_2E5_2E33_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E33_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Quorum.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A quorum of a public body is a majority of the number of members fixed by statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{\*\bkmkstart stylerid1_2E5_2E34_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E34_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Repeal \u8212\'3f effect of.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The repeal of a statute, after it becomes effective, does not revive a statute previously repealed, nor affect any right which has accrued, any duty imposed, any penalty incurred, or any proceeding commenced, under or by virtue of the statute repealed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRule\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fregulation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{\*\bkmkstart stylerid1_2E5_2E36_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E36_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Seal.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where the seal of a court, public office, public officer, or public or private corporation may be required to be affixed to any paper, the word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fseal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall include an impression upon the paper alone, or upon wax, a wafer affixed to the paper, or an official stamp of a notarial officer as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 9B}}}{{\f5\fs18\hyphpar0\qj{. If the seal of a court is required, the word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fseal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may also include a visible electronic image of the seal on an electronic document.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{29.}}}{\*\bkmkstart stylerid1_2E5_2E37_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E37_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Series.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a statute refers to a series of numbers or letters, the first and the last numbers or letters are included.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{30.}}}{\*\bkmkstart stylerid1_2E5_2E38_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E38_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Shall, must, and may.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Unless otherwise specifically provided by the general assembly, whenever the following words are used in a statute enacted after July 1, 1971, their meaning and application shall be:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fshall\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ imposes a duty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmust\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ states a requirement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmay\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ confers a power.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{31.}}}{\*\bkmkstart stylerid1_2E5_2E39_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E39_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Sheriff.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsheriff\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may be extended to any person performing the duties of the sheriff, either generally or in special cases.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{32.}}}{\*\bkmkstart stylerid1_2E5_2E4_30_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E4_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{State.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstate\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when applied to the different parts of the United States, includes the District of Columbia and the territories, and the words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnited States\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may include the said district and territories.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{33.}}}{\*\bkmkstart stylerid1_2E5_2E41_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E41_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Tense.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Words in the present tense include the future.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{34.}}}{\*\bkmkstart stylerid1_2E5_2E42_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E42_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Time \u8212\'3f legal holidays.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In computing time, the first day shall be excluded and the last included, unless the last falls on Sunday, in which case the time prescribed shall be extended so as to include the whole of the following Monday. However, when by the provisions of a statute or rule prescribed under authority of a statute, the last day for the commencement of an action or proceedings, the filing of a pleading or motion in a pending action or proceedings, or the perfecting or filing of an appeal from the decision or award of a court, board, commission, or official falls on a Saturday, a Sunday, a day on which the office of the clerk of the district court is closed in whole or in part pursuant to the authority of the supreme court, the first day of January, the third Monday in January, the twelfth day of February, the third Monday in February, the last Monday in May, the fourth day of July, the first Monday in September, the eleventh day of November, the fourth Thursday in November, the twenty-fifth day of December, and the following Monday when any of the foregoing named legal holidays fall on a Sunday, and any day appointed or recommended by the governor of Iowa or the president of the United States as a day of fasting or thanksgiving, the time shall be extended to include the next day which the office of the clerk of the court or the office of the board, commission, or official is open to receive the filing of a commencement of an action, pleading or a motion in a pending action or proceeding, or the perfecting or filing of an appeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{35.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnited States\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes all the states.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{36.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fweek\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means seven consecutive days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{37.}}}{\*\bkmkstart stylerid1_2E5_2E45_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E45_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Will.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwill\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes codicils.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{38.}}}{\*\bkmkstart stylerid1_2E5_2E46_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E46_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Words and phrases.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Words and phrases shall be construed according to the context and the approved usage of the language; but technical words and phrases, and such others as may have acquired a peculiar and appropriate meaning in law, shall be construed according to such meaning.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{39.}}}{\*\bkmkstart stylerid1_2E5_2E47_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E47_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Written \u8212\'3f in writing \u8212\'3f signature.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The words }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwritten\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fin writing\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may include any mode of representing words or letters in general use, and include an electronic record as defined in }}}{{\f5\fs18\hyphpar0\qj{section 554D.103}}}{{\f5\fs18\hyphpar0\qj{. A signature, when required by law, must be made by the writing or markings of the person whose signature is required. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSignature\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes an electronic signature as defined in }}}{{\f5\fs18\hyphpar0\qj{section 554D.103}}}{{\f5\fs18\hyphpar0\qj{. If a person is unable due to a physical disability to make a written signature or mark, that person may substitute either of the following in lieu of a signature required by law:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The name of the person with a disability written by another upon the request and in the presence of the person with a disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A rubber stamp reproduction of the name or facsimile of the actual signature when adopted by the person with a disability for all purposes requiring a signature and then only when affixed by that person or another upon request and in the presence of the person with a disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{40.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The word }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fyear\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means twelve consecutive months.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a726, 2513; R60, \'a729, 4121, 4123, 4124; C73, \'a745; C97, \'a748; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{63;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{83 Acts, ch 186, \'a710002, 10201}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1151, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 9, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 43, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1153, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1047, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 146, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1189, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a7106}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1137, \'a71, 71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 33, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 69, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1019, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1050, \'a732, 60}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1131, \'a758}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a79E.2}}}{{\f5\fs12\hyphpar0\qj{, 28J.1}}}{{\f5\fs12\hyphpar0\qj{, 43.49}}}{{\f5\fs12\hyphpar0\qj{, 50.24}}}{{\f5\fs12\hyphpar0\qj{, 50.46}}}{{\f5\fs12\hyphpar0\qj{, 142C.2}}}{{\f5\fs12\hyphpar0\qj{, 163.35}}}{{\f5\fs12\hyphpar0\qj{, 203.1}}}{{\f5\fs12\hyphpar0\qj{, 203C.1}}}{{\f5\fs12\hyphpar0\qj{, 217.30}}}{{\f5\fs12\hyphpar0\qj{, 222.2}}}{{\f5\fs12\hyphpar0\qj{, 226.8}}}{{\f5\fs12\hyphpar0\qj{, 229.1}}}{{\f5\fs12\hyphpar0\qj{, 235B.2}}}{{\f5\fs12\hyphpar0\qj{, 235E.1}}}{{\f5\fs12\hyphpar0\qj{, 256H.1}}}{{\f5\fs12\hyphpar0\qj{, 347.9A}}}{{\f5\fs12\hyphpar0\qj{, 362.2}}}{{\f5\fs12\hyphpar0\qj{, 386.1}}}{{\f5\fs12\hyphpar0\qj{, 421.9}}}{{\f5\fs12\hyphpar0\qj{, 421.9A}}}{{\f5\fs12\hyphpar0\qj{, 446.16}}}{{\f5\fs12\hyphpar0\qj{, 455B.482}}}{{\f5\fs12\hyphpar0\qj{, 480.1}}}{{\f5\fs12\hyphpar0\qj{, 481B.1}}}{{\f5\fs12\hyphpar0\qj{, 486A.101}}}{{\f5\fs12\hyphpar0\qj{, 489.14102}}}{{\f5\fs12\hyphpar0\qj{, 490.140}}}{{\f5\fs12\hyphpar0\qj{, 502A.1}}}{{\f5\fs12\hyphpar0\qj{, 508B.5}}}{{\f5\fs12\hyphpar0\qj{, 514.1}}}{{\f5\fs12\hyphpar0\qj{, 514E.1}}}{{\f5\fs12\hyphpar0\qj{, 515.115}}}{{\f5\fs12\hyphpar0\qj{, 515G.5}}}{{\f5\fs12\hyphpar0\qj{, 523H.1}}}{{\f5\fs12\hyphpar0\qj{, 524.103}}}{{\f5\fs12\hyphpar0\qj{, 527.5}}}{{\f5\fs12\hyphpar0\qj{, 533.405}}}{{\f5\fs12\hyphpar0\qj{, 537A.10}}}{{\f5\fs12\hyphpar0\qj{, 543E.3}}}{{\f5\fs12\hyphpar0\qj{, 551A.1}}}{{\f5\fs12\hyphpar0\qj{, 562A.8A}}}{{\f5\fs12\hyphpar0\qj{, 562B.9A}}}{{\f5\fs12\hyphpar0\qj{, 633.552}}}{{\f5\fs12\hyphpar0\qj{, 686D.2}}}{{\f5\fs12\hyphpar0\qj{, 714.15}}}{{\f5\fs12\hyphpar0\qj{, 714E.1}}}{{\f5\fs12\hyphpar0\qj{, 715.3}}}{{\f5\fs12\hyphpar0\qj{, 716A.1}}}{{\f5\fs12\hyphpar0\qj{, 904.108}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Similar provision on population, }{{\f5\fs12\hyphpar0\qj{\'a79F.6}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Definition of \u8220\'3fspecial state agents\u8221\'3f, }{{\f5\fs12\hyphpar0\qj{\'a780.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statutory construction }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ sex and related terms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the construction of statutes, the following rules shall be observed with regard to a person\u8217\'3fs biological sex:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSex\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when used to classify or describe a natural person, means the state of being either male or female as observed or clinically verified at birth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When used in reference to a natural person, a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffemale\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who has, had, will have through the course of normal development, or would have but for a developmental anomaly, genetic anomaly, or accident, a reproductive system that at some point produces ova, and a }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmale\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual who has, had, will have through the course of normal development, or would have but for a developmental anomaly, genetic anomaly, or accident, a reproductive system that at some point produces sperm.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fwoman\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fgirl\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ refers to a female and the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fman\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fboy\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ refers to a male.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmother\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a parent who is female and the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffather\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a parent who is male.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGender\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when used alone in reference to males, females, or the natural differences between males and females shall be considered a synonym for sex and shall not be considered a synonym or shorthand expression for gender identity, experienced gender, gender expression, or gender role.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fequal\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fsame\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fidentical\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Separate accommodations are not inherently unequal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person born with a medically verifiable diagnosis of disorder or difference of sex development shall be provided the legal protections and accommodations afforded under the federal }}}{{\f5\fs18\hyphpar0\qj{Americans with Disabilities Act of 1990}}}{{\f5\fs18\hyphpar0\qj{ and applicable state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any state law, policy, or program that prohibits discrimination on the basis of sex shall be construed to forbid unfair or discriminatory practices against females or males in relation to similarly situated members of the opposite sex.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any provision of state law to the contrary, distinctions based on sex, including but not limited to in prisons or other detention facilities, domestic violence shelters, rape crisis centers, locker rooms, restrooms, and in other contexts where health, safety, or privacy are implicated resulting in separate accommodations, are substantially related to the important government objectives of protecting the health, safety, and privacy of the persons in these contexts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any state department or subunit of a department, or any political subdivision of the state including a city, county, township, or school district that collects vital statistics for the purpose of complying with state antidiscrimination laws, or for the purpose of gathering accurate state public health, crime, economic, or other data, shall identify the sex of each person included in the collected data as either male or female.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstate law\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes any state statute or rule.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 1, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7144.13}}}{{\f5\fs12\hyphpar0\qj{, 144.23}}}{{\f5\fs12\hyphpar0\qj{, 261I.1}}}{{\f5\fs12\hyphpar0\qj{, 280.33}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{NEW section}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Common law rule of construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The rule of the common law, that statutes in derogation thereof are to be strictly construed, has no application to this Code. Its provisions and all proceedings under it shall be liberally construed with a view to promote its objects and assist the parties in obtaining justice.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C51, \'a72503; R60, \'a72622; C73, \'a72528; C97, \'a73446; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{64;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{References to other statutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any statute which adopts by reference the whole or a portion of another statute of this state shall be construed to include subsequent amendments of the statute or the portion thereof so adopted by reference unless a contrary intent is expressed.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Presumption of enactment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In enacting a statute, it is presumed that:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compliance with the Constitutions of the state and of the United States is intended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The entire statute is intended to be effective.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A just and reasonable result is intended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A result feasible of execution is intended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Public interest is favored over any private interest.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prospective statutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A statute is presumed to be prospective in its operation unless expressly made retrospective.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.6}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Ambiguous statutes \u8212\'3f interpretation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a statute is ambiguous, the court, in determining the intention of the legislature, may consider among other matters:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The object sought to be attained.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The circumstances under which the statute was enacted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The legislative history.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The common law or former statutory provisions, including laws upon the same or similar subjects.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The consequences of a particular construction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The administrative construction of the statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The preamble or statement of policy.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.7}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conflicts between general and special statutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If a general provision conflicts with a special or local provision, they shall be construed, if possible, so that effect is given to both. If the conflict between the provisions is irreconcilable, the special or local provision prevails as an exception to the general provision.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.7}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a77E.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Intent of general assembly that }{{\f5\fs12\hyphpar0\qj{\'a77E.6}}}{ govern compensation of members of boards, committees, commissions, or councils except for certain provisions enacted subsequent to July 1, 1986; see }{{\f5\fs12\hyphpar0\qj{\'a77E.6(1)}}}{ and (7)}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.8}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Irreconcilable statutes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If statutes enacted at the same or different sessions of the legislature are irreconcilable, the statute latest in date of enactment by the general assembly prevails. If provisions of the same Act are irreconcilable, the provision listed last in the Act prevails.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.8}}}{]}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Code editor authority to harmonize and rules for codification of irreconcilable statutes, see also }{{\f5\fs12\hyphpar0\qj{\'a72B.13(1)(h)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.9}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Official copy prevails.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the language of the official copy of a statute conflicts with the language of any subsequent printing or reprinting of the statute, the language of the official copy prevails.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.10}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reenactment of statutes \u8212\'3f continuation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A statute which is reenacted, revised or amended is intended to be a continuation of the prior statute and not a new enactment, so far as it is the same as the prior statute.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.11}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Conflicting amendments to same statutes \u8212\'3f interpretation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If amendments to the same statute are enacted at the same or different sessions of the general assembly, one amendment without reference to another, the amendments are to be harmonized, if possible, so that effect may be given to each. If the amendments are irreconcilable, the latest in date of enactment by the general assembly prevails.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.12}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Acts or statutes are severable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any provision of an Act or statute or the application thereof to any person or circumstance is held invalid, the invalidity does not affect other provisions or applications of the Act or statute which can be given effect without the invalid provision or application, and to this end the provisions of the Act or statute are severable.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.13}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General savings provision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The reenactment, revision, amendment, or repeal of a statute does not affect any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prior operation of the statute or any prior action taken under the statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any validation, cure, right, privilege, obligation, or liability previously acquired, accrued, accorded, or incurred under the statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any violation of the statute or penalty, forfeiture, or punishment incurred in respect to the statute, prior to the amendment or repeal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any investigation, proceeding, or remedy in respect of any privilege, obligation, liability, penalty, forfeiture, or punishment; and the investigation, proceeding, or remedy may be instituted, continued, or enforced, and the penalty, forfeiture, or punishment imposed, as if the statute had not been repealed or amended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the penalty, forfeiture, or punishment for any offense is reduced by a reenactment, revision, or amendment of a statute, the penalty, forfeiture, or punishment if not already imposed shall be imposed according to the statute as amended.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a74.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1031, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7124.201}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.14}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{General rules of construction for English language laws.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{It is presumed that English language requirements in the public sector are consistent with the laws of Iowa and any ambiguity in the English language text of the laws of Iowa shall be resolved, in accordance with the }{{\f5\fs18\hyphpar0\qj{ninth and tenth amendments of the Constitution of the United States}}}{, not to deny or disparage rights retained by the people, and to reserve powers to the states or to the people.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1007, \'a72}}}\par}}