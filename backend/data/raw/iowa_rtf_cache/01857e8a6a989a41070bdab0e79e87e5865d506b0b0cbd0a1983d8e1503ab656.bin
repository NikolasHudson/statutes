\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F229A}{\*\bkmkend codeChapter_5F229A}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 229A}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{COMMITMENT OF SEXUALLY VIOLENT PREDATORS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a713B.4}}}{{\f5\fs12\qc{, 81.2}}}{{\f5\fs12\qc{, 226.1}}}{{\f5\fs12\qc{, 232.55}}}{{\f5\fs12\qc{, 235A.15}}}{{\f5\fs12\qc{, 235A.18}}}{{\f5\fs12\qc{, 692A.114}}}{{\f5\fs12\qc{, 811.1}}}{{\f5\fs12\qc{, 815.9}}}{{\f5\fs12\qc{, 815.10}}}{{\f5\fs12\qc{, 815.11}}}{{\f5\fs12\qc{, 901A.2}}}{{\f5\fs12\qc{, 915.45}}}\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{Notice to victims of discharge of committed}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\sa0\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{person, see }{{\f5\fs12\qc{\'a7915.45}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.1}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Legislative findings.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly finds that a small but extremely dangerous group of sexually violent predators exists which is made up of persons who do not have a mental disease or defect that renders them appropriate for involuntary treatment pursuant to the treatment provisions for mentally ill persons under }}}{{\f5\fs18\hyphpar0\qj{chapter 229}}}{{\f5\fs18\hyphpar0\qj{, since that chapter is intended to provide short-term treatment to persons with serious mental disorders and then return them to the community. In contrast to persons appropriate for civil commitment under }}}{{\f5\fs18\hyphpar0\qj{chapter 229}}}{{\f5\fs18\hyphpar0\qj{, sexually violent predators generally have antisocial personality features that are unamenable to existing mental illness treatment modalities and that render them likely to engage in sexually violent behavior.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly finds that sexually violent predators\u8217\'3f likelihood of engaging in repeat acts of predatory sexual violence is high and that the existing involuntary commitment procedure under }}}{{\f5\fs18\hyphpar0\qj{chapter 229}}}{{\f5\fs18\hyphpar0\qj{ is inadequate to address the risk these sexually violent predators pose to society.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The general assembly further finds that the prognosis for rehabilitating sexually violent predators in a prison setting is poor, because the treatment needs of this population are very long-term, and the treatment modalities for this population are very different from the traditional treatment modalities available in a prison setting or for persons appropriate for commitment under }}}{{\f5\fs18\hyphpar0\qj{chapter 229}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Therefore, the general assembly finds that a civil commitment procedure for the long-term care and treatment of the sexually violent predator is necessary. The procedures regarding sexually violent predators should reflect legitimate public safety concerns, while providing treatment services designed to benefit sexually violent predators who are civilly committed. The procedures should also reflect the need to protect the public, to respect the needs of the victims of sexually violent offenses, and to encourage full, meaningful participation of sexually violent predators in treatment programs.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1139, \'a71, 27}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a719}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.2}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAgency with jurisdiction\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an agency which has custody of or releases a person serving a sentence or term of confinement or is otherwise in confinement based upon a lawful order or authority, and includes but is not limited to the department of corrections, the department of health and human services, a judicial district department of correctional services, and the Iowa board of parole.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAppropriate secure facility\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a state facility that is designed to confine but not necessarily to treat a sexually violent predator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConvicted\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means found guilty of, pleads guilty to, or is sentenced or adjudicated delinquent for an act which is an indictable offense in this state or in another jurisdiction including in a federal, military, tribal, or foreign court, including but not limited to a juvenile who has been adjudicated delinquent, whether or not the juvenile court records have been sealed under }}}{{\f5\fs18\hyphpar0\qj{section 232.150}}}{{\f5\fs18\hyphpar0\qj{, and a person who has received a deferred sentence or a deferred judgment or has been acquitted by reason of insanity. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConvicted\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes the conviction of a juvenile prosecuted as an adult. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConvicted\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ also includes a conviction for an attempt or conspiracy to commit an offense. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fConvicted\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not mean a plea, sentence, adjudication, deferred sentence, or deferred judgment which has been reversed or otherwise set aside.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDirector\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the director of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDischarge\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an unconditional discharge from the sexually violent predator program. A person released from a secure facility into a transitional release program or released with supervision is not considered to be discharged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLikely to engage in predatory acts of sexual violence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that the person more likely than not will engage in acts of a sexually violent nature. If a person is not confined at the time that a petition is filed, a person is }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3flikely to engage in predatory acts of sexual violence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ only if the person commits a recent overt act.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMental abnormality\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a congenital or acquired condition affecting the emotional or volitional capacity of a person and predisposing that person to commit sexually violent offenses to a degree which would constitute a menace to the health and safety of others.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPredatory\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means acts directed toward a person with whom a relationship has been established or promoted for the primary purpose of victimization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPresently confined\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means incarceration or detention in a correctional facility, a rehabilitation camp, a residential facility, a county jail, a halfway house, or any other comparable facility, including but not limited to placement at such a facility as a condition of probation, parole, or special sentence following conviction for a sexually violent offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fRecent overt act\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any act that has either caused harm of a sexually violent nature or creates a reasonable apprehension of such harm.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSafekeeper\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is confined in an appropriate secure facility pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ but who is not subject to an order of commitment pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSexually motivated\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means that one of the purposes for commission of a crime is the purpose of sexual gratification of the perpetrator of the crime.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSexually violent offense\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of any provision of }}}{{\f5\fs18\hyphpar0\qj{chapter 709}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of any of the following if the offense involves sexual abuse, attempted sexual abuse, or intent to commit sexual abuse:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Murder as defined in }}}{{\f5\fs18\hyphpar0\qj{section 707.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Kidnapping as defined in }}}{{\f5\fs18\hyphpar0\qj{section 710.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Burglary as defined in }}}{{\f5\fs18\hyphpar0\qj{section 713.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Child endangerment under }}}{{\f5\fs18\hyphpar0\qj{section 726.6, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual exploitation of a minor in violation of }}}{{\f5\fs18\hyphpar0\qj{section 728.12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Pandering involving a minor in violation of }}}{{\f5\fs18\hyphpar0\qj{section 725.3, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An offense involving an attempt or conspiracy to commit any offense referred to in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An offense under prior law of this state or an offense committed in another jurisdiction which would constitute an equivalent offense under paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ through }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any act which, either at the time of sentencing for the offense or subsequently during civil commitment proceedings pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, has been determined beyond a reasonable doubt to have been sexually motivated.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSexually violent predator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who has been convicted of or charged with a sexually violent offense and who suffers from a mental abnormality which makes the person likely to engage in predatory acts constituting sexually violent offenses, if not confined in a secure facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fTransitional release\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a conditional release from a secure facility operated by the department with the conditions of such release set by the court or the department.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 61, \'a71, 14}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1139, \'a72, 27}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 91, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1074, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1059, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1165, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 17, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7534}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7272C.15}}}{{\f5\fs12\hyphpar0\qj{, 671A.2}}}{{\f5\fs12\hyphpar0\qj{, 692A.101}}}{{\f5\fs12\hyphpar0\qj{, 901A.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.3}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Notice of discharge of sexually violent predator \u8212\'3f immunity from liability \u8212\'3f multidisciplinary team \u8212\'3f prosecutor\u8217\'3fs review committee \u8212\'3f assessment of person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When it appears that a person who is confined may meet the definition of a sexually violent predator, the agency with jurisdiction shall give written notice to the attorney general and the multidisciplinary team established in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, no later than ninety days prior to any of the following events:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The anticipated discharge of a person who has been convicted of a sexually violent offense from total confinement, except that in the case of a person who is returned to prison for no more than ninety days as a result of revocation of parole, written notice shall be given as soon as practicable following the person\u8217\'3fs readmission to prison.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The discharge of a person who has been charged with a sexually violent offense and who has been determined to be incompetent to stand trial pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 812}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The discharge of a person who has been found not guilty by reason of insanity of a sexually violent offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If notice is given under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, the agency with jurisdiction shall inform the attorney general and the multidisciplinary team established in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, of both of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person\u8217\'3fs name, identifying factors, anticipated future residence, and offense history.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Documentation of any institutional evaluation and any treatment received.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The agency with jurisdiction, its employees, officials, members of the multidisciplinary team established in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, members of the prosecutor\u8217\'3fs review committee appointed as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 5}}}{{\f5\fs18\hyphpar0\qj{, and individuals contracting, appointed, or volunteering to perform services under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be immune from liability for any good-faith conduct under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of corrections shall establish a multidisciplinary team which may include individuals from other state agencies to review available records of each person referred to such team pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The team, within thirty days of receiving notice, shall assess whether or not the person meets the definition of a sexually violent predator. The team shall notify the attorney general of its assessment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general shall appoint a prosecutor\u8217\'3fs review committee to review the records of each person referred to the attorney general pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{. The prosecutor\u8217\'3fs review committee shall assist the attorney general in the determination of whether or not the person meets the definition of a sexually violent predator. The assessment of the multidisciplinary team shall be made available to the attorney general and the prosecutor\u8217\'3fs review committee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed as a limit on persons subject to commitment under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 17, \'a73}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229A.5A}}}{{\f5\fs12\hyphpar0\qj{, 229A.14}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.4}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petition }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ time }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ contents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it appears that a person presently confined may be a sexually violent predator and the prosecutor\u8217\'3fs review committee has determined that the person meets the definition of a sexually violent predator, the attorney general may file a petition alleging that the person is a sexually violent predator and stating sufficient facts to support such an allegation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prosecuting attorney of the county in which the person was convicted or charged, or the attorney general if requested by the prosecuting attorney, may file a petition alleging that a person is a sexually violent predator and stating sufficient facts to support such an allegation, if it appears that a person who has committed a recent overt act meets any of the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person was convicted of a sexually violent offense and is no longer presently confined for that offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person was charged with, but was acquitted of, a sexually violent offense by reason of insanity and has been released from confinement or any supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person was charged with, but was found to be incompetent to stand trial for, a sexually violent offense and has been released from confinement or any supervision.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 61, \'a72, 14}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 17, \'a74}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229A.5}}}{{\f5\fs12\hyphpar0\qj{, 229A.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.5}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Person taken into custody }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ determination of probable cause }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ hearing }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ evaluation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon filing of a petition under }}}{{\f5\fs18\hyphpar0\qj{section 229A.4}}}{{\f5\fs18\hyphpar0\qj{, the court shall make a preliminary determination as to whether probable cause exists to believe that the person named in the petition is a sexually violent predator. Upon a preliminary finding of probable cause, the court shall direct that the person named in the petition be taken into custody and that the person be served with a copy of the petition and any supporting documentation and notice of the procedures required by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. If the person is in custody at the time of the filing of the petition, the court shall determine whether a transfer of the person to an appropriate secure facility is appropriate pending the outcome of the proceedings or whether the custody order should be delayed until the date of release of the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within seventy-two hours after being taken into custody or being transferred to an appropriate secure facility, a hearing shall be held to determine whether probable cause exists to believe the detained person is a sexually violent predator. The hearing may be waived by the respondent. The hearing may be continued upon the request of either party and a showing of good cause, or by the court on its own motion in the due administration of justice, and if the respondent is not substantially prejudiced. At the probable cause hearing, the detained person shall have the following rights:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be provided with prior notice of date, time, and location of the probable cause hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To respond to the preliminary finding of probable cause.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To appear in person at the hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To be represented by counsel.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To present evidence on the respondent\u8217\'3fs own behalf.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To cross-examine witnesses who testify against the respondent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To view and copy all petitions and reports in the possession of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the hearing, the rules of evidence do not apply, and the state may rely solely upon the petition filed under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, but the state may also supplement the petition with additional documentary evidence or live testimony.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the conclusion of the hearing, the court shall enter an order which does both of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Verifies the respondent\u8217\'3fs identity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Determines whether probable cause exists to believe that the respondent is a sexually violent predator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines that probable cause does exist, the court shall direct that the respondent be transferred to an appropriate secure facility for an evaluation as to whether the respondent is a sexually violent predator. The evaluation shall be conducted by a person deemed to be professionally qualified to conduct such an examination.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 61, \'a73, 4, 14}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a73, 27}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229A.5B}}}{{\f5\fs12\hyphpar0\qj{, 229A.5C}}}{{\f5\fs12\hyphpar0\qj{, 229A.6A}}}{{\f5\fs12\hyphpar0\qj{, 229A.7}}}{{\f5\fs12\hyphpar0\qj{, 229A.12A}}}{{\f5\fs12\hyphpar0\qj{, 811.1}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.5A}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers of investigative personnel before a petition is filed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prosecuting attorney or attorney general is authorized upon the occurrence of a recent overt act, or upon receiving written notice pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229A.3}}}{{\f5\fs18\hyphpar0\qj{, or before the filing of a petition under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, to subpoena and compel the attendance of witnesses, examine the witnesses under oath, and require the production of documentary evidence for inspection, reproduction, or copying. Except as otherwise provided by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the prosecuting attorney or attorney general shall have the same powers and limitations, subject to judicial oversight and enforcement, as provided by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ and by the Iowa rules of civil procedure. Any person compelled to appear under a demand for oral testimony under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be accompanied, represented, and advised by counsel at the person\u8217\'3fs own expense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The examination of all witnesses under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be conducted by the prosecuting attorney or attorney general before an officer authorized to administer oaths under }}}{{\f5\fs18\hyphpar0\qj{section 63A.1}}}{{\f5\fs18\hyphpar0\qj{. The testimony shall be taken by a certified shorthand reporter or by a sound recording device and shall be transcribed or otherwise preserved in the same manner as provided for the preservation of depositions under the Iowa rules of civil procedure. The prosecuting attorney or attorney general may exclude from the examination all persons except the witness, witness\u8217\'3fs counsel, the officer before whom the testimony is to be taken, law enforcement officials, and a certified shorthand reporter. Prior to oral examination, the person shall be advised by the prosecuting attorney or attorney general of the person\u8217\'3fs right to refuse to answer any questions on the basis of the privilege against self-incrimination. The examination shall be conducted in a manner consistent with the rules dealing with the taking of depositions.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 61, \'a75, 14}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1058, \'a723}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.5B}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Escape from custody \u8212\'3f penalty.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is detained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229A.5}}}{{\f5\fs18\hyphpar0\qj{ or is subject to an order of civil commitment under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall remain in custody unless released by court order or discharged under }}}{{\f5\fs18\hyphpar0\qj{section 229A.8}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{229A.10}}}{{\f5\fs18\hyphpar0\qj{. A person who has been placed in a transitional release program or who is under release with supervision is considered to be in custody. A person in custody under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Leave or attempt to leave a facility without the accompaniment of authorized personnel or leave or attempt to leave a facility without authorization.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly and voluntarily be absent from a place where the person is required to be present.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Leave or attempt to leave the custody of personnel transporting or guarding the person while the person is away from a facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ commits a serious misdemeanor or may be subject to punishment for contempt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person commits a violation of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and remains unconfined, the attorney general or the chief law enforcement officer of the political subdivision where the violation occurs may make a public announcement that the person is unconfined and may provide relevant information about the person to the community. The attorney general may also notify a victim or the family of a victim of the person that the person is unconfined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit the use of other lawful means for the return of the person.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 27, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1139, \'a74, 27}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 12, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1165, \'a797}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229A.8A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.5C}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Criminal offenses committed while detained or subject to an order of commitment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person who is detained pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229A.5}}}{{\f5\fs18\hyphpar0\qj{ or who is subject to an order of civil commitment under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ commits a public offense, the civil commitment proceedings or treatment process shall be suspended until the criminal proceedings, including any term of confinement, are completed. The person shall also not be eligible for bail pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 811.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the filing of a complaint, indictment, or information, the person shall be transferred to the county jail in the county where the public offense occurred until the criminal proceedings have been completed.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person is sentenced to a term of confinement in a county jail, the person shall serve the sentence at the county jail. If the person is sentenced to the custody of the director of the department of corrections, the person shall serve the sentence at a correctional institution.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person who is subject to an order of civil commitment under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is transferred to a county jail or sentenced to a term of confinement in a county jail pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the department shall reimburse the county at a rate of fifty dollars per day for the time period the person is temporarily held after transfer or is confined in the county jail.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall use funds appropriated to the department for costs associated with the treatment and commitment of sexually violent predators in the unit located at the state mental health institute at Cherokee, or use funds transferred pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 218.6}}}{{\f5\fs18\hyphpar0\qj{, for the payment of reimbursements pursuant to subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is subject to an order of civil commitment under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall not be released from jail or paroled or released to a facility or program located outside the county jail or correctional institution other than to a secure facility operated by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who committed a public offense while in a transitional release program or on release with supervision may be returned to a secure facility operated by the department upon completion of any term of confinement that resulted from the commission of the public offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the civil commitment proceedings for a person are suspended due to the commission of a public offense by the person, the ninety-day trial demand lapses. Upon completion of any term of confinement that resulted from the commission of the public offense, a new ninety-day trial demand automatically begins.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a75, 27}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1165, \'a798}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7535}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 96, \'a71}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 2 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.5D}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Medical treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A safekeeper is entitled to necessary medical treatment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a76, 27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.6}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Counsel and experts }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ indigent persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A respondent to a petition alleging the person to be a sexually violent predator shall be entitled to the assistance of counsel upon the filing of the petition under }}}{{\f5\fs18\hyphpar0\qj{section 229A.4}}}{{\f5\fs18\hyphpar0\qj{ and, if the respondent is indigent, the court shall appoint counsel to assist the respondent at state expense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a respondent is subjected to an examination under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the respondent may retain experts or professional persons to perform an independent examination on the respondent\u8217\'3fs behalf. If the respondent wishes to be examined by a qualified expert or professional person of the respondent\u8217\'3fs own choice, the examiner of the respondent\u8217\'3fs choice shall be given reasonable access to the respondent for the purpose of the examination, as well as access to all relevant medical and psychological records and reports. If the respondent is indigent, the court, upon the respondent\u8217\'3fs request, shall determine whether the services are necessary and the reasonable compensation for the services. If the court determines that the services are necessary and the requested compensation for the services is reasonable, the court shall assist the respondent in obtaining an expert or professional person to perform an examination or participate in the trial on the respondent\u8217\'3fs behalf. The court shall approve payment for such services upon the filing of a certified claim for compensation supported by a written statement specifying the time expended, services rendered, expenses incurred on behalf of the respondent, and compensation received in the same case or for the same services from any other source.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.6A}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Transport orders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who has been detained prior to trial pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229A.5}}}{{\f5\fs18\hyphpar0\qj{ or who has been civilly committed may be transported for the following purposes:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To trial and any other court proceedings if the court has authorized a transport order. A transport order may only be requested by the court, the person\u8217\'3fs attorney, or the attorney general. Transportation shall be provided by the sheriff of the county in which the action has been brought, unless the court specifies otherwise or the parties agree to a different transportation arrangement. If a transport order is not authorized, the person may appear at any court proceedings other than trial by telephone or electronic means.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a medical facility for medical treatment, if necessary medical treatment is not available at the facility where the person is confined. A transport order is not required to transport the person for medical treatment. However, the person is not entitled to choose the medical facility where treatment is to be obtained or the medical personnel to provide the treatment. Transportation of a committed person shall be provided by the sheriff of the county in which the person is confined if requested by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a medical, psychological, or psychiatric evaluation. A person shall not be transported to another facility for evaluation without a court order. When a transportation order is requested under this paragraph, notice must be provided to the opposing party, and the opposing party must be given a reasonable amount of time to object to the issuance of such an order. The cost of the transportation shall be paid by the party who requests the order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To a facility for placement or treatment in a transitional release program or for release with supervision. A transport order is not required under this paragraph.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to grant a person the right to personally appear at all court proceedings under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a77, 27}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1165, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7536}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.7}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Trial }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ determination }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ commitment procedure }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ }}}{{\f5\b\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\b\fs18\hyphpar0\qj{ agreements }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ mistrials.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the person charged with a sexually violent offense has been found incompetent to stand trial and the person is about to be released pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 812}}}{{\f5\fs18\hyphpar0\qj{, or if a petition has been filed seeking the person\u8217\'3fs commitment under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, the court shall first hear evidence and determine whether the person did commit the act or acts charged. At the hearing on this issue, the rules of evidence applicable in criminal cases shall apply, and all constitutional rights available to defendants at criminal trials, other than the right not to be tried while incompetent, shall apply. After hearing evidence on this issue, the court shall make specific findings on whether the person did commit the act or acts charged, the extent to which the person\u8217\'3fs incompetence affected the outcome of the hearing, including its effect on the person\u8217\'3fs ability to consult with and assist counsel and to testify on the person\u8217\'3fs own behalf, the extent to which the evidence could be reconstructed without the assistance of the person, and the strength of the prosecution\u8217\'3fs case. If, after the conclusion of the hearing on this issue, the court finds, beyond a reasonable doubt, that the person did commit the act or acts charged, the court shall enter a final order, appealable by the person, on that issue, and may proceed to consider whether the person should be committed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person has been found not guilty by reason of insanity, the court shall determine whether the acts charged were proven as a matter of law. If as a matter of law the finding of not guilty by reason of insanity requires a finding that the underlying elements of the charged offense were proven, then no further fact-finding is required. If as a matter of law the finding of not guilty by reason of insanity does not require a finding that the underlying elements of the charged offense be proven, the case shall proceed in the same manner as if the person were found to be incompetent to stand trial as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Within ninety days after either the entry of the order waiving the probable cause hearing or completion of the probable cause hearing held under }}}{{\f5\fs18\hyphpar0\qj{section 229A.5}}}{{\f5\fs18\hyphpar0\qj{, the court shall conduct a trial to determine whether the respondent is a sexually violent predator. The respondent or the attorney for the respondent may waive the ninety-day trial requirement as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{; however, the respondent or the attorney for the respondent may reassert a demand and the trial shall be held within ninety days from the date of filing the demand with the clerk of court. The trial may be continued upon the request of either party and a showing of good cause, or by the court on its own motion in the due administration of justice, and when the respondent will not be substantially prejudiced. In determining what constitutes good cause, the court shall consider the length of the pretrial detention of the respondent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The respondent, the attorney general, or the judge shall have the right to demand that the trial be before a jury. Such demand for the trial to be before a jury shall be filed, in writing, at least ten days prior to trial. If no demand is made, the trial shall be before the court. Except as otherwise provided, the Iowa rules of evidence and the Iowa rules of civil procedure shall apply to all civil commitment proceedings initiated pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At trial, the court or jury shall determine whether, beyond a reasonable doubt, the respondent is a sexually violent predator. If the case is before a jury, the verdict shall be unanimous that the respondent is a sexually violent predator.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court or jury determines that the respondent is a sexually violent predator, the respondent shall be committed to the custody of the director for control, care, and treatment until such time as the person\u8217\'3fs mental abnormality has so changed that the person is safe to be placed in a transitional release program or discharged. The determination may be appealed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At trial, the court shall admit, and the fact finder may rely on, the findings of an administrative parole judge or other agency fact finder.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court or jury determines that the respondent is a sexually violent predator, the court shall order the respondent to submit a DNA sample for DNA profiling pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 81.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The control, care, and treatment of a person determined to be a sexually violent predator shall be provided at a facility operated by the department. At all times prior to placement in a transitional release program or release with supervision, persons committed for control, care, and treatment by the department pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be kept in a secure facility and those patients shall be segregated at all times from any other patient under the supervision of the department. A person committed pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ to the custody of the department may be kept in a facility or building separate from any other patient under the supervision of the department. The department may enter into a }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ agreement with the department of corrections or other appropriate agency in this state or another state for the confinement of patients who have been determined to be sexually violent predators. Patients who are in the custody of the director of the department of corrections pursuant to a }}}{{\f5\fs18\hyphpar0\qj{chapter 28E}}}{{\f5\fs18\hyphpar0\qj{ agreement and who have not been placed in a transitional release program or released with supervision shall be housed and managed separately from criminal offenders in the custody of the director of the department of corrections, and except for occasional instances of supervised incidental contact, shall be segregated from those offenders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court makes the determination or the jury determines that the respondent is not a sexually violent predator, the court shall direct the respondent\u8217\'3fs release. Upon release, the respondent shall comply with any requirements to register as a sex offender as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 692A}}}{{\f5\fs18\hyphpar0\qj{. Upon a mistrial, the court shall direct that the respondent be held at an appropriate secure facility until another trial is conducted. Any subsequent trial following a mistrial shall be held within ninety days of the previous trial, unless such subsequent trial is continued or the ninety days are waived as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 61, \'a76, 7, 14}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1058, \'a724}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1139, \'a78, 9, 27}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1060, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1084, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 158, \'a711, 19}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7228}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1165, \'a7100}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 17, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7537, 538}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a79E.2}}}{{\f5\fs12\hyphpar0\qj{, 81.1}}}{{\f5\fs12\hyphpar0\qj{, 92.20}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.8}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Annual examinations and review \u8212\'3f discharge or transitional release petitions by persons committed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon civil commitment of a person pursuant to }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, a rebuttable presumption exists that the commitment should continue. The presumption may be rebutted when facts exist to warrant a hearing to determine whether a committed person no longer suffers from a mental abnormality which makes the person likely to engage in predatory acts constituting sexually violent offenses if discharged, or the committed person is suitable for placement in a transitional release program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person committed under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall have a current examination of the person\u8217\'3fs mental abnormality made once every year. The person may retain, or if the person is indigent and so requests, the court may appoint a qualified expert or professional person to examine such person, and such expert or professional person shall be given access to all records concerning the person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The annual report shall be provided to the court that committed the person under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{. The court shall conduct an annual review and, if warranted, set a final hearing on the status of the committed person. The annual review may be based only on written records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing contained in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall prohibit the person from otherwise petitioning the court for discharge or placement in a transitional release program at the annual review. The department shall provide the committed person with an annual written notice of the person\u8217\'3fs right to petition the court for discharge or placement in a transitional release program without authorization from the director. The notice shall contain a waiver of rights. The department shall forward the notice and waiver form to the court with the annual report.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following provisions apply to an annual review:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person shall have a right to have an attorney represent the person but the person is not entitled to be present at the hearing, if a hearing is held.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa rules of evidence do not apply.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person may waive an annual review or may stipulate that the commitment should continue for another year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall review the annual report of the state and the report of any qualified expert or professional person retained by or appointed for the committed person and may receive arguments from the attorney general and the attorney for the committed person if either requests a hearing. The request for a hearing must be in writing, within thirty days of the notice of annual review being provided to counsel for the committed person, or on motion by the court. Such a hearing may be conducted in writing without any attorneys present.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall consider all evidence presented by both parties at the annual review. The burden is on the committed person to prove by a preponderance of the evidence that there is relevant and reliable evidence to rebut the presumption of continued commitment, which would lead a reasonable person to believe a final hearing should be held to determine either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The mental abnormality of the committed person has so changed that the person is not likely to engage in predatory acts constituting sexually violent offenses if discharged.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person is suitable for placement in a transitional release program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229A.8A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the committed person shows by a preponderance of the evidence that a final hearing should be held on either determination under subparagraph (1), subparagraph division (a) or (b), or both, the court shall set a final hearing within sixty days of the determination that a final hearing be held.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person may waive the sixty-day final hearing requirement under subparagraph subdivision (a); however, the committed person or the attorney for the committed person may reassert the requirement by filing a demand that the final hearing be held within sixty days from the date of the filing of the demand with the clerk of court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The final hearing may be continued upon request of either party and a showing of good cause, or by the court on its own motion in the due administration of justice, and if the committed person is not substantially prejudiced. In determining what constitutes good cause, the court shall consider the length of the pretrial detention of the committed person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at the time for the annual review the committed person has filed a petition for discharge or placement in a transitional release program with authorization from the director, the court shall set a final hearing within ninety days of the authorization by the director, and no annual review shall be held.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the committed person has not filed a petition, or has filed a petition for discharge or for placement in a transitional release program without authorization from the director, the court shall first conduct the annual review as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any petition can summarily be dismissed by the court as provided in }}}{{\f5\fs18\hyphpar0\qj{section 229A.11}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If at the time of the annual review the committed person is in a secure facility and not in the transitional release program, the state shall have the right to demand that both determinations in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), be submitted to the court or jury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following provisions shall apply to a final hearing:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person shall be entitled to an attorney and is entitled to the benefit of all constitutional protections that were afforded the person at the original commitment proceeding. The committed person shall be entitled to a jury trial, if such a demand is made in writing and filed with the clerk of court at least ten days prior to the final hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person shall have the right to have experts evaluate the person on the person\u8217\'3fs behalf. The court shall appoint an expert if the person is indigent and requests an appointment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general shall represent the state and shall have a right to demand a jury trial. The jury demand shall be filed, in writing, at least ten days prior to the final hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The burden of proof at the final hearing shall be upon the state to prove beyond a reasonable doubt either of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person\u8217\'3fs mental abnormality remains such that the person is likely to engage in predatory acts that constitute sexually violent offenses if discharged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person is not suitable for placement in a transitional release program pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229A.8A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director has authorized the committed person to petition for discharge or for placement in a transitional release program and the case is before a jury, testimony by a victim of a prior sexually violent offense committed by the person is not admissible. If the director has not authorized the petition or the case is before the court, testimony by a victim of a sexually violent offense committed by the person may be admitted.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a mistrial is declared, the confinement or placement status of the committed person shall not change. After a mistrial has been declared, a new trial must be held within ninety days of the mistrial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The state and the committed person may stipulate to a transfer to a transitional release program if the court approves the stipulation.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1139, \'a710, 27}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7229}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 116, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a762}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 24, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a766}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7539 \u8211\'3f 541}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229A.5B}}}{{\f5\fs12\hyphpar0\qj{, 229A.9A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.8A}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Transitional release.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may establish a transitional release program and provide control, care, and treatment, and supervision of committed persons placed in such a program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A committed person is suitable for placement in the transitional release program if the court finds that all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person\u8217\'3fs mental abnormality is no longer such that the person is a high risk to reoffend.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person has achieved and demonstrated significant insights into the person\u8217\'3fs sex offending cycle.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person has accepted responsibility for past behavior and understands the impact sexually violent crimes have upon a victim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A detailed relapse prevention plan has been developed and accepted by the treatment provider which is appropriate for the committed person\u8217\'3fs mental abnormality and sex offending history.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No major discipline reports have been issued for the committed person for a period of six months.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person is not likely to escape or attempt to escape custody pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 229A.5B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person is not likely to engage in predatory acts constituting sexually violent offenses while in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The placement is in the best interest of the committed person.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The committed person has demonstrated a willingness to agree to and abide by all rules of the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the committed person does not agree to the conditions of release, the person is not eligible for the transitional release program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A committed person who refuses to register as a sex offender is not eligible for placement in a transitional release program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Committed persons in the transitional release program are not necessarily required to be segregated from other persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall be responsible for establishing and implementing the rules and directives regarding the location of the transitional release program, staffing needs, restrictions on confinement and the movement of committed persons, and for assessing the progress of committed persons in the program. The court may also impose conditions on a committed person placed in the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may contract with other government or private agencies, including the department of corrections, to implement and administer the transitional release program.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a711, 27}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 44, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7463, 468}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7542}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229A.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.8B}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations of transitional release.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treatment staff in a transitional release program may remove the committed person from the program for a violation of any rule or directive, and return the person to a secure facility. The treatment staff may request the district court to issue an emergency ex parte order directing any law enforcement officer to take the committed person into custody so that the person can be returned to a secure facility. The request for an ex parte order may be made orally or by telephone, but the original written request or a facsimile copy of the original request shall be filed with the clerk of court no later than 4:30 p.m. on the next business day the office of the clerk of court is open.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a committed person absconds from a transitional release program in violation of the rules or directives, a presumption arises that the person poses a risk to public safety. The department, in cooperation with local law enforcement agencies, may make a public announcement about the absconder. The public announcement may include a description of the committed person, that the person is in transitional release from the sexually violent predator program, and any other information important to public safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the return of the committed person to a secure facility, the director or the director\u8217\'3fs designee shall notify the court that issued the ex parte order that the absconder has been returned to a secure facility, and the court shall set a hearing to determine if a violation occurred. If a court order was not issued, the director or the director\u8217\'3fs designee shall contact the nearest district court with jurisdiction to set a hearing to determine whether a violation of the rules or directives occurred. The court shall schedule a hearing after receiving notice that the committed person has been returned from the transitional release program to a secure facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the hearing, the burden shall be upon the attorney general to show by a preponderance of the evidence that a violation of the rules or directives occurred. The hearing shall be to the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines a violation occurred, the court shall either order the committed person to be returned to the transitional release program or to be confined in a secure facility. The court may impose further conditions upon the committed person if returned to the transitional release program. If the court determines no violation occurred, the committed person shall be returned to the transitional release program.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a712, 27}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1165, \'a7101}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7543}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.9}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Detention and commitment to conform to constitutional requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The involuntary detention or commitment of persons under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall conform to constitutional requirements for care and treatment.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a79}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.9A}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Release with supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any proceeding under }}}{{\f5\fs18\hyphpar0\qj{section 229A.8}}}{{\f5\fs18\hyphpar0\qj{, the court may order the committed person released with supervision if any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general stipulates to the release with supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court or jury has determined that the person should be released from a secure facility or a transitional release program, but the court has determined the person suffers from a mental abnormality and it is in the best interest of the community to order release with supervision before the committed person is discharged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If release with supervision is ordered, the department shall prepare within sixty days of the order of the court a release plan addressing the person\u8217\'3fs needs for counseling, medication, community support services, residential services, vocational services, substance use disorder treatment, sex offender treatment, or any other treatment or supervision necessary.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall set a hearing on the release plan prepared by the department before the committed person is released from a secure facility or a transitional release program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court orders release with supervision, the court shall order supervision by an agency with jurisdiction that is familiar with the placement of criminal offenders in the community. The agency with jurisdiction shall be responsible for initiating proceedings for violations of the release plan as provided in }}}{{\f5\fs18\hyphpar0\qj{section 229A.9B}}}{{\f5\fs18\hyphpar0\qj{. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A committed person may not petition the court for release with supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A committed person released with supervision is not considered discharged from civil commitment under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After being released with supervision, the person may petition the court for discharge as provided in }}}{{\f5\fs18\hyphpar0\qj{section 229A.8}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The court shall retain jurisdiction over the committed person who has been released with supervision until the person is discharged from the program. The department or a judicial district department of correctional services shall not be held liable for any acts committed by a committed person who has been ordered released with supervision.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a713, 27}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1059, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1165, \'a7102}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7544}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.9B}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations of release with supervision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a committed person violates the release plan, the agency with jurisdiction over the person may request the court to issue an emergency ex parte order directing any law enforcement officer to take the person into custody so that the person can be returned to a secure facility. The request for an ex parte order may be made orally or by telephone, but the original written request or a facsimile copy of the request shall be filed with the clerk of court no later than 4:30 p.m. on the next business day the office of the clerk of court is open.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a committed person has absconded in violation of the conditions of the person\u8217\'3fs release plan, a presumption arises that the person poses a risk to public safety. The department or contracting agency, in cooperation with local law enforcement agencies, may make a public announcement about the absconder. The public announcement may include a description of the committed person, that the committed person is on release with supervision from the sexually violent predator program, and any other information pertinent to public safety.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon the return of the committed person to a secure facility, the director or the director\u8217\'3fs designee shall notify the court that issued the ex parte order that the committed person has been returned to a secure facility, and the court shall set hearing to determine if a violation occurred. If a court order was not issued, the director or the director\u8217\'3fs designee shall contact the nearest district court with jurisdiction to set a hearing to determine whether a violation of the conditions of the release plan occurred. The court shall schedule a hearing after receiving notice that the committed person has been returned to a secure facility.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At the hearing, the burden shall be upon the attorney general to show by a preponderance of the evidence that a violation of the release plan occurred.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the court determines a violation occurred, the court shall receive release recommendations from the department and either order that the committed person be returned to release with supervision or placed in a transitional release program, or be confined in a secure facility. The court may impose further conditions upon the committed person if returned to release with supervision or placed in the transitional release program. If the court determines no violation occurred, the committed person shall be returned to release with supervision.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a714, 27}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1165, \'a7103}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7545}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229A.9A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.10}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Petition for discharge \u8212\'3f procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the director determines that the person\u8217\'3fs mental abnormality has so changed that the person is not likely to engage in predatory acts that constitute sexually violent offenses if discharged, the director shall authorize the person to petition the court for discharge. The petition shall be served upon the court and the attorney general. The court, upon receipt of the petition for discharge, shall order a hearing within thirty days. The attorney general shall represent the state, and shall have the right to have the petitioner examined by an expert or professional person of the attorney general\u8217\'3fs choice. The hearing shall be before a jury if demanded by either the petitioner or the attorney general. If the attorney general objects to the petition for discharge, the burden of proof shall be upon the attorney general to show beyond a reasonable doubt that the petitioner\u8217\'3fs mental abnormality or personality disorder remains such that the petitioner is likely to engage in predatory acts that constitute sexually violent offenses if discharged.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon a finding that the state has failed to meet its burden of proof under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the court shall authorize the committed person to be discharged.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 61, \'a78, 14}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a715, 27}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 44, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7546}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229A.5B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.11}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Subsequent discharge or transitional release petitions }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Nothing in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall prohibit a person from filing a petition for discharge or placement in a transitional release program, pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. However, if a person has previously filed a petition for discharge or for placement in a transitional release program without the authorization of the director, and the court determines either upon review of the petition or following a hearing that the petition was frivolous or that the petitioner\u8217\'3fs condition had not so changed that the person was not likely to engage in predatory acts constituting sexually violent offenses if discharged, or was not suitable for placement in the transitional release program, then the court shall summarily deny the subsequent petition unless the petition contains facts upon which a court could find the condition of the petitioner had so changed that a hearing was warranted. Upon receipt of a first or subsequent petition from a committed person without the director\u8217\'3fs authorization, the court shall endeavor whenever possible to review the petition and determine if the petition is based upon frivolous grounds. If the court determines that a petition is frivolous, the court shall dismiss the petition without a hearing.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a711}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a716, 27}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7547}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7229A.8}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.12}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Director }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ responsibility for costs }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ reimbursement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director shall be responsible for all costs relating to the evaluation, treatment, and services provided to a person that are incurred after the person is committed to the director\u8217\'3fs custody after the court or jury determines that the respondent is a sexually violent predator and pursuant to commitment under any provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. If placement in a transitional release program or supervision is ordered, the director shall also be responsible for all costs related to the transitional release program or to the supervision and treatment of any person. Reimbursement may be obtained by the director from the patient and any person legally liable or bound by contract for the support of the patient for the cost of confinement or of care and treatment provided. To the extent allowed by the United States social security administration, any benefit payments received by the person pursuant to the federal }{{\f5\fs18\hyphpar0\qj{Social Security Act}}}{ shall be used for the costs incurred. As used in }{{\f5\fs18\hyphpar0\qj{this section}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fany person legally liable\u8221\'3f}}}{ does not include a political subdivision.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1181, \'a726}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 61, \'a79, 14}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a717, 27}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 175, \'a799}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7548}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.12A}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Director of the department of corrections \u8212\'3f responsibility for safekeeper.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director of the department of corrections shall have authority, once a person is detained pursuant to }{{\f5\fs18\hyphpar0\qj{section 229A.5}}}{, to make a determination as to the appropriate secure facility within the department of corrections in which the safekeeper is to be placed, taking into consideration the safekeeper\u8217\'3fs medical needs and ability to interact with offenders who have been committed to the custody of the director of the department of corrections. The director has authority to determine the safekeeper\u8217\'3fs degree of segregation from offenders, including whether total segregation is appropriate under the circumstances or whether the safekeeper should be permitted to participate in normal confinement activities in the presence of offenders.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a718, 27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.13}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Severability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If any provision of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or the application thereof to any person or circumstances is held invalid, the invalidity shall not affect other provisions or applications of the chapter which can be given effect without the invalid provisions or application and, to this end, the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ are severable.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a714}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.14}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Release of confidential or privileged information and records.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding any provision in the Code regarding confidentiality to the contrary, any relevant information and records which would otherwise be confidential or privileged, except information subject to attorney-client privilege and attorney work product, shall be released to the agency with jurisdiction or the attorney general for the purpose of meeting the notice requirement provided in }{{\f5\fs18\hyphpar0\qj{section 229A.3}}}{ and determining whether a person is or continues to be a sexually violent predator.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a719, 27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.15}}}{\*\bkmkstart stylerid1_2E3_30_2E2_2E2}{\*\bkmkend stylerid1_2E3_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Court records }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ sealed and opened by court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, any psychological reports, drug and alcohol reports, treatment records, reports of any diagnostic center, medical records, or victim impact statements which have been submitted to the court or admitted into evidence under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ shall be part of the record but shall be sealed and opened only on order of the court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The documents described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be available to the prosecuting attorney or attorney general, the committed person, and the attorney for the committed person without an order of the court.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a763}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.15A}}}{\*\bkmkstart stylerid1_2E31_2E2_2E2}{\*\bkmkend stylerid1_2E31_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Civil protective order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A victim of a crime that was committed before the filing of a petition under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ by a safekeeper or by a person subjected to an order of civil commitment pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, may obtain a protective order against the safekeeper or person using the procedures set out in }{{\f5\fs18\hyphpar0\qj{section 915.22}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a720, 27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.15B}}}{\*\bkmkstart stylerid1_2E32_2E2_2E2}{\*\bkmkend stylerid1_2E32_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rulemaking authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department shall adopt rules pursuant to }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{ necessary to administer }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1139, \'a721, 27}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7549}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{229A.16}}}{\*\bkmkstart stylerid1_2E33_2E2_2E2}{\*\bkmkend stylerid1_2E33_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Short title.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This chapter}}}{ shall be known and may be cited as the }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSexually Violent Predator Act\u8221\'3f}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1171, \'a717}}}\par}}