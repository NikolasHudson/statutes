\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F285}{\*\bkmkend codeChapter_5F285}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 285}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{STATE AID FOR TRANSPORTATION}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7256F.4}}}{{\f5\fs12\qc{, 261E.9}}}{{\f5\fs12\qc{, 274.3}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{When entitled to state aid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors in every school district shall provide transportation, either directly or by reimbursement for transportation, for all resident pupils attending public school, kindergarten through twelfth grade, except that:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Elementary pupils shall be entitled to transportation only if they live more than two miles from the school designated for attendance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{High school pupils shall be entitled to transportation only if they live more than three miles from the school designated for attendance.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Children attending prekindergarten programs offered or sponsored by the district or nonpublic school and approved by the department of education or department of health and human services or children participating in preschool in an approved local program under }}}{{\f5\fs18\hyphpar0\qj{chapter 256C}}}{{\f5\fs18\hyphpar0\qj{ may be provided transportation services. However, transportation services provided to nonpublic school children are not eligible for reimbursement under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Districts are not required to maintain seating space on school buses for students who are otherwise to be provided transportation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ if the students do not or will not regularly utilize the district\u8217\'3fs transportation service for extended periods during the school year. The student, or the student\u8217\'3fs parent or legal guardian if the student is less than eighteen years of age, shall be notified by the district before transportation services may be suspended, and the suspension may continue until the student, or the student\u8217\'3fs parent or legal guardian, notifies the district that regular student ridership will continue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhigh school\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a school which commences with either grade nine or grade ten, as determined by the board of directors of the school district or by the governing authority of the nonpublic school in the case of nonpublic schools.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Boards in their discretion may provide transportation for some or all resident pupils attending public school or pupils who attend nonpublic schools who are not entitled to transportation. Boards in their discretion may collect from the parent or guardian of the pupil not more than the pro rata cost for such optional transportation, determined as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 12}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any pupil may be required to meet a school bus on the approved route a distance of not to exceed three-fourths of a mile without reimbursement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In a district where transportation by school bus is impracticable, where necessary to implement a whole grade sharing agreement under }}}{{\f5\fs18\hyphpar0\qj{section 282.10}}}{{\f5\fs18\hyphpar0\qj{, or where school bus service is not available, the board may require parents or guardians to furnish transportation for their children to the schools designated for attendance. Except as provided in }}}{{\f5\fs18\hyphpar0\qj{section 285.3}}}{{\f5\fs18\hyphpar0\qj{, the parent or guardian shall be reimbursed for such transportation service for public and nonpublic school pupils by the board of the resident district in an amount equal to eighty dollars plus seventy-five percent of the difference between eighty dollars and the previous school year\u8217\'3fs statewide average per pupil transportation cost, as determined by the department of education. However, a parent or guardian shall not receive reimbursement for furnishing transportation for more than three family members who attend elementary school and one family member who attends high school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In all districts where unsatisfactory roads or other conditions make it advisable, the board at its discretion may require the parents or guardians of public and nonpublic school pupils to furnish transportation for their children up to two miles to connect with vehicles of transportation. The parents or guardians shall be reimbursed for such transportation by the boards of the resident districts at the rate of twenty-eight cents per mile per day, one way, per family for the distance from the pupil\u8217\'3fs residence to the bus route.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where transportation by school bus is impracticable or not available or other existing conditions warrant it, arrangements may be made for use of common carriers according to uniform standards established by the director of the department of education and at a cost based upon the actual cost of service and approved by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When the school designated for attendance of pupils is engaged in the transportation of pupils, the sending or designating school shall use these facilities and pay the pro rata cost of transportation except that a district sending pupils to another school may make other arrangements when it can be shown that such arrangements will be more efficient and economical than to use facilities of the receiving school, providing such arrangements are approved by the board of the area education agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a local board closes either elementary or high school facilities and is approved by the board of the area education agency to operate its own transportation equipment, the full cost of transportation shall be paid by the board for all pupils living beyond the statutory walking distance from the school designated for attendance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transportation service may be suspended upon any day or days, due to inclemency of the weather, conditions of roads, or the existence of other conditions, by the board of the school district operating the buses, when in their judgment it is deemed advisable and when the school or schools are closed to all children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Distance to school or to a bus route shall in all cases be measured on the public highway only and over the most passable and safest route as determined by the area education agency board, starting in the roadway opposite the private entrance to the residence of the pupil and ending in the roadway opposite the entrance to the school grounds or designated point on bus route.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board in any district providing transportation for nonresident pupils shall collect the pro rata cost of transportation from the district of pupil\u8217\'3fs residence for all properly designated pupils so transported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Boards in districts operating buses may transport nonresident pupils who attend public school, kindergarten through junior college, who are not entitled to free transportation provided they collect the pro rata cost of transportation from the parents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The pro rata cost of transportation shall be based upon the actual cost for all the children transported in all school buses. It shall include one-seventh of the original net cost of the bus and other items as determined and approved by the director of the department of education but no part of the capital outlay cost for school buses and transportation equipment for which the school district is reimbursed from state funds or that portion of the cost of the operation of a school bus used in transporting pupils to and from extracurricular activities shall be included in determining the pro rata cost. In a district where, because of unusual conditions, the cost of transportation is in excess of the actual operating cost of the bus route used to furnish transportation to nonresident pupils, the board of the local district may charge a cost equal to the cost of other schools supplying such service to that area, upon receiving approval of the director of the department of education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a local board fails to pay transportation costs due to another school for transportation service rendered, the board of the creditor corporation shall file a sworn statement with the area education agency board specifying the amount due. The agency board shall check such claim and if the claim is valid shall certify to the county auditor. The auditor shall transmit to the county treasurer an order directing the county treasurer to transfer the amount of such claim from the funds of the debtor corporation to the creditor corporation and the treasurer shall pay the same accordingly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Resident pupils attending a nonpublic school located either within or without the school district of the pupil\u8217\'3fs residence shall be entitled to transportation on the same basis as provided for resident public school pupils under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The public school district providing transportation to a nonpublic school pupil shall determine the days on which bus service is provided, which shall be based upon the days for which bus service is provided to public school pupils, and the public school district shall determine bus schedules and routes. In the case of nonpublic school pupils the term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fschool designated for attendance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the nonpublic school which is designated for attendance by the parents of the nonpublic school pupil.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the nonpublic school designated for attendance is located within the public school district in which the pupil is a resident, the pupil shall be transported to the nonpublic school designated for attendance as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the nonpublic school designated for attendance of a pupil is located outside the boundary line of the school district of the pupil\u8217\'3fs residence, the pupil may be transported by the district of residence to a public school or other location within the district of the pupil\u8217\'3fs residence. A public school district in which a nonpublic school is located may establish school bus collection locations within its district from which nonresident nonpublic school pupils may be transported to and from a nonpublic school located in the district. If a pupil receives such transportation, the district of the pupil\u8217\'3fs residence shall be relieved of any requirement to provide transportation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As an alternative to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, subject to }}}{{\f5\fs18\hyphpar0\qj{section 285.9, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, where practicable, and at the option of the public school district in which a nonpublic school pupil resides, the school district may transport a nonpublic school pupil to a nonpublic school located outside the boundary lines of the public school district if the nonpublic school is located in a school district contiguous to the school district which is transporting the nonpublic school pupils, or may contract with the contiguous public school district in which a nonpublic school is located for the contiguous school district to transport the nonpublic school pupils to the nonpublic school of attendance within the boundary lines of the contiguous school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the nonpublic school designated for attendance of a pupil is located outside the boundary line of the school district of the pupil\u8217\'3fs residence and the district of residence meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsections 14}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{15}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ by using }}}{{\f5\fs18\hyphpar0\qj{subsection 17}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and the district in which the nonpublic school is located is contiguous to the district of the pupil\u8217\'3fs residence and is willing to provide transportation under }}}{{\f5\fs18\hyphpar0\qj{subsection 17}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the district in which the nonpublic school is located may provide transportation services, subject to }}}{{\f5\fs18\hyphpar0\qj{section 285.9, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and may make the claim for reimbursement under }}}{{\f5\fs18\hyphpar0\qj{section 285.2}}}{{\f5\fs18\hyphpar0\qj{. The district in which the nonpublic school is located shall notify the district of the pupil\u8217\'3fs residence that it is making the claim for reimbursement, and the district of the pupil\u8217\'3fs residence shall be relieved of the requirement for providing transportation and shall not make a claim for reimbursement for those nonpublic school pupils for which a claim is filed by the district in which the nonpublic school is located.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The public school district may meet the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsections 14 through 16}}}{{\f5\fs18\hyphpar0\qj{ by any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transportation in a school bus operated by a public school district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracting with private parties as provided in }}}{{\f5\fs18\hyphpar0\qj{section 285.5}}}{{\f5\fs18\hyphpar0\qj{. However, contracts shall not provide payment in excess of the average per pupil transportation costs of the school district for that year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Utilizing the transportation reimbursement provision of }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracting with a contiguous public school district to transport resident nonpublic school pupils the entire distance from the nonpublic pupil\u8217\'3fs residence to the nonpublic school located in the contiguous public school district or from the boundary line of the public school district to the nonpublic school.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of education may review all transportation arrangements to see that they meet all legal and established uniform standard requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transportation authorized by }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ is exempt from all laws of this state regulating common carriers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Transportation for which the pro rata cost or other charge is collected shall not be provided outside the state of Iowa except in accordance with rules adopted by the department of education in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{. The rules shall take into account any applicable federal requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Boards in districts operating buses may in their discretion transport senior citizens, children, persons with disabilities, and other persons and groups, who are not otherwise entitled to free transportation, and shall collect the pro rata cost of transportation. Transportation under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not be provided when the school bus is being used to transport pupils to or from school unless the board determines that such transportation is desirable and will not interfere with or delay the transportation of pupils.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1), a parent or guardian of an elementary pupil entitled to transportation pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, may request that a child care facility be designated for purposes of }}}{{\f5\fs18\hyphpar0\qj{subsection 9}}}{{\f5\fs18\hyphpar0\qj{ rather than the residence of the pupil. The request shall be submitted for a period of time of at least one semester and may not be submitted more than twice during a school year.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72794-b, -c, -d, -e; SS15, \'a72794-a, -g; C24, 27, 31, \'a74179 \u8211\'3f 4181, 4184, 4186; C35, \'a74179 \u8211\'3f 4181, 4184, 4186, 4233-e5; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4179 \u8211\'3f 4181, 4184, 4186, 4233.5;}}}{ C46, \'a7276.26, 276.28, 276.29, 276.32, 276.34, 279.20, 285.1, 285.5; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7135}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 6, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 115, \'a742}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 233, \'a7488}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1263, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 127, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1060, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 209, \'a715}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1129, \'a7113}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 192, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 148, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a7109}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a7153, 154}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71052}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.16C}}}{{\f5\fs12\hyphpar0\qj{, 257.31}}}{{\f5\fs12\hyphpar0\qj{, 282.1}}}{{\f5\fs12\hyphpar0\qj{, 282.18}}}{{\f5\fs12\hyphpar0\qj{, 285.2}}}{{\f5\fs12\hyphpar0\qj{, 285.3}}}{{\f5\fs12\hyphpar0\qj{, 285.11}}}{{\f5\fs12\hyphpar0\qj{, 321.18}}}{{\f5\fs12\hyphpar0\qj{, 331.502}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Parent or guardian required to transport pupil participating in open enrollment without reimbursement to receiving district\u8217\'3fs regular school bus route; }{{\f5\fs12\hyphpar0\qj{\'a7282.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Payment of claims for nonpublic school pupil transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Boards of directors of school districts shall be required to provide transportation services to nonpublic school pupils as provided in }}}{{\f5\fs18\hyphpar0\qj{section 285.1}}}{{\f5\fs18\hyphpar0\qj{ when the general assembly appropriates funds to the department of education for the payment of claims for transportation costs submitted by the school district.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{There is appropriated from the general fund of the state to the department of education funds sufficient to pay the approved claims of public school districts for transportation services to nonpublic school pupils as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The portion of the amount appropriated for approved claims under }}}{{\f5\fs18\hyphpar0\qj{section 285.1, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, shall be determined under }}}{{\f5\fs18\hyphpar0\qj{section 285.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The costs of providing transportation to nonpublic school pupils as provided in }}}{{\f5\fs18\hyphpar0\qj{section 285.1}}}{{\f5\fs18\hyphpar0\qj{ shall not be included in the computation of district cost under }}}{{\f5\fs18\hyphpar0\qj{chapter 257}}}{{\f5\fs18\hyphpar0\qj{, but shall be shown in the budget as an expense from miscellaneous income. Any transportation reimbursements received by a local school district for transporting nonpublic school pupils shall not affect district cost limitations of }}}{{\f5\fs18\hyphpar0\qj{chapter 257}}}{{\f5\fs18\hyphpar0\qj{. The reimbursements provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are miscellaneous income as defined in }}}{{\f5\fs18\hyphpar0\qj{section 257.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Claims for reimbursement shall be made to the department of education by the public school district providing transportation or transportation reimbursement during a school year on a form prescribed by the department, and the claim shall state the services provided and the actual costs incurred. A claim shall not exceed the average transportation costs of the district per pupil transported except as otherwise provided. If transportation is provided under }}}{{\f5\fs18\hyphpar0\qj{section 285.1, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the amount of a claim shall be determined under }}}{{\f5\fs18\hyphpar0\qj{section 285.3}}}{{\f5\fs18\hyphpar0\qj{ regardless of the average transportation costs of the district per pupil transported.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Claims shall be accompanied by an affidavit of an officer of the public school district affirming the accuracy of the claim.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By February 1 and on or about June 15 of each year, the department shall certify to the department of administrative services the amounts of approved claims to be paid, and the department of administrative services shall draw warrants payable to school districts which have established claims.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Claims shall be allowed where practical, and at the option of the public school district of the pupil\u8217\'3fs residence, subject to approval by the area education agency of the pupil\u8217\'3fs residence, under }}}{{\f5\fs18\hyphpar0\qj{section 285.9, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, the public school district of the pupil\u8217\'3fs residence may transport a pupil to a school located in a contiguous public school district outside the boundary lines of the public school district of the pupil\u8217\'3fs residence.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The public school district of the pupil\u8217\'3fs residence may contract with the contiguous public school district or with a private contractor under }}}{{\f5\fs18\hyphpar0\qj{section 285.5}}}{{\f5\fs18\hyphpar0\qj{ to transport the pupils to the school of attendance within the boundary lines of the contiguous public school district. The public school district in which the pupil resides may contract with the contiguous public school district or with a private contractor under }}}{{\f5\fs18\hyphpar0\qj{section 285.5}}}{{\f5\fs18\hyphpar0\qj{ to transport the pupil from the pupil\u8217\'3fs residence or from designated school bus collection locations to the school located within the boundary lines of the contiguous public school district, subject to the approval of the area education agency of the pupil\u8217\'3fs residence. The public school district of the pupil\u8217\'3fs residence may utilize the reimbursement provisions of }}}{{\f5\fs18\hyphpar0\qj{section 285.1, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1302, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1246, \'a7136, 137}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 135, \'a792}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1181, \'a714, 18}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 214, \'a710, 11}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 145, \'a7286}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7285.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See Iowa Acts for provisions relating to appropriations for approved claims in a given year}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Parental reimbursement for nonpublic school pupil transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A parent or legal guardian of a student attending an accredited nonpublic school, who furnishes transportation for the student pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 285.1, subsection 17}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and who meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, is entitled to reimbursement equal to an amount calculated under the provisions of }}}{{\f5\fs18\hyphpar0\qj{section 285.1, subsection 3}}}{{\f5\fs18\hyphpar0\qj{. In addition, a parent or guardian who transports one or more family members more than four miles to their nonpublic school of attendance shall be entitled to one supplemental mileage payment per family, per claim period, equal to thirteen percent of the parental reimbursement for the claim period rounded to the nearest whole dollar.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{To qualify for parental reimbursement under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a parent or guardian of a student attending an accredited nonpublic school who furnishes transportation for the student in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, shall submit a notice of nonpublic school attendance to the resident public school district, notifying the district that the student is enrolled in and will attend an accredited nonpublic school during the period for which parental reimbursement is being requested. The notice shall be filed with the resident public school district not later than December 1 for the first semester claim and May 1 for the second semester claim each year. The notice shall include the parent\u8217\'3fs name and address, the name, age, and grade level of the student, and the name of the nonpublic school and its location. The resident public school district shall submit claims for reimbursement to the department of education on behalf of the parent or guardian if the parent or guardian meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 6, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1140, \'a726}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7285.1}}}{{\f5\fs12\hyphpar0\qj{, 285.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Pupils sent to another district.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a board closes its elementary school facilities for lack of pupils or by action of the board, it shall, if there is a school bus service available in the area, designate for attendance the school operating the buses, provided the board of such school is willing to receive them and the facilities and curricular offerings are adequate. The board of the district where the pupils reside may with the approval of the area education agency board, subject to legal limitations and established uniform standards, designate another rural school and provide their own transportation if the transportation costs will be less than to use the established bus service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All designations must be submitted to the area education agency board on or before July 15, for review and approval. The agency board shall after due investigation alter or change designations to make them conform to legal requirements and established uniform standards for making designations and for locating and establishing bus routes. After designations are made, they will remain the same from year to year except that on or before July 15, of each year, the rural board or parents may petition the agency board for a change of designation to another school. Appeals from the decision of the agency board on designations may be made by either the parents or board to the director of the department of education as provided in }}}{{\f5\fs18\hyphpar0\qj{section 285.12}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 285.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a74274-e1, -e3, -e4, -e6; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4274.03, 4274.05, 4274.06, 4274.08;}}}{ C46, \'a7282.10, 282.12, 282.13, 282.15, 285.4; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a7150}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contracts for transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Contracts for school bus service with private parties shall be in writing and be for the transportation of children who attend public school and children who attend nonpublic school. Such contracts shall define the route, the length of time, service contracted for, the compensation, and the vehicle to be used. The contract shall prescribe the duties of the contractor and driver of the vehicles and shall provide that every person in charge of a vehicle conveying children to and from school shall be at all times subject to any rules said board shall adopt for the protection of the children, or to govern the conduct of the persons in charge of said conveyance. Contracts may be made for a period not to exceed three years.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contract shall provide that the contractor will sell the equipment to the board should the contractor desire to terminate the contract, provided the board should desire to purchase said equipment, the price of the equipment to be determined by an appraisal board composed of one person appointed by the school board, one appointed by the owner of the equipment, and a third selected by these two.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The contractor shall operate the vehicle or provide a driver who must be approved by the board. The contractor and driver shall be subject to all laws and prescribed standards for school bus drivers. Failure to comply shall constitute grounds for dismissal of the driver or cancellation of the contract if the board so desires.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All vehicles of transportation provided by contractor shall be inspected, approved and certified before being put into operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All contracts may be terminated by either party on a ninety-day notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of education shall prepare a uniform contract containing provisions not in conflict with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ which shall be used by all schools in contracting for transportation service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All contractors shall carry liability insurance in amounts and kind as provided in the official contract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All contracts for transportation service and for drivers of school-owned and operated buses shall be made with someone outside the board except where no other transportation service is available, a board member may transport the member\u8217\'3fs own children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Private buses other than common carriers not used exclusively in transportation of pupils while under contract to a school district shall meet all requirements for school-owned buses, as to construction and operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All bus drivers for school-owned equipment shall be under contract with the board. The director of the department of education shall prepare a uniform contract containing provision not in conflict with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ which shall be used by all school boards in contracting with drivers of school-owned vehicles.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a72794-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4182, 4183;}}}{ C46, \'a7276.30, 276.31; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1061, \'a7180}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 25, \'a724}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7285.1}}}{{\f5\fs12\hyphpar0\qj{, 285.2}}}{{\f5\fs12\hyphpar0\qj{, 452A.17}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Personnel \u8212\'3f expenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The director of the department of education shall employ the necessary qualified personnel to implement }{{\f5\fs18\hyphpar0\qj{this chapter}}}{. The appropriation provided by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ may be expended in part for the direction and supervision provided by the chapter which shall include salaries and all necessary traveling expense incurred by personnel in the performance of their official duties.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71488}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.7}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and duties of department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The powers and duties of the department shall be to:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exercise general supervision over the school transportation system in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review and establish the location of bus routes which are located in more than one area education agency when the area education agency boards of the affected area education agencies after formal action do not approve.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish uniform standards for locating and operating bus routes and for the protection of the health and safety of pupils transported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inspect or cause to be inspected all vehicles used as school buses to transport school children to determine if such vehicles meet all legal and established standards of construction and can be operated with safety, comfort, and economy. When it is determined that further use of such vehicles is dangerous to the pupils transported and to the safety and welfare of the traveling public, the department of education shall order such vehicle to be withdrawn from further use on a specified date. School buses which do not conform to the requirements of the department of education may be issued a temporary certificate of operation provided that such school buses can be operated with safety, and provided further that no such certificate shall be issued for a period in excess of one year. All equipment can be required to be altered, or safety equipment added in order to make vehicles reasonably safe for operation. New buses after initial inspection and approval shall be issued a seal of inspection. After each annual inspection a seal of inspection and approval shall be issued. Said seals shall be mounted on the lower right hand corner of the windshield.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Aid in the enforcement of the motor vehicle laws relating to the transportation of school children.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribe uniform standards and regulations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the efficient operation and maintenance of school transportation equipment and for the protection of the health and safety of children transported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For locating and establishing bus routes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For procedures and requirements in making designations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For standard of safety in construction of school transportation equipment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For procedures for purchase of buses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For qualification of school bus drivers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As deemed necessary for the efficient administration of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review all transportation arrangements when deemed necessary and shall disapprove any arrangements that are not in conformity with the law and established standards and require the same to be altered or changed so that they do conform.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conduct schools of instruction for transportation personnel as needed or requested.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish a fee for conducting school bus inspections in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ and issuing school bus driver authorizations in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 321.376}}}{{\f5\fs18\hyphpar0\qj{, which shall not exceed the budgeted cost for conducting inspections and administering authorizations.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a724}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1140, \'a727}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and duties of area boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The powers and duties of the respective area education agency boards shall be to:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Enforce all laws and all rules and regulations of the department of education relating to transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Review and approve all transportation arrangements between districts in the agency and in all districts in the agency not operating high schools. If such transportation arrangements, designations, and contracts are not in conformity to law or established uniform standards for the locating and operating of bus routes, the agency board shall, after receiving all facts, make such alterations or changes as necessary to make the arrangements, designations, and contracts conform to the legal and established requirements and shall notify local board of such action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Approve all bus routes outside the boundary of the district of the school operating buses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a local board fails to make designations and other necessary arrangements for transportation as required by law, the agency board shall, after due notice to the local board, make necessary arrangements in conformity with law and established requirements. Notice shall be given to the local board of the arrangements as made. The arrangements shall be binding on the local board which shall pay the costs for service as arranged.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C35, \'a74274-e1, -e2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4274.03, 4274.04;}}}{ C46, \'a7282.10, 282.11, 285.9; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.9}}}{]}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7285.1}}}{{\f5\fs12\hyphpar0\qj{, 285.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers and duties of local boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The powers and duties of the local school boards shall be to:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Provide transportation for each resident pupil who attends public school, and each resident pupil who attends a nonpublic school, and who is entitled to transportation under the laws of this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Establish, maintain, and operate bus routes for the transportation of pupils so as to provide for the economical and efficient operation thereof without duplication of facilities, and to properly safeguard the health and safety of the pupils transported.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Purchase or lease buses and other transportation facilities, and maintain same, and to enter into contracts for transportation subject to any provisions of law affecting same.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Employ such drivers and other employees as may be necessary and prescribe their qualifications and adopt rules for their conduct.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Exercise any and all powers and duties relating to transportation of pupils enjoined upon them by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Shall purchase liability insurance and other insurance coverage which the board deems advisable to insure the school district, its officers, employees, and agents against liability incurred as a result of operating school buses, including but not limited to liability to pupils or other persons lawfully transported. }}}{{\f5\fs18\hyphpar0\qj{Section 670.7}}}{{\f5\fs18\hyphpar0\qj{ shall apply to such insurance. However, the board of directors in its discretion shall determine the insurance coverages and limits, and the school district and directors shall not be liable as a result of any such discretionary decision.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a school qualifies to purchase buses, they may be purchased as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{From funds available in the general fund or in the physical plant and equipment levy fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{By purchasing buses and entering into contracts to pay for such buses over a five-year period as follows:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{one-fourth of the cost when the bus is delivered and the balance in equal annual installments, plus simple interest due. The interest rate shall be the lowest rate available and shall not exceed the rate in effect under }}}{{\f5\fs18\hyphpar0\qj{section 74A.2}}}{{\f5\fs18\hyphpar0\qj{. The bus shall serve as security for balance due. Competitive bids on comparable equipment shall be requested on all school bus purchases and shall be based upon minimum construction standards established by the department of education. Bids shall be requested unless the bus is a used or demonstrator bus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Boards in school districts which have sufficient resident pupils they are required to transport to warrant the purchase of transportation equipment may purchase buses needed to provide the transportation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the discretion of the board, furnish a school bus and services of a qualified driver to an organization of, or sponsoring activities for, senior citizens, children, persons with disabilities, or other persons and groups in this state. The board shall charge and collect an amount sufficient to reimburse all costs of furnishing the bus and driver except when the bus is used for transporting pupils to and from extracurricular activities sponsored by the school. A school bus shall be used as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ only at times when it is not needed for transportation of pupils.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the discretion of the board, furnish a school bus and services of a qualified driver for transportation of persons other than pupils to activities in which pupils from the school are participants or are attending the activity or for which the school is a sponsor. The board shall charge and collect an amount sufficient to reimburse all costs of furnishing the bus and driver. A school bus shall be used as provided in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ only at times when it is not needed for transportation of pupils.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1187, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{93 Acts, ch 127, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1029, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1129, \'a7113}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 180, \'a752}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1086, \'a758}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7279.48}}}{{\f5\fs12\hyphpar0\qj{, 285.11}}}{{\f5\fs12\hyphpar0\qj{, 321.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Bus routes \u8212\'3f basis of operation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The establishment and operation of bus routes and the contracting for transportation shall be based upon the following considerations:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each bus route shall be planned and adjusted to utilize the normal seating capacity of each bus insofar as it is possible to do so.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each bus route shall serve only those pupils living in those areas where transportation by bus is the most economical method for providing adequate transportation facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A route shall not be extended for the purpose of accommodating pupils whose homes are nearer another bus route.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Special contracts for transportation of pupils entitled to transportation shall be entered into only when it is more economical to make such special provision than to provide same by regular bus route, or when by reason of physical or mental disability of the pupil such pupil cannot be transported with safety by bus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The boards shall take advantage of all tax exemptions on fuel, equipment, and of such other economies as are available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The use of school buses shall be restricted to transporting pupils to and from school and to and from extracurricular activities sponsored by the school when such extracurricular activity is under the direction of a qualified member of the faculty and a part of the regular school program and to transporting other persons to the extent permitted by }}}{{\f5\fs18\hyphpar0\qj{section 285.1, subsection 1}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{section 285.10, subsections 9 and 10}}}{{\f5\fs18\hyphpar0\qj{. School employees of districts operating buses may be transported to and from school and approved activities which they are required to attend as a result of their responsibilities. Provided, however, nothing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall prohibit the use of school buses in transporting a school teacher going to and from the teacher\u8217\'3fs school when such school is on an established school bus route and such teacher makes arrangements with the district operating such school bus.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No bus shall leave the public highway to receive or discharge pupils unless their safety is enhanced thereby, or the private road is maintained in the same manner as a public roadway.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bus routes shall be established only to give service to properly designated pupils.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{4179.1;}}}{ C46, \'a7276.27, 285.11; C50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1230, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1129, \'a7113}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1152, \'a745}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.12}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disputes \u8212\'3f hearings and appeals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In the event of a disagreement between a school patron and the board of the school district, the patron if dissatisfied with the decision of the district board, may appeal to the area education agency board, notifying the secretary of the district in writing within ten days of the decision of the board and by filing an affidavit of appeal with the agency board within the ten-day period. The affidavit of appeal shall include the reasons for the appeal and points at issue. The secretary of the local board on receiving notice of appeal shall certify all papers to the agency board which shall hear the appeal within ten days of the receipt of the papers and decide it within three days of the conclusion of the hearing and shall immediately notify all parties of its decision. Either party may appeal the decision of the agency board to the director of the department of education by notifying the opposite party and the agency administrator in writing within five days after receipt of notice of the decision of the agency board and by filing with the director of the department of education an affidavit of appeal, reasons for appeal, and the facts involved in the disagreement within five days after receipt of notice of the decision of the agency board. The agency administrator shall, within ten days of receipt of the notice, file with the director all records and papers pertaining to the case, including action of the agency board. The director shall hear the appeal within fifteen days of the filing of the records in the director\u8217\'3fs office, notifying all parties and the agency administrator of the date and time of hearing. The director shall notify all parties of the decision and return all papers with a copy of the decision to the agency administrator. The decision of the director shall be subject to judicial review in accordance with }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{. Pending final order made by the director, upon any appeal prosecuted to such director, the order of the agency board from which the appeal is taken shall be operative and be in full force and effect.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.12}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a721 \u8211\'3f 23}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 159, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1140, \'a728}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 108, \'a7127, 132}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7285.4}}}{{\f5\fs12\hyphpar0\qj{, 285.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.13}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Disagreements between boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In the event of a disagreement between the board of a school district and the board of an area education agency, the board of the school district may appeal to the director of the department of education and the procedure and times provided for in }{{\f5\fs18\hyphpar0\qj{section 285.12}}}{ shall prevail in any such case. The decision of the director shall be subject to judicial review in accordance with the terms of the Iowa administrative procedure Act, }{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.13}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 212, \'a721}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 44, \'a7114}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7285.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.14}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nonstandard buses \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who operates or permits to be operated as a school bus to transport pupils, any vehicle which does not comply with the requirements provided by law or by the rules and regulations of the department of education, or for which there is not a valid temporary certificate for operation, shall be guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vehicle used for an approved driver education course in which the driver education teacher transports driver education students from their residences for street or highway driving is not a school bus.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2021 Acts, ch 76, \'a7150}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.15}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Forfeiture of reimbursement rights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The failure of any local district to comply with the provisions of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or any other laws relating to the transportation of pupils, or any rules made by the department of education under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or the final decisions of the area education agency board, or the final decisions of the department of education shall during the period such failure to comply existed forfeit the rights to collect transportation costs from school or parents while operating in such illegal manner. Any superintendent, board, or board member who knowingly operates or permits to be operated any school bus transporting public school pupils in violation of any school transportation law shall be deemed guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.15}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{285.16}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{\u8220\'3fNonpublic school\u8221\'3f defined.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{As used in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{, }{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fnonpublic school\u8221\'3f}}}{ means those nonpublic schools accredited by the department of education as provided in }{{\f5\fs18\hyphpar0\qj{section 256.11}}}{ and nonpublic institutions which comply with state board of education standards for providing special education programs.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7285.16}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{87 Acts, ch 115, \'a743}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7257.11B}}}\par}}