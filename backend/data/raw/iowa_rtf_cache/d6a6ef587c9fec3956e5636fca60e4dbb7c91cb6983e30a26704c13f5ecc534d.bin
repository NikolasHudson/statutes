}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.97}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.98 through 147.100}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \f5 \fs18{{2008 Acts, ch 1088, \'a779}}}}}}{{\f5\fs18\qj{2008 Acts, ch 1088, \'a779}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.101}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.102 through 147.103A}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \f5 \fs18{{2008 Acts, ch 1088, \'a779}}}}}}{{\f5\fs18\qj{2008 Acts, ch 1088, \'a779}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.104}}}{\*\bkmkstart stylerid1_2E95_2E2_2E2}{\*\bkmkend stylerid1_2E95_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Records.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \cf5 \f5 \fs18{{2008 Acts, ch 1088, \'a778}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.105}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E97_2E1_2E1}{ANATOMIC PATHOLOGY}{\*\bkmkend stylerid1_2E97_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{SERVICES BILLING}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.106}}}{\*\bkmkstart stylerid1_2E98_2E2_2E2}{\*\bkmkend stylerid1_2E98_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Anatomic pathology services \u8212\'3f billing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physician or a clinical laboratory located in this state or in another state that provides anatomic pathology services to a patient in this state shall present or cause to be presented a claim, bill, or demand for payment for such services only to the following persons:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The patient who is the recipient of the services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The insurer or other third-party payor responsible for payment of the services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The hospital that ordered the services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The public health clinic or nonprofit clinic that ordered the services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The referring clinical laboratory, other than the laboratory of a physician\u8217\'3fs office or group practice, that ordered the services. A laboratory of a physician\u8217\'3fs office or group practice that ordered the services may be presented a claim, bill, or demand for payment if a physician in the physician\u8217\'3fs office or group practice is performing the professional component of the anatomic pathology services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A governmental agency or a specified public or private agent, agency, or organization that is responsible for payment of the services on behalf of the recipient of the services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided under }}}{{\f5\fs18\hyphpar0\qj{subsections 5 and 6}}}{{\f5\fs18\hyphpar0\qj{, a clinical laboratory or a physician providing anatomic pathology services to patients in this state shall not, directly or indirectly, charge, bill, or otherwise solicit payment for such services unless the services were personally rendered by the clinical laboratory or the physician or under the direct supervision of the clinical laboratory or the physician in accordance with section 353 of the federal Public Health Service Act, 42 U.S.C. \'a7263a.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person to whom a claim, bill, or demand for payment for anatomic pathology services is submitted is not required to pay the claim, bill, or demand for payment if the claim, bill, or demand for payment is submitted in violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to mandate the assignment of benefits for anatomic pathology services as defined in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit claims or charges presented to a referring clinical laboratory, other than a laboratory of a physician\u8217\'3fs office or group practice unless in accordance with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fe\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, by another clinical laboratory when samples are transferred between laboratories for the provision of anatomic pathology services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit claims or charges for anatomic pathology services presented on behalf of a public health clinic or nonprofit clinic that ordered the services provided that the clinic is identified on the claim or charge presented.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ by a physician shall subject the physician to the disciplinary provisions of }}}{{\f5\fs18\hyphpar0\qj{section 272C.3, subsection 2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAnatomic pathology services\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Histopathology or surgical pathology, meaning the gross and microscopic examination and histologic processing of organ tissue performed by a physician or under the supervision of a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cytopathology, meaning the examination of cells from fluids, aspirates, washings, brushings, or smears, including the Pap test examination, performed by a physician or under the supervision of a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Hematology, meaning the microscopic evaluation of bone marrow aspirates and biopsies performed by a physician or under the supervision of a physician, and the examination of peripheral blood smears performed by a physician or under the supervision of a physician upon the request of an attending or treating physician or technologist that a blood smear be reviewed by a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subcellular pathology and molecular pathology services performed by a physician or under the supervision of a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Bloodbanking services performed by a physician or under the supervision of a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPhysician\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any person licensed to practice medicine and surgery or osteopathic medicine and surgery in this state or in another state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 10, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 179, \'a7120}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1185, \'a773, 74}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a795}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E99_2E1_2E1}{DRUG AND LENS DISPENSING, SUPPLYING,}{\*\bkmkend stylerid1_2E99_2E1_2E1}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0{AND PRESCRIBING}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.107}}}{\*\bkmkstart stylerid1_2E1_30_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Drug dispensing, supplying, and prescribing \u8212\'3f limitations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person, other than a pharmacist, physician, dentist, podiatric physician, prescribing psychologist, or veterinarian who dispenses as an incident to the practice of the practitioner\u8217\'3fs profession, shall not dispense prescription drugs or controlled substances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prescriber who dispenses prescription drugs, including but not limited to controlled substances, for human use, may delegate nonjudgmental dispensing functions to staff assistants only when verification of the accuracy and completeness of the dispensing is determined by the practitioner in the practitioner\u8217\'3fs physical presence. However, the physical presence requirement does not apply when a practitioner is utilizing an automated dispensing system. When using an automated dispensing system, the practitioner shall utilize an internal quality control assurance plan that ensures accuracy for dispensing. Verification of automated dispensing accuracy and completeness remains the responsibility of the practitioner and shall be determined in accordance with rules adopted by the board of medicine, the dental board, the board of podiatry, and the board of behavioral health professionals for their respective licensees.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prescriber who dispenses prescription drugs, other than drug samples, pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, shall report the fact that they dispense prescription drugs with the practitioner\u8217\'3fs respective board at least biennially.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prescriber who dispenses prescription drugs, other than drug samples, pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, shall provide the patient with a prescription, if requested, that may be dispensed from a pharmacy of the patient\u8217\'3fs choice or offer to transmit the prescription orally, electronically, or by facsimile in accordance with }}}{{\f5\fs18\hyphpar0\qj{section 155A.27}}}{{\f5\fs18\hyphpar0\qj{ to a pharmacy of the patient\u8217\'3fs choice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pharmacist who dispenses prescription drugs, including but not limited to controlled substances, for human use, may delegate nonjudgmental dispensing functions only when verification of the accuracy and completeness of the dispensing is determined by the pharmacist in the pharmacist\u8217\'3fs physical presence. The pharmacist\u8217\'3fs verification of the accuracy of the prescription drug dispensed shall not be required when verified by a certified pharmacy technician in a technician product verification program as defined in }}}{{\f5\fs18\hyphpar0\qj{section 155A.3}}}{{\f5\fs18\hyphpar0\qj{. The pharmacist\u8217\'3fs physical presence shall not be required when the pharmacist is remotely supervising pharmacy personnel operating in a licensed telepharmacy site or when utilizing an automated dispensing system that utilizes an internal quality control assurance plan. When utilizing a technician product verification program, or when remotely supervising pharmacy personnel operating at a licensed telepharmacy site, the pharmacist shall utilize an internal quality control assurance plan, in accordance with rules adopted by the board of pharmacy, that ensures accuracy for dispensing. Automated dispensing verification, technician product verification, and telepharmacy practice accuracy and completeness remains the responsibility of the pharmacist and shall be determined in accordance with rules adopted by the board of pharmacy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A registered nurse may supply, when pharmacist services are not reasonably available or when it is in the best interests of the patient, on the direct order of the supervising physician, a quantity of properly packaged and labeled prescription drugs, controlled substances, or contraceptive devices necessary to complete a course of therapy. However, a remote clinic, staffed by a registered nurse, where pharmacy services are not reasonably available, shall secure the regular advice and consultation of a pharmacist regarding the distribution, storage, and appropriate use of such drugs, substances, and devices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ and any other provision of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ to the contrary, a physician assistant may prescribe, dispense, order, administer, or procure prescription drugs, controlled substances, or medical devices necessary to complete a course of therapy pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 148C.4}}}{{\f5\fs18\hyphpar0\qj{. Rules relating to the authority of physician assistants to prescribe drugs, controlled substances, and medical devices pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be adopted by the board of physician assistants after consultation with the board of medicine and board of pharmacy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, a family planning clinic may dispense birth control drugs and devices upon the order of a physician. }}}{{\f5\fs18\hyphpar0\qj{Subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{ do not apply to a family planning clinic under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, but subject to the limitations contained in }}}{{\f5\fs18\hyphpar0\qj{subsections 2 and 3}}}{{\f5\fs18\hyphpar0\qj{, a registered nurse who is licensed as an advanced registered nurse practitioner may prescribe substances or devices, including controlled substances or devices, if the nurse is engaged in the practice of a nursing specialty regulated under rules adopted by the board of nursing in consultation with the board of medicine and the board of pharmacy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 147.86}}}{{\f5\fs18\hyphpar0\qj{, a person, including a pharmacist, who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1006, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1232, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 238, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 239, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1163, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1183, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1134, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 108, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1108, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 93, \'a73, 14}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 108, \'a739}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1036, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1101, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1094, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a778}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 218, \'a7202}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1016, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 56, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1093, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1112, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1142, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1020, \'a71, 12}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 68, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 73, \'a75, 6}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7490}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7148G.1}}}{{\f5\fs12\hyphpar0\qj{, 152B.1}}}{{\f5\fs12\hyphpar0\qj{, 154.1}}}{{\f5\fs12\hyphpar0\qj{, 155A.2}}}{{\f5\fs12\hyphpar0\qj{, 155A.4}}}{{\f5\fs12\hyphpar0\qj{, 155A.47}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.108}}}{\*\bkmkstart stylerid1_2E1_301_2E2_2E2}{\*\bkmkend stylerid1_2E1_301_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contact lens prescribing and dispensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not dispense or adapt contact lenses without first receiving authorization to do so by a written, electronic, or facsimile prescription, except when authorized orally under }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, from a person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{. The board of optometry shall adopt rules relating to electronic or facsimile transmission of a prescription under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{After contact lenses have been adequately adapted and the patient released from initial follow-up care by a person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{, the patient may request a copy, at no cost, of the contact lens prescription from that licensed person. A person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{ shall not withhold a contact lens prescription after the requirements of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ have been met. The prescription, at the option of the prescriber, may be given orally only to a person who is actively practicing and licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{, or }}}{{\f5\fs18\hyphpar0\qj{155A}}}{{\f5\fs18\hyphpar0\qj{. The contact lens prescription shall contain an expiration date, at the discretion of the prescriber, but not to exceed eighteen months. The contact lens prescription shall contain the necessary requirements of the ophthalmic lens, and the prescription validation requirements as defined by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The prescription may contain adapting and material guidelines and may also contain specific instructions for use by the patient. For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fophthalmic lens\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one which has been fabricated to fill the requirements of a particular contact lens prescription, including pharmaceutical-delivering contact lenses as defined in }}}{{\f5\fs18\hyphpar0\qj{section 154.1, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who fills a contact lens prescription shall maintain a file of a valid prescription for a period of two years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 147.86}}}{{\f5\fs18\hyphpar0\qj{, a person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor for a first violation. Subsequent violations are governed by }}}{{\f5\fs18\hyphpar0\qj{section 147.86}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1098, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1036, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a779}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a796}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1010, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1004, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.109}}}{\*\bkmkstart stylerid1_2E1_302_2E2_2E2}{\*\bkmkend stylerid1_2E1_302_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Ophthalmic spectacle lens prescribing and dispensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not dispense or adapt an ophthalmic spectacle lens or lenses without first receiving authorization to do so by a written, electronic, or facsimile prescription from a person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{. For the purpose of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fophthalmic spectacle lens\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one which has been fabricated to fill the requirements of a particular spectacle lens prescription. The board of optometry shall adopt rules relating to electronic or facsimile transmission of a prescription under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon completion of an eye examination, a person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{ shall furnish the patient a copy of their ophthalmic spectacle lens prescription at no cost. The ophthalmic spectacle lens prescription shall contain an expiration date. The ophthalmic spectacle lens prescription shall contain the requirements of the ophthalmic spectacle lens and the prescription validation requirements as defined by rules adopted pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The prescription, at the option of the prescriber, may contain adapting and material guidelines and may also contain specific instructions for use by the patient.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon request of a patient, a person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{ shall provide the prescription of the patient, if the prescription has not expired, at no cost to another person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{. The person licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{154}}}{{\f5\fs18\hyphpar0\qj{ shall accept the prescription and shall not require the patient to undergo an eye examination unless, due to observation or patient history, the licensee has reason to require an examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A dispenser shall maintain a file of a valid prescription for a period of two years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 147.86}}}{{\f5\fs18\hyphpar0\qj{, a person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is guilty of a simple misdemeanor for a first violation. Subsequent violations are governed by }}}{{\f5\fs18\hyphpar0\qj{section 147.86}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1098, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1036, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a780}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a797}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.110}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E1_304_2E1_2E1}{WOUNDS BY CRIMINAL VIOLENCE OR MOTOR VEHICLE}{\*\bkmkend stylerid1_2E1_304_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.111}}}{\*\bkmkstart stylerid1_2E1_305_2E2_2E2}{\*\bkmkend stylerid1_2E1_305_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Report of treatment of wounds and other injuries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{ A person licensed under the provisions of }}}{{\f5\fs18\hyphpar0\qj{this subtitle}}}{{\f5\fs18\hyphpar0\qj{ who administers any treatment to any person suffering a gunshot or stab wound or other serious injury, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.18}}}{{\f5\fs18\hyphpar0\qj{, which appears to have been received in connection with the commission of a criminal offense, or a motor vehicle accident or crash, or to whom an application is made for treatment of any nature because of any such gunshot or stab wound or other serious injury, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.18}}}{{\f5\fs18\hyphpar0\qj{, shall at once but not later than twelve hours thereafter, report that fact to the law enforcement agency within whose jurisdiction the treatment was administered or an application for treatment was made, or if ascertainable, to the law enforcement agency in whose jurisdiction the gunshot or stab wound or other serious injury occurred, stating the name of such person, the person\u8217\'3fs residence if ascertainable, and giving a brief description of the gunshot or stab wound or other serious injury. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person certified under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 147A}}}{{\f5\fs18\hyphpar0\qj{ who administers any treatment to any person suffering a gunshot or stab wound or other serious injury, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 702.18}}}{{\f5\fs18\hyphpar0\qj{, which appears to have been received in connection with the commission of a criminal offense, or a motor vehicle accident or crash, or to whom an application is made for treatment of any nature because of any such gunshot or stab wound or other serious injury, may report that fact to the law enforcement agency within whose jurisdiction the treatment was administered or application for treatment was made, or if ascertainable, to the law enforcement agency in whose jurisdiction the gunshot or stab wound or other serious injury occurred, stating the name of the person, the person\u8217\'3fs residence if ascertainable, and giving a brief description of the gunshot or stab wound or other serious injury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any provision of law or rule of evidence relating to a confidential communication is suspended for communications under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a72537-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2537.7;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.111}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 100, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1132, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1036, \'a730}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1053, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 114, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1127, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7147.112}}}{{\f5\fs12\hyphpar0\qj{, 331.653}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.112}}}{\*\bkmkstart stylerid1_2E1_306_2E2_2E2}{\*\bkmkend stylerid1_2E1_306_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Investigation and report by law enforcement agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The law enforcement agency who has received any report required by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and who has any reason to believe that the person injured was involved in the commission of any crime, either as perpetrator or victim, shall at once commence an investigation into the circumstances of the gunshot or stab wound or other serious injury and make a report of the investigation to the county attorney in whose jurisdiction the gunshot or stab wound or other serious injury occurred. Law enforcement personnel shall not divulge any information received under the provisions of }{{\f5\fs18\hyphpar0\qj{this section}}}{ and }{{\f5\fs18\hyphpar0\qj{section 147.111}}}{ to any person other than a law enforcing officer, and then only in connection with the investigation of the alleged commission of a crime.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a72537-d2; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2537.8;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.112}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 100, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{99 Acts, ch 114, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7331.653}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{\u8220\'3fSerious injury\u8221\'3f definition, see }{{\f5\fs12\hyphpar0\qj{\'a7702.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.113}}}{\*\bkmkstart stylerid1_2E1_307_2E2_2E2}{\*\bkmkend stylerid1_2E1_307_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person failing to make the report required herein shall be guilty of a simple misdemeanor.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a72537-d3; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2537.9;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.113}}}{]}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E1_308_2E1_2E1}{BURN INJURIES}{\*\bkmkend stylerid1_2E1_308_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.113A}}}{\*\bkmkstart stylerid1_2E1_309_2E2_2E2}{\*\bkmkend stylerid1_2E1_309_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Report of burn injuries.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person licensed under the provisions of this subtitle who administers any treatment to a person suffering a burn which appears to be of a suspicious nature on the body, a burn to the upper respiratory tract, a laryngeal edema due to the inhalation of super-heated air, or a burn injury that is likely to result in death, which appears to have been received in connection with the commission of a criminal offense, or to whom an application is made for treatment of any nature because of any such burn or burn injury shall at once but not later than twelve hours after treatment was administered or application was made report the fact to law enforcement. The report shall be made to the law enforcement agency within whose jurisdiction the treatment was administered or application was made, or if ascertainable, to the law enforcement agency in whose jurisdiction the burn or burn injury occurred, stating the name of such person, the person\u8217\'3fs residence if ascertainable, and giving a brief description of the burn or burn injury. Any provision of law or rule of evidence relative to confidential communications is suspended insofar as the provisions of }{{\f5\fs18\hyphpar0\qj{this section}}}{ are concerned.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 134, \'a71}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E11_30_2E1_2E1}{PELVIC EXAMINATIONS \u8212\'3f INFORMED CONSENT}{\*\bkmkend stylerid1_2E11_30_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.114}}}{\*\bkmkstart stylerid1_2E111_2E2_2E2}{\*\bkmkend stylerid1_2E111_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Prior informed consent relative to pelvic examinations }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ patient under anesthesia or unconscious }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person licensed or certified to practice a profession, or a student undertaking a course of instruction or participating in a clinical training or residency program for a profession, shall not perform a pelvic examination on an anesthetized or unconscious patient unless one of the following conditions is met:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The patient or the patient\u8217\'3fs authorized representative provides prior written informed consent to the pelvic examination, and the pelvic examination is necessary for preventive, diagnostic, or treatment purposes. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The patient or the patient\u8217\'3fs authorized representative has provided prior written informed consent to a surgical procedure or diagnostic examination to be performed on the patient, and the performance of a pelvic examination is within the scope of care ordered for that surgical procedure or diagnostic examination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The patient is unconscious and incapable of providing prior informed consent, and the pelvic examination is necessary for diagnostic or treatment purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A court has ordered the performance of the pelvic examination for the purposes of collection of evidence. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is subject to the penalty specified under }}}{{\f5\fs18\hyphpar0\qj{section 147.86}}}{{\f5\fs18\hyphpar0\qj{, and any professional disciplinary provisions, as applicable.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 174, \'a7111}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.115 through 147.134}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E113_2E1_2E1}{MALPRACTICE}{\*\bkmkend stylerid1_2E113_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.135}}}{\*\bkmkstart stylerid1_2E114_2E2_2E2}{\*\bkmkend stylerid1_2E114_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Peer review committees \u8212\'3f nonliability \u8212\'3f records and reports privileged and confidential.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not be civilly liable as a result of acts, omissions, or decisions made in connection with the person\u8217\'3fs service on a peer review committee. However, such immunity from civil liability shall not apply if an act, omission, or decision is made with malice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpeer review records\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means all complaint files, investigation files, reports, and other investigative information relating to licensee discipline or professional competence in the possession of a peer review committee or an employee of a peer review committee. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpeer review committee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include licensing boards. Peer review records are privileged and confidential, are not subject to discovery, subpoena, or other means of legal compulsion for release to a person other than an affected licensee or a peer review committee, and are not admissible in evidence in a judicial or administrative proceeding other than a proceeding involving licensee discipline or a proceeding brought by a licensee who is the subject of a peer review record and whose competence is at issue. A person shall not be liable as a result of filing a report or complaint with a peer review committee or providing information to such a committee, or for disclosure of privileged matter to a peer review committee. A person present at a meeting of a peer review committee shall not be permitted to testify as to the findings, recommendations, evaluations, or opinions of the peer review committee in any judicial or administrative proceeding other than a proceeding involving licensee discipline or a proceeding brought by a licensee who is the subject of a peer review committee meeting and whose competence is at issue. Information or documents discoverable from sources other than the peer review committee do not become nondiscoverable from the other sources merely because they are made available to or are in the possession of a peer review committee. However, such information relating to licensee discipline may be disclosed to an appropriate licensing authority in any jurisdiction in which the licensee is licensed or has applied for a license. If such information indicates a crime has been committed, the information shall be reported to the proper law enforcement agency. }}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ shall not preclude the discovery of the identification of witnesses or documents known to a peer review committee. Any final written decision and finding of fact by a licensing board in a disciplinary proceeding is a public record. Upon appeal by a licensee of a decision of a board, the entire case record shall be submitted to the reviewing court. In all cases where privileged and confidential information under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ becomes discoverable, admissible, or part of a court record the identity of an individual whose privilege has been involuntarily waived shall be withheld.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A full and confidential report concerning any final hospital disciplinary action approved by a hospital board of trustees that results in a limitation, suspension, or revocation of a physician\u8217\'3fs privilege to practice for reasons relating to the physician\u8217\'3fs professional competence or concerning any voluntary surrender or limitation of privileges for reasons relating to professional competence shall be made to the board of medicine by the hospital administrator or chief of medical staff within ten days of such action. The board of medicine shall investigate the report and take appropriate action. These reports shall be privileged and confidential as though included in and subject to the requirements for peer review committee information in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{. Persons making these reports and persons participating in resulting proceedings related to these reports shall be immune from civil liability with respect to the making of the report or participation in resulting proceedings. As used in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fphysician\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person licensed pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, if the board of medicine conducts an investigation based on a complaint received or upon its own motion, a hospital pursuant to subpoena shall make available information and documents requested by the board, specifically including reports or descriptions of any complaints or incidents concerning an individual who is the subject of the board\u8217\'3fs investigation, even though the information and documents are also kept for, are the subject of, or are being used in peer review by the hospital. However, the deliberations, testimony, decisions, conclusions, findings, recommendations, evaluations, work product, or opinions of a peer review committee or its members and those portions of any documents or records containing or revealing information relating thereto shall not be subject to the board\u8217\'3fs request for information, subpoena, or other legal compulsion. All information and documents received by the board from a hospital under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be confidential pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 272C.6, subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.135}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1211, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1086, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a782}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a751}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7139A.22}}}{{\f5\fs12\hyphpar0\qj{, 147.1}}}{{\f5\fs12\hyphpar0\qj{, 147A.23}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.136}}}{\*\bkmkstart stylerid1_2E115_2E2_2E2}{\*\bkmkend stylerid1_2E115_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Scope of recovery.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{, in an action for damages for personal injury against a physician and surgeon, osteopathic physician and surgeon, dentist, podiatric physician, optometrist, pharmacist, chiropractor, physician assistant, or nurse licensed to practice that profession in this state, or against a hospital licensed for operation in this state, based on the alleged negligence of the practitioner in the practice of the profession or occupation, or upon the alleged negligence of the hospital in patient care, in which liability is admitted or established, the damages awarded shall not include actual economic losses incurred or to be incurred in the future by the claimant by reason of the personal injury, including but not limited to the cost of reasonable and necessary medical care, rehabilitation services, and custodial care, and the loss of services and loss of earned income, to the extent that those losses are replaced or are indemnified by insurance, or by governmental, employment, or service benefit programs or from any other source.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not bar recovery of economic losses replaced or indemnified by any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Benefits received under the medical assistance program under }}}{{\f5\fs18\hyphpar0\qj{chapter 249A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The assets of the claimant or of the members of the claimant\u8217\'3fs immediate family.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.136}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 108, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7141}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 129, \'a785, 156}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1020, \'a72, 12}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7668.14}}}{{\f5\fs12\hyphpar0\qj{, 668.14A}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.136A}}}{\*\bkmkstart stylerid1_2E116_2E2_2E2}{\*\bkmkend stylerid1_2E116_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Noneconomic damage awards against health care providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of this section:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth care provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a hospital as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135B.1}}}{{\f5\fs18\hyphpar0\qj{, a health care facility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135C.1}}}{{\f5\fs18\hyphpar0\qj{, a health facility as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135P.1}}}{{\f5\fs18\hyphpar0\qj{, a physician or an osteopathic physician licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{, a physician assistant licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{, a podiatrist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 149}}}{{\f5\fs18\hyphpar0\qj{, a chiropractor licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 151}}}{{\f5\fs18\hyphpar0\qj{, a licensed practical nurse, a registered nurse, or an advanced registered nurse practitioner licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{152E}}}{{\f5\fs18\hyphpar0\qj{, a dentist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 153}}}{{\f5\fs18\hyphpar0\qj{, an optometrist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154}}}{{\f5\fs18\hyphpar0\qj{, a pharmacist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 155A}}}{{\f5\fs18\hyphpar0\qj{, a professional corporation under }}}{{\f5\fs18\hyphpar0\qj{chapter 496C}}}{{\f5\fs18\hyphpar0\qj{ that is owned by persons licensed to practice a profession listed in this paragraph, or any other person or entity who is licensed, certified, or otherwise authorized or permitted by the law of this state to administer health care in the ordinary course of business or in the practice of a profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNoneconomic damages\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means damages arising from pain, suffering, inconvenience, physical impairment, mental anguish, emotional pain and suffering, loss of chance, loss of consortium, or any other nonpecuniary damages.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fNoneconomic damages\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include the loss of dependent care, including the loss of child care, due to the death of or severe injury to a spouse or parent who is the primary caregiver of a child under the age of eighteen or a disabled adult. Such damages shall be considered economic damages.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOccurrence\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the event, incident, or happening, and the acts or omissions incident thereto, which proximately caused injuries or damages for which recovery is claimed by the patient or the patient\u8217\'3fs representative.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{, the total amount recoverable in any civil action for noneconomic damages for personal injury or death, whether in tort, contract, or otherwise, against a health care provider for any occurrence resulting in injury or death of a patient regardless of the number of plaintiffs, derivative claims, theories of liability, or defendants in the civil action, shall not exceed two hundred fifty thousand dollars unless the jury determines that there is a substantial or permanent loss or impairment of a bodily function, substantial disfigurement, loss of pregnancy, or death, which warrants a finding that imposition of such a limitation would deprive the plaintiff of just compensation for the injuries sustained, in which case the amount recoverable shall not exceed one million dollars, or two million dollars if the civil action includes a hospital as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135B.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The limitation on damages contained in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply as to a defendant if that defendant\u8217\'3fs actions constituted actual malice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The limitations on damages contained in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ shall increase by two and one-tenth percent on January 1, 2028, and each January 1 thereafter. In any civil action described in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, such limitations on damages shall be the amount effective at the time of the occurrence. The commissioner of insurance shall publish the amount of the limitations on damages contained in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ on the insurance division\u8217\'3fs internet site and shall update the published amount annually.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 107, \'a72, 5}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a746}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 4, \'a71 \u8211\'3f 3, 5, 6}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 73, \'a77}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7147.139}}}{{\f5\fs12\hyphpar0\qj{, 147.140}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies to causes of action that accrue on or after July 1, 2017; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2017/CH0107.pdf" }{\fldrslt \cf5 \f5 \fs12{{2017 Acts, ch 107, \'a75}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2023 amendments to subsection 1, paragraph b, subsection 2, and new subsection 4, by 2023 Acts, ch 4, apply to causes of action accrued on or after February 16, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 4, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.137}}}{\*\bkmkstart stylerid1_2E117_2E2_2E2}{\*\bkmkend stylerid1_2E117_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Consent in writing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A consent in writing to any medical or surgical procedure or course of procedures in patient care which meets the requirements of }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall create a presumption that informed consent was given. A consent in writing meets the requirements of }{{\f5\fs18\hyphpar0\qj{this section}}}{ if it:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sets forth in general terms the nature and purpose of the procedure or procedures, together with the known risks, if any, of death, brain damage, quadriplegia, paraplegia, the loss or loss of function of any organ or limb, or disfiguring scars associated with such procedure or procedures, with the probability of each such risk if reasonably determinable.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Acknowledges that the disclosure of that information has been made and that all questions asked about the procedure or procedures have been answered in a satisfactory manner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Is signed by the patient for whom the procedure is to be performed, or if the patient for any reason lacks legal capacity to consent, is signed by a person who has legal authority to consent on behalf of that patient in those circumstances.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.137}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.138}}}{\*\bkmkstart stylerid1_2E118_2E2_2E2}{\*\bkmkend stylerid1_2E118_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Contingent fee of attorney reviewed by court.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In any action for personal injury or wrongful death against any physician and surgeon, osteopathic physician and surgeon, dentist, podiatric physician, optometrist, pharmacist, chiropractor, physician assistant, or nurse licensed under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or against any hospital licensed under }{{\f5\fs18\hyphpar0\qj{chapter 135B}}}{, based upon the alleged negligence of the licensee in the practice of that profession or occupation, or upon the alleged negligence of the hospital in patient care, the court shall determine the reasonableness of any contingent fee arrangement between the plaintiff and the plaintiff\u8217\'3fs attorney.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.138}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{95 Acts, ch 108, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a7141}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1020, \'a73, 12}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.139}}}{\*\bkmkstart stylerid1_2E119_2E2_2E2}{\*\bkmkend stylerid1_2E119_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expert witness standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the standard of care given by a health care provider, as defined in }{{\f5\fs18\hyphpar0\qj{section 147.136A}}}{, is at issue, the court shall only allow a person the plaintiff designates as an expert witness to qualify as an expert witness and to testify on the issue of the appropriate standard of care or breach of the standard of care if all of the following are established by the evidence:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The person is licensed to practice in the same or a substantially similar field as the defendant, is in good standing in each state of licensure, and in the five years preceding the act or omission alleged to be negligent, has not had a license in any state revoked or suspended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In the five years preceding the act or omission alleged to be negligent, the person actively practiced in the same or a substantially similar field as the defendant or was a qualified instructor at an accredited university in the same field as the defendant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant is board-certified in a specialty, the person is certified in the same or a substantially similar specialty by a board recognized by the American board of medical specialties, the American osteopathic association, or the council on podiatric medical education.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant is a licensed physician or osteopathic physician under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{, the person is a physician or osteopathic physician licensed in this state or another state.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the defendant is a licensed podiatric physician under }}}{{\f5\fs18\hyphpar0\qj{chapter 149}}}{{\f5\fs18\hyphpar0\qj{, the person is a physician, osteopathic physician, or a podiatric physician licensed in this state or another state.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1211, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a798}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 107, \'a73, 5}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a746}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7147.140}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{2017 amendment applies to causes of action that accrue on or after July 1, 2017; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2017/CH0107.pdf" }{\fldrslt \cf5 \f5 \fs12{{2017 Acts, ch 107, \'a75}}}}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.140}}}{\*\bkmkstart stylerid1_2E12_30_2E2_2E2}{\*\bkmkend stylerid1_2E12_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Expert witness }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ certificate of merit affidavit.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In any action for personal injury or wrongful death against a health care provider based upon the alleged negligence in the practice of that profession or occupation or in patient care, which includes a cause of action for which expert testimony is necessary to establish a prima facie case, the plaintiff shall, prior to the commencement of discovery in the case and within sixty days of the defendant\u8217\'3fs answer, serve upon the defendant a certificate of merit affidavit signed by an expert witness with respect to the issue of standard of care and an alleged breach of the standard of care. The expert witness must meet the qualifying standards of }}}{{\f5\fs18\hyphpar0\qj{section 147.139}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A certificate of merit affidavit must be signed by the expert witness and certify the purpose for calling the expert witness by providing under the oath of the expert witness all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The expert witness\u8217\'3fs statement of familiarity with the applicable standard of care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The expert witness\u8217\'3fs statement that the standard of care was breached by the health care provider named in the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A plaintiff shall serve a separate certificate of merit affidavit on each defendant named in the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An expert witness\u8217\'3fs certificate of merit affidavit does not preclude additional discovery and supplementation of the expert witness\u8217\'3fs opinions in accordance with the rules of civil procedure.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parties shall comply with the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 668.11}}}{{\f5\fs18\hyphpar0\qj{ and all other applicable law governing certification and disclosure of expert witnesses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The parties by agreement or the court for good cause shown and in response to a motion filed prior to the expiration of the time limits specified in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ may provide for extensions of the time limits. Good cause shall include but not be limited to the inability to timely obtain the plaintiff\u8217\'3fs medical records from health care providers when requested prior to filing the petition.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the plaintiff is acting pro se, the plaintiff shall have the expert witness sign the certificate of merit affidavit or answers to interrogatories referred to in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and the plaintiff shall be bound by those provisions as if represented by an attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure to substantially comply with }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall result, upon motion, in dismissal with prejudice of each cause of action as to which expert witness testimony is necessary to establish a prima facie case.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhealth care provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 147.136A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 107, \'a74, 5}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies to causes of action that accrue on or after July 1, 2017; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2017/CH0107.pdf" }{\fldrslt \cf5 \f5 \fs12{{2017 Acts, ch 107, \'a75}}}}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.141 through 147.150}}}{Reserved.}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E122_2E1_2E1}{SPEECH PATHOLOGISTS AND AUDIOLOGISTS}{\*\bkmkend stylerid1_2E122_2E1_2E1}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.151 and 147.152}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \f5 \fs18{{2008 Acts, ch 1088, \'a779}}}}}}{{\f5\fs18\qj{2008 Acts, ch 1088, \'a779}}}{.}{{\f5\fs18\qj{\~\~}}}{See }{{\f5\fs18\qj{\'a7154F.1}}}{, }{{\f5\fs18\qj{154F.2}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.153 through 147.156}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \f5 \fs18{{2008 Acts, ch 1088, \'a778}}}}}}{{\f5\fs18\qj{2008 Acts, ch 1088, \'a778}}}{.}{{\f5\fs18\qj{\~\~}}}{See }{{\f5\fs18\qj{\'a7154F.3 through 154F.6}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.157 through 147.160}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E126_2E1_2E1}{MENTAL HEALTH PROFESSIONALS EMPLOYMENT AGREEMENTS}{\*\bkmkend stylerid1_2E126_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.161}}}{\*\bkmkstart stylerid1_2E127_2E2_2E2}{\*\bkmkend stylerid1_2E127_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Mental health professionals }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ limitations on competition prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEmployer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person, as defined in }}}{{\f5\fs18\hyphpar0\qj{chapter 4}}}{{\f5\fs18\hyphpar0\qj{, who in this state employs for wages an employee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMental health professional\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 228.1}}}{{\f5\fs18\hyphpar0\qj{, and includes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals who are completing their supervisory requirement under a temporary license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensed master social workers with a current and active supervision plan on file with the board of behavioral health professionals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An employer shall not enter into an agreement with a licensed mental health professional that limits the location at which the licensee may practice, prohibits the licensee from contacting for professional services a person previously treated by the licensee, or imposes a time restriction on the practice of the licensee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A provision of an agreement entered into between an employer and a licensed mental health professional prior to, on, or after June 1, 2023, that is contrary to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be void and unenforceable.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 120, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7491}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E128_2E1_2E1}{OPIOID PRESCRIPTION RULES}{\*\bkmkend stylerid1_2E128_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.162}}}{\*\bkmkstart stylerid1_2E129_2E2_2E2}{\*\bkmkend stylerid1_2E129_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules and directives relating to opioids.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any board created under }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ that licenses a prescribing practitioner shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing penalties for prescribing practitioners that prescribe opioids in dosage amounts exceeding what would be prescribed by a reasonably prudent prescribing practitioner engaged in the same practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fprescribing practitioner\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a licensed health care professional with the authority to prescribe prescription drugs including opioids. }}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1138, \'a721}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E13_30_2E1_2E1}{AMBULATORY SURGICAL CENTERS}{\*\bkmkend stylerid1_2E13_30_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.163}}}{\*\bkmkstart stylerid1_2E131_2E2_2E2}{\*\bkmkend stylerid1_2E131_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Provision of information }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ referral to ambulatory surgical center }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ licensee discipline. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care provider who determines that a patient is a candidate for outpatient surgery based on the patient\u8217\'3fs medical status and surgical service needs, and refers the patient to an ambulatory surgical center as an option for the surgery, shall provide the patient with a written document listing the factors the patient should consider to make a fully informed decision about the patient\u8217\'3fs recommended course of care. The considerations shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The differences in ownership; licensure, certification, or accreditation; and payment alternatives between the ambulatory surgical center and a hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The types of medical personnel generally involved in the patient\u8217\'3fs surgical service and the capacity of the ambulatory surgical center and a hospital to comply with the personnel requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The capacity of the ambulatory surgical center and a hospital to respond to medical complications and emergencies that may arise from the surgical service.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The proximity of the ambulatory surgical center to a hospital and the protocols in place for transfer of a patient from the ambulatory surgical center to the hospital for emergency care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The type of anesthesia generally used for the patient\u8217\'3fs surgical service and the capacity of the ambulatory surgical center and a hospital to comply with requirements relative to the use of anesthesia.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAmbulatory surgical center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a distinct facility that operates exclusively for the purpose of providing surgical services to patients not requiring hospitalization and in which the expected duration of services does not exceed twenty-four hours following an admission. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAmbulatory surgical center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a facility that otherwise meets the definition of ambulatory surgical center whether or not licensed, certified, or accredited as an ambulatory surgical center and which may or may not operate on a partially cash-only or completely cash-only basis. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAmbulatory surgical center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include individual or group practice offices of private physicians or podiatrists that do not contain a distinct area used for outpatient surgical treatment on a regular basis, or that only provide surgery routinely provided in a physician\u8217\'3fs or podiatrist\u8217\'3fs office using local anesthesia or conscious sedation; individual or group practice offices of private dentists; or a portion of a licensed hospital designated for outpatient surgical treatment. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth care provider\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is licensed, certified, or otherwise authorized or permitted by the laws of this state to administer health care in the ordinary course of business or in the practice of a profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHospital\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 135B.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care provider who violates }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ is subject to licensee discipline by the appropriate licensing or disciplinary authority.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1153, \'a748}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E132_2E1_2E1}{GENDER TRANSITION PROCEDURES AND MINORS}{\*\bkmkend stylerid1_2E132_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.164}}}{\*\bkmkstart stylerid1_2E133_2E2_2E2}{\*\bkmkend stylerid1_2E133_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Gender transition procedure-related activities }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ minors }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ prohibitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fGender\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the psychological, behavioral, social, and cultural aspects of being male or female.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fHealth care professional\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a person who is licensed, certified, or otherwise authorized or permitted by the law of this state to administer health care in the ordinary course of business or in the practice of a profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fMinor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an unemancipated person under eighteen years of age.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fSex\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the biological indication of male and female, including sex chromosomes, naturally occurring sex hormones, gonads, and nonambiguous internal and external genitalia present at birth without regard to an individual\u8217\'3fs psychological, chosen, or subjective experience of gender.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as otherwise provided in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, a health care professional shall not knowingly engage in or cause any of the following practices to be performed on a minor if the practice is performed for the purpose of attempting to alter the appearance of, or affirm the minor\u8217\'3fs perception of, the minor\u8217\'3fs gender or sex, if that appearance or perception is inconsistent with the minor\u8217\'3fs sex:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing or administering gonadotropin-releasing hormone analogues or other synthetic drugs used to stop luteinizing hormone and follicle-stimulating hormone secretion, synthetic antiandrogen drugs used to block the androgen receptor, or any drug to suppress or delay normal puberty.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Prescribing or administering testosterone, estrogen, or progesterone to a minor in an amount greater than would normally be produced endogenously in a healthy individual of that individual\u8217\'3fs age and sex.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Performing surgeries that sterilize, including castration, vasectomy, hysterectomy, oophorectomy, orchiectomy, and penectomy.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Performing surgeries that artificially construct tissue with the appearance of genitalia that differs from the individual\u8217\'3fs sex, including metoidioplasty, phalloplasty, and vaginoplasty.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Removing any healthy or nondiseased body part or tissue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care professional shall not knowingly engage in conduct that aids or abets the practices described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{. This paragraph shall not be construed to impose liability on any speech protected by federal or state law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ do not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Services provided to a minor born with a medically verifiable disorder of sex development, including a minor with external biological sex characteristics that are irresolvably ambiguous, such as a minor born with forty-six XX chromosomes with virilization, forty-six XY chromosomes with undervirilization, or having both ovarian and testicular tissue.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Services provided to a minor who has otherwise been diagnosed with a disorder of sexual development by a physician, when the physician has determined through genetic or biochemical testing that the minor does not have a normal sex chromosome structure, sex steroid hormone production, or sex steroid hormone action for a biological male or biological female.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treatment of any infection, injury, disease, or disorder that has been caused or exacerbated by the performance of gender transition procedures, whether or not the procedures were performed in accordance with state and federal law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any procedure undertaken because a minor suffers from a physical disorder, physical injury, or physical illness that is certified by a physician and that would place the minor in imminent danger of death or impairment of a major bodily function unless surgery is performed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A violation of the prohibitions under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ by a health care professional is considered unprofessional conduct and subject to licensee discipline by the appropriate licensing board or entity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person may assert an actual or threatened violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ as a claim or defense in a judicial or administrative proceeding and may obtain compensatory damages, injunctive relief, declaratory relief, or any other appropriate relief.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An action brought for a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be brought within two years after the cause of action accrues. However, a minor may bring an action during the minor\u8217\'3fs minority through a parent or legal guardian, and may bring an action in the minor\u8217\'3fs own name upon reaching majority and for twenty years after reaching majority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other law to the contrary, an action under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be commenced, and relief may be granted, in a judicial proceeding without regard to whether the person commencing the action has sought or exhausted available administrative remedies. In an action or proceeding to enforce }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a prevailing party may recover reasonable attorney fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The attorney general may bring an action to enforce }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to deny, impair, or otherwise affect any right or authority of the attorney general, the state, or any agency, officer, or employee of the state to institute or intervene in any proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Compliance with, or enforcement or implementation of, }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not constitute a violation of any provision of }}}{{\f5\fs18\hyphpar0\qj{chapter 216}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 9, \'a71 \u8211\'3f 3}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 119, \'a739, 47, 49}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7601.1}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section applies one hundred eighty days after March 22, 2023; }{{\f5\fs12\hyphpar0\qj{2023 Acts, ch 9, \'a73}}}\par}}