s24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.6}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Certificate presumptive evidence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every license issued under this subtitle shall be presumptive evidence of the right of the holder to practice in this state the profession therein specified.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72576; S13, \'a72575-a30, -a38, 2576, 2583-k, 2600-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2443;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.6}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1132, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1036, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1053, \'a75}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.7}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Display of license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A board may require every person licensed by the board to display the license and evidence of current renewal publicly in a manner prescribed by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to a person who is licensed in another state and recognized for licensure in this state pursuant to the nurse licensure compact contained in }}}{{\f5\fs18\hyphpar0\qj{section 152E.1}}}{{\f5\fs18\hyphpar0\qj{ or pursuant to the advanced practice registered nurse compact contained in }}}{{\f5\fs18\hyphpar0\qj{section 152E.3}}}{{\f5\fs18\hyphpar0\qj{. A person licensed in another state and recognized for licensure in this state pursuant to either compact shall, however, maintain a copy of a license issued by the person\u8217\'3fs home state available for inspection when engaged in the practice of nursing in this state.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72591; S13, \'a72600-o1; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2444;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.7}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1086, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1132, \'a713}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1036, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1053, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{2000 Acts, ch 1008, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2005 Acts, ch 53, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2006 Acts, ch 1010, \'a754}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.8}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Record of licenses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A board shall keep the following information available for public inspection for each person licensed by the board:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Address of record.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The number of the license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The date of issuance of the license.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72591; S13, \'a72575-a40, 2583-a, -k, 2600-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2445;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.8}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1128, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a750}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.9}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Change of address.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Every person licensed pursuant to }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall notify the board which issued the license of a change in the person\u8217\'3fs address of record within a time period established by board rule.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72591; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2446;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.9}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1086, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1132, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1036, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1053, \'a77}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.10}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Renewal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Every license to practice a profession shall expire in multiyear intervals and be renewed as determined by the board upon application by the licensee. Each board shall establish rules for license renewal and concomitant fees. Application for renewal shall be made to the board accompanied by the required fee at least thirty days prior to the expiration of such license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each board may by rule establish a grace period following expiration of a license in which the license is not invalidated. Each board may assess a reasonable penalty for renewal of a license during the grace period. Failure of a licensee to renew a license within the grace period shall cause the license to become inactive or lapsed. A licensee whose license is inactive or lapsed shall not engage in the practice of the profession until the license is reactivated or reinstated.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72590; S13, \'a72575-a39, 2589-d; C24, 27, 31, \'a72447; C35, \'a72447, 2573-g2 \u8211\'3f 2573-g4; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2447, 2573.02 \u8211\'3f 2573.04;}}}{ C46, 50, 54, 58, 62, 66, \'a7147.10, 153.11 \u8211\'3f 153.12; C71, 73, \'a7147.10, 153.9, 153.10; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.10}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1108, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a79}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7147.11}}}{{\f5\fs12\hyphpar0\qj{, 148.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.11}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reactivation and reinstatement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee who allows the license to become inactive or lapsed by failing to renew the license, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 147.10}}}{{\f5\fs18\hyphpar0\qj{, may reactivate the license upon payment of a reactivation fee and compliance with other terms established by board rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A licensee whose license has been revoked, suspended, or voluntarily surrendered must apply for and receive reinstatement of the license in accordance with board rule and must apply for and be granted reactivation of the license in accordance with board rule prior to practicing the profession.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2448;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.11}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a730}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a751}}}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E19_2E1_2E1}{HEALTH PROFESSION BOARDS}{\*\bkmkend stylerid1_2E19_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.12}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Health profession boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governor shall appoint, subject to confirmation by the senate, a board for each of the professions. The board members shall not be required to be members of professional societies or associations composed of members of their professions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a person who has been appointed by the governor to serve on a board has ever been disciplined in a contested case by the board to which the person has been appointed, all board statements of charges, settlement agreements, findings of fact, and orders pertaining to the disciplinary action shall be made available to the senate committee to which the appointment is referred at the committee\u8217\'3fs request before the full senate votes on the person\u8217\'3fs appointment.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72576, 2584; S13, \'a72575-a29, -a37, 2576, 2583-a, -h, 2600-b; SS15, \'a72584; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2449;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.12}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1128, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1132, \'a715}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1036, \'a710}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1053, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a731}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a711}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7147.13}}}{{\f5\fs12\hyphpar0\qj{, 148.2A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Board of medicine alternate members, see }{{\f5\fs12\hyphpar0\qj{\'a7148.2A}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.13}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Designation of boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The boards provided in }{{\f5\fs18\hyphpar0\qj{section 147.12}}}{ shall be designated as follows:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medicine and surgery, osteopathic medicine and surgery, acupuncture, and genetic counseling, the board of medicine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For physician assistants, the board of physician assistants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For psychology, social work, applied behavior analysis, marital and family therapy, and mental health counseling, the board of behavioral health professionals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For podiatry, the board of podiatry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For chiropractic, the board of chiropractic.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For physical therapy and occupational therapy, the board of physical and occupational therapy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For nursing and midwifery, the board of nursing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For dentistry, dental hygiene, and dental assisting, the dental board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For optometry, the board of optometry.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For speech pathology and audiology, the board of speech pathology and audiology.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For cosmetology arts and sciences, the board of barbering and cosmetology arts and sciences.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For pharmacy, the board of pharmacy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For mortuary science, the board of mortuary science.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For dietetics, the board of dietetics.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For respiratory care and polysomnography, the board of respiratory care and polysomnography.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For massage therapy, the board of massage therapy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For athletic training, the board of athletic training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For interpreting, the board of sign language interpreters and transliterators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For nursing home administration, the board of nursing home administrators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For orthotics, prosthetics, and pedorthics, the board of podiatry.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2450;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1075, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 168, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1225, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 229, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1205, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 86, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1036, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1053, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1002, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7422, 433}}}{{\f5\fs18\hyphpar0\qj{; 2006 Acts, ch 1155, \'a73, 15}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 218, \'a7197}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a712, 141}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a752}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1101, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 57, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 70, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1052, \'a73, 12}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1106, \'a74, 14}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 99, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 127, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7226, 486, 487}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7147.1}}}{{\f5\fs12\hyphpar0\qj{, 147.82}}}{{\f5\fs12\hyphpar0\qj{, 232.69}}}{{\f5\fs12\hyphpar0\qj{, 235B.16}}}{{\f5\fs12\hyphpar0\qj{, 280.13C}}}{{\f5\fs12\hyphpar0\qj{, 422.7(16)}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.14}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Composition of boards \u8212\'3f quorum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board members shall consist of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medicine, five members licensed to practice medicine and surgery, two members licensed to practice osteopathic medicine and surgery, and three members not licensed to practice either medicine and surgery or osteopathic medicine and surgery, and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For nursing, three registered nurses, one of whom shall be actively engaged in practice, one of whom shall be a nurse educator from a nursing education program, and one of whom shall be an advanced registered nurse practitioner; one licensed practical nurse actively engaged in practice; and one member who is not a registered nurse or licensed practical nurse and who shall represent the general public. The representative of the general public shall not be a member of a health care delivery system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For dentistry, five members licensed to practice dentistry, two members licensed to practice dental hygiene, and two members not licensed to practice dentistry or dental hygiene and who shall represent the general public. The two dental hygienist board members and one dentist board member shall constitute a dental hygiene committee of the board as provided in }}}{{\f5\fs18\hyphpar0\qj{section 153.33A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For pharmacy, four members licensed to practice pharmacy, one member registered as a certified pharmacy technician as defined by the board by rule, and one member who is not licensed to practice pharmacy or registered as a certified pharmacy technician and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For optometry, four members licensed to practice optometry and one member who is not licensed to practice optometry and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For behavioral health professionals, two members who are licensed to practice psychology, two members who are licensed to practice social work as a master social worker or independent social worker, one member licensed to practice marital and family therapy, one member licensed to practice mental health counseling, one member licensed as a behavior analyst, and one member not licensed to practice psychology, social work, marital and family therapy, or mental health counseling, or as a behavior analyst, and who shall represent the general public. }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of behavioral health professionals shall establish an advisory committee of psychology, an advisory committee of social workers, and an advisory committee of mental health counselors, marital and family therapists, and behavior analysts to provide recommendations to the board on license reviews and implementation of state laws and administrative rules. Each advisory committee shall be comprised of at least five individuals licensed in the profession or professions about which the advisory committee provides recommendations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For chiropractic, five members licensed to practice chiropractic and two members who are not licensed to practice chiropractic and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For speech pathology and audiology, five members licensed to practice speech pathology or audiology at least two of whom shall be licensed to practice speech pathology and at least two of whom shall be licensed to practice audiology, and two members who are not licensed to practice speech pathology or audiology and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For physical therapy and occupational therapy, three members licensed to practice physical therapy, two members licensed to practice occupational therapy, and two members who are not licensed to practice physical therapy or occupational therapy and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For dietetics, one licensed dietitian representing the approved or accredited dietetic education programs, one licensed dietitian representing clinical dietetics, one licensed dietitian representing community nutrition services, and two members who are not licensed dietitians and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the board of physician assistants, five members licensed to practice as physician assistants, at least two of whom practice in counties with a population of less than fifty thousand, one member licensed to practice medicine and surgery who supervises a physician assistant engaged in independent practice or collaborates with a physician assistant, one member licensed to practice osteopathic medicine and surgery who supervises a physician assistant engaged in independent practice or collaborates with a physician assistant, and two members who are not licensed to practice either medicine and surgery or osteopathic medicine and surgery or licensed as a physician assistant and who shall represent the general public. At least one of the physician or osteopathic physician members shall be in practice in a county with a population of less than fifty thousand.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For respiratory care and polysomnography, one licensed physician with training in respiratory care, two respiratory care practitioners who have practiced respiratory care for a minimum of six years immediately preceding their appointment to the board and who are recommended by the society for respiratory care, one polysomnographic technologist who has practiced polysomnography for a minimum of six years immediately preceding appointment to the board and who is recommended by the Iowa sleep society, and one member not licensed to practice medicine, osteopathic medicine, polysomnography, or respiratory care who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For mortuary science, three members licensed to practice mortuary science, one member owning, operating, or employed by a crematory, and one member not licensed to practice mortuary science and not a crematory owner, operator, or employee who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For massage therapists, four members licensed to practice massage therapy and three members who are not licensed to practice massage therapy and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For athletic trainers, three members licensed to practice athletic training, three members licensed to practice medicine and surgery, and one member not licensed to practice athletic training or medicine and surgery and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For podiatry, five members licensed to practice podiatry, two members licensed to practice orthotics, prosthetics, or pedorthics, and two members who are not so licensed and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For sign language interpreting and transliterating, three members licensed to practice interpreting and transliterating, two of whom shall be practicing interpreters and transliterators at the time of appointment to the board and at least one of whom is employed in an educational setting; and two members who are consumers of interpreting or transliterating services as defined in }}}{{\f5\fs18\hyphpar0\qj{section 154E.1}}}{{\f5\fs18\hyphpar0\qj{, each of whom shall be deaf or hard of hearing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For nursing home administrators, a total of nine members, four who are licensed nursing home administrators, one of whom is the administrator of a nonproprietary nursing home; three licensed members of any profession concerned with the care and treatment of chronically ill or elderly patients who are not nursing home administrators or nursing home owners; and two members of the general public who are not licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 155}}}{{\f5\fs18\hyphpar0\qj{, have no financial interest in any nursing home, and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For barbering and cosmetology arts and sciences, three members who are licensed barbers or cosmetologists; one member who is a licensed instructor of barbering and cosmetology arts and sciences; one member who is a licensed electrologist, esthetician, or nail technologist; one member who owns a school of barbering and cosmetology arts and sciences; and one member who is not licensed in the practice of barbering and cosmetology arts and sciences and who shall represent the general public.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A majority of the members of a board constitutes a quorum.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72564, 2576, 2584; S13, \'a72564, 2575-a29, -a30, -a37, -a38, 2576, 2583-a, -h, -i, 2600-b, -c; SS15, \'a72584; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2451, 2452, 2475;}}}{ C46, 50, 54, 58, 62, 66, \'a7147.14, 147.15, 147.38; C71, 73, \'a7147.14, 147.15, 147.38, 153.1; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.14}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1075, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 168, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1003, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1022, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1134, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1225, \'a76, 7}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 229, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1183, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1205, \'a715, 16}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1035, \'a72, 3, 13}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1036, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1148, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1002, \'a71, 2}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1010, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1053, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 19, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 96, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7423, 433}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 3, \'a736}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 218, \'a7188}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1032, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 56, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2010 Acts, ch 1069, \'a718}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1101, \'a74}}}{{\f5\