\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1204, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{2001 Acts, ch 58, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a767}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a740}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.92}}}{\*\bkmkstart stylerid1_2E88_2E2_2E2}{\*\bkmkend stylerid1_2E88_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Attorney general.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Upon request of a board the attorney general shall institute in the name of the state the proper proceedings against any person charged by the board with violating any provision of this or the following chapters of this subtitle.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72600-o7; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2527;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.92}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1132, \'a729}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1173, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1036, \'a728}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1053, \'a726}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a741}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyp