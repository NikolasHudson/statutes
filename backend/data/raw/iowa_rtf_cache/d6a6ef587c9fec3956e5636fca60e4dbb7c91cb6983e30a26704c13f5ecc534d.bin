phpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.30}}}{\*\bkmkstart stylerid1_2E4_30_2E2_2E2}{\*\bkmkend stylerid1_2E4_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Time and place of examinations.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \cf5 \f5 \fs18{{2008 Acts, ch 1088, \'a778}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{See }}}{{\f5\fs18\hyphpar0\qj{\'a7147.34}}}{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.31 and 147.32}}}{Reserved.}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.33}}}{\*\bkmkstart stylerid1_2E42_2E2_2E2}{\*\bkmkend stylerid1_2E42_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Professional schools.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A dean of a college or university which provides instruction or training in a profession shall supply information or data related to the college or university upon request of a board.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2470;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.33}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a744}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a720}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.34}}}{\*\bkmkstart stylerid1_2E43_2E2_2E2}{\*\bkmkend stylerid1_2E43_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Examinations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each board shall by rule prescribe the examination or examinations required for licensure for the profession and the manner in which an applicant shall complete the examination process. A board may develop and administer the examination, may designate a national, uniform, or other examination as the prescribed examination, or may contract for such services. Dentists shall pass an examination approved by a majority of the dentist members of the dental board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{When a board administers an examination, the board shall provide adequate public notice of the time and place of the examination to allow candidates to comply with the provisions of this subtitle. Administration of examinations, including location, frequency, and reexamination, may be determined by the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Applicants who fail the examination once shall be allowed to take the examination at the next authorized time. Thereafter, applicants shall be allowed to take the examination at the discretion of the board. An applicant who has failed an examination may request in writing information from the board concerning the examination grade and subject areas or questions which the applicant failed to answer correctly, except that if the board prescribes a national or uniform examination, the board shall only be required to provide the examination grade and such other information concerning the applicant\u8217\'3fs examination results which are available to the board.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72576, 2582, 2589, 2597; S13, \'a72575-a29, -a37, 2576, 2582, 2583-a, -i, -k, 2589-a, 2600-c, -d; SS15, \'a72589-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2471, 2567, 2572, 2573;}}}{ C46, 50, 54, 58, 62, 66, \'a7147.34, 153.3, 153.8, 153.9; C71, 73, \'a7147.34, 153.2, 153.6, 153.8; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.34}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1132, \'a717}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1036, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1053, \'a712}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a745}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a721}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7153.21}}}{{\f5\fs12\hyphpar0\qj{, 155.3}}}{{\f5\fs12\hyphpar0\qj{, 156.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.35}}}{\*\bkmkstart stylerid1_2E44_2E2_2E2}{\*\bkmkend stylerid1_2E44_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Names of eligible candidates.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \cf5 \f5 \fs18{{2008 Acts, ch 1088, \'a779}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.36}}}{\*\bkmkstart stylerid1_2E45_2E2_2E2}{\*\bkmkend stylerid1_2E45_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each board may establish rules for any of the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The qualifications required for applicants seeking to take examinations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The denial of applicants seeking to take examinations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The conducting of examinations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The grading of examinations and passing upon the technical qualifications of applicants, as shown by such examinations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The minimum scores required for passing standardized examinations.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72584; S13, \'a72575-a38, 2583-a, -i, 2600-e; SS15, \'a72584; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2473;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.36}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1183, \'a73}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a747}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a722}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.37}}}{\*\bkmkstart stylerid1_2E46_2E2_2E2}{\*\bkmkend stylerid1_2E46_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Identity of candidate concealed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The identity of the person taking an examination shall not be disclosed during the examination process and in practice the identity of the candidate shall be concealed to the extent possible.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72576; S13, \'a72576, 2583-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2474;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.37}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a748}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a723}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.38}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.39 through 147.42}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \f5 \fs18{{2008 Acts, ch 1088, \'a779}}}}}}{{\f5\fs18\qj{2008 Acts, ch 1088, \'a779}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.43}}}{\*\bkmkstart stylerid1_2E49_2E2_2E2}{\*\bkmkend stylerid1_2E49_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Preservation of records.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \cf5 \f5 \fs18{{2008 Acts, ch 1088, \'a778}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E5_30_2E1_2E1}{RECIPROCAL LICENSES}{\*\bkmkend stylerid1_2E5_30_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.44}}}{\*\bkmkstart stylerid1_2E51_2E2_2E2}{\*\bkmkend stylerid1_2E51_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reciprocal agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A board may enter into a reciprocal agreement with a licensing authority of another state for the purpose of recognizing licenses issued by the other state, provided that such licensing authority imposes licensure requirements substantially equivalent to those imposed in this state. The board may establish by rule the conditions for the recognition of such licenses and the process for licensing such individuals to practice in this state.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72582; S13, \'a72582; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2481;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.44}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1132, \'a719}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1036, \'a716}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1053, \'a714}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a753}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a724}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7148.3}}}{{\f5\fs12\hyphpar0\qj{, 152.8}}}{{\f5\fs12\hyphpar0\qj{, 153.36}}}{{\f5\fs12\hyphpar0\qj{, 155.11}}}{{\f5\fs12\hyphpar0\qj{, 157.3}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.45 through 147.47}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \f5 \fs18{{2008 Acts, ch 1088, \'a779}}}}}}{{\f5\fs18\qj{2008 Acts, ch 1088, \'a779}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.48}}}{\*\bkmkstart stylerid1_2E53_2E2_2E2}{\*\bkmkend stylerid1_2E53_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Termination of reciprocal agreements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{If the requirements for a license in any state with which this state has a reciprocal agreement are changed by any law or rule of the authorities in that state so that such requirements are no longer substantially equivalent to those existing in this state, the agreement shall be deemed terminated and licenses issued in that state shall not be recognized as a basis of granting a license in this state until a new agreement has been negotiated.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2485;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.48}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a757}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a725}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7152.8}}}{{\f5\fs12\hyphpar0\qj{, 153.36}}}{{\f5\fs12\hyphpar0\qj{, 155.11}}}{{\f5\fs12\hyphpar0\qj{, 157.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.49}}}{\*\bkmkstart stylerid1_2E54_2E2_2E2}{\*\bkmkend stylerid1_2E54_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License of another state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A board shall, upon presentation of a license to practice a profession issued by the duly constituted authority of another state with which this state has established reciprocal relations, and subject to the rules of the board for such profession, license the applicant to practice in this state, unless under the rules of the board a practical or jurisprudence examination is required. The board of medicine may accept in lieu of the examination prescribed in }{{\f5\fs18\hyphpar0\qj{section 148.3}}}{ a license to practice medicine and surgery or osteopathic medicine and surgery, issued by the duly constituted authority of another state, territory, or foreign country. Endorsement may be accepted in lieu of further written examination without regard to the existence or nonexistence of a reciprocal agreement, but shall not be in lieu of the standards and qualifications prescribed by }{{\f5\fs18\hyphpar0\qj{section 148.3}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72582; S13, \'a72575-a30, -a39, 2582, 2583-l, 2589-b, 2600-m; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2486;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.49}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a758}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a726}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7152.8}}}{{\f5\fs12\hyphpar0\qj{, 153.36}}}{{\f5\fs12\hyphpar0\qj{, 155.11}}}{{\f5\fs12\hyphpar0\qj{, 157.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.50}}}{\*\bkmkstart stylerid1_2E55_2E2_2E2}{\*\bkmkend stylerid1_2E55_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Practical examinations.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \cf5 \f5 \fs18{{2008 Acts, ch 1088, \'a779}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.51 and 147.52}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \f5 \fs18{{2008 Acts, ch 1088, \'a778}}}}}}{{\f5\fs18\qj{2008 Acts, ch 1088, \'a778}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.53}}}{\*\bkmkstart stylerid1_2E57_2E2_2E2}{\*\bkmkend stylerid1_2E57_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Power to adopt rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Each board entering into a reciprocal agreement shall adopt necessary rules, not inconsistent with law, for carrying out the reciprocal relations with other states which are authorized by }{{\f5\fs18\hyphpar0\qj{this chapter}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2490;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.53}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a760}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a727}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7152.8}}}{{\f5\fs12\hyphpar0\qj{, 153.36}}}{{\f5\fs12\hyphpar0\qj{, 155.11}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.54}}}{\*\bkmkstart stylerid1_2E58_2E2_2E2}{\*\bkmkend stylerid1_2E58_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Change of residence.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \cf5 \f5 \fs18{{2008 Acts, ch 1088, \'a778}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E59_2E1_2E1}{LICENSEE DISCIPLINE}{\*\bkmkend stylerid1_2E59_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.55}}}{\*\bkmkstart stylerid1_2E6_30_2E2_2E2}{\*\bkmkend stylerid1_2E6_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Grounds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A licensee\u8217\'3fs license to practice a profession shall be revoked or suspended, or the licensee otherwise disciplined by the board for that profession, when the licensee is guilty of any of the following acts or offenses:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraud in procuring a license.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Professional incompetence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Knowingly making misleading, deceptive, untrue, or fraudulent representations in the practice of a profession or engaging in unethical conduct or practice harmful or detrimental to the public. Proof of actual injury need not be established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Habitual intoxication or addiction to the use of drugs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraud in representations as to skill or ability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Use of untruthful or improbable statements in advertisements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Willful or repeated violations of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{chapter 272C}}}{{\f5\fs18\hyphpar0\qj{, or a board\u8217\'3fs enabling statute.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sexual abuse in the fourth degree in violation of }}}{{\f5\fs18\hyphpar0\qj{section 709.4A}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraud in assisted reproduction in violation of }}}{{\f5\fs18\hyphpar0\qj{section 714I.3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Other acts or offenses as specified by board rule.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72578; S13, \'a72575-a33, -a41, 2578, 2583-c, 2600-o5; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2492;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.55(1)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72578; S13, \'a72578, 2583-c, -m; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2492;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.55(2)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72578; S13, \'a72575-a33, -a41, 2578, 2583-m, 2600-o5; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2492;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.55(3)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72578; S13, \'a72575-a41, 2578, 2583-c, -m, 2600-o5; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2492;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.55(4)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72578; S13, \'a72578, 2583-c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2492;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.55(6)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72578; S13, \'a72578, 2583-c, 2600-o5; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2492;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.55(7)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72596; S13, \'a72575-a33, -a41; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2492;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, \'a7147.55(9); C79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.55(8)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 133, \'a748}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1103, \'a712, 31}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1123, \'a75}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7148.6}}}{{\f5\fs12\hyphpar0\qj{, 148.7}}}{{\f5\fs12\hyphpar0\qj{, 148A.7}}}{{\f5\fs12\hyphpar0\qj{, 148E.8}}}{{\f5\fs12\hyphpar0\qj{, 148H.7}}}{{\f5\fs12\hyphpar0\qj{, 152.10}}}{{\f5\fs12\hyphpar0\qj{, 152D.6}}}{{\f5\fs12\hyphpar0\qj{, 153.36}}}{{\f5\fs12\hyphpar0\qj{, 155.4}}}{{\f5\fs12\hyphpar0\qj{, 155A.12}}}{{\f5\fs12\hyphpar0\qj{, 156.9}}}{{\f5\fs12\hyphpar0\qj{, 272C.3}}}{{\f5\fs12\hyphpar0\qj{, 272C.4}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.56}}}{\*\bkmkstart stylerid1_2E61_2E2_2E2}{\*\bkmkend stylerid1_2E61_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Lyme disease treatment }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exemption from discipline.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A person licensed by a board under this subtitle shall not be subject to discipline under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or the board\u8217\'3fs enabling statute based solely on the licensee\u8217\'3fs recommendation or provision of a treatment method for Lyme disease or other tick-borne disease if the recommendation or provision of such treatment meets all the following criteria:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treatment is provided after an examination is performed and informed consent is received from the patient.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee identifies a medical reason for recommending or providing the treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treatment is provided after the licensee informs the patient about other recognized treatment options and describes to the patient the licensee\u8217\'3fs education, experience, and credentials regarding the treatment of Lyme disease or other tick-borne disease.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The licensee uses the licensee\u8217\'3fs own medical judgment based on a thorough review of all available clinical information and Lyme disease or other tick-borne disease literature to determine the best course of treatment for the individual patient.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The treatment will not, in the opinion of the licensee, result in the direct and proximate death of or serious bodily injury to the patient.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2017 Acts, ch 16, \'a71, 2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.57}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reserved.}}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.58 through 147.71}}}{Repealed by }{{\f5\fs18\qj{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \f5 \fs18{{2008 Acts, ch 1088, \'a778}}}}}}{{\f5\fs18\qj{2008 Acts, ch 1088, \'a778}}}{. }{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E64_2E1_2E1}{USE OF TITLES AND DEGREES}{\*\bkmkend stylerid1_2E64_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.72}}}{\*\bkmkstart stylerid1_2E65_2E2_2E2}{\*\bkmkend stylerid1_2E65_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Professional titles and abbreviations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any person licensed to practice a profession under this subtitle may append to the person\u8217\'3fs name any recognized title or abbreviation, which the person is entitled to use, to designate the person\u8217\'3fs particular profession, but no other person shall assume or use such title or abbreviation, and no licensee shall advertise in such a manner as to lead the public to believe that the licensee is engaged in the practice of any other profession than the one which the licensee is licensed to practice.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a28, -a31, 2583-q; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2509;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.72}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1132, \'a722}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1036, \'a719}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1053, \'a717}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7147.73}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.73}}}{\*\bkmkstart stylerid1_2E66_2E2_2E2}{\*\bkmkend stylerid1_2E66_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Titles used by holder of degree.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Nothing in }{{\f5\fs18\hyphpar0\qj{section 147.72}}}{ shall be construed:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As authorizing any person licensed to practice a profession under this subtitle to use or assume any degree or abbreviation of the degree unless such degree has been conferred upon the person by an institution of learning accredited by the appropriate board, or by some recognized state or national accredited agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As prohibiting any holder of a degree conferred by an institution of learning accredited by the appropriate board created in }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, or by some recognized state or national accrediting agency, from using the title which such degree authorizes the holder to use, but the holder shall not use such degree or abbreviation in any manner which might mislead the public as to the holder\u8217\'3fs qualifications to treat human ailments.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2510;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.73}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1132, \'a723}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1036, \'a720}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1053, \'a718}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.74}}}{\*\bkmkstart stylerid1_2E67_2E2_2E2}{\*\bkmkend stylerid1_2E67_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Professional titles or abbreviations \u8212\'3f false use prohibited.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who falsely claims by the use of any professional title or abbreviation, either in writing, cards, signs, circulars, advertisements, the internet, or other written or electronic means, to be a practitioner of a profession other than the one under which the person holds a license or who fails to use the designations provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physician or surgeon may use the prefix \u8220\'3fDr.\u8221\'3f or \u8220\'3fDoctor\u8221\'3f, and shall add after the person\u8217\'3fs name the letters, \u8220\'3fM.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{D.\u8221\'3f}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An osteopathic physician and surgeon may use the prefix \u8220\'3fDr.\u8221\'3f or \u8220\'3fDoctor\u8221\'3f, and shall add after the person\u8217\'3fs name the letters, \u8220\'3fD.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{O.\u8221\'3f, or the words \u8220\'3fosteopathic physician and surgeon\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A chiropractor may use the prefix \u8220\'3fDr.\u8221\'3f or \u8220\'3fDoctor\u8221\'3f, but shall add after the person\u8217\'3fs name the letters, \u8220\'3fD.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{C.\u8221\'3f or the word, \u8220\'3fchiropractor\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A dentist may use the prefix \u8220\'3fDr.\u8221\'3f or \u8220\'3fDoctor\u8221\'3f, but shall add after the person\u8217\'3fs name the letters \u8220\'3fD.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{D.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{S.\u8221\'3f, or \u8220\'3fD.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{M.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{D.\u8221\'3f, or the word \u8220\'3fdentist\u8221\'3f or \u8220\'3fdental surgeon\u8221\'3f. A dental hygienist may use the words \u8220\'3fregistered dental hygienist\u8221\'3f or the letters \u8220\'3fR.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{D.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{H.\u8221\'3f after the person\u8217\'3fs name. A registered dental assistant may use the words \u8220\'3fregistered dental assistant\u8221\'3f or the letters \u8220\'3fR.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{D.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{A.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A podiatric physician may use the prefix \u8220\'3fDr.\u8221\'3f or \u8220\'3fDoctor\u8221\'3f, but shall add after the person\u8217\'3fs name the letters \u8220\'3fD.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{P.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{M.\u8221\'3f or the words \u8220\'3fpodiatric physician\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A graduate of a school accredited by the board of optometry may use the prefix \u8220\'3fDr.\u8221\'3f or \u8220\'3fDoctor\u8221\'3f, but shall add after the person\u8217\'3fs name the letters \u8220\'3fO.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{D.\u8221\'3f}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physical therapist registered or licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148A}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3fphysical therapist\u8221\'3f after the person\u8217\'3fs name or signify the same by the use of the letters \u8220\'3fP.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{T.\u8221\'3f after the person\u8217\'3fs name. A physical therapist with an earned doctoral degree from an accredited school, college, or university may use the suffix designating the degree, or the prefix \u8220\'3fDoctor\u8221\'3f or \u8220\'3fDr.\u8221\'3f and add after the person\u8217\'3fs name the words \u8220\'3fphysical therapist\u8221\'3f. An occupational therapist registered or licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148B}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3foccupational therapist\u8221\'3f after the person\u8217\'3fs name or signify the same by the use of the letters \u8220\'3fO.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{T.\u8221\'3f after the person\u8217\'3fs name. An occupational therapist with an earned doctoral degree from an accredited school, college, or university may use the suffix designating the degree, or the prefix \u8220\'3fDoctor\u8221\'3f or \u8220\'3fDr.\u8221\'3f and add after the person\u8217\'3fs name the words \u8220\'3foccupational therapist\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physical therapist assistant licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148A}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3fphysical therapist assistant\u8221\'3f after the person\u8217\'3fs name or signify the same by use of the letters \u8220\'3fP.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{T.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{A.\u8221\'3f after the person\u8217\'3fs name. An occupational therapy assistant licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148B}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3foccupational therapy assistant\u8221\'3f after the person\u8217\'3fs name or signify the same by use of the letters \u8220\'3fO.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{T.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{A.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A psychologist who possesses a doctoral degree may use the prefix \u8220\'3fDr.\u8221\'3f or \u8220\'3fDoctor\u8221\'3f but shall add after the person\u8217\'3fs name the word \u8220\'3fpsychologist\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A speech pathologist with an earned doctoral degree in speech pathology obtained beyond a bachelor\u8217\'3fs degree from an accredited school, college, or university, may use the suffix designating the degree, or the prefix \u8220\'3fDoctor\u8221\'3f or \u8220\'3fDr.\u8221\'3f and add after the person\u8217\'3fs name the words \u8220\'3fspeech pathologist\u8221\'3f. An audiologist with an earned doctoral degree in audiology obtained beyond a bachelor\u8217\'3fs degree from an accredited school, college, or university, may use the suffix designating the degree, or the prefix \u8220\'3fDoctor\u8221\'3f or \u8220\'3fDr.\u8221\'3f and add after the person\u8217\'3fs name the word \u8220\'3faudiologist\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A bachelor social worker licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154C}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed bachelor social worker\u8221\'3f or the letters \u8220\'3fL.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{B.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{S.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{W.\u8221\'3f after the person\u8217\'3fs name. A master social worker licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154C}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed master social worker\u8221\'3f or the letters \u8220\'3fL.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{M.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{S.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{W.\u8221\'3f after the person\u8217\'3fs name. An independent social worker licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154C}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed independent social worker\u8221\'3f, or the letters \u8220\'3fL.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{I.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{S.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{W.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A marital and family therapist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154D}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed marital and family therapist\u8221\'3f after the person\u8217\'3fs name or signify the same by the use of the letters \u8220\'3fL.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{M.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{F.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{T.\u8221\'3f after the person\u8217\'3fs name. A marital and family therapist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154D}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ who possesses a doctoral degree may use the prefix \u8220\'3fDoctor\u8221\'3f or \u8220\'3fDr.\u8221\'3f in conjunction with the person\u8217\'3fs name, but shall add after the person\u8217\'3fs name the words \u8220\'3flicensed marital and family therapist\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A mental health counselor licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154D}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed mental health counselor\u8221\'3f after the person\u8217\'3fs name. A mental health counselor licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154D}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ who possesses a doctoral degree may use the prefix \u8220\'3fDoctor\u8221\'3f or \u8220\'3fDr.\u8221\'3f in conjunction with the person\u8217\'3fs name, but shall add after the person\u8217\'3fs name the words \u8220\'3flicensed mental health counselor\u8221\'3f.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A behavior analyst licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154D}}}{{\f5\fs18\hyphpar0\qj{ may use the letters \u8220\'3fLBA\u8221\'3f after the person\u8217\'3fs name.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An assistant behavior analyst licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154D}}}{{\f5\fs18\hyphpar0\qj{ may use the letters \u8220\'3fLABA\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pharmacist who possesses a doctoral degree recognized by the accreditation council for pharmacy education from a college of pharmacy approved by the board of pharmacy or a doctor of philosophy degree in an area related to pharmacy may use the prefix \u8220\'3fDoctor\u8221\'3f or \u8220\'3fDr.\u8221\'3f but shall add after the person\u8217\'3fs name the word \u8220\'3fpharmacist\u8221\'3f or \u8220\'3fPharm. D.\u8221\'3f}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A physician assistant licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3fphysician assistant\u8221\'3f after the person\u8217\'3fs name or signify the same by the use of the letters \u8220\'3fP.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{A.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A massage therapist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152C}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed massage therapist\u8221\'3f or the initials \u8220\'3fL.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{M.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{T.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An acupuncturist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148E}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed acupuncturist\u8221\'3f or the abbreviation \u8220\'3fL.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{Ac.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A respiratory care practitioner licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152B}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may use the title \u8220\'3frespiratory care practitioner\u8221\'3f or the letters \u8220\'3fR.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{C.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{P.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An athletic trainer licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152D}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed athletic trainer\u8221\'3f or the letters \u8220\'3fLAT\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A registered nurse licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3fregistered nurse\u8221\'3f or the letters \u8220\'3fR.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{N.\u8221\'3f after the person\u8217\'3fs name. A licensed practical nurse licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed practical nurse\u8221\'3f or the letters \u8220\'3fL.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{P.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{N.\u8221\'3f after the person\u8217\'3fs name. An advanced registered nurse practitioner licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 152}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{152E}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3fadvanced registered nurse practitioner\u8221\'3f or the letters \u8220\'3fA.R.N.P.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A sign language interpreter or transliterator licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 154E}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ may use the title \u8220\'3flicensed sign language interpreter\u8221\'3f or the letters \u8220\'3fL.}}}{\f5\fs18\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{I.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An orthotist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148F}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed orthotist\u8221\'3f after the person\u8217\'3fs name or signify the same by the use of the letters \u8220\'3fL.O.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A pedorthist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148F}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed pedorthist\u8221\'3f after the person\u8217\'3fs name or signify the same by the use of the letters \u8220\'3fL.ped.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prosthetist licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148F}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed prosthetist\u8221\'3f after the person\u8217\'3fs name or signify the same by the use of the letters \u8220\'3fL.P.\u8221\'3f after the person\u8217\'3fs name. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A genetic counselor licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148H}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3fgenetic counselor\u8221\'3f or \u8220\'3flicensed genetic counselor\u8221\'3f or corresponding abbreviations after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{26.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person who is licensed to engage in the practice of polysomnography shall have the right to use the title \u8220\'3fpolysomnographic technologist\u8221\'3f or the letters \u8220\'3fP.S.G.T.\u8221\'3f after the person\u8217\'3fs name. No other person may use that title or letters or any other words or letters indicating that the person is a polysomnographic technologist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{27.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{No other practitioner licensed to practice a profession under any of the provisions of this subtitle shall be entitled to use the prefix \u8220\'3fDr.\u8221\'3f or \u8220\'3fDoctor\u8221\'3f unless the licensed practitioner possesses an earned doctoral degree. Such a practitioner shall reference the degree held after the person\u8217\'3fs name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{28.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A midwife licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148I}}}{{\f5\fs18\hyphpar0\qj{ may use the words \u8220\'3flicensed midwife\u8221\'3f or the initials \u8220\'3fL.M.\u8221\'3f after the person\u8217\'3fs name.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C31, 35, \'a72510-d1; C39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2510.1;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.74}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 66, \'a71}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1075, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 215, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1225, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 90 Acts, ch 1168, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 228, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 229, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1137, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1183, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 93 Acts, ch 86, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 108, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1035, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1036, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1053, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 101, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1053, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 58, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2003 Acts, ch 93, \'a71, 14}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1045, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7424, 433}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a761}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 215, \'a7246}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a731}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1101, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2014 Acts, ch 1019, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 70, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1052, \'a74, 12}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1106, \'a76, 14}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 127, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 41, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7148A.7}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.75}}}{\*\bkmkstart stylerid1_2E68_2E2_2E2}{\*\bkmkend stylerid1_2E68_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Itinerants.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs18\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2008/CH1088.pdf" }{\fldrslt \cf5 \f5 \fs18{{2008 Acts, ch 1088, \'a778}}}}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{. }}}{\f5\fs18\hyphpar0\qj\chcbpat2}{\f5\fs18\hyphpar0\qj}\par}{}{\pard\plain\f5\fs18\fi0\ri0\li0{\f5\fs18\chcbpat2}\par}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E69_2E2_2E1}{RULES}{\*\bkmkend stylerid1_2E69_2E2_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.76}}}{\*\bkmkstart stylerid1_2E7_30_2E2_2E2}{\*\bkmkend stylerid1_2E7_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Rules.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The boards for the various professions shall adopt all necessary and proper rules to administer and interpret }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ and }{{\f5\fs18\hyphpar0\qj{chapters 148 through 157}}}{, except }{{\f5\fs18\hyphpar0\qj{chapter 148D}}}{.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.76}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{89 Acts, ch 83, \'a728}}}{; }{{\f5\fs18\hyphpar0\qj{92 Acts, ch 1097, \'a74}}}{; }{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 10, \'a762}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 99, \'a76}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.77}}}{\*\bkmkstart stylerid1_2E71_2E2_2E2}{\*\bkmkend stylerid1_2E71_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Powers, privileges, rights, or duties provided by rule }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ applicability to physician assistants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following agencies that adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ providing a power, privilege, right, or duty to a physician licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148}}}{{\f5\fs18\hyphpar0\qj{ or other profession licensed under }}}{{\f5\fs18\hyphpar0\qj{this subtitle}}}{{\f5\fs18\hyphpar0\qj{ relating to the following subjects shall, consistent with the scope of practice of physician assistants licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{, and unless otherwise inconsistent with state or federal law, provide the same power, privilege, right, or duty by rule to a physician assistant licensed under }}}{{\f5\fs18\hyphpar0\qj{chapter 148C}}}{{\f5\fs18\hyphpar0\qj{:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of administrative services, with respect to rules relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Retroactive conversion of vacation time to sick leave for vacation time spent under the care of a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Certification of a catastrophic illness by a physician for purposes of donation of leave and second medical opinions and updates sought from a physician relating to such certifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of corrections, with respect to rules relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That a parolee shall not use, purchase, possess, or transfer any drugs unless prescribed by a physician. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That a serious medical need is one that has been diagnosed by a physician as requiring treatment or is one so obvious that a lay person would easily recognize the necessity for a physician\u8217\'3fs attention.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That each jail shall have a designated licensed physician, licensed osteopathic physician, or medical resource designated for the medical supervision, care, and treatment of prisoners as deemed necessary and appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That prescription medication, as ordered by a licensed physician, licensed osteopathic physician, or licensed dentist shall be provided in accordance with the directions of the prescribing physician or dentist. Prisoners with medication from a personal physician, osteopathic physician, or dentist may be evaluated by a physician, osteopathic physician, or dentist selected by the jail administrator to determine if the present medication is appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That expired drugs or drugs not in unit dose packaging, whose administration had been discontinued by the attending physician, shall be destroyed by the jail administrator or designee in the presence of a witness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That special diets in jails prescribed by a physician shall be followed and documented, that the physician who prescribes the special diet shall specify a date on which the diet will be reviewed for renewal or discontinuation, and that unless specified by the prescribing physician, a certified dietitian shall develop the menu.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That special diets prescribed by a physician for the care and treatment of juveniles in nonsecure hold shall be followed and documented. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medical services in temporary holding facilities, that a serious medical need is one that has been diagnosed by a physician as requiring treatment or one that is so obvious that a lay person would easily recognize the necessity for a physician\u8217\'3fs attention.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medical resources in temporary holding facilities, that each facility shall have a designated licensed physician, licensed osteopathic physician, or medical resource designated for the medical supervision, care, and treatment of detainees as deemed necessary and appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Medication procedures in temporary holding facilities, that prescription medication, as ordered by a licensed physician, licensed osteopathic physician, or licensed dentist shall be provided in accordance with the directions of the prescribing physician or dentist. Detainees with medication from a personal physician, osteopathic physician, or dentist may be evaluated by a physician, osteopathic physician, or dentist selected by the facility administrator to determine if the present medication is appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medication storage in temporary holding facilities, that expired drugs or drugs not in unit dose packaging, whose administration had been discontinued by the attending physician, shall be destroyed by the facility administrator or designee in the presence of a witness.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medical diets in temporary holding facilities, that special diets as prescribed by a physician shall be followed and documented.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medical care and treatment for juveniles in nonsecure holds in temporary holding facilities, that special diets as prescribed by a physician shall be followed and documented.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The economic development authority, with respect to rules relating to the certification of a person with a disability for the purpose of the targeted small business program, that in order to be considered a person with a disability for the purpose of the targeted small business program, the person must qualify and receive certification as having a disability from a licensed medical physician or must have been found eligible for vocational rehabilitation services by the department of workforce development, division of vocational rehabilitation services, or by the department for the blind.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of education, with respect to rules relating to the following: }}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For statements relating to medication administration policies, that a statement that persons administering medication shall include authorized practitioners, such as licensed registered nurses and physicians, and persons to whom authorized practitioners have delegated the administration of prescription and nonprescription drugs. Individuals shall self-administer asthma or other airway constricting disease medication or possess and have use of an epinephrine auto-injector with parent and physician consent on file, without the necessity of demonstrating competency to self-administer these medications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medication administration courses relating to medication administration policies, that a medication administration course be conducted by a registered nurse or licensed pharmacist and include an annual medication administration procedural skills check completed with a registered nurse or pharmacist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For school-based youth services programs, that preventive and primary health care services shall be delivered by specifically credentialed providers as specified.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of health and human services, with respect to rules relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That an incident for purposes of accreditation of providers of services to persons with mental illness, intellectual disabilities, or developmental disabilities includes but is not limited to an occurrence involving the individual using the service that results in a physical injury to or by the individual that requires a physician\u8217\'3fs treatment or admission to a hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That a mental health professional, for purposes of accreditation of providers of services to persons with mental illness, intellectual disabilities, or developmental disabilities, includes a medical professional licensed in this state, provided that the professional otherwise meets all of the conditions to qualify as a mental health professional. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That home health aide services for purposes of disability services management and regional services may include medications specifically ordered by a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That payment relating to the state supplementary assistance program for residential care shall only be made when there is on file an order written by a physician certifying that the applicant or recipient being admitted requires residential care but does not require nursing services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That a case folder for a facility participating in the state supplementary assistance program must include a physician\u8217\'3fs statement certifying that a resident does not require nursing services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That personnel providing psychological evaluations and counseling or psychotherapy services for area education agencies under the medical assistance program include specified professions endorsed, licensed, or registered in this state, provided that the professional otherwise meets all of the conditions to qualify as a mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That personnel providing psychological evaluations and counseling or psychotherapy services for providers of infant and toddler program services under the medical assistance program include specified professions endorsed, licensed, or registered in this state, provided that the professional otherwise meets all of the conditions to qualify as a mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That personnel providing other services for providers of infant and toddler program services under the medical assistance program include specified professions recognized, endorsed, or licensed in this state, provided that the professional otherwise meets all of the conditions to qualify as a mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That personnel providing psychological evaluations and counseling or psychotherapy services for providers of local education agency services under the medical assistance program include specified professions endorsed, licensed, or registered in this state, provided that the professional otherwise meets all of the conditions to qualify as a mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That personnel providing other services for providers of local education agency services under the medical assistance program include specified professions recognized, endorsed, or licensed in this state, provided that the professional otherwise meets all of the conditions to qualify as a mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For payment for medically necessary home health agency services under the medical assistance program, that payment shall be approved for medically necessary home health agency services prescribed by a physician in a plan of home health care provided by a Medicare-certified home health agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For authorization for medically necessary home health agency services under the medical assistance program, that services shall be authorized by a physician, evidenced by the physician\u8217\'3fs signature and date on a plan of treatment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For treatment plans of home health agencies under the medical assistance program, that a member\u8217\'3fs medical condition shall be reflected by the date last seen by a physician, if available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(14)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For items included in treatment plans of home health agencies under the medical assistance program, that a plan of care shall include a physician\u8217\'3fs signature and date and that the plan of care must be signed and dated by the physician before the claim for service is submitted for reimbursement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(15)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For skilled nursing services provided by a home health agency under the medical assistance program, that medical documentation shall be submitted justifying the need for continued visits, including the physician\u8217\'3fs estimate of the length of time that additional visits will be necessary, and that daily skilled nursing visits or multiple daily visits for wound care or insulin injections shall be covered when ordered by a physician and included in the plan of care. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(16)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For physical therapy services provided by a home health agency under the medical assistance program, that payment shall be made for physical therapy services when the services follow a treatment plan established by the physician after any needed consultation with the qualified physical therapist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(17)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For occupational therapy services provided by a home health agency under the medical assistance program, that payment shall be made for occupational therapy services when the services follow a treatment plan established by the physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(18)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For speech therapy services provided by a home health agency under the medical assistance program, that payment shall be made for speech therapy services when the services follow a treatment plan established by the physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(19)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For home health aide services provided by a home health agency under the medical assistance program, that the service as well as the frequency and duration are stated in a written plan of treatment established by a physician. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(20)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For home health aide services provided by a home health agency under the medical assistance program, that services provided for specified durations when ordered by a physician and included in a plan of care shall be allowed as intermittent services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(21)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For home health aide services provided by a home health agency under the medical assistance program, that personal care services include helping the member take medications specifically ordered by a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(22)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For private duty nursing or personal care services for persons aged twenty and under, under the medical assistance program, that private duty nursing services are those services which are provided by a registered nurse or a licensed practical nurse under the direction of the member\u8217\'3fs physician to a member in the member\u8217\'3fs place of residence or outside the member\u8217\'3fs residence, when normal life activities take the member outside the place of residence.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(23)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For private duty nursing or personal care services for persons aged twenty and under, under the medical assistance program, that services shall be provided according to a written plan of care authorized by a licensed physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(24)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For private duty nursing or personal care services for persons aged twenty and under, under the medical assistance program, that personal care services are those services provided by a home health aide or certified nurse\u8217\'3fs aide and which are delegated and supervised by a registered nurse under the direction of the member\u8217\'3fs physician to a member in the member\u8217\'3fs place of residence or outside the member\u8217\'3fs residence, when normal life activities take the member outside the place of residence, and that these services shall be in accordance with the member\u8217\'3fs plan of care and authorized by a physician. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(25)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For requirements for private duty nursing or personal care services for persons aged twenty and under, under the medical assistance program, that private duty nursing or personal care services shall be ordered in writing by a physician as evidenced by the physician\u8217\'3fs signature on the plan of care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(26)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For obtaining prescription medications for children in juvenile detention and shelter care homes, that prescription medication provided to residents shall be dispensed only from a licensed pharmacy in this state in accordance with state law, from a licensed pharmacy in another state according to the laws of that state, or by a licensed physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(27)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For health and dental programs provided by agencies providing foster care services, that a child\u8217\'3fs physical examination shall be performed by a licensed physician or licensed nurse practitioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(28)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For health and dental programs provided by agencies providing foster care services, that if documentation of prior immunization is unavailable, immunizations required by the department shall begin within thirty days of placement, unless contraindicated and unless a statement from a physician to that effect is included in the child\u8217\'3fs medical record, and that a statement from a physician, referring agency, parent, or guardian indicating immunizations are current is sufficient documentation of immunizations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(29)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the dispensing, storage, authorization, and recording of medications in child care centers, that all medications shall be stored in their original containers, with accompanying physician or pharmacist\u8217\'3fs directions and label intact and stored so they are inaccessible to children and the public. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(30)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For an infants\u8217\'3f area in a child care center, that upon the recommendation of a child\u8217\'3fs physician or the area education agency serving the child, a child who is two years of age or older with a disability that results in significant developmental delays in physical and cognitive functioning who does not pose a threat to the safety of the infants may, if appropriate and for a limited time approved by the department, remain in the infant area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(31)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For facility requirements for a child development home, that the telephone number for each child\u8217\'3fs physician shall be written on paper and readily accessible by the telephone. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(32)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medications and hazardous materials in a child development home, that medications shall be given only with the parent\u8217\'3fs or doctor\u8217\'3fs written authorization, and that each prescribed medication shall be accompanied by a physician\u8217\'3fs or pharmacist\u8217\'3fs direction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(33)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medical reports regarding the health of a family in a family life home, that a medical report shall provide significant findings of a physician, such as the presence or absence of any communicable disease.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(34)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medical reexaminations of a family in a family life home, that medical reexaminations may be required at the discretion of a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(35)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For medical examinations of a client in a family life home, that a physician shall certify that the client is free from any communicable disease and does not require a higher level of care than that provided by a family life home.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(36)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the records of a client in a family life home, that the family shall have available at all times, the name, address, and telephone number of the client\u8217\'3fs physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(37)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the facility requirements for a child care home, that the telephone number for each child\u8217\'3fs physician shall be written on paper and readily accessible by the telephone. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(38)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the administration of medications at a child care home, that medications shall be given only with the parent\u8217\'3fs or doctor\u8217\'3fs written authorization and each prescribed medication shall be accompanied by a physician\u8217\'3fs or pharmacist\u8217\'3fs direction. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(39)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For payments for foster care, that an intellectual disabilities professional includes specified professions, provided that the professional otherwise meets all of the conditions to qualify as an intellectual disabilities professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(40)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For payments for foster care, that a mental health professional includes specified professions, provided that the professional otherwise meets all of the conditions to qualify as a mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(41)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the subsidized adoption program, that a qualified intellectual disability professional includes specified professions, provided that the professional otherwise meets all of the conditions to qualify as a qualified intellectual disability professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(42)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the subsidized adoption program, that a qualified mental health professional includes specified professions, provided that the professional otherwise meets all of the conditions to qualify as a qualified mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(43)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the information provided to a foster care provider by a department worker at the time of placement, that the information shall include the names, addresses, and telephone numbers of the child\u8217\'3fs physician and dentist.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(44)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A written order from a physician for an older individual requesting a therapeutic diet, and the interpretation of such orders. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(45)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fimpaired glucose tolerance\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for purposes of outpatient diabetes education programs, means a condition in which blood glucose levels are higher than normal, diagnosed by a physician, and treated with a food plan, exercise, or weight control.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(46)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For instructors for programs not recognized by the American diabetes association or accredited by the American association of diabetes educators, that the primary instructors shall be one or more of specified health care professionals who are knowledgeable about the disease process of diabetes and the treatment of diabetes. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(47)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the written form for participation in the prescription drug donation repository program, that the form shall include the name and telephone number of the responsible pharmacist, physician, or nurse practitioner who is employed by or under contract with the pharmacy or medical facility, and shall also include a statement, signed and dated by the responsible pharmacist, physician, or nurse practitioner, indicating that the pharmacy or medical facility meets the eligibility requirements and shall comply with the requirements established by rule.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(48)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the dispensing of donated prescription drugs and supplies, that donated drugs and supplies may be dispensed only if the drugs or supplies are prescribed by a health care practitioner for use by an eligible individual and are dispensed by a licensed pharmacist, physician, or nurse practitioner.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of inspections, appeals, and licensing, with respect to rules relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the qualifications of an attending physician at a hospice, that the person shall have an active Iowa license to practice medicine.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For residential care facilities for persons with intellectual disabilities, that a qualified intellectual disability professional includes specified professions, provided that the professional otherwise meets all of the conditions to qualify as a qualified intellectual disability professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For nursing facilities, that a qualified intellectual disabilities professional includes specified professions, provided that the professional otherwise meets all of the conditions to qualify as a qualified intellectual disabilities professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For intermediate care facilities for persons with mental illness, that a qualified mental health professional includes specified professions, provided that the professional otherwise meets all of the conditions to qualify as a qualified mental health professional.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For notifications submitted to the department from a subacute mental health care facility in the event of an accident causing a major injury, including as a major injury an injury which requires consultation with the attending physician or designee of the physician or advanced registered nurse practitioner who determines that an injury is a major injury.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For applications for a license to practice asbestos removal, that except as noted in rule, only worker and contractor/supervisor license applicants must submit the respiratory protection and physician\u8217\'3fs certification forms.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For documentation held by persons licensed for asbestos abatement in an area that is subject to a disaster emergency proclamation, that the director of the department of inspections, appeals, and licensing deems an individual contractor, supervisor, or worker to be licensed and authorized for asbestos abatement if the individual, in addition to other specified conditions, makes immediately available on the work site a copy of a physician\u8217\'3fs statement indicating that, consistent with federal law, a licensed physician has examined the individual within the past twelve months and approved the individual to work while wearing a respirator.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(8)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the contents of an application for an event license for a covered athletic event other than a professional wrestling event shall contain, along with other requirements, a copy of the medical license of the ringside physician and the date, time, and location of the ringside physician\u8217\'3fs examination of the contestants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(9)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the responsibilities of the promoter of an athletic event, that the promoter submit test results to the ringside physician no later than at the time of the physical showing that each contestant scheduled for the event tested negative for the human immunodeficiency, hepatitis B, and hepatitis C viruses within the one-year period prior to the event, and that the contestant shall not participate and the physician shall notify the promoter that the contestant is prohibited from participating for medical reasons if specified circumstances occur.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(10)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For injuries during a professional boxing match, that if a contestant claims to be injured during the bout, the referee shall stop the bout and request the attending physician to make an examination. If the physician decides that the contestant has been injured as the result of a foul, the physician shall advise the referee of the injury. If the physician is of the opinion that the injured contestant may be able to continue, the physician shall order an intermission, after which the physician shall make another examination and again advise the referee of the injured contestant\u8217\'3fs condition. It shall be the duty of the promoter to have an approved physician in attendance during the entire duration of all bouts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(11)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For persons allowed in a ring during a professional boxing match, that no person other than the contestants and the referee shall enter the ring during the bout, excepting the seconds between the rounds or the attending physician if asked by the referee to examine an injury to a contestant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(12)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the weighing of contestants in a professional boxing match, that contestants shall be weighed and examined on the day of the scheduled match by the attending ring physician at a time and place to be determined by the state commissioner of athletics.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(13)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For attending ring physicians during a professional boxing match, that when a boxer has been injured seriously, knocked out, or technically knocked out, the referee shall immediately summon the attending ring physician to aid the stricken boxer, and that managers, handlers, and seconds shall not attend to the stricken boxer, except at the request of the physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(14)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the keeping of time during a professional boxing match, that the timekeeper shall keep an exact record of time taken out at the request of a referee for an examination of a contestant by the physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(15)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the suspension of contestants during a professional boxing match that is an elimination tournament, that a contestant who for specified reasons is not permitted to box in the state for a period of time shall be examined by a physician approved by the state commissioner of athletics before being permitted to fight again.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(16)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the designation of officials for professional kickboxing, that the designation of physicians is subject to the approval of the state commissioner of athletics or designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(17)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For officials for a mixed martial arts event, that officials shall include a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(18)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the keeping of time for a mixed martial arts event, that the timekeeper shall keep an exact record of time taken out at the request of a referee for an examination of a contestant by the physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(19)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For persons allowed in the cage during a mixed martial arts event, that a physician may enter the cage to examine a contestant upon the request of the referee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(20)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the decorum of persons involved in a mixed martial arts event, that a contestant is exempt from prohibitions on specified conduct while interacting with the contestant\u8217\'3fs opponent during a round, but if the round is stopped by the physician or referee for a time out, the prohibitions shall apply to the contestant.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(21)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the examination of contestants in a mixed martial arts event, that on the day of the event, at a time and place to be approved by the state commissioner of athletics, the ringside physician shall conduct a rigorous physical examination to determine the contestant\u8217\'3fs fitness to participate in a mixed martial arts match, and that a contestant deemed not fit by the physician shall not participate in the event.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(22)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For injuries during a mixed martial arts event, that if a contestant claims to be injured or when a contestant has been injured seriously or knocked out, the referee shall immediately stop the fight and summon the attending ring physician to make an examination of the stricken fighter. If the physician decides that the contestant has been injured, the physician shall advise the referee of the severity of the injury. If the physician is of the opinion the injured contestant may be able to continue, the physician shall order an intermission, after which the physician shall make another examination and again advise the referee of the injured contestant\u8217\'3fs condition. Managers, handlers, and seconds shall not attend to the stricken fighter, except at the request of the physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The racing and gaming commission, with respect to rules relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the grounds for denial, suspension, or revocation of an occupational or vendor license, that a license shall be denied if the applicant has a history of mental illness without demonstrating successful treatment by a licensed medical physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the qualifications for jockeys, that a jockey shall pass a physical examination by a licensed physician affirming fitness to participate as a jockey. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the regulation of licensees in restricted areas of a racing facility, that licensees whose duties require them to be in a restricted area of a racing facility shall not have present within their systems any controlled substance as listed in schedules I to V of section 202 of the federal Controlled Substances Act, 21 U.S.C. \'a7812, }}}{{\f5\fs18\hyphpar0\qj{chapter 124}}}{{\f5\fs18\hyphpar0\qj{, or any prescription drug unless it was obtained directly or pursuant to valid prescription or order from a duly licensed physician who is acting in the course of professional practice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa law enforcement academy, with respect to rules relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the minimum standards for law enforcement officers, that an officer is examined by a licensed physician or surgeon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For hiring standards must be reverified if an individual is not hired by an Iowa law enforcement agency during a specified period of time following completion of the course of study, that the individual must be examined by a licensed physician or surgeon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the selection or appointment of reserve peace officers, that the person shall be examined by a licensed physician or surgeon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The natural resource commission, with respect to rules relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That the grounds for revoking or suspending an instructor license include participation in a course while ingesting prescription medication in a manner contrary to the dosing directions given by the prescribing physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For applications for use of a crossbow for deer and turkey hunting by handicapped individuals, that an application must include a statement signed by the applicant\u8217\'3fs physician declaring that the individual is not physically capable of shooting a bow and arrow. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For authorization for the use of a crossbow for deer and turkey hunting by handicapped individuals, that if a conservation officer has probable cause to believe the person\u8217\'3fs handicapped status has improved, making it possible for the person to shoot a bow and arrow, the department of natural resources may, upon the officer\u8217\'3fs request, require the person to obtain in writing a current physician\u8217\'3fs statement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For licenses for nonresidents to participate in a special deer hunting season for severely disabled persons, that a nonresident applying for the license must have on file with the department of natural resources either a copy of a disabilities parking permit issued by a state department of transportation or an Iowa department of natural resources form signed by a physician that verifies their disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of public safety, with respect to rules relating to permits to carry weapons, that a person who is an unlawful user of or addicted to any controlled substance includes any person who is a current user of a controlled substance in a manner other than as prescribed by a licensed physician. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of transportation, with respect to rules relating to exemptions from motor vehicle window transparency requirements, that a motor vehicle fitted with a front windshield, a front side window, or a front sidewing with less than seventy percent but not less than thirty-five percent light transmittance before July 4, 2012, may continue to be maintained and operated with a front windshield, a front side window, or a front sidewing with less than seventy percent but not less than thirty-five percent light transmittance on or after July 4, 2012, so long as the vehicle continues to be used for the transport of a passenger or operator who documented in the manner specified by the department a medical need for such reduced transparency, which document was signed by the person\u8217\'3fs physician before July 4, 2012. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa department of veterans affairs, with respect to rules relating to expenses relating to the purchase of durable equipment or services, that individuals requesting reimbursement who need durable equipment as a medical necessity should provide information from a physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development, with respect to rules relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That a voluntary quit shall be presumed to be without good cause attributable to the employer for purposes of unemployment compensation if a claimant left employment because of illness or injury which was not caused or aggravated by the employment or pregnancy and failed to obtain the advice of a licensed and practicing physician, obtain certification of release for work from a licensed and practicing physician, or return to the employer and offer services upon recovery and certification for work by a licensed and practicing physician.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That for purposes of unemployment compensation, it is a reason for a claimant leaving employment with good cause attributable to the employer if the claimant left employment because of illness, injury, or pregnancy upon the advice of a licensed and practicing physician, and upon recovery, when recovery was certified by a licensed and practicing physician, the claimant returned and offered to perform services to the employer, but no suitable, comparable work was available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{That for purposes of unemployment compensation it is a reason for a claimant leaving employment with good cause attributable to the employer if the claimant left employment upon the advice of a licensed and practicing physician for the sole purpose of taking a family member to a place having a different climate and subsequently returned to the claimant\u8217\'3fs regular employer and offered to perform services, but the claimant\u8217\'3fs regular or comparable work was not available.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The labor services division of the department of inspections, appeals, and licensing, with respect to rules relating to the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the disclosure of a trade secret relating to a hazardous chemical during a medical emergency, that where a treating physician or nurse determines that a medical emergency exists and the specific chemical identity of a hazardous chemical is necessary for emergency or first-aid treatment, the chemical manufacturer, importer, or employer shall immediately disclose the specific chemical identity of a trade secret chemical to that treating physician or nurse, regardless of the existence of a written statement of need or a confidentiality agreement. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the disclosure of a trade secret relating to a hazardous chemical in a nonemergency situation, that in nonemergency situations, a chemical manufacturer, importer, or employer shall, upon request, disclose a specific chemical identity, otherwise permitted to be withheld by rule, to a specified health professional providing medical or other occupational health services to exposed employees or designated representatives in specified circumstances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to expand, diminish, or otherwise modify the scope of practice of any profession licensed under }}}{{\f5\fs18\hyphpar0\qj{this subtitle}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rulemaking requirements provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to prohibit the agencies listed in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ from engaging in further rulemaking not in conflict with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or state or federal law relating to the subject matter of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ or to otherwise diminish the authority to engage in rulemaking provided to those agencies by any other statute.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2022 Acts, ch 1066, \'a751}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1153, \'a78, 9}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a7263, 1910 \u8211\'3f 1913}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a719}}}\par}{}{\pard\plain\keep\f5\fs18\qj\fi0\sb260\ri0\li0{{\f5\b\fs18\qj{147.78 and 147.79}}}{Reserved.}{\f5\fs18\qj\chcbpat2}{\f5\fs18\qj}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E73_2E1_2E1}{FEES}{\*\bkmkend stylerid1_2E73_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.80}}}{\*\bkmkstart stylerid1_2E74_2E2_2E2}{\*\bkmkend stylerid1_2E74_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Establishment of fees }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ administrative costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Each board, following approval by the department, may, or at the direction of the department, shall, by rule establish or revise fees for the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Examinations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Licensure, certification, or registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Renewal of licensure, certification, or registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Renewal of licensure, certification, or registration during the grace period.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reinstatement or reactivation of licensure, certification, or registration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issuance of a certified statement that a person is licensed, registered, or has been issued a certificate to practice in this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issuance of a duplicate license, registration, or certificate, which shall be so designated on its face. A board may require satisfactory proof that the original license, registration, or certificate issued by the board has been lost or destroyed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Issuance of a renewal card.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Verification of licensure, registration, or certification.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Returned checks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Inspections.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall annually prepare estimates of projected revenues to be generated by all fees collected as well as a projection of the aggregate administrative costs and rental expenses attributable to all boards and the division of the department responsible for licensing related to such boards. The department shall annually review and, if necessary, direct the boards to adjust the schedule of fees to cover aggregate projected expenses and ensure fees imposed in this state are not greater than similar fees imposed by similar boards or agencies in other states. The department shall annually provide to each appropriate board a comparison of the amount of the board\u8217\'3fs fees as compared to similar fees imposed by similar boards or agencies in other states.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72576, 2597, 2590; S13, \'a72575-a30, -a38, -a39, 2582, 2583-a, -l, 2589-d, 2600-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2516;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.80}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 2, \'a710(5)}}}{, }{{\f5\fs18\hyphpar0\qj{ch 5, \'a74(5)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72597; S13, \'a72600-d, -m; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2516;}}}{ C46, 50, 54, 58, 62, \'a7147.80(1, 2, 7); C66, 71, 73, \'a7147.80(1, 7); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.80(1)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72590; S13, \'a72589-b, -d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2516;}}}{ C46, 50, 54, 58, 62, \'a7147.80(5 \u8211\'3f 7); C66, 71, 73, \'a7147.80(1, 7); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.80(2)}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\b\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{[C97, \'a72576; S13, \'a72576, 2582, 2583-a; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2516;}}}{ C46, 50, 54, 58, 62, \'a7147.80(1 \u8211\'3f 4); C66, 71, 73, \'a7147.80(2, 7); C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.80(3)}}}{]}\par}{}{\pard\p