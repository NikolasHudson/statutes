d\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBoard\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one of the boards enumerated in }}}{{\f5\fs18\hyphpar0\qj{section 147.13}}}{{\f5\fs18\hyphpar0\qj{ or any other board established in this subtitle whose members are appointed by the governor to license applicants and impose licensee discipline as authorized by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDepartment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the department of inspections, appeals, and licensing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fLicensed\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fcertified\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, when applied to a physician and surgeon, podiatric physician, osteopathic physician and surgeon, genetic counselor, physician assistant, psychologist, chiropractor, nurse, dentist, dental hygienist, dental assistant, optometrist, speech pathologist, audiologist, pharmacist, physical therapist, physical therapist assistant, occupational therapist, occupational therapy assistant, orthotist, prosthetist, pedorthist, respiratory care practitioner, practitioner of cosmetology arts and sciences, practitioner of barbering, funeral director, dietitian, behavior analyst, assistant behavior analyst, marital and family therapist, mental health counselor, midwife, respiratory care and polysomnography practitioner, polysomnographic technologist, social worker, massage therapist, athletic trainer, acupuncturist, nursing home administrator, hearing aid specialist, or sign language interpreter or transliterator means a person licensed under }}}{{\f5\fs18\hyphpar0\qj{this subtitle}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeer review\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means evaluation of professional services rendered by a person licensed to practice a profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fPeer review committee\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one or more persons acting in a peer review capacity who also serve as an officer, director, trustee, agent, or member of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A state or local professional society of a profession for which there is peer review.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any organization approved to conduct peer review by a society as designated in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The medical staff of any licensed hospital.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A board enumerated in }}}{{\f5\fs18\hyphpar0\qj{section 147.13}}}{{\f5\fs18\hyphpar0\qj{ or any other board established in this subtitle which is appointed by the governor to license applicants and impose licensee discipline as authorized by law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of trustees of a licensed hospital when performing a function relating to the reporting required by }}}{{\f5\fs18\hyphpar0\qj{section 147.135, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A health care entity, including but not limited to a group medical practice, that provides health care services and follows a formal peer review process for the purpose of furthering quality health care.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statewide nonprofit organization that is an organ procurement organization, as }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3forgan procurement organization\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ is defined in }}}{{\f5\fs18\hyphpar0\qj{section 142C.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProfession\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means medicine and surgery, podiatry, osteopathic medicine and surgery, genetic counseling, practice as a physician assistant, psychology, chiropractic, nursing, dentistry, dental hygiene, dental assisting, optometry, speech pathology, audiology, pharmacy, physical therapy, physical therapist assisting, occupational therapy, occupational therapy assisting, respiratory care, cosmetology arts and sciences, barbering, mortuary science, applied behavior analysis, marital and family therapy, mental health counseling, midwifery, polysomnography, social work, dietetics, massage therapy, athletic training, acupuncture, nursing home administration, practice as a hearing aid specialist, sign language interpreting or transliterating, orthotics, prosthetics, or pedorthics.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2438;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.1}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1075, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 168, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 86 Acts, ch 1211, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 87 Acts, ch 91, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1225, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 89 Acts, ch 89, \'a74, 5}}}{{\f5\fs18\hyphpar0\qj{; 91 Acts, ch 229, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 92 Acts, ch 1205, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1132, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 41, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 95 Acts, ch 108, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1036, \'a73, 4}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1109, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1219, \'a720}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1053, \'a72, 3}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1053, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1148, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7419, 420, 433}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a726, 27}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1101, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 30, \'a760}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 57, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 70, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1052, \'a71, 12}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1106, \'a72, 14}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71623}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 127, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 99, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7148F.4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 5, NEW paragraph g}\par}{}{}{}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb120\ri0\li0{\*\bkmkstart stylerid1_2E8_2E1_2E1}{LICENSES}{\*\bkmkend stylerid1_2E8_2E1_2E1}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb360\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.2}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{License required.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A person shall not engage in the practice of medicine and surgery, podiatry, osteopathic medicine and surgery, genetic counseling, psychology, chiropractic, physical therapy, physical therapist assisting, nursing, dentistry, dental hygiene, dental assisting, optometry, speech pathology, audiology, occupational therapy, occupational therapy assisting, orthotics, prosthetics, pedorthics, respiratory care, pharmacy, cosmetology arts and sciences, barbering, social work, dietetics, applied behavior analysis, marital and family therapy or mental health counseling, massage therapy, mortuary science, polysomnography, athletic training, acupuncture, nursing home administration, or sign language interpreting or transliterating, or shall not practice as a physician assistant or a hearing aid specialist, unless the person has obtained a license for that purpose from the board for the profession.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a person who is licensed in another state and recognized for licensure in this state pursuant to the nurse licensure compact contained in }}}{{\f5\fs18\hyphpar0\qj{section 152E.1}}}{{\f5\fs18\hyphpar0\qj{ or pursuant to the advanced practice registered nurse compact contained in }}}{{\f5\fs18\hyphpar0\qj{section 152E.3}}}{{\f5\fs18\hyphpar0\qj{ shall be considered to have obtained a license to practice nursing.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72582, 2588; S13, \'a72575-a28, -a31, -a36, 2582, 2583-a, -d, -r, 2600-o4; SS15, \'a72588; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2439;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{85 Acts, ch 168, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1225, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1035, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1036, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1050, \'a71, 5}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1008, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1053, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2000 Acts, ch 1185, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1045, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2004 Acts, ch 1175, \'a7421, 433}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 53, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 10, \'a728}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1009, \'a71, 5}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1101, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 57, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2015 Acts, ch 70, \'a73, 18}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1052, \'a72, 12}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1106, \'a73, 14}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7148.6}}}{{\f5\fs12\hyphpar0\qj{, 148G.1}}}{{\f5\fs12\hyphpar0\qj{, 148G.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.3}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Qualifications.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{An applicant for a license to practice a profession under this subtitle is not ineligible because of age, citizenship, sex, race, religion, marital status, or national origin, although the application form may require citizenship information. }\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a72575-a29, -a37, 2583-a, -1, 2600-d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2440, 2567;}}}{ C46, 50, 54, 58, 62, 66, \'a7147.3, 153.3; C71, 73, \'a7147.3, 153.5; C75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.3}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{84 Acts, ch 1075, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 85 Acts, ch 168, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 88 Acts, ch 1225, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 94 Acts, ch 1132, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1036, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1053, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1088, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1103, \'a711, 31}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7152.7}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{147.4}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Grounds for refusing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A board may refuse to grant a license to practice a profession to any person otherwise qualified upon any of the grounds for which a license may be revoked or suspended.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72578; S13, \'a72575-a33, -a41, 2578, 2583-c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{2441;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7147.4}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1086, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1088, \'a74}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Grounds for revocation, see }{{\f5\fs12\hyphpar0\qj{\'a7147.55}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0