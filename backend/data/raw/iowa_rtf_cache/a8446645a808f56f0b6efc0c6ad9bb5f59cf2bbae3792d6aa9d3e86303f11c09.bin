\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F8_30F}{\*\bkmkend codeChapter_5F8_30F}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 80F}}}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{RIGHTS OF PEACE OFFICERS AND PUBLIC SAFETY}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keep\keepn\f5\fs18\qc\fi0\ri0\li0\sa0\par}{\pard\plain\keep\f5\fs18\qc\fi0\ri0\li0{ AND EMERGENCY PERSONNEL}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7400.24}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{80F.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Peace officer, public safety, and emergency personnel bill of rights.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fBrady-Giglio list\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a list compiled by a prosecuting agency containing the names and details of officers who have sustained incidents of untruthfulness, criminal convictions, candor issues, or some other type of issue which places the officer\u8217\'3fs credibility into question. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fComplaint\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a formal written allegation signed by the complainant or a signed written statement by an officer receiving an oral complaint stating the complainant\u8217\'3fs allegation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fFormal administrative investigation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an investigative process ordered by a commanding officer of an agency or commander\u8217\'3fs designee during which the questioning of an officer is intended to gather evidence to determine the merit of a complaint which may be the basis for seeking removal, discharge, or suspension, or other disciplinary action against the officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInformal inquiry\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a meeting by supervisory or command personnel with an officer who is the subject of an allegation, for the purpose of resolving the allegation or determining whether a formal administrative investigation should be commenced.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInterview\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the questioning of an officer who is the subject of a complaint pursuant to the formal administrative investigation procedures of the investigating agency, if such a complaint may be the basis for seeking removal, discharge, or suspension, or other disciplinary action against the officer. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInterview\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ does not include questioning as part of any informal inquiry or questioning related to minor infractions of agency rules which will not result in removal, discharge, suspension, or other disciplinary action against the officer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOfficer\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a certified law enforcement officer, fire fighter, emergency medical technician, corrections officer, detention officer, jailer, probation or parole officer, public safety telecommunicator, or any other law enforcement officer certified by the Iowa law enforcement academy and employed by a municipality, county, or state agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fProsecuting agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the attorney general, an assistant attorney general, the county attorney, an assistant county attorney, a special prosecutor, a city attorney, or an assistant city attorney.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fStatement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the statement of the officer who is the subject of an allegation in response to a complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ is not applicable to a criminal investigation of an officer or where other investigations pursuant to state or federal law require different investigatory procedures.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A formal administrative investigation of an officer shall be commenced and completed in a reasonable period of time. An officer shall be immediately notified in writing of the results of the investigation when the investigation is completed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer shall not be compelled to submit to a polygraph examination against the will of the officer except as otherwise provided in }}}{{\f5\fs18\hyphpar0\qj{section 730.4, subsection 3}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer who is the subject of a complaint, shall at a minimum, be provided a written summary of the complaint prior to an interview. If a collective bargaining agreement applies, the complaint or written summary shall be provided pursuant to the procedures established under the collective bargaining agreement. If the complaint alleges domestic abuse, sexual abuse, workplace harassment, or sexual harassment, an officer shall not receive more than a written summary of the complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer being interviewed shall be advised by the interviewer that the officer shall answer the questions and be advised that the answers shall not be used against the officer in any subsequent criminal proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An interview of an officer who is the subject of the complaint shall, at a minimum, be audio recorded.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The officer shall have the right to have the assistance of legal counsel, at the officer\u8217\'3fs expense, during the interview of the officer and during hearings or other disciplinary or administrative proceedings relating to the complaint. In addition, the officer shall have the right, at the officer\u8217\'3fs expense, to have a union representative present during the interview or, if not a member of a union, the officer shall have the right to have a designee present.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The officer\u8217\'3fs legal counsel, union representative, or employee representative shall not be compelled to disclose in any judicial proceeding, nor be subject to any investigation or punitive action for refusing to disclose, any information received from an officer under investigation or from an agent of the officer, so long as the officer or agent of the officer is an uninvolved party and not considered a witness to any incident. The officer\u8217\'3fs legal counsel may coordinate and communicate in confidence with the officer\u8217\'3fs designated union representative or employee representative, and such communications are not subject to discovery in any proceeding.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a formal administrative investigation results in the removal, discharge, or suspension, or other disciplinary action against an officer, copies of any witness statements and the complete investigative agency\u8217\'3fs report shall be timely provided to the officer upon the request of the officer or the officer\u8217\'3fs legal counsel upon request at the completion of the investigation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An interview shall be conducted at any facility of the investigating agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an interview is conducted while an officer is off duty, the officer shall be compensated as provided by law, or as provided in the applicable collective bargaining agreement.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a complaint is determined by the investigating officer to be a violation of }}}{{\f5\fs18\hyphpar0\qj{section 718.6}}}{{\f5\fs18\hyphpar0\qj{, the investigating officer shall be responsible for filing the necessary paperwork with the county attorney\u8217\'3fs office in order for the county attorney to make a determination as to whether to charge the person with a violation of }}}{{\f5\fs18\hyphpar0\qj{section 718.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer shall have the right to bring a cause of action against any person, group of persons, organization, or corporation for damages arising from the filing of a false complaint against the officer or any other violation of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ including but not limited to actual damages, court costs, and reasonable attorney fees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding any other provision of state law to the contrary, an officer shall not be denied the opportunity to be a candidate for any elected office as long as the officer\u8217\'3fs candidacy does not violate the federal Hatch Act, 5 U.S.C. \'a71501 et seq. An officer may be required, as a condition of being a candidate, to take a leave of absence during the campaign. If the officer is subject to }}}{{\f5\fs18\hyphpar0\qj{chapter 341A}}}{{\f5\fs18\hyphpar0\qj{ and is a candidate for county sheriff, the candidate, upon the candidate\u8217\'3fs request, shall automatically be given a leave of absence without pay as provided in }}}{{\f5\fs18\hyphpar0\qj{section 341A.18}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer shall have the right, as any other citizen, to engage in political activity except while on duty as long as the officer\u8217\'3fs political activity does not violate the federal Hatch Act, 5 U.S.C. \'a71501 et seq. An officer shall not be required to engage in political activity by the officer\u8217\'3fs agency, a representative of the officer\u8217\'3fs agency, or any other agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer shall not be discharged, disciplined, or threatened with discharge or discipline in retaliation for exercising the rights of the officer enumerated in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rights enumerated in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ are in addition to any other rights granted pursuant to a collective bargaining agreement or other applicable law.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A municipality, county, or state agency employing an officer shall not publicly release the officer\u8217\'3fs official photograph without the written permission of the officer or without a request to release pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{. An officer\u8217\'3fs personal information including but not limited to the officer\u8217\'3fs home address, personal telephone number, personal electronic mail address, date of birth, social security number, and driver\u8217\'3fs license number shall be confidential and shall be redacted from any record prior to the record\u8217\'3fs release to the public by the employing agency. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ prohibits the release of an officer\u8217\'3fs photograph or unredacted personal information to the officer\u8217\'3fs legal counsel, union representative, or designated employee representative upon the officer\u8217\'3fs request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a formal administrative investigation results in removal, discharge, suspension, or disciplinary action against an officer, and the officer alleges in writing a violation of the provisions of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the municipality, county, or state agency employing the officer shall hold in abeyance for a period of ten days any punitive action taken as a result of the investigation, including a reprimand. An allegation of a violation of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may be raised and given due consideration in any properly authorized grievance or appeal exercised by an officer, including but not limited to a grievance or appeal exercised pursuant to the terms of an applicable collective bargaining agreement and an appeal right exercised under }}}{{\f5\fs18\hyphpar0\qj{section 341A.12}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{400.20}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The employing agency shall keep an officer\u8217\'3fs statement, recordings, or transcripts of any interviews or disciplinary proceedings, and any complaints made against an officer confidential unless otherwise provided by law or with the officer\u8217\'3fs written consent. Nothing in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ prohibits the release of an officer\u8217\'3fs statement, recordings, or transcripts of any interviews or disciplinary proceedings, and any complaints made against an officer to the officer or the officer\u8217\'3fs legal counsel upon the officer\u8217\'3fs request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An agency employing full-time or part-time officers shall provide training to any officer or supervisor who performs or supervises an investigation under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and shall maintain documentation of any training related to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The Iowa law enforcement academy shall adopt minimum training standards not inconsistent with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, including training standards concerning interviewing an officer subject to a complaint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon written request, the employing agency shall provide to the requesting officer or the officer\u8217\'3fs legal counsel a copy of the officer\u8217\'3fs personnel file and training records regardless of whether the officer is subject to a formal administrative investigation at the time of the request.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{23.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer shall not be discharged, disciplined, or threatened with discharge or discipline by a state, county, or municipal law enforcement agency solely due to a prosecuting agency making a determination or disclosure that exculpatory evidence exists concerning the officer.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not prohibit a law enforcement agency from dismissing, suspending, demoting, or taking other disciplinary actions against an officer based on the underlying actions that resulted in the exculpatory evidence being withheld. If a collective bargaining agreement applies, the actions taken by the law enforcement agency shall conform to the rules and procedures adopted by the collective bargaining agreement. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{24.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prosecuting agency that maintains a Brady-Giglio list shall adopt a policy that, at a minimum, includes all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The criteria used by the prosecuting agency to place an officer\u8217\'3fs name on a Brady-Giglio list.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The officer\u8217\'3fs right to receive written notice before the prosecuting agency places the officer\u8217\'3fs name on a Brady-Giglio list, and the officer\u8217\'3fs right to provide input to the prosecuting agency before the prosecuting agency makes a determination of whether the officer\u8217\'3fs name should be placed on a Brady-Giglio list.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The duty of the prosecuting agency to provide notice of the prosecuting agency\u8217\'3fs decision regarding placement of the officer\u8217\'3fs name on a Brady-Giglio list.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The officer\u8217\'3fs right to make a request for reconsideration of the prosecuting agency\u8217\'3fs determination to include the officer\u8217\'3fs name on a Brady-Giglio list and to submit supporting and corroborating documents and evidence in support of the officer\u8217\'3fs request for reconsideration.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The applicable time frame and procedures for notifying the officer of the prosecuting agency\u8217\'3fs final decision on an officer\u8217\'3fs request for reconsideration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Before a prosecuting agency places an officer\u8217\'3fs name on a Brady-Giglio list, the prosecuting agency shall send a written notice by mail or email to the officer\u8217\'3fs current or last known employment address. Upon receipt of the notice, and if the officer\u8217\'3fs contact information is known, the officer\u8217\'3fs current or last known employer shall provide the written notice to the officer. The written notice shall include, at a minimum, all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A notice that the officer\u8217\'3fs name may be placed on a Brady-Giglio list.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The officer\u8217\'3fs right to request documents, records, and any other evidence in the possession of the prosecuting agency relevant to the determination of whether the officer\u8217\'3fs name should be placed on a Brady-Giglio list from the prosecuting agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The officer\u8217\'3fs right to provide input to the prosecuting agency prior to the prosecuting agency\u8217\'3fs determination of whether the officer\u8217\'3fs name should be placed on a Brady-Giglio list.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prosecuting agency\u8217\'3fs procedural requirements for an officer to provide input to the prosecuting agency prior to the prosecuting agency\u8217\'3fs determination of whether the officer\u8217\'3fs name should be placed on a Brady-Giglio list.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the prosecuting agency makes a determination to place the officer\u8217\'3fs name on a Brady-Giglio list, the prosecuting agency shall send a written notice by mail or email to the officer\u8217\'3fs current or last known employment address. Upon receipt of the notice, and if the officer\u8217\'3fs contact information is known, the officer\u8217\'3fs current or last known employer shall provide the written notice to the officer. The written notice shall include, at a minimum, all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The officer\u8217\'3fs right to make a request to reconsider the allegations and the placement of the officer\u8217\'3fs name on a Brady-Giglio list.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The prosecuting agency\u8217\'3fs procedural requirements for submitting a written request for reconsideration of the prosecuting agency\u8217\'3fs determination to place the officer\u8217\'3fs name on a Brady-Giglio list including the method and time frame for submitting the request for reconsideration and any supporting and corroborating documents and evidence from any pertinent sources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A statement that, if the officer intends to make a request for reconsideration, the officer must submit the written request for reconsideration to the prosecuting agency within ten business days after receiving the notice.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If an officer submits a request for reconsideration pursuant to }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ and the officer\u8217\'3fs request for reconsideration is approved by the prosecuting agency on its merits, the officer\u8217\'3fs name shall be removed from the Brady-Giglio list. If the officer\u8217\'3fs request for reconsideration is denied by the prosecuting agency, the officer\u8217\'3fs name shall remain on the Brady-Giglio list. If the officer does not submit a request for reconsideration or fails to comply with the requirements for submitting a request for reconsideration, the officer\u8217\'3fs name shall remain on the Brady-Giglio list.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer whose name was placed on a Brady-Giglio list prior to July 1, 2022, shall have the right to request reconsideration as follows:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prosecuting agency shall notify the officer, within ninety days of July 1, 2022, and provide the officer with the information required under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fc\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Upon receipt of a notification from a prosecuting agency pursuant to subparagraph (1), an officer shall have ten days to request reconsideration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A prosecuting agency shall keep confidential and shall not release to the public an officer\u8217\'3fs personnel file, medical records, or any statement, recording, transcript, or complaint protected under }}}{{\f5\fs18\hyphpar0\qj{subsection 20}}}{{\f5\fs18\hyphpar0\qj{, to the public. Nothing in this paragraph shall be construed to prohibit the release of records to the officer or the officer\u8217\'3fs legal counsel as required under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ upon the request of the officer or the officer\u8217\'3fs legal counsel or as otherwise provided by law or court order.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not limit the duty of a prosecuting agency to produce Brady-Giglio discovery evidence in all cases as required by the Constitution of the United States, the Constitution of the State of Iowa, and the rules of criminal procedure, including after the initial placement of the officer\u8217\'3fs name on a Brady-Giglio list, while the decision or a request for reconsideration is still under consideration.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not limit or restrict a prosecuting agency\u8217\'3fs ability to remove an officer\u8217\'3fs name from a Brady-Giglio list if, upon receipt of additional supporting and corroborating information or a change in factual circumstances at any time, the prosecuting agency determines that the officer\u8217\'3fs name no longer requires placement on a Brady-Giglio list.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This subsection}}}{{\f5\fs18\hyphpar0\qj{ does not create a private cause of action against a prosecuting agency or an employee of a prosecuting agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{25.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An officer shall have the right to petition the district court, appeal, or intervene in an action regarding a prosecuting agency\u8217\'3fs decision to place an officer on a Brady-Giglio list. The district court shall have jurisdiction over the review of the prosecuting agency\u8217\'3fs decision. The district court shall perform an in camera review of the evidence and may hold a closed hearing upon the request of the officer or prosecuting agency, or upon the court\u8217\'3fs own motion. The district court may affirm, modify, or reverse a prosecuting agency\u8217\'3fs decision, and issue orders or provide relief, including removal of the officer from a Brady-Giglio list, as justice may require. Evidence presented to the district court shall be provided under seal and kept confidential unless otherwise provided by law and ordered by the district court.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2007 Acts, ch 160, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 183, \'a717 \u8211\'3f 20}}}{{\f5\fs18\hyphpar0\qj{; 2022 Acts, ch 1142, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 149, \'a71 \u8211\'3f 4}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1058, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1121, \'a71}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7364.3}}}{{\f5\fs12\hyphpar0\qj{, 400.24}}}{{\f5\fs12\hyphpar0\qj{, 400.27}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{80F.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reimbursement of defense costs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a peace officer, as defined in }}}{{\f5\fs18\hyphpar0\qj{section 801.4}}}{{\f5\fs18\hyphpar0\qj{, or a corrections officer is charged with the alleged commission of a public offense, based on acts or omissions within the scope of the officer\u8217\'3fs lawful duty or authority, and the charge is dismissed or the officer is acquitted of the charge, the presiding magistrate or judge shall enter judgment awarding reimbursement to the officer for any costs incurred in defending against the charge, including but not limited to a reasonable attorney fee, if the court finds the existence of any of the following grounds:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The charge was without probable cause.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The charge was filed for malicious purposes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The charge was unwarranted in consideration of all of the circumstances and matters of law attending the alleged offense.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The officer may apply for review of a failure or refusal to rule or an adverse ruling as to the existence of any of the above grounds. The application shall be to a district judge if the officer is seeking review of the act of a magistrate or district associate judge and the application shall be to a different district judge if review is sought of an act of a district judge.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2016 Acts, ch 1049, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{80F.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Standard of proof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The standard of proof for an allegation, administrative charge, complaint, cause of action, claim, or defense under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ shall be a preponderance of the evidence unless a higher standard of proof is required by law.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1121, \'a72}}}\par}}