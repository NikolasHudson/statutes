\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F19_30}{\*\bkmkend codeChapter_5F19_30}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 190}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{ADULTERATION OF FOODS}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\sb140\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\qc{\'a7189.11}}}{{\f5\fs12\qc{, 191.2}}}{{\f5\fs12\qc{, 191.4}}}{{\f5\fs12\qc{, 192.107}}}{{\f5\fs12\qc{, 192.108}}}{{\f5\fs12\qc{, 192.146}}}{{\f5\fs12\qc{, 195.1}}}{{\f5\fs12\qc{, 195.2}}}\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions and standards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For the purpose of this subtitle, except }{{\f5\fs18\hyphpar0\qj{chapters 192}}}{, }{{\f5\fs18\hyphpar0\qj{203}}}{, }{{\f5\fs18\hyphpar0\qj{203C}}}{, }{{\f5\fs18\hyphpar0\qj{203D}}}{, }{{\f5\fs18\hyphpar0\qj{207}}}{, and }{{\f5\fs18\hyphpar0\qj{208}}}{, the following definitions and standards of food are established:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E5_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Butter.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Butter is the clean, nonrancid product made by gathering in any manner the fat of fresh or ripened milk or cream into a mass, with or without the addition of salt, or harmless coloring matter, and containing at least eighty percent, by weight, of milk fat.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Flavoring extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A flavoring extract is a solution in ethyl alcohol or other suitable medium of the sapid and odorous principles derived from an aromatic plant, or parts of the plant, with or without its coloring matter, and conforms in name to the plant used in its preparation.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Almond extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Almond extract is the flavoring extract prepared from oil of bitter almonds, free from hydrocyanic acid, and contains not less than one percent by volume of oil of bitter almonds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Anise extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Anise extract is the flavoring extract prepared from oil of anise, and contains not less than three percent by volume of oil of anise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Cassia extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cassia extract is the flavoring extract prepared from oil of cassia, and contains not less than two percent by volume of oil of cassia.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Celery seed extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Celery seed extract is the flavoring extract prepared from celery seed or the oil of celery seed, or both, and contains not less than three-tenths percent by volume of oil of celery seed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Cinnamon extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cinnamon extract is the flavoring extract prepared from oil of cinnamon, and contains not less than two percent by volume of oil of cinnamon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Clove extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Clove extract is the flavoring extract prepared from oil of cloves, and contains not less than two percent by volume of oil of cloves.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Ginger extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ginger extract is the flavoring extract prepared from ginger, and contains in each one hundred cubic centimeters the alcohol-soluble matters from not less than twenty grams of ginger.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Lemon extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lemon extract is the flavoring extract prepared from oil of lemon, or from lemon peel, or both, and contains not less than five percent by volume of oil of lemon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Terpeneless extract of lemon.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Terpeneless extract of lemon is the flavoring extract prepared by shaking oil of lemon with dilute alcohol, or other suitable medium, or by dissolving terpeneless oil of lemon in such medium, and contains not less than two-tenths percent by weight of citral derived from oil of lemon.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Nutmeg extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Nutmeg extract is the flavoring extract prepared from oil of nutmeg, and contains not less than two percent by volume of oil of nutmeg.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Orange extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Orange extract is the flavoring extract prepared from oil of orange, or from orange peel, or both, and contains not less than five percent by volume of oil of orange.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Terpeneless extract of orange.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Terpeneless extract of orange is the flavoring extract prepared by shaking oil of orange with dilute alcohol, or other suitable medium, or by dissolving terpeneless oil of orange in such medium, and corresponds in flavoring strength to orange extract.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Peppermint extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Peppermint extract is the flavoring extract prepared from oil of peppermint, or from peppermint, or both, and contains not less than three percent by volume of oil of peppermint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E16_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E16_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rose extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rose extract is the flavoring extract prepared from attar of roses, with or without red rose petals, and contains not less than four-tenths percent by volume of attar of roses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E17_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E17_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Savory extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Savory extract is the flavoring extract prepared from oil of savory, or from savory, or both, and contains not less than thirty-five hundredths percent by volume of oil of savory.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E18_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E18_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Spearmint extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Spearmint extract is the flavoring extract prepared from oil of spearmint, or from spearmint, or both, and contains not less than three percent by volume of oil of spearmint.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E19_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E19_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Star anise extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Star anise extract is the flavoring extract prepared from oil of star anise, and contains not less than three percent by volume of oil of star anise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E2_30_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E2_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Sweet basil extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sweet basil extract is the flavoring extract prepared from oil of sweet basil, or from sweet basil, or both, and contains not less than one-tenth percent by volume of oil of sweet basil.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{s.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E21_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E21_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Sweet marjoram extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sweet marjoram extract is the flavoring extract prepared from the oil of marjoram, or from marjoram, or both, and contains not less than one percent by volume of oil of marjoram.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{t.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E22_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E22_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Thyme extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Thyme extract is the flavoring extract prepared from oil of thyme, or from thyme, or both, and contains not less than two-tenths percent by volume of oil of thyme.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{u.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E23_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E23_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Tonka extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tonka extract is the flavoring extract prepared from tonka bean, with or without sugar or glycerin, and contains not less than one-tenth percent by weight of coumarin extracted from the tonka bean, together with a corresponding proportion of the other soluble matters thereof.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{v.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E24_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E24_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Vanilla extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vanilla extract is the flavoring extract prepared from vanilla bean, with or without sugar or glycerin, and contains in one hundred cubic centimeters the soluble matters from not less than ten grams of the vanilla bean, and contains not less than thirty percent by volume of absolute ethyl alcohol, or other suitable medium.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{w.}}}{\*\bkmkstart stylerid1_2E5_2E5_2E25_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E5_2E25_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Wintergreen extract.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Wintergreen extract is the flavoring extract prepared from oil of wintergreen, and contains not less than three percent by volume of oil of wintergreen.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E5_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Food.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Food shall include any article used by humans or domestic animals for food, drink, confectionery, or condiment, or which enters into the composition of the same, whether simple, blended, mixed, or compound. The term }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fblended\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be construed to mean a mixture of like substances.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E5_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Honey.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Honey is the secretion of floral nectar collected by the honeybee and stored in wax combs constructed by the honeybee, or the liquid derived therefrom.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E5_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Lard.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Lard is the fat rendered from fresh, clean, sound, fatty tissues from hogs in good health at the time of slaughter, with or without lard stearin or a hardened lard. The tissues do not include bones, detached skin, head fat, ears, tails, organs, windpipes, large blood vessels, scrap fat, skimmings, settlings, pressings and the like and are reasonably free from muscle tissue and blood.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E5_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Oleomargarine.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Oleo, oleomargarine or margarine includes all substances, mixtures and compounds known as oleo, oleomargarine or margarine, or all substances, mixtures and compounds which have a consistence similar to that of butter and which contain any edible oils or fats other than milk fat if made in imitation or semblance of butter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E5_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Oysters.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Oysters shall not contain ice, nor more than sixteen and two-thirds percent by weight of free liquid.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{\*\bkmkstart stylerid1_2E5_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Rendered pork fat.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Rendered pork fat is the fat other than lard, rendered from clean, sound carcasses, parts of carcasses, or edible organs from hogs in good health at the time of slaughter, except that stomachs, tails, bones from the head and bones from cured or cooked pork are not included. The tissues rendered are usually fresh, but may be cured, cooked, or otherwise prepared and may contain some meat food products. Rendered pork fat may be hardened by the use of lard stearin or hardened lard or rendered pork fat stearin or hardened rendered pork fat or any combination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{\*\bkmkstart stylerid1_2E5_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Renovated butter.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Renovated butter is butter produced by taking original packing stock butter, or other butter, or both, and melting the same so that the milk fat can be extracted, then by mixing the said milk fat with skimmed milk, milk, cream, or some milk product, and rechurning or reworking the said mixture; or butter made by any method which produces a product commonly known as boiled, processed, or renovated butter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{\*\bkmkstart stylerid1_2E5_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Sorghum syrup.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sorghum syrup is liquid food derived by the concentration and heat treatment of the juice of sorghum cane including sorgo and sorghum vulgare. Sorghum syrup must contain not less than seventy-four percent by weight of soluble solids derived solely from juices of sorghum cane.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{\*\bkmkstart stylerid1_2E5_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Substitute for sugar.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Where sugar is given as one of the ingredients in a food product when the definition is established by law or by regulation, the following products may be used as optional ingredients:}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Dextrose (corn sugar) or corn syrup.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{\*\bkmkstart stylerid1_2E5_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Vinegar.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vinegar is the product made by the alcoholic and subsequent fermentation of fruits, grain, vegetables, sugar, or syrups without the addition of any other substance and containing an acidity of not less than four percent by weight of absolute acetic acid. The product may be distilled, but when not distilled it shall not carry in solution any other substance except the extractive matter derived from the substances from which it was made.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E5_2E15_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E15_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Cider or apple vinegar.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Cider or apple vinegar is a similar product made by the same process solely from the juice of apples. Such vinegar which during the course of manufacture has developed in excess of four percent acetic acid may be reduced to said strength.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E5_2E15_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E15_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Corn sugar vinegar.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Corn sugar vinegar is a similar product made by the same process solely from solutions of starch sugar.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E5_2E15_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E15_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Malt vinegar.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Malt vinegar is a similar product made by the same process solely from barley malt or cereals whose starch has been converted by malt.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{\*\bkmkstart stylerid1_2E5_2E15_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E5_2E15_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Sugar vinegar.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sugar vinegar is a similar product made by the same process solely from sucrose.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74042; C97, \'a72516, 2518, 4989 \u8211\'3f 4991; S13, \'a72515-b, -d; SS15, \'a74999-a31, -a31c; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3058;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.1}}}{; }{{\f5\fs18\hyphpar0\qj{81 Acts, ch 72, \'a71}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{88 Acts, ch 1195, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{89 Acts, ch 151, \'a72}}}{; }{{\f5\fs18\hyphpar0\qj{91 Acts, ch 74, \'a72, 3}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1023, \'a741}}}{; }{{\f5\fs18\hyphpar0\qj{2003 Acts, ch 69, \'a745}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7189.14}}}{{\f5\fs12\hyphpar0\qj{, 191.6}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Further definitions, see }{{\f5\fs12\hyphpar0\qj{\'a7189.1}}}{ }\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{\u8220\'3fPerson\u8221\'3f also defined, }{{\f5\fs12\hyphpar0\qj{\'a7191.4}}}{ }\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.2}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Additional standards \u8212\'3f milk and dairy products }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ exceptions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department may establish and publish standards for foods when such standards are not fixed by law. The standards shall conform with standards for foods adopted by federal agencies including but not limited to the United States department of agriculture.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall adopt rules specifying standards for milk and dairy products which are consistent with the \u8220\'3fPasteurized Milk Ordinance\u8221\'3f, as provided in }}}{{\f5\fs18\hyphpar0\qj{chapter 192}}}{{\f5\fs18\hyphpar0\qj{, and applicable federal standards of identity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ does not apply to any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The production, processing, labeling, marketing, or distribution of raw milk by a raw milk producer in compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 195}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The manufacture, labeling, marketing, or distribution of a raw milk product or raw milk dairy product by a raw milk producer in compliance with }}}{{\f5\fs18\hyphpar0\qj{chapter 195}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[S13, \'a74999-a18; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3059;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.2}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 74, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1032, \'a76}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a7121}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 64, \'a727}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 75, \'a78}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.3}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Food adulterations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For the purposes of }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{, any food shall be deemed to be adulterated:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any substance has been mixed or packed with it so as to reduce or injuriously affect its quality.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any substance has been substituted to any extent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any valuable constituent has been removed to any extent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it has been mixed, colored, powdered, coated, or stained whereby damage or inferiority is concealed.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it contains formaldehyde, sulphites or boron compound, or any poisonous or other ingredients injurious to health.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it consists to any extent of a diseased, filthy, or decomposed animal or vegetable substance, whether manufactured or otherwise.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it consists to any extent of an animal that has died otherwise than by slaughter.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it is the product of or obtained from a diseased or infected animal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it has been damaged by freezing.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it does not conform to the standards established by law or by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The provisions of }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraphs }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, shall not apply to the addition of vitamins approved by the United States Pharmacopoeia or the removal of milk fat from milk.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C73, \'a74042; C97, \'a74989, 4990; S13, \'a72515-b, -d; SS15, \'a74999-a31e; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3060;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.3}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 74, \'a75}}}{; }{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 41, \'a7263}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a7190.4}}}{{\f5\fs12\hyphpar0\qj{, 190.9}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.4}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adulterations of dairy products.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to the adulterations enumerated in }{{\f5\fs18\hyphpar0\qj{section 190.3}}}{, milk, cream, or skimmed milk shall be deemed to be adulterated:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it contains visible dirt or is kept or placed at any time in an unclean container.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If obtained from a cow within fifteen days before or five days after calving.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If obtained from a cow stabled in an unhealthful place, or fed upon any substance in a state of putrefaction or of unhealthful nature.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If obtained from a cow which has consumed chemical, medicinal, or radioactive agents capable of being secreted in milk.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If obtained from a cow in a mastitic condition.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a74989, 4990; S13, \'a72515-b, -d; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3061;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.4}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.5}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adulterated milk or milk products.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Any milk or milk product shall further be deemed to be adulterated:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it bears or contains any poisonous or deleterious substance in a quantity which may render it injurious to health.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it bears or contains any added poisonous or deleterious substance for which no safe tolerance has been established by state or federal regulation, or in excess of such tolerance if one has been established.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it consists, in whole or in part, of any substance unfit for human consumption.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If it has been produced, processed, prepared, packed, or held under insanitary conditions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If its container is composed, in whole or in part, of any poisonous or deleterious substance which may render the contents injurious to health.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If any substance has been added thereto or mixed or packed therewith so as to increase its bulk or weight, or reduce its quality or strength, or make it appear better or of greater value than it is.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.5}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.6}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adulteration with fats and oils.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No milk, cream, skimmed milk, buttermilk, condensed or evaporated milk, powdered or desiccated milk, condensed skimmed milk, ice cream, or any fluid derivatives of any of them shall be made from or have added thereto any fat or oil other than milk fat, and no product so made or prepared shall be sold, offered or exposed for sale, or possessed with the intent to sell, under any trade name or other designation of any kind. Provided however, that it shall be lawful to produce and sell a condensed or evaporated milk product in which the milk fat has been replaced by an edible vegetable fat made from soybean oil. Such a product shall be given a distinctive name to distinguish it from natural, condensed, or evaporated milk, which name shall not include the words \u8220\'3fmilk\u8221\'3f or \u8220\'3fmilk products\u8221\'3f or any derivative thereof, and the label under which such a product is sold at retail shall clearly state the vegetable fat content of the product.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3062;}}}{ C46, 50, 54, 58, 62, 66, \'a7190.5; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.6}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.7}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Coloring imitation cheese.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No imitation cheese shall be colored with any substance and no such imitation cheese shall be made by mixing animal fats, vegetable oils, or other substances for the purpose or with the effect of imparting to the mixture the color of yellow cheese.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72518; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3063;}}}{ C46, 50, 54, 58, 62, 66, \'a7190.6; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.7}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.8}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Coloring vinegar.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Vinegar shall not be colored with coloring matter and distilled vinegar shall not have a brown color in imitation of cider vinegar.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a74999-a31; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3064;}}}{ C46, 50, 54, 58, 62, 66, \'a7190.7; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.8}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.9}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adulteration of candies.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to the adulterations enumerated in }{{\f5\fs18\hyphpar0\qj{section 190.3}}}{, candy shall be deemed to be adulterated if it contains terra alba, barytes, talc, paraffin, chrome yellow, or other mineral substance.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[SS15, \'a74999-a31e; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3065;}}}{ C46, 50, 54, 58, 62, 66, \'a7190.8; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.9}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.10}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Sale by false name.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{No person shall offer or expose for sale, sell, or deliver any article of food which is defined in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ under any other name than the one herein specified or offer or expose for sale, sell, or deliver any article of food which is not defined in }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ under any other name than its true name, trade name, or trademark name.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{3066;}}}{ C46, 50, 54, 58, 62, 66, \'a7190.9; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.10}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.11}}}{\*\bkmkstart stylerid1_2E15_2E2_2E2}{\*\bkmkend stylerid1_2E15_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Artificial sweetening }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ labeling.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Where any approved artificial sweetening product such as saccharin or sulfamate is used by any person in the manufacture or sale of any article of food intended for human consumption, the container in which any such food or beverage is sold or offered for sale to the public shall be clearly, legibly and noticeably labeled with the name of the sweetening product used. The portion of the store, display counter, shelving, or other place where such food or beverage is displayed or offered for sale, shall be clearly and plainly identified by an appropriate sign reading:}\par}{}{\pard\plain\keepn\f5\fs18\hyphpar0\qc\fi0\ri0\li0{\f5\fs18\hyphpar0\qc}{ FOR DIETARY PURPOSES.}{\f5\fs18\hyphpar0\qc}\par}{\pard\plain\f5\fs8\hyphpar0\qj\fi0\ri0\li0\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C54, 58, 62, 66, \'a7190.10; C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.11}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2015 Acts, ch 29, \'a730}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.12}}}{\*\bkmkstart stylerid1_2E16_2E2_2E2}{\*\bkmkend stylerid1_2E16_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Standards for frozen desserts.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Frozen desserts and the pasteurized dairy ingredients used in the manufacture thereof, shall comply with the following standards:}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\sb80\ri1084\li1084{{\f5\fs18\hyphpar0\qj{____________________________________________________________}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Milk, cream, and fluid}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Temperature}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Storage at }\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{dairy ingredient}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{45 degrees }\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Fahrenheit.}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Bacterial limit}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{50,000 per }\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{milliliter}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Coliform limit}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{10 per milliliter}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{____________________________________________________________}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Frozen dessert mixes,}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Temperature}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Storage at }\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{frozen desserts (plain)}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{45 degrees }\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Fahrenheit.}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Bacterial limit}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{50,000 per gram}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Coliform limit}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{10 per gram}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{____________________________________________________________}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Dry dairy ingredient}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Extra grade or better as defined by}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{U.}{\f5\fs18\hyphpar0\qj}{S. Standards for grades for the}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{particular product.}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{____________________________________________________________}}}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{Dry powder mix}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Bacterial limit}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{50,000 per gram}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{Coliform limit}{{\f5\fs18\hyphpar0\qj{\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~\~}}}{10 per gram}\par}{\pard\plain\keep\keepn\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa0\par}{\pard\plain\keep\f5\fs18\hyphpar0\qj\fi0\ri1084\li1084\sa80{{\f5\fs18\hyphpar0\qj{____________________________________________________________}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bacteria count and coliform determination shall not exceed these standards in three out of the last five consecutive samples taken by the regulatory agency.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not preclude holding mix at a higher temperature for a short period of time immediately prior to freezing where applicable to the particular manufacturing or processing practices.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not apply to sterilized mix in hermetically sealed containers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The coliform determination for bulky flavored frozen desserts shall not be more than twenty per gram.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.12}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2009 Acts, ch 133, \'a774}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 30, \'a741}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.13}}}{\*\bkmkstart stylerid1_2E17_2E2_2E2}{\*\bkmkend stylerid1_2E17_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Frozen desserts \u8212\'3f edible containers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{Notwithstanding any other labeling provision of the Code, frozen dessert of any kind or flavor may be dispensed and sold at retail in edible containers or as a part of any food preparation intended for consumption without further preparation, including but not limited to the preparations commonly termed milk shakes, malted milks, sundaes, and floats.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a7190.13}}}{]}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.14}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Administration \u8212\'3f milk and dairy products.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department shall administer }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{ consistent with the provisions of the \u8220\'3fGrade \u8216\'3fA\u8217\'3f Pasteurized Milk Ordinance\u8221\'3f, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 192.102}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department, as provided in }}}{{\f5\fs18\hyphpar0\qj{section 192.108}}}{{\f5\fs18\hyphpar0\qj{, may contract with a person qualified by the department to perform inspection of dairy farms, milk plants, receiving stations, or transfer stations to ensure compliance with }}}{{\f5\fs18\hyphpar0\qj{this chapter}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 74, \'a76}}}{; }{{\f5\fs18\hyphpar0\qj{94 Acts, ch 1198, \'a737}}}{; }{{\f5\fs18\hyphpar0\qj{97 Acts, ch 33, \'a74}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{190.15}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Violations \u8212\'3f injunction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department may restrain a person violating }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ or a rule adopted by the department under }{{\f5\fs18\hyphpar0\qj{this chapter}}}{ by petitioning the district court where the violation occurs for injunctive relief. Each day that a violation continues constitutes a separate violation.}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{91 Acts, ch 74, \'a77}}}\par}}