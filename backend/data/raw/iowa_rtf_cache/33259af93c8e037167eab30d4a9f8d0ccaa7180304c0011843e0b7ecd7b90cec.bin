\formshade0\sectd\pgwsxn10479\pghsxn14642\marglsxn1272\margrsxn1272\margtsxn1532\margbsxn809\footery0\headery0\gutter0 \f5\fs18\fi0\ri0\li0\facingp\titlepg{\headerf}{\headerr}{\headerl}{\footerf}{\footerr}{\footerl}{\f5\fs18\fi0\ri0\li0{\*\bkmkstart codeChapter_5F84A}{\*\bkmkend codeChapter_5F84A}}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\fi0\ri0\li0}{\pard\plain\f5\fs18\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\fs18\qc\fi0\sb600\ri0\li0{{\f5\fs24\qc\sb280{CHAPTER 84A}}}\par}{\pard\plain\keep\f5\fs18\qc\fi0\sb4\ri0\li0{\*\bkmkstart stylerid1_2E2_2E2}{DEPARTMENT OF WORKFORCE DEVELOPMENT}{\*\bkmkend stylerid1_2E2_2E2}\par}{\pard\plain\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{\f5\fs12\qc}{For disposition of all unencumbered and unobligated moneys remaining in any account or fund under the control of the former department of aging on July 1, 2023, and that are related to }\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445\cf5{{\f5\fs12\qc\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2023/CH19.pdf" }{\fldrslt \cf5 \f5 \fs12{{2023 Acts, ch 19, \'a72192 \u8211\'3f 2292}}}}}}\par}{\pard\plain\keep\keepn\f5\fs12\qc\fi0\ri1445\li1445{, see }{{\f5\fs12\qc{2023 Acts, ch 19, \'a72232}}}\par}{\pard\plain\keep\keepn\f5\fs2\qc\fi0\ri0\li0\par}{}{\pard\plain\keep\keepn\f5\fs17\fi0\sb280\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.1}}}{\*\bkmkstart stylerid1_2E5_2E2_2E2}{\*\bkmkend stylerid1_2E5_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department of workforce development \u8212\'3f director \u8212\'3f divisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development is created to administer the laws of this state relating to unemployment compensation insurance and job placement and training.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief executive officer of the department of workforce development is the director who shall be appointed by the governor, subject to confirmation by the senate under the confirmation procedures of }}}{{\f5\fs18\hyphpar0\qj{section 2.32}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of workforce development shall serve at the pleasure of the governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governor shall set the salary of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director shall be selected solely on the ability to administer the duties and functions granted to the director and the department and shall devote full time to the duties of the director.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the office of director becomes vacant, the vacancy shall be filled in the same manner as the original appointment was made.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of workforce development shall, subject to the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 84A.1B}}}{{\f5\fs18\hyphpar0\qj{, prepare, administer, and control the budget of the department and its divisions and shall approve the employment of all personnel of the department and its divisions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall include the division of vocational rehabilitation services, and other divisions as appropriate.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7901}}}{; }{{\f5\fs18\hyphpar0\qj{87 Acts, ch 234, \'a7424}}}{; }{{\f5\fs18\hyphpar0\qj{90 Acts, ch 1261, \'a725}}}{; }{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1186, \'a78}}}{; }{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1061, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2002 Acts, ch 1050, \'a79}}}{; }{{\f5\fs18\hyphpar0\qj{2008 Acts, ch 1032, \'a7168}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71440, 2234, 2798, 2802}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 6, \'a72}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a77E.5}}}{{\f5\fs12\hyphpar0\qj{, 96.1A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 1 amended}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.1A}}}{\*\bkmkstart stylerid1_2E6_2E2_2E2}{\*\bkmkend stylerid1_2E6_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Workforce development board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa workforce development board is created, consisting of the following members.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The voting members of the Iowa workforce development board shall include the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One state senator appointed by the president of the senate after consultation with the majority leader of the senate, who shall serve a term as provided in }}}{{\f5\fs18\hyphpar0\qj{section 4A.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One state representative appointed by the speaker of the house of representatives after consultation with the majority leader of the house of representatives, who shall serve a term as provided in }}}{{\f5\fs18\hyphpar0\qj{section 4A.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of workforce development or the director\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department for the blind or the director\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(6)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The administrator of the division of Iowa vocational rehabilitation services of the department of workforce development or the administrator\u8217\'3fs designee.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(7)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The following members who shall be appointed by the governor for staggered terms of four years beginning and ending as provided in }}}{{\f5\fs18\hyphpar0\qj{section 69.19}}}{{\f5\fs18\hyphpar0\qj{, subject to confirmation by the senate:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ten members who shall be representatives of businesses in the state to whom each of the following applies, and at least one of whom shall represent small businesses as defined by the United States small business administration:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall be owners of businesses, chief executives or operating officers of businesses, or other business executives or employers with optimum policymaking or hiring authority, and may, in addition, be members of a local workforce development board described in }}}{{\f5\fs18\hyphpar0\qj{section 84A.4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall represent businesses, including small businesses, or organizations representing businesses described in this subparagraph (a), that provide employment opportunities that, at a minimum, include high quality, work-relevant training and development in in-demand industry sectors or occupations in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall be appointed from among individuals nominated by state business organizations and business trade associations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Four members who shall be representatives of the workforce in the state and who shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At least two representatives of labor organizations who have been nominated by state labor federations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At least one representative of a joint labor-management apprenticeship program in the state who shall be a member of a labor organization or a training director. If such a joint program does not exist in the state, the member shall instead be a representative of an apprenticeship program in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One city chief elected official, as defined in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a73(9)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(d)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One county chief elected official, as defined in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a73(9)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of education or the director\u8217\'3fs designee shall serve as an ex officio, nonvoting member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The terms of members of the board described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (7), shall be staggered so that the terms of no more than nine members expire in a calendar year.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of the board shall represent diverse geographic areas of the state, including urban, rural, and suburban areas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An individual shall not serve as a member of the board in more than one capacity described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A vacancy on the workforce development board shall be filled in the same manner as regular appointments are made for the unexpired portion of the regular term.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governor shall select a chairperson for the workforce development board from among the members who are representatives of business described in }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (7), subparagraph division (a). The workforce development board shall meet at the call of the chairperson or when a majority of voting members of the workforce development board file a written request with the chairperson for a meeting. Written notice of the time and place of each meeting shall be given to each member of the workforce development board. A majority of the voting members constitutes a quorum.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the workforce development board and other employees of the department of workforce development shall be allowed their actual and necessary expenses incurred in the performance of their duties. All expenses shall be paid from appropriations for those purposes and the department of workforce development is subject to the budget requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 8}}}{{\f5\fs18\hyphpar0\qj{. Each member of the workforce development board may also be eligible to receive compensation as provided in }}}{{\f5\fs18\hyphpar0\qj{section 7E.6}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of the workforce development board shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vote on a matter under consideration by the board that concerns the provision of services by the member or by an entity that the member represents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vote on a matter under consideration by the board that would provide direct financial benefit to the member or the immediate family of the member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Engage in any other activity determined by the governor to constitute a conflict of interest as specified in the state workforce development plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The workforce development board may establish standing committees of the board in the bylaws of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{, the workforce development board shall make available to the public, on a regular basis through electronic means and, if applicable, through open meetings in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{, information regarding the activities of the board, including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All documents required by current federal workforce rules and regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information regarding the membership of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bylaws of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 4A.12}}}{{\f5\fs18\hyphpar0\qj{ shall apply only to those members of the board appointed by the governor pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (7).}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1186, \'a79}}}{{\f5\fs18\hyphpar0\qj{; 97 Acts, ch 110, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a721}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1156, \'a725, 58}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 3, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2009 Acts, ch 41, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1118, \'a71 \u8211\'3f 3, 21}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 74, \'a71, 2, 6}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 170, \'a734, 43}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1143, \'a71, 2, 9}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a746, 2235}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1004, \'a714}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1043, \'a737}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1170, \'a7181 \u8211\'3f 186}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 6, \'a73, 4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Confirmation, see }{{\f5\fs12\hyphpar0\qj{\'a72.32}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 6 stricken and rewritten}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 7, paragraph a stricken and rewritten}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.1B}}}{\*\bkmkstart stylerid1_2E7_2E2_2E2}{\*\bkmkend stylerid1_2E7_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Duties of workforce development board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{In addition to the duties outlined in current federal workforce rules and regulations, the workforce development board shall do the following:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Implement the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 73}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assist the governor in the designation of local workforce development areas or regions as outlined in current federal workforce rules and regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Create, and update as necessary, a list of high-demand jobs statewide for purposes of the future ready Iowa registered apprenticeship programs created in }}}{{\f5\fs18\hyphpar0\qj{chapter 84F}}}{{\f5\fs18\hyphpar0\qj{, the summer youth intern pilot program established under }}}{{\f5\fs18\hyphpar0\qj{section 84A.12}}}{{\f5\fs18\hyphpar0\qj{, the Iowa employer innovation program established under }}}{{\f5\fs18\hyphpar0\qj{section 84A.13}}}{{\f5\fs18\hyphpar0\qj{, the future ready Iowa skilled workforce last-dollar scholarship program established under }}}{{\f5\fs18\hyphpar0\qj{section 256.228}}}{{\f5\fs18\hyphpar0\qj{, the future ready Iowa skilled workforce grant program established under }}}{{\f5\fs18\hyphpar0\qj{section 256.229}}}{{\f5\fs18\hyphpar0\qj{, and postsecondary summer classes for high school students as provided under }}}{{\f5\fs18\hyphpar0\qj{section 261E.8, subsection 8}}}{{\f5\fs18\hyphpar0\qj{. In addition to the list created by the workforce development board under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, each community college, in consultation with regional career and technical education planning partnerships, and with the approval of the board of directors of the community college, may identify and maintain a list of not more than five regional high-demand jobs in the community college region, and shall share the lists with the workforce development board. The lists submitted by community colleges under the subsection may be used in that community college region for purposes of programs identified under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. The workforce development board shall have full discretion to select and prioritize statewide high-demand jobs after consulting with business and education stakeholders, as appropriate, and seeking public comment. The workforce development board may add to the list of high-demand jobs as it deems necessary. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhigh-demand job\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a job in the state that the board, or a community college in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, has identified in accordance with }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{. In creating a list under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the following criteria, at a minimum, shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entry-level hourly wage of not less than fourteen dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Educational attainment of a qualifying credential up to a bachelor\u8217\'3fs degree.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One or both of the following criteria:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Projected annual job openings of at least two hundred fifty or more during the next five years. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annual job growth of at least one percent.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Make recommendations to the general assembly and governor regarding workforce development services, programs, and activities, including but not limited to allocation of resources.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Create, in collaboration with the state board of regents, a list of high-wage and high-demand jobs and corresponding academic majors offered by institutions of higher education governed by the state board of regents for purposes of the Iowa workforce grant and incentive program established under }}}{{\f5\fs18\hyphpar0\qj{section 256.230}}}{{\f5\fs18\hyphpar0\qj{. The workforce development board, in collaboration with the state board of regents, shall update the list at least once every two years. In creating a list under }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{, the following criteria, at a minimum, apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An entry-level annual salary of not less than forty thousand dollars.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Educational attainment of a qualifying credential of at least a bachelor\u8217\'3fs degree, or attainment of an initial or intern Iowa teaching license issued under }}}{{\f5\fs18\hyphpar0\qj{chapter 256}}}{{\f5\fs18\hyphpar0\qj{ through a pathway to licensure offered by an institution of higher education under the control of the state board of regents or an accredited private institution as defined in }}}{{\f5\fs18\hyphpar0\qj{section 256.183}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{At least one of any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Projected annual job openings of at least two hundred fifty during the next five years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Projected annual growth in the number of job openings of at least one percent.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1186, \'a710}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a722}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1118, \'a74 \u8211\'3f 6, 21}}}{{\f5\fs18\hyphpar0\qj{; 2017 Acts, ch 74, \'a73, 4, 6}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1067, \'a77, 15}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1143, \'a73, 9}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 135, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1117, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 111, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 6, \'a75 \u8211\'3f 7}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.1}}}{{\f5\fs12\hyphpar0\qj{, 84A.1C}}}{{\f5\fs12\hyphpar0\qj{, 84A.13}}}{{\f5\fs12\hyphpar0\qj{, 84F.1}}}{{\f5\fs12\hyphpar0\qj{, 256.183}}}{{\f5\fs12\hyphpar0\qj{, 256.228}}}{{\f5\fs12\hyphpar0\qj{, 256.229}}}{{\f5\fs12\hyphpar0\qj{, 256.230}}}{{\f5\fs12\hyphpar0\qj{, 261E.8}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended and editorially internally renumbered}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.1C}}}{\*\bkmkstart stylerid1_2E8_2E2_2E2}{\*\bkmkend stylerid1_2E8_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Workforce development corporation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E8_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Nonprofit corporation for receiving and disbursing funds.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa workforce development board may organize a corporation under the provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 504}}}{{\f5\fs18\hyphpar0\qj{ for the purpose of receiving and disbursing funds from public or private sources to be used to further workforce development in this state and to accomplish the mission of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E8_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Incorporators.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The incorporators of the corporation organized pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be the chairperson of the Iowa workforce development board, the director of the department of workforce development, and a member of the Iowa workforce development board selected by the chairperson.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E8_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Board of directors.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The board of directors of the corporation organized pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ shall be the members of the Iowa workforce development board or their successors in office.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E8_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E8_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Accepting grants in aid.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The corporation organized pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ may accept grants of money or property from the federal government or any other source and may upon its own order use its money, property, or other resources for any of the purposes identified in }}}{{\f5\fs18\hyphpar0\qj{section 84A.1B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{99 Acts, ch 21, \'a71}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1049, \'a7191}}}{; }{{\f5\fs18\hyphpar0\qj{2004 Acts, ch 1175, \'a7393}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.2}}}{\*\bkmkstart stylerid1_2E9_2E2_2E2}{\*\bkmkend stylerid1_2E9_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Definitions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{For purposes of }{{\f5\fs18\hyphpar0\qj{this chapter}}}{:}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fChief elected official\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief elected executive officer of a unit of general local government in a local workforce development area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a local workforce development area includes more than one unit of general local government, the individuals designated under the agreement described in }}}{{\f5\fs18\hyphpar0\qj{section 84A.4, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fg\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (2).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommunity-based organization\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a private nonprofit organization, which may include a faith-based organization, that is representative of a community or a significant segment of a community and that has demonstrated expertise and effectiveness in the field of workforce development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCompetitive integrated employment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means work that is performed on a full-time or part-time basis, including self-employment, to which all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All of the following apply to the individual performing the work:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual is compensated at a rate in accordance with all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the individual is not self-employed, all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rate of compensation shall not be less than the higher of the applicable federal or state minimum wage.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The rate of compensation shall not be less than the customary rate paid by the employer for the same or similar work performed by other employees who are not individuals with disabilities, and who are similarly situated in similar occupations by the same employer and who have similar training, experience, and skills.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the individual is self-employed, the rate of compensation yields an income that is comparable to the income received by other individuals who are not individuals with disabilities, and who are self-employed in similar occupations or on similar tasks and who have similar training, experience, and skills.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual is eligible for the level of benefits provided to other employees.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The work is at a location where the individual interacts with other persons who are not individuals with disabilities, not including supervisory personnel or individuals who are providing services to such individual, to the same extent that individuals who are not individuals with disabilities and who are in comparable positions interact with other persons.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The work, as appropriate, presents opportunities for advancement that are similar to those for other employees who are not individuals with disabilities and who have similar positions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCooperative agreement\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an agreement entered into by a state-designated agency or state-designated unit under }}}{{\f5\fs18\hyphpar0\qj{section 101(a)(11)(A) of the federal Rehabilitation Act of 1973}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCore program\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a program authorized under any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Chapters 2 and 3 of subtitle B of Tit. I of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{, relating to youth workforce investment activities and adult and dislocated worker employment and training activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tit. II of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{, relating to adult education and literacy activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Sections 1 through 13 of the federal Wagner-Peyser Act}}}{{\f5\fs18\hyphpar0\qj{, as codified at }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a749 et seq.}}}{{\f5\fs18\hyphpar0\qj{, relating to employment services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Tit. I of the federal Rehabilitation Act of 1973}}}{{\f5\fs18\hyphpar0\qj{, as codified at }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7720 et seq.}}}{{\f5\fs18\hyphpar0\qj{, relating to vocational rehabilitation services, excluding }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7732 and 741}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDemonstrated experience and expertise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for purposes of the state workforce development board, means the expertise had by an individual with documented leadership in developing or implementing workforce development, human resources, training and development, or a core program function. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDemonstrated experience and expertise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may include individuals with experience in education or training of individuals with a barrier to employment.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fDemonstrated experience and expertise\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, for purposes of a local workforce development board, means the expertise had by an individual to whom any of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual is a workplace learning advisor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual contributes to the field of workforce development, human resources, training and development, or a core program function.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The individual has been recognized by the local workforce development board for valuable contributions in education or workforce development-related fields.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEconomic development agency\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ includes a local workforce development planning or zoning commission or board, a community development agency, or another local agency or institution responsible for regulating, promoting, or assisting in local economic development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fEligible youth\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an in-school or out-of-school youth, except as provided in }}}{{\f5\fs18\hyphpar0\qj{subtitles C and D of Tit. I of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{,}}}{{\f5\fs18\hyphpar0\qj{ Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIn-demand industry sector or occupation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An industry sector that has a substantial current or potential impact, including through jobs that lead to economic self-sufficiency and opportunities for advancement, on the state, regional, or local economy, as appropriate, and that contributes to the growth or stability of other supporting businesses, or the growth of other industry sectors.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An occupation that currently has or is projected to have a number of positions, including positions that lead to economic self-sufficiency and opportunities for advancement, in an industry sector so as to have a significant impact on the state, regional, or local economy, as appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The determination of whether an industry sector or occupation is an }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fin-demand industry sector or occupation\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall be made by the state workforce development board or local workforce development board, as appropriate, using state and regional business and labor market projections, including the use of labor market information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndividual with a barrier to employment\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a member of one or more of the following populations:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Displaced homemakers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Low-income individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Indians, Alaska Natives, and Native Hawaiians, as such terms are defined in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7166}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals with disabilities, including youth who are individuals with disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals fifty-five years of age or older.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ex-offenders.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Homeless individuals as defined in }}}{{\f5\fs18\hyphpar0\qj{34 U.S.C. \'a712473}}}{{\f5\fs18\hyphpar0\qj{, or homeless children and youths as defined in }}}{{\f5\fs18\hyphpar0\qj{34 U.S.C. \'a711434a(2)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Youth who are in or have aged out of the foster care system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals who are English language learners, individuals who have low levels of literacy, and individuals facing substantial cultural barriers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Eligible migrant and seasonal farmworkers, as defined in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7167(i)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Individuals within two years of exhausting lifetime eligibility under}}}{{\f5\fs18\hyphpar0\qj{ part A of Tit. IV of the Social Security Act}}}{{\f5\fs18\hyphpar0\qj{, as codified in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a7601 et seq.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Single parents and single pregnant women.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Long-term unemployed individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Such other groups as the governor determines to have a barrier to employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndividual with a disability\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual with a disability as defined in }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a712102}}}{{\f5\fs18\hyphpar0\qj{. }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndividuals with disabilities\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means more than one individual with a disability.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndustry or sector partnership\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a workforce collaborative, convened by or acting in partnership with the state workforce development board or a local workforce development board, that organizes key stakeholders in an industry cluster into a working group that focuses on the shared goals and human resources needs of the industry cluster and that includes, at the appropriate stage of development of the partnership, all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representatives of multiple businesses or other employers in the industry cluster, including small and medium-sized employers when practicable.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One or more representatives of a recognized state labor organization or central labor council, or another labor representative, as appropriate.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{One or more representatives of an institution of higher education with, or another provider of, education or training programs that support the industry cluster.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIndustry or sector partnership\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ may include representatives of state or local government, state or local economic development agencies, the state workforce development board, local workforce development boards, the department of workforce development or another entity providing employment services, state or local agencies, business or trade associations, economic development organizations, nonprofit organizations, community-based organizations, philanthropic organizations, industry associations, and other organizations, as determined to be necessary by the members comprising the industry or sector partnership.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{13.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIn-school youth\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means youth described in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7129(a)(1)(C)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{14.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInstitution of higher education\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{20 U.S.C. \'a71001 and 1002(a)(1)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{15.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOffender\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adult or juvenile who is or has been subject to any stage of the criminal or juvenile justice process, and for whom workforce services may be beneficial.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An adult or juvenile who requires assistance overcoming an artificial barrier to employment resulting from a record of arrest or conviction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{16.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOne-stop center\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a site described in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7121(e)(2)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{17.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOne-stop operator\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means one or more entities designated or certified under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7121(d)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{18.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOptimum policymaking authority\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the authority of an individual who can reasonably be expected to speak affirmatively on behalf of the entity the individual represents and to commit that entity to a chosen course of action.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{19.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fOut-of-school youth\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a youth described in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7129(a)(1)(B)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{20.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fUnit of general local government\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a county or city.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{21.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWorkforce investment activity\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an employment and training activity or a youth workforce investment activity.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{22.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fWorkforce learning advisor\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means an individual employed by an organization who has the knowledge and skills necessary to advise other employees of that organization about the education, skill development, job training, career counseling services, and credentials, including services provided through the workforce development system, required to progress toward career goals of such employees in order to meet employer requirements related to job openings and career advancements that support economic self-sufficiency.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1143, \'a74, 9}}}{{\f5\fs18\hyphpar0\qj{; 2019 Acts, ch 59, \'a734}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1063, \'a741}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 80, \'a732}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.3}}}{\*\bkmkstart stylerid1_2E1_30_2E2_2E2}{\*\bkmkend stylerid1_2E1_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local workforce development plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local workforce development board shall, in partnership with the chief elected official, develop a local workforce development plan in accordance with current federal workforce laws, rules, and regulations. The local workforce development board shall submit the workforce development plan to the department of workforce development for review and approval in the manner and form determined by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{All local workforce plan modifications shall be submitted to the department of workforce development for review and approval in the manner and form determined by the department. Modifications to the local workforce development plan must be developed in accordance with current federal workforce laws, rules, and regulations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development plan and modifications shall include the contents required by current federal workforce laws, rules, and regulations, and such other information as the department of workforce development or the state workforce development board may require.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1143, \'a75, 9}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 6, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.4}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section stricken and rewritten}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.4}}}{\*\bkmkstart stylerid1_2E11_2E2_2E2}{\*\bkmkend stylerid1_2E11_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Local workforce development boards.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{\*\bkmkstart stylerid1_2E11_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Establishment.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department of workforce development shall establish and certify a local workforce development board in each local workforce development area of the state to carry out the functions described in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{ and any functions specified for the local workforce development board under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{, or the provisions establishing a core program for such local workforce development area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{\*\bkmkstart stylerid1_2E11_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Membership.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E11_2E4_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{State criteria.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The governor, in partnership with the state workforce development board, shall establish criteria for use by chief elected officials in the local workforce development areas for appointment of members of the local workforce development boards in such areas in accordance with the requirements of paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E11_2E4_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Composition.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The membership criteria for a local workforce development board shall include, at a minimum, all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A majority of the membership of each local workforce development board shall be representatives of business in the local workforce development area appointed from among individuals nominated by local business organizations and business trade associations, to whom all of the following shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall be owners of businesses, chief executives or operating officers of businesses, or other business executives or employers with optimum policymaking authority or hiring authority.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall represent businesses, including small businesses, that provide employment opportunities that, at a minimum, include high-quality, work-relevant training and development in in-demand industry sectors or occupations in the local workforce development area, or organizations representing such businesses.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Not less than twenty percent of the membership of a local workforce development board shall be representatives of the workforce within the local workforce development area, to whom all of the following shall apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For a local workforce development area in which employees are represented by labor organizations, the members shall include representatives of labor organizations or persons who have been nominated by local labor federations. For a local workforce development area in which employees are not represented by such organizations, the members shall include other representatives of employees;}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall include a representative who is a member of a labor organization or a training director, a representative from a joint labor-management apprenticeship program, or, if no such joint program exists in the area, a representative of an apprenticeship program in the area, if such a program exists.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The membership of a local workforce development board described in subparagraph division (a) may include one or more of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representatives of community-based organizations that have demonstrated experience and expertise in addressing the employment needs of individuals with a barrier to employment, including organizations that serve veterans or that provide or support competitive integrated employment for individuals with disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representatives of organizations that have demonstrated experience and expertise in addressing the employment, training, or education needs of eligible youth, including representatives of organizations that serve out-of-school youth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The membership of a local workforce development board shall include representatives of entities administering education and training activities in the local workforce development area, to whom all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall include a representative of eligible providers administering adult education and literacy activities under }}}{{\f5\fs18\hyphpar0\qj{Tit. II of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall include a representative of institutions of higher education, including community colleges, providing workforce investment activities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If multiple eligible providers are serving the local workforce development area by administering adult education and literacy activities under }}}{{\f5\fs18\hyphpar0\qj{Tit. II of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{, or multiple institutions of higher education serving the local workforce development area by providing workforce investment activities, each representative thereof on the local workforce development board, respectively, shall be appointed from among individuals nominated by local providers representing such providers or institutions, respectively.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The membership may include representatives of local educational agencies and of community-based organizations with demonstrated experience and expertise in addressing the education or training needs of individuals with a barrier to employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The membership of a local workforce development board shall include representatives of governmental and economic and community development entities serving the local workforce development area, to whom all of the following apply:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall include a representative of economic and community development entities.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall include at least one appropriate representative from the state employment service office under the federal }}}{{\f5\fs18\hyphpar0\qj{Wagner-Peyser Act}}}{{\f5\fs18\hyphpar0\qj{, as codified at }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a749 et seq.}}}{{\f5\fs18\hyphpar0\qj{, serving the local workforce development area and nominated by the director of the department of workforce development.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(iii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members shall include at least one appropriate representative of the programs carried out under Tit. I of the federal }}}{{\f5\fs18\hyphpar0\qj{ Rehabilitation Act of 1973}}}{{\f5\fs18\hyphpar0\qj{, as codified at }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7720 et seq.}}}{{\f5\fs18\hyphpar0\qj{, relating to vocational rehabilitation services, excluding }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7732 and 741}}}{{\f5\fs18\hyphpar0\qj{, serving the local workforce development area and nominated by the administrator of the division of vocational rehabilitation services of the department of workforce development or director of the department for the blind, as appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members may include one or more of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representatives of agencies or entities administering programs serving the local workforce development area relating to transportation, housing, and public assistance.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Representatives of philanthropic organizations serving the local workforce development area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(5)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The membership of a local workforce development board may include such other individuals or representatives of entities as the chief elected official in the local workforce development area may determine to be appropriate.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E11_2E4_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Political affiliation.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Section 4A.12}}}{{\f5\fs18\hyphpar0\qj{ shall apply to the total membership of a local workforce development board excluding members required under paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (4), subparagraph division (a), subparagraph subdivisions (ii) and (iii).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{\*\bkmkstart stylerid1_2E11_2E4_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Chairperson.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The members of a local workforce development board shall elect a chairperson from among the representatives of business described in paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, subparagraph (1).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{\*\bkmkstart stylerid1_2E11_2E4_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Standing committees.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local workforce development board may designate and direct the activities of standing committees to provide information and to assist the local workforce development board in carrying out activities under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Such standing committees shall be chaired by a member of the local workforce development board. Such standing committees may include other members of the local workforce development board and shall include other individuals appointed by the local workforce development board who are not members of the local workforce development board and who the local workforce development board determines have appropriate experience and expertise. At a minimum, the local workforce development board may designate each of the following standing committees:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A standing committee to provide information and assist with operational and other issues relating to the one-stop delivery system, which may include as members representatives of the one-stop partners.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A standing committee to provide information and to assist with planning, operational, and other issues relating to the provision of services to youth, which shall include community-based organizations with a demonstrated record of success in serving eligible youth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A standing committee to provide information and to assist with operational and other issues relating to the provision of services to individuals with disabilities, including issues relating to compliance with }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a73248}}}{{\f5\fs18\hyphpar0\qj{, if applicable, and applicable provisions of the }}}{{\f5\fs18\hyphpar0\qj{Americans with Disabilities Act of 1990}}}{{\f5\fs18\hyphpar0\qj{, codified at }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a712101 et seq.}}}{{\f5\fs18\hyphpar0\qj{, regarding providing programmatic and physical access to the services, programs, and activities of the one-stop delivery system, as well as appropriate training for staff on providing supports for or accommodations to, and finding employment opportunities for, individuals with disabilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Additional committees in the discretion of the local workforce development board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{\*\bkmkstart stylerid1_2E11_2E4_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Additional membership requirements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Members of the local workforce development board that represent organizations, agencies, or other entities shall be individuals with optimum policymaking authority within the organizations, agencies, or entities. The members of the board shall represent diverse geographic areas within the local workforce development area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{\*\bkmkstart stylerid1_2E11_2E4_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E4_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Chief elected officials.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief elected official in a local workforce development area may appoint the members of the local workforce development board for such area, in accordance with the state criteria established by the governor in partnership with the state workforce development board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If a local workforce development area includes more than one unit of general local government, the chief elected officials of such units may execute an agreement that specifies the respective roles of the individual chief elected officials relating to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(i)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Appointing the members of the local workforce development board from the individuals nominated or recommended to be such members in accordance with the criteria established in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(ii)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carrying out any other responsibilities assigned to such officials under }}}{{\f5\fs18\hyphpar0\qj{Tit. I of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If, after a reasonable effort, the chief elected officials are unable to reach such an agreement, the governor may appoint the members of the local workforce development board from individuals so nominated or recommended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{\*\bkmkstart stylerid1_2E11_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Certification procedures.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E11_2E5_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Certification.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Once every two years, the department of workforce development shall certify one local workforce development board for each local workforce development area in the state. Such certification shall be based on the extent to which the local workforce development board has ensured that workforce investment activities carried out in the local workforce development area have enabled the local workforce development area to meet the corresponding performance accountability measures and achieve sustained fiscal integrity, as defined in }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a73121(e)(2)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E11_2E5_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Failure to achieve certification.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure of a local workforce development board to achieve certification shall result in appointment and certification of a new local workforce development board for the local workforce development area pursuant to the process described in }}}{{\f5\fs18\hyphpar0\qj{subsection 2}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E11_2E5_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E5_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Decertification.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department of workforce development may decertify a local workforce development board for any of the following reasons at any time after providing notice and an opportunity for comment:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Fraud or abuse.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Failure to carry out the functions specified for the local workforce development board in }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fa\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, the department of workforce development may decertify a local workforce development board if the local workforce development area fails to meet the local performance accountability measures for the local workforce development area in accordance with }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a73141(c)}}}{{\f5\fs18\hyphpar0\qj{ for two consecutive program years.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the department of workforce development decertifies a local workforce development board for a local workforce development area, the department of workforce development may require that a new local workforce development board be appointed and certified for the local workforce development area pursuant to a reorganization plan developed by the governor, in consultation with the chief elected official in the local workforce development area and in accordance with the criteria established under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{Tit. I of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Functions.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consistent with }}}{{\f5\fs18\hyphpar0\qj{section 84A.3}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{section 108 of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{, the functions of a local workforce development board shall include all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Local workforce development plan.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board, in partnership with the chief elected official for the local workforce development area, shall develop and submit a local workforce development plan to the department of workforce development that meets the requirements of }}}{{\f5\fs18\hyphpar0\qj{section 84A.3}}}{{\f5\fs18\hyphpar0\qj{. If the local workforce development area is part of a planning region that includes other local workforce development areas, the local workforce development board shall collaborate with the other local workforce development boards and chief elected officials from such other local workforce development areas in the preparation and submission of a regional plan as described in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7106(c)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Workforce research and regional labor market analysis.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In order to assist in the development and implementation of the local workforce development plan, the local workforce development board shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Carry out analyses of the economic conditions in the region, the needed knowledge and skills for the region, the workforce in the region, and workforce development activities, including education and training, in the region described in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7108(b)(1)(D)}}}{{\f5\fs18\hyphpar0\qj{, and regularly update such information.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Assist the department of workforce development in developing the statewide workforce and labor market information system described in }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a749l-2(e)}}}{{\f5\fs18\hyphpar0\qj{, specifically in the collection, analysis, and utilization of workforce and labor market information for the region.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conduct such other research, data collection, and analysis related to the workforce needs of the regional economy as the board, after receiving input from a wide array of stakeholders, determines to be necessary to carry out its functions.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E5_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E5_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Convening, brokering, and leveraging.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board shall convene local workforce development system stakeholders to assist in the development of the local workforce development plan under }}}{{\f5\fs18\hyphpar0\qj{section 84A.3}}}{{\f5\fs18\hyphpar0\qj{ and in identifying non-federal expertise and resources to leverage support for workforce development activities. The local workforce development board, including its standing committees, may engage such stakeholders in carrying out the functions described in }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E6_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E6_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Employer engagement.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board shall lead efforts to engage with a diverse range of employers and with entities in the region involved to do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Promote business representation on the local workforce development board, particularly representatives with optimal policymaking authority or hiring authority from employers whose employment opportunities reflect existing and emerging employment opportunities in the region.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop effective linkages, including the use of intermediaries, with employers in the region to support employer utilization of the local workforce development system and to support local workforce investment activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ensure that workforce investment activities meet the needs of employers and support economic growth in the region by enhancing communication, coordination, and collaboration among employers, economic development entities, and service providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Develop and implement proven or promising strategies for meeting the employment and skill needs of workers and employers, such as the establishment of industry or sector partnerships. Such strategies shall provide the skilled workforce needed by employers in the region and expand employment and career advancement opportunities for workforce development system participants in in-demand industry sectors or occupations.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Career pathways development.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board, with representatives of secondary and postsecondary education programs, shall lead efforts in the local workforce development area to develop and implement career pathways within the local workforce development area by aligning the employment, training, education, and supportive services that are needed by adults and youth, particularly individuals with a barrier to employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Proven and promising practices.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board shall lead efforts in the local workforce development area to identify and promote proven and promising strategies and initiatives for meeting the needs of employers, workers, and jobseekers, including individuals with a barrier to employment, in the local workforce development system, including providing physical and programmatic accessibility, in accordance with }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a73248}}}{{\f5\fs18\hyphpar0\qj{, if applicable, applicable provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 216}}}{{\f5\fs18\hyphpar0\qj{, and applicable provisions of the }}}{{\f5\fs18\hyphpar0\qj{Americans with Disabilities Act of 1990}}}{{\f5\fs18\hyphpar0\qj{, codified at }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a712101 et seq.}}}{{\f5\fs18\hyphpar0\qj{, to the one-stop delivery system.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Technology.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board shall develop strategies for using technology to maximize the accessibility and effectiveness of the local workforce development system for employers, workers, and jobseekers, by doing all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facilitating connections among the intake and case management information systems of the one-stop partner programs to support a comprehensive workforce development system in the local workforce development area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Facilitating access to services provided through the one-stop delivery system involved, including facilitating the access in remote areas.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Identifying strategies for better meeting the needs of individuals with a barrier to employment, including strategies that augment traditional service delivery and increase access to services and programs of the one-stop delivery system, such as improving digital literacy skills.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Leveraging resources and capacity within the local workforce development system, including resources and capacity for services for individuals with a barrier to employment.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E1_30_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E1_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Program oversight.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board, in partnership with the chief elected official for the local workforce development area, shall do all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Conduct oversight for local youth workforce investment activities authorized under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7129(c)}}}{{\f5\fs18\hyphpar0\qj{, local employment and training activities authorized under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7134(c) and (d)}}}{{\f5\fs18\hyphpar0\qj{, and the one-stop delivery system in the local workforce development area.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Ensure the appropriate use and management of the funds provided under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, Tit. I, subtitle B}}}{{\f5\fs18\hyphpar0\qj{, for the activities and system described in subparagraph division (a).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For workforce development activities, ensure the appropriate use, management, and investment of funds to maximize performance outcomes under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7116}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E11_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E11_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Negotiation of local performance accountability measures.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board, the chief elected official, and the department of workforce development shall negotiate and reach agreement on local performance accountability measures as described in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7116(c)}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E12_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E12_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Selection of one-stop operators.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consistent with the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7121(d)}}}{{\f5\fs18\hyphpar0\qj{, the local workforce development board, with the agreement of the chief elected official for the local workforce development area, shall designate or certify one-stop operators as described in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7121(d)(2)(A)}}}{{\f5\fs18\hyphpar0\qj{. The local workforce development board, with the agreement of the chief elected official for the local workforce development area, may terminate for cause the eligibility of such operators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E13_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E13_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Selection of youth providers.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consistent with the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7123}}}{{\f5\fs18\hyphpar0\qj{, the local workforce development board shall identify eligible providers of youth workforce investment activities in the local workforce development area by awarding grants or contracts on a competitive basis, except as provided in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7123(b)}}}{{\f5\fs18\hyphpar0\qj{, based on the recommendations of the youth standing committee, if such a committee is established for the local workforce development area. When identifying eligible providers, the local workforce development board shall consider community-based and governmental organizations as possible eligible providers. The local workforce development board may terminate for cause the eligibility of such providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E14_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E14_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Identification of eligible providers of training services.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consistent with the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7122}}}{{\f5\fs18\hyphpar0\qj{, the local workforce development board shall identify eligible providers of training services in the local workforce development area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{m.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E15_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E15_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Identification of eligible providers of career services.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{If the one-stop operator does not provide career services described in the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7134(c)(2)}}}{{\f5\fs18\hyphpar0\qj{, in a local workforce development area, the local workforce development board shall identify eligible providers of those career services in the local workforce development area by awarding contracts. When identifying eligible providers, the local workforce development board shall consider community-based and governmental organizations as possible eligible providers.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{n.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E16_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E16_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Consumer choice requirements.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Consistent with the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7122 and 134(c)(2) and (3)}}}{{\f5\fs18\hyphpar0\qj{, the local workforce development board shall work with the state to ensure sufficient numbers and types of providers of career services and training services are serving the local workforce development area and providing the services involved in a manner that maximizes consumer choice, as well as providing opportunities that lead to competitive integrated employment for individuals with a disability. Such providers shall include eligible providers with expertise in assisting individuals with a disability and eligible providers with expertise in assisting adults in need of adult education and literacy activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{o.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E17_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E17_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Coordination with education providers.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board shall coordinate activities with education and training providers in the local workforce development area, including providers of workforce investment activities, providers of adult education and literacy activities under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, Tit. II}}}{{\f5\fs18\hyphpar0\qj{, providers of career and technical education as defined in }}}{{\f5\fs18\hyphpar0\qj{20 U.S.C. \'a72302}}}{{\f5\fs18\hyphpar0\qj{, and local agencies administering plans under }}}{{\f5\fs18\hyphpar0\qj{Tit. I of the federal Rehabilitation Act of 1973}}}{{\f5\fs18\hyphpar0\qj{, as codified at }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7720 et seq.}}}{{\f5\fs18\hyphpar0\qj{, relating to vocational rehabilitation services, excluding }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7732 and 741}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The coordination described in subparagraph (1) shall include, consistent with the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7232}}}{{\f5\fs18\hyphpar0\qj{, all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Reviewing the applications to provide adult education and literacy activities under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, Tit. II}}}{{\f5\fs18\hyphpar0\qj{, for the local workforce development area, submitted under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7232}}}{{\f5\fs18\hyphpar0\qj{, to the eligible agency by eligible providers, to determine whether such applications are consistent with the local workforce development plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Making recommendations to the eligible agency to promote alignment with such plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The coordination described in subparagraph (1) shall also include replicating cooperative agreements in accordance with }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7721(a)(11)(B)}}}{{\f5\fs18\hyphpar0\qj{, and implementing cooperative agreements in accordance with }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7721(a)(11)}}}{{\f5\fs18\hyphpar0\qj{ with the local agencies administering plans under }}}{{\f5\fs18\hyphpar0\qj{Tit. I of the federal Rehabilitation Act of 1973}}}{{\f5\fs18\hyphpar0\qj{, as codified at }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7720 et seq.}}}{{\f5\fs18\hyphpar0\qj{, relating to vocational rehabilitation services, excluding }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a7732 and 741}}}{{\f5\fs18\hyphpar0\qj{, and subject to the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7121(f)}}}{{\f5\fs18\hyphpar0\qj{, with respect to efforts that will enhance the provision of services to individuals with a disability and other individuals, such as cross-training of staff, technical assistance, use and sharing of information, cooperative efforts with employers, and other efforts at cooperation, collaboration, and coordination.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{p.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E18_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E18_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Budget and administration.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{\*\bkmkstart stylerid1_2E11_2E6_2E18_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E18_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Budget.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board shall develop a budget for the activities of the local workforce development board in the local workforce development area, consistent with the local workforce development plan and the duties of the local workforce development board under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, subject to the approval of the chief elected official.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{\*\bkmkstart stylerid1_2E11_2E6_2E18_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E18_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Administration.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The chief elected official in a local workforce development area shall serve as the local grant recipient for, and shall be liable for any misuse of, the grant funds allocated to the local workforce development area under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7128 and 133}}}{{\f5\fs18\hyphpar0\qj{, unless the chief elected official reaches an agreement with the department of workforce development for the department to act as the local grant recipient and bear such liability. In order to assist in administration of the grant funds, the chief elected official or the department, where the department serves as the local grant recipient for a local workforce development area, may designate an entity to serve as a local grant subrecipient for such funds or as a local fiscal agent. Such designation shall not relieve the chief elected official or the department of the liability for any misuse of grant funds. The local grant recipient or designated entity shall disburse the grant funds for workforce investment activities at the direction of the local workforce development board, pursuant to the requirements of the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, Tit. I}}}{{\f5\fs18\hyphpar0\qj{. The local grant recipient or designated entity shall disburse the funds immediately upon receiving such direction from the local workforce development board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board may solicit and accept grants and donations from sources other than federal or state funds.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of carrying out duties under }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, a local workforce development board may incorporate and may operate as an entity described in }}}{{\f5\fs18\hyphpar0\qj{section 501(c)(3) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{ that is exempt from taxation under }}}{{\f5\fs18\hyphpar0\qj{section 501(a) of the Internal Revenue Code}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{q.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E19_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E19_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Accessibility for individuals with disabilities.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board shall annually assess the physical and programmatic accessibility, in accordance with }}}{{\f5\fs18\hyphpar0\qj{29 U.S.C. \'a73248}}}{{\f5\fs18\hyphpar0\qj{, if applicable, applicable provisions of }}}{{\f5\fs18\hyphpar0\qj{chapter 216}}}{{\f5\fs18\hyphpar0\qj{, and applicable provisions of the }}}{{\f5\fs18\hyphpar0\qj{Americans with Disabilities Act of 1990}}}{{\f5\fs18\hyphpar0\qj{, codified at }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a712101 et seq.}}}{{\f5\fs18\hyphpar0\qj{, of all one-stop centers in the local workforce development area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{r.}}}{\*\bkmkstart stylerid1_2E11_2E6_2E2_30_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E6_2E2_30_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Statewide workforce development initiatives.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The local workforce development board shall participate in statewide workforce development initiatives in accordance with guidance and oversight by the state workforce development board or department of workforce development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{\*\bkmkstart stylerid1_2E11_2E7_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E7_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Limitations.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{\*\bkmkstart stylerid1_2E11_2E7_2E2_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E7_2E2_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Training services.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Except as provided in subparagraph (2), a local workforce development board shall not provide training services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development may, pursuant to a request from a local workforce development board, grant a written waiver of the prohibition set forth in subparagraph (1) for a program of training services, if the local workforce development board does all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(a)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Submits to the governor a proposed request for the waiver that includes satisfactory evidence that an insufficient number of eligible providers of such a program of training services is available to meet local demand in the local workforce development area; information demonstrating that the board meets the requirements for an eligible provider of training services under }}}{{\f5\fs18\hyphpar0\qj{section 122 of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{; and information demonstrating that the program of training services prepares participants for an in-demand industry sector or occupation in the local workforce development area.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(b)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Makes the proposed request available to eligible providers of training services and other interested members of the public for a public comment period of not less than thirty days.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(c)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Includes in the final request for the waiver the evidence and information described in subparagraph division (a) and the comments received pursuant to subparagraph division (b).}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A waiver granted to a local workforce development board under subparagraph (2) shall apply for a period that shall not exceed the duration of the local workforce development plan. The waiver may be renewed for additional periods under subsequent local plans, not to exceed the durations of such subsequent plans, pursuant to requests from the local workforce development board, if the board meets the requirements of subparagraph (2) in making the requests.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(4)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development may revoke the waiver during the appropriate period described in subparagraph (3) if the department determines the waiver is no longer needed or that the local workforce development board involved has engaged in a pattern of inappropriate referrals to training services operated by the local workforce development board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{\*\bkmkstart stylerid1_2E11_2E7_2E3_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E7_2E3_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Career services; designation or certification as one-stop operators.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A local workforce development board may provide career services described in }}}{{\f5\fs18\hyphpar0\qj{section 134(c)(2) of the federal Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{, through a one-stop delivery system or be designated or certified as a one-stop operator only with the agreement of the chief elected official in the local workforce development area and the department of workforce development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{\*\bkmkstart stylerid1_2E11_2E7_2E4_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E7_2E4_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Limitation on authority.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ shall not be construed to provide a local workforce development board with the authority to mandate curricula for schools.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{\*\bkmkstart stylerid1_2E11_2E8_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E8_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Conflict of interest.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A member of a local workforce development board, or a member of a standing committee, shall not do any of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vote on a matter under consideration by the board or committee that concerns the provision of services by the member or by an entity that the member represents.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Vote on a matter under consideration by the board or committee that would provide direct financial benefit to the member or the immediate family of the member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Engage in any other activity determined by the governor to constitute a conflict of interest as specified in the state workforce development plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{\*\bkmkstart stylerid1_2E11_2E9_2E1_2E2}{\*\bkmkend stylerid1_2E11_2E9_2E1_2E2}{{\i\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{Public information.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{In addition to meeting the requirements of }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{, local workforce development boards shall make available to the public, on a regular basis through electronic means and, if applicable, through open meetings in accordance with }}}{{\f5\fs18\hyphpar0\qj{chapter 21}}}{{\f5\fs18\hyphpar0\qj{, information regarding the activities of the board, including all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information regarding the local workforce development plan, as required under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128}}}{{\f5\fs18\hyphpar0\qj{, prior to submission of the local workforce development plan or modification of the plan.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Information regarding local workforce development board membership, including the name and affiliation of each member.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bylaws of the board.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Designation and certification of one-stop operators.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Award of grants or contracts to eligible training providers of workforce investment activities, including providers of youth investment activities.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1186, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 21, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 24, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1119, \'a78}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1011, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1118, \'a77 \u8211\'3f 9, 21}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1041, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1143, \'a76, 9}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1172, \'a717}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72236}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1004, \'a715}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.1A}}}{{\f5\fs12\hyphpar0\qj{, 84A.2}}}{{\f5\fs12\hyphpar0\qj{, 84A.5}}}{{\f5\fs12\hyphpar0\qj{, 256.136}}}{{\f5\fs12\hyphpar0\qj{, 260H.2}}}{{\f5\fs12\hyphpar0\qj{, 260H.4}}}{{\f5\fs12\hyphpar0\qj{, 260H.8}}}{{\f5\fs12\hyphpar0\qj{, 260I.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.5}}}{\*\bkmkstart stylerid1_2E12_2E2_2E2}{\*\bkmkend stylerid1_2E12_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Department of workforce development \u8212\'3f primary responsibilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{The department of workforce development, in consultation with the workforce development board and the local workforce development boards, has the primary responsibilities set out in }{{\f5\fs18\hyphpar0\qj{this section}}}{.}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall develop and implement a workforce development system which increases the skills of the Iowa workforce, fosters economic growth and the creation of new high skill and high wage jobs through job placement and training services, increases the competitiveness of Iowa businesses by promoting high performance workplaces, and encourages investment in workers.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The workforce development system shall strive to provide high quality services to its customers including workers, families, and businesses. The department of workforce development shall maintain a common intake, assessment, and customer tracking system and to the extent practical provide one-stop services to customers at workforce development centers and other service access points. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The system shall include an accountability system to measure program performance, identify accomplishments, and evaluate programs to ensure goals and standards are met. The accountability system shall use information obtained from the customer tracking system, the economic development authority, the department of education, and training providers to evaluate the effectiveness of programs. The economic development authority, the department of education, and training providers shall report information concerning the use of any state or federal training or retraining funds to the department of workforce development in a form as required by the department of workforce development. The accountability system shall evaluate all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The impact of services on wages earned by individuals.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The effectiveness of training services providers in raising the skills of the Iowa workforce.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(3)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The impact of placement and training services on Iowa\u8217\'3fs families, communities, and economy.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall make information from the customer tracking and accountability system available to the economic development authority, the department of education, and other appropriate public agencies for the purpose of assisting with the evaluation of programs administered by those departments and agencies and for planning and researching public policies relating to education and economic development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development is responsible for administration of unemployment compensation benefits and collection of employer contributions under }}}{{\f5\fs18\hyphpar0\qj{chapter 96}}}{{\f5\fs18\hyphpar0\qj{, providing for the delivery of free public employment services established pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 96}}}{{\f5\fs18\hyphpar0\qj{, other job placement and training programs established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 84A.6}}}{{\f5\fs18\hyphpar0\qj{, employment agencies under }}}{{\f5\fs18\hyphpar0\qj{chapter 84I}}}{{\f5\fs18\hyphpar0\qj{, and the delivery of services located throughout the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of workforce development shall form a coordinating committee composed of the director of the department of workforce development and other administrators. The committee shall monitor federal compliance issues relating to coordination of functions within the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall administer the following programs:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa employer innovation program established under }}}{{\f5\fs18\hyphpar0\qj{section 84A.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The workforce development centers established under }}}{{\f5\fs18\hyphpar0\qj{chapter 84B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The new jobs training program under }}}{{\f5\fs18\hyphpar0\qj{chapter 260E}}}{{\f5\fs18\hyphpar0\qj{, in consultation with the community colleges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa jobs training act under }}}{{\f5\fs18\hyphpar0\qj{chapter 260F}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The workforce development fund program under }}}{{\f5\fs18\hyphpar0\qj{chapter 84G}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The accelerated career education program under }}}{{\f5\fs18\hyphpar0\qj{chapter 260G}}}{{\f5\fs18\hyphpar0\qj{, in coordination with the community colleges.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{g.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The older American community service employment program under }}}{{\f5\fs18\hyphpar0\qj{section 84A.17}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{h.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The apprenticeship training program under }}}{{\f5\fs18\hyphpar0\qj{chapter 84E}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{i.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The future ready Iowa registered apprenticeship development program under }}}{{\f5\fs18\hyphpar0\qj{section 84F.1}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{j.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The future ready Iowa expanded registered apprenticeship opportunities program under }}}{{\f5\fs18\hyphpar0\qj{section 84F.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{k.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Adult education and literacy programs with community colleges under }}}{{\f5\fs18\hyphpar0\qj{section 84A.19}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{l.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The supplemental nutrition assistance program employment and training program pursuant to }}}{{\f5\fs18\hyphpar0\qj\cf1{7 C.F.R. pt. 273}}}{{\f5\fs18\hyphpar0\qj{, administered jointly with the department of health and human services.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{6.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall work with the economic development authority to incorporate workforce development as a component of community-based economic development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{7.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall provide access to information and documents necessary for employers and payors of income, as defined in }}}{{\f5\fs18\hyphpar0\qj{sections 252D.16}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{252G.1}}}{{\f5\fs18\hyphpar0\qj{, to comply with child support reporting and payment requirements. Access to the information and documents shall be provided at the central location of the department of workforce development and at each workforce development center.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{8.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of workforce development may adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to charge and collect fees for enhanced or value-added services provided by the department of workforce development which are not required by law to be provided by the department and are not generally available from the department of workforce development. Fees shall not be charged to provide a free public labor exchange. Fees established by the director of the department of workforce development shall be based upon the costs of administering the service, with due regard to the anticipated time spent, and travel costs incurred, by personnel performing the service. The collection of fees authorized by }}}{{\f5\fs18\hyphpar0\qj{this subsection}}}{{\f5\fs18\hyphpar0\qj{ shall be treated as appropriated receipts as defined in }}}{{\f5\fs18\hyphpar0\qj{section 8.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{9.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development is responsible for the development and oversight of industry and sector partnerships in the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{10.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development is responsible for the administration of the state list of eligible providers and programs under the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{Pub. L. No. 113-128, \'a7122}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{11.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development is responsible for the review of local workforce development plans under }}}{{\f5\fs18\hyphpar0\qj{section 84A.4}}}{{\f5\fs18\hyphpar0\qj{. The department may approve a local workforce development plan, conditionally approve a local workforce development plan with requests for additional information and recommended changes, or reject a local workforce development plan and request the submission of a new local workforce development plan. The department may create templates, policies, and procedures regarding the submission, format, and contents of local workforce development plans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{12.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall provide oversight, guidance, and technical assistance to local workforce development areas, including but not limited to local workforce development boards, local fiscal agents, youth providers, and eligible providers of career services.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7902}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a784A.2}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{93 Acts, ch 180, \'a753}}}{{\f5\fs18\hyphpar0\qj{; 96 Acts, ch 1186, \'a712}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C97, \'a784A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1061, \'a72, 11}}}{{\f5\fs18\hyphpar0\qj{; 98 Acts, ch 1170, \'a719}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 21, \'a73}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 68, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 99 Acts, ch 130, \'a77}}}{{\f5\fs18\hyphpar0\qj{; 2001 Acts, ch 61, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a711}}}{{\f5\fs18\hyphpar0\qj{; 2007 Acts, ch 211, \'a733}}}{{\f5\fs18\hyphpar0\qj{; 2008 Acts, ch 1191, \'a743}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1118, \'a710, 11, 21}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1026, \'a729}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1067, \'a78, 15}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1143, \'a77, 9}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a71441, 1739, 2192, 2193}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1162, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7113, 114}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1185, \'a7120}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 6, \'a79 \u8211\'3f 12}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784G.5}}}{{\f5\fs12\hyphpar0\qj{, 260G.5}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section amended and editorially internally redesignated and renumbered}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.6}}}{\*\bkmkstart stylerid1_2E13_2E2_2E2}{\*\bkmkend stylerid1_2E13_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Job placement and training programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development, in consultation with the workforce development board and the local workforce development boards, the department of education, and the economic development authority, shall work together to develop policies encouraging coordination between skill development, labor exchange, and economic development activities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of workforce development, in cooperation with the department of health and human services, shall provide job placement and training to persons referred by the department of health and human services under the promoting independence and self-sufficiency through employment job opportunities and basic skills program established pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 239B}}}{{\f5\fs18\hyphpar0\qj{ and the supplemental nutrition assistance program employment and training program pursuant to }}}{{\f5\fs18\hyphpar0\qj\cf1{7 C.F.R. pt. 273}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development, in consultation with the department of health and human services, shall develop and implement departmental recruitment and employment practices that address the needs of former and current participants in the family investment program under }}}{{\f5\fs18\hyphpar0\qj{chapter 239B}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of workforce development, in cooperation with the department of health and human services and the vocational rehabilitation services division of the department of workforce development, shall establish a program to provide job placement and training to persons with disabilities.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a7903}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a784A.3}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1186, \'a713}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C97, \'a784A.6}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{97 Acts, ch 41, \'a732}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1050, \'a712}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 175, \'a758}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2012 Acts, ch 1132, \'a716}}}{{\f5\fs18\hyphpar0\qj{; 2016 Acts, ch 1118, \'a712, 21}}}{{\f5\fs18\hyphpar0\qj{; 2018 Acts, ch 1067, \'a79, 15}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a747}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 111, \'a740}}}{{\f5\fs18\hyphpar0\qj{; 2024 Acts, ch 1182, \'a7115}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 1, \'a72}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 6, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 142, \'a78}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.5}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{See Code editor\u8217\'3fs note on simple harmonization at the beginning of this Code volume}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 4 stricken}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.7}}}{\*\bkmkstart stylerid1_2E14_2E2_2E2}{\*\bkmkend stylerid1_2E14_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa conservation corps.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 6, \'a717}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.8}}}{\*\b