\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.11}}}{\*\bkmkstart stylerid1_2E18_2E2_2E2}{\*\bkmkend stylerid1_2E18_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Nursing workforce data clearinghouse.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2025 Acts, ch 6, \'a717}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.12}}}{\*\bkmkstart stylerid1_2E19_2E2_2E2}{\*\bkmkend stylerid1_2E19_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Summer youth intern pilot program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A summer youth intern pilot program is established within the department of workforce development to provide youths who are at risk of not graduating from high school, who are from low-income households, who are from communities underrepresented in the Iowa workforce, or who otherwise face barriers to success and upward mobility in the labor market, with internship opportunities that allow these youths to explore and prepare for high-demand careers, to gain work experience, and to develop personal attributes necessary to succeed in the workplace.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to an appropriation of funds by the general assembly for this purpose, the department of workforce development shall award grants for summer youth intern pilot projects on a competitive basis as provided in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. The department shall work with employers, nonprofit organizations, and educational institutions to place youth in internships primarily in high-demand career fields.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall annually issue a request for proposals to the public, specifying the expectations and requirements for summer youth intern pilot project grant qualification, including but not limited to the provision of facilities, programming, staffing, and outcomes.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall give full and fair consideration to each proposal submitted under }}}{{\f5\fs18\hyphpar0\qj{subsection 3}}}{{\f5\fs18\hyphpar0\qj{, and shall award grants after considering, at a minimum, the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bidder\u8217\'3fs history and experience in the community.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The capacity to serve a substantial number of youth.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The suitability of the available facilities.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The bidder\u8217\'3fs contacts and partnerships in the community that can be leveraged to maximize opportunity for project participants.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The capacity to provide employability skills, including but not limited to training relating to soft skills, financial literacy, and career development.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1067, \'a710, 15}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.1B}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.13}}}{\*\bkmkstart stylerid1_2E2_30_2E2_2E2}{\*\bkmkend stylerid1_2E2_30_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa employer innovation program }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fhigh-demand job\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a job identified by the workforce development board or a community college pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 84A.1B, subsection 3}}}{{\f5\fs18\hyphpar0\qj{, as a high-demand job.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Subject to an appropriation of funds by the general assembly for this purpose, the Iowa employer innovation program is established in the department of workforce development. The department shall administer the program in consultation with the workforce development board. The purpose of the Iowa employer innovation program is to expand opportunities for credit and noncredit education and training leading to high-demand jobs for the residents of Iowa and to encourage Iowa employers, community leaders, and others to provide leadership and support for regional workforce talent pools throughout the state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing a program application and award process to match employer moneys and the criteria for the allocation of moneys in the fund established pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{. An employer, employer consortium, community organization, or other entity seeking matching moneys shall submit an application and a proposal to the department. In awarding matching moneys, the department shall take into account various factors, including but not limited to all of the following:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The range of high-demand jobs, innovative measures, and geographic fairness and equity included in the proposal.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the proposal increases the number of eligible students receiving financial assistance under the future ready Iowa skilled workforce last-dollar scholarship or future ready Iowa skilled workforce grant programs established under sections }}}{{\f5\fs18\hyphpar0\qj{256.228}}}{{\f5\fs18\hyphpar0\qj{ and }}}{{\f5\fs18\hyphpar0\qj{256.229}}}{{\f5\fs18\hyphpar0\qj{; or increases the donation of books, transportation, child care, and other wrap-around support to assist eligible students receiving financial assistance under }}}{{\f5\fs18\hyphpar0\qj{section 256.228}}}{{\f5\fs18\hyphpar0\qj{ or }}}{{\f5\fs18\hyphpar0\qj{256.229}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the proposal includes performance-based bonuses paid when high school students earn national industry-recognized credentials aligned with high-demand jobs that meet regional workforce needs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{d.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the proposal expands internships leading to high-demand jobs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{e.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the proposal offers innovative ways of expanding opportunities for credit and noncredit education and training leading to high-demand jobs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{f.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Whether the proposal addresses areas of workforce need throughout the region.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa employer innovation fund is created in the state treasury as a separate fund under the control of the department of workforce development, in consultation with the workforce development board. The fund shall consist of any moneys appropriated by the general assembly and any other moneys available to and obtained or accepted by the department from the federal government. A portion of the moneys deposited in the fund, in an amount to be determined annually by the department of workforce development in consultation with the workforce development board, shall be transferred annually to the Iowa child care challenge fund created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 84A.13A}}}{{\f5\fs18\hyphpar0\qj{. The assets of the Iowa employer innovation fund shall be used by the department in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. All moneys deposited or paid into the fund are appropriated and made available to the board to be used in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, any balance in the fund on June 30 of each fiscal year shall not revert to the general fund of the state, but shall be available for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ and for transfer in accordance with }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{ in subsequent fiscal years.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1067, \'a711, 15}}}{{\f5\fs18\hyphpar0\qj{; 2020 Acts, ch 1117, \'a75}}}{{\f5\fs18\hyphpar0\qj{; 2021 Acts, ch 76, \'a716}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.1B}}}{{\f5\fs12\hyphpar0\qj{, 84A.5}}}{{\f5\fs12\hyphpar0\qj{, 84A.13A}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Section not amended; internal reference change applied}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.13A}}}{\*\bkmkstart stylerid1_2E21_2E2_2E2}{\*\bkmkend stylerid1_2E21_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa child care challenge program }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fconsortium\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a consortium of two or more employers or businesses, at least one of which must be a private employer.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The Iowa child care challenge program is established in the department of workforce development. The department shall administer the program in consultation with the workforce development board. The purpose of the Iowa child care challenge program is to encourage and enable businesses, nonprofit organizations, and consortiums to establish local child care facilities and increase the availability of quality, affordable child care for working Iowans.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall adopt rules under }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ establishing a program application and award process to match business, nonprofit organization, or consortium moneys and the criteria for the allocation of moneys in the fund established pursuant to }}}{{\f5\fs18\hyphpar0\qj{subsection 4}}}{{\f5\fs18\hyphpar0\qj{. A business, nonprofit organization, or consortium seeking matching moneys shall submit an application and a proposal for the new construction of a child care facility, rehabilitation of an existing structure as a child care facility, or the retrofitting and repurposing of an existing structure for use as a child care facility to the department. Proposals shall include a financial statement and a description of funds to be provided by the business, nonprofit organization, or consortium, including in-kind donations, and a plan for sustainability. Match amount awards made by the department that are unclaimed or unused as of June 1 of the fiscal year shall be canceled by the department.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa child care challenge fund is created in the state treasury as a separate fund under the control of the department of workforce development, in consultation with the workforce development board. The fund shall consist of appropriations made to the fund, any other moneys available to and obtained or accepted by the department from the federal government or private sources for placement in the fund, and transfers of interest, earnings, and moneys from other funds as provided by law. The assets of the fund shall be used by the department only for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. All moneys deposited, transferred to, or paid into the fund are appropriated and made available to the department to be used for purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{. Any unclaimed moneys in the fund by June 1 annually shall be transferred to the Iowa employer innovation fund, created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 84A.13}}}{{\f5\fs18\hyphpar0\qj{, to be used only for purposes of the Iowa employer innovation program established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 84A.13}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys deposited after May 1 annually in the Iowa child care challenge fund that remain unencumbered or unobligated at the close of a fiscal year shall not revert to the general fund of the state but shall be transferred to the Iowa employer innovation fund created pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 84A.13}}}{{\f5\fs18\hyphpar0\qj{ to be used for purposes of the Iowa employer innovation program established pursuant to }}}{{\f5\fs18\hyphpar0\qj{section 84A.13}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2020 Acts, ch 1117, \'a76}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.13}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.14}}}{\*\bkmkstart stylerid1_2E22_2E2_2E2}{\*\bkmkend stylerid1_2E22_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Criminal history checks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{A current or prospective contractor, vendor, employee, or any other individual performing work for the department of workforce development who will have access to federal tax information shall be subject to a national criminal history check through the federal bureau of investigation at least once every ten years if such a check is required pursuant to guidance from the federal internal revenue service. The department of workforce development shall request the national criminal history check and shall provide the individual\u8217\'3fs fingerprints to the department of public safety for submission through the state criminal history repository to the federal bureau of investigation. The individual shall authorize release of the results of the national criminal history check to the department of workforce development. The department of workforce development shall pay the actual cost of the fingerprinting and national criminal history check, if any. The results of a criminal history check conducted pursuant to }{{\f5\fs18\hyphpar0\qj{this section}}}{ shall not be considered a public record under }{{\f5\fs18\hyphpar0\qj{chapter 22}}}{.}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2018 Acts, ch 1080, \'a71}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.15}}}{\*\bkmkstart stylerid1_2E23_2E2_2E2}{\*\bkmkend stylerid1_2E23_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Regional industry sector partnerships.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1162, \'a79}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.16}}}{\*\bkmkstart stylerid1_2E24_2E2_2E2}{\*\bkmkend stylerid1_2E24_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Statewide work-based learning intermediary network }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ fund }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ steering committee }}}{{\f5\b\fs18\hyphpar0\qj{\u8212\'3f}}}{{\f5\b\fs18\hyphpar0\qj{ regional networks.}}}{\f5\b\fs2\hyphpar0\qj}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Repealed by }}}{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1162, \'a79}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\sb0\ri0\li0\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.17}}}{\*\bkmkstart stylerid1_2E25_2E2_2E2}{\*\bkmkend stylerid1_2E25_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Older American community service employment program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall direct and administer the older American community service employment program as authorized by the federal }}}{{\f5\fs18\hyphpar0\qj{Older Americans Act of 1965}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\f5\fs18\hyphpar0\qj{42 U.S.C. \'a73001 et seq.}}}{{\f5\fs18\hyphpar0\qj{, as amended.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of the program is to foster individual economic self-sufficiency and to increase the number of participants placed in unsubsidized employment in the public and private sectors while maintaining the community service focus of the program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Funds appropriated to the department of workforce development from the United States department of labor shall be distributed to subgrantees in accordance with federal requirements.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall require such uniform reporting and financial accounting by subgrantees as may be necessary to fulfill the purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{5.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The older American community service employment program shall be coordinated with the federal }}}{{\f5\fs18\hyphpar0\qj{Workforce Innovation and Opportunity Act}}}{{\f5\fs18\hyphpar0\qj{ administered by the department of workforce development.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{86 Acts, ch 1245, \'a71019}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C87, \'a7249D.51}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C93, \'a7231.51}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{96 Acts, ch 1186, \'a723}}}{{\f5\fs18\hyphpar0\qj{; 2002 Acts, ch 1058, \'a71}}}{{\f5\fs18\hyphpar0\qj{; 2005 Acts, ch 45, \'a713}}}{{\f5\fs18\hyphpar0\qj{; 2011 Acts, ch 118, \'a785, 89}}}{{\f5\fs18\hyphpar0\qj{; 2013 Acts, ch 18, \'a726}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72229, 2231}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a784A.17}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.18}}}{\*\bkmkstart stylerid1_2E26_2E2_2E2}{\*\bkmkend stylerid1_2E26_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Reports and records \u8212\'3f penalties.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An owner, operator, or manager of every factory, mill, workshop, mine, store, railway, business house, public or private work, or any other establishment where labor is employed, shall submit to the department of workforce development reports in the form and manner prescribed by the director of the department of workforce development by rule, for the purpose of compiling labor statistics. The owner, operator, or business manager shall submit the reports within sixty days from receipt of notice, and shall certify under oath the accuracy of the reports. For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3ffactory\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmill\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fworkshop\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fmine\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fstore\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3frailway\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fbusiness house\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{, and }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fpublic or private work\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ shall mean any factory, mill, workshop, mine, store, railway, business house, or public or private work where wage earners are employed for compensation.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{chapter 22}}}{{\f5\fs18\hyphpar0\qj{, records submitted under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ that contain identifiable financial institution or credit card account numbers shall be kept confidential.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any officer or employee of the department of workforce development who makes unlawful use of a report submitted under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be guilty of a serious misdemeanor.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any person who has access to a report submitted under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ who makes unlawful use of the report shall be guilty of a serious misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Any owner, operator, or manager of a factory, mill, workshop, mine, store, railway, business house, or public or private work who fails to submit the report required under }}}{{\f5\fs18\hyphpar0\qj{subsection 1}}}{{\f5\fs18\hyphpar0\qj{ shall be guilty of a simple misdemeanor.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The director of the department of workforce development shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{[C97, \'a72474; S13, \'a72474; C24, 27, 31, 35, 39, \'a7}{{\f5\b\fs18\hyphpar0\qj{1521;}}}{ C46, 50, 54, 58, 62, 66, 71, 73, 75, 77, 79, }{{\f5\fs18\hyphpar0\qj{81, \'a791.12}}}{]}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{98 Acts, ch 1105, \'a74}}}{{\f5\fs18\hyphpar0\qj{; 2023 Acts, ch 19, \'a72289, 2290}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{C2024, \'a784A.18}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.19}}}{\*\bkmkstart stylerid1_2E27_2E2_2E2}{\*\bkmkend stylerid1_2E27_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Adult education and literacy programs.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{For purposes of }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fAdult education and literacy programs\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means adult basic education, adult education leading to a high school equivalency diploma under }}}{{\f5\fs18\hyphpar0\qj{chapter 259A}}}{{\f5\fs18\hyphpar0\qj{, English as a second language instruction, and workplace and family literacy instruction.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fCommunity colleges\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 260C.2}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development and community colleges shall jointly implement adult education and literacy programs to assist adults and youths sixteen years of age and older who are not in school in obtaining the knowledge and skills necessary for further education, work, and community involvement. }}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development, in consultation with community colleges, shall prescribe standards for adult education and literacy programs including but not limited to contextualized and integrated instruction, assessments, instructor qualification and professional development, data collection and reporting, and performance benchmarks.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development, in consultation with community colleges, shall adopt rules pursuant to }}}{{\f5\fs18\hyphpar0\qj{chapter 17A}}}{{\f5\fs18\hyphpar0\qj{ to administer }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2023 Acts, ch 19, \'a72291}}}\par}{}{\pard\plain\keep\keepn\f5\fs12\hyphpar0\qj\fi180\ri0\li0\cbpat2{Referred to in }{{\f5\fs12\hyphpar0\qj{\'a784A.5}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0{\f5\fs18\hyphpar0\qj\chcbpat2}\par}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.20}}}{\*\bkmkstart stylerid1_2E28_2E2_2E2}{\*\bkmkend stylerid1_2E28_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Workforce opportunity fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{A workforce opportunity fund is created in the state treasury as a separate fund under the control of the department of workforce development. The fund shall consist of appropriations made to the fund, any other moneys available to and obtained or accepted by the department from the federal government or private sources for placement in the fund, and transfers of interest, earnings, and moneys from other funds as provided by law. Moneys in the fund are appropriated to the department of workforce development for the purposes of training and infrastructure related to the growth and maintenance of the state\u8217\'3fs workforce programs. Permitted uses of the moneys in the fund include but are not limited to equipment, instructional materials, stipends, and other training-related costs. The department of workforce development shall only distribute moneys in the fund to workforce programs located within this state.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Annually, on or before December 31 of each year, the department of workforce development shall submit a report to the general assembly and the legislative services agency that contains a list of all expenditures from the workforce opportunity fund made in the previous fiscal year. The legislative services agency shall provide a copy of the report to the co-chairpersons and ranking members of the joint appropriations subcommittee on economic development.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{, moneys in the workforce opportunity fund that remain unencumbered or unobligated at the close of the fiscal year shall not revert but shall remain available for expenditure for the purposes designated for subsequent fiscal years. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7, subsection 2}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{4.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{This section}}}{{\f5\fs18\hyphpar0\qj{ is repealed July 1, 2029.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1162, \'a719}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\sb219\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0\cbpat2\par}{}{\pard\plain\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{\~\~}}}\par}{\pard\plain\f5\b0\fs24\hyphpar0\qj\fi0\ri0\li0{ }{\f5\b0\fs24\hyphpar0\qj}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}{{\f5\b0\fs24\hyphpar0\qj{\~\~}}}\par}{\pard\plain\keepn\f5\b\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\b\fs18\hyphpar0\qj{84A.21}}}{\*\bkmkstart stylerid1_2E29_2E2_2E2}{\*\bkmkend stylerid1_2E29_2E2_2E2}{{\f5\b\fs18\hyphpar0\qj{\~\~}}}{{\f5\b\fs18\hyphpar0\qj{Iowa student internship program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{1.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{As used in }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, unless the context otherwise requires:}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInnovative business\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means the same as defined in }}}{{\f5\fs18\hyphpar0\qj{section 15E.52}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fInternship\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means temporary employment of a student that focuses on providing the student with work experience in the student\u8217\'3fs field of study.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fIowa student\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{ means a student of an Iowa community college, private college, or institution of higher learning under the control of the state board of regents, or a student who graduated from high school in Iowa but now attends an institution of higher learning outside the state of Iowa.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{2.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The department of workforce development shall establish and administer an internship program with two components for Iowa students. To the extent permitted by }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, the department of workforce development shall administer the two components in as similar a manner as possible.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of the first component of the program is to link Iowa students to small and medium-sized Iowa firms through internship opportunities. An Iowa employer may receive financial assistance on a matching basis for a portion of the wages paid to an intern. If providing financial assistance, the department of workforce development shall provide the assistance on a reimbursement basis such that for every two dollars of wages earned by the student, one dollar paid by the employer is matched by one dollar from the department of workforce development. The amount of financial assistance shall not exceed three thousand one hundred dollars for any single internship, or nine thousand three hundred dollars for any single employer. In order to be eligible to receive financial assistance, the employer must have five hundred or fewer employees and must be an innovative business. The department of workforce development shall encourage youth who reside in economically distressed areas, youth adjudicated to have committed a delinquent act, and youth transitioning out of foster care to participate in the first component of the internship program.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(1)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The purpose of the second component of the program is to assist in placing Iowa students studying in the fields of science, technology, engineering, and mathematics into internships that lead to permanent positions with Iowa employers. The department of workforce development shall collaborate with eligible employers, including but not limited to innovative businesses, to ensure that the interns hired are studying in such fields. An Iowa employer may receive financial assistance on a matching basis for a portion of the wages paid to an intern. If providing financial assistance, the department of workforce development shall provide the assistance on a reimbursement basis such that for every two dollars of wages earned by the student, one dollar paid by the employer is matched by one dollar from the department of workforce development. The amount of financial assistance shall not exceed five thousand dollars per internship. The department of workforce development may adopt rules to administer this component. In adopting rules to administer this component, the department of workforce development shall adopt rules as similar as possible to those adopted pursuant to paragraph }}}{{\i\f5\fs18\hyphpar0\qj{\u8220\'3fb\u8221\'3f}}}{{\f5\fs18\hyphpar0\qj{.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{(2)}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{The requirement to administer this component of the internship program is contingent upon the provision of funding for such purposes by the general assembly.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{3.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{a.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{An Iowa student internship fund is created in the state treasury under the control of the department of workforce development. The fund shall consist of moneys appropriated to the department of workforce development and any other moneys available to or obtained or accepted by the department of workforce development for placement in the fund.}}}\par}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{b.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Payments of interest, repayments of moneys loaned pursuant to }}}{{\f5\fs18\hyphpar0\qj{this section}}}{{\f5\fs18\hyphpar0\qj{, and recaptures of financial assistance shall be credited to the fund. Moneys in the fund are not subject to }}}{{\f5\fs18\hyphpar0\qj{section 8.33}}}{{\f5\fs18\hyphpar0\qj{. Notwithstanding }}}{{\f5\fs18\hyphpar0\qj{section 12C.7}}}{{\f5\fs18\hyphpar0\qj{, interest or earnings on moneys in the fund shall be credited to the fund.}}}\par}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi0\ri0\li0{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\i\f5\fs18\hyphpar0\qj{c.}}}{{\f5\fs18\hyphpar0\qj{\~\~}}}{{\f5\fs18\hyphpar0\qj{Moneys in the fund are appropriated to the department of workforce development and, with the approval of the Iowa workforce development board, shall be used to increase the availability of skilled workers in innovative businesses, by providing Iowa student internship opportunities. Such moneys shall not be used for the support of retail businesses, health care businesses, or other businesses requiring a professional license.}}}\par}{}{}{\pard\plain\f5\fs18\hyphpar0\qj\fi180\ri0\li0{{\f5\fs18\hyphpar0\qj{2024 Acts, ch 1182, \'a7139}}}{{\f5\fs18\hyphpar0\qj{; 2025 Acts, ch 30, \'a714}}}\par}{}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Any internship or financial assistance awarded under }{{\f5\fs12\hyphpar0\qj{section 15.411, Code 2024}}}{, prior to July 1, 2024, is valid and shall continue as provided in the terms of the internship or financial assistance under this section; }\par}{\pard\plain\f5\fs12\hyphpar0\qj\fi0\ri0\li0\cf5{{\f5\fs12\hyphpar0\qj\cf5{\field{\*\fldinst HYPERLINK "https://www.legis.iowa.gov/docs/acts/2024/CH1182.pdf" }{\fldrslt \cf5 \f5 \fs12{{2024 Acts, ch 1182, \'a7140}}}}}}\par}{}{\pard\plain\f5\fs12\hyphpar0\qj\fi180\ri0\li0{\f5\fs12\hyphpar0\qj}{Subsection 3, paragraph a amended}\par}}